[49m[38;5;10m+      1[0m:[38;5;10m[49m # Recipe 8.8: Python Implementation Example
[0m[49m[38;5;10m+      2[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      3[0m:[38;5;10m[49m > **Heads up:** This is a deliberately simple, illustrative implementation of the pseudocode walkthrough from Recipe 8.8. It shows one way you could translate the clinical assertion classification concepts into working Python code. It is not production-ready. The rule-based layer is intentionally minimal, the "ML model" is simulated with a SageMaker endpoint call pattern, and the synthetic data is designed to exercise the core logic paths. Think of it as a sketch: useful for understanding the shape of the solution, not something you'd deploy against a live clinical NLP pipeline on Monday morning. Consider it a starting point, not a destination.
[0m[49m[38;5;10m+      4[0m:[38;5;10m[49m >
[0m[49m[38;5;10m+      5[0m:[38;5;10m[49m > This recipe uses two AWS services in combination: Amazon Comprehend Medical for entity extraction (with its built-in trait detection) and Amazon SageMaker for custom assertion classification when the built-in traits are too coarse. The hybrid approach (rules first, ML model for ambiguous cases) is the pattern you'll see in production systems.
[0m[49m[38;5;10m+      6[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      7[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+      8[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      9[0m:[38;5;10m[49m ## Setup
[0m[49m[38;5;10m+     10[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     11[0m:[38;5;10m[49m You'll need the AWS SDK for Python installed:
[0m[49m[38;5;10m+     12[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     13[0m:[38;5;10m[49m ```bash
[0m[49m[38;5;10m+     14[0m:[38;5;10m[49m pip install boto3
[0m[49m[38;5;10m+     15[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     16[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     17[0m:[38;5;10m[49m Your environment needs credentials configured (via environment variables, an instance profile, or `~/.aws/credentials`). The IAM role or user needs:
[0m[49m[38;5;10m+     18[0m:[38;5;10m[49m - `comprehendmedical:DetectEntitiesV2`
[0m[49m[38;5;10m+     19[0m:[38;5;10m[49m - `sagemaker:InvokeEndpoint`
[0m[49m[38;5;10m+     20[0m:[38;5;10m[49m - `s3:GetObject`
[0m[49m[38;5;10m+     21[0m:[38;5;10m[49m - `s3:PutObject`
[0m[49m[38;5;10m+     22[0m:[38;5;10m[49m - `dynamodb:PutItem`
[0m[49m[38;5;10m+     23[0m:[38;5;10m[49m - `dynamodb:Query`
[0m[49m[38;5;10m+     24[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     25[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     26[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     27[0m:[38;5;10m[49m ## Configuration and Constants
[0m[49m[38;5;10m+     28[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     29[0m:[38;5;10m[49m Everything that's really configuration rather than logic lives here. The assertion rules, section mappings, and thresholds are the pieces that need tuning to your institution's documentation patterns. Treat them as living documents.
[0m[49m[38;5;10m+     30[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     31[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     32[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+     33[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+     34[0m:[38;5;10m[49m import re
[0m[49m[38;5;10m+     35[0m:[38;5;10m[49m import datetime
[0m[49m[38;5;10m+     36[0m:[38;5;10m[49m from datetime import timezone
[0m[49m[38;5;10m+     37[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+     38[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     39[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+     40[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+     41[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     42[0m:[38;5;10m[49m # Structured logging. Never log PHI field values (entity text, patient IDs).
[0m[49m[38;5;10m+     43[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+     44[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+     45[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     46[0m:[38;5;10m[49m # Retry configuration for AWS API calls under load.
[0m[49m[38;5;10m+     47[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+     48[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     49[0m:[38;5;10m[49m # Module-level clients reused across Lambda invocations.
[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m comprehend_medical_client = boto3.client("comprehendmedical", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m sagemaker_runtime_client = boto3.client("sagemaker-runtime", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb")
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m # ---------- Assertion Configuration ----------
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m # The seven assertion classes from the i2b2/VA 2010 taxonomy.
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m ASSERTION_CLASSES = [
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m     "present", "absent", "possible", "conditional",
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m     "historical", "family", "hypothetical"
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m # Confidence threshold: entities classified below this go to human review.
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m CONFIDENCE_THRESHOLD = 0.85
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m # Context window: characters before and after the entity to extract.
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m # ~2-3 sentences of surrounding text. Enough for negation cues without noise.
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m CONTEXT_WINDOW_CHARS = 300
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m # Entity extraction confidence: skip low-confidence entities from Comprehend Medical.
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m ENTITY_CONFIDENCE_THRESHOLD = 0.80
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m # SageMaker endpoint name for the custom assertion classifier.
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m # Replace with your deployed endpoint name.
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m SAGEMAKER_ENDPOINT_NAME = "clinical-assertion-classifier"
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m # DynamoDB table for annotated entities.
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m ANNOTATED_ENTITIES_TABLE = "assertion-annotated-entities"
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m # ---------- Rule-Based Assertion Patterns ----------
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m # Negation cues: words/phrases that signal the entity is absent.
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m # These are checked in the text BEFORE the entity (pre-negation).
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m NEGATION_CUES_PRE = [
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m     "no evidence of", "no signs of", "no symptoms of",
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m     "denies", "denied", "denying",
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m     "negative for", "without",
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m     "rules out", "ruled out", "rule out",
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m     "absence of", "free of", "unremarkable for",
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m     "no ", "not "
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m # Post-entity negation cues (less common but real).
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m NEGATION_CUES_POST = [
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m     "absent", "negative", "not found", "not seen",
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m     "not present", "not detected", "ruled out"
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m # Pseudo-negation: patterns that LOOK like negation but aren't.
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m # "not only" means the condition IS present (and more).
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m # "no longer" means it WAS present (historical, not absent).
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m PSEUDO_NEGATION = [
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m     "not only", "no longer", "no increase",
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m     "no change", "no improvement", "not ruled out"
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m # Historical cues: signals the condition existed in the past.
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m HISTORICAL_CUES = [
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m     "history of", "h/o", "s/p", "status post",
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m     "previously", "prior", "in the past",
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m     "resolved", "former", "remote history",
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m     "childhood history of", "past history of"
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m # Hedging cues: signals the clinician is uncertain (possible/probable).
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m HEDGING_CUES = [
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m     "possible", "probable", "likely", "suspected",
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m     "concerning for", "suspicious for", "consistent with",
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m     "cannot rule out", "cannot exclude", "differential includes",
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m     "questionable", "equivocal", "uncertain"
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m # Conditional cues: the entity depends on a future condition.
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m CONDITIONAL_CUES = [
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m     "if ", "in the event of", "should ",
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m     "in case of", "when ", "upon ",
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m     "contingent on", "provided that"
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m # Hypothetical cues: planning or speculative context.
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m HYPOTHETICAL_CUES = [
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m     "will consider", "may start", "would recommend",
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m     "plan to", "consider starting", "may develop",
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m     "could lead to", "potential for", "risk of developing"
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m # Family cues: entity pertains to a family member, not the patient.
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m FAMILY_CUES = [
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m     "mother", "father", "brother", "sister",
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m     "maternal", "paternal", "family history",
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m     "fhx", "family hx", "grandfather", "grandmother",
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m     "aunt", "uncle", "cousin", "sibling"
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m # Section headers that carry strong assertion signals.
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m # Mapping from normalized section name to the default assertion for entities
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m # found in that section. This is a strong prior, not absolute.
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m SECTION_ASSERTION_MAP = {
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m     "family history": "family",
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m     "fhx": "family",
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m     "family hx": "family",
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m     "past medical history": "historical",
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m     "pmh": "historical",
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m     "past surgical history": "historical",
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m     "psh": "historical",
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m     "surgical history": "historical",
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m # Maximum characters for entity text in the context window before we
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m # skip the rules and go straight to the model.
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m MAX_RULE_ENTITY_LENGTH = 100
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m ## Step 1: Extract Entities from Clinical Text
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m *Maps to pseudocode Step 1. We call Comprehend Medical's `DetectEntitiesV2` to identify clinical entities (conditions, medications, procedures, tests) with their character offsets and built-in traits.*
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m def extract_entities(note_text: str) -> list[dict]:
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m     Extract clinical entities from note text using Comprehend Medical.
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m     DetectEntitiesV2 identifies medical conditions, medications, tests,
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m     procedures, and anatomy mentions. Each entity comes with:
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m       - Character offsets (BeginOffset, EndOffset) in the original text
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m       - Category and Type labels
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m       - Confidence score
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m       - Traits (including basic negation detection)
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m     We filter to entities above ENTITY_CONFIDENCE_THRESHOLD to reduce noise.
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m     The built-in Traits include NEGATION and other signals, but they only
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m     cover present vs. absent. Our assertion classifier extends this to the
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m     full 7-class taxonomy.
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m         note_text: raw clinical note text (up to 20,000 characters for DetectEntitiesV2)
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m         List of entity dicts with text, category, offsets, traits, and score.
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m     # DetectEntitiesV2 accepts up to 20,000 UTF-8 characters per request.
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m     # For longer notes, you'd split at sentence boundaries and process in chunks.
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m     if len(note_text) > 20000:
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m         note_text = note_text[:20000]
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m         logger.warning("Note text truncated to 20,000 chars for DetectEntitiesV2")
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m     response = comprehend_medical_client.detect_entities_v2(Text=note_text)
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m     entities = []
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m     for entity in response.get("Entities", []):
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m         score = entity.get("Score", 0.0)
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m         if score < ENTITY_CONFIDENCE_THRESHOLD:
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m         # Extract trait names for quick lookup downstream.
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m         # Traits include NEGATION, SIGN, SYMPTOM, DIAGNOSIS, etc.
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m         trait_names = [
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m             t["Name"] for t in entity.get("Traits", [])
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m             if t.get("Score", 0.0) >= 0.75
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m         ]
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m         entities.append({
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m             "text": entity["Text"],
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m             "category": entity["Category"],
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m             "type": entity.get("Type", ""),
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m             "begin_offset": entity["BeginOffset"],
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m             "end_offset": entity["EndOffset"],
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m             "score": round(score, 3),
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m             "traits": trait_names,
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m     logger.info("Extracted %d entities above confidence threshold", len(entities))
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m     return entities
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m ## Step 2: Extract Context Windows for Each Entity
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m *Maps to pseudocode Step 2. For each entity, we pull surrounding text and attempt to detect the section header. The classifier needs this context to identify negation cues, hedging language, and scope boundaries.*
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m def detect_section_header(note_text: str, entity_offset: int) -> str | None:
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m     Attempt to detect the section header governing a given text position.
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m     Clinical notes are structured into sections (Assessment, HPI, PMH, etc.)
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m     but section headers are inconsistent across EHR templates and institutions.
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m     We look backwards from the entity position for common header patterns.
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m     This is deliberately simple. Production systems use ML-based section
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m     detection or rely on EHR-provided section metadata.
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m     # Look backwards up to 500 chars for a line that looks like a section header.
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m     # Common patterns: "FAMILY HISTORY:", "Past Medical History", "Assessment and Plan"
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m     search_start = max(0, entity_offset - 500)
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     preceding_text = note_text[search_start:entity_offset]
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m     # Split into lines and search backwards for a header-like line.
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m     lines = preceding_text.split("\n")
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m     for line in reversed(lines):
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m         stripped = line.strip()
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m         if not stripped:
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m         # Heuristic: section headers are short, often uppercase or end with ":"
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m         if len(stripped) < 50 and (stripped.endswith(":") or stripped.isupper()):
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m             return stripped.rstrip(":").strip().lower()
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m     return None
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m def extract_context_windows(note_text: str, entities: list[dict]) -> list[dict]:
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m     Build context windows around each entity for assertion classification.
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m     Each context window includes:
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m       - The surrounding text (CONTEXT_WINDOW_CHARS before and after)
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m       - The entity's position within that window
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m       - The detected section header (if any)
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m     The classifier uses this window to find negation cues, hedging language,
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m     family history indicators, and other assertion-relevant signals.
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m         note_text: the full clinical note text
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m         entities:  list of entity dicts from extract_entities
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m         List of context dicts, one per entity, ready for classification.
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m     entity_contexts = []
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m     for entity in entities:
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m         begin = entity["begin_offset"]
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m         end = entity["end_offset"]
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m         # Calculate window boundaries, clamping to document edges.
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m         window_start = max(0, begin - CONTEXT_WINDOW_CHARS)
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m         window_end = min(len(note_text), end + CONTEXT_WINDOW_CHARS)
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m         context_text = note_text[window_start:window_end]
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m         # Entity position within the extracted context window.
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m         entity_start_in_context = begin - window_start
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m         entity_end_in_context = end - window_start
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m         # Detect the section header for this region of the note.
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m         section_header = detect_section_header(note_text, begin)
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m         entity_contexts.append({
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m             "entity": entity,
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m             "context_text": context_text,
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m             "entity_start_in_context": entity_start_in_context,
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m             "entity_end_in_context": entity_end_in_context,
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m             "section_header": section_header,
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m     return entity_contexts
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m ## Step 3: Classify Assertion Status (Hybrid: Rules + ML)
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m *Maps to pseudocode Step 3. The two-pass approach: rules handle the obvious cases quickly (negations, family history sections, clear temporal markers). Everything the rules can't confidently classify goes to the SageMaker-hosted ML model.*
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m def apply_assertion_rules(ctx: dict) -> dict | None:
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m     Rule-based assertion detection for high-confidence cases.
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m     This handles about 60% of entities in typical clinical text:
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m       - Clear negations ("denies", "no evidence of", "negative for")
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m       - Section-based assertions (Family History section -> family)
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m       - Obvious historical markers ("history of", "s/p", "previously")
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m       - Clear hedging ("possible", "suspected", "cannot rule out")
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m     Returns a result dict if rules can confidently classify, or None if
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m     the entity needs ML model classification.
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m         ctx: context dict from extract_context_windows
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m         Dict with assertion and confidence, or None if rules can't decide.
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m     section = ctx["section_header"]
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m     entity_start = ctx["entity_start_in_context"]
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m     entity_end = ctx["entity_end_in_context"]
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m     context = ctx["context_text"]
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m     # Text before and after the entity in the context window.
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m     text_before = context[:entity_start].lower()
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m     text_after = context[entity_end:].lower()
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m     # --- Check 1: Section header (strongest signal) ---
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m     if section and section in SECTION_ASSERTION_MAP:
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m             "assertion": SECTION_ASSERTION_MAP[section],
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m             "confidence": 0.93,
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m             "method": "rule_based",
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m             "rule": f"section_header:{section}",
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m     # --- Check 2: Family cues in surrounding text ---
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m     for cue in FAMILY_CUES:
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m         if cue in text_before[-80:]:
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m             return {
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m                 "assertion": "family",
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m                 "confidence": 0.91,
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m                 "method": "rule_based",
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m                 "rule": f"family_cue:{cue}",
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m     # --- Check 3: Pre-entity negation ---
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m     # Only look within 60 chars before the entity (scope approximation).
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m     near_text_before = text_before[-60:]
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m     # First check for pseudo-negation (looks like negation but isn't).
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m     for pseudo in PSEUDO_NEGATION:
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m         if pseudo in near_text_before:
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m             # Pseudo-negation detected. Don't classify as absent.
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m             # Fall through to ML model for nuanced classification.
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m             return None
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m     for cue in NEGATION_CUES_PRE:
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m         if cue in near_text_before:
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m             return {
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m                 "assertion": "absent",
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m                 "confidence": 0.92,
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m                 "method": "rule_based",
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m                 "rule": f"negation_pre:{cue}",
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m     # Post-entity negation (less common).
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m     near_text_after = text_after[:40]
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m     for cue in NEGATION_CUES_POST:
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m         if cue in near_text_after:
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m             return {
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m                 "assertion": "absent",
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m                 "confidence": 0.89,
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m                 "method": "rule_based",
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m                 "rule": f"negation_post:{cue}",
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m     # --- Check 4: Historical cues ---
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m     for cue in HISTORICAL_CUES:
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m         if cue in near_text_before:
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m             return {
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m                 "assertion": "historical",
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m                 "confidence": 0.88,
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m                 "method": "rule_based",
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m                 "rule": f"historical:{cue}",
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m     # --- Check 5: Conditional cues ---
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m     for cue in CONDITIONAL_CUES:
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m         if cue in near_text_before:
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m             return {
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m                 "assertion": "conditional",
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m                 "confidence": 0.86,
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m                 "method": "rule_based",
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m                 "rule": f"conditional:{cue}",
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m     # --- Check 6: Hypothetical cues ---
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m     for cue in HYPOTHETICAL_CUES:
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m         if cue in text_before[-100:]:
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m             return {
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m                 "assertion": "hypothetical",
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m                 "confidence": 0.85,
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m                 "method": "rule_based",
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m                 "rule": f"hypothetical:{cue}",
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m     # --- Check 7: Hedging cues ---
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m     for cue in HEDGING_CUES:
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m         if cue in near_text_before:
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m             return {
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m                 "assertion": "possible",
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m                 "confidence": 0.87,
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m                 "method": "rule_based",
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m                 "rule": f"hedging:{cue}",
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m     # Rules couldn't confidently classify. Pass to ML model.
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m     return None
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m def classify_with_model(ctx: dict) -> dict:
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m     Call the SageMaker-hosted assertion classifier for ambiguous cases.
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m     The model expects input formatted with [ENTITY] markers around the
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m     target span, plus the section header prepended as context. This tells
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m     the model which concept to classify vs. what's just surrounding text.
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m     Example input:
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m       "Section: Assessment\nPatient has [ENTITY]early-stage CKD[/ENTITY] based on labs"
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m     The model returns a JSON response with the predicted assertion class
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m     and confidence score.
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m         ctx: context dict from extract_context_windows
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m         Dict with assertion, confidence, and method="ml_model".
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m     context_text = ctx["context_text"]
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m     start = ctx["entity_start_in_context"]
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m     end = ctx["entity_end_in_context"]
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m     section = ctx["section_header"]
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m     # Format input: insert entity markers so the model knows the target span.
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m     marked_text = (
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m         context_text[:start]
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m         + "[ENTITY]"
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m         + context_text[start:end]
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m         + "[/ENTITY]"
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m         + context_text[end:]
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m     # Prepend section header if available.
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m     if section:
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m         model_input = f"Section: {section}\n{marked_text}"
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m         model_input = marked_text
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m     # Call the SageMaker endpoint.
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m     payload = json.dumps({"text": model_input})
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m     response = sagemaker_runtime_client.invoke_endpoint(
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m         EndpointName=SAGEMAKER_ENDPOINT_NAME,
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m         ContentType="application/json",
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m         Body=payload,
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m     result = json.loads(response["Body"].read().decode("utf-8"))
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m         "assertion": result["assertion_class"],
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m         "confidence": result["confidence"],
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m         "method": "ml_model",
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m def classify_assertions(entity_contexts: list[dict]) -> list[dict]:
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m     Two-pass assertion classification: rules first, ML model for the rest.
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m     Pass 1 (rules): handles obvious negations, section-based assertions,
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m     and clear temporal/hedging cues. Fast, deterministic, no network call.
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m     Pass 2 (ML model): invoked only for entities the rules couldn't
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m     confidently classify. Calls the SageMaker endpoint.
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m         entity_contexts: list of context dicts from extract_context_windows
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m         List of classification result dicts with entity, assertion, confidence, and method.
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m     results = []
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m     rule_count = 0
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m     model_count = 0
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m     for ctx in entity_contexts:
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m         # Pass 1: Try rules.
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m         rule_result = apply_assertion_rules(ctx)
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m         if rule_result and rule_result["confidence"] >= CONFIDENCE_THRESHOLD:
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m             results.append({
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m                 "entity": ctx["entity"],
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m                 "assertion": rule_result["assertion"],
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m                 "confidence": rule_result["confidence"],
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m                 "method": rule_result["method"],
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m                 "rule": rule_result.get("rule"),
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m             rule_count += 1
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m         # Pass 2: ML model for ambiguous cases.
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m         try:
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m             model_result = classify_with_model(ctx)
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m             results.append({
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m                 "entity": ctx["entity"],
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m                 "assertion": model_result["assertion"],
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m                 "confidence": model_result["confidence"],
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m                 "method": model_result["method"],
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m             model_count += 1
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m         except Exception as e:
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m             # If the model endpoint is unavailable, fall back to "present"
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m             # with low confidence (will be flagged for review).
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m             logger.warning("Model invocation failed for entity '%s': %s",
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m                            ctx["entity"]["text"], str(e))
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m             results.append({
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m                 "entity": ctx["entity"],
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m                 "assertion": "present",
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m                 "confidence": 0.50,
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m                 "method": "fallback",
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m     logger.info("Classification complete: %d by rules, %d by model", rule_count, model_count)
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m     return results
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m ## Step 4: Post-Process and Resolve Conflicts
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m *Maps to pseudocode Step 4. When the same clinical concept appears multiple times with different assertion statuses, we resolve to the most clinically relevant assertion using section priority and note position.*
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m # Section priority for conflict resolution.
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m # Higher number = more likely to reflect current clinical truth.
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m SECTION_PRIORITY = {
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m     "assessment": 5, "assessment and plan": 5, "a/p": 5, "plan": 5,
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m     "hpi": 4, "history of present illness": 4,
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m     "ros": 3, "review of systems": 3,
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m     "pmh": 2, "past medical history": 2,
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m     "fhx": 1, "family history": 1, "family hx": 1,
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m def resolve_assertion_conflicts(classified_entities: list[dict]) -> list[dict]:
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m     Resolve conflicts when the same concept has multiple assertion mentions.
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m     Example: "diabetes" in PMH (historical) AND in Assessment (present).
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m     The Assessment mention wins because it reflects today's clinical state.
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m     We group by normalized entity text and pick the highest-priority mention.
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m     All mentions are preserved in the audit trail.
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m         classified_entities: list from classify_assertions
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m         Deduplicated list with one assertion per unique concept.
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m         Conflict-resolved entries include all_mentions for audit.
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m     # Group entities by normalized text (lowercase, stripped).
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m     groups = {}
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m     for item in classified_entities:
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m         key = item["entity"]["text"].lower().strip()
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m         if key not in groups:
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m             groups[key] = []
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m         groups[key].append(item)
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m     resolved = []
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m     for concept, mentions in groups.items():
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m         if len(mentions) == 1:
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m             resolved.append(mentions[0])
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m         # Multiple mentions: pick highest priority.
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m         def priority_score(item):
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m             # Use section priority if available, otherwise default to 3.
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m             section = item["entity"].get("section_header") or ""
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m             section_score = SECTION_PRIORITY.get(section, 3)
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m             # Tie-break: later in the note = higher priority.
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m             position_score = item["entity"]["begin_offset"] / 10000.0
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m             return section_score + position_score
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m         best = max(mentions, key=priority_score)
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m         best["all_mentions"] = mentions
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m         best["conflict_resolved"] = True
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m         resolved.append(best)
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m     conflicts = sum(1 for r in resolved if r.get("conflict_resolved"))
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m     if conflicts:
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m         logger.info("Resolved %d assertion conflicts", conflicts)
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m     return resolved
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m ## Step 5: Store Annotated Entities
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m *Maps to pseudocode Step 5. Write assertion-classified entities to DynamoDB, indexed for downstream queries.*
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m def store_annotated_entities(
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m     patient_id: str,
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m     note_id: str,
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m     note_date: str,
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m     resolved_entities: list[dict],
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m     Write assertion-annotated entities to DynamoDB.
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m     Each entity record includes:
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m       - Patient/note linkage for provenance
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m       - The assertion classification and confidence
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m       - A needs_review flag for low-confidence classifications
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m       - A context snippet for human review
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m     Also writes a note-level summary showing assertion distribution.
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m         patient_id: patient identifier
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m         note_id:    unique note identifier
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m         note_date:  ISO date string for the clinical note
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m         resolved_entities: deduplicated list from resolve_assertion_conflicts
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m         Summary dict with counts by assertion class.
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m     table = dynamodb.Table(ANNOTATED_ENTITIES_TABLE)
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m     # Count assertions by class for the summary.
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m     assertion_counts = {cls: 0 for cls in ASSERTION_CLASSES}
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m     review_count = 0
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m     for idx, result in enumerate(resolved_entities):
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m         needs_review = result["confidence"] < CONFIDENCE_THRESHOLD
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m         if needs_review:
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m             review_count += 1
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m         assertion = result["assertion"]
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m         if assertion in assertion_counts:
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m             assertion_counts[assertion] += 1
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m         record = {
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m             "patient_id": patient_id,
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m             "note_id_entity_idx": f"{note_id}#{idx:04d}",
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m             "note_id": note_id,
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m             "note_date": note_date,
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m             "entity_text": result["entity"]["text"],
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m             "entity_category": result["entity"]["category"],
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m             "assertion_status": assertion,
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m             "confidence": Decimal(str(round(result["confidence"], 3))),
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m             "method": result["method"],
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m             "needs_review": needs_review,
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m             "processed_at": datetime.datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m         table.put_item(Item=record)
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m     summary = {
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m         "note_id": note_id,
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m         "patient_id": patient_id,
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m         "note_date": note_date,
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m         "total_entities": len(resolved_entities),
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m         "assertion_counts": assertion_counts,
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m         "needs_review_count": review_count,
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m         "Stored %d annotated entities (%d for review)",
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m         len(resolved_entities), review_count
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m     return summary
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m ## Putting It All Together
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m The full pipeline assembled into a single function. This orchestrates all five steps from the recipe pseudocode.
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    717[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    718[0m:[38;5;10m[49m def classify_note_assertions(
[0m[49m[38;5;10m+    719[0m:[38;5;10m[49m     note_text: str,
[0m[49m[38;5;10m+    720[0m:[38;5;10m[49m     patient_id: str,
[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m     note_id: str,
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m     note_date: str,
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    725[0m:[38;5;10m[49m     Run the full assertion classification pipeline on one clinical note.
[0m[49m[38;5;10m+    726[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    727[0m:[38;5;10m[49m     Steps:
[0m[49m[38;5;10m+    728[0m:[38;5;10m[49m       1. Extract entities with Comprehend Medical
[0m[49m[38;5;10m+    729[0m:[38;5;10m[49m       2. Build context windows around each entity
[0m[49m[38;5;10m+    730[0m:[38;5;10m[49m       3. Classify assertions (rules + ML model)
[0m[49m[38;5;10m+    731[0m:[38;5;10m[49m       4. Resolve conflicts for repeated concepts
[0m[49m[38;5;10m+    732[0m:[38;5;10m[49m       5. Store annotated entities in DynamoDB
[0m[49m[38;5;10m+    733[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    734[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    735[0m:[38;5;10m[49m         note_text:   raw clinical note text
[0m[49m[38;5;10m+    736[0m:[38;5;10m[49m         patient_id:  patient identifier
[0m[49m[38;5;10m+    737[0m:[38;5;10m[49m         note_id:     unique note identifier
[0m[49m[38;5;10m+    738[0m:[38;5;10m[49m         note_date:   ISO date string
[0m[49m[38;5;10m+    739[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    740[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    741[0m:[38;5;10m[49m         Summary dict with assertion counts and review statistics.
[0m[49m[38;5;10m+    742[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    743[0m:[38;5;10m[49m     # Step 1: Entity extraction.
[0m[49m[38;5;10m+    744[0m:[38;5;10m[49m     logger.info("Step 1: Extracting entities from note %s", note_id)
[0m[49m[38;5;10m+    745[0m:[38;5;10m[49m     entities = extract_entities(note_text)
[0m[49m[38;5;10m+    746[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    747[0m:[38;5;10m[49m     if not entities:
[0m[49m[38;5;10m+    748[0m:[38;5;10m[49m         logger.info("No entities found in note %s", note_id)
[0m[49m[38;5;10m+    749[0m:[38;5;10m[49m         return {"note_id": note_id, "total_entities": 0}
[0m[49m[38;5;10m+    750[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    751[0m:[38;5;10m[49m     # Step 2: Context window extraction.
[0m[49m[38;5;10m+    752[0m:[38;5;10m[49m     logger.info("Step 2: Extracting context windows for %d entities", len(entities))
[0m[49m[38;5;10m+    753[0m:[38;5;10m[49m     entity_contexts = extract_context_windows(note_text, entities)
[0m[49m[38;5;10m+    754[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    755[0m:[38;5;10m[49m     # Step 3: Assertion classification (hybrid rules + ML).
[0m[49m[38;5;10m+    756[0m:[38;5;10m[49m     logger.info("Step 3: Classifying assertion status")
[0m[49m[38;5;10m+    757[0m:[38;5;10m[49m     classified = classify_assertions(entity_contexts)
[0m[49m[38;5;10m+    758[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    759[0m:[38;5;10m[49m     # Step 4: Conflict resolution.
[0m[49m[38;5;10m+    760[0m:[38;5;10m[49m     logger.info("Step 4: Resolving assertion conflicts")
[0m[49m[38;5;10m+    761[0m:[38;5;10m[49m     resolved = resolve_assertion_conflicts(classified)
[0m[49m[38;5;10m+    762[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    763[0m:[38;5;10m[49m     # Step 5: Store results.
[0m[49m[38;5;10m+    764[0m:[38;5;10m[49m     logger.info("Step 5: Storing annotated entities")
[0m[49m[38;5;10m+    765[0m:[38;5;10m[49m     summary = store_annotated_entities(patient_id, note_id, note_date, resolved)
