[0m[49m[38;5;10m+    884[0m:[38;5;10m[49m         #     QueueUrl=os.environ["REVIEW_QUEUE_URL"],
[0m[49m[38;5;10m+    885[0m:[38;5;10m[49m         #     MessageBody=json.dumps({"note_id": note_id, "patient_id": patient_id}),
[0m[49m[38;5;10m+    886[0m:[38;5;10m[49m         # )
