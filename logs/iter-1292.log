[0m[49m[38;5;10m+    843[0m:[38;5;10m[49m def lambda_handler(event: dict, context) -> dict:
[0m[49m[38;5;10m+    844[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    845[0m:[38;5;10m[49m     Lambda handler for real-time assertion classification.
[0m[49m[38;5;10m+    846[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    847[0m:[38;5;10m[49m     Triggered by a note finalization event containing:
[0m[49m[38;5;10m+    848[0m:[38;5;10m[49m       - note_text or an S3 reference to the note
[0m[49m[38;5;10m+    849[0m:[38;5;10m[49m       - patient_id
[0m[49m[38;5;10m+    850[0m:[38;5;10m[49m       - note_id
[0m[49m[38;5;10m+    851[0m:[38;5;10m[49m       - note_date
[0m[49m[38;5;10m+    852[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    853[0m:[38;5;10m[49m     Returns the assertion summary for monitoring and downstream routing.
[0m[49m[38;5;10m+    854[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    855[0m:[38;5;10m[49m     # Extract note metadata from the event.
[0m[49m[38;5;10m+    856[0m:[38;5;10m[49m     # Adapt this to your integration layer's event format.
[0m[49m[38;5;10m+    857[0m:[38;5;10m[49m     record = event.get("detail", event)
[0m[49m[38;5;10m+    858[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    859[0m:[38;5;10m[49m     note_text = record.get("note_text")
[0m[49m[38;5;10m+    860[0m:[38;5;10m[49m     patient_id = record["patient_id"]
[0m[49m[38;5;10m+    861[0m:[38;5;10m[49m     note_id = record["note_id"]
[0m[49m[38;5;10m+    862[0m:[38;5;10m[49m     note_date = record["note_date"]
[0m[49m[38;5;10m+    863[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    864[0m:[38;5;10m[49m     # If note_text not inline, fetch from S3.
[0m[49m[38;5;10m+    865[0m:[38;5;10m[49m     if not note_text and "s3_bucket" in record:
[0m[49m[38;5;10m+    866[0m:[38;5;10m[49m         s3 = boto3.client("s3")
[0m[49m[38;5;10m+    867[0m:[38;5;10m[49m         obj = s3.get_object(
[0m[49m[38;5;10m+    868[0m:[38;5;10m[49m             Bucket=record["s3_bucket"],
[0m[49m[38;5;10m+    869[0m:[38;5;10m[49m             Key=record["s3_key"],
[0m[49m[38;5;10m+    870[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    871[0m:[38;5;10m[49m         note_text = obj["Body"].read().decode("utf-8")
[0m[49m[38;5;10m+    872[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    873[0m:[38;5;10m[49m     if not note_text:
[0m[49m[38;5;10m+    874[0m:[38;5;10m[49m         logger.error("No note text available for note %s", note_id)
[0m[49m[38;5;10m+    875[0m:[38;5;10m[49m         return {"error": "no_note_text", "note_id": note_id}
[0m[49m[38;5;10m+    876[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    877[0m:[38;5;10m[49m     summary = classify_note_assertions(note_text, patient_id, note_id, note_date)
[0m[49m[38;5;10m+    878[0m:[38;5;10m[49m 
