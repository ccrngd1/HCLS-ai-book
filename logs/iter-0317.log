[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m │    - Random sample plus targeted sample                 │
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m │    - Reviewers tag failure modes                        │
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m │    - Improvement loop                                   │
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m │           │                                              │
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m │           ▼                                              │
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m │   [Output: audit trail, telemetry, learning signals]    │
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m │                                                          │
