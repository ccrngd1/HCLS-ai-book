[0m[49m[38;5;10m+    1682[0m:[38;5;10m[49m             attach_greeting=attach_initial_greeting,
[0m[49m[38;5;10m+    1683[0m:[38;5;10m[49m             disposition="provider_not_found")
[0m[49m[38;5;10m+    1684[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1685[0m:[38;5;10m[49m     provider = matches[0]
[0m[49m[38;5;10m+    1686[0m:[38;5;10m[49m     in_network = provider.get("in_network", False)
[0m[49m[38;5;10m+    1687[0m:[38;5;10m[49m     is_facility = provider.get("is_facility", False)
[0m[49m[38;5;10m+    1688[0m:[38;5;10m[49m     ancillary_warning = lookup.get(
