[0m[48;2;40;67;43m[39m+    585[0m:[39m[48;2;24;38;30m [38;2;191;97;106m-[38;2;191;97;106m [38;2;235;203;139m**[38;2;235;203;139mExpert:[38;2;235;203;139m**[38;2;191;97;106m Voice / Publication Readiness[K
[0m[48;2;40;67;43m[39m+    586[0m:[39m[48;2;24;38;30m [38;2;191;97;106m-[38;2;191;97;106m [38;2;235;203;139m**[38;2;235;203;139mLocation:[38;2;235;203;139m**[38;2;191;97;106m Expected Results "Performance benchmarks (illustrative; measure against your own data)" table.[K
