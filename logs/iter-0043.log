[0m[49m[38;5;10m+    3631[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3632[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3633[0m:[38;5;10m[49m class MockKnowledgeBase:
[0m[49m[38;5;10m+    3634[0m:[38;5;10m[49m     """Stand-in for the plan-document corpus retrieval."""
[0m[49m[38;5;10m+    3635[0m:[38;5;10m[49m     def retrieve(self, query, plan_id, plan_year,
[0m[49m[38;5;10m+    3636[0m:[38;5;10m[49m                   document_types_in_scope, top_k):
[0m[49m[38;5;10m+    3637[0m:[38;5;10m[49m         chunks = PLAN_DOCUMENT_CORPUS.get(
[0m[49m[38;5;10m+    3638[0m:[38;5;10m[49m             (plan_id, plan_year), [])
[0m[49m[38;5;10m+    3639[0m:[38;5;10m[49m         # Filter by document type.
[0m[49m[38;5;10m+    3640[0m:[38;5;10m[49m         chunks = [c for c in chunks
[0m[49m[38;5;10m+    3641[0m:[38;5;10m[49m                    if c["document_type"] in
[0m[49m[38;5;10m+    3642[0m:[38;5;10m[49m                    document_types_in_scope]
[0m[49m[38;5;10m+    3643[0m:[38;5;10m[49m         # Crude relevance: any keyword in the chunk text
[0m[49m[38;5;10m+    3644[0m:[38;5;10m[49m         # matches a query term.
[0m[49m[38;5;10m+    3645[0m:[38;5;10m[49m         terms = set(re.findall(r"[a-zA-Z]+",
[0m[49m[38;5;10m+    3646[0m:[38;5;10m[49m                                   (query or "").lower()))
[0m[49m[38;5;10m+    3647[0m:[38;5;10m[49m         scored = []
[0m[49m[38;5;10m+    3648[0m:[38;5;10m[49m         for c in chunks:
[0m[49m[38;5;10m+    3649[0m:[38;5;10m[49m             chunk_terms = set(re.findall(
[0m[49m[38;5;10m+    3650[0m:[38;5;10m[49m                 r"[a-zA-Z]+", c["text"].lower()))
[0m[49m[38;5;10m+    3651[0m:[38;5;10m[49m             overlap = len(terms & chunk_terms)
[0m[49m[38;5;10m+    3652[0m:[38;5;10m[49m             scored.append((overlap, c))
[0m[49m[38;5;10m+    3653[0m:[38;5;10m[49m         scored.sort(key=lambda t: t[0], reverse=True)
[0m[49m[38;5;10m+    3654[0m:[38;5;10m[49m         top = [c for score, c in scored[:top_k]
[0m[49m[38;5;10m+    3655[0m:[38;5;10m[49m                 if score > 0]
[0m[49m[38;5;10m+    3656[0m:[38;5;10m[49m         return {"chunks": top}
[0m[49m[38;5;10m+    3657[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3658[0m:[38;5;10m[49m 
