[0m[49m[38;5;10m+    2456[0m:[38;5;10m[49m         "you should take ibuprofen",
[0m[49m[38;5;10m+    2457[0m:[38;5;10m[49m         "you should stop taking",
[0m[49m[38;5;10m+    2458[0m:[38;5;10m[49m         "the right medication for you is",
[0m[49m[38;5;10m+    2459[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    2460[0m:[38;5;10m[49m     for phrase in treatment:
[0m[49m[38;5;10m+    2461[0m:[38;5;10m[49m         if phrase in lowered:
[0m[49m[38;5;10m+    2462[0m:[38;5;10m[49m             return "treatment_recommendation_attempted"
[0m[49m[38;5;10m+    2463[0m:[38;5;10m[49m     return None
[0m[49m[38;5;10m+    2464[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    2465[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2466[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    2467[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2468[0m:[38;5;10m[49m ## Step 8: Persist the Durable Triage-Decision Record
[0m[49m[38;5;10m+    2469[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2470[0m:[38;5;10m[49m *The pseudocode calls this `persist_triage_decision_record(session_id, response)`. The conversation log captures the dialog. The triage-decision-record journal captures, separately, every recommendation with its citation evidence and version stamps. This is the audit surface for clinical-quality review, for regulatory review (where applicable), for outcome correlation, and for any case where the recommendation is later disputed.*
[0m[49m[38;5;10m+    2471[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2472[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    2473[0m:[38;5;10m[49m def _persist_decision_record(session_id: str,
[0m[49m[38;5;10m+    2474[0m:[38;5;10m[49m                                 question_text: str,
[0m[49m[38;5;10m+    2475[0m:[38;5;10m[49m                                 answer_text: str,
[0m[49m[38;5;10m+    2476[0m:[38;5;10m[49m                                 protocol_id: Optional[str],
[0m[49m[38;5;10m+    2477[0m:[38;5;10m[49m                                 protocol_version:
[0m[49m[38;5;10m+    2478[0m:[38;5;10m[49m                                     Optional[str],
[0m[49m[38;5;10m+    2479[0m:[38;5;10m[49m                                 protocol_answer_set: dict,
[0m[49m[38;5;10m+    2480[0m:[38;5;10m[49m                                 clinical_rule_results: list,
[0m[49m[38;5;10m+    2481[0m:[38;5;10m[49m                                 final_recommendation: dict,
[0m[49m[38;5;10m+    2482[0m:[38;5;10m[49m                                 citations: list) -> None:
[0m[49m[38;5;10m+    2483[0m:[38;5;10m[49m     """Persist a structured record of the triage decision."""
[0m[49m[38;5;10m+    2484[0m:[38;5;10m[49m     session = _session_state(session_id)
[0m[49m[38;5;10m+    2485[0m:[38;5;10m[49m     decision_id = f"decision-{uuid.uuid4()}"
[0m[49m[38;5;10m+    2486[0m:[38;5;10m[49m     decision_record = {
[0m[49m[38;5;10m+    2487[0m:[38;5;10m[49m         "decision_id":   decision_id,
[0m[49m[38;5;10m+    2488[0m:[38;5;10m[49m         "session_id":    session_id,
[0m[49m[38;5;10m+    2489[0m:[38;5;10m[49m         "patient_id":
[0m[49m[38;5;10m+    2490[0m:[38;5;10m[49m             session.get("verified_patient_id"),
[0m[49m[38;5;10m+    2491[0m:[38;5;10m[49m         "pediatric_vs_adult":
[0m[49m[38;5;10m+    2492[0m:[38;5;10m[49m             session.get("pediatric_vs_adult"),
[0m[49m[38;5;10m+    2493[0m:[38;5;10m[49m         "special_population_flags":
[0m[49m[38;5;10m+    2494[0m:[38;5;10m[49m             session.get("special_population_flags", []),
[0m[49m[38;5;10m+    2495[0m:[38;5;10m[49m         "presenting_complaint":
[0m[49m[38;5;10m+    2496[0m:[38;5;10m[49m             session.get("primary_presenting_symptom"),
[0m[49m[38;5;10m+    2497[0m:[38;5;10m[49m         "protocol_id":   protocol_id,
[0m[49m[38;5;10m+    2498[0m:[38;5;10m[49m         "protocol_version": protocol_version,
[0m[49m[38;5;10m+    2499[0m:[38;5;10m[49m         "protocol_answer_set":
[0m[49m[38;5;10m+    2500[0m:[38;5;10m[49m             _redact_protocol_answers(protocol_answer_set),
[0m[49m[38;5;10m+    2501[0m:[38;5;10m[49m         "clinical_rule_results": clinical_rule_results,
[0m[49m[38;5;10m+    2502[0m:[38;5;10m[49m         "recommendation_care_level":
[0m[49m[38;5;10m+    2503[0m:[38;5;10m[49m             final_recommendation.get("care_level"),
[0m[49m[38;5;10m+    2504[0m:[38;5;10m[49m         "recommendation_rationale":
[0m[49m[38;5;10m+    2505[0m:[38;5;10m[49m             final_recommendation.get("rationale"),
[0m[49m[38;5;10m+    2506[0m:[38;5;10m[49m         "recommendation_text": answer_text,
[0m[49m[38;5;10m+    2507[0m:[38;5;10m[49m         "upgrades_applied":
[0m[49m[38;5;10m+    2508[0m:[38;5;10m[49m             final_recommendation.get(
[0m[49m[38;5;10m+    2509[0m:[38;5;10m[49m                 "upgrades_applied", []),
[0m[49m[38;5;10m+    2510[0m:[38;5;10m[49m         "citations":     citations,
[0m[49m[38;5;10m+    2511[0m:[38;5;10m[49m         "active_chart_context_as_of_date":
[0m[49m[38;5;10m+    2512[0m:[38;5;10m[49m             session.get("chart_context_as_of_date"),
[0m[49m[38;5;10m+    2513[0m:[38;5;10m[49m         "active_model_id":
[0m[49m[38;5;10m+    2514[0m:[38;5;10m[49m             session.get("model_id"),
[0m[49m[38;5;10m+    2515[0m:[38;5;10m[49m         "active_prompt_version":
[0m[49m[38;5;10m+    2516[0m:[38;5;10m[49m             session.get("prompt_version"),
[0m[49m[38;5;10m+    2517[0m:[38;5;10m[49m         "active_agent_version":
[0m[49m[38;5;10m+    2518[0m:[38;5;10m[49m             session.get("agent_version"),
[0m[49m[38;5;10m+    2519[0m:[38;5;10m[49m         "active_disclosure_library_version":
[0m[49m[38;5;10m+    2520[0m:[38;5;10m[49m             session.get("disclosure_library_version"),
[0m[49m[38;5;10m+    2521[0m:[38;5;10m[49m         "delivered_at":  _now_iso(),
[0m[49m[38;5;10m+    2522[0m:[38;5;10m[49m         "channel":       session.get("channel"),
[0m[49m[38;5;10m+    2523[0m:[38;5;10m[49m         "language":      session.get("language"),
[0m[49m[38;5;10m+    2524[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    2525[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2526[0m:[38;5;10m[49m     # Write the decision record into the DynamoDB table for
[0m[49m[38;5;10m+    2527[0m:[38;5;10m[49m     # operational queries.
[0m[49m[38;5;10m+    2528[0m:[38;5;10m[49m     table = dynamodb.Table(DECISION_RECORD_TABLE)
[0m[49m[38;5;10m+    2529[0m:[38;5;10m[49m     try:
[0m[49m[38;5;10m+    2530[0m:[38;5;10m[49m         table.put_item(Item=_to_decimal(decision_record))
[0m[49m[38;5;10m+    2531[0m:[38;5;10m[49m     except Exception as exc:
[0m[49m[38;5;10m+    2532[0m:[38;5;10m[49m         logger.error(
[0m[49m[38;5;10m+    2533[0m:[38;5;10m[49m             "Decision-record table write failed for %s: %s",
[0m[49m[38;5;10m+    2534[0m:[38;5;10m[49m             decision_id, exc)
[0m[49m[38;5;10m+    2535[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2536[0m:[38;5;10m[49m     # Write a durable copy into the S3 journal for long-term
[0m[49m[38;5;10m+    2537[0m:[38;5;10m[49m     # audit. Production has Object Lock in compliance mode and
[0m[49m[38;5;10m+    2538[0m:[38;5;10m[49m     # retention sized to the longest of HIPAA's six-year
[0m[49m[38;5;10m+    2539[0m:[38;5;10m[49m     # minimum, state medical-record retention rules, FDA SaMD
[0m[49m[38;5;10m+    2540[0m:[38;5;10m[49m     # post-market obligations where applicable, and the
[0m[49m[38;5;10m+    2541[0m:[38;5;10m[49m     # institutional regulatory floor.
[0m[49m[38;5;10m+    2542[0m:[38;5;10m[49m     _write_decision_journal(decision_record)
[0m[49m[38;5;10m+    2543[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2544[0m:[38;5;10m[49m     # Queue for outcome correlation. The pipeline pulls
[0m[49m[38;5;10m+    2545[0m:[38;5;10m[49m     # subsequent encounter records (ED visits, urgent care
[0m[49m[38;5;10m+    2546[0m:[38;5;10m[49m     # visits, primary care visits, hospital admissions) within
[0m[49m[38;5;10m+    2547[0m:[38;5;10m[49m     # a 72-hour window and computes per-protocol over-triage
[0m[49m[38;5;10m+    2548[0m:[38;5;10m[49m     # and under-triage rates.
[0m[49m[38;5;10m+    2549[0m:[38;5;10m[49m     _queue_outcome_correlation(decision_record)
[0m[49m[38;5;10m+    2550[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2551[0m:[38;5;10m[49m     # Track count on the session for the closing metrics.
[0m[49m[38;5;10m+    2552[0m:[38;5;10m[49m     count = int(session.get("decision_count", 0)) + 1
[0m[49m[38;5;10m+    2553[0m:[38;5;10m[49m     _update_session_field(
[0m[49m[38;5;10m+    2554[0m:[38;5;10m[49m         session_id, "decision_count", count)
[0m[49m[38;5;10m+    2555[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2556[0m:[38;5;10m[49m     _put_metric("CitationCoverageRate",
[0m[49m[38;5;10m+    2557[0m:[38;5;10m[49m                 1 if citations else 0,
[0m[49m[38;5;10m+    2558[0m:[38;5;10m[49m                 {"protocol_id": protocol_id or "unknown"})
[0m[49m[38;5;10m+    2559[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2560[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2561[0m:[38;5;10m[49m def _redact_protocol_answers(answer_set: dict) -> dict:
[0m[49m[38;5;10m+    2562[0m:[38;5;10m[49m     """Redact free-text raw fields from protocol answers."""
[0m[49m[38;5;10m+    2563[0m:[38;5;10m[49m     redacted = {}
[0m[49m[38;5;10m+    2564[0m:[38;5;10m[49m     for q_id, value in (answer_set or {}).items():
[0m[49m[38;5;10m+    2565[0m:[38;5;10m[49m         if isinstance(value, dict):
[0m[49m[38;5;10m+    2566[0m:[38;5;10m[49m             redacted_value = dict(value)
[0m[49m[38;5;10m+    2567[0m:[38;5;10m[49m             if "raw" in redacted_value:
[0m[49m[38;5;10m+    2568[0m:[38;5;10m[49m                 redacted_value["raw"] = "[REDACTED]"
[0m[49m[38;5;10m+    2569[0m:[38;5;10m[49m             redacted[q_id] = redacted_value
[0m[49m[38;5;10m+    2570[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    2571[0m:[38;5;10m[49m             redacted[q_id] = value
[0m[49m[38;5;10m+    2572[0m:[38;5;10m[49m     return redacted
[0m[49m[38;5;10m+    2573[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2574[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2575[0m:[38;5;10m[49m def _write_decision_journal(record: dict) -> None:
[0m[49m[38;5;10m+    2576[0m:[38;5;10m[49m     """Write a durable decision-record journal entry to S3."""
[0m[49m[38;5;10m+    2577[0m:[38;5;10m[49m     key = (
[0m[49m[38;5;10m+    2578[0m:[38;5;10m[49m         f"{INSTITUTION_ID}/"
[0m[49m[38;5;10m+    2579[0m:[38;5;10m[49m         f"{datetime.now(timezone.utc):%Y/%m/%d}/"
[0m[49m[38;5;10m+    2580[0m:[38;5;10m[49m         f"{record['decision_id']}.json")
[0m[49m[38;5;10m+    2581[0m:[38;5;10m[49m     try:
[0m[49m[38;5;10m+    2582[0m:[38;5;10m[49m         s3_client.put_object(
[0m[49m[38;5;10m+    2583[0m:[38;5;10m[49m             Bucket=DECISION_RECORD_BUCKET,
[0m[49m[38;5;10m+    2584[0m:[38;5;10m[49m             Key=key,
[0m[49m[38;5;10m+    2585[0m:[38;5;10m[49m             Body=(json.dumps(_from_decimal(record))
[0m[49m[38;5;10m+    2586[0m:[38;5;10m[49m                    + "\n").encode("utf-8"),
[0m[49m[38;5;10m+    2587[0m:[38;5;10m[49m             ContentType="application/json",
[0m[49m[38;5;10m+    2588[0m:[38;5;10m[49m             ServerSideEncryption="aws:kms")
[0m[49m[38;5;10m+    2589[0m:[38;5;10m[49m     except Exception as exc:
[0m[49m[38;5;10m+    2590[0m:[38;5;10m[49m         logger.error(
[0m[49m[38;5;10m+    2591[0m:[38;5;10m[49m             "Decision-journal write failed for %s: %s",
[0m[49m[38;5;10m+    2592[0m:[38;5;10m[49m             record.get("decision_id"), exc)
[0m[49m[38;5;10m+    2593[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2594[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2595[0m:[38;5;10m[49m def _queue_outcome_correlation(record: dict) -> None:
[0m[49m[38;5;10m+    2596[0m:[38;5;10m[49m     """Queue the decision for 72-hour outcome correlation."""
[0m[49m[38;5;10m+    2597[0m:[38;5;10m[49m     try:
[0m[49m[38;5;10m+    2598[0m:[38;5;10m[49m         table = dynamodb.Table(OUTCOME_CORRELATION_TABLE)
[0m[49m[38;5;10m+    2599[0m:[38;5;10m[49m         delivered = datetime.fromisoformat(
[0m[49m[38;5;10m+    2600[0m:[38;5;10m[49m             record["delivered_at"])
[0m[49m[38;5;10m+    2601[0m:[38;5;10m[49m         correlation_window_end = (
[0m[49m[38;5;10m+    2602[0m:[38;5;10m[49m             delivered + timedelta(hours=72)).isoformat()
[0m[49m[38;5;10m+    2603[0m:[38;5;10m[49m         table.put_item(Item=_to_decimal({
[0m[49m[38;5;10m+    2604[0m:[38;5;10m[49m             "decision_id":   record["decision_id"],
[0m[49m[38;5;10m+    2605[0m:[38;5;10m[49m             "patient_id":    record.get("patient_id"),
