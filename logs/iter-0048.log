[0m[49m[38;5;10m+    2414[0m:[38;5;10m[49m     # specifies a min_acuity floor and the proposed care level
[0m[49m[38;5;10m+    2415[0m:[38;5;10m[49m     # is below that floor, raise the recommendation. The
[0m[49m[38;5;10m+    2416[0m:[38;5;10m[49m     # demo's protocol-runtime should already have applied the
[0m[49m[38;5;10m+    2417[0m:[38;5;10m[49m     # floor in Step 6, but the verifier here is a defensive
[0m[49m[38;5;10m+    2418[0m:[38;5;10m[49m     # second check.
[0m[49m[38;5;10m+    2419[0m:[38;5;10m[49m     protocol_def = PROTOCOL_LIBRARY.get(protocol_id)
[0m[49m[38;5;10m+    2420[0m:[38;5;10m[49m     if protocol_def:
[0m[49m[38;5;10m+    2421[0m:[38;5;10m[49m         floor = protocol_def.get("min_acuity")
[0m[49m[38;5;10m+    2422[0m:[38;5;10m[49m         if floor and \
[0m[49m[38;5;10m+    2423[0m:[38;5;10m[49m                 _care_level_acuity(floor) > \
[0m[49m[38;5;10m+    2424[0m:[38;5;10m[49m                 _care_level_acuity(proposed_care_level):
[0m[49m[38;5;10m+    2425[0m:[38;5;10m[49m             _put_metric("ConservativeBiasFloorRaised", 1, {
[0m[49m[38;5;10m+    2426[0m:[38;5;10m[49m                 "protocol_id": protocol_id or "unknown",
[0m[49m[38;5;10m+    2427[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    2428[0m:[38;5;10m[49m             return {
[0m[49m[38;5;10m+    2429[0m:[38;5;10m[49m                 "action":            "regenerate_with_higher_acuity",
[0m[49m[38;5;10m+    2430[0m:[38;5;10m[49m                 "target_care_level": floor,
[0m[49m[38;5;10m+    2431[0m:[38;5;10m[49m                 "response_text":     response_text,
[0m[49m[38;5;10m+    2432[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    2433[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2434[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    2435[0m:[38;5;10m[49m         "action":         "deliver",
[0m[49m[38;5;10m+    2436[0m:[38;5;10m[49m         "response_text":  response_text,
[0m[49m[38;5;10m+    2437[0m:[38;5;10m[49m         "citations":      citations,
[0m[49m[38;5;10m+    2438[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    2439[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2440[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2441[0m:[38;5;10m[49m def _detect_triage_scope_violation(text: str
[0m[49m[38;5;10m+    2442[0m:[38;5;10m[49m                                        ) -> Optional[str]:
[0m[49m[38;5;10m+    2443[0m:[38;5;10m[49m     """Backstop keyword scope check on generated output."""
[0m[49m[38;5;10m+    2444[0m:[38;5;10m[49m     lowered = text.lower()
[0m[49m[38;5;10m+    2445[0m:[38;5;10m[49m     diagnosis = [
[0m[49m[38;5;10m+    2446[0m:[38;5;10m[49m         "you have ", "you probably have",
[0m[49m[38;5;10m+    2447[0m:[38;5;10m[49m         "this is definitely a",
[0m[49m[38;5;10m+    2448[0m:[38;5;10m[49m         "diagnosed with",
[0m[49m[38;5;10m+    2449[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    2450[0m:[38;5;10m[49m     for phrase in diagnosis:
[0m[49m[38;5;10m+    2451[0m:[38;5;10m[49m         if phrase in lowered:
[0m[49m[38;5;10m+    2452[0m:[38;5;10m[49m             return "diagnosis_attempted"
[0m[49m[38;5;10m+    2453[0m:[38;5;10m[49m     treatment = [
[0m[49m[38;5;10m+    2454[0m:[38;5;10m[49m         "i recommend you take",
