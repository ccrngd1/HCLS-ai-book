[0m[49m[38;5;10m+     879[0m:[38;5;10m[49m                     auth_context: Optional[dict] = None,
[0m[49m[38;5;10m+     880[0m:[38;5;10m[49m                     deep_link_params: Optional[dict] = None,
[0m[49m[38;5;10m+     881[0m:[38;5;10m[49m                     language: str = "en-US") -> dict:
[0m[49m[38;5;10m+     882[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     883[0m:[38;5;10m[49m     Entry point for an inbound chat message.
[0m[49m[38;5;10m+     884[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     885[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     886[0m:[38;5;10m[49m         channel:            web_chat, institution_app_embed,
[0m[49m[38;5;10m+     887[0m:[38;5;10m[49m                             sms, voice.
[0m[49m[38;5;10m+     888[0m:[38;5;10m[49m         channel_session_id: Stable identifier from the channel.
[0m[49m[38;5;10m+     889[0m:[38;5;10m[49m         user_message:       The patient's typed message.
[0m[49m[38;5;10m+     890[0m:[38;5;10m[49m         auth_context:       Dict with `authenticated` (bool)
[0m[49m[38;5;10m+     891[0m:[38;5;10m[49m                             and `patient_id` (str) for an
[0m[49m[38;5;10m+     892[0m:[38;5;10m[49m                             authenticated session.
