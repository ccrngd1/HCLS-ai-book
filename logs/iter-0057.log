[0m[48;2;40;67;43m[39m+     540[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAmazon DynamoDB[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m session-state (current patient, current section, last command, staleness timestamp); command-audit (every command with intent, slots, confidences, outcome); configuration (intent taxonomy, read-write rules) [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+     541[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAmazon S3[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m Audio recording storage (when retained, with brief lifecycle); audit-log archive with Object Lock [38;2;192;197;206m|[K
