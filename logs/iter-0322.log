[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m │      IRB_approval_reference                              │
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m │           │                                              │
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m │           ▼                                              │
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m │   [Output: composed response with citations and tool-    │
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m │    call audit trail]                                     │
