[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m │           │                                              │
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m │           ▼                                              │
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m │   [Output: handoff event with structured payload to      │
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m │    research coordinator; coordinator-team-notification   │
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m │    event where consented]                                │
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m │                                                          │
