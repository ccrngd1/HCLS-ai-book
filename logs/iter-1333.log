[0m[49m[39m  471, 471[0m:[39m[49m   "description": "Type 2 diabetes mellitus with hyperglycemia",
[0m[49m[39m  472, 472[0m:[39m[49m   "query_type": "crosswalks",
[0m[49m[39m  473, 473[0m:[39m[49m   "target_system": "CPT",
[0m[49m[39m  474, 474[0m:[39m[49m   "results": [
[0m[49m[39m  475, 475[0m:[39m[49m     {"code": "CPT:82947", "description": "Glucose; quantitative, blood", "payer": "Medicare", "effective_date": "2024-01-01"},
[0m[49m[39m  476, 476[0m:[39m[49m     {"code": "CPT:83036", "description": "Hemoglobin; glycosylated (A1C)", "payer": "Medicare", "effective_date": "2024-01-01"},
[0m[49m[39m  477, 477[0m:[39m[49m     {"code": "CPT:80053", "description": "Comprehensive metabolic panel", "payer": "Medicare", "effective_date": "2024-01-01"}
[0m[49m[39m  478, 478[0m:[39m[49m   ],
[0m[49m[39m  479, 479[0m:[39m[49m   "total_results": 3,
