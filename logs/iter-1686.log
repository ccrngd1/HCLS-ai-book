[49m[39m  246, 246[0m:[39m[49m def _to_decimal(value) -> Decimal:
[0m[49m[39m  247, 247[0m:[39m[49m     """
[0m[49m[39m  248, 248[0m:[39m[49m     Coerce numeric input into Decimal for DynamoDB and for downstream math.
[0m[49m[39m  249, 249[0m:[39m[49m 
[0m[49m[39m  250, 250[0m:[39m[49m     DynamoDB rejects float. Always pass Decimal. Quantizing to four decimal
[0m[49m[39m  251, 251[0m:[39m[49m     places keeps the storage format predictable without losing meaningful
[0m[49m[39m  252, 252[0m:[39m[49m     precision for probabilities, rates, or z-scores.
[0m[49m[38;5;10m+      253[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      254[0m:[38;5;10m[49m     NaN and Inf are coerced to zero. This masks an upstream error (a feature
[0m[49m[38;5;10m+      255[0m:[38;5;10m[49m     computation that produced NaN means missing data or division by zero).
[0m[49m[38;5;10m+      256[0m:[38;5;10m[49m     In production, log a warning when this branch fires so the data
[0m[49m[38;5;10m+      257[0m:[38;5;10m[49m     engineering team can trace the root cause. The zero-coercion keeps the
[0m[49m[38;5;10m+      258[0m:[38;5;10m[49m     DynamoDB write from failing but loses the error signal.
[0m[49m[39m  253, 259[0m:[39m[49m     """
[0m[49m[39m  254, 260[0m:[39m[49m     if isinstance(value, Decimal):
[0m[49m[39m  255, 261[0m:[39m[49m         return value
[0m[49m[39m  256, 262[0m:[39m[49m     if value is None:
[0m[49m[39m  257, 263[0m:[39m[49m         return Decimal("0.0000")
[0m[49m[39m  258, 264[0m:[39m[49m     if isinstance(value, float) and (math.isnan(value) or math.isinf(value)):
[0m[49m[38;5;10m+      265[0m:[38;5;10m[49m         logger.warning("decimal_coercion_masked_nan_or_inf", extra={"raw_value": str(value)})
[0m[49m[39m  259, 266[0m:[39m[49m         return Decimal("0.0000")
[0m[49m[39m  260, 267[0m:[39m[49m     return Decimal(str(value)).quantize(Decimal("0.0001"))
