[0m[49m[38;5;10m+      677[0m:[38;5;10m[49m                 "ADD outreach_recent_wellness_count :neg_one, outreach_recent_total_count :neg_one",
[0m[49m[38;5;10m+      678[0m:[38;5;10m[49m                 values = { ":neg_one": -1 }
[0m[49m[38;5;10m+      679[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+      680[0m:[38;5;10m[49m             DynamoDB.UpdateItem(
