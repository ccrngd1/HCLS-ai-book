[0m[49m[38;5;10m+      661[0m:[38;5;10m[49m     // Pull recommendation-log rows from yesterday that lack any
[0m[49m[38;5;10m+      662[0m:[38;5;10m[49m     // engagement-stream confirmation.
[0m[49m[38;5;10m+      663[0m:[38;5;10m[49m     stale_recs = query_recommendation_log(
[0m[49m[38;5;10m+      664[0m:[38;5;10m[49m         run_date = run_date_minus_1,
[0m[49m[38;5;10m+      665[0m:[38;5;10m[49m         filter   = "NOT EXISTS engagement_events WHERE tracking_id = rec.tracking_id"
[0m[49m[38;5;10m+      666[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+      667[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      668[0m:[38;5;10m[49m     FOR rec in stale_recs:
[0m[49m[38;5;10m+      669[0m:[38;5;10m[49m         // Check the channel optimizer's dispatch status.
[0m[49m[38;5;10m+      670[0m:[38;5;10m[49m         dispatch_status = ChannelOptimizer.GetDispatchStatus(rec.tracking_id)
[0m[49m[38;5;10m+      671[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      672[0m:[38;5;10m[49m         IF dispatch_status == "never_dispatched" OR dispatch_status == "unknown":
[0m[49m[38;5;10m+      673[0m:[38;5;10m[49m             // Safe to decrement: the outreach was never actually sent.
[0m[49m[38;5;10m+      674[0m:[38;5;10m[49m             DynamoDB.UpdateItem(
[0m[49m[38;5;10m+      675[0m:[38;5;10m[49m                 "patient-profile",
