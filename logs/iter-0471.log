[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m     is already in a canonical-ish shape (the synthetic generator
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m     produced it that way), so the harmonization logic here mostly
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m     validates fields, enforces the payer-catalog mapping, and
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m     writes the output partitioned by payer and submission month.
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m     Production also handles 837 to 835 claim-line reconciliation,
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m     cross-payer take-back / refund linkage, and contract-effective-
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m     date filtering. The demo skips those for clarity but calls
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m     them out in the gap-to-production section.
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m     harmonized = []
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m     quarantined = 0
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m     for raw in raw_remits:
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m         if raw["payer_id"] not in PAYER_CATALOG:
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m             logger.warning("unknown payer id: %s", raw["payer_id"])
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m             quarantined += 1
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m         # Validate required fields. Production has a much richer
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m         # validation layer (X12 line-level checks, NPI validation,
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m         # CPT code presence, modifier consistency).
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m         if raw.get("submitted_date") is None or raw.get("billed_amount") is None:
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m             quarantined += 1
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m         # Filter by contract effective date. Records before the
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m         # current contract took effect must not feed the curves
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m         # because the dynamics changed.
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m         catalog       = PAYER_CATALOG[raw["payer_id"]]
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m         effective_d   = date.fromisoformat(catalog["contract_effective_date"])
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m         submitted_d   = date.fromisoformat(raw["submitted_date"])
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m         in_contract   = submitted_d >= effective_d
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m         # Compute the lag in days when the payment is observed;
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m         # leave None for right-censored records.
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m         if raw.get("payment_received_date") is not None:
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m             paid_d = date.fromisoformat(raw["payment_received_date"])
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m             payment_lag_days = (paid_d - submitted_d).days
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m             payment_lag_days = None
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m         rec = {
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m             "claim_id":               raw["claim_id"],
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m             "payer_id":               raw["payer_id"],
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m             "payer_class":            catalog["payer_class"],
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m             "submitted_date":         raw["submitted_date"],
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m             "billed_amount":          float(raw["billed_amount"]),
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m             "expected_allowed_amount": float(raw.get("expected_allowed_amount") or 0.0),
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m             "denial_flag":            bool(raw.get("denial_flag")),
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m             "denial_reason":          raw.get("denial_reason"),
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m             "payment_received_date":  raw.get("payment_received_date"),
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m             "payment_amount":         (float(raw["payment_amount"])
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m                                        if raw.get("payment_amount") is not None
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m                                        else None),
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m             "payment_lag_days":       payment_lag_days,
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m             "in_contract":            in_contract,
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m             "as_of":                  datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m         # Partition the harmonized output by payer and submission
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m         # month so downstream curve fitting can read it efficiently.
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m         sub_d = date.fromisoformat(rec["submitted_date"])
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m         s3_key = (f"payer={rec['payer_id']}/"
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m                   f"year={sub_d.year:04d}/month={sub_d.month:02d}/"
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m                   f"{rec['claim_id']}.json")
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m         s3.put_object(Bucket=bucket, Key=s3_key,
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m                       Body=json.dumps(rec))
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m         harmonized.append(rec)
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m         "Harmonized %d of %d raw records (%d quarantined)",
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m         len(harmonized), len(raw_remits), quarantined)
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m     return harmonized
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m ## Step 2: Fit Per-Payer Payment-Time Distributions
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m For each payer, compute the empirical payment-time distribution from the historical (submitted_ts, payment_received_ts) pairs. This is a survival problem: the event of interest is "claim paid," and open (still-unpaid) claims are right-censored. The Kaplan-Meier estimator handles censoring correctly by accounting for the at-risk population at each observed payment day. The denial-and-appeal sub-process is fit separately and folded into the composite curve.
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m class KaplanMeierEstimator:
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m     """Pedagogical Kaplan-Meier survival estimator with right-censoring.
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m     For revenue cycle: the survival function S(t) is the
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m     probability that a claim is still unpaid at day t after
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m     submission. The complement 1 - S(t) is the cumulative
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m     payment probability, which is what the Monte Carlo step in
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m     Step 3 samples from.
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m     Production uses lifelines.KaplanMeierFitter, which handles
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m     confidence intervals, point-wise variance estimation
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m     (Greenwood's formula), and the smoothing options the demo
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m     skips. The pure-Python version below makes the math visible.
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    717[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    718[0m:[38;5;10m[49m     name = "kaplan_meier"
[0m[49m[38;5;10m+    719[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    720[0m:[38;5;10m[49m     def __init__(self):
[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m         self.times      = []     # observed event/censor times (days)
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m         self.events     = []     # 1 if event (payment), 0 if censored
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m         self.curve      = []     # list of (day, survival_prob) tuples
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    725[0m:[38;5;10m[49m     def fit(self, durations, event_observed):
[0m[49m[38;5;10m+    726[0m:[38;5;10m[49m         """Fit the survival curve from (durations, event_observed) pairs.
[0m[49m[38;5;10m+    727[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    728[0m:[38;5;10m[49m         durations: list of integer days from submission to either
[0m[49m[38;5;10m+    729[0m:[38;5;10m[49m                    payment (event=1) or as-of-now (event=0).
[0m[49m[38;5;10m+    730[0m:[38;5;10m[49m         event_observed: list of 0/1 flags matching durations.
[0m[49m[38;5;10m+    731[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+    732[0m:[38;5;10m[49m         if len(durations) != len(event_observed):
[0m[49m[38;5;10m+    733[0m:[38;5;10m[49m             raise ValueError("durations and event_observed must align")
[0m[49m[38;5;10m+    734[0m:[38;5;10m[49m         if not durations:
[0m[49m[38;5;10m+    735[0m:[38;5;10m[49m             self.curve = [(0, 1.0)]
[0m[49m[38;5;10m+    736[0m:[38;5;10m[49m             return self
[0m[49m[38;5;10m+    737[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    738[0m:[38;5;10m[49m         pairs = sorted(zip(durations, event_observed))
[0m[49m[38;5;10m+    739[0m:[38;5;10m[49m         self.times  = [p[0] for p in pairs]
[0m[49m[38;5;10m+    740[0m:[38;5;10m[49m         self.events = [p[1] for p in pairs]
[0m[49m[38;5;10m+    741[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    742[0m:[38;5;10m[49m         # Group by unique day. At each day, count the number of
[0m[49m[38;5;10m+    743[0m:[38;5;10m[49m         # events (claims paid) and the at-risk population (claims
[0m[49m[38;5;10m+    744[0m:[38;5;10m[49m         # not yet paid, not yet censored before that day).
[0m[49m[38;5;10m+    745[0m:[38;5;10m[49m         unique_days = sorted(set(self.times))
[0m[49m[38;5;10m+    746[0m:[38;5;10m[49m         n_at_risk   = len(self.times)
[0m[49m[38;5;10m+    747[0m:[38;5;10m[49m         survival    = 1.0
[0m[49m[38;5;10m+    748[0m:[38;5;10m[49m         curve       = [(0, 1.0)]
[0m[49m[38;5;10m+    749[0m:[38;5;10m[49m         idx_pos     = 0
[0m[49m[38;5;10m+    750[0m:[38;5;10m[49m         for day in unique_days:
[0m[49m[38;5;10m+    751[0m:[38;5;10m[49m             d_count    = 0
[0m[49m[38;5;10m+    752[0m:[38;5;10m[49m             c_count    = 0
[0m[49m[38;5;10m+    753[0m:[38;5;10m[49m             while idx_pos < len(pairs) and pairs[idx_pos][0] == day:
[0m[49m[38;5;10m+    754[0m:[38;5;10m[49m                 if pairs[idx_pos][1] == 1:
[0m[49m[38;5;10m+    755[0m:[38;5;10m[49m                     d_count += 1
[0m[49m[38;5;10m+    756[0m:[38;5;10m[49m                 else:
[0m[49m[38;5;10m+    757[0m:[38;5;10m[49m                     c_count += 1
[0m[49m[38;5;10m+    758[0m:[38;5;10m[49m                 idx_pos += 1
[0m[49m[38;5;10m+    759[0m:[38;5;10m[49m             if n_at_risk > 0 and d_count > 0:
[0m[49m[38;5;10m+    760[0m:[38;5;10m[49m                 survival *= (1.0 - d_count / n_at_risk)
[0m[49m[38;5;10m+    761[0m:[38;5;10m[49m             curve.append((day, survival))
[0m[49m[38;5;10m+    762[0m:[38;5;10m[49m             n_at_risk -= (d_count + c_count)
[0m[49m[38;5;10m+    763[0m:[38;5;10m[49m         # Anchor a long-tail terminal point so the cumulative
[0m[49m[38;5;10m+    764[0m:[38;5;10m[49m         # probability function is well-defined across the
[0m[49m[38;5;10m+    765[0m:[38;5;10m[49m         # forecast horizon. If there are right-censored claims
[0m[49m[38;5;10m+    766[0m:[38;5;10m[49m         # remaining, treat them as never-paying for forecast
[0m[49m[38;5;10m+    767[0m:[38;5;10m[49m         # purposes; the bad-debt model handles those separately.
[0m[49m[38;5;10m+    768[0m:[38;5;10m[49m         if n_at_risk > 0:
[0m[49m[38;5;10m+    769[0m:[38;5;10m[49m             curve.append((max(unique_days) + 365, survival))
[0m[49m[38;5;10m+    770[0m:[38;5;10m[49m         self.curve = curve
[0m[49m[38;5;10m+    771[0m:[38;5;10m[49m         return self
[0m[49m[38;5;10m+    772[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    773[0m:[38;5;10m[49m     def survival_at(self, day):
[0m[49m[38;5;10m+    774[0m:[38;5;10m[49m         """Interpolate the survival probability at an arbitrary day."""
[0m[49m[38;5;10m+    775[0m:[38;5;10m[49m         if not self.curve:
[0m[49m[38;5;10m+    776[0m:[38;5;10m[49m             return 1.0
[0m[49m[38;5;10m+    777[0m:[38;5;10m[49m         if day <= self.curve[0][0]:
[0m[49m[38;5;10m+    778[0m:[38;5;10m[49m             return self.curve[0][1]
[0m[49m[38;5;10m+    779[0m:[38;5;10m[49m         if day >= self.curve[-1][0]:
[0m[49m[38;5;10m+    780[0m:[38;5;10m[49m             return self.curve[-1][1]
[0m[49m[38;5;10m+    781[0m:[38;5;10m[49m         # Step function: find the largest tabulated day <= query.
[0m[49m[38;5;10m+    782[0m:[38;5;10m[49m         prev = self.curve[0][1]
[0m[49m[38;5;10m+    783[0m:[38;5;10m[49m         for d, s in self.curve:
[0m[49m[38;5;10m+    784[0m:[38;5;10m[49m             if d > day:
[0m[49m[38;5;10m+    785[0m:[38;5;10m[49m                 return prev
[0m[49m[38;5;10m+    786[0m:[38;5;10m[49m             prev = s
[0m[49m[38;5;10m+    787[0m:[38;5;10m[49m         return prev
[0m[49m[38;5;10m+    788[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    789[0m:[38;5;10m[49m     def cumulative_payment_prob(self, day):
[0m[49m[38;5;10m+    790[0m:[38;5;10m[49m         """1 - S(t): probability that the claim has paid by day t."""
[0m[49m[38;5;10m+    791[0m:[38;5;10m[49m         return 1.0 - self.survival_at(day)
[0m[49m[38;5;10m+    792[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    793[0m:[38;5;10m[49m     def sample_payment_day(self, max_horizon_days, rng):
[0m[49m[38;5;10m+    794[0m:[38;5;10m[49m         """Inverse-CDF sample of a payment day.
[0m[49m[38;5;10m+    795[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    796[0m:[38;5;10m[49m         Returns an integer day in [1, max_horizon_days], or None
[0m[49m[38;5;10m+    797[0m:[38;5;10m[49m         if the sampled u-quantile lies above S(max_horizon_days)
[0m[49m[38;5;10m+    798[0m:[38;5;10m[49m         (interpreted as "claim does not pay within the horizon").
[0m[49m[38;5;10m+    799[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+    800[0m:[38;5;10m[49m         u = rng.random()
[0m[49m[38;5;10m+    801[0m:[38;5;10m[49m         # Inverse-CDF on (1 - S(t)): find the smallest day where
[0m[49m[38;5;10m+    802[0m:[38;5;10m[49m         # cumulative payment probability >= u.
[0m[49m[38;5;10m+    803[0m:[38;5;10m[49m         if u >= self.cumulative_payment_prob(max_horizon_days):
[0m[49m[38;5;10m+    804[0m:[38;5;10m[49m             # Beyond horizon: returned as "no payment in window".
[0m[49m[38;5;10m+    805[0m:[38;5;10m[49m             if u >= self.cumulative_payment_prob(self.curve[-1][0]):
[0m[49m[38;5;10m+    806[0m:[38;5;10m[49m                 return None
