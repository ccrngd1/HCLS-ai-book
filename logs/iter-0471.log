[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m def _draw_payment_lag(payer_id, rng):
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m     """Sample a payment-lag-in-days for a single claim from a payer-shaped distribution.
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m     Each payer class has a different "shape" of payment lag.
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m     Medicare FFS pays on a tight, predictable schedule centered
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m     around 14-21 days. State Medicaid is wider with a longer
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m     right tail. Commercial payers vary; the BCBS plan in this
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m     demo pays a bit faster than the national plan. Self-pay has
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m     a very long, lognormal-like tail that captures statement
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m     cycles plus the realities of patient payment behavior.
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m     Production fits these distributions empirically from
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m     historical 837 / 835 pairs; the demo uses analytic shapes
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m     so the synthetic data is reproducible.
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m     if payer_id == "MEDI-FFS-001":
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m         # Tight gaussian-ish around 17 days
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m         return max(1, int(rng.gauss(17, 4)))
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m     if payer_id == "MCAID-STATE-001":
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m         # Wider, slight right skew (lognormal approximation)
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m         return max(1, int(math.exp(rng.gauss(math.log(28), 0.35))))
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m     if payer_id == "COMM-BCBS-001":
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m         return max(1, int(rng.gauss(22, 6)))
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m     if payer_id == "COMM-NATIONAL-001":
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m         return max(1, int(rng.gauss(31, 9)))
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m     if payer_id == "SELF-PAY-001":
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m         # Very long right tail
