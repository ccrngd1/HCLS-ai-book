[0m[49m[38;5;10m+    1309[0m:[38;5;10m[49m         for p, c in curves.items()
[0m[49m[38;5;10m+    1310[0m:[38;5;10m[49m         if c is not None
[0m[49m[38;5;10m+    1311[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1312[0m:[38;5;10m[49m     s3.put_object(
