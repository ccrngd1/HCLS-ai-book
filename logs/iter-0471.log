[0m[49m[38;5;10m+    1317[0m:[38;5;10m[49m     # --- Step 3: Monte Carlo simulation ---
[0m[49m[38;5;10m+    1318[0m:[38;5;10m[49m     print("\n[step 3] simulate_cash_flow")
[0m[49m[38;5;10m+    1319[0m:[38;5;10m[49m     per_week_samples, aging_summary = simulate_cash_flow(
[0m[49m[38;5;10m+    1320[0m:[38;5;10m[49m         open_harmonized, curves, PAYER_CATALOG,
