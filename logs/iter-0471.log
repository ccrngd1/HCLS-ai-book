[0m[49m[38;5;10m+    1010[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    1011[0m:[38;5;10m[49m         bucket = _ar_aging_bucket(claim["submitted_date"], as_of_dt)
[0m[49m[38;5;10m+    1012[0m:[38;5;10m[49m         aging_summary[bucket][claim["payer_id"]] += claim.get(
[0m[49m[38;5;10m+    1013[0m:[38;5;10m[49m             "expected_allowed_amount", 0.0)
[0m[49m[38;5;10m+    1014[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1015[0m:[38;5;10m[49m         for s_idx in range(n_samples):
[0m[49m[38;5;10m+    1016[0m:[38;5;10m[49m             pay_date, amt = simulate_claim_payment(
