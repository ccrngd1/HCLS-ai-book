[0m[49m[38;5;10m+    1292[0m:[38;5;10m[49m         med = c.get("median_paid_lag")
[0m[49m[38;5;10m+    1293[0m:[38;5;10m[49m         med_str = f"{med}" if med is not None else "n/a"
