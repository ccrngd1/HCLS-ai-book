[0m[49m[38;5;10m+    1296[0m:[38;5;10m[49m               f"denial={c['denial_rate']:.2%} median_lag={med_str}")
[0m[49m[38;5;10m+    1297[0m:[38;5;10m[49m     # Persist the curves to S3 so SageMaker training jobs and
