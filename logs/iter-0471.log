[0m[49m[38;5;10m+    1058[0m:[38;5;10m[49m     # cross-payer correlation that Independent percentile
[0m[49m[38;5;10m+    1059[0m:[38;5;10m[49m     # aggregation would lose.
[0m[49m[38;5;10m+    1060[0m:[38;5;10m[49m     payers_seen = set()
[0m[49m[38;5;10m+    1061[0m:[38;5;10m[49m     for (payer_id, week_idx) in per_week_samples.keys():
[0m[49m[38;5;10m+    1062[0m:[38;5;10m[49m         payers_seen.add(payer_id)
[0m[49m[38;5;10m+    1063[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1064[0m:[38;5;10m[49m     # Per-payer per-week records.
[0m[49m[38;5;10m+    1065[0m:[38;5;10m[49m     for payer_id in sorted(payers_seen):
[0m[49m[38;5;10m+    1066[0m:[38;5;10m[49m         for week_idx in range(horizon_weeks):
[0m[49m[38;5;10m+    1067[0m:[38;5;10m[49m             samples = per_week_samples.get((payer_id, week_idx))
[0m[49m[38;5;10m+    1068[0m:[38;5;10m[49m             if samples is None:
[0m[49m[38;5;10m+    1069[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    1070[0m:[38;5;10m[49m             mean_v   = sum(samples) / len(samples)
[0m[49m[38;5;10m+    1071[0m:[38;5;10m[49m             sorted_s = sorted(samples)
[0m[49m[38;5;10m+    1072[0m:[38;5;10m[49m             p10 = sorted_s[int(0.10 * len(sorted_s))]
[0m[49m[38;5;10m+    1073[0m:[38;5;10m[49m             p50 = sorted_s[int(0.50 * len(sorted_s))]
[0m[49m[38;5;10m+    1074[0m:[38;5;10m[49m             p90 = sorted_s[int(0.90 * len(sorted_s))]
[0m[49m[38;5;10m+    1075[0m:[38;5;10m[49m             forecasts.append({
[0m[49m[38;5;10m+    1076[0m:[38;5;10m[49m                 "forecast_week":     week_start_dates[week_idx].isoformat(),
[0m[49m[38;5;10m+    1077[0m:[38;5;10m[49m                 "week_index":        week_idx,
[0m[49m[38;5;10m+    1078[0m:[38;5;10m[49m                 "payer_id":          payer_id,
[0m[49m[38;5;10m+    1079[0m:[38;5;10m[49m                 "payer_display":     PAYER_CATALOG[payer_id]["display"],
[0m[49m[38;5;10m+    1080[0m:[38;5;10m[49m                 "expected_cash":     round(mean_v, 2),
[0m[49m[38;5;10m+    1081[0m:[38;5;10m[49m                 "p10_cash":          round(p10, 2),
[0m[49m[38;5;10m+    1082[0m:[38;5;10m[49m                 "p50_cash":          round(p50, 2),
[0m[49m[38;5;10m+    1083[0m:[38;5;10m[49m                 "p90_cash":          round(p90, 2),
[0m[49m[38;5;10m+    1084[0m:[38;5;10m[49m                 "sample_count":      len(samples),
[0m[49m[38;5;10m+    1085[0m:[38;5;10m[49m                 "generated_at":      as_of_dt.isoformat(),
[0m[49m[38;5;10m+    1086[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    1087[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1088[0m:[38;5;10m[49m     # All-payer aggregate per week (sample-wise summing).
[0m[49m[38;5;10m+    1089[0m:[38;5;10m[49m     n_samples = None
[0m[49m[38;5;10m+    1090[0m:[38;5;10m[49m     if per_week_samples:
[0m[49m[38;5;10m+    1091[0m:[38;5;10m[49m         n_samples = len(next(iter(per_week_samples.values())))
[0m[49m[38;5;10m+    1092[0m:[38;5;10m[49m     if n_samples:
[0m[49m[38;5;10m+    1093[0m:[38;5;10m[49m         for week_idx in range(horizon_weeks):
[0m[49m[38;5;10m+    1094[0m:[38;5;10m[49m             sample_totals = [0.0] * n_samples
[0m[49m[38;5;10m+    1095[0m:[38;5;10m[49m             for (payer_id, w_idx), vals in per_week_samples.items():
