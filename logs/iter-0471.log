[0m[49m[38;5;10m+    1108[0m:[38;5;10m[49m                 "payer_id":          "ALL",
[0m[49m[38;5;10m+    1109[0m:[38;5;10m[49m                 "payer_display":     "All Payers (aggregate)",
[0m[49m[38;5;10m+    1110[0m:[38;5;10m[49m                 "expected_cash":     round(mean_v, 2),
[0m[49m[38;5;10m+    1111[0m:[38;5;10m[49m                 "p10_cash":          round(p10, 2),
[0m[49m[38;5;10m+    1112[0m:[38;5;10m[49m                 "p50_cash":          round(p50, 2),
[0m[49m[38;5;10m+    1113[0m:[38;5;10m[49m                 "p90_cash":          round(p90, 2),
[0m[49m[38;5;10m+    1114[0m:[38;5;10m[49m                 "sample_count":      n_samples,
[0m[49m[38;5;10m+    1115[0m:[38;5;10m[49m                 "generated_at":      as_of_dt.isoformat(),
[0m[49m[38;5;10m+    1116[0m:[38;5;10m[49m             })
