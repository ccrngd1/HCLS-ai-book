[0m[49m[38;5;10m+    1101[0m:[38;5;10m[49m             sorted_s = sorted(sample_totals)
[0m[49m[38;5;10m+    1102[0m:[38;5;10m[49m             p10 = sorted_s[int(0.10 * n_samples)]
[0m[49m[38;5;10m+    1103[0m:[38;5;10m[49m             p50 = sorted_s[int(0.50 * n_samples)]
[0m[49m[38;5;10m+    1104[0m:[38;5;10m[49m             p90 = sorted_s[int(0.90 * n_samples)]
