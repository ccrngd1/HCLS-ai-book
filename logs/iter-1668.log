[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m FUNCTION check_cache(original_text, target_grade):
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m     // Compute a stable key from the source text and reading level target.
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m     // SHA-256 is deterministic and collision-resistant enough for a cache key.
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m     cache_key = SHA256(original_text + "|" + target_grade)
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m     // Look up in the results table. DynamoDB GetItem is single-digit
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m     // millisecond latency vs. 3-6 seconds for the full pipeline.
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m     cached = GET from "simplified-documents" WHERE cache_key = cache_key
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m     IF cached exists AND cached.simplified_text is not empty:
