[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m     dbp_6h = np.array(vitals["dbp"][-window_6h:])
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m     features["map_min_6h"] = float(np.nanmin(vitals["map"][-window_6h:]))
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m     features["map_max_6h"] = float(np.nanmax(vitals["map"][-window_6h:]))
