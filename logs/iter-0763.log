[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m     "pao2_latest", "ph_latest", "bicarbonate_latest",
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m     "sodium_latest", "potassium_latest", "glucose_latest",
