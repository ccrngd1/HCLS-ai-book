[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m         # Missing indicator
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m         if lab_name in ("lactate", "pao2"):
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m             features[f"{lab_name}_missing"] = 0  # synthetic data always has values
