[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m     # Medications
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m     medications = {
