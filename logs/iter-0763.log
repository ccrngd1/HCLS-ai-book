[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m ## Step 1: Generate Synthetic ICU Data
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m *The main recipe's Step 1 queries HealthLake for real patient data. Here we generate realistic synthetic ICU data so you can run the full pipeline locally without a FHIR store or real PHI. The distributions are loosely based on published ICU population statistics.*
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m def generate_synthetic_icu_patient(patient_id: str, hours_in_icu: float = 72.0,
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m                                     severity: str = "moderate") -> dict:
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m     Generate a synthetic ICU patient with realistic vital signs, labs, and metadata.
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m     This is for demonstration only. Real patients are messier: values arrive
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m     at irregular intervals, labs are missing for clinical reasons, and the
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m     temporal patterns are far more complex than what we simulate here.
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m         patient_id: An identifier for this synthetic patient.
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m         hours_in_icu: How many hours since ICU admission. Affects data volume.
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m         severity: One of "mild", "moderate", "severe". Controls how abnormal
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m                   the generated values are.
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m         A dictionary mimicking what you'd get from a HealthLake query:
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m         vitals, labs, medications, demographics, and comorbidities.
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m     rng = np.random.default_rng(hash(patient_id) % (2**32))
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m     # Severity multipliers shift vital signs and labs toward abnormal ranges.
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m     severity_configs = {
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m         "mild":     {"hr_base": 80,  "sbp_base": 120, "lactate_base": 1.2, "pf_base": 350},
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m         "moderate": {"hr_base": 100, "sbp_base": 100, "lactate_base": 2.8, "pf_base": 220},
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m         "severe":   {"hr_base": 120, "sbp_base": 80,  "lactate_base": 5.5, "pf_base": 110},
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m     cfg = severity_configs[severity]
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m     # Generate vital sign time series (one reading every 15 minutes)
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m     n_vitals = int(hours_in_icu * 4)  # 4 readings per hour
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m     timestamps = [datetime.now(timezone.utc) - timedelta(hours=hours_in_icu)
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m                   + timedelta(minutes=15 * i) for i in range(n_vitals)]
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m     vitals = {
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m         "heart_rate": cfg["hr_base"] + rng.normal(0, 12, n_vitals),
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m         "sbp": cfg["sbp_base"] + rng.normal(0, 15, n_vitals),
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m         "dbp": (cfg["sbp_base"] * 0.6) + rng.normal(0, 8, n_vitals),
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m         "map": (cfg["sbp_base"] * 0.73) + rng.normal(0, 10, n_vitals),
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m         "resp_rate": 18 + rng.normal(0, 4, n_vitals),
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m         "spo2": np.clip(97 - (3 if severity == "severe" else 0) + rng.normal(0, 2, n_vitals), 70, 100),
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m         "temp": 37.2 + rng.normal(0, 0.5, n_vitals),
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m         "timestamps": timestamps,
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m     # Add a trend for severe patients: things get worse over time
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m     if severity == "severe":
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m         trend = np.linspace(0, 15, n_vitals)
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m         vitals["heart_rate"] += trend
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m         vitals["sbp"] -= trend * 0.5
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m     # Generate lab values (typically 4-8 draws per day in ICU)
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m     n_labs = int(hours_in_icu / 6)  # roughly every 6 hours
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m     lab_timestamps = [datetime.now(timezone.utc) - timedelta(hours=hours_in_icu)
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m                       + timedelta(hours=6 * i) for i in range(n_labs)]
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m     labs = {
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m         "lactate": np.clip(cfg["lactate_base"] + rng.normal(0, 0.8, n_labs), 0.5, 20),
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m         "creatinine": np.clip(1.0 + (1.5 if severity == "severe" else 0.3) + rng.normal(0, 0.3, n_labs), 0.3, 12),
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m         "bilirubin": np.clip(0.8 + (3.0 if severity == "severe" else 0.2) + rng.normal(0, 0.5, n_labs), 0.1, 30),
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m         "platelets": np.clip(200 - (120 if severity == "severe" else 20) + rng.normal(0, 30, n_labs), 5, 500),
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m         "wbc": np.clip(10 + (8 if severity == "severe" else 2) + rng.normal(0, 3, n_labs), 0.5, 50),
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m         "hemoglobin": np.clip(11 - (3 if severity == "severe" else 0.5) + rng.normal(0, 1, n_labs), 4, 18),
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m         "pao2": np.clip(cfg["pf_base"] * 0.4 + rng.normal(0, 10, n_labs), 40, 500),
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m         "ph": np.clip(7.38 - (0.1 if severity == "severe" else 0) + rng.normal(0, 0.03, n_labs), 6.8, 7.6),
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m         "bicarbonate": np.clip(24 - (6 if severity == "severe" else 1) + rng.normal(0, 2, n_labs), 8, 40),
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m         "sodium": np.clip(140 + rng.normal(0, 3, n_labs), 120, 160),
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m         "potassium": np.clip(4.2 + (0.8 if severity == "severe" else 0) + rng.normal(0, 0.4, n_labs), 2.5, 7.0),
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m         "glucose": np.clip(130 + (50 if severity == "severe" else 10) + rng.normal(0, 30, n_labs), 40, 500),
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m         "inr": np.clip(1.1 + (0.8 if severity == "severe" else 0.1) + rng.normal(0, 0.2, n_labs), 0.8, 6.0),
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m         "bun": np.clip(20 + (30 if severity == "severe" else 5) + rng.normal(0, 5, n_labs), 5, 120),
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m         "timestamps": lab_timestamps,
