[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m     # --- Demographics ---
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m     features["age"] = demo["age"]
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m     features["sex_male"] = demo["sex_male"]
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m     features["hours_in_icu"] = raw_data["hours_in_icu"]
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m     features["surgical_admission"] = demo["surgical_admission"]
