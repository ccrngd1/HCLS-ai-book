[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m     # --- Derived physiological indices ---
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m     fio2 = meds["fio2"] if meds["fio2"] > 0 else 0.21
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m     pao2 = features.get("pao2_latest", np.nan)
