[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m ## Step 2: Engineer Temporal Features
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m *The main recipe's Step 2 transforms raw time-series clinical data into model-ready features. This includes temporal aggregations, trend calculations, derived physiological indices, and SOFA component scores. The key insight: a heart rate of 110 means something completely different depending on whether it's been 110 for three days or jumped from 70 in the last hour.*
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m def compute_sofa_respiratory(pf_ratio: float) -> int:
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m     """Compute SOFA respiratory component from P/F ratio."""
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m     if pf_ratio is None or np.isnan(pf_ratio):
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m         return 0  # can't score without data
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m     for threshold, score in SOFA_RESPIRATORY_THRESHOLDS:
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m         if pf_ratio >= threshold:
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m             return score
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m     return 4
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m def compute_sofa_coagulation(platelets: float) -> int:
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m     """Compute SOFA coagulation component from platelet count."""
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     if platelets is None or np.isnan(platelets):
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m         return 0
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m     for threshold, score in SOFA_COAGULATION_THRESHOLDS:
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m         if platelets >= threshold:
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m             return score
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m     return 4
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m def compute_sofa_liver(bilirubin: float) -> int:
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m     """Compute SOFA liver component from bilirubin."""
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m     if bilirubin is None or np.isnan(bilirubin):
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m         return 0
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m     for threshold, score in SOFA_LIVER_THRESHOLDS:
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m         if bilirubin < threshold:
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m             return score
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m     return 4
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m def compute_sofa_cardiovascular(mean_map: float, norepi_dose: float) -> int:
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m     Compute SOFA cardiovascular component.
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m     Based on MAP and vasopressor requirements.
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m     if norepi_dose > 0.1:
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m         return 4
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m     elif norepi_dose > 0:
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m         return 3
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m     elif mean_map is not None and mean_map < 70:
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m         return 1
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m     return 0
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m def compute_trend(values: np.ndarray) -> float:
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m     Compute linear trend (slope) of a time series using least squares.
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m     Returns slope in units-per-hour. Positive = increasing.
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m     if len(values) < 2:
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m         return 0.0
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m     x = np.arange(len(values), dtype=float)
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m     # Simple linear regression: slope = cov(x,y) / var(x)
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m     slope = np.polyfit(x, values, 1)[0]
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m     return float(slope)
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m def engineer_features(raw_data: dict) -> dict:
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m     Transform raw ICU data into the feature vector the model expects.
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m     This is where clinical knowledge meets data engineering. Each feature
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m     is chosen because it has demonstrated predictive value for ICU mortality
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m     in published literature or in our own model development.
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m         raw_data: Output of generate_synthetic_icu_patient (or a real HealthLake query).
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m         A dictionary mapping feature names to float values, matching FEATURE_SCHEMA.
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m     vitals = raw_data["vitals"]
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m     labs = raw_data["labs"]
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m     meds = raw_data["medications"]
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m     demo = raw_data["demographics"]
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m     comorbidities = raw_data["comorbidities"]
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m     features = {}
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m     # --- Vital sign summaries (last 6 hours) ---
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m     # In a real system, you'd filter by timestamp. Here we take the last 24 readings
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m     # (6 hours * 4 readings/hour) as our 6-hour window.
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m     window_6h = 24  # last 24 readings = 6 hours at 15-min intervals
