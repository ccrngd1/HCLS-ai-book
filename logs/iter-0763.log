[0m[49m[38;5;10m+     31[0m:[38;5;10m[49m import pandas as pd
[0m[49m[38;5;10m+     32[0m:[38;5;10m[49m from datetime import datetime, timezone, timedelta
[0m[49m[38;5;10m+     33[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+     34[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+     35[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     36[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+     37[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+     38[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     39[0m:[38;5;10m[49m # Feature schema: the ordered list of features the model expects.
