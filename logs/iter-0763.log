[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m         values = np.array(vitals[vital_name][-window_6h:])
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m         features[f"{vital_name}_min_6h"] = float(np.nanmin(values))
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m         features[f"{vital_name}_max_6h"] = float(np.nanmax(values))
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m         features[f"{vital_name}_mean_6h"] = float(np.nanmean(values))
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m         if vital_name in ("heart_rate", "sbp"):
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m             features[f"{vital_name}_std_6h"] = float(np.nanstd(values))
