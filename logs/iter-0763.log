[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m     "sofa_respiratory", "sofa_coagulation", "sofa_liver",
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m     "sofa_cardiovascular", "sofa_cns", "sofa_renal",
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m     "sofa_total", "sofa_trend_24h",
