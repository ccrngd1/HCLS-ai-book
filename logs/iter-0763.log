[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m # SOFA score thresholds (used in feature engineering)
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m # These are the standard SOFA scoring criteria from Vincent et al. 1996.
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m SOFA_RESPIRATORY_THRESHOLDS = [
