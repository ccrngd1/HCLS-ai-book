[0m[49m[38;5;10m+     41[0m:[38;5;10m[49m # Changing the order or adding/removing features without retraining = garbage predictions.
[0m[49m[38;5;10m+     42[0m:[38;5;10m[49m FEATURE_SCHEMA = [
[0m[49m[38;5;10m+     43[0m:[38;5;10m[49m     # Vital sign summaries (6-hour window)
[0m[49m[38;5;10m+     44[0m:[38;5;10m[49m     "heart_rate_min_6h", "heart_rate_max_6h", "heart_rate_mean_6h", "heart_rate_std_6h",
[0m[49m[38;5;10m+     45[0m:[38;5;10m[49m     "sbp_min_6h", "sbp_max_6h", "sbp_mean_6h", "sbp_std_6h",
[0m[49m[38;5;10m+     46[0m:[38;5;10m[49m     "map_min_6h", "map_max_6h", "map_mean_6h",
