[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m         "vasopressor_count": 2 if severity == "severe" else (1 if severity == "moderate" and rng.random() > 0.6 else 0),
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m         "norepinephrine_dose": 0.15 if severity == "severe" else (0.05 if severity == "moderate" else 0.0),
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m         "on_mechanical_ventilation": severity in ("severe", "moderate"),
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m         "fio2": 0.80 if severity == "severe" else (0.50 if severity == "moderate" else 0.21),
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m     }
