[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m ]  # P/F ratio thresholds -> SOFA points
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m SOFA_COAGULATION_THRESHOLDS = [
