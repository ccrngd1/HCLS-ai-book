[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m ]  # Platelets (x10^3/uL) -> SOFA points
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m SOFA_LIVER_THRESHOLDS = [
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m     (1.2, 0), (2.0, 1), (6.0, 2), (12.0, 3), (float("inf"), 4)
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m ]  # Bilirubin (mg/dL) -> SOFA points
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m # Model configuration
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m MODEL_ENDPOINT_NAME = "icu-mortality-model-v2"
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m DYNAMODB_TABLE_NAME = "icu-mortality-predictions"
