[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m ## Step 3: Train a Mortality Model (Local Demo)
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m *In production, model training happens in SageMaker with historical ICU data (thousands of admissions with known outcomes). Here we train a small XGBoost model on synthetic data so you can see the full pipeline end-to-end. The model won't be clinically valid, but the code patterns are identical to what you'd use with real data.*
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m from xgboost import XGBClassifier
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m from sklearn.model_selection import train_test_split
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m from sklearn.calibration import CalibratedClassifierCV
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m from sklearn.metrics import roc_auc_score, brier_score_loss
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m def generate_training_dataset(n_patients: int = 2000) -> tuple[pd.DataFrame, np.ndarray]:
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m     Generate a synthetic training dataset of ICU patients with mortality outcomes.
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m     The outcome (died vs. survived) is determined by severity:
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m     - mild patients: ~5% mortality
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m     - moderate patients: ~25% mortality
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m     - severe patients: ~60% mortality
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m     This is a gross simplification. Real mortality depends on hundreds of factors
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m     and their interactions. But it gives us a dataset where the model can learn
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m     that sicker-looking patients are more likely to die, which is enough to
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m     demonstrate the pipeline.
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m     rng = np.random.default_rng(42)
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m     records = []
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m     outcomes = []
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m     for i in range(n_patients):
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m         # Assign severity with realistic ICU distribution
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m         severity_roll = rng.random()
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m         if severity_roll < 0.35:
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m             severity = "mild"
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m             mortality_prob = 0.05
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m         elif severity_roll < 0.75:
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m             severity = "moderate"
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m             mortality_prob = 0.25
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m             severity = "severe"
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m             mortality_prob = 0.60
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m         hours = float(rng.integers(12, 168))  # 12 hours to 7 days
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m         patient = generate_synthetic_icu_patient(f"train-{i}", hours, severity)
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m         features = engineer_features(patient)
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m         # Ensure feature vector matches schema
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m         row = [features.get(f, np.nan) for f in FEATURE_SCHEMA]
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m         records.append(row)
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m         # Determine outcome (with some noise)
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m         died = int(rng.random() < mortality_prob)
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m         outcomes.append(died)
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m     df = pd.DataFrame(records, columns=FEATURE_SCHEMA)
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m     labels = np.array(outcomes)
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m     logger.info("Generated %d patients. Mortality rate: %.1f%%",
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m                 n_patients, 100 * labels.mean())
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m     return df, labels
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m def train_mortality_model(X: pd.DataFrame, y: np.ndarray) -> tuple:
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m     Train an XGBoost mortality model with isotonic calibration.
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m     Returns both the raw model (for SHAP explanations) and the calibrated
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m     model (for honest probability estimates).
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m     In production, this runs in a SageMaker Training Job with:
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m     - Hyperparameter tuning (Bayesian optimization over learning rate, depth, etc.)
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m     - Cross-validation for stability estimates
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m     - Stratified splits to preserve mortality rate in each fold
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m     - Subgroup performance analysis before promoting to production
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m     X_train, X_test, y_train, y_test = train_test_split(
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m         X, y, test_size=0.25, random_state=42, stratify=y
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m     # XGBoost with conservative hyperparameters.
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m     # In production you'd tune these with SageMaker Automatic Model Tuning.
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m     raw_model = XGBClassifier(
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m         n_estimators=200,
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m         max_depth=5,
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m         learning_rate=0.05,
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m         subsample=0.8,
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m         colsample_bytree=0.8,
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m         min_child_weight=10,  # conservative to avoid overfitting on small groups
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m         reg_alpha=0.1,
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m         reg_lambda=1.0,
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m         use_label_encoder=False,
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m         eval_metric="logloss",
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m         random_state=42,
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m     raw_model.fit(X_train, y_train)
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m     # Evaluate discrimination (AUC)
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m     y_pred_raw = raw_model.predict_proba(X_test)[:, 1]
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m     auc = roc_auc_score(y_test, y_pred_raw)
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m     brier = brier_score_loss(y_test, y_pred_raw)
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m     logger.info("Raw model - AUC: %.3f, Brier: %.3f", auc, brier)
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m     # Calibrate using isotonic regression on the test set.
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m     # This makes the predicted probabilities honest: if the model says 30%,
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m     # approximately 30% of those patients should actually die.
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m     # In production, calibration is done on a held-out local dataset, not the test set.
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m     calibrated_model = CalibratedClassifierCV(
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m         raw_model, method="isotonic", cv="prefit"
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m     calibrated_model.fit(X_test, y_test)
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m     y_pred_cal = calibrated_model.predict_proba(X_test)[:, 1]
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m     brier_cal = brier_score_loss(y_test, y_pred_cal)
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m     logger.info("Calibrated model - Brier: %.3f (lower is better)", brier_cal)
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m     return raw_model, calibrated_model, X_test, y_test
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m ## Step 4: Score a Patient and Explain the Prediction
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m *The main recipe's Steps 3 and 4 invoke a SageMaker endpoint and apply local calibration. Here we use the locally trained model directly. The SHAP explanation is the critical piece: clinicians don't trust a number without knowing why.*
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m import shap
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m def score_patient(features: dict, raw_model, calibrated_model) -> dict:
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m     Score a single patient and generate SHAP explanations.
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m         features: The engineered feature dictionary from engineer_features().
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m         raw_model: The uncalibrated XGBoost model (needed for SHAP).
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m         calibrated_model: The isotonic-calibrated model (for honest probabilities).
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m         A dictionary with the calibrated mortality probability, confidence interval,
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m         and the top contributing features with plain-language explanations.
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m     # Build the feature vector in the correct order
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m     feature_vector = np.array([[features.get(f, np.nan) for f in FEATURE_SCHEMA]])
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m     feature_df = pd.DataFrame(feature_vector, columns=FEATURE_SCHEMA)
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m     # Get calibrated probability
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m     calibrated_prob = float(calibrated_model.predict_proba(feature_df)[:, 1][0])
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m     # Compute SHAP values for explainability.
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m     # TreeExplainer is exact for tree-based models (no approximation needed).
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m     explainer = shap.TreeExplainer(raw_model)
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m     shap_values = explainer.shap_values(feature_df)
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m     # Get the top 5 contributing features by absolute SHAP value
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m     shap_array = shap_values[0]  # single patient
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m     feature_importance = list(zip(FEATURE_SCHEMA, shap_array, feature_vector[0]))
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m     feature_importance.sort(key=lambda x: abs(x[1]), reverse=True)
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m     top_contributors = []
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m     for feat_name, shap_val, feat_val in feature_importance[:5]:
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m         direction = "increasing risk" if shap_val > 0 else "decreasing risk"
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m         plain_text = _explain_feature(feat_name, feat_val, shap_val)
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m         top_contributors.append({
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m             "feature": feat_name,
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m             "value": round(float(feat_val), 2) if not np.isnan(feat_val) else None,
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m             "shap_contribution": round(float(shap_val), 4),
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m             "direction": direction,
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m             "plain_text": plain_text,
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m     # Confidence interval (Wilson score interval approximation)
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m     # In production this uses the calibration sample size for tighter bounds.
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m     # Here we use a rough estimate based on model uncertainty.
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m     n_cal = 500  # approximate calibration sample size
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m     ci_width = 1.96 * np.sqrt(calibrated_prob * (1 - calibrated_prob) / n_cal)
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m     ci_lower = max(0.0, calibrated_prob - ci_width)
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m     ci_upper = min(1.0, calibrated_prob + ci_width)
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m         "mortality_probability": round(calibrated_prob, 3),
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m         "confidence_interval": [round(ci_lower, 3), round(ci_upper, 3)],
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m         "top_contributors": top_contributors,
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m def _explain_feature(feature_name: str, value: float, shap_val: float) -> str:
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m     Translate a feature name and value into plain language a clinician can read.
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m     This is where data science meets clinical communication. The explanations
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m     need to be medically meaningful, not just statistically descriptive.
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m     explanations = {
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m         "sofa_total": f"Total organ failure score: {int(value)} (higher = more organ systems failing)",
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m         "sofa_trend_24h": f"Organ failure trend: {'worsening' if value > 0 else 'stable/improving'} over 24h",
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m         "lactate_latest": f"Lactate: {value:.1f} mmol/L ({'elevated, suggesting tissue hypoperfusion' if value > 2 else 'normal'})",
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m         "vasopressor_count": f"On {int(value)} vasopressor(s) for blood pressure support",
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m         "on_vasopressors": "Requiring vasopressor support" if value else "No vasopressor requirement",
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m         "pf_ratio": f"P/F ratio: {value:.0f} ({'severe ARDS' if value < 100 else 'moderate' if value < 200 else 'mild' if value < 300 else 'normal'})",
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m         "shock_index": f"Shock index: {value:.2f} ({'concerning' if value > 1.0 else 'normal'})",
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m         "age": f"Age: {int(value)} years",
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m         "creatinine_latest": f"Creatinine: {value:.1f} mg/dL ({'elevated, kidney dysfunction' if value > 1.5 else 'normal'})",
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m         "heart_rate_mean_6h": f"Mean heart rate (6h): {value:.0f} bpm",
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m         "sbp_mean_6h": f"Mean systolic BP (6h): {value:.0f} mmHg",
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m         "norepinephrine_dose": f"Norepinephrine dose: {value:.2f} mcg/kg/min",
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m         "hours_in_icu": f"Hours in ICU: {value:.0f}",
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m         "sofa_cardiovascular": f"Cardiovascular SOFA: {int(value)}/4",
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m         "sofa_respiratory": f"Respiratory SOFA: {int(value)}/4",
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m         "fio2_latest": f"FiO2: {value:.0%} ({'high oxygen requirement' if value > 0.5 else 'low/room air'})",
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m     if feature_name in explanations:
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m         return explanations[feature_name]
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m     # Generic fallback
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m     direction = "elevated" if shap_val > 0 else "low/protective"
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m     return f"{feature_name}: {value:.2f} ({direction})"
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m ## Step 5: Store Prediction (DynamoDB)
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m *The main recipe's Step 5 writes the prediction to DynamoDB for audit, outcome tracking, and clinical display. Here we show the boto3 call structure. In local testing, you can skip the actual write and just inspect the record.*
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m def build_prediction_record(patient_id: str, admission_id: str,
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m                             score_result: dict, features: dict) -> dict:
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m     Assemble the complete prediction record for DynamoDB storage.
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m     This record serves three purposes:
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m     1. Clinical display: the probability and explanations shown to clinicians
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m     2. Audit trail: who was scored, when, with what model version
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m     3. Outcome tracking: the actual_outcome field gets filled in later for monitoring
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m     prediction_id = f"pred-{datetime.now(timezone.utc).strftime('%Y%m%d%H%M%S')}-{patient_id[-5:]}"
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m     record = {
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m         "prediction_id": prediction_id,
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m         "patient_id": patient_id,
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m         "admission_id": admission_id,
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m         "timestamp": datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m         "model_version": "icu-mortality-v2.3-demo",
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m         # The prediction
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m         "mortality_probability": Decimal(str(score_result["mortality_probability"])),
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m         "confidence_interval_lower": Decimal(str(score_result["confidence_interval"][0])),
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m         "confidence_interval_upper": Decimal(str(score_result["confidence_interval"][1])),
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m         # Explainability
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m         "top_contributors": score_result["top_contributors"],
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m         # Context
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m         "hours_since_admission": Decimal(str(features.get("hours_in_icu", 0))),
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m         "sofa_total": int(features.get("sofa_total", 0)),
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m         # Outcome tracking (filled in when patient is discharged or dies)
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m         "actual_outcome": None,
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m         "goals_of_care_changed": None,
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m     return record
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m def store_prediction_dynamodb(record: dict) -> None:
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m     Write the prediction record to DynamoDB.
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m     In production, this table has:
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m     - Partition key: prediction_id
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m     - GSI on patient_id + timestamp (for patient-level queries)
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m     - GSI on model_version + timestamp (for model monitoring queries)
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m     - TTL on a retention_expiry field (for data lifecycle management)
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m     # DynamoDB requires Decimal for numeric types, not float.
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m     # The build_prediction_record function already handles this for top-level fields.
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m     # For nested structures (top_contributors), we'd need to recursively convert.
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m     # Skipping the actual write here since this is a local demo.
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m     # In production:
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m     # dynamodb = boto3.resource("dynamodb")
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m     # table = dynamodb.Table(DYNAMODB_TABLE_NAME)
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m     # table.put_item(Item=record)
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m     logger.info("Would write prediction %s to DynamoDB (skipped in demo mode)",
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m                 record["prediction_id"])
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m ## Step 6: Publish Monitoring Metrics (CloudWatch)
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m *The main recipe emphasizes continuous monitoring of prediction distribution and calibration drift. This step publishes custom CloudWatch metrics so you can alarm on shifts in model behavior.*
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m def publish_prediction_metric(mortality_prob: float, model_version: str,
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m                                hospital_id: str = "demo-hospital") -> None:
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m     Publish the predicted mortality probability as a CloudWatch custom metric.
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m     Why this matters: if the average predicted mortality across your ICU suddenly
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m     shifts (say, from 25% to 40% over a week), something changed. Either your
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m     patient population got sicker (possible), your data pipeline broke (check first),
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m     or the model is drifting (retrain). Without this metric, you won't notice
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m     until someone complains that the scores "feel wrong."
[0m[49m[38;5;10m+    717[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    718[0m:[38;5;10m[49m     In production, you'd also publish:
[0m[49m[38;5;10m+    719[0m:[38;5;10m[49m     - Feature distribution metrics (detect data pipeline issues)
[0m[49m[38;5;10m+    720[0m:[38;5;10m[49m     - Prediction latency (detect infrastructure problems)
[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m     - Calibration metrics (weekly, comparing predictions to outcomes)
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m     # In production:
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m     # cloudwatch = boto3.client("cloudwatch")
[0m[49m[38;5;10m+    725[0m:[38;5;10m[49m     # cloudwatch.put_metric_data(
[0m[49m[38;5;10m+    726[0m:[38;5;10m[49m     #     Namespace=CLOUDWATCH_NAMESPACE,
[0m[49m[38;5;10m+    727[0m:[38;5;10m[49m     #     MetricData=[{
[0m[49m[38;5;10m+    728[0m:[38;5;10m[49m     #         "MetricName": "PredictedMortality",
[0m[49m[38;5;10m+    729[0m:[38;5;10m[49m     #         "Value": mortality_prob,
[0m[49m[38;5;10m+    730[0m:[38;5;10m[49m     #         "Unit": "None",
[0m[49m[38;5;10m+    731[0m:[38;5;10m[49m     #         "Dimensions": [
[0m[49m[38;5;10m+    732[0m:[38;5;10m[49m     #             {"Name": "HospitalId", "Value": hospital_id},
[0m[49m[38;5;10m+    733[0m:[38;5;10m[49m     #             {"Name": "ModelVersion", "Value": model_version},
[0m[49m[38;5;10m+    734[0m:[38;5;10m[49m     #         ],
[0m[49m[38;5;10m+    735[0m:[38;5;10m[49m     #     }]
[0m[49m[38;5;10m+    736[0m:[38;5;10m[49m     # )
[0m[49m[38;5;10m+    737[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    738[0m:[38;5;10m[49m     logger.info("Would publish metric: PredictedMortality=%.3f (hospital=%s, model=%s)",
[0m[49m[38;5;10m+    739[0m:[38;5;10m[49m                 mortality_prob, hospital_id, model_version)
[0m[49m[38;5;10m+    740[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    741[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    742[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    743[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    744[0m:[38;5;10m[49m ## Putting It All Together
[0m[49m[38;5;10m+    745[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    746[0m:[38;5;10m[49m Here's the full pipeline assembled into a single callable function. This trains a model on synthetic data, scores a new patient, explains the prediction, and shows what would be stored and monitored.
[0m[49m[38;5;10m+    747[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    748[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    749[0m:[38;5;10m[49m def run_full_pipeline():
[0m[49m[38;5;10m+    750[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    751[0m:[38;5;10m[49m     Demonstrate the complete ICU mortality risk scoring pipeline.
[0m[49m[38;5;10m+    752[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    753[0m:[38;5;10m[49m     This function:
[0m[49m[38;5;10m+    754[0m:[38;5;10m[49m     1. Generates synthetic training data (stand-in for historical ICU admissions)
[0m[49m[38;5;10m+    755[0m:[38;5;10m[49m     2. Trains and calibrates an XGBoost mortality model
[0m[49m[38;5;10m+    756[0m:[38;5;10m[49m     3. Generates a new synthetic patient (stand-in for a real-time HealthLake query)
[0m[49m[38;5;10m+    757[0m:[38;5;10m[49m     4. Engineers features from the patient's ICU data
[0m[49m[38;5;10m+    758[0m:[38;5;10m[49m     5. Scores the patient with SHAP explanations
[0m[49m[38;5;10m+    759[0m:[38;5;10m[49m     6. Builds the prediction record for storage
[0m[49m[38;5;10m+    760[0m:[38;5;10m[49m     7. Shows what would be published to CloudWatch for monitoring
[0m[49m[38;5;10m+    761[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    762[0m:[38;5;10m[49m     In production, steps 1-2 happen in a SageMaker Training Pipeline (monthly).
[0m[49m[38;5;10m+    763[0m:[38;5;10m[49m     Steps 3-7 happen on every scoring event (every 4 hours per patient, or on
[0m[49m[38;5;10m+    764[0m:[38;5;10m[49m     significant clinical change).
[0m[49m[38;5;10m+    765[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    766[0m:[38;5;10m[49m     print("=" * 70)
[0m[49m[38;5;10m+    767[0m:[38;5;10m[49m     print("ICU Mortality Risk Scoring Pipeline (Demo)")
[0m[49m[38;5;10m+    768[0m:[38;5;10m[49m     print("=" * 70)
[0m[49m[38;5;10m+    769[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    770[0m:[38;5;10m[49m     # --- Training phase (happens offline in SageMaker) ---
[0m[49m[38;5;10m+    771[0m:[38;5;10m[49m     print("\n[Phase 1] Training mortality model on synthetic ICU data...")
[0m[49m[38;5;10m+    772[0m:[38;5;10m[49m     X_train_full, y_train_full = generate_training_dataset(n_patients=2000)
[0m[49m[38;5;10m+    773[0m:[38;5;10m[49m     raw_model, calibrated_model, X_test, y_test = train_mortality_model(X_train_full, y_train_full)
[0m[49m[38;5;10m+    774[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    775[0m:[38;5;10m[49m     # Report model performance
[0m[49m[38;5;10m+    776[0m:[38;5;10m[49m     y_pred = calibrated_model.predict_proba(X_test)[:, 1]
[0m[49m[38;5;10m+    777[0m:[38;5;10m[49m     print(f"  Model AUC: {roc_auc_score(y_test, y_pred):.3f}")
[0m[49m[38;5;10m+    778[0m:[38;5;10m[49m     print(f"  Brier Score: {brier_score_loss(y_test, y_pred):.3f}")
[0m[49m[38;5;10m+    779[0m:[38;5;10m[49m     print(f"  Mortality rate in test set: {y_test.mean():.1%}")
[0m[49m[38;5;10m+    780[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    781[0m:[38;5;10m[49m     # --- Scoring phase (happens in real-time) ---
[0m[49m[38;5;10m+    782[0m:[38;5;10m[49m     print("\n[Phase 2] Scoring a new ICU patient...")
[0m[49m[38;5;10m+    783[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    784[0m:[38;5;10m[49m     # Generate a severe patient (simulating a real-time HealthLake query)
[0m[49m[38;5;10m+    785[0m:[38;5;10m[49m     patient = generate_synthetic_icu_patient(
[0m[49m[38;5;10m+    786[0m:[38;5;10m[49m         patient_id="patient-72849",
[0m[49m[38;5;10m+    787[0m:[38;5;10m[49m         hours_in_icu=72.0,
[0m[49m[38;5;10m+    788[0m:[38;5;10m[49m         severity="severe"
[0m[49m[38;5;10m+    789[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    790[0m:[38;5;10m[49m     print(f"  Patient: {patient['patient_id']}, {patient['hours_in_icu']:.0f}h in ICU")
[0m[49m[38;5;10m+    791[0m:[38;5;10m[49m     print(f"  Age: {patient['demographics']['age']}, "
[0m[49m[38;5;10m+    792[0m:[38;5;10m[49m           f"Vasopressors: {patient['medications']['vasopressor_count']}, "
[0m[49m[38;5;10m+    793[0m:[38;5;10m[49m           f"Ventilated: {patient['medications']['on_mechanical_ventilation']}")
[0m[49m[38;5;10m+    794[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    795[0m:[38;5;10m[49m     # Engineer features
[0m[49m[38;5;10m+    796[0m:[38;5;10m[49m     print("\n[Phase 3] Engineering temporal features...")
[0m[49m[38;5;10m+    797[0m:[38;5;10m[49m     features = engineer_features(patient)
[0m[49m[38;5;10m+    798[0m:[38;5;10m[49m     print(f"  Total features: {len(features)}")
[0m[49m[38;5;10m+    799[0m:[38;5;10m[49m     print(f"  SOFA total: {features['sofa_total']}")
[0m[49m[38;5;10m+    800[0m:[38;5;10m[49m     print(f"  P/F ratio: {features.get('pf_ratio', 'N/A')}")
[0m[49m[38;5;10m+    801[0m:[38;5;10m[49m     print(f"  Shock index: {features.get('shock_index', 'N/A'):.2f}")
[0m[49m[38;5;10m+    802[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    803[0m:[38;5;10m[49m     # Score with explanations
[0m[49m[38;5;10m+    804[0m:[38;5;10m[49m     print("\n[Phase 4] Scoring patient and generating explanations...")
[0m[49m[38;5;10m+    805[0m:[38;5;10m[49m     score_result = score_patient(features, raw_model, calibrated_model)
[0m[49m[38;5;10m+    806[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    807[0m:[38;5;10m[49m     print(f"\n  *** Mortality Probability: {score_result['mortality_probability']:.1%} ***")
[0m[49m[38;5;10m+    808[0m:[38;5;10m[49m     print(f"  95% CI: [{score_result['confidence_interval'][0]:.1%}, "
[0m[49m[38;5;10m+    809[0m:[38;5;10m[49m           f"{score_result['confidence_interval'][1]:.1%}]")
[0m[49m[38;5;10m+    810[0m:[38;5;10m[49m     print(f"\n  Top contributing factors:")
[0m[49m[38;5;10m+    811[0m:[38;5;10m[49m     for i, contrib in enumerate(score_result["top_contributors"], 1):
[0m[49m[38;5;10m+    812[0m:[38;5;10m[49m         print(f"    {i}. {contrib['plain_text']}")
[0m[49m[38;5;10m+    813[0m:[38;5;10m[49m         print(f"       (SHAP contribution: {contrib['shap_contribution']:+.4f})")
[0m[49m[38;5;10m+    814[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    815[0m:[38;5;10m[49m     # Build prediction record
[0m[49m[38;5;10m+    816[0m:[38;5;10m[49m     print("\n[Phase 5] Building prediction record for storage...")
[0m[49m[38;5;10m+    817[0m:[38;5;10m[49m     record = build_prediction_record(
[0m[49m[38;5;10m+    818[0m:[38;5;10m[49m         patient_id=patient["patient_id"],
[0m[49m[38;5;10m+    819[0m:[38;5;10m[49m         admission_id="enc-2026-03-12-4821",
[0m[49m[38;5;10m+    820[0m:[38;5;10m[49m         score_result=score_result,
[0m[49m[38;5;10m+    821[0m:[38;5;10m[49m         features=features,
[0m[49m[38;5;10m+    822[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    823[0m:[38;5;10m[49m     print(f"  Prediction ID: {record['prediction_id']}")
[0m[49m[38;5;10m+    824[0m:[38;5;10m[49m     print(f"  Model version: {record['model_version']}")
[0m[49m[38;5;10m+    825[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    826[0m:[38;5;10m[49m     # Store (demo mode: just logs)
[0m[49m[38;5;10m+    827[0m:[38;5;10m[49m     store_prediction_dynamodb(record)
[0m[49m[38;5;10m+    828[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    829[0m:[38;5;10m[49m     # Publish monitoring metric (demo mode: just logs)
[0m[49m[38;5;10m+    830[0m:[38;5;10m[49m     publish_prediction_metric(
[0m[49m[38;5;10m+    831[0m:[38;5;10m[49m         score_result["mortality_probability"],
[0m[49m[38;5;10m+    832[0m:[38;5;10m[49m         model_version="icu-mortality-v2.3-demo"
[0m[49m[38;5;10m+    833[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    834[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    835[0m:[38;5;10m[49m     # --- Show the full output as JSON ---
[0m[49m[38;5;10m+    836[0m:[38;5;10m[49m     print("\n[Output] Full prediction record (as JSON):")
[0m[49m[38;5;10m+    837[0m:[38;5;10m[49m     # Convert Decimals to floats for JSON serialization
[0m[49m[38;5;10m+    838[0m:[38;5;10m[49m     output = {
[0m[49m[38;5;10m+    839[0m:[38;5;10m[49m         "prediction_id": record["prediction_id"],
[0m[49m[38;5;10m+    840[0m:[38;5;10m[49m         "patient_id": record["patient_id"],
[0m[49m[38;5;10m+    841[0m:[38;5;10m[49m         "admission_id": record["admission_id"],
[0m[49m[38;5;10m+    842[0m:[38;5;10m[49m         "timestamp": record["timestamp"],
[0m[49m[38;5;10m+    843[0m:[38;5;10m[49m         "model_version": record["model_version"],
[0m[49m[38;5;10m+    844[0m:[38;5;10m[49m         "mortality_probability": float(record["mortality_probability"]),
[0m[49m[38;5;10m+    845[0m:[38;5;10m[49m         "confidence_interval": [
[0m[49m[38;5;10m+    846[0m:[38;5;10m[49m             float(record["confidence_interval_lower"]),
[0m[49m[38;5;10m+    847[0m:[38;5;10m[49m             float(record["confidence_interval_upper"]),
[0m[49m[38;5;10m+    848[0m:[38;5;10m[49m         ],
[0m[49m[38;5;10m+    849[0m:[38;5;10m[49m         "top_contributors": score_result["top_contributors"],
[0m[49m[38;5;10m+    850[0m:[38;5;10m[49m         "sofa_total": record["sofa_total"],
[0m[49m[38;5;10m+    851[0m:[38;5;10m[49m         "hours_since_admission": float(record["hours_since_admission"]),
[0m[49m[38;5;10m+    852[0m:[38;5;10m[49m         "actual_outcome": None,
[0m[49m[38;5;10m+    853[0m:[38;5;10m[49m         "goals_of_care_changed": None,
[0m[49m[38;5;10m+    854[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    855[0m:[38;5;10m[49m     print(json.dumps(output, indent=2, default=str))
[0m[49m[38;5;10m+    856[0m:[38;5;10m[49m 
