[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m     # --- SOFA component scores ---
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m     features["sofa_respiratory"] = compute_sofa_respiratory(features.get("pf_ratio"))
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m     features["sofa_coagulation"] = compute_sofa_coagulation(features.get("platelets_latest"))
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m     features["sofa_liver"] = compute_sofa_liver(features.get("bilirubin_latest"))
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m     features["sofa_cardiovascular"] = compute_sofa_cardiovascular(
