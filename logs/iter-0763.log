[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m     window_24h = 96  # 24 hours * 4 readings/hour
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m     for vital_name in ["heart_rate", "sbp", "map"]:
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m         values_24h = np.array(vitals[vital_name][-window_24h:])
