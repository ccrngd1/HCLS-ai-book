[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m         "has_chf": int(rng.random() < comorbidity_prob),
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m         "has_copd": int(rng.random() < comorbidity_prob * 0.7),
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m         "has_diabetes": int(rng.random() < comorbidity_prob * 1.2),
