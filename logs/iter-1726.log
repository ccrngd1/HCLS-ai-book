[0m[49m[39m  312, 317[0m:[39m[49m         score      = prediction.propensity_score
[0m[49m[39m  313, 318[0m:[39m[49m         balance_id = prediction.balance_id
[0m[49m[39m  314, 319[0m:[39m[49m         patient_id = prediction.patient_id
