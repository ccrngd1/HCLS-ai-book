[0m[49m[38;5;10m+      332[0m:[38;5;10m[49m             random_strategy = random_choice(["standard_statements",
[0m[49m[38;5;10m+      333[0m:[38;5;10m[49m                                              "payment_plan_offer",
[0m[49m[38;5;10m+      334[0m:[38;5;10m[49m                                              "financial_counselor_outreach",
[0m[49m[38;5;10m+      335[0m:[38;5;10m[49m                                              "financial_assistance_screening"])
[0m[49m[38;5;10m+      336[0m:[38;5;10m[49m             route_to_queue(random_strategy, balance_id)
[0m[49m[38;5;10m+      337[0m:[38;5;10m[49m             log_decision(balance_id, patient_id, score, random_strategy,
