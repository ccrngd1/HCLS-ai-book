[0m[49m[38;5;9m- 321     [0m:[38;5;9m[49m             log_decision(balance_id, patient_id, score, "new_patient_default")
[0m[49m[38;5;10m+      345[0m:[38;5;10m[49m             log_decision(balance_id, patient_id, score, "new_patient_default", is_holdout=false)
[0m[49m[39m  322, 346[0m:[39m[49m             CONTINUE
[0m[49m[39m  323, 347[0m:[39m[49m 
[0m[49m[39m  324, 348[0m:[39m[49m         IF score >= HIGH_THRESHOLD:
[0m[49m[39m  325, 349[0m:[39m[49m             // High propensity: standard statement cadence.
[0m[49m[39m  326, 350[0m:[39m[49m             // These patients typically pay without special intervention.
[0m[49m[39m  327, 351[0m:[39m[49m             // Don't waste outreach resources here.
[0m[49m[39m  328, 352[0m:[39m[49m             route_to_queue("standard_statements", balance_id)
[0m[49m[39m  329, 353[0m:[39m[49m 
[0m[49m[39m  330, 354[0m:[39m[49m         ELSE IF score >= MEDIUM_THRESHOLD:
[0m[49m[39m  331, 355[0m:[39m[49m             // Medium propensity: proactive intervention likely to help.
[0m[49m[39m  332, 356[0m:[39m[49m             // Offer payment plan early (before frustration builds).
[0m[49m[39m  333, 357[0m:[39m[49m             // Financial counselor outreach for larger balances.
[0m[49m[39m  334, 358[0m:[39m[49m             IF amount > 500:
