[0m[49m[39m  336, 360[0m:[39m[49m             ELSE:
[0m[49m[39m  337, 361[0m:[39m[49m                 route_to_queue("payment_plan_offer", balance_id)
[0m[49m[39m  338, 362[0m:[39m[49m 
[0m[49m[39m  339, 363[0m:[39m[49m         ELSE:
[0m[49m[39m  340, 364[0m:[39m[49m             // Low propensity: likely unable to pay.
