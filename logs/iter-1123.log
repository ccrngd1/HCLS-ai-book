[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m     "reduce_ps_4",            # 2: reduce pressure support by 4 cmH2O
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m     "reduce_fio2_5",          # 3: reduce FiO2 by 5 percentage points
