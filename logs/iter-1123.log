[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m     "recommend_extubation",   # 7: patient ready for extubation
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m 
