[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m ┌────────── INPUT SAFETY + EMERGENCY SCREENING ────────────┐
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m │                                                           │
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m │   [Standard input safety primitives]                     │
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m │    - Prompt-injection detection                          │
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m │    - PHI minimization                                    │
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m │                                                           │
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m │   [Continuous emergency screening]                       │
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m │    - Active emergency (chest pain, severe shortness of   │
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m │      breath, stroke symptoms, etc.) routes to triage     │
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m │      pathway and 911 routing                             │
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m │    - Suicidal ideation screening                         │
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m │    - Sensitive-disclosure detection                      │
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m │      (IPV, child abuse, elder abuse, substance-use       │
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m │      crisis, mandatory-reporting categories)             │
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m │                                                           │
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m │   [Coordination-specific signal detection]               │
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m │    - Care-conflict signals (provider disagreement)       │
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m │    - Social-determinants signals (transportation,        │
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m │      food insecurity, housing, financial barriers,       │
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m │      language access, caregiver burden)                  │
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m │    - Adherence concerns                                  │
