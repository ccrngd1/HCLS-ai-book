[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m   "waveform_type": "ecg_lead_ii",
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m   "analysis_window": {
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m     "start": "2026-03-01T14:22:00Z",
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m     "end": "2026-03-01T14:22:30Z",
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m     "signal_quality": 0.91
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m   },
