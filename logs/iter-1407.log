[0m[49m[38;5;10m+     152[0m:[38;5;10m[49m     for patient_id, studies in patient_studies.items():
[0m[49m[38;5;10m+     153[0m:[38;5;10m[49m         # Get the unique modalities available for this patient.
[0m[49m[38;5;10m+     154[0m:[38;5;10m[49m         modalities_present = set(s["modality"] for s in studies)
[0m[49m[38;5;10m+     155[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     156[0m:[38;5;10m[49m         if len(modalities_present) < 2:
[0m[49m[38;5;10m+     157[0m:[38;5;10m[49m             logger.info(
[0m[49m[38;5;10m+     158[0m:[38;5;10m[49m                 "Patient %s has only one modality (%s), skipping fusion",
[0m[49m[38;5;10m+     159[0m:[38;5;10m[49m                 patient_id, modalities_present
[0m[49m[38;5;10m+     160[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+     161[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     162[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     163[0m:[38;5;10m[49m         # For radiation therapy fusion, CT is the fixed (reference) image.
[0m[49m[38;5;10m+     164[0m:[38;5;10m[49m         # Dose calculation requires CT electron density data.
[0m[49m[38;5;10m+     165[0m:[38;5;10m[49m         ct_studies = [s for s in studies if s["modality"] == "CT"]
[0m[49m[38;5;10m+     166[0m:[38;5;10m[49m         if not ct_studies:
[0m[49m[38;5;10m+     167[0m:[38;5;10m[49m             logger.warning("Patient %s has no CT study, cannot proceed", patient_id)
[0m[49m[38;5;10m+     168[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     169[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     170[0m:[38;5;10m[49m         # Use the most recent CT as the fixed image.
[0m[49m[38;5;10m+     171[0m:[38;5;10m[49m         fixed_study = ct_studies[-1]
[0m[49m[38;5;10m+     172[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     173[0m:[38;5;10m[49m         # Everything else is a moving image to register to the CT.
[0m[49m[38;5;10m+     174[0m:[38;5;10m[49m         moving_studies = [s for s in studies if s["modality"] != "CT"]
[0m[49m[38;5;10m+     175[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     176[0m:[38;5;10m[49m         # Validate frame counts. Incomplete series produce garbage registration.
[0m[49m[38;5;10m+     177[0m:[38;5;10m[49m         for study in [fixed_study] + moving_studies:
[0m[49m[38;5;10m+     178[0m:[38;5;10m[49m             if study["frame_count"] < 10:
[0m[49m[38;5;10m+     179[0m:[38;5;10m[49m                 logger.warning(
[0m[49m[38;5;10m+     180[0m:[38;5;10m[49m                     "Study %s has only %d frames, likely incomplete. Skipping.",
[0m[49m[38;5;10m+     181[0m:[38;5;10m[49m                     study["image_set_id"], study["frame_count"]
[0m[49m[38;5;10m+     182[0m:[38;5;10m[49m                 )
[0m[49m[38;5;10m+     183[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+     184[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     185[0m:[38;5;10m[49m         # Create a fusion job for each CT + moving modality pair.
[0m[49m[38;5;10m+     186[0m:[38;5;10m[49m         for moving_study in moving_studies:
[0m[49m[38;5;10m+     187[0m:[38;5;10m[49m             job_id = f"fusion-{datetime.datetime.now(timezone.utc).strftime('%Y%m%d-%H%M%S')}-{patient_id[-5:]}"
[0m[49m[38;5;10m+     188[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     189[0m:[38;5;10m[49m             job_record = {
[0m[49m[38;5;10m+     190[0m:[38;5;10m[49m                 "job_id": job_id,
[0m[49m[38;5;10m+     191[0m:[38;5;10m[49m                 "patient_id": patient_id,
[0m[49m[38;5;10m+     192[0m:[38;5;10m[49m                 "fixed_image_set_id": fixed_study["image_set_id"],
[0m[49m[38;5;10m+     193[0m:[38;5;10m[49m                 "moving_image_set_id": moving_study["image_set_id"],
[0m[49m[38;5;10m+     194[0m:[38;5;10m[49m                 "fixed_modality": "CT",
[0m[49m[38;5;10m+     195[0m:[38;5;10m[49m                 "moving_modality": moving_study["modality"],
[0m[49m[38;5;10m+     196[0m:[38;5;10m[49m                 "status": "VALIDATED",
[0m[49m[38;5;10m+     197[0m:[38;5;10m[49m                 "created_at": datetime.datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+     198[0m:[38;5;10m[49m                 "quality_metrics": {},
[0m[49m[38;5;10m+     199[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+     200[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     201[0m:[38;5;10m[49m             # Write to DynamoDB. This record tracks the job through the pipeline.
[0m[49m[38;5;10m+     202[0m:[38;5;10m[49m             table.put_item(Item=json.loads(
