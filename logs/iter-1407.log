[0m[49m[38;5;10m+       5[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+       6[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+       7[0m:[38;5;10m[49m ## Setup
[0m[49m[38;5;10m+       8[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+       9[0m:[38;5;10m[49m You'll need the AWS SDK for Python and several scientific computing libraries:
[0m[49m[38;5;10m+      10[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      11[0m:[38;5;10m[49m ```bash
[0m[49m[38;5;10m+      12[0m:[38;5;10m[49m pip install boto3 numpy scipy SimpleITK nibabel
[0m[49m[38;5;10m+      13[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+      14[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      15[0m:[38;5;10m[49m Your environment needs credentials configured (via environment variables, an instance profile, or `~/.aws/credentials`). The IAM role or user needs:
[0m[49m[38;5;10m+      16[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      17[0m:[38;5;10m[49m - `medical-imaging:GetImageSet`, `medical-imaging:GetImageFrame`, `medical-imaging:CreateImageSet` (AWS HealthImaging)
[0m[49m[38;5;10m+      18[0m:[38;5;10m[49m - `s3:GetObject`, `s3:PutObject` (processing bucket)
[0m[49m[38;5;10m+      19[0m:[38;5;10m[49m - `sagemaker:InvokeEndpoint` (registration model)
[0m[49m[38;5;10m+      20[0m:[38;5;10m[49m - `dynamodb:PutItem`, `dynamodb:UpdateItem`, `dynamodb:GetItem` (metadata table)
[0m[49m[38;5;10m+      21[0m:[38;5;10m[49m - `states:StartExecution` (Step Functions, if using orchestration)
[0m[49m[38;5;10m+      22[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      23[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+      24[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      25[0m:[38;5;10m[49m ## Config and Constants
[0m[49m[38;5;10m+      26[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      27[0m:[38;5;10m[49m Before we get to the pipeline steps, here's the configuration that drives the fusion process. Registration parameters, quality thresholds, and AWS resource names all live here so they're easy to tune without digging through logic.
[0m[49m[38;5;10m+      28[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      29[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+      30[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+      31[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+      32[0m:[38;5;10m[49m import datetime
[0m[49m[38;5;10m+      33[0m:[38;5;10m[49m from datetime import timezone
[0m[49m[38;5;10m+      34[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+      35[0m:[38;5;10m[49m from typing import Optional
[0m[49m[38;5;10m+      36[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      37[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+      38[0m:[38;5;10m[49m import numpy as np
[0m[49m[38;5;10m+      39[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+      40[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      41[0m:[38;5;10m[49m # Structured logging. In production, use JSON-formatted output for
[0m[49m[38;5;10m+      42[0m:[38;5;10m[49m # CloudWatch Logs Insights queries. Never log patient identifiers or PHI.
[0m[49m[38;5;10m+      43[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+      44[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+      45[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      46[0m:[38;5;10m[49m # Retry config for AWS API calls. Medical imaging pipelines can hit
[0m[49m[38;5;10m+      47[0m:[38;5;10m[49m # throttling during batch processing of large study volumes.
[0m[49m[38;5;10m+      48[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 5, "mode": "adaptive"})
[0m[49m[38;5;10m+      49[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      50[0m:[38;5;10m[49m # AWS clients
[0m[49m[38;5;10m+      51[0m:[38;5;10m[49m s3_client = boto3.client("s3", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+      52[0m:[38;5;10m[49m sagemaker_runtime = boto3.client("sagemaker-runtime", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+      53[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+      54[0m:[38;5;10m[49m healthimaging_client = boto3.client("medical-imaging", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+      55[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      56[0m:[38;5;10m[49m # --- Pipeline Configuration ---
[0m[49m[38;5;10m+      57[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      58[0m:[38;5;10m[49m # S3 bucket for intermediate processing artifacts (preprocessed volumes,
[0m[49m[38;5;10m+      59[0m:[38;5;10m[49m # deformation fields, QA visualizations). Must have SSE-KMS encryption enabled.
[0m[49m[38;5;10m+      60[0m:[38;5;10m[49m PROCESSING_BUCKET = "my-imaging-fusion-processing"
[0m[49m[38;5;10m+      61[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      62[0m:[38;5;10m[49m # DynamoDB table for fusion job metadata and quality tracking.
[0m[49m[38;5;10m+      63[0m:[38;5;10m[49m METADATA_TABLE = "imaging-fusion-metadata"
[0m[49m[38;5;10m+      64[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      65[0m:[38;5;10m[49m # SageMaker endpoint hosting the registration model (VoxelMorph or similar).
[0m[49m[38;5;10m+      66[0m:[38;5;10m[49m REGISTRATION_ENDPOINT = "registration-model-endpoint"
[0m[49m[38;5;10m+      67[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      68[0m:[38;5;10m[49m # AWS HealthImaging datastore ID for DICOM storage.
[0m[49m[38;5;10m+      69[0m:[38;5;10m[49m HEALTHIMAGING_DATASTORE_ID = "ds-12345678abcdef"
[0m[49m[38;5;10m+      70[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      71[0m:[38;5;10m[49m # --- Registration Parameters ---
[0m[49m[38;5;10m+      72[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      73[0m:[38;5;10m[49m # Target voxel spacing for resampling before registration (in mm).
[0m[49m[38;5;10m+      74[0m:[38;5;10m[49m # 1mm isotropic works for brain. Use 2mm for abdomen/pelvis to manage
[0m[49m[38;5;10m+      75[0m:[38;5;10m[49m # memory and compute requirements.
[0m[49m[38;5;10m+      76[0m:[38;5;10m[49m TARGET_SPACING_MM = [1.0, 1.0, 1.0]
[0m[49m[38;5;10m+      77[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      78[0m:[38;5;10m[49m # Registration type selection by body region.
[0m[49m[38;5;10m+      79[0m:[38;5;10m[49m # Brain: rigid is usually sufficient (skull constrains deformation).
[0m[49m[38;5;10m+      80[0m:[38;5;10m[49m # Body: deformable is required (organ motion between scans).
[0m[49m[38;5;10m+      81[0m:[38;5;10m[49m REGISTRATION_CONFIG = {
[0m[49m[38;5;10m+      82[0m:[38;5;10m[49m     "brain": {"type": "rigid", "levels": 3, "metric": "mutual_information"},
[0m[49m[38;5;10m+      83[0m:[38;5;10m[49m     "body": {"type": "deformable", "levels": 3, "metric": "mutual_information"},
[0m[49m[38;5;10m+      84[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+      85[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      86[0m:[38;5;10m[49m # --- Quality Thresholds ---
[0m[49m[38;5;10m+      87[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      88[0m:[38;5;10m[49m # Mutual information threshold for accepting registration.
[0m[49m[38;5;10m+      89[0m:[38;5;10m[49m # Well-registered cross-modal pairs typically score 1.0-2.0.
[0m[49m[38;5;10m+      90[0m:[38;5;10m[49m # Below this threshold triggers manual physics review.
[0m[49m[38;5;10m+      91[0m:[38;5;10m[49m MI_THRESHOLD = 1.0
[0m[49m[38;5;10m+      92[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      93[0m:[38;5;10m[49m # Maximum allowable fraction of voxels with negative Jacobian determinant.
[0m[49m[38;5;10m+      94[0m:[38;5;10m[49m # Negative Jacobian means the deformation folds tissue through itself,
[0m[49m[38;5;10m+      95[0m:[38;5;10m[49m # which is physically impossible. More than 0.1% is suspicious.
[0m[49m[38;5;10m+      96[0m:[38;5;10m[49m MAX_FOLDING_FRACTION = 0.001
[0m[49m[38;5;10m+      97[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      98[0m:[38;5;10m[49m # Mean target registration error threshold (in mm).
[0m[49m[38;5;10m+      99[0m:[38;5;10m[49m # AAPM recommends < 2mm for treatment planning. We alert at 3mm.
[0m[49m[38;5;10m+     100[0m:[38;5;10m[49m MAX_MEAN_TRE_MM = 3.0
[0m[49m[38;5;10m+     101[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     102[0m:[38;5;10m[49m # --- Modality-Specific Preprocessing Parameters ---
[0m[49m[38;5;10m+     103[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     104[0m:[38;5;10m[49m # CT Hounsfield unit clipping range. Values outside this are scanner artifacts.
[0m[49m[38;5;10m+     105[0m:[38;5;10m[49m CT_HU_MIN = -1024
[0m[49m[38;5;10m+     106[0m:[38;5;10m[49m CT_HU_MAX = 3071
[0m[49m[38;5;10m+     107[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     108[0m:[38;5;10m[49m # MRI intensity normalization percentiles. Clipping at 1st and 99th percentile
[0m[49m[38;5;10m+     109[0m:[38;5;10m[49m # removes outlier voxels (air, artifact) without affecting tissue contrast.
[0m[49m[38;5;10m+     110[0m:[38;5;10m[49m MRI_NORM_PERCENTILE_LOW = 1
[0m[49m[38;5;10m+     111[0m:[38;5;10m[49m MRI_NORM_PERCENTILE_HIGH = 99
[0m[49m[38;5;10m+     112[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     113[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     114[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     115[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     116[0m:[38;5;10m[49m ## Step 1: Ingest and Validate DICOM Studies
[0m[49m[38;5;10m+     117[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     118[0m:[38;5;10m[49m *The pseudocode calls this `ingest_and_validate(study_notifications)`. It receives notifications about new imaging studies, groups them by patient, and identifies fusion-eligible pairs (at least two modalities for the same patient).*
[0m[49m[38;5;10m+     119[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     120[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     121[0m:[38;5;10m[49m def ingest_and_validate(study_notifications: list[dict]) -> list[dict]:
[0m[49m[38;5;10m+     122[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     123[0m:[38;5;10m[49m     Process incoming study notifications and create fusion jobs for eligible pairs.
[0m[49m[38;5;10m+     124[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     125[0m:[38;5;10m[49m     In a real system, these notifications come from AWS HealthImaging via
[0m[49m[38;5;10m+     126[0m:[38;5;10m[49m     EventBridge when new studies are imported. Here we expect a list of dicts
[0m[49m[38;5;10m+     127[0m:[38;5;10m[49m     with metadata about each study.
[0m[49m[38;5;10m+     128[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     129[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     130[0m:[38;5;10m[49m         study_notifications: List of dicts, each containing:
[0m[49m[38;5;10m+     131[0m:[38;5;10m[49m             - patient_id: Patient identifier
[0m[49m[38;5;10m+     132[0m:[38;5;10m[49m             - modality: Imaging modality ("CT", "MR", "PT")
[0m[49m[38;5;10m+     133[0m:[38;5;10m[49m             - image_set_id: AWS HealthImaging image set ID
[0m[49m[38;5;10m+     134[0m:[38;5;10m[49m             - series_count: Number of series in the study
[0m[49m[38;5;10m+     135[0m:[38;5;10m[49m             - frame_count: Total number of image frames (slices)
[0m[49m[38;5;10m+     136[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     137[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     138[0m:[38;5;10m[49m         List of fusion job records (dicts) that were created and written
[0m[49m[38;5;10m+     139[0m:[38;5;10m[49m         to DynamoDB. Each job represents one registration pair (e.g., CT + MRI).
[0m[49m[38;5;10m+     140[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     141[0m:[38;5;10m[49m     # Group studies by patient. We need at least two modalities per patient
[0m[49m[38;5;10m+     142[0m:[38;5;10m[49m     # to have anything worth fusing.
[0m[49m[38;5;10m+     143[0m:[38;5;10m[49m     from collections import defaultdict
[0m[49m[38;5;10m+     144[0m:[38;5;10m[49m     patient_studies = defaultdict(list)
[0m[49m[38;5;10m+     145[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     146[0m:[38;5;10m[49m     for notification in study_notifications:
[0m[49m[38;5;10m+     147[0m:[38;5;10m[49m         patient_studies[notification["patient_id"]].append(notification)
[0m[49m[38;5;10m+     148[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     149[0m:[38;5;10m[49m     created_jobs = []
[0m[49m[38;5;10m+     150[0m:[38;5;10m[49m     table = dynamodb.Table(METADATA_TABLE)
