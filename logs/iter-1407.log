[0m[49m[38;5;10m+    1028[0m:[38;5;10m[49m     4. Validate quality
[0m[49m[38;5;10m+    1029[0m:[38;5;10m[49m     5. Generate fused output
[0m[49m[38;5;10m+    1030[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1031[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    1032[0m:[38;5;10m[49m         fixed_modality: The reference modality (typically "CT")
[0m[49m[38;5;10m+    1033[0m:[38;5;10m[49m         moving_modality: The modality to register ("MR" or "PT")
[0m[49m[38;5;10m+    1034[0m:[38;5;10m[49m         body_region: "brain" (rigid) or "body" (deformable)
[0m[49m[38;5;10m+    1035[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1036[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    1037[0m:[38;5;10m[49m         Complete fusion result with quality metrics and output locations
[0m[49m[38;5;10m+    1038[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1039[0m:[38;5;10m[49m     job_id = f"fusion-demo-{datetime.datetime.now(timezone.utc).strftime('%Y%m%d-%H%M%S')}"
[0m[49m[38;5;10m+    1040[0m:[38;5;10m[49m     logger.info("=" * 60)
[0m[49m[38;5;10m+    1041[0m:[38;5;10m[49m     logger.info("Starting fusion pipeline: job_id=%s", job_id)
[0m[49m[38;5;10m+    1042[0m:[38;5;10m[49m     logger.info("  Fixed: %s, Moving: %s, Region: %s", fixed_modality, moving_modality, body_region)
[0m[49m[38;5;10m+    1043[0m:[38;5;10m[49m     logger.info("=" * 60)
[0m[49m[38;5;10m+    1044[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1045[0m:[38;5;10m[49m     # --- Step 1: Create/retrieve study volumes ---
[0m[49m[38;5;10m+    1046[0m:[38;5;10m[49m     logger.info("\nStep 1: Ingesting study volumes")
[0m[49m[38;5;10m+    1047[0m:[38;5;10m[49m     fixed_volume, fixed_affine = create_synthetic_volume(fixed_modality)
