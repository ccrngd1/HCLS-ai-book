[0m[49m[38;5;10m+     925[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     926[0m:[38;5;10m[49m def generate_checkerboard_slice(fixed_slice: np.ndarray,
[0m[49m[38;5;10m+     927[0m:[38;5;10m[49m                                  moving_slice: np.ndarray,
[0m[49m[38;5;10m+     928[0m:[38;5;10m[49m                                  tile_size: int = 16) -> np.ndarray:
[0m[49m[38;5;10m+     929[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     930[0m:[38;5;10m[49m     Create a checkerboard comparison of two aligned image slices.
[0m[49m[38;5;10m+     931[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     932[0m:[38;5;10m[49m     Alternating tiles from the fixed and moving images let you visually
[0m[49m[38;5;10m+     933[0m:[38;5;10m[49m     assess alignment quality. Misregistration shows up as discontinuities
[0m[49m[38;5;10m+     934[0m:[38;5;10m[49m     at tile boundaries (edges that don't connect across tiles).
[0m[49m[38;5;10m+     935[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     936[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     937[0m:[38;5;10m[49m         fixed_slice: 2D slice from fixed image
[0m[49m[38;5;10m+     938[0m:[38;5;10m[49m         moving_slice: 2D slice from registered moving image
[0m[49m[38;5;10m+     939[0m:[38;5;10m[49m         tile_size: Size of each checkerboard tile in pixels
[0m[49m[38;5;10m+     940[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     941[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     942[0m:[38;5;10m[49m         2D array containing the checkerboard composite
[0m[49m[38;5;10m+     943[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     944[0m:[38;5;10m[49m     h, w = fixed_slice.shape[:2]
[0m[49m[38;5;10m+     945[0m:[38;5;10m[49m     result = np.zeros_like(fixed_slice)
[0m[49m[38;5;10m+     946[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     947[0m:[38;5;10m[49m     for i in range(0, h, tile_size):
[0m[49m[38;5;10m+     948[0m:[38;5;10m[49m         for j in range(0, w, tile_size):
[0m[49m[38;5;10m+     949[0m:[38;5;10m[49m             tile_row = (i // tile_size) % 2
[0m[49m[38;5;10m+     950[0m:[38;5;10m[49m             tile_col = (j // tile_size) % 2
[0m[49m[38;5;10m+     951[0m:[38;5;10m[49m             i_end = min(i + tile_size, h)
[0m[49m[38;5;10m+     952[0m:[38;5;10m[49m             j_end = min(j + tile_size, w)
[0m[49m[38;5;10m+     953[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     954[0m:[38;5;10m[49m             if (tile_row + tile_col) % 2 == 0:
[0m[49m[38;5;10m+     955[0m:[38;5;10m[49m                 result[i:i_end, j:j_end] = fixed_slice[i:i_end, j:j_end]
[0m[49m[38;5;10m+     956[0m:[38;5;10m[49m             else:
[0m[49m[38;5;10m+     957[0m:[38;5;10m[49m                 result[i:i_end, j:j_end] = moving_slice[i:i_end, j:j_end]
[0m[49m[38;5;10m+     958[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     959[0m:[38;5;10m[49m     return result
[0m[49m[38;5;10m+     960[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     961[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     962[0m:[38;5;10m[49m def generate_color_overlay_slice(fixed_slice: np.ndarray,
[0m[49m[38;5;10m+     963[0m:[38;5;10m[49m                                   moving_slice: np.ndarray,
[0m[49m[38;5;10m+     964[0m:[38;5;10m[49m                                   moving_modality: str,
[0m[49m[38;5;10m+     965[0m:[38;5;10m[49m                                   alpha: float = 0.4) -> np.ndarray:
[0m[49m[38;5;10m+     966[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     967[0m:[38;5;10m[49m     Create a color overlay of the moving image on the fixed image.
[0m[49m[38;5;10m+     968[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     969[0m:[38;5;10m[49m     The fixed image (CT) is shown in grayscale. The registered moving image
[0m[49m[38;5;10m+     970[0m:[38;5;10m[49m     (MRI or PET) is shown as a colored wash on top. Clinicians use this
[0m[49m[38;5;10m+     971[0m:[38;5;10m[49m     to verify registration quality and to see both modalities simultaneously.
[0m[49m[38;5;10m+     972[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     973[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     974[0m:[38;5;10m[49m         fixed_slice: 2D slice from fixed image (grayscale base)
[0m[49m[38;5;10m+     975[0m:[38;5;10m[49m         moving_slice: 2D slice from registered moving image (color overlay)
[0m[49m[38;5;10m+     976[0m:[38;5;10m[49m         moving_modality: "MR" or "PT" (determines color scheme)
[0m[49m[38;5;10m+     977[0m:[38;5;10m[49m         alpha: Transparency of the overlay (0 = invisible, 1 = opaque)
[0m[49m[38;5;10m+     978[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     979[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     980[0m:[38;5;10m[49m         3D array (H, W, 3) RGB image with the overlay
[0m[49m[38;5;10m+     981[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     982[0m:[38;5;10m[49m     # Normalize both slices to [0, 1] for display.
[0m[49m[38;5;10m+     983[0m:[38;5;10m[49m     def normalize(img):
[0m[49m[38;5;10m+     984[0m:[38;5;10m[49m         mn, mx = img.min(), img.max()
[0m[49m[38;5;10m+     985[0m:[38;5;10m[49m         if mx - mn < 1e-8:
[0m[49m[38;5;10m+     986[0m:[38;5;10m[49m             return np.zeros_like(img)
[0m[49m[38;5;10m+     987[0m:[38;5;10m[49m         return (img - mn) / (mx - mn)
[0m[49m[38;5;10m+     988[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     989[0m:[38;5;10m[49m     fixed_norm = normalize(fixed_slice)
[0m[49m[38;5;10m+     990[0m:[38;5;10m[49m     moving_norm = normalize(moving_slice)
[0m[49m[38;5;10m+     991[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     992[0m:[38;5;10m[49m     # Create RGB output. Fixed as grayscale background.
[0m[49m[38;5;10m+     993[0m:[38;5;10m[49m     rgb = np.stack([fixed_norm, fixed_norm, fixed_norm], axis=-1)
[0m[49m[38;5;10m+     994[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     995[0m:[38;5;10m[49m     # Overlay color depends on modality.
[0m[49m[38;5;10m+     996[0m:[38;5;10m[49m     if moving_modality == "PT":
[0m[49m[38;5;10m+     997[0m:[38;5;10m[49m         # PET: hot colormap (red/yellow for high uptake).
[0m[49m[38;5;10m+     998[0m:[38;5;10m[49m         overlay_color = np.stack([moving_norm, moving_norm * 0.5, np.zeros_like(moving_norm)], axis=-1)
[0m[49m[38;5;10m+     999[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    1000[0m:[38;5;10m[49m         # MRI: blue/cyan.
[0m[49m[38;5;10m+    1001[0m:[38;5;10m[49m         overlay_color = np.stack([np.zeros_like(moving_norm), moving_norm * 0.7, moving_norm], axis=-1)
[0m[49m[38;5;10m+    1002[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1003[0m:[38;5;10m[49m     # Blend with alpha compositing.
[0m[49m[38;5;10m+    1004[0m:[38;5;10m[49m     rgb = (1 - alpha) * rgb + alpha * overlay_color
[0m[49m[38;5;10m+    1005[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1006[0m:[38;5;10m[49m     return np.clip(rgb, 0, 1)
[0m[49m[38;5;10m+    1007[0m:[38;5;10m[49m ```
