[0m[49m[38;5;10m+    1065[0m:[38;5;10m[49m     fixed_processed = fixed_processed[:min_shape[0], :min_shape[1], :min_shape[2]]
[0m[49m[38;5;10m+    1066[0m:[38;5;10m[49m     moving_processed = moving_processed[:min_shape[0], :min_shape[1], :min_shape[2]]
