[0m[49m[38;5;10m+    1069[0m:[38;5;10m[49m     reg_config = REGISTRATION_CONFIG.get(body_region, REGISTRATION_CONFIG["brain"])
[0m[49m[38;5;10m+    1070[0m:[38;5;10m[49m     logger.info("\nStep 3: Computing %s registration", reg_config["type"])
