[0m[49m[38;5;10m+    1053[0m:[38;5;10m[49m     target_spacing = TARGET_SPACING_MM if body_region == "brain" else [2.0, 2.0, 2.0]
[0m[49m[38;5;10m+    1054[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1055[0m:[38;5;10m[49m     fixed_processed, fixed_new_affine = preprocess_volume(
[0m[49m[38;5;10m+    1056[0m:[38;5;10m[49m         fixed_volume, fixed_affine, fixed_modality, target_spacing
[0m[49m[38;5;10m+    1057[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    1058[0m:[38;5;10m[49m     moving_processed, moving_new_affine = preprocess_volume(
[0m[49m[38;5;10m+    1059[0m:[38;5;10m[49m         moving_volume, moving_affine, moving_modality, target_spacing
[0m[49m[38;5;10m+    1060[0m:[38;5;10m[49m     )
