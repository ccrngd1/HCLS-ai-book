[0m[49m[38;5;10m+     211[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     212[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     213[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     214[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     215[0m:[38;5;10m[49m ## Step 2: Preprocess Each Modality
[0m[49m[38;5;10m+     216[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     217[0m:[38;5;10m[49m *The pseudocode calls this `preprocess_study(study_id, modality, target_spacing)`. It retrieves DICOM data, converts to volumetric arrays, applies modality-specific corrections (bias field for MRI, SUV for PET, HU clipping for CT), and resamples to a common voxel spacing.*
[0m[49m[38;5;10m+     218[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     219[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     220[0m:[38;5;10m[49m def create_synthetic_volume(modality: str, shape: tuple = (128, 128, 64)) -> tuple:
[0m[49m[38;5;10m+     221[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     222[0m:[38;5;10m[49m     Generate a synthetic 3D medical image volume for demonstration purposes.
[0m[49m[38;5;10m+     223[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     224[0m:[38;5;10m[49m     Real volumes come from AWS HealthImaging via GetImageFrame API calls,
[0m[49m[38;5;10m+     225[0m:[38;5;10m[49m     then get assembled from DICOM slices into 3D arrays using libraries like
[0m[49m[38;5;10m+     226[0m:[38;5;10m[49m     pydicom or SimpleITK. Here we create synthetic data that mimics the
[0m[49m[38;5;10m+     227[0m:[38;5;10m[49m     intensity characteristics of each modality.
[0m[49m[38;5;10m+     228[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     229[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     230[0m:[38;5;10m[49m         modality: One of "CT", "MR", "PT"
[0m[49m[38;5;10m+     231[0m:[38;5;10m[49m         shape: Volume dimensions (height, width, depth)
[0m[49m[38;5;10m+     232[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     233[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     234[0m:[38;5;10m[49m         Tuple of (volume as numpy array, affine matrix as 4x4 numpy array)
[0m[49m[38;5;10m+     235[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     236[0m:[38;5;10m[49m     np.random.seed(42)  # Reproducible synthetic data
[0m[49m[38;5;10m+     237[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     238[0m:[38;5;10m[49m     if modality == "CT":
[0m[49m[38;5;10m+     239[0m:[38;5;10m[49m         # CT values are in Hounsfield units. Air = -1000, water = 0, bone = 1000+.
[0m[49m[38;5;10m+     240[0m:[38;5;10m[49m         # Simulate a head CT: mostly soft tissue (20-80 HU) with a skull rim (800-1200 HU).
[0m[49m[38;5;10m+     241[0m:[38;5;10m[49m         volume = np.random.normal(loc=40, scale=15, size=shape).astype(np.float32)
[0m[49m[38;5;10m+     242[0m:[38;5;10m[49m         # Add a "skull" ring at the edges.
[0m[49m[38;5;10m+     243[0m:[38;5;10m[49m         center = np.array(shape[:2]) / 2
[0m[49m[38;5;10m+     244[0m:[38;5;10m[49m         y, x = np.ogrid[:shape[0], :shape[1]]
[0m[49m[38;5;10m+     245[0m:[38;5;10m[49m         dist_from_center = np.sqrt((y - center[0])**2 + (x - center[1])**2)
[0m[49m[38;5;10m+     246[0m:[38;5;10m[49m         skull_mask = (dist_from_center > 45) & (dist_from_center < 55)
[0m[49m[38;5;10m+     247[0m:[38;5;10m[49m         for z in range(shape[2]):
[0m[49m[38;5;10m+     248[0m:[38;5;10m[49m             volume[skull_mask, z] = np.random.normal(loc=1000, scale=100,
[0m[49m[38;5;10m+     249[0m:[38;5;10m[49m                                                       size=skull_mask.sum())
[0m[49m[38;5;10m+     250[0m:[38;5;10m[49m         # Add a "tumor" region with slightly different density.
[0m[49m[38;5;10m+     251[0m:[38;5;10m[49m         volume[50:70, 50:70, 25:40] = np.random.normal(loc=55, scale=10,
[0m[49m[38;5;10m+     252[0m:[38;5;10m[49m                                                          size=(20, 20, 15))
[0m[49m[38;5;10m+     253[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     254[0m:[38;5;10m[49m     elif modality == "MR":
[0m[49m[38;5;10m+     255[0m:[38;5;10m[49m         # MRI T1-weighted: CSF is dark, white matter bright, gray matter intermediate.
[0m[49m[38;5;10m+     256[0m:[38;5;10m[49m         # Simulate with a bias field artifact (smooth intensity gradient).
[0m[49m[38;5;10m+     257[0m:[38;5;10m[49m         volume = np.random.normal(loc=150, scale=30, size=shape).astype(np.float32)
[0m[49m[38;5;10m+     258[0m:[38;5;10m[49m         # Add bias field: signal stronger on one side (mimics coil proximity).
[0m[49m[38;5;10m+     259[0m:[38;5;10m[49m         bias_field = np.linspace(0.7, 1.3, shape[0])[:, np.newaxis, np.newaxis]
[0m[49m[38;5;10m+     260[0m:[38;5;10m[49m         volume = volume * bias_field
[0m[49m[38;5;10m+     261[0m:[38;5;10m[49m         # Tumor: brighter on T1 post-contrast.
[0m[49m[38;5;10m+     262[0m:[38;5;10m[49m         volume[50:70, 50:70, 25:40] = np.random.normal(loc=220, scale=20,
[0m[49m[38;5;10m+     263[0m:[38;5;10m[49m                                                          size=(20, 20, 15))
[0m[49m[38;5;10m+     264[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     265[0m:[38;5;10m[49m     elif modality == "PT":
[0m[49m[38;5;10m+     266[0m:[38;5;10m[49m         # PET: metabolic activity measured in SUV. Background ~1-2, active tumor 5-15.
[0m[49m[38;5;10m+     267[0m:[38;5;10m[49m         volume = np.random.exponential(scale=1.5, size=shape).astype(np.float32)
[0m[49m[38;5;10m+     268[0m:[38;5;10m[49m         # Hot tumor: high SUV.
[0m[49m[38;5;10m+     269[0m:[38;5;10m[49m         volume[50:70, 50:70, 25:40] = np.random.normal(loc=8.0, scale=2.0,
[0m[49m[38;5;10m+     270[0m:[38;5;10m[49m                                                          size=(20, 20, 15))
[0m[49m[38;5;10m+     271[0m:[38;5;10m[49m         volume = np.clip(volume, 0, None)  # SUV cannot be negative
[0m[49m[38;5;10m+     272[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     273[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+     274[0m:[38;5;10m[49m         volume = np.random.normal(loc=100, scale=20, size=shape).astype(np.float32)
[0m[49m[38;5;10m+     275[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     276[0m:[38;5;10m[49m     # Create a simple affine matrix (maps voxel indices to physical mm coordinates).
[0m[49m[38;5;10m+     277[0m:[38;5;10m[49m     # In real DICOM, this comes from ImagePositionPatient and ImageOrientationPatient.
[0m[49m[38;5;10m+     278[0m:[38;5;10m[49m     spacing = [1.0, 1.0, 2.0]  # mm per voxel (in-plane 1mm, slice thickness 2mm)
[0m[49m[38;5;10m+     279[0m:[38;5;10m[49m     affine = np.eye(4)
[0m[49m[38;5;10m+     280[0m:[38;5;10m[49m     affine[0, 0] = spacing[0]
[0m[49m[38;5;10m+     281[0m:[38;5;10m[49m     affine[1, 1] = spacing[1]
[0m[49m[38;5;10m+     282[0m:[38;5;10m[49m     affine[2, 2] = spacing[2]
[0m[49m[38;5;10m+     283[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     284[0m:[38;5;10m[49m     return volume, affine
[0m[49m[38;5;10m+     285[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     286[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     287[0m:[38;5;10m[49m def preprocess_volume(volume: np.ndarray, affine: np.ndarray,
[0m[49m[38;5;10m+     288[0m:[38;5;10m[49m                       modality: str, target_spacing: list[float]) -> tuple:
[0m[49m[38;5;10m+     289[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     290[0m:[38;5;10m[49m     Apply modality-specific preprocessing and resample to target spacing.
[0m[49m[38;5;10m+     291[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     292[0m:[38;5;10m[49m     This is where the modality-specific physics shows up. Each imaging technology
[0m[49m[38;5;10m+     293[0m:[38;5;10m[49m     has its own artifacts and normalization requirements:
[0m[49m[38;5;10m+     294[0m:[38;5;10m[49m     - CT: Hounsfield unit range clipping
[0m[49m[38;5;10m+     295[0m:[38;5;10m[49m     - MRI: Bias field correction + intensity normalization
[0m[49m[38;5;10m+     296[0m:[38;5;10m[49m     - PET: SUV normalization (in real data; our synthetic data is already SUV-like)
[0m[49m[38;5;10m+     297[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     298[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     299[0m:[38;5;10m[49m         volume: 3D numpy array of image intensities
[0m[49m[38;5;10m+     300[0m:[38;5;10m[49m         affine: 4x4 affine matrix mapping voxel indices to physical coordinates
[0m[49m[38;5;10m+     301[0m:[38;5;10m[49m         modality: "CT", "MR", or "PT"
[0m[49m[38;5;10m+     302[0m:[38;5;10m[49m         target_spacing: Desired output voxel spacing [x, y, z] in mm
[0m[49m[38;5;10m+     303[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     304[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     305[0m:[38;5;10m[49m         Tuple of (preprocessed volume, updated affine matrix)
[0m[49m[38;5;10m+     306[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     307[0m:[38;5;10m[49m     if modality == "CT":
[0m[49m[38;5;10m+     308[0m:[38;5;10m[49m         # Clip to standard Hounsfield unit range.
[0m[49m[38;5;10m+     309[0m:[38;5;10m[49m         # Values outside this range are scanner table, air outside the patient,
[0m[49m[38;5;10m+     310[0m:[38;5;10m[49m         # or metal artifact. They don't help registration.
[0m[49m[38;5;10m+     311[0m:[38;5;10m[49m         volume = np.clip(volume, CT_HU_MIN, CT_HU_MAX)
[0m[49m[38;5;10m+     312[0m:[38;5;10m[49m         logger.info("  CT preprocessed: clipped to [%d, %d] HU", CT_HU_MIN, CT_HU_MAX)
[0m[49m[38;5;10m+     313[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     314[0m:[38;5;10m[49m     elif modality == "MR":
[0m[49m[38;5;10m+     315[0m:[38;5;10m[49m         # Bias field correction: the real version uses N4ITK algorithm from SimpleITK.
[0m[49m[38;5;10m+     316[0m:[38;5;10m[49m         # Here we approximate it by dividing out a smoothed version of the image.
[0m[49m[38;5;10m+     317[0m:[38;5;10m[49m         # This removes the low-frequency intensity gradient from coil proximity.
[0m[49m[38;5;10m+     318[0m:[38;5;10m[49m         from scipy.ndimage import gaussian_filter
[0m[49m[38;5;10m+     319[0m:[38;5;10m[49m         # Estimate the bias field as a heavily smoothed version of the volume.
[0m[49m[38;5;10m+     320[0m:[38;5;10m[49m         bias_estimate = gaussian_filter(volume, sigma=30)
[0m[49m[38;5;10m+     321[0m:[38;5;10m[49m         # Avoid division by zero in air regions.
[0m[49m[38;5;10m+     322[0m:[38;5;10m[49m         bias_estimate = np.maximum(bias_estimate, 1.0)
[0m[49m[38;5;10m+     323[0m:[38;5;10m[49m         volume = volume / bias_estimate * np.mean(bias_estimate)
[0m[49m[38;5;10m+     324[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     325[0m:[38;5;10m[49m         # Intensity normalization using percentile clipping.
[0m[49m[38;5;10m+     326[0m:[38;5;10m[49m         # This makes the intensity range consistent across different MRI scanners
[0m[49m[38;5;10m+     327[0m:[38;5;10m[49m         # and acquisition parameters.
[0m[49m[38;5;10m+     328[0m:[38;5;10m[49m         p_low = np.percentile(volume, MRI_NORM_PERCENTILE_LOW)
[0m[49m[38;5;10m+     329[0m:[38;5;10m[49m         p_high = np.percentile(volume, MRI_NORM_PERCENTILE_HIGH)
[0m[49m[38;5;10m+     330[0m:[38;5;10m[49m         volume = np.clip(volume, p_low, p_high)
[0m[49m[38;5;10m+     331[0m:[38;5;10m[49m         volume = (volume - p_low) / (p_high - p_low + 1e-8)  # normalize to [0, 1]
[0m[49m[38;5;10m+     332[0m:[38;5;10m[49m         logger.info("  MRI preprocessed: bias corrected, normalized to [0, 1]")
[0m[49m[38;5;10m+     333[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     334[0m:[38;5;10m[49m     elif modality == "PT":
[0m[49m[38;5;10m+     335[0m:[38;5;10m[49m         # In real data, this step converts raw PET counts to Standardized Uptake
[0m[49m[38;5;10m+     336[0m:[38;5;10m[49m         # Values using patient weight and injected dose from DICOM headers.
[0m[49m[38;5;10m+     337[0m:[38;5;10m[49m         # Our synthetic data is already in SUV-like units.
[0m[49m[38;5;10m+     338[0m:[38;5;10m[49m         volume = np.clip(volume, 0, None)  # SUV cannot be negative
[0m[49m[38;5;10m+     339[0m:[38;5;10m[49m         logger.info("  PET preprocessed: clipped negative values")
[0m[49m[38;5;10m+     340[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     341[0m:[38;5;10m[49m     # Resample to target isotropic spacing.
[0m[49m[38;5;10m+     342[0m:[38;5;10m[49m     # Both images need the same voxel dimensions for registration to work properly.
[0m[49m[38;5;10m+     343[0m:[38;5;10m[49m     current_spacing = [affine[0, 0], affine[1, 1], affine[2, 2]]
[0m[49m[38;5;10m+     344[0m:[38;5;10m[49m     zoom_factors = [
[0m[49m[38;5;10m+     345[0m:[38;5;10m[49m         current_spacing[i] / target_spacing[i] for i in range(3)
[0m[49m[38;5;10m+     346[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+     347[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     348[0m:[38;5;10m[49m     from scipy.ndimage import zoom
[0m[49m[38;5;10m+     349[0m:[38;5;10m[49m     volume_resampled = zoom(volume, zoom_factors, order=1)  # linear interpolation
[0m[49m[38;5;10m+     350[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     351[0m:[38;5;10m[49m     # Update affine to reflect new spacing.
[0m[49m[38;5;10m+     352[0m:[38;5;10m[49m     new_affine = affine.copy()
[0m[49m[38;5;10m+     353[0m:[38;5;10m[49m     new_affine[0, 0] = target_spacing[0]
[0m[49m[38;5;10m+     354[0m:[38;5;10m[49m     new_affine[1, 1] = target_spacing[1]
[0m[49m[38;5;10m+     355[0m:[38;5;10m[49m     new_affine[2, 2] = target_spacing[2]
[0m[49m[38;5;10m+     356[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     357[0m:[38;5;10m[49m     logger.info("  Resampled from %s to %s mm, shape: %s -> %s",
[0m[49m[38;5;10m+     358[0m:[38;5;10m[49m                current_spacing, target_spacing, volume.shape, volume_resampled.shape)
[0m[49m[38;5;10m+     359[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     360[0m:[38;5;10m[49m     return volume_resampled, new_affine
[0m[49m[38;5;10m+     361[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     362[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     363[0m:[38;5;10m[49m def upload_preprocessed_volume(volume: np.ndarray, job_id: str,
[0m[49m[38;5;10m+     364[0m:[38;5;10m[49m                                 role: str) -> str:
[0m[49m[38;5;10m+     365[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     366[0m:[38;5;10m[49m     Save a preprocessed volume to S3 as a compressed numpy array.
[0m[49m[38;5;10m+     367[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     368[0m:[38;5;10m[49m     In production, you'd save as NIfTI format (.nii.gz) which preserves
[0m[49m[38;5;10m+     369[0m:[38;5;10m[49m     the affine matrix and is the standard for neuroimaging. Here we use
[0m[49m[38;5;10m+     370[0m:[38;5;10m[49m     numpy's native format for simplicity.
[0m[49m[38;5;10m+     371[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     372[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     373[0m:[38;5;10m[49m         volume: Preprocessed 3D numpy array
[0m[49m[38;5;10m+     374[0m:[38;5;10m[49m         job_id: Fusion job identifier
[0m[49m[38;5;10m+     375[0m:[38;5;10m[49m         role: "fixed" or "moving" (for naming)
[0m[49m[38;5;10m+     376[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     377[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     378[0m:[38;5;10m[49m         S3 key where the volume was stored
[0m[49m[38;5;10m+     379[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     380[0m:[38;5;10m[49m     import io
[0m[49m[38;5;10m+     381[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     382[0m:[38;5;10m[49m     s3_key = f"{job_id}/{role}_preprocessed.npy"
[0m[49m[38;5;10m+     383[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     384[0m:[38;5;10m[49m     # Serialize numpy array to bytes.
[0m[49m[38;5;10m+     385[0m:[38;5;10m[49m     buffer = io.BytesIO()
[0m[49m[38;5;10m+     386[0m:[38;5;10m[49m     np.save(buffer, volume)
[0m[49m[38;5;10m+     387[0m:[38;5;10m[49m     buffer.seek(0)
[0m[49m[38;5;10m+     388[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     389[0m:[38;5;10m[49m     s3_client.put_object(
[0m[49m[38;5;10m+     390[0m:[38;5;10m[49m         Bucket=PROCESSING_BUCKET,
[0m[49m[38;5;10m+     391[0m:[38;5;10m[49m         Key=s3_key,
[0m[49m[38;5;10m+     392[0m:[38;5;10m[49m         Body=buffer.getvalue(),
[0m[49m[38;5;10m+     393[0m:[38;5;10m[49m         ServerSideEncryption="aws:kms",
[0m[49m[38;5;10m+     394[0m:[38;5;10m[49m         # In production, specify your CMK: SSEKMSKeyId="arn:aws:kms:..."
[0m[49m[38;5;10m+     395[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     396[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     397[0m:[38;5;10m[49m     logger.info("  Uploaded %s volume to s3://%s/%s", role, PROCESSING_BUCKET, s3_key)
[0m[49m[38;5;10m+     398[0m:[38;5;10m[49m     return s3_key
[0m[49m[38;5;10m+     399[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     400[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     401[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     402[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     403[0m:[38;5;10m[49m ## Step 3: Compute Registration (Align Moving to Fixed)
[0m[49m[38;5;10m+     404[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     405[0m:[38;5;10m[49m *The pseudocode calls this `register_images(fixed_path, moving_path, registration_type)`. This is the computational core: it aligns the moving image (MRI or PET) to the fixed image (CT) by finding the spatial transformation that maximizes their statistical similarity.*
[0m[49m[38;5;10m+     406[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     407[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     408[0m:[38;5;10m[49m def compute_rigid_registration(fixed: np.ndarray, moving: np.ndarray) -> dict:
[0m[49m[38;5;10m+     409[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     410[0m:[38;5;10m[49m     Compute rigid registration between two volumes using mutual information.
[0m[49m[38;5;10m+     411[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     412[0m:[38;5;10m[49m     Rigid registration finds 6 parameters (3 translations + 3 rotations) that
[0m[49m[38;5;10m+     413[0m:[38;5;10m[49m     best align the moving image to the fixed image. Appropriate for brain imaging
[0m[49m[38;5;10m+     414[0m:[38;5;10m[49m     where the skull constrains soft tissue motion.
[0m[49m[38;5;10m+     415[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     416[0m:[38;5;10m[49m     This uses scipy's optimization to maximize mutual information. In production,
[0m[49m[38;5;10m+     417[0m:[38;5;10m[49m     you'd use SimpleITK's registration framework or a SageMaker-hosted model.
[0m[49m[38;5;10m+     418[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     419[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     420[0m:[38;5;10m[49m         fixed: 3D numpy array (the reference, typically CT)
[0m[49m[38;5;10m+     421[0m:[38;5;10m[49m         moving: 3D numpy array (to be aligned, typically MRI or PET)
[0m[49m[38;5;10m+     422[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     423[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     424[0m:[38;5;10m[49m         Dict containing:
[0m[49m[38;5;10m+     425[0m:[38;5;10m[49m         - transform_params: The 6 rigid body parameters [tx, ty, tz, rx, ry, rz]
[0m[49m[38;5;10m+     426[0m:[38;5;10m[49m         - registered_moving: The moving image after applying the transform
[0m[49m[38;5;10m+     427[0m:[38;5;10m[49m         - mutual_information: MI score of the aligned pair
[0m[49m[38;5;10m+     428[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     429[0m:[38;5;10m[49m     from scipy.ndimage import affine_transform
[0m[49m[38;5;10m+     430[0m:[38;5;10m[49m     from scipy.optimize import minimize
[0m[49m[38;5;10m+     431[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     432[0m:[38;5;10m[49m     def compute_mi(image1: np.ndarray, image2: np.ndarray, bins: int = 32) -> float:
[0m[49m[38;5;10m+     433[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     434[0m:[38;5;10m[49m         Compute mutual information between two images.
[0m[49m[38;5;10m+     435[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     436[0m:[38;5;10m[49m         MI measures statistical dependence: if two images are well-aligned,
[0m[49m[38;5;10m+     437[0m:[38;5;10m[49m         knowing the intensity at a location in one image reduces your
[0m[49m[38;5;10m+     438[0m:[38;5;10m[49m         uncertainty about the intensity at the corresponding location in
[0m[49m[38;5;10m+     439[0m:[38;5;10m[49m         the other image.
[0m[49m[38;5;10m+     440[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     441[0m:[38;5;10m[49m         Higher MI = better alignment. This works across modalities because
[0m[49m[38;5;10m+     442[0m:[38;5;10m[49m         it doesn't assume intensities match, only that they're correlated.
[0m[49m[38;5;10m+     443[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     444[0m:[38;5;10m[49m         # Downsample for speed during optimization (compute MI on a subsample).
[0m[49m[38;5;10m+     445[0m:[38;5;10m[49m         step = 2
[0m[49m[38;5;10m+     446[0m:[38;5;10m[49m         img1_flat = image1[::step, ::step, ::step].ravel()
[0m[49m[38;5;10m+     447[0m:[38;5;10m[49m         img2_flat = image2[::step, ::step, ::step].ravel()
[0m[49m[38;5;10m+     448[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     449[0m:[38;5;10m[49m         # Joint histogram.
[0m[49m[38;5;10m+     450[0m:[38;5;10m[49m         hist_2d, _, _ = np.histogram2d(img1_flat, img2_flat, bins=bins)
[0m[49m[38;5;10m+     451[0m:[38;5;10m[49m         # Normalize to probability distribution.
[0m[49m[38;5;10m+     452[0m:[38;5;10m[49m         pxy = hist_2d / hist_2d.sum()
[0m[49m[38;5;10m+     453[0m:[38;5;10m[49m         px = pxy.sum(axis=1)  # marginal for image 1
[0m[49m[38;5;10m+     454[0m:[38;5;10m[49m         py = pxy.sum(axis=0)  # marginal for image 2
[0m[49m[38;5;10m+     455[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     456[0m:[38;5;10m[49m         # MI = sum over all bins of p(x,y) * log(p(x,y) / (p(x) * p(y)))
[0m[49m[38;5;10m+     457[0m:[38;5;10m[49m         # Use masks to avoid log(0).
[0m[49m[38;5;10m+     458[0m:[38;5;10m[49m         nonzero = pxy > 0
[0m[49m[38;5;10m+     459[0m:[38;5;10m[49m         px_py = px[:, np.newaxis] * py[np.newaxis, :]
[0m[49m[38;5;10m+     460[0m:[38;5;10m[49m         mi = np.sum(pxy[nonzero] * np.log(pxy[nonzero] / (px_py[nonzero] + 1e-10)))
[0m[49m[38;5;10m+     461[0m:[38;5;10m[49m         return mi
[0m[49m[38;5;10m+     462[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     463[0m:[38;5;10m[49m     def apply_rigid_transform(volume: np.ndarray, params: np.ndarray) -> np.ndarray:
[0m[49m[38;5;10m+     464[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     465[0m:[38;5;10m[49m         Apply a rigid body transformation to a 3D volume.
[0m[49m[38;5;10m+     466[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     467[0m:[38;5;10m[49m         params: [tx, ty, tz, rx, ry, rz]
[0m[49m[38;5;10m+     468[0m:[38;5;10m[49m         - tx, ty, tz: translation in voxels
[0m[49m[38;5;10m+     469[0m:[38;5;10m[49m         - rx, ry, rz: rotation in radians (small angles approximation)
[0m[49m[38;5;10m+     470[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     471[0m:[38;5;10m[49m         tx, ty, tz, rx, ry, rz = params
[0m[49m[38;5;10m+     472[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     473[0m:[38;5;10m[49m         # Rotation matrix from Euler angles (small angle approximation for speed).
[0m[49m[38;5;10m+     474[0m:[38;5;10m[49m         cos_x, sin_x = np.cos(rx), np.sin(rx)
[0m[49m[38;5;10m+     475[0m:[38;5;10m[49m         cos_y, sin_y = np.cos(ry), np.sin(ry)
[0m[49m[38;5;10m+     476[0m:[38;5;10m[49m         cos_z, sin_z = np.cos(rz), np.sin(rz)
[0m[49m[38;5;10m+     477[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     478[0m:[38;5;10m[49m         # Combined rotation matrix (Rz * Ry * Rx).
[0m[49m[38;5;10m+     479[0m:[38;5;10m[49m         rot_matrix = np.array([
[0m[49m[38;5;10m+     480[0m:[38;5;10m[49m             [cos_y * cos_z, sin_x * sin_y * cos_z - cos_x * sin_z,
[0m[49m[38;5;10m+     481[0m:[38;5;10m[49m              cos_x * sin_y * cos_z + sin_x * sin_z],
[0m[49m[38;5;10m+     482[0m:[38;5;10m[49m             [cos_y * sin_z, sin_x * sin_y * sin_z + cos_x * cos_z,
[0m[49m[38;5;10m+     483[0m:[38;5;10m[49m              cos_x * sin_y * sin_z - sin_x * cos_z],
[0m[49m[38;5;10m+     484[0m:[38;5;10m[49m             [-sin_y, sin_x * cos_y, cos_x * cos_y]
[0m[49m[38;5;10m+     485[0m:[38;5;10m[49m         ])
[0m[49m[38;5;10m+     486[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     487[0m:[38;5;10m[49m         # Offset for rotation about volume center.
[0m[49m[38;5;10m+     488[0m:[38;5;10m[49m         center = np.array(volume.shape) / 2.0
[0m[49m[38;5;10m+     489[0m:[38;5;10m[49m         offset = center - rot_matrix @ center + np.array([tx, ty, tz])
[0m[49m[38;5;10m+     490[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     491[0m:[38;5;10m[49m         transformed = affine_transform(volume, rot_matrix, offset=offset, order=1)
[0m[49m[38;5;10m+     492[0m:[38;5;10m[49m         return transformed
[0m[49m[38;5;10m+     493[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     494[0m:[38;5;10m[49m     def neg_mi_objective(params):
[0m[49m[38;5;10m+     495[0m:[38;5;10m[49m         """Objective function: negative MI (minimize negative = maximize MI)."""
[0m[49m[38;5;10m+     496[0m:[38;5;10m[49m         transformed = apply_rigid_transform(moving, params)
[0m[49m[38;5;10m+     497[0m:[38;5;10m[49m         return -compute_mi(fixed, transformed)
[0m[49m[38;5;10m+     498[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     499[0m:[38;5;10m[49m     # Multi-resolution: start at coarse resolution for robustness,
[0m[49m[38;5;10m+     500[0m:[38;5;10m[49m     # then refine at full resolution.
[0m[49m[38;5;10m+     501[0m:[38;5;10m[49m     logger.info("  Running rigid registration (mutual information)...")
[0m[49m[38;5;10m+     502[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     503[0m:[38;5;10m[49m     # Initial parameters: no transformation.
[0m[49m[38;5;10m+     504[0m:[38;5;10m[49m     x0 = np.zeros(6)
[0m[49m[38;5;10m+     505[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     506[0m:[38;5;10m[49m     # Optimize with bounded search (translations within +/- 20 voxels,
[0m[49m[38;5;10m+     507[0m:[38;5;10m[49m     # rotations within +/- 15 degrees).
[0m[49m[38;5;10m+     508[0m:[38;5;10m[49m     bounds = [(-20, 20), (-20, 20), (-20, 20),
[0m[49m[38;5;10m+     509[0m:[38;5;10m[49m               (-0.26, 0.26), (-0.26, 0.26), (-0.26, 0.26)]
[0m[49m[38;5;10m+     510[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     511[0m:[38;5;10m[49m     result = minimize(neg_mi_objective, x0, method="L-BFGS-B",
[0m[49m[38;5;10m+     512[0m:[38;5;10m[49m                      bounds=bounds, options={"maxiter": 100, "ftol": 1e-6})
[0m[49m[38;5;10m+     513[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     514[0m:[38;5;10m[49m     # Apply the optimized transform to get the registered moving image.
[0m[49m[38;5;10m+     515[0m:[38;5;10m[49m     best_params = result.x
[0m[49m[38;5;10m+     516[0m:[38;5;10m[49m     registered_moving = apply_rigid_transform(moving, best_params)
[0m[49m[38;5;10m+     517[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     518[0m:[38;5;10m[49m     # Compute final MI score.
[0m[49m[38;5;10m+     519[0m:[38;5;10m[49m     final_mi = compute_mi(fixed, registered_moving)
[0m[49m[38;5;10m+     520[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     521[0m:[38;5;10m[49m     logger.info("  Rigid registration complete. MI: %.3f, params: %s",
[0m[49m[38;5;10m+     522[0m:[38;5;10m[49m                final_mi, np.round(best_params, 3))
[0m[49m[38;5;10m+     523[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     524[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     525[0m:[38;5;10m[49m         "transform_params": best_params.tolist(),
[0m[49m[38;5;10m+     526[0m:[38;5;10m[49m         "registered_moving": registered_moving,
[0m[49m[38;5;10m+     527[0m:[38;5;10m[49m         "mutual_information": final_mi,
[0m[49m[38;5;10m+     528[0m:[38;5;10m[49m         "registration_type": "rigid",
[0m[49m[38;5;10m+     529[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     530[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     531[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     532[0m:[38;5;10m[49m def compute_deformable_registration_via_sagemaker(
[0m[49m[38;5;10m+     533[0m:[38;5;10m[49m     fixed: np.ndarray, moving: np.ndarray, job_id: str
[0m[49m[38;5;10m+     534[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+     535[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     536[0m:[38;5;10m[49m     Invoke a SageMaker-hosted deep learning model for deformable registration.
[0m[49m[38;5;10m+     537[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     538[0m:[38;5;10m[49m     In production, this calls a VoxelMorph or TransMorph model that predicts
[0m[49m[38;5;10m+     539[0m:[38;5;10m[49m     a dense displacement field in a single forward pass. The model takes
[0m[49m[38;5;10m+     540[0m:[38;5;10m[49m     the fixed and moving volumes as input (concatenated along channel dimension)
[0m[49m[38;5;10m+     541[0m:[38;5;10m[49m     and outputs a 3-channel displacement field (dx, dy, dz per voxel).
[0m[49m[38;5;10m+     542[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     543[0m:[38;5;10m[49m     For this example, we simulate the model output since we can't actually
[0m[49m[38;5;10m+     544[0m:[38;5;10m[49m     invoke a trained endpoint without one deployed. The structure shows exactly
[0m[49m[38;5;10m+     545[0m:[38;5;10m[49m     how you'd interact with SageMaker Runtime.
[0m[49m[38;5;10m+     546[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     547[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     548[0m:[38;5;10m[49m         fixed: Preprocessed fixed volume (CT)
[0m[49m[38;5;10m+     549[0m:[38;5;10m[49m         moving: Preprocessed moving volume (MRI), already rigidly aligned
[0m[49m[38;5;10m+     550[0m:[38;5;10m[49m         job_id: For tracking
[0m[49m[38;5;10m+     551[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     552[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     553[0m:[38;5;10m[49m         Dict with deformation_field, registered_moving, and quality info
[0m[49m[38;5;10m+     554[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     555[0m:[38;5;10m[49m     # --- In production, this is the actual SageMaker invocation: ---
[0m[49m[38;5;10m+     556[0m:[38;5;10m[49m     #
[0m[49m[38;5;10m+     557[0m:[38;5;10m[49m     # # Prepare model input: stack fixed and moving as a 2-channel input.
[0m[49m[38;5;10m+     558[0m:[38;5;10m[49m     # model_input = np.stack([fixed, moving], axis=0)  # shape: (2, H, W, D)
[0m[49m[38;5;10m+     559[0m:[38;5;10m[49m     #
[0m[49m[38;5;10m+     560[0m:[38;5;10m[49m     # # Serialize to bytes for the endpoint.
[0m[49m[38;5;10m+     561[0m:[38;5;10m[49m     # import io
[0m[49m[38;5;10m+     562[0m:[38;5;10m[49m     # buffer = io.BytesIO()
[0m[49m[38;5;10m+     563[0m:[38;5;10m[49m     # np.save(buffer, model_input.astype(np.float32))
[0m[49m[38;5;10m+     564[0m:[38;5;10m[49m     # payload = buffer.getvalue()
[0m[49m[38;5;10m+     565[0m:[38;5;10m[49m     #
[0m[49m[38;5;10m+     566[0m:[38;5;10m[49m     # # Invoke the SageMaker endpoint.
[0m[49m[38;5;10m+     567[0m:[38;5;10m[49m     # response = sagemaker_runtime.invoke_endpoint(
[0m[49m[38;5;10m+     568[0m:[38;5;10m[49m     #     EndpointName=REGISTRATION_ENDPOINT,
[0m[49m[38;5;10m+     569[0m:[38;5;10m[49m     #     ContentType="application/x-npy",
[0m[49m[38;5;10m+     570[0m:[38;5;10m[49m     #     Accept="application/x-npy",
[0m[49m[38;5;10m+     571[0m:[38;5;10m[49m     #     Body=payload,
[0m[49m[38;5;10m+     572[0m:[38;5;10m[49m     # )
[0m[49m[38;5;10m+     573[0m:[38;5;10m[49m     #
[0m[49m[38;5;10m+     574[0m:[38;5;10m[49m     # # Parse the response: a displacement field of shape (3, H, W, D).
[0m[49m[38;5;10m+     575[0m:[38;5;10m[49m     # result_buffer = io.BytesIO(response["Body"].read())
[0m[49m[38;5;10m+     576[0m:[38;5;10m[49m     # deformation_field = np.load(result_buffer)
[0m[49m[38;5;10m+     577[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     578[0m:[38;5;10m[49m     # --- For demonstration, simulate a small deformation field ---
[0m[49m[38;5;10m+     579[0m:[38;5;10m[49m     logger.info("  Computing deformable registration via SageMaker endpoint...")
[0m[49m[38;5;10m+     580[0m:[38;5;10m[49m     logger.info("  (Simulating model inference for demonstration)")
[0m[49m[38;5;10m+     581[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     582[0m:[38;5;10m[49m     # Simulate a smooth, physically plausible deformation field.
[0m[49m[38;5;10m+     583[0m:[38;5;10m[49m     # In reality, the model would output learned displacements.
[0m[49m[38;5;10m+     584[0m:[38;5;10m[49m     from scipy.ndimage import gaussian_filter
[0m[49m[38;5;10m+     585[0m:[38;5;10m[49m     shape = fixed.shape
[0m[49m[38;5;10m+     586[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     587[0m:[38;5;10m[49m     # Random displacement field smoothed to be physically plausible.
[0m[49m[38;5;10m+     588[0m:[38;5;10m[49m     deformation_field = np.zeros((*shape, 3), dtype=np.float32)
[0m[49m[38;5;10m+     589[0m:[38;5;10m[49m     for axis in range(3):
[0m[49m[38;5;10m+     590[0m:[38;5;10m[49m         raw_displacement = np.random.normal(0, 0.5, shape)
[0m[49m[38;5;10m+     591[0m:[38;5;10m[49m         # Heavy smoothing ensures the deformation is diffeomorphic (no folding).
[0m[49m[38;5;10m+     592[0m:[38;5;10m[49m         deformation_field[..., axis] = gaussian_filter(raw_displacement, sigma=10)
[0m[49m[38;5;10m+     593[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     594[0m:[38;5;10m[49m     # Apply deformation field to moving image using grid sampling.
[0m[49m[38;5;10m+     595[0m:[38;5;10m[49m     registered_moving = apply_deformation_field(moving, deformation_field)
[0m[49m[38;5;10m+     596[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     597[0m:[38;5;10m[49m     # Compute MI on the result.
[0m[49m[38;5;10m+     598[0m:[38;5;10m[49m     # (Reusing the MI function from rigid registration for consistency.)
[0m[49m[38;5;10m+     599[0m:[38;5;10m[49m     hist_2d, _, _ = np.histogram2d(
[0m[49m[38;5;10m+     600[0m:[38;5;10m[49m         fixed[::2, ::2, ::2].ravel(),
[0m[49m[38;5;10m+     601[0m:[38;5;10m[49m         registered_moving[::2, ::2, ::2].ravel(),
[0m[49m[38;5;10m+     602[0m:[38;5;10m[49m         bins=32
[0m[49m[38;5;10m+     603[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     604[0m:[38;5;10m[49m     pxy = hist_2d / hist_2d.sum()
[0m[49m[38;5;10m+     605[0m:[38;5;10m[49m     px = pxy.sum(axis=1)
[0m[49m[38;5;10m+     606[0m:[38;5;10m[49m     py = pxy.sum(axis=0)
[0m[49m[38;5;10m+     607[0m:[38;5;10m[49m     nonzero = pxy > 0
[0m[49m[38;5;10m+     608[0m:[38;5;10m[49m     px_py = px[:, np.newaxis] * py[np.newaxis, :]
[0m[49m[38;5;10m+     609[0m:[38;5;10m[49m     final_mi = float(np.sum(pxy[nonzero] * np.log(pxy[nonzero] / (px_py[nonzero] + 1e-10))))
[0m[49m[38;5;10m+     610[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     611[0m:[38;5;10m[49m     logger.info("  Deformable registration complete. MI: %.3f", final_mi)
[0m[49m[38;5;10m+     612[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     613[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     614[0m:[38;5;10m[49m         "deformation_field": deformation_field,
[0m[49m[38;5;10m+     615[0m:[38;5;10m[49m         "registered_moving": registered_moving,
[0m[49m[38;5;10m+     616[0m:[38;5;10m[49m         "mutual_information": final_mi,
[0m[49m[38;5;10m+     617[0m:[38;5;10m[49m         "registration_type": "deformable",
[0m[49m[38;5;10m+     618[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     619[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     620[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     621[0m:[38;5;10m[49m def apply_deformation_field(volume: np.ndarray,
[0m[49m[38;5;10m+     622[0m:[38;5;10m[49m                             deformation_field: np.ndarray) -> np.ndarray:
[0m[49m[38;5;10m+     623[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     624[0m:[38;5;10m[49m     Warp a volume using a dense displacement field.
[0m[49m[38;5;10m+     625[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     626[0m:[38;5;10m[49m     Each voxel in the output is sampled from the input at coordinates
[0m[49m[38;5;10m+     627[0m:[38;5;10m[49m     shifted by the displacement vector at that location.
[0m[49m[38;5;10m+     628[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     629[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     630[0m:[38;5;10m[49m         volume: Input 3D volume to warp
[0m[49m[38;5;10m+     631[0m:[38;5;10m[49m         deformation_field: Shape (H, W, D, 3), displacement in voxels per axis
[0m[49m[38;5;10m+     632[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     633[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     634[0m:[38;5;10m[49m         Warped volume with same shape as input
[0m[49m[38;5;10m+     635[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     636[0m:[38;5;10m[49m     from scipy.ndimage import map_coordinates
[0m[49m[38;5;10m+     637[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     638[0m:[38;5;10m[49m     shape = volume.shape
[0m[49m[38;5;10m+     639[0m:[38;5;10m[49m     # Create a regular coordinate grid.
[0m[49m[38;5;10m+     640[0m:[38;5;10m[49m     coords = np.mgrid[0:shape[0], 0:shape[1], 0:shape[2]].astype(np.float32)
[0m[49m[38;5;10m+     641[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     642[0m:[38;5;10m[49m     # Add displacement field to coordinates.
[0m[49m[38;5;10m+     643[0m:[38;5;10m[49m     # coords shape: (3, H, W, D), deformation_field needs to be transposed.
[0m[49m[38;5;10m+     644[0m:[38;5;10m[49m     displaced_coords = coords + deformation_field.transpose(3, 0, 1, 2)
[0m[49m[38;5;10m+     645[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     646[0m:[38;5;10m[49m     # Sample the volume at displaced coordinates using trilinear interpolation.
[0m[49m[38;5;10m+     647[0m:[38;5;10m[49m     warped = map_coordinates(volume, displaced_coords, order=1, mode="nearest")
[0m[49m[38;5;10m+     648[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     649[0m:[38;5;10m[49m     return warped
[0m[49m[38;5;10m+     650[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     651[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     652[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     653[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     654[0m:[38;5;10m[49m ## Step 4: Validate Registration Quality
[0m[49m[38;5;10m+     655[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     656[0m:[38;5;10m[49m *The pseudocode calls this `validate_registration_quality(job_id, fixed_volume, registered_moving, deformation_field)`. This is the safety mechanism. A registration that looks plausible can still be subtly wrong, and in treatment planning a 3mm error means irradiating the wrong tissue.*
[0m[49m[38;5;10m+     657[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     658[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     659[0m:[38;5;10m[49m def validate_registration_quality(
[0m[49m[38;5;10m+     660[0m:[38;5;10m[49m     job_id: str,
[0m[49m[38;5;10m+     661[0m:[38;5;10m[49m     fixed: np.ndarray,
[0m[49m[38;5;10m+     662[0m:[38;5;10m[49m     registered_moving: np.ndarray,
[0m[49m[38;5;10m+     663[0m:[38;5;10m[49m     deformation_field: Optional[np.ndarray] = None
[0m[49m[38;5;10m+     664[0m:[38;5;10m[49m ) -> tuple[bool, dict]:
[0m[49m[38;5;10m+     665[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     666[0m:[38;5;10m[49m     Run automated quality checks on a completed registration.
[0m[49m[38;5;10m+     667[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     668[0m:[38;5;10m[49m     Three checks are applied:
[0m[49m[38;5;10m+     669[0m:[38;5;10m[49m     1. Mutual information: is the statistical alignment good enough?
[0m[49m[38;5;10m+     670[0m:[38;5;10m[49m     2. Jacobian determinant (deformable only): is the deformation physically plausible?
[0m[49m[38;5;10m+     671[0m:[38;5;10m[49m     3. Overlap of automatically detected structures: do known landmarks align?
[0m[49m[38;5;10m+     672[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     673[0m:[38;5;10m[49m     If any check fails, the job is routed to a medical physicist for manual
[0m[49m[38;5;10m+     674[0m:[38;5;10m[49m     review rather than being silently accepted. In radiation therapy, the
[0m[49m[38;5;10m+     675[0m:[38;5;10m[49m     consequences of bad registration include irradiating the wrong anatomy.
[0m[49m[38;5;10m+     676[0m:[38;5;10m[49m     The quality gate is not optional.
[0m[49m[38;5;10m+     677[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     678[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     679[0m:[38;5;10m[49m         job_id: Fusion job identifier
[0m[49m[38;5;10m+     680[0m:[38;5;10m[49m         fixed: The fixed (reference) volume
[0m[49m[38;5;10m+     681[0m:[38;5;10m[49m         registered_moving: The moving volume after registration
[0m[49m[38;5;10m+     682[0m:[38;5;10m[49m         deformation_field: Dense displacement field (None for rigid)
[0m[49m[38;5;10m+     683[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     684[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     685[0m:[38;5;10m[49m         Tuple of (passed: bool, quality_report: dict with all metrics)
[0m[49m[38;5;10m+     686[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     687[0m:[38;5;10m[49m     quality_report = {}
[0m[49m[38;5;10m+     688[0m:[38;5;10m[49m     passed = True
[0m[49m[38;5;10m+     689[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     690[0m:[38;5;10m[49m     # --- Check 1: Mutual Information ---
[0m[49m[38;5;10m+     691[0m:[38;5;10m[49m     # Compute MI between fixed and registered moving.
[0m[49m[38;5;10m+     692[0m:[38;5;10m[49m     hist_2d, _, _ = np.histogram2d(
[0m[49m[38;5;10m+     693[0m:[38;5;10m[49m         fixed[::2, ::2, ::2].ravel(),
[0m[49m[38;5;10m+     694[0m:[38;5;10m[49m         registered_moving[::2, ::2, ::2].ravel(),
[0m[49m[38;5;10m+     695[0m:[38;5;10m[49m         bins=32
[0m[49m[38;5;10m+     696[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     697[0m:[38;5;10m[49m     pxy = hist_2d / hist_2d.sum()
[0m[49m[38;5;10m+     698[0m:[38;5;10m[49m     px = pxy.sum(axis=1)
[0m[49m[38;5;10m+     699[0m:[38;5;10m[49m     py = pxy.sum(axis=0)
[0m[49m[38;5;10m+     700[0m:[38;5;10m[49m     nonzero = pxy > 0
[0m[49m[38;5;10m+     701[0m:[38;5;10m[49m     px_py = px[:, np.newaxis] * py[np.newaxis, :]
[0m[49m[38;5;10m+     702[0m:[38;5;10m[49m     mi_score = float(np.sum(pxy[nonzero] * np.log(pxy[nonzero] / (px_py[nonzero] + 1e-10))))
[0m[49m[38;5;10m+     703[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     704[0m:[38;5;10m[49m     quality_report["mutual_information"] = round(mi_score, 4)
[0m[49m[38;5;10m+     705[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     706[0m:[38;5;10m[49m     if mi_score < MI_THRESHOLD:
[0m[49m[38;5;10m+     707[0m:[38;5;10m[49m         passed = False
[0m[49m[38;5;10m+     708[0m:[38;5;10m[49m         quality_report["mi_failure"] = (
[0m[49m[38;5;10m+     709[0m:[38;5;10m[49m             f"MI ({mi_score:.3f}) below threshold ({MI_THRESHOLD}). "
[0m[49m[38;5;10m+     710[0m:[38;5;10m[49m             "Possible misregistration or poor image quality."
[0m[49m[38;5;10m+     711[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     712[0m:[38;5;10m[49m         logger.warning("  QA FAILED: MI below threshold (%.3f < %.3f)",
[0m[49m[38;5;10m+     713[0m:[38;5;10m[49m                       mi_score, MI_THRESHOLD)
[0m[49m[38;5;10m+     714[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     715[0m:[38;5;10m[49m     # --- Check 2: Jacobian Determinant (deformable only) ---
[0m[49m[38;5;10m+     716[0m:[38;5;10m[49m     # The Jacobian determinant at each voxel measures local volume change.
[0m[49m[38;5;10m+     717[0m:[38;5;10m[49m     # det(J) = 1: no change. det(J) > 1: expansion. det(J) < 1: compression.
[0m[49m[38;5;10m+     718[0m:[38;5;10m[49m     # det(J) <= 0: folding (tissue passes through itself). Physically impossible.
[0m[49m[38;5;10m+     719[0m:[38;5;10m[49m     if deformation_field is not None:
[0m[49m[38;5;10m+     720[0m:[38;5;10m[49m         jacobian_det = compute_jacobian_determinant(deformation_field)
[0m[49m[38;5;10m+     721[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     722[0m:[38;5;10m[49m         folding_fraction = float(np.mean(jacobian_det <= 0))
[0m[49m[38;5;10m+     723[0m:[38;5;10m[49m         quality_report["folding_fraction"] = round(folding_fraction, 6)
[0m[49m[38;5;10m+     724[0m:[38;5;10m[49m         quality_report["jacobian_min"] = round(float(jacobian_det.min()), 4)
[0m[49m[38;5;10m+     725[0m:[38;5;10m[49m         quality_report["jacobian_max"] = round(float(jacobian_det.max()), 4)
[0m[49m[38;5;10m+     726[0m:[38;5;10m[49m         quality_report["jacobian_mean"] = round(float(jacobian_det.mean()), 4)
[0m[49m[38;5;10m+     727[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     728[0m:[38;5;10m[49m         if folding_fraction > MAX_FOLDING_FRACTION:
[0m[49m[38;5;10m+     729[0m:[38;5;10m[49m             passed = False
[0m[49m[38;5;10m+     730[0m:[38;5;10m[49m             quality_report["jacobian_failure"] = (
[0m[49m[38;5;10m+     731[0m:[38;5;10m[49m                 f"Folding fraction ({folding_fraction:.4f}) exceeds "
[0m[49m[38;5;10m+     732[0m:[38;5;10m[49m                 f"threshold ({MAX_FOLDING_FRACTION}). Deformation is "
[0m[49m[38;5;10m+     733[0m:[38;5;10m[49m                 "physically implausible in some regions."
[0m[49m[38;5;10m+     734[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+     735[0m:[38;5;10m[49m             logger.warning("  QA FAILED: Excessive folding (%.4f > %.4f)",
[0m[49m[38;5;10m+     736[0m:[38;5;10m[49m                           folding_fraction, MAX_FOLDING_FRACTION)
[0m[49m[38;5;10m+     737[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+     738[0m:[38;5;10m[49m         quality_report["folding_fraction"] = None
[0m[49m[38;5;10m+     739[0m:[38;5;10m[49m         quality_report["note"] = "Rigid registration: no deformation field to check"
[0m[49m[38;5;10m+     740[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     741[0m:[38;5;10m[49m     # --- Check 3: Structure overlap (simplified) ---
[0m[49m[38;5;10m+     742[0m:[38;5;10m[49m     # In production, you'd segment known structures (e.g., skull, ventricles)
[0m[49m[38;5;10m+     743[0m:[38;5;10m[49m     # in both images and compute Dice overlap after registration.
[0m[49m[38;5;10m+     744[0m:[38;5;10m[49m     # Here we use a simple intensity-based landmark check.
[0m[49m[38;5;10m+     745[0m:[38;5;10m[49m     # Threshold both images to find high-intensity regions and compute overlap.
[0m[49m[38;5;10m+     746[0m:[38;5;10m[49m     fixed_mask = fixed > np.percentile(fixed, 90)
[0m[49m[38;5;10m+     747[0m:[38;5;10m[49m     moving_mask = registered_moving > np.percentile(registered_moving, 90)
[0m[49m[38;5;10m+     748[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     749[0m:[38;5;10m[49m     # Dice coefficient: 2 * |intersection| / (|A| + |B|)
[0m[49m[38;5;10m+     750[0m:[38;5;10m[49m     intersection = np.sum(fixed_mask & moving_mask)
[0m[49m[38;5;10m+     751[0m:[38;5;10m[49m     dice = 2.0 * intersection / (np.sum(fixed_mask) + np.sum(moving_mask) + 1e-8)
[0m[49m[38;5;10m+     752[0m:[38;5;10m[49m     quality_report["high_intensity_dice"] = round(float(dice), 4)
[0m[49m[38;5;10m+     753[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     754[0m:[38;5;10m[49m     # Update status in DynamoDB.
[0m[49m[38;5;10m+     755[0m:[38;5;10m[49m     status = "QA_PASSED" if passed else "QA_FAILED_REVIEW_NEEDED"
[0m[49m[38;5;10m+     756[0m:[38;5;10m[49m     table = dynamodb.Table(METADATA_TABLE)
[0m[49m[38;5;10m+     757[0m:[38;5;10m[49m     table.update_item(
[0m[49m[38;5;10m+     758[0m:[38;5;10m[49m         Key={"job_id": job_id},
[0m[49m[38;5;10m+     759[0m:[38;5;10m[49m         UpdateExpression="SET #s = :status, quality_metrics = :qm",
[0m[49m[38;5;10m+     760[0m:[38;5;10m[49m         ExpressionAttributeNames={"#s": "status"},
[0m[49m[38;5;10m+     761[0m:[38;5;10m[49m         ExpressionAttributeValues={
[0m[49m[38;5;10m+     762[0m:[38;5;10m[49m             ":status": status,
[0m[49m[38;5;10m+     763[0m:[38;5;10m[49m             ":qm": json.loads(json.dumps(quality_report), parse_float=Decimal),
[0m[49m[38;5;10m+     764[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+     765[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     766[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     767[0m:[38;5;10m[49m     logger.info("  Quality validation %s. MI=%.3f, Dice=%.3f",
[0m[49m[38;5;10m+     768[0m:[38;5;10m[49m                "PASSED" if passed else "FAILED", mi_score, dice)
[0m[49m[38;5;10m+     769[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     770[0m:[38;5;10m[49m     return passed, quality_report
[0m[49m[38;5;10m+     771[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     772[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     773[0m:[38;5;10m[49m def compute_jacobian_determinant(deformation_field: np.ndarray) -> np.ndarray:
[0m[49m[38;5;10m+     774[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     775[0m:[38;5;10m[49m     Compute the Jacobian determinant of a displacement field.
[0m[49m[38;5;10m+     776[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     777[0m:[38;5;10m[49m     The Jacobian determinant at each voxel tells you whether the deformation
[0m[49m[38;5;10m+     778[0m:[38;5;10m[49m     is locally expanding (det > 1), compressing (0 < det < 1), or folding
[0m[49m[38;5;10m+     779[0m:[38;5;10m[49m     (det <= 0). Folding is physically impossible and indicates a registration
[0m[49m[38;5;10m+     780[0m:[38;5;10m[49m     failure.
[0m[49m[38;5;10m+     781[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     782[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     783[0m:[38;5;10m[49m         deformation_field: Shape (H, W, D, 3), displacement per voxel
[0m[49m[38;5;10m+     784[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     785[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     786[0m:[38;5;10m[49m         3D array of Jacobian determinant values, same spatial shape as input
[0m[49m[38;5;10m+     787[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     788[0m:[38;5;10m[49m     # Add identity to displacement to get the full coordinate mapping.
[0m[49m[38;5;10m+     789[0m:[38;5;10m[49m     # The Jacobian of the transformation is I + grad(displacement).
[0m[49m[38;5;10m+     790[0m:[38;5;10m[49m     dx = deformation_field[..., 0]
[0m[49m[38;5;10m+     791[0m:[38;5;10m[49m     dy = deformation_field[..., 1]
[0m[49m[38;5;10m+     792[0m:[38;5;10m[49m     dz = deformation_field[..., 2]
[0m[49m[38;5;10m+     793[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     794[0m:[38;5;10m[49m     # Compute spatial gradients of each displacement component.
[0m[49m[38;5;10m+     795[0m:[38;5;10m[49m     # Using central differences for interior points.
[0m[49m[38;5;10m+     796[0m:[38;5;10m[49m     ddx_dx = np.gradient(dx, axis=0)
[0m[49m[38;5;10m+     797[0m:[38;5;10m[49m     ddx_dy = np.gradient(dx, axis=1)
[0m[49m[38;5;10m+     798[0m:[38;5;10m[49m     ddx_dz = np.gradient(dx, axis=2)
[0m[49m[38;5;10m+     799[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     800[0m:[38;5;10m[49m     ddy_dx = np.gradient(dy, axis=0)
[0m[49m[38;5;10m+     801[0m:[38;5;10m[49m     ddy_dy = np.gradient(dy, axis=1)
[0m[49m[38;5;10m+     802[0m:[38;5;10m[49m     ddy_dz = np.gradient(dy, axis=2)
[0m[49m[38;5;10m+     803[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     804[0m:[38;5;10m[49m     ddz_dx = np.gradient(dz, axis=0)
[0m[49m[38;5;10m+     805[0m:[38;5;10m[49m     ddz_dy = np.gradient(dz, axis=1)
[0m[49m[38;5;10m+     806[0m:[38;5;10m[49m     ddz_dz = np.gradient(dz, axis=2)
[0m[49m[38;5;10m+     807[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     808[0m:[38;5;10m[49m     # Jacobian matrix at each voxel is I + gradient of displacement.
[0m[49m[38;5;10m+     809[0m:[38;5;10m[49m     # det(J) = det([[1+ddx/dx, ddx/dy, ddx/dz],
[0m[49m[38;5;10m+     810[0m:[38;5;10m[49m     #               [ddy/dx, 1+ddy/dy, ddy/dz],
[0m[49m[38;5;10m+     811[0m:[38;5;10m[49m     #               [ddz/dx, ddz/dy, 1+ddz/dz]])
[0m[49m[38;5;10m+     812[0m:[38;5;10m[49m     j11 = 1 + ddx_dx
[0m[49m[38;5;10m+     813[0m:[38;5;10m[49m     j12 = ddx_dy
[0m[49m[38;5;10m+     814[0m:[38;5;10m[49m     j13 = ddx_dz
[0m[49m[38;5;10m+     815[0m:[38;5;10m[49m     j21 = ddy_dx
[0m[49m[38;5;10m+     816[0m:[38;5;10m[49m     j22 = 1 + ddy_dy
[0m[49m[38;5;10m+     817[0m:[38;5;10m[49m     j23 = ddy_dz
[0m[49m[38;5;10m+     818[0m:[38;5;10m[49m     j31 = ddz_dx
[0m[49m[38;5;10m+     819[0m:[38;5;10m[49m     j32 = ddz_dy
[0m[49m[38;5;10m+     820[0m:[38;5;10m[49m     j33 = 1 + ddz_dz
[0m[49m[38;5;10m+     821[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     822[0m:[38;5;10m[49m     # 3x3 determinant formula.
[0m[49m[38;5;10m+     823[0m:[38;5;10m[49m     det = (j11 * (j22 * j33 - j23 * j32)
[0m[49m[38;5;10m+     824[0m:[38;5;10m[49m            - j12 * (j21 * j33 - j23 * j31)
[0m[49m[38;5;10m+     825[0m:[38;5;10m[49m            + j13 * (j21 * j32 - j22 * j31))
[0m[49m[38;5;10m+     826[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     827[0m:[38;5;10m[49m     return det
[0m[49m[38;5;10m+     828[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     829[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     830[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     831[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     832[0m:[38;5;10m[49m ## Step 5: Generate Fused Output
[0m[49m[38;5;10m+     833[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     834[0m:[38;5;10m[49m *The pseudocode calls this `generate_fusion_output(...)`. After registration passes quality checks, this step creates the clinical deliverables: fused overlay visualizations, DICOM-compatible output, and summary metrics for the treatment planning team.*
[0m[49m[38;5;10m+     835[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     836[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     837[0m:[38;5;10m[49m def generate_fusion_output(
[0m[49m[38;5;10m+     838[0m:[38;5;10m[49m     job_id: str,
[0m[49m[38;5;10m+     839[0m:[38;5;10m[49m     fixed: np.ndarray,
[0m[49m[38;5;10m+     840[0m:[38;5;10m[49m     registered_moving: np.ndarray,
[0m[49m[38;5;10m+     841[0m:[38;5;10m[49m     moving_modality: str,
[0m[49m[38;5;10m+     842[0m:[38;5;10m[49m     quality_report: dict,
[0m[49m[38;5;10m+     843[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+     844[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     845[0m:[38;5;10m[49m     Generate fused visualization and clinical output from registered images.
[0m[49m[38;5;10m+     846[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     847[0m:[38;5;10m[49m     Creates two types of output:
[0m[49m[38;5;10m+     848[0m:[38;5;10m[49m     1. Checkerboard visualization: alternating tiles from fixed and moving,
[0m[49m[38;5;10m+     849[0m:[38;5;10m[49m        revealing misalignment at tile boundaries.
[0m[49m[38;5;10m+     850[0m:[38;5;10m[49m     2. Color overlay: fixed (CT) as grayscale base with registered moving
[0m[49m[38;5;10m+     851[0m:[38;5;10m[49m        (MRI/PET) as a colored wash on top.
[0m[49m[38;5;10m+     852[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     853[0m:[38;5;10m[49m     In production, this step also generates DICOM Registration Objects and
[0m[49m[38;5;10m+     854[0m:[38;5;10m[49m     resampled DICOM series for integration with PACS and treatment planning
[0m[49m[38;5;10m+     855[0m:[38;5;10m[49m     systems. That requires pydicom and DICOM UID generation which we skip here.
[0m[49m[38;5;10m+     856[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     857[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     858[0m:[38;5;10m[49m         job_id: Fusion job identifier
[0m[49m[38;5;10m+     859[0m:[38;5;10m[49m         fixed: Fixed volume (CT)
[0m[49m[38;5;10m+     860[0m:[38;5;10m[49m         registered_moving: Moving volume after registration
[0m[49m[38;5;10m+     861[0m:[38;5;10m[49m         moving_modality: "MR" or "PT" (affects color scheme)
[0m[49m[38;5;10m+     862[0m:[38;5;10m[49m         quality_report: Quality metrics from validation step
[0m[49m[38;5;10m+     863[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     864[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     865[0m:[38;5;10m[49m         Dict with output locations and summary information
[0m[49m[38;5;10m+     866[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     867[0m:[38;5;10m[49m     # --- Generate checkerboard visualization ---
[0m[49m[38;5;10m+     868[0m:[38;5;10m[49m     # Take a representative axial slice (middle of the volume).
[0m[49m[38;5;10m+     869[0m:[38;5;10m[49m     mid_slice = fixed.shape[2] // 2
[0m[49m[38;5;10m+     870[0m:[38;5;10m[49m     fixed_slice = fixed[:, :, mid_slice]
[0m[49m[38;5;10m+     871[0m:[38;5;10m[49m     moving_slice = registered_moving[:, :, mid_slice]
[0m[49m[38;5;10m+     872[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     873[0m:[38;5;10m[49m     checkerboard = generate_checkerboard_slice(fixed_slice, moving_slice, tile_size=16)
[0m[49m[38;5;10m+     874[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     875[0m:[38;5;10m[49m     # --- Generate color overlay ---
[0m[49m[38;5;10m+     876[0m:[38;5;10m[49m     overlay = generate_color_overlay_slice(fixed_slice, moving_slice, moving_modality)
[0m[49m[38;5;10m+     877[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     878[0m:[38;5;10m[49m     # --- Upload QA visualizations to S3 ---
[0m[49m[38;5;10m+     879[0m:[38;5;10m[49m     checkerboard_key = f"{job_id}/qa_checkerboard.npy"
[0m[49m[38;5;10m+     880[0m:[38;5;10m[49m     overlay_key = f"{job_id}/qa_color_overlay.npy"
[0m[49m[38;5;10m+     881[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     882[0m:[38;5;10m[49m     import io
[0m[49m[38;5;10m+     883[0m:[38;5;10m[49m     for array, key in [(checkerboard, checkerboard_key), (overlay, overlay_key)]:
[0m[49m[38;5;10m+     884[0m:[38;5;10m[49m         buffer = io.BytesIO()
[0m[49m[38;5;10m+     885[0m:[38;5;10m[49m         np.save(buffer, array)
[0m[49m[38;5;10m+     886[0m:[38;5;10m[49m         buffer.seek(0)
[0m[49m[38;5;10m+     887[0m:[38;5;10m[49m         s3_client.put_object(
[0m[49m[38;5;10m+     888[0m:[38;5;10m[49m             Bucket=PROCESSING_BUCKET,
[0m[49m[38;5;10m+     889[0m:[38;5;10m[49m             Key=key,
[0m[49m[38;5;10m+     890[0m:[38;5;10m[49m             Body=buffer.getvalue(),
[0m[49m[38;5;10m+     891[0m:[38;5;10m[49m             ServerSideEncryption="aws:kms",
[0m[49m[38;5;10m+     892[0m:[38;5;10m[49m         )
