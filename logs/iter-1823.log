[0m[49m[38;5;10m+      242[0m:[38;5;10m[49m         ).total_seconds()
[0m[49m[38;5;10m+      243[0m:[38;5;10m[49m         if time_delta_s > 0 and distance_km / (time_delta_s / 3600) > 200:
[0m[49m[38;5;10m+      244[0m:[38;5;10m[49m             return False, "impossible_movement"
[0m[49m[38;5;10m+      245[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      246[0m:[38;5;10m[49m     return True, "ok"
