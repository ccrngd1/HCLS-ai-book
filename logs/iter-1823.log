[0m[49m[38;5;10m+      203[0m:[38;5;10m[49m     the DynamoDB write. Invalid fixes are logged to a GPS anomalies table
[0m[49m[38;5;10m+      204[0m:[38;5;10m[49m     for fleet maintenance review but do not update the unit's position.
[0m[49m[38;5;10m+      205[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      206[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+      207[0m:[38;5;10m[49m         gps_event: dict with unit_id, latitude, longitude, timestamp, speed
[0m[49m[38;5;10m+      208[0m:[38;5;10m[49m         previous_fix: the last accepted fix for this unit (for movement checks)
[0m[49m[38;5;10m+      209[0m:[38;5;10m[49m         service_area_bounds: dict with min_lat, max_lat, min_lon, max_lon
[0m[49m[38;5;10m+      210[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      211[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+      212[0m:[38;5;10m[49m         (is_valid, reason) tuple. If invalid, reason explains why.
[0m[49m[38;5;10m+      213[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+      214[0m:[38;5;10m[49m     lat = gps_event.get("latitude", 0)
[0m[49m[38;5;10m+      215[0m:[38;5;10m[49m     lon = gps_event.get("longitude", 0)
[0m[49m[38;5;10m+      216[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      217[0m:[38;5;10m[49m     # Check for GPS default/null coordinates (common when device loses lock)
[0m[49m[38;5;10m+      218[0m:[38;5;10m[49m     if lat == 0 and lon == 0:
[0m[49m[38;5;10m+      219[0m:[38;5;10m[49m         return False, "null_coordinates"
[0m[49m[38;5;10m+      220[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      221[0m:[38;5;10m[49m     # Bounds check: must be within service area (with buffer for mutual aid)
[0m[49m[38;5;10m+      222[0m:[38;5;10m[49m     if service_area_bounds:
[0m[49m[38;5;10m+      223[0m:[38;5;10m[49m         buffer = 0.5  # ~55 km buffer for mutual aid runs
[0m[49m[38;5;10m+      224[0m:[38;5;10m[49m         if not (service_area_bounds["min_lat"] - buffer <= lat
[0m[49m[38;5;10m+      225[0m:[38;5;10m[49m                 <= service_area_bounds["max_lat"] + buffer):
[0m[49m[38;5;10m+      226[0m:[38;5;10m[49m             return False, "latitude_out_of_bounds"
[0m[49m[38;5;10m+      227[0m:[38;5;10m[49m         if not (service_area_bounds["min_lon"] - buffer <= lon
[0m[49m[38;5;10m+      228[0m:[38;5;10m[49m                 <= service_area_bounds["max_lon"] + buffer):
[0m[49m[38;5;10m+      229[0m:[38;5;10m[49m             return False, "longitude_out_of_bounds"
[0m[49m[38;5;10m+      230[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      231[0m:[38;5;10m[49m     # Speed plausibility: ambulances do not exceed 200 km/h
[0m[49m[38;5;10m+      232[0m:[38;5;10m[49m     if gps_event.get("speed", 0) > 200:
[0m[49m[38;5;10m+      233[0m:[38;5;10m[49m         return False, "speed_implausible"
