[0m[49m[38;5;10m+    1871[0m:[38;5;10m[49m             ref_point = scen["forecast"][min(20, len(scen["forecast"]) - 1)]
[0m[49m[38;5;10m+    1872[0m:[38;5;10m[49m             print(f"  scenario: {scen['scenario_name']}")
[0m[49m[38;5;10m+    1873[0m:[38;5;10m[49m             print(f"    eGFR forecast at month {ref_point['months_from_zero']}: "
[0m[49m[38;5;10m+    1874[0m:[38;5;10m[49m                   f"P10={ref_point['p10']}, P50={ref_point['p50']}, "
[0m[49m[38;5;10m+    1875[0m:[38;5;10m[49m                   f"P90={ref_point['p90']}")
[0m[49m[38;5;10m+    1876[0m:[38;5;10m[49m             print(f"    fraction to endpoint in horizon: "
[0m[49m[38;5;10m+    1877[0m:[38;5;10m[49m                   f"{tte['fraction_reaching_endpoint_in_horizon']*100:.0f}%")
[0m[49m[38;5;10m+    1878[0m:[38;5;10m[49m             print(f"    median months to endpoint: {tte['p50_months']}")
[0m[49m[38;5;10m+    1879[0m:[38;5;10m[49m             print(f"    explanation: {scen['explanation_text'][:120]}...")
[0m[49m[38;5;10m+    1880[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1881[0m:[38;5;10m[49m     print("\n=== Sample DynamoDB record ===")
[0m[49m[38;5;10m+    1882[0m:[38;5;10m[49m     if table.items:
[0m[49m[38;5;10m+    1883[0m:[38;5;10m[49m         first_key = next(iter(table.items))
[0m[49m[38;5;10m+    1884[0m:[38;5;10m[49m         sample_item = table.items[first_key]
[0m[49m[38;5;10m+    1885[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1886[0m:[38;5;10m[49m         def _decimalify(o):
[0m[49m[38;5;10m+    1887[0m:[38;5;10m[49m             if isinstance(o, Decimal):
[0m[49m[38;5;10m+    1888[0m:[38;5;10m[49m                 return str(o)
[0m[49m[38;5;10m+    1889[0m:[38;5;10m[49m             if isinstance(o, datetime):
[0m[49m[38;5;10m+    1890[0m:[38;5;10m[49m                 return o.isoformat()
[0m[49m[38;5;10m+    1891[0m:[38;5;10m[49m             return o
[0m[49m[38;5;10m+    1892[0m:[38;5;10m[49m         print(json.dumps(sample_item, default=_decimalify, indent=2))
