[0m[49m[38;5;10m+     923[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     924[0m:[38;5;10m[49m ## Step 3: Train the Disease-Specific Trajectory Model
[0m[49m[38;5;10m+     925[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     926[0m:[38;5;10m[49m The model captures three nested layers: a population-level disease slope (anchored to clinical literature), per-patient deviations from that slope (random intercepts and slopes), and treatment-effect modifiers driven by trial-derived priors. The demo implements a simplified Bayesian linear mixed-effects fit using closed-form posterior updates so the math is visible. Production replaces this with a real PyMC, Stan, or NumPyro model that handles non-linear forms, joint time-to-event components, and the full posterior via NUTS sampling.
[0m[49m[38;5;10m+     927[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     928[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     929[0m:[38;5;10m[49m class BayesianHierarchicalMixedEffects:
[0m[49m[38;5;10m+     930[0m:[38;5;10m[49m     """Pedagogical Bayesian hierarchical linear mixed-effects model.
[0m[49m[38;5;10m+     931[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     932[0m:[38;5;10m[49m     The model is:
[0m[49m[38;5;10m+     933[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     934[0m:[38;5;10m[49m         egfr_observed[i, t] ~ Normal(
[0m[49m[38;5;10m+     935[0m:[38;5;10m[49m             intercept[i] + slope[i] * months_from_zero[i, t]
[0m[49m[38;5;10m+     936[0m:[38;5;10m[49m               + treatment_effect[i, t],
[0m[49m[38;5;10m+     937[0m:[38;5;10m[49m             observation_noise_sd
[0m[49m[38;5;10m+     938[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     939[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     940[0m:[38;5;10m[49m         intercept[i]  ~ Normal(prior_intercept_mean, prior_intercept_sd)
[0m[49m[38;5;10m+     941[0m:[38;5;10m[49m         slope[i]      ~ Normal(population_slope, prior_per_patient_slope_sd)
[0m[49m[38;5;10m+     942[0m:[38;5;10m[49m         population_slope ~ Normal(prior_population_slope_mean,
[0m[49m[38;5;10m+     943[0m:[38;5;10m[49m                                   prior_population_slope_sd)
[0m[49m[38;5;10m+     944[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     945[0m:[38;5;10m[49m     The treatment effect is a multiplicative slope modifier driven
[0m[49m[38;5;10m+     946[0m:[38;5;10m[49m     by trial-derived priors. For example, when tolvaptan is active,
[0m[49m[38;5;10m+     947[0m:[38;5;10m[49m     the effective slope becomes slope[i] * (1 - tolvaptan_modifier).
[0m[49m[38;5;10m+     948[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     949[0m:[38;5;10m[49m     Production uses PyMC or Stan to fit the joint posterior with
[0m[49m[38;5;10m+     950[0m:[38;5;10m[49m     proper NUTS sampling and rich diagnostic output. The demo uses
[0m[49m[38;5;10m+     951[0m:[38;5;10m[49m     closed-form normal-conjugate updates per patient (which is what
[0m[49m[38;5;10m+     952[0m:[38;5;10m[49m     the linear-Gaussian case allows analytically) plus an empirical
[0m[49m[38;5;10m+     953[0m:[38;5;10m[49m     estimate of the population slope. This is deliberately simpler
[0m[49m[38;5;10m+     954[0m:[38;5;10m[49m     than what a real model fit produces, but it captures the same
[0m[49m[38;5;10m+     955[0m:[38;5;10m[49m     structure: population shape, per-patient deviation, treatment
[0m[49m[38;5;10m+     956[0m:[38;5;10m[49m     modifier, and posterior uncertainty.
[0m[49m[38;5;10m+     957[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     958[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     959[0m:[38;5;10m[49m     def __init__(self, hyperparameters, trial_priors):
[0m[49m[38;5;10m+     960[0m:[38;5;10m[49m         self.hyper       = dict(hyperparameters)
[0m[49m[38;5;10m+     961[0m:[38;5;10m[49m         self.trial_priors = dict(trial_priors)
[0m[49m[38;5;10m+     962[0m:[38;5;10m[49m         self.fitted      = False
[0m[49m[38;5;10m+     963[0m:[38;5;10m[49m         self.population_slope_mean = None
[0m[49m[38;5;10m+     964[0m:[38;5;10m[49m         self.population_slope_sd   = None
[0m[49m[38;5;10m+     965[0m:[38;5;10m[49m         self.per_patient_params    = {}    # patient_id -> dict
[0m[49m[38;5;10m+     966[0m:[38;5;10m[49m         self.training_summary      = {}
[0m[49m[38;5;10m+     967[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     968[0m:[38;5;10m[49m     def _treatment_modifier(self, treatments, months_from_zero):
[0m[49m[38;5;10m+     969[0m:[38;5;10m[49m         """Compute the active treatment slope modifier at a time point.
[0m[49m[38;5;10m+     970[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     971[0m:[38;5;10m[49m         Returns the multiplicative factor on the slope. A patient
[0m[49m[38;5;10m+     972[0m:[38;5;10m[49m         with no active treatments returns 1.0; a patient on
[0m[49m[38;5;10m+     973[0m:[38;5;10m[49m         tolvaptan returns approximately (1 - tolvaptan_mean).
[0m[49m[38;5;10m+     974[0m:[38;5;10m[49m         Multiple concurrent treatments compound multiplicatively
[0m[49m[38;5;10m+     975[0m:[38;5;10m[49m         as a simplification; production uses an additive
[0m[49m[38;5;10m+     976[0m:[38;5;10m[49m         log-slope formulation or a proper joint model.
[0m[49m[38;5;10m+     977[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     978[0m:[38;5;10m[49m         modifier = 1.0
[0m[49m[38;5;10m+     979[0m:[38;5;10m[49m         for tx in treatments:
[0m[49m[38;5;10m+     980[0m:[38;5;10m[49m             if tx["start_months_from_zero"] > months_from_zero:
[0m[49m[38;5;10m+     981[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+     982[0m:[38;5;10m[49m             if (tx["end_months_from_zero"] is not None
[0m[49m[38;5;10m+     983[0m:[38;5;10m[49m                     and tx["end_months_from_zero"] < months_from_zero):
[0m[49m[38;5;10m+     984[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+     985[0m:[38;5;10m[49m             prior = self.trial_priors.get(tx["drug_class"])
[0m[49m[38;5;10m+     986[0m:[38;5;10m[49m             if not prior:
[0m[49m[38;5;10m+     987[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+     988[0m:[38;5;10m[49m             modifier *= (1.0 - prior["slope_modifier_mean"])
[0m[49m[38;5;10m+     989[0m:[38;5;10m[49m         return modifier
[0m[49m[38;5;10m+     990[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     991[0m:[38;5;10m[49m     def fit(self, harmonized_cohort, primary_outcome_loinc):
[0m[49m[38;5;10m+     992[0m:[38;5;10m[49m         """Fit the model on the harmonized cohort.
[0m[49m[38;5;10m+     993[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     994[0m:[38;5;10m[49m         Returns the population-level summary plus per-patient
[0m[49m[38;5;10m+     995[0m:[38;5;10m[49m         posterior parameters. Production fits this with NUTS in
[0m[49m[38;5;10m+     996[0m:[38;5;10m[49m         PyMC/Stan and returns full posterior samples.
[0m[49m[38;5;10m+     997[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     998[0m:[38;5;10m[49m         # Step 3a: extract per-patient (months_from_zero, value)
[0m[49m[38;5;10m+     999[0m:[38;5;10m[49m         # series for the primary outcome, chronic-context only.
[0m[49m[38;5;10m+    1000[0m:[38;5;10m[49m         per_patient_series = {}
[0m[49m[38;5;10m+    1001[0m:[38;5;10m[49m         for patient in harmonized_cohort:
[0m[49m[38;5;10m+    1002[0m:[38;5;10m[49m             obs = [(o["months_from_zero"], o["value"], o["context_tag"])
[0m[49m[38;5;10m+    1003[0m:[38;5;10m[49m                    for o in patient["observations"]
[0m[49m[38;5;10m+    1004[0m:[38;5;10m[49m                    if o["loinc_code"] == primary_outcome_loinc
[0m[49m[38;5;10m+    1005[0m:[38;5;10m[49m                    and o["context_tag"] == "chronic"]
[0m[49m[38;5;10m+    1006[0m:[38;5;10m[49m             if len(obs) < 3:
[0m[49m[38;5;10m+    1007[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    1008[0m:[38;5;10m[49m             obs.sort(key=lambda x: x[0])
[0m[49m[38;5;10m+    1009[0m:[38;5;10m[49m             per_patient_series[patient["patient_id"]] = {
[0m[49m[38;5;10m+    1010[0m:[38;5;10m[49m                 "series":     obs,
[0m[49m[38;5;10m+    1011[0m:[38;5;10m[49m                 "treatments": patient["treatments"],
[0m[49m[38;5;10m+    1012[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    1013[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1014[0m:[38;5;10m[49m         if not per_patient_series:
[0m[49m[38;5;10m+    1015[0m:[38;5;10m[49m             raise ValueError("No qualifying per-patient series for fit")
[0m[49m[38;5;10m+    1016[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1017[0m:[38;5;10m[49m         # Step 3b: estimate population slope as the inverse-variance-
[0m[49m[38;5;10m+    1018[0m:[38;5;10m[49m         # weighted mean of per-patient OLS slopes (with intercept).
[0m[49m[38;5;10m+    1019[0m:[38;5;10m[49m         # The slopes are computed against the treatment-adjusted
[0m[49m[38;5;10m+    1020[0m:[38;5;10m[49m         # months so that treatment effects do not bias the population
[0m[49m[38;5;10m+    1021[0m:[38;5;10m[49m         # estimate.
[0m[49m[38;5;10m+    1022[0m:[38;5;10m[49m         per_patient_ols = {}
[0m[49m[38;5;10m+    1023[0m:[38;5;10m[49m         for pid, pdata in per_patient_series.items():
[0m[49m[38;5;10m+    1024[0m:[38;5;10m[49m             xs = [m for (m, v, c) in pdata["series"]]
[0m[49m[38;5;10m+    1025[0m:[38;5;10m[49m             ys = [v for (m, v, c) in pdata["series"]]
[0m[49m[38;5;10m+    1026[0m:[38;5;10m[49m             n = len(xs)
[0m[49m[38;5;10m+    1027[0m:[38;5;10m[49m             mean_x = sum(xs) / n
[0m[49m[38;5;10m+    1028[0m:[38;5;10m[49m             mean_y = sum(ys) / n
[0m[49m[38;5;10m+    1029[0m:[38;5;10m[49m             num = sum((xs[i] - mean_x) * (ys[i] - mean_y) for i in range(n))
[0m[49m[38;5;10m+    1030[0m:[38;5;10m[49m             den = sum((xs[i] - mean_x) ** 2 for i in range(n))
[0m[49m[38;5;10m+    1031[0m:[38;5;10m[49m             if den <= 0:
[0m[49m[38;5;10m+    1032[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    1033[0m:[38;5;10m[49m             slope = num / den
[0m[49m[38;5;10m+    1034[0m:[38;5;10m[49m             intercept = mean_y - slope * mean_x
[0m[49m[38;5;10m+    1035[0m:[38;5;10m[49m             # Residual variance for the inverse-variance weight.
[0m[49m[38;5;10m+    1036[0m:[38;5;10m[49m             residuals = [ys[i] - (intercept + slope * xs[i]) for i in range(n)]
[0m[49m[38;5;10m+    1037[0m:[38;5;10m[49m             resid_var = sum(r ** 2 for r in residuals) / max(n - 2, 1)
[0m[49m[38;5;10m+    1038[0m:[38;5;10m[49m             slope_var = resid_var / max(den, 1e-9)
[0m[49m[38;5;10m+    1039[0m:[38;5;10m[49m             per_patient_ols[pid] = {
[0m[49m[38;5;10m+    1040[0m:[38;5;10m[49m                 "slope":      slope,
[0m[49m[38;5;10m+    1041[0m:[38;5;10m[49m                 "intercept":  intercept,
[0m[49m[38;5;10m+    1042[0m:[38;5;10m[49m                 "slope_var":  max(slope_var, 1e-6),
[0m[49m[38;5;10m+    1043[0m:[38;5;10m[49m                 "n_obs":      n,
[0m[49m[38;5;10m+    1044[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    1045[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1046[0m:[38;5;10m[49m         # Inverse-variance-weighted population slope.
[0m[49m[38;5;10m+    1047[0m:[38;5;10m[49m         total_weight = sum(1.0 / o["slope_var"] for o in per_patient_ols.values())
[0m[49m[38;5;10m+    1048[0m:[38;5;10m[49m         weighted_sum = sum(o["slope"] / o["slope_var"]
[0m[49m[38;5;10m+    1049[0m:[38;5;10m[49m                            for o in per_patient_ols.values())
[0m[49m[38;5;10m+    1050[0m:[38;5;10m[49m         empirical_pop_slope = weighted_sum / max(total_weight, 1e-9)
[0m[49m[38;5;10m+    1051[0m:[38;5;10m[49m         empirical_pop_sd    = math.sqrt(1.0 / max(total_weight, 1e-9))
[0m[49m[38;5;10m+    1052[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1053[0m:[38;5;10m[49m         # Step 3c: combine the empirical estimate with the literature
[0m[49m[38;5;10m+    1054[0m:[38;5;10m[49m         # prior using a normal-conjugate update.
[0m[49m[38;5;10m+    1055[0m:[38;5;10m[49m         prior_mean = self.hyper["prior_population_slope_mean"]
[0m[49m[38;5;10m+    1056[0m:[38;5;10m[49m         prior_sd   = self.hyper["prior_population_slope_sd"]
[0m[49m[38;5;10m+    1057[0m:[38;5;10m[49m         prior_var  = prior_sd ** 2
[0m[49m[38;5;10m+    1058[0m:[38;5;10m[49m         emp_var    = empirical_pop_sd ** 2
[0m[49m[38;5;10m+    1059[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1060[0m:[38;5;10m[49m         post_var  = 1.0 / (1.0 / prior_var + 1.0 / emp_var)
[0m[49m[38;5;10m+    1061[0m:[38;5;10m[49m         post_mean = post_var * (prior_mean / prior_var
[0m[49m[38;5;10m+    1062[0m:[38;5;10m[49m                                 + empirical_pop_slope / emp_var)
[0m[49m[38;5;10m+    1063[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1064[0m:[38;5;10m[49m         self.population_slope_mean = post_mean
[0m[49m[38;5;10m+    1065[0m:[38;5;10m[49m         self.population_slope_sd   = math.sqrt(post_var)
[0m[49m[38;5;10m+    1066[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1067[0m:[38;5;10m[49m         # Step 3d: per-patient posterior. Shrink each patient's
[0m[49m[38;5;10m+    1068[0m:[38;5;10m[49m         # OLS slope toward the population posterior using the
[0m[49m[38;5;10m+    1069[0m:[38;5;10m[49m         # configured per-patient slope SD as the prior.
[0m[49m[38;5;10m+    1070[0m:[38;5;10m[49m         per_pat_prior_sd = self.hyper["prior_per_patient_slope_sd"]
[0m[49m[38;5;10m+    1071[0m:[38;5;10m[49m         per_pat_prior_var = per_pat_prior_sd ** 2
[0m[49m[38;5;10m+    1072[0m:[38;5;10m[49m         for pid, ols in per_patient_ols.items():
[0m[49m[38;5;10m+    1073[0m:[38;5;10m[49m             patient_prior_var = post_var + per_pat_prior_var
[0m[49m[38;5;10m+    1074[0m:[38;5;10m[49m             obs_var = ols["slope_var"]
[0m[49m[38;5;10m+    1075[0m:[38;5;10m[49m             shrunk_var = 1.0 / (1.0 / patient_prior_var + 1.0 / obs_var)
[0m[49m[38;5;10m+    1076[0m:[38;5;10m[49m             shrunk_mean = shrunk_var * (post_mean / patient_prior_var
[0m[49m[38;5;10m+    1077[0m:[38;5;10m[49m                                         + ols["slope"] / obs_var)
[0m[49m[38;5;10m+    1078[0m:[38;5;10m[49m             self.per_patient_params[pid] = {
[0m[49m[38;5;10m+    1079[0m:[38;5;10m[49m                 "slope_mean":     shrunk_mean,
[0m[49m[38;5;10m+    1080[0m:[38;5;10m[49m                 "slope_sd":       math.sqrt(shrunk_var),
[0m[49m[38;5;10m+    1081[0m:[38;5;10m[49m                 "intercept_mean": ols["intercept"],
[0m[49m[38;5;10m+    1082[0m:[38;5;10m[49m                 "intercept_sd":   self.hyper["prior_per_patient_intercept_sd"],
[0m[49m[38;5;10m+    1083[0m:[38;5;10m[49m                 "n_obs":          ols["n_obs"],
[0m[49m[38;5;10m+    1084[0m:[38;5;10m[49m                 "treatments":     per_patient_series[pid]["treatments"],
[0m[49m[38;5;10m+    1085[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    1086[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1087[0m:[38;5;10m[49m         # Step 3e: temporal-holdout calibration check. For each
[0m[49m[38;5;10m+    1088[0m:[38;5;10m[49m         # patient, hold out the most recent fraction of observations,
[0m[49m[38;5;10m+    1089[0m:[38;5;10m[49m         # refit (here, just predict at held-out times using the
[0m[49m[38;5;10m+    1090[0m:[38;5;10m[49m         # already-fit per-patient posterior), and compute coverage.
[0m[49m[38;5;10m+    1091[0m:[38;5;10m[49m         calibration = self._compute_calibration(
[0m[49m[38;5;10m+    1092[0m:[38;5;10m[49m             per_patient_series,
[0m[49m[38;5;10m+    1093[0m:[38;5;10m[49m             self.hyper["temporal_holdout_fraction"])
[0m[49m[38;5;10m+    1094[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1095[0m:[38;5;10m[49m         self.training_summary = {
[0m[49m[38;5;10m+    1096[0m:[38;5;10m[49m             "cohort_size":              len(per_patient_series),
[0m[49m[38;5;10m+    1097[0m:[38;5;10m[49m             "population_slope_mean":    round(self.population_slope_mean, 4),
[0m[49m[38;5;10m+    1098[0m:[38;5;10m[49m             "population_slope_sd":      round(self.population_slope_sd, 4),
[0m[49m[38;5;10m+    1099[0m:[38;5;10m[49m             "empirical_pop_slope":      round(empirical_pop_slope, 4),
[0m[49m[38;5;10m+    1100[0m:[38;5;10m[49m             "literature_prior_slope":   prior_mean,
[0m[49m[38;5;10m+    1101[0m:[38;5;10m[49m             "calibration":              calibration,
[0m[49m[38;5;10m+    1102[0m:[38;5;10m[49m             "model_version":            MODEL_VERSION_TAG,
[0m[49m[38;5;10m+    1103[0m:[38;5;10m[49m             "trial_prior_version":      TRIAL_PRIOR_VERSION,
[0m[49m[38;5;10m+    1104[0m:[38;5;10m[49m             "trained_at_ts":            datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    1105[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1106[0m:[38;5;10m[49m         self.fitted = True
[0m[49m[38;5;10m+    1107[0m:[38;5;10m[49m         return self.training_summary
[0m[49m[38;5;10m+    1108[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1109[0m:[38;5;10m[49m     def _compute_calibration(self, per_patient_series, holdout_fraction):
[0m[49m[38;5;10m+    1110[0m:[38;5;10m[49m         """Coverage of credible intervals on a temporal holdout.
[0m[49m[38;5;10m+    1111[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1112[0m:[38;5;10m[49m         For each patient, hold out the last `holdout_fraction` of
[0m[49m[38;5;10m+    1113[0m:[38;5;10m[49m         observations, predict at those times using the per-patient
[0m[49m[38;5;10m+    1114[0m:[38;5;10m[49m         posterior, and compute the empirical coverage of the
[0m[49m[38;5;10m+    1115[0m:[38;5;10m[49m         50/80/90/95% credible intervals.
[0m[49m[38;5;10m+    1116[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+    1117[0m:[38;5;10m[49m         coverage_50 = 0
[0m[49m[38;5;10m+    1118[0m:[38;5;10m[49m         coverage_80 = 0
[0m[49m[38;5;10m+    1119[0m:[38;5;10m[49m         coverage_90 = 0
[0m[49m[38;5;10m+    1120[0m:[38;5;10m[49m         coverage_95 = 0
[0m[49m[38;5;10m+    1121[0m:[38;5;10m[49m         total = 0
[0m[49m[38;5;10m+    1122[0m:[38;5;10m[49m         for pid, pdata in per_patient_series.items():
[0m[49m[38;5;10m+    1123[0m:[38;5;10m[49m             params = self.per_patient_params.get(pid)
[0m[49m[38;5;10m+    1124[0m:[38;5;10m[49m             if not params:
[0m[49m[38;5;10m+    1125[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    1126[0m:[38;5;10m[49m             n = len(pdata["series"])
[0m[49m[38;5;10m+    1127[0m:[38;5;10m[49m             n_hold = max(1, int(round(n * holdout_fraction)))
[0m[49m[38;5;10m+    1128[0m:[38;5;10m[49m             holdout = pdata["series"][-n_hold:]
[0m[49m[38;5;10m+    1129[0m:[38;5;10m[49m             for (m, v, c) in holdout:
[0m[49m[38;5;10m+    1130[0m:[38;5;10m[49m                 modifier = self._treatment_modifier(params["treatments"], m)
[0m[49m[38;5;10m+    1131[0m:[38;5;10m[49m                 pred_mean = (params["intercept_mean"]
[0m[49m[38;5;10m+    1132[0m:[38;5;10m[49m                              + params["slope_mean"] * modifier * m)
[0m[49m[38;5;10m+    1133[0m:[38;5;10m[49m                 # Predictive SD combines slope uncertainty
[0m[49m[38;5;10m+    1134[0m:[38;5;10m[49m                 # propagated through `m`, intercept uncertainty,
[0m[49m[38;5;10m+    1135[0m:[38;5;10m[49m                 # and observation noise.
[0m[49m[38;5;10m+    1136[0m:[38;5;10m[49m                 pred_sd = math.sqrt(
[0m[49m[38;5;10m+    1137[0m:[38;5;10m[49m                     (params["slope_sd"] * m) ** 2
[0m[49m[38;5;10m+    1138[0m:[38;5;10m[49m                     + params["intercept_sd"] ** 2
[0m[49m[38;5;10m+    1139[0m:[38;5;10m[49m                     + self.hyper["observation_noise_sd"] ** 2)
[0m[49m[38;5;10m+    1140[0m:[38;5;10m[49m                 # 50/80/90/95 z thresholds for normal CI.
[0m[49m[38;5;10m+    1141[0m:[38;5;10m[49m                 for z, target in [(0.674, 50), (1.282, 80),
[0m[49m[38;5;10m+    1142[0m:[38;5;10m[49m                                   (1.645, 90), (1.960, 95)]:
[0m[49m[38;5;10m+    1143[0m:[38;5;10m[49m                     lo = pred_mean - z * pred_sd
[0m[49m[38;5;10m+    1144[0m:[38;5;10m[49m                     hi = pred_mean + z * pred_sd
[0m[49m[38;5;10m+    1145[0m:[38;5;10m[49m                     if lo <= v <= hi:
[0m[49m[38;5;10m+    1146[0m:[38;5;10m[49m                         if target == 50: coverage_50 += 1
[0m[49m[38;5;10m+    1147[0m:[38;5;10m[49m                         elif target == 80: coverage_80 += 1
[0m[49m[38;5;10m+    1148[0m:[38;5;10m[49m                         elif target == 90: coverage_90 += 1
[0m[49m[38;5;10m+    1149[0m:[38;5;10m[49m                         else: coverage_95 += 1
[0m[49m[38;5;10m+    1150[0m:[38;5;10m[49m                 total += 1
[0m[49m[38;5;10m+    1151[0m:[38;5;10m[49m         if total == 0:
[0m[49m[38;5;10m+    1152[0m:[38;5;10m[49m             return {"coverage_50": None, "coverage_80": None,
[0m[49m[38;5;10m+    1153[0m:[38;5;10m[49m                     "coverage_90": None, "coverage_95": None,
[0m[49m[38;5;10m+    1154[0m:[38;5;10m[49m                     "holdout_count": 0}
[0m[49m[38;5;10m+    1155[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    1156[0m:[38;5;10m[49m             "coverage_50":   round(coverage_50 / total, 3),
[0m[49m[38;5;10m+    1157[0m:[38;5;10m[49m             "coverage_80":   round(coverage_80 / total, 3),
