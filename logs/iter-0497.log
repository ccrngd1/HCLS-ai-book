[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m     def search_observations(self, patient_id, loinc_code=None):
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m         out = []
