[0m[49m[38;5;10m+    1216[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    1217[0m:[38;5;10m[49m def _build_forecast_grid(from_months, horizon_months, step_months):
[0m[49m[38;5;10m+    1218[0m:[38;5;10m[49m     """Return a list of months_from_zero for the forecast horizon."""
[0m[49m[38;5;10m+    1219[0m:[38;5;10m[49m     grid = []
[0m[49m[38;5;10m+    1220[0m:[38;5;10m[49m     cursor = from_months
[0m[49m[38;5;10m+    1221[0m:[38;5;10m[49m     end = from_months + horizon_months
[0m[49m[38;5;10m+    1222[0m:[38;5;10m[49m     while cursor <= end + 1e-6:
[0m[49m[38;5;10m+    1223[0m:[38;5;10m[49m         grid.append(round(cursor, 2))
[0m[49m[38;5;10m+    1224[0m:[38;5;10m[49m         cursor += step_months
[0m[49m[38;5;10m+    1225[0m:[38;5;10m[49m     return grid
[0m[49m[38;5;10m+    1226[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1227[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1228[0m:[38;5;10m[49m def _forecast_at_time(model, params, treatments, m_target,
