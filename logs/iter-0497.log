[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m         self.conditions    = []   # FHIR Condition dicts
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m         self.medications   = []   # FHIR MedicationRequest dicts
