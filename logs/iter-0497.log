[0m[49m[38;5;10m+    1515[0m:[38;5;10m[49m     """Step 5: Compose counterfactual scenarios for one patient.
[0m[49m[38;5;10m+    1516[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1517[0m:[38;5;10m[49m     Returns a payload containing the baseline scenario, every
[0m[49m[38;5;10m+    1518[0m:[38;5;10m[49m     requested counterfactual scenario, and the assumption
[0m[49m[38;5;10m+    1519[0m:[38;5;10m[49m     disclosure for each.
[0m[49m[38;5;10m+    1520[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1521[0m:[38;5;10m[49m     anchor = patient["last_observation_months"]
[0m[49m[38;5;10m+    1522[0m:[38;5;10m[49m     grid = _build_forecast_grid(anchor, forecast_horizon_months, grid_step)
[0m[49m[38;5;10m+    1523[0m:[38;5;10m[49m     params = model.per_patient_params.get(patient["patient_id"])
[0m[49m[38;5;10m+    1524[0m:[38;5;10m[49m     if params is None:
[0m[49m[38;5;10m+    1525[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+    1526[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1527[0m:[38;5;10m[49m     rng_seed = 23456 + hash(patient["patient_id"]) % 10000
[0m[49m[38;5;10m+    1528[0m:[38;5;10m[49m     counterfactual_results = []
[0m[49m[38;5;10m+    1529[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1530[0m:[38;5;10m[49m     for scenario in scenarios:
[0m[49m[38;5;10m+    1531[0m:[38;5;10m[49m         modified_timeline = _apply_treatment_change(
[0m[49m[38;5;10m+    1532[0m:[38;5;10m[49m             patient["treatments"], scenario.get("change"), anchor)
[0m[49m[38;5;10m+    1533[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1534[0m:[38;5;10m[49m         # Forward forecast under the modified timeline.
[0m[49m[38;5;10m+    1535[0m:[38;5;10m[49m         scenario_forecast = []
[0m[49m[38;5;10m+    1536[0m:[38;5;10m[49m         for m in grid:
[0m[49m[38;5;10m+    1537[0m:[38;5;10m[49m             pred_mean, pred_sd = _forecast_at_time(
[0m[49m[38;5;10m+    1538[0m:[38;5;10m[49m                 model, params, modified_timeline, m,
[0m[49m[38;5;10m+    1539[0m:[38;5;10m[49m                 treatment_override=modified_timeline)
[0m[49m[38;5;10m+    1540[0m:[38;5;10m[49m             scenario_forecast.append({
[0m[49m[38;5;10m+    1541[0m:[38;5;10m[49m                 "months_from_zero": m,
[0m[49m[38;5;10m+    1542[0m:[38;5;10m[49m                 "p10":              round(pred_mean - 1.282 * pred_sd, 2),
[0m[49m[38;5;10m+    1543[0m:[38;5;10m[49m                 "p50":              round(pred_mean, 2),
[0m[49m[38;5;10m+    1544[0m:[38;5;10m[49m                 "p90":              round(pred_mean + 1.282 * pred_sd, 2),
[0m[49m[38;5;10m+    1545[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    1546[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1547[0m:[38;5;10m[49m         # Time-to-endpoint Monte Carlo under the modified timeline.
[0m[49m[38;5;10m+    1548[0m:[38;5;10m[49m         rng = random.Random(rng_seed + hash(scenario["name"]) % 10000)
[0m[49m[38;5;10m+    1549[0m:[38;5;10m[49m         threshold = endpoint_definition["threshold_value"]
[0m[49m[38;5;10m+    1550[0m:[38;5;10m[49m         direction_below = (endpoint_definition["threshold_direction"] == "below")
[0m[49m[38;5;10m+    1551[0m:[38;5;10m[49m         crossings = []
[0m[49m[38;5;10m+    1552[0m:[38;5;10m[49m         for _ in range(num_endpoint_samples):
[0m[49m[38;5;10m+    1553[0m:[38;5;10m[49m             sampled_slope = rng.gauss(params["slope_mean"], params["slope_sd"])
[0m[49m[38;5;10m+    1554[0m:[38;5;10m[49m             sampled_intercept = rng.gauss(
[0m[49m[38;5;10m+    1555[0m:[38;5;10m[49m                 params["intercept_mean"], params["intercept_sd"])
[0m[49m[38;5;10m+    1556[0m:[38;5;10m[49m             sampled_modifiers = {}
[0m[49m[38;5;10m+    1557[0m:[38;5;10m[49m             for tx in modified_timeline:
[0m[49m[38;5;10m+    1558[0m:[38;5;10m[49m                 prior = model.trial_priors.get(tx["drug_class"])
[0m[49m[38;5;10m+    1559[0m:[38;5;10m[49m                 if prior:
[0m[49m[38;5;10m+    1560[0m:[38;5;10m[49m                     sampled_modifiers[tx["drug_class"]] = rng.gauss(
[0m[49m[38;5;10m+    1561[0m:[38;5;10m[49m                         prior["slope_modifier_mean"],
[0m[49m[38;5;10m+    1562[0m:[38;5;10m[49m                         prior["slope_modifier_sd"])
[0m[49m[38;5;10m+    1563[0m:[38;5;10m[49m                 else:
[0m[49m[38;5;10m+    1564[0m:[38;5;10m[49m                     sampled_modifiers[tx["drug_class"]] = 0.0
[0m[49m[38;5;10m+    1565[0m:[38;5;10m[49m             crossing_m = None
[0m[49m[38;5;10m+    1566[0m:[38;5;10m[49m             for m in grid:
[0m[49m[38;5;10m+    1567[0m:[38;5;10m[49m                 modifier = 1.0
[0m[49m[38;5;10m+    1568[0m:[38;5;10m[49m                 for tx in modified_timeline:
[0m[49m[38;5;10m+    1569[0m:[38;5;10m[49m                     if tx["start_months_from_zero"] > m:
[0m[49m[38;5;10m+    1570[0m:[38;5;10m[49m                         continue
[0m[49m[38;5;10m+    1571[0m:[38;5;10m[49m                     if (tx["end_months_from_zero"] is not None
[0m[49m[38;5;10m+    1572[0m:[38;5;10m[49m                             and tx["end_months_from_zero"] < m):
[0m[49m[38;5;10m+    1573[0m:[38;5;10m[49m                         continue
[0m[49m[38;5;10m+    1574[0m:[38;5;10m[49m                     modifier *= (1.0 - sampled_modifiers.get(tx["drug_class"], 0.0))
[0m[49m[38;5;10m+    1575[0m:[38;5;10m[49m                 v = (sampled_intercept + sampled_slope * modifier * m
[0m[49m[38;5;10m+    1576[0m:[38;5;10m[49m                      + rng.gauss(0.0, model.hyper["observation_noise_sd"]))
[0m[49m[38;5;10m+    1577[0m:[38;5;10m[49m                 if direction_below and v <= threshold:
[0m[49m[38;5;10m+    1578[0m:[38;5;10m[49m                     crossing_m = m; break
[0m[49m[38;5;10m+    1579[0m:[38;5;10m[49m                 if not direction_below and v >= threshold:
[0m[49m[38;5;10m+    1580[0m:[38;5;10m[49m                     crossing_m = m; break
[0m[49m[38;5;10m+    1581[0m:[38;5;10m[49m             crossings.append(crossing_m)
[0m[49m[38;5;10m+    1582[0m:[38;5;10m[49m         finite = sorted([c for c in crossings if c is not None])
[0m[49m[38;5;10m+    1583[0m:[38;5;10m[49m         fraction = len(finite) / len(crossings)
[0m[49m[38;5;10m+    1584[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1585[0m:[38;5;10m[49m         def _pct(data, p):
[0m[49m[38;5;10m+    1586[0m:[38;5;10m[49m             if not data:
[0m[49m[38;5;10m+    1587[0m:[38;5;10m[49m                 return None
[0m[49m[38;5;10m+    1588[0m:[38;5;10m[49m             i = max(0, min(len(data) - 1, int(round(p / 100.0 * len(data)))))
[0m[49m[38;5;10m+    1589[0m:[38;5;10m[49m             return data[i]
[0m[49m[38;5;10m+    1590[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1591[0m:[38;5;10m[49m         time_to_endpoint = {
[0m[49m[38;5;10m+    1592[0m:[38;5;10m[49m             "endpoint_definition":  endpoint_definition,
[0m[49m[38;5;10m+    1593[0m:[38;5;10m[49m             "fraction_reaching_endpoint_in_horizon": round(fraction, 3),
[0m[49m[38;5;10m+    1594[0m:[38;5;10m[49m             "p10_months":           _pct(finite, 10),
[0m[49m[38;5;10m+    1595[0m:[38;5;10m[49m             "p50_months":           _pct(finite, 50),
[0m[49m[38;5;10m+    1596[0m:[38;5;10m[49m             "p90_months":           _pct(finite, 90),
[0m[49m[38;5;10m+    1597[0m:[38;5;10m[49m             "samples":              len(crossings),
[0m[49m[38;5;10m+    1598[0m:[38;5;10m[49m             "horizon_months":       forecast_horizon_months,
[0m[49m[38;5;10m+    1599[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1600[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1601[0m:[38;5;10m[49m         explanation = _compose_explanation_text(
[0m[49m[38;5;10m+    1602[0m:[38;5;10m[49m             patient["patient_id"],
[0m[49m[38;5;10m+    1603[0m:[38;5;10m[49m             scenario_forecast,
[0m[49m[38;5;10m+    1604[0m:[38;5;10m[49m             time_to_endpoint,
[0m[49m[38;5;10m+    1605[0m:[38;5;10m[49m             scenario["name"])
[0m[49m[38;5;10m+    1606[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1607[0m:[38;5;10m[49m         counterfactual_results.append({
