[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m # --- Acute Encounter Classes ---
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m # Encounter classes that get tagged "acute" and excluded from the
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m # chronic-trajectory training data.
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m ACUTE_ENCOUNTER_CLASSES = {"inpatient", "emergency", "observation"}
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m # --- Trial-Literature-Derived Effect Priors ---
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m # Calibrated prior beliefs about how each treatment bends the
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m # trajectory. Each entry encodes the slope-modifier point estimate
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m # and the credible-interval bounds derived from cited published
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m # trial evidence. Production maintains this registry as a versioned
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m # config with explicit clinical-advisor sign-off.
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m #
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m # IMPORTANT: The numeric values in this demo are illustrative
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m # approximations of trial-derived estimates. They are not exact
