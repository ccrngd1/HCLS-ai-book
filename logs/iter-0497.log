[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m     if isinstance(value, Decimal):
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m         return value
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m     if isinstance(value, bool):
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m         return value
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m     if isinstance(value, (int, float)):
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m         return Decimal(str(round(float(value), 6)))
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m     if isinstance(value, str):
