[0m[49m[38;5;10m+    1656[0m:[38;5;10m[49m                 target_m = anchor_m + 60.0
[0m[49m[38;5;10m+    1657[0m:[38;5;10m[49m                 ref_point = min(forecast,
[0m[49m[38;5;10m+    1658[0m:[38;5;10m[49m                                 key=lambda f: abs(f["months_from_zero"] - target_m))
[0m[49m[38;5;10m+    1659[0m:[38;5;10m[49m                 sk = (f"adpkd#{MODEL_VERSION_TAG}#"
[0m[49m[38;5;10m+    1660[0m:[38;5;10m[49m                       f"{payload['generated_at_ts']}#{scen['scenario_name']}")
[0m[49m[38;5;10m+    1661[0m:[38;5;10m[49m                 item = {
[0m[49m[38;5;10m+    1662[0m:[38;5;10m[49m                     "patient_id":               payload["patient_id"],
[0m[49m[38;5;10m+    1663[0m:[38;5;10m[49m                     "disease_modelversion_generated_at": sk,
[0m[49m[38;5;10m+    1664[0m:[38;5;10m[49m                     "scenario_name":            scen["scenario_name"],
[0m[49m[38;5;10m+    1665[0m:[38;5;10m[49m                     "model_version":            MODEL_VERSION_TAG,
[0m[49m[38;5;10m+    1666[0m:[38;5;10m[49m                     "trial_prior_version":      TRIAL_PRIOR_VERSION,
[0m[49m[38;5;10m+    1667[0m:[38;5;10m[49m                     "cohort_definition_version": payload["cohort_definition_version"],
[0m[49m[38;5;10m+    1668[0m:[38;5;10m[49m                     "ref_point_month":          _to_decimal(ref_point["months_from_zero"]),
[0m[49m[38;5;10m+    1669[0m:[38;5;10m[49m                     "ref_point_p10":            _to_decimal(ref_point["p10"]),
[0m[49m[38;5;10m+    1670[0m:[38;5;10m[49m                     "ref_point_p50":            _to_decimal(ref_point["p50"]),
[0m[49m[38;5;10m+    1671[0m:[38;5;10m[49m                     "ref_point_p90":            _to_decimal(ref_point["p90"]),
[0m[49m[38;5;10m+    1672[0m:[38;5;10m[49m                     "fraction_to_endpoint":     _to_decimal(
[0m[49m[38;5;10m+    1673[0m:[38;5;10m[49m                         tte["fraction_reaching_endpoint_in_horizon"]),
[0m[49m[38;5;10m+    1674[0m:[38;5;10m[49m                     "p10_months_to_endpoint":   _to_decimal(tte.get("p10_months")),
[0m[49m[38;5;10m+    1675[0m:[38;5;10m[49m                     "p50_months_to_endpoint":   _to_decimal(tte.get("p50_months")),
[0m[49m[38;5;10m+    1676[0m:[38;5;10m[49m                     "p90_months_to_endpoint":   _to_decimal(tte.get("p90_months")),
[0m[49m[38;5;10m+    1677[0m:[38;5;10m[49m                     "endpoint_display":         tte["endpoint_definition"]["display"],
[0m[49m[38;5;10m+    1678[0m:[38;5;10m[49m                     "explanation_text":         scen["explanation_text"],
[0m[49m[38;5;10m+    1679[0m:[38;5;10m[49m                     "assumption_disclosure":    scen["assumption_disclosure"],
[0m[49m[38;5;10m+    1680[0m:[38;5;10m[49m                     "generated_at_ts":          payload["generated_at_ts"],
[0m[49m[38;5;10m+    1681[0m:[38;5;10m[49m                     "run_id":                   run_id,
[0m[49m[38;5;10m+    1682[0m:[38;5;10m[49m                     "pipeline_version":         PIPELINE_VERSION,
[0m[49m[38;5;10m+    1683[0m:[38;5;10m[49m                 }
[0m[49m[38;5;10m+    1684[0m:[38;5;10m[49m                 bw.put_item(Item=item)
[0m[49m[38;5;10m+    1685[0m:[38;5;10m[49m                 written += 1
[0m[49m[38;5;10m+    1686[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1687[0m:[38;5;10m[49m     # 5c. EventBridge completion event (no PHI in the payload).
[0m[49m[38;5;10m+    1688[0m:[38;5;10m[49m     event_bus.put_events(Entries=[{
[0m[49m[38;5;10m+    1689[0m:[38;5;10m[49m         "Source":       "trajectory.adpkd",
[0m[49m[38;5;10m+    1690[0m:[38;5;10m[49m         "DetailType":   "TrajectoryBatchCompleted",
[0m[49m[38;5;10m+    1691[0m:[38;5;10m[49m         "EventBusName": TRAJECTORY_EVENT_BUS_NAME,
