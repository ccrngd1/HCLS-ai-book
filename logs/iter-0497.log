[0m[49m[38;5;10m+    1640[0m:[38;5;10m[49m         s3_key = (f"counterfactuals/adpkd/{payload['patient_id']}/"
[0m[49m[38;5;10m+    1641[0m:[38;5;10m[49m                   f"{payload['generated_at_ts'][:19].replace(':', '-')}.json")
[0m[49m[38;5;10m+    1642[0m:[38;5;10m[49m         s3.put_object(Bucket=counterfactual_bucket, Key=s3_key,
[0m[49m[38;5;10m+    1643[0m:[38;5;10m[49m                       Body=json.dumps(payload, default=str))
[0m[49m[38;5;10m+    1644[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1645[0m:[38;5;10m[49m         # 5b. Summarized record per scenario to DynamoDB. The sort
[0m[49m[38;5;10m+    1646[0m:[38;5;10m[49m         # key combines disease, model version, and generated_at so
[0m[49m[38;5;10m+    1647[0m:[38;5;10m[49m         # the latest record per patient is a Query with prefix and
[0m[49m[38;5;10m+    1648[0m:[38;5;10m[49m         # Limit=1 in descending order.
[0m[49m[38;5;10m+    1649[0m:[38;5;10m[49m         with table.batch_writer() as bw:
[0m[49m[38;5;10m+    1650[0m:[38;5;10m[49m             for scen in payload["scenarios"]:
[0m[49m[38;5;10m+    1651[0m:[38;5;10m[49m                 tte = scen["time_to_endpoint"]
[0m[49m[38;5;10m+    1652[0m:[38;5;10m[49m                 forecast = scen["forecast"]
[0m[49m[38;5;10m+    1653[0m:[38;5;10m[49m                 # Use the forecast point closest to 60 months
