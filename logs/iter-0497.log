[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m     query, get_item. Not a complete DynamoDB emulation; covers
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m     what this pipeline needs.
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m     def __init__(self, name):
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m         self.name        = name
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m         self.items       = {}
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m         self.write_count = 0
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m     class _BatchWriter:
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m         def __init__(self, table):
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m             self.table = table
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m         def __enter__(self):
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m             return self
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m         def __exit__(self, *exc):
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m             return False
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m         def put_item(self, Item):
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m             pk = Item["patient_id"]
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m             sk = Item["disease_modelversion_generated_at"]
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m             self.table.items[(pk, sk)] = dict(Item)
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m             self.table.write_count += 1
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m     def batch_writer(self):
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m         return self._BatchWriter(self)
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m     def put_item(self, Item):
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m         pk = Item["patient_id"]
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m         sk = Item["disease_modelversion_generated_at"]
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m         self.items[(pk, sk)] = dict(Item)
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m         self.write_count += 1
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m class MockEventBus:
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m     """In-memory stand-in for EventBridge."""
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m     def __init__(self, name):
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m         self.name   = name
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m         self.events = []
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m     def put_events(self, Entries):
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m         self.events.extend(Entries)
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m         return {"FailedEntryCount": 0}
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m class MockCloudWatch:
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m     """In-memory stand-in for CloudWatch."""
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m     def __init__(self):
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m         self.metrics = defaultdict(list)
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m     def put_metric_data(self, Namespace, MetricData):
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m         for m in MetricData:
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m             self.metrics[f"{Namespace}/{m['MetricName']}"].append({
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m                 "Value": m["Value"],
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m                 "Unit":  m.get("Unit", "None"),
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m                 "Time":  datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m def generate_synthetic_adpkd_cohort(
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m         patient_count=SYNTHETIC_PATIENT_COUNT,
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m         seed=SYNTHETIC_RANDOM_SEED):
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m     """Generate a synthetic ADPKD cohort with longitudinal trajectories.
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m     Production reads from an Amazon HealthLake FHIR datastore that
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m     has been ingesting from the institutional EHR. The demo
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m     synthesizes a small ADPKD cohort with varied disease severity,
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m     varied observation density, and varied treatment exposures so
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m     you can see the qualification, harmonization, training, and
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m     forecasting steps work end-to-end.
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m     Each patient has:
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m       - A diagnosis Condition with an inclusion ICD-10 code
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m       - A series of eGFR Observations spanning multiple years
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m       - A series of total kidney volume Observations (less frequent)
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m       - A series of systolic BP Observations
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m       - Optional medication history (ACEi/ARB, possibly SGLT2)
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m       - A few inpatient eGFR values that the chronic pipeline
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m         must exclude
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m     The synthetic eGFR trajectory is generated as:
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m         egfr(t) = baseline + slope_per_month * months_since_dx + noise
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m     where slope_per_month varies per patient (faster vs slower
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m     progressors) and is dampened if the patient is on a relevant
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m     medication. This lets the trained model recover both the
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m     population slope and the per-patient deviations.
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m     rng = random.Random(seed)
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m     today = date.today()
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m     patients = []
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m     for i in range(patient_count):
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m         patient_id = f"patient-adpkd-{i+1:03d}"
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m         # Random history length and diagnosis date.
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m         history_years = rng.uniform(
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m             SYNTHETIC_HISTORY_YEARS_MIN, SYNTHETIC_HISTORY_YEARS_MAX)
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m         diagnosis_date = today - timedelta(days=int(history_years * 365.25))
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m         # Patient-specific disease severity. Slope is in mL/min/1.73m^2 per month.
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m         # Population mean is around -0.25; per-patient deviation is wide.
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m         true_slope_per_month = rng.gauss(-0.25, 0.20)
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m         # Clip to clinically plausible range.
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m         true_slope_per_month = max(min(true_slope_per_month, 0.0), -0.7)
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m         # Patient-specific baseline eGFR at diagnosis.
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m         true_baseline_egfr = rng.gauss(85.0, 12.0)
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m         true_baseline_egfr = max(min(true_baseline_egfr, 110.0), 50.0)
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m         # Treatment exposure flags. Most patients are on ACEi/ARB.
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m         on_acei_arb_from_month = rng.choice([0, 0, 0, 6, 12, None])
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m         on_sglt2_from_month    = rng.choice([None, None, None, 24, 36])
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m         on_tolvaptan_from_month = rng.choice([None, None, None, None, 18])
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m         patients.append({
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m             "patient_id":               patient_id,
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m             "diagnosis_date":           diagnosis_date,
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m             "history_years":            history_years,
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m             "true_slope_per_month":     true_slope_per_month,
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m             "true_baseline_egfr":       true_baseline_egfr,
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m             "on_acei_arb_from_month":   on_acei_arb_from_month,
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m             "on_sglt2_from_month":      on_sglt2_from_month,
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m             "on_tolvaptan_from_month":  on_tolvaptan_from_month,
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m     return patients
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m def populate_synthetic_healthlake(patients, healthlake, seed=SYNTHETIC_RANDOM_SEED):
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m     """Populate the MockHealthLake with synthetic FHIR resources.
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m     Walks each synthetic patient and emits the Condition for the
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m     diagnosis, the Observations for eGFR / TKV / SBP across the
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m     history, and the MedicationRequest entries for the relevant
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m     drug classes. A few inpatient-context eGFR values are
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m     interspersed to exercise the chronic-vs-acute filtering.
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m     rng = random.Random(seed + 1)
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m     today = date.today()
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m     for p in patients:
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m         # Diagnosis Condition (drives cohort qualification).
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m         healthlake.put_condition({
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m             "resourceType":      "Condition",
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m             "subject_reference": f"Patient/{p['patient_id']}",
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m             "code_icd10":        rng.choice(["Q61.2", "Q61.3"]),
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m             "onset_dt":          p["diagnosis_date"].isoformat(),
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m         # eGFR observations (~ every 3 months in chronic care).
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m         cursor_months = 0.0
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m         history_months = p["history_years"] * 12.0
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m         while cursor_months <= history_months:
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m             obs_date = p["diagnosis_date"] + timedelta(days=int(cursor_months * 30.5))
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m             if obs_date > today:
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m                 break
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m             # Apply treatment effects to the synthetic trajectory.
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m             effective_slope = p["true_slope_per_month"]
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m             if (p["on_acei_arb_from_month"] is not None
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m                     and cursor_months >= p["on_acei_arb_from_month"]):
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m                 effective_slope *= (1.0 - 0.10)
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m             if (p["on_sglt2_from_month"] is not None
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m                     and cursor_months >= p["on_sglt2_from_month"]):
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m                 effective_slope *= (1.0 - 0.25)
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m             if (p["on_tolvaptan_from_month"] is not None
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m                     and cursor_months >= p["on_tolvaptan_from_month"]):
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m                 effective_slope *= (1.0 - 0.30)
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m             value = (p["true_baseline_egfr"]
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m                      + effective_slope * cursor_months
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m                      + rng.gauss(0.0, 3.0))
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m             value = max(value, 5.0)
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m             healthlake.put_observation({
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m                 "resourceType":      "Observation",
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m                 "subject_reference": f"Patient/{p['patient_id']}",
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m                 "code_loinc":        "48642-3",
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m                 "value_quantity":    round(value, 1),
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m                 "value_unit":        "mL/min/1.73m2",
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m                 "effective_dt":      obs_date.isoformat(),
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m                 "encounter_class":   "ambulatory",
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m             cursor_months += rng.uniform(2.5, 4.0)
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m         # Two acute-context eGFR values mid-history (must be excluded).
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m         if history_months > 30:
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m             for offset_months in (12.0, 12.2):
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m                 d = p["diagnosis_date"] + timedelta(days=int(offset_months * 30.5))
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m                 healthlake.put_observation({
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m                     "resourceType":      "Observation",
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m                     "subject_reference": f"Patient/{p['patient_id']}",
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m                     "code_loinc":        "48642-3",
