[0m[49m[38;5;10m+    1236[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1237[0m:[38;5;10m[49m     treatments_to_use = treatment_override or treatments
[0m[49m[38;5;10m+    1238[0m:[38;5;10m[49m     modifier = model._treatment_modifier(treatments_to_use, m_target)
[0m[49m[38;5;10m+    1239[0m:[38;5;10m[49m     pred_mean = (params["intercept_mean"]
[0m[49m[38;5;10m+    1240[0m:[38;5;10m[49m                  + params["slope_mean"] * modifier * m_target)
[0m[49m[38;5;10m+    1241[0m:[38;5;10m[49m     # Slope-uncertainty contribution (scaled by the lever arm m).
[0m[49m[38;5;10m+    1242[0m:[38;5;10m[49m     slope_var_contrib = (params["slope_sd"] * modifier * m_target) ** 2
[0m[49m[38;5;10m+    1243[0m:[38;5;10m[49m     # Treatment-effect uncertainty contribution. For each active
[0m[49m[38;5;10m+    1244[0m:[38;5;10m[49m     # treatment, the trial-derived SD propagates through the slope
[0m[49m[38;5;10m+    1245[0m:[38;5;10m[49m     # and the lever arm.
[0m[49m[38;5;10m+    1246[0m:[38;5;10m[49m     tx_var_contrib = 0.0
[0m[49m[38;5;10m+    1247[0m:[38;5;10m[49m     for tx in treatments_to_use:
