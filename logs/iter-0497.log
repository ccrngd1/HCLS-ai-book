[0m[49m[38;5;10m+    1613[0m:[38;5;10m[49m             "explanation_text":       explanation,
[0m[49m[38;5;10m+    1614[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    1615[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1616[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    1617[0m:[38;5;10m[49m         "patient_id":                patient["patient_id"],
[0m[49m[38;5;10m+    1618[0m:[38;5;10m[49m         "scenarios":                 counterfactual_results,
[0m[49m[38;5;10m+    1619[0m:[38;5;10m[49m         "baseline_scenario_name":    "current_continued",
[0m[49m[38;5;10m+    1620[0m:[38;5;10m[49m         "model_version":             MODEL_VERSION_TAG,
[0m[49m[38;5;10m+    1621[0m:[38;5;10m[49m         "trial_prior_version":       TRIAL_PRIOR_VERSION,
[0m[49m[38;5;10m+    1622[0m:[38;5;10m[49m         "cohort_definition_version": patient["cohort_definition_version"],
[0m[49m[38;5;10m+    1623[0m:[38;5;10m[49m         "generated_at_ts":           datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    1624[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1625[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1626[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1627[0m:[38;5;10m[49m def deliver_trajectory_payloads(payloads, table, event_bus, cloudwatch,
[0m[49m[38;5;10m+    1628[0m:[38;5;10m[49m                                   s3, counterfactual_bucket, run_id):
[0m[49m[38;5;10m+    1629[0m:[38;5;10m[49m     """Persist per-patient counterfactual payloads.
[0m[49m[38;5;10m+    1630[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1631[0m:[38;5;10m[49m     Surfaced records go to DynamoDB with the disease + model version
[0m[49m[38;5;10m+    1632[0m:[38;5;10m[49m     + generated_at composite sort key. Full payloads (including
[0m[49m[38;5;10m+    1633[0m:[38;5;10m[49m     every scenario forecast point) go to S3 as the analytic record.
[0m[49m[38;5;10m+    1634[0m:[38;5;10m[49m     Pipeline-completion events go to EventBridge; metrics go to
[0m[49m[38;5;10m+    1635[0m:[38;5;10m[49m     CloudWatch.
[0m[49m[38;5;10m+    1636[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1637[0m:[38;5;10m[49m     written = 0
[0m[49m[38;5;10m+    1638[0m:[38;5;10m[49m     for payload in payloads:
