[0m[49m[38;5;10m+      659[0m:[38;5;10m[49m         anion_gap = panel.get("2951-2").value - panel.get("2075-0").value - panel.get("1963-8").value
[0m[49m[38;5;10m+      660[0m:[38;5;10m[49m         IF anion_gap < 3 OR anion_gap > 30:
[0m[49m[38;5;10m+      661[0m:[38;5;10m[49m             flags.append({
[0m[49m[38;5;10m+      662[0m:[38;5;10m[49m                 rule_type:    "panel_coherence_anion_gap",
