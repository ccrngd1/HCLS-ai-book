[0m[49m[39m  486, 486[0m:[39m[49m   "patient_id": "PAT-00839271",
[0m[49m[39m  487, 487[0m:[39m[49m   "unit": "4-North Medical",
[0m[49m[39m  488, 488[0m:[39m[49m   "bed": "4N-12",
