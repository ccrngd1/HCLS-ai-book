[0m[49m[39m  179, 179[0m:[39m[49m ### Ingredients
[0m[49m[39m  180, 180[0m:[39m[49m 
[0m[49m[39m  181, 181[0m:[39m[49m | AWS Service | Role |
[0m[49m[39m  182, 182[0m:[39m[49m |------------|------|
[0m[49m[39m  183, 183[0m:[39m[49m | **Amazon SageMaker** | Model training, hosting, batch inference, model registry |
[0m[49m[39m  184, 184[0m:[39m[49m | **SageMaker Feature Store** | Consistent feature serving for training and inference |
[0m[49m[39m  185, 185[0m:[39m[49m | **AWS HealthLake** | FHIR-compliant clinical data store; source for feature engineering |
[0m[49m[39m  186, 186[0m:[39m[49m | **AWS Lambda** | Event-driven triggers for re-prediction on clinical state changes |
[0m[49m[39m  187, 187[0m:[39m[49m | **Amazon DynamoDB** | Low-latency prediction store for operational queries |
[0m[49m[39m  188, 188[0m:[39m[49m | **Amazon S3** | Training data, model artifacts, batch prediction outputs |
[0m[49m[39m  189, 189[0m:[39m[49m | **Amazon QuickSight** | Operational dashboards for bed management and discharge planning |
[0m[49m[39m  190, 190[0m:[39m[49m | **Amazon SNS** | Alerts for extended-stay predictions and discharge readiness |
[0m[49m[39m  191, 191[0m:[39m[49m | **AWS KMS** | Encryption key management for all PHI-containing stores |
[0m[49m[39m  192, 192[0m:[39m[49m | **Amazon CloudWatch** | Model performance monitoring, prediction latency, drift detection |
[0m[49m[39m  193, 193[0m:[39m[49m 
[0m[49m[39m  194, 194[0m:[39m[49m ### Code
[0m[49m[39m  195, 195[0m:[39m[49m 
[0m[49m[39m  196, 196[0m:[39m[49m #### Walkthrough
[0m[49m[39m  197, 197[0m:[39m[49m 
[0m[49m[39m  198, 198[0m:[39m[49m **Step 1: Feature extraction from clinical data.** The foundation of any LOS model is the feature set. At admission time, you extract static features (demographics, diagnosis, comorbidities, admission source). As the stay progresses, you extract dynamic features (latest labs, vital sign trends, medication changes, procedures). The feature extraction logic must handle missing data gracefully because not every patient has every lab drawn on every day. The key design decision: compute features at a consistent cadence (every 24 hours at midnight, for example) so that training data and inference data are aligned temporally. Skip this step or compute features inconsistently, and your model will learn patterns that don't exist in production.
[0m[49m[39m  199, 199[0m:[39m[49m 
[0m[49m[39m  200, 200[0m:[39m[49m ```
[0m[49m[39m  201, 201[0m:[39m[49m FUNCTION extract_admission_features(encounter):
[0m[49m[39m  202, 202[0m:[39m[49m     // Static features available at the moment of admission.
[0m[49m[39m  203, 203[0m:[39m[49m     // These form the baseline prediction before any clinical trajectory is observed.
[0m[49m[39m  204, 204[0m:[39m[49m     
[0m[49m[39m  205, 205[0m:[39m[49m     features = {
[0m[49m[39m  206, 206[0m:[39m[49m         "age":                  encounter.patient.age_at_admission,
[0m[49m[39m  207, 207[0m:[39m[49m         "sex":                  encode_categorical(encounter.patient.sex),
[0m[49m[39m  208, 208[0m:[39m[49m         "admission_source":     encode_categorical(encounter.admission_source),  // ED, direct, transfer
[0m[49m[39m  209, 209[0m:[39m[49m         "admission_type":       encode_categorical(encounter.admission_type),    // emergent, elective, urgent
[0m[49m[39m  210, 210[0m:[39m[49m         "primary_dx_category":  map_icd10_to_category(encounter.primary_diagnosis),
[0m[49m[39m  211, 211[0m:[39m[49m         "drg_code":             encounter.drg_assignment,
[0m[49m[39m  212, 212[0m:[39m[49m         "drg_geometric_mean":   lookup_drg_mean_los(encounter.drg_assignment),   // CMS benchmark
[0m[49m[39m  213, 213[0m:[39m[49m         "charlson_score":       compute_charlson_index(encounter.diagnosis_list),
[0m[49m[39m  214, 214[0m:[39m[49m         "elixhauser_count":     count_elixhauser_categories(encounter.diagnosis_list),
[0m[49m[39m  215, 215[0m:[39m[49m         "prior_admits_12mo":    count_admissions_last_12_months(encounter.patient_id),
[0m[49m[39m  216, 216[0m:[39m[49m         "prior_ed_visits_12mo": count_ed_visits_last_12_months(encounter.patient_id),
[0m[49m[39m  217, 217[0m:[39m[49m         "insurance_category":   encode_categorical(encounter.insurance_type),    // Medicare, Medicaid, commercial
[0m[49m[39m  218, 218[0m:[39m[49m         "day_of_week_admit":    encounter.admission_datetime.day_of_week,
[0m[49m[39m  219, 219[0m:[39m[49m         "hour_of_admit":        encounter.admission_datetime.hour
[0m[49m[39m  220, 220[0m:[39m[49m     }
[0m[49m[39m  221, 221[0m:[39m[49m     
[0m[49m[39m  222, 222[0m:[39m[49m     RETURN features
[0m[49m[39m  223, 223[0m:[39m[49m 
[0m[49m[39m  224, 224[0m:[39m[49m 
[0m[49m[39m  225, 225[0m:[39m[49m FUNCTION extract_daily_features(encounter, as_of_date):
[0m[49m[39m  226, 226[0m:[39m[49m     // Dynamic features computed at a specific point during the stay.
[0m[49m[39m  227, 227[0m:[39m[49m     // These capture the clinical trajectory and enable prediction updates.
[0m[49m[39m  228, 228[0m:[39m[49m     
[0m[49m[39m  229, 229[0m:[39m[49m     current_day = days_between(encounter.admission_date, as_of_date)
[0m[49m[39m  230, 230[0m:[39m[49m     
[0m[49m[39m  231, 231[0m:[39m[49m     // Lab features: most recent values and trends
[0m[49m[39m  232, 232[0m:[39m[49m     labs = get_latest_labs(encounter.patient_id, as_of_date)
[0m[49m[39m  233, 233[0m:[39m[49m     lab_features = {
[0m[49m[39m  234, 234[0m:[39m[49m         "wbc_latest":           labs.get("WBC", NULL),
[0m[49m[39m  235, 235[0m:[39m[49m         "wbc_trend_48h":        compute_trend(labs, "WBC", hours=48),  // rising, falling, stable
[0m[49m[39m  236, 236[0m:[39m[49m         "creatinine_latest":    labs.get("CREATININE", NULL),
[0m[49m[39m  237, 237[0m:[39m[49m         "albumin_latest":       labs.get("ALBUMIN", NULL),
[0m[49m[39m  238, 238[0m:[39m[49m         "lactate_latest":       labs.get("LACTATE", NULL),
[0m[49m[39m  239, 239[0m:[39m[49m         "abnormal_lab_count":   count_abnormal_flags(labs)
[0m[49m[39m  240, 240[0m:[39m[49m     }
[0m[49m[39m  241, 241[0m:[39m[49m     
[0m[49m[39m  242, 242[0m:[39m[49m     // Vital sign stability
[0m[49m[39m  243, 243[0m:[39m[49m     vitals = get_vitals_last_24h(encounter.patient_id, as_of_date)
[0m[49m[39m  244, 244[0m:[39m[49m     vital_features = {
[0m[49m[39m  245, 245[0m:[39m[49m         "temp_max_24h":         max(vitals.temperature),
[0m[49m[39m  246, 246[0m:[39m[49m         "hr_variability_24h":   std_deviation(vitals.heart_rate),
[0m[49m[39m  247, 247[0m:[39m[49m         "o2_requirement":       latest_o2_flow_rate(vitals),
[0m[49m[39m  248, 248[0m:[39m[49m         "bp_stable":            is_bp_stable_24h(vitals)  // boolean
[0m[49m[39m  249, 249[0m:[39m[49m     }
[0m[49m[39m  250, 250[0m:[39m[49m     
[0m[49m[39m  251, 251[0m:[39m[49m     // Treatment intensity signals
[0m[49m[39m  252, 252[0m:[39m[49m     treatment_features = {
[0m[49m[39m  253, 253[0m:[39m[49m         "iv_antibiotics_active":    has_active_iv_antibiotics(encounter, as_of_date),
[0m[49m[39m  254, 254[0m:[39m[49m         "vasopressors_active":      has_active_vasopressors(encounter, as_of_date),
[0m[49m[39m  255, 255[0m:[39m[49m         "new_consults_today":       count_consults_ordered(encounter, as_of_date),
[0m[49m[39m  256, 256[0m:[39m[49m         "procedures_pending":       count_pending_procedures(encounter, as_of_date),
[0m[49m[39m  257, 257[0m:[39m[49m         "diet_status":              get_diet_order_status(encounter, as_of_date)  // NPO, clear, regular
[0m[49m[39m  258, 258[0m:[39m[49m     }
[0m[49m[39m  259, 259[0m:[39m[49m     
[0m[49m[39m  260, 260[0m:[39m[49m     // Combine all feature sets with the current day of stay
[0m[49m[39m  261, 261[0m:[39m[49m     all_features = merge(lab_features, vital_features, treatment_features)
[0m[49m[39m  262, 262[0m:[39m[49m     all_features["current_day_of_stay"] = current_day
[0m[49m[39m  263, 263[0m:[39m[49m     
[0m[49m[39m  264, 264[0m:[39m[49m     RETURN all_features
[0m[49m[39m  265, 265[0m:[39m[49m ```
[0m[49m[39m  266, 266[0m:[39m[49m 
[0m[49m[39m  267, 267[0m:[39m[49m **Step 2: Training data preparation.** For training, you need historical encounters with known outcomes (actual LOS). The trick is creating training examples at multiple time points during each stay. A patient who stayed 7 days generates training examples at day 0 (target: 7), day 1 (target: 6), day 2 (target: 5), and so on. This teaches the model to predict remaining LOS from any point during the stay, not just admission. Filter out encounters that ended in death or transfer (different outcome distributions) unless you're building separate models for those populations. Also exclude encounters shorter than 24 hours (observation stays) unless your use case specifically includes them.
[0m[49m[39m  268, 268[0m:[39m[49m 
[0m[49m[39m  269, 269[0m:[39m[49m ```
[0m[49m[39m  270, 270[0m:[39m[49m FUNCTION prepare_training_data(historical_encounters, min_los=1, max_los=60):
[0m[49m[39m  271, 271[0m:[39m[49m     // Build training examples from completed encounters.
[0m[49m[39m  272, 272[0m:[39m[49m     // Each encounter generates multiple examples: one per day of stay.
[0m[49m[39m  273, 273[0m:[39m[49m     
[0m[49m[39m  274, 274[0m:[39m[49m     training_examples = empty list
[0m[49m[39m  275, 275[0m:[39m[49m     
[0m[49m[39m  276, 276[0m:[39m[49m     FOR each encounter in historical_encounters:
[0m[49m[39m  277, 277[0m:[39m[49m         actual_los = encounter.actual_length_of_stay_days
[0m[49m[39m  278, 278[0m:[39m[49m         
[0m[49m[39m  279, 279[0m:[39m[49m         // Filter: exclude very short stays (observation) and extreme outliers
[0m[49m[39m  280, 280[0m:[39m[49m         IF actual_los < min_los OR actual_los > max_los:
[0m[49m[39m  281, 281[0m:[39m[49m             CONTINUE
[0m[49m[39m  282, 282[0m:[39m[49m         
[0m[49m[39m  283, 283[0m:[39m[49m         // Filter: exclude deaths and transfers (build separate models for these)
[0m[49m[39m  284, 284[0m:[39m[49m         IF encounter.discharge_disposition IN ["expired", "transfer_acute"]:
[0m[49m[39m  285, 285[0m:[39m[49m             CONTINUE
[0m[49m[39m  286, 286[0m:[39m[49m         
[0m[49m[39m  287, 287[0m:[39m[49m         // Generate admission-time example
[0m[49m[39m  288, 288[0m:[39m[49m         admission_features = extract_admission_features(encounter)
[0m[49m[39m  289, 289[0m:[39m[49m         admission_features["remaining_los"] = actual_los  // target variable
[0m[49m[39m  290, 290[0m:[39m[49m         admission_features["prediction_day"] = 0
[0m[49m[39m  291, 291[0m:[39m[49m         append admission_features to training_examples
[0m[49m[39m  292, 292[0m:[39m[49m         
[0m[49m[39m  293, 293[0m:[39m[49m         // Generate daily examples for each day of the stay
[0m[49m[39m  294, 294[0m:[39m[49m         FOR day = 1 TO actual_los - 1:
[0m[49m[39m  295, 295[0m:[39m[49m             as_of_date = encounter.admission_date + day days
[0m[49m[39m  296, 296[0m:[39m[49m             
[0m[49m[39m  297, 297[0m:[39m[49m             daily_features = extract_daily_features(encounter, as_of_date)
[0m[49m[39m  298, 298[0m:[39m[49m             combined = merge(admission_features, daily_features)
[0m[49m[39m  299, 299[0m:[39m[49m             combined["remaining_los"] = actual_los - day  // remaining days from this point
[0m[49m[39m  300, 300[0m:[39m[49m             combined["prediction_day"] = day
[0m[49m[39m  301, 301[0m:[39m[49m             
[0m[49m[39m  302, 302[0m:[39m[49m             append combined to training_examples
[0m[49m[39m  303, 303[0m:[39m[49m     
[0m[49m[39m  304, 304[0m:[39m[49m     RETURN training_examples
[0m[49m[39m  305, 305[0m:[39m[49m ```
[0m[49m[39m  306, 306[0m:[39m[49m 
[0m[49m[39m  307, 307[0m:[39m[49m **Step 3: Model training with service-line stratification.** One model does not fit all. Cardiac surgery patients have fundamentally different LOS drivers than general medicine patients. Train separate models per service line (or DRG family) to capture these differences. Use gradient boosted trees as the baseline because they handle the mixed feature types, missing values, and non-linear relationships well. Evaluate using mean absolute error (MAE) and the percentage of predictions within 1 day of actual. Also evaluate calibration: does the model's predicted distribution match the actual distribution?
[0m[49m[39m  308, 308[0m:[39m[49m 
[0m[49m[39m  309, 309[0m:[39m[49m ```
[0m[49m[39m  310, 310[0m:[39m[49m FUNCTION train_los_model(training_data, service_line):
[0m[49m[39m  311, 311[0m:[39m[49m     // Train a gradient boosted tree model for a specific service line.
[0m[49m[39m  312, 312[0m:[39m[49m     // Separate models per service line capture different LOS dynamics.
[0m[49m[39m  313, 313[0m:[39m[49m     
[0m[49m[39m  314, 314[0m:[39m[49m     // Filter training data to this service line
[0m[49m[39m  315, 315[0m:[39m[49m     service_data = filter training_data WHERE service_line matches
[0m[49m[39m  316, 316[0m:[39m[49m     
[0m[49m[39m  317, 317[0m:[39m[49m     // Split: 80% train, 10% validation, 10% test (time-based split, not random)
[0m[49m[39m  318, 318[0m:[39m[49m     // Time-based split prevents data leakage from future patterns
[0m[49m[39m  319, 319[0m:[39m[49m     train, validation, test = temporal_split(service_data, ratios=[0.8, 0.1, 0.1])
[0m[49m[39m  320, 320[0m:[39m[49m     
[0m[49m[39m  321, 321[0m:[39m[49m     // Define features (exclude the target and metadata columns)
[0m[49m[39m  322, 322[0m:[39m[49m     feature_columns = all columns EXCEPT ["remaining_los", "encounter_id", "patient_id"]
[0m[49m[39m  323, 323[0m:[39m[49m     target_column = "remaining_los"
[0m[49m[39m  324, 324[0m:[39m[49m     
[0m[49m[39m  325, 325[0m:[39m[49m     // Train XGBoost regressor
[0m[49m[39m  326, 326[0m:[39m[49m     model = XGBoost.train(
[0m[49m[39m  327, 327[0m:[39m[49m         objective       = "reg:squarederror",
[0m[49m[39m  328, 328[0m:[39m[49m         train_data      = train[feature_columns],
[0m[49m[39m  329, 329[0m:[39m[49m         train_labels    = train[target_column],
[0m[49m[39m  330, 330[0m:[39m[49m         validation_data = validation[feature_columns],
[0m[49m[39m  331, 331[0m:[39m[49m         validation_labels = validation[target_column],
[0m[49m[39m  332, 332[0m:[39m[49m         hyperparameters = {
[0m[49m[39m  333, 333[0m:[39m[49m             "max_depth":        6,
[0m[49m[39m  334, 334[0m:[39m[49m             "learning_rate":    0.05,
[0m[49m[39m  335, 335[0m:[39m[49m             "n_estimators":     500,
[0m[49m[39m  336, 336[0m:[39m[49m             "subsample":        0.8,
[0m[49m[39m  337, 337[0m:[39m[49m             "colsample_bytree": 0.8,
[0m[49m[39m  338, 338[0m:[39m[49m             "early_stopping":   20,       // stop if validation doesn't improve for 20 rounds
[0m[49m[39m  339, 339[0m:[39m[49m             "min_child_weight": 10        // prevent overfitting to rare cases
[0m[49m[39m  340, 340[0m:[39m[49m         }
[0m[49m[39m  341, 341[0m:[39m[49m     )
[0m[49m[39m  342, 342[0m:[39m[49m     
[0m[49m[39m  343, 343[0m:[39m[49m     // Evaluate on held-out test set
[0m[49m[39m  344, 344[0m:[39m[49m     predictions = model.predict(test[feature_columns])
[0m[49m[39m  345, 345[0m:[39m[49m     metrics = {
[0m[49m[39m  346, 346[0m:[39m[49m         "mae":              mean_absolute_error(test[target_column], predictions),
[0m[49m[39m  347, 347[0m:[39m[49m         "within_1_day":     percentage_within_threshold(test[target_column], predictions, threshold=1),
[0m[49m[39m  348, 348[0m:[39m[49m         "within_2_days":    percentage_within_threshold(test[target_column], predictions, threshold=2),
[0m[49m[39m  349, 349[0m:[39m[49m         "median_error":     median(absolute(test[target_column] - predictions)),
[0m[49m[39m  350, 350[0m:[39m[49m         "r_squared":        r2_score(test[target_column], predictions)
[0m[49m[39m  351, 351[0m:[39m[49m     }
[0m[49m[39m  352, 352[0m:[39m[49m     
[0m[49m[39m  353, 353[0m:[39m[49m     // Log metrics and register model
[0m[49m[39m  354, 354[0m:[39m[49m     log_metrics(metrics, service_line=service_line)
[0m[49m[39m  355, 355[0m:[39m[49m     register_model(model, service_line=service_line, metrics=metrics)
[0m[49m[39m  356, 356[0m:[39m[49m     
[0m[49m[39m  357, 357[0m:[39m[49m     RETURN model, metrics
[0m[49m[39m  358, 358[0m:[39m[49m ```
[0m[49m[39m  359, 359[0m:[39m[49m 
[0m[49m[39m  360, 360[0m:[39m[49m **Step 4: Real-time inference for current inpatients.** For operational use, the system needs to produce updated predictions for all current inpatients at least daily, and ideally whenever significant clinical events occur (new lab results, procedure completion, status change). The inference pipeline pulls the latest features from the feature store, selects the appropriate service-line model, runs prediction, and writes the result to the prediction store. Include a confidence interval (not just a point estimate) so that operations teams can distinguish between "we're fairly sure this patient leaves tomorrow" and "this could be anywhere from 2 to 10 more days."
[0m[49m[39m  361, 361[0m:[39m[49m 
[0m[49m[39m  362, 362[0m:[39m[49m <!-- TODO (TechWriter): Expert review A2 (MEDIUM). Clarify multi-model endpoint pattern: separate endpoints per service line vs. SageMaker Multi-Model Endpoints (lower cost, ~50ms model-loading overhead). Update cost estimate to reflect multiple service lines. -->
[0m[49m[39m  363, 363[0m:[39m[49m 
[0m[49m[39m  364, 364[0m:[39m[49m ```
[0m[49m[39m  365, 365[0m:[39m[49m FUNCTION predict_remaining_los(encounter_id):
[0m[49m[39m  366, 366[0m:[39m[49m     // Generate an updated LOS prediction for a current inpatient.
[0m[49m[39m  367, 367[0m:[39m[49m     // Called on a schedule (daily) and on clinical event triggers.
[0m[49m[39m  368, 368[0m:[39m[49m     
[0m[49m[39m  369, 369[0m:[39m[49m     // Get encounter metadata to select the right model
[0m[49m[39m  370, 370[0m:[39m[49m     encounter = get_active_encounter(encounter_id)
[0m[49m[39m  371, 371[0m:[39m[49m     service_line = encounter.service_line
[0m[49m[39m  372, 372[0m:[39m[49m     
[0m[49m[39m  373, 373[0m:[39m[49m     // Pull latest features from the feature store (ensures consistency with training)
[0m[49m[39m  374, 374[0m:[39m[49m     admission_features = feature_store.get_online(
[0m[49m[39m  375, 375[0m:[39m[49m         feature_group = "admission_features",
[0m[49m[39m  376, 376[0m:[39m[49m         record_id     = encounter_id
[0m[49m[39m  377, 377[0m:[39m[49m     )
[0m[49m[39m  378, 378[0m:[39m[49m     daily_features = feature_store.get_online(
[0m[49m[39m  379, 379[0m:[39m[49m         feature_group = "daily_features",
[0m[49m[39m  380, 380[0m:[39m[49m         record_id     = encounter_id
[0m[49m[39m  381, 381[0m:[39m[49m     )
[0m[49m[39m  382, 382[0m:[39m[49m     
[0m[49m[39m  383, 383[0m:[39m[49m     // Combine feature sets
[0m[49m[39m  384, 384[0m:[39m[49m     features = merge(admission_features, daily_features)
[0m[49m[39m  385, 385[0m:[39m[49m     
[0m[49m[39m  386, 386[0m:[39m[49m     // Select the model for this service line
[0m[49m[39m  387, 387[0m:[39m[49m     model_endpoint = get_model_endpoint(service_line)
[0m[49m[39m  388, 388[0m:[39m[49m     
[0m[49m[39m  389, 389[0m:[39m[49m     // Run inference
[0m[49m[39m  390, 390[0m:[39m[49m     prediction = invoke_endpoint(model_endpoint, features)
[0m[49m[39m  391, 391[0m:[39m[49m     
[0m[49m[39m  392, 392[0m:[39m[49m     // Compute confidence interval using quantile predictions
[0m[49m[39m  393, 393[0m:[39m[49m     // (requires training quantile regression models or using prediction intervals)
[0m[49m[39m  394, 394[0m:[39m[49m     lower_bound = max(0, prediction.point_estimate - prediction.uncertainty)
[0m[49m[39m  395, 395[0m:[39m[49m     upper_bound = prediction.point_estimate + prediction.uncertainty
[0m[49m[39m  396, 396[0m:[39m[49m     
[0m[49m[39m  397, 397[0m:[39m[49m     // Calculate predicted discharge date
[0m[49m[39m  398, 398[0m:[39m[49m     current_day = days_since_admission(encounter)
[0m[49m[39m  399, 399[0m:[39m[49m     predicted_discharge = encounter.admission_date + current_day + prediction.point_estimate
[0m[49m[39m  400, 400[0m:[39m[49m     
[0m[49m[39m  401, 401[0m:[39m[49m     // Store prediction
[0m[49m[39m  402, 402[0m:[39m[49m     result = {
[0m[49m[39m  403, 403[0m:[39m[49m         "encounter_id":         encounter_id,
[0m[49m[39m  404, 404[0m:[39m[49m         "patient_id":           encounter.patient_id,
[0m[49m[39m  405, 405[0m:[39m[49m         "unit":                 encounter.current_unit,
[0m[49m[39m  406, 406[0m:[39m[49m         "bed":                  encounter.current_bed,
[0m[49m[39m  407, 407[0m:[39m[49m         "service_line":         service_line,
[0m[49m[39m  408, 408[0m:[39m[49m         "current_day_of_stay":  current_day,
[0m[49m[39m  409, 409[0m:[39m[49m         "predicted_remaining":  round(prediction.point_estimate, 1),
[0m[49m[39m  410, 410[0m:[39m[49m         "confidence_lower":     round(lower_bound, 1),
[0m[49m[39m  411, 411[0m:[39m[49m         "confidence_upper":     round(upper_bound, 1),
[0m[49m[39m  412, 412[0m:[39m[49m         "predicted_discharge":  predicted_discharge,
[0m[49m[39m  413, 413[0m:[39m[49m         "drg_expected_los":     lookup_drg_mean_los(encounter.drg_assignment),
[0m[49m[39m  414, 414[0m:[39m[49m         "exceeds_expected":     (current_day + prediction.point_estimate) > lookup_drg_mean_los(encounter.drg_assignment),
[0m[49m[39m  415, 415[0m:[39m[49m         "prediction_timestamp": current_utc_timestamp(),
[0m[49m[39m  416, 416[0m:[39m[49m         "model_version":        model_endpoint.version
[0m[49m[39m  417, 417[0m:[39m[49m     }
[0m[49m[39m  418, 418[0m:[39m[49m     
[0m[49m[39m  419, 419[0m:[39m[49m     write_to_prediction_store(result)
[0m[49m[39m  420, 420[0m:[39m[49m     
[0m[49m[39m  421, 421[0m:[39m[49m     // Alert if predicted to significantly exceed DRG expected LOS
[0m[49m[39m  422, 422[0m:[39m[49m     IF result.exceeds_expected AND current_day <= 2:
[0m[49m[39m  423, 423[0m:[39m[49m         send_alert("extended_stay_early_warning", result)
[0m[49m[39m  424, 424[0m:[39m[49m     
[0m[49m[39m  425, 425[0m:[39m[49m     RETURN result
[0m[49m[39m  426, 426[0m:[39m[49m ```
[0m[49m[39m  427, 427[0m:[39m[49m 
[0m[49m[39m  428, 428[0m:[39m[49m **Step 5: Daily batch refresh and monitoring.** Once a day, re-score all current inpatients and compare yesterday's predictions against today's reality. Patients who were discharged yesterday provide ground truth for model monitoring. Track prediction accuracy over time and trigger retraining when performance degrades. Also monitor for distribution drift: if the patient population is changing (new service lines, seasonal patterns, pandemic surges), the model may need updating even if recent accuracy looks acceptable. Orchestrate this batch with a workflow engine (such as Step Functions): check HealthLake data freshness before scoring, checkpoint progress so the pipeline can resume on partial failure, and alert the operations team if the batch doesn't complete within its expected window.
[0m[49m[39m  429, 429[0m:[39m[49m 
[0m[49m[39m  430, 430[0m:[39m[49m ```
[0m[49m[39m  431, 431[0m:[39m[49m FUNCTION daily_batch_refresh():
[0m[49m[39m  432, 432[0m:[39m[49m     // Run every morning: update all predictions and monitor model performance.
[0m[49m[39m  433, 433[0m:[39m[49m     
[0m[49m[39m  434, 434[0m:[39m[49m     // 1. Score all current inpatients
[0m[49m[39m  435, 435[0m:[39m[49m     active_encounters = get_all_active_inpatient_encounters()
[0m[49m[39m  436, 436[0m:[39m[49m     
[0m[49m[39m  437, 437[0m:[39m[49m     FOR each encounter in active_encounters:
[0m[49m[39m  438, 438[0m:[39m[49m         // Update features in the feature store
[0m[49m[39m  439, 439[0m:[39m[49m         daily_features = extract_daily_features(encounter, today)
[0m[49m[39m  440, 440[0m:[39m[49m         feature_store.put_online("daily_features", encounter.encounter_id, daily_features)
[0m[49m[39m  441, 441[0m:[39m[49m         
[0m[49m[39m  442, 442[0m:[39m[49m         // Generate fresh prediction
[0m[49m[39m  443, 443[0m:[39m[49m         predict_remaining_los(encounter.encounter_id)
[0m[49m[39m  444, 444[0m:[39m[49m     
[0m[49m[39m  445, 445[0m:[39m[49m     // 2. Evaluate yesterday's predictions against actual outcomes
[0m[49m[39m  446, 446[0m:[39m[49m     discharged_yesterday = get_encounters_discharged(yesterday)
[0m[49m[39m  447, 447[0m:[39m[49m     
[0m[49m[39m  448, 448[0m:[39m[49m     errors = empty list
[0m[49m[39m  449, 449[0m:[39m[49m     FOR each encounter in discharged_yesterday:
[0m[49m[39m  450, 450[0m:[39m[49m         // Get the prediction that was active at the start of yesterday
[0m[49m[39m  451, 451[0m:[39m[49m         yesterday_prediction = get_prediction_as_of(encounter.encounter_id, yesterday)
[0m[49m[39m  452, 452[0m:[39m[49m         actual_remaining = days_between(yesterday, encounter.discharge_datetime)
[0m[49m[39m  453, 453[0m:[39m[49m         
[0m[49m[39m  454, 454[0m:[39m[49m         error = yesterday_prediction.predicted_remaining - actual_remaining
[0m[49m[39m  455, 455[0m:[39m[49m         append error to errors
[0m[49m[39m  456, 456[0m:[39m[49m     
[0m[49m[39m  457, 457[0m:[39m[49m     // 3. Compute and log monitoring metrics
[0m[49m[39m  458, 458[0m:[39m[49m     monitoring_metrics = {
[0m[49m[39m  459, 459[0m:[39m[49m         "date":                 today,
[0m[49m[39m  460, 460[0m:[39m[49m         "patients_scored":      length(active_encounters),
[0m[49m[39m  461, 461[0m:[39m[49m         "patients_discharged":  length(discharged_yesterday),
[0m[49m[39m  462, 462[0m:[39m[49m         "mae_yesterday":        mean(absolute(errors)),
[0m[49m[39m  463, 463[0m:[39m[49m         "bias_yesterday":       mean(errors),  // positive = overpredicting LOS
[0m[49m[39m  464, 464[0m:[39m[49m         "within_1_day_pct":     percentage_within(errors, threshold=1),
[0m[49m[39m  465, 465[0m:[39m[49m         "active_census":        length(active_encounters)
[0m[49m[39m  466, 466[0m:[39m[49m     }
[0m[49m[39m  467, 467[0m:[39m[49m     
[0m[49m[39m  468, 468[0m:[39m[49m     log_monitoring_metrics(monitoring_metrics)
[0m[49m[39m  469, 469[0m:[39m[49m     
[0m[49m[39m  470, 470[0m:[39m[49m     // 4. Alert if model performance is degrading
[0m[49m[39m  471, 471[0m:[39m[49m     IF monitoring_metrics.mae_yesterday > PERFORMANCE_THRESHOLD:
[0m[49m[39m  472, 472[0m:[39m[49m         send_alert("model_performance_degradation", monitoring_metrics)
[0m[49m[39m  473, 473[0m:[39m[49m     
[0m[49m[39m  474, 474[0m:[39m[49m     RETURN monitoring_metrics
[0m[49m[39m  475, 475[0m:[39m[49m ```
[0m[49m[39m  476, 476[0m:[39m[49m 
[0m[49m[39m  477, 477[0m:[39m[49m > **Curious how this looks in Python?** The pseudocode above covers the concepts. If you'd like to see sample Python code that demonstrates these patterns using boto3, check out the [Python Example](chapter07.07-python-example). It walks through each step with inline comments and notes on what you'd need to change for a real deployment.
[0m[49m[39m  478, 478[0m:[39m[49m 
[0m[49m[39m  479, 479[0m:[39m[49m ### Expected Results
[0m[49m[39m  480, 480[0m:[39m[49m 
[0m[49m[39m  481, 481[0m:[39m[49m **Sample prediction output for a current inpatient:**
[0m[49m[39m  482, 482[0m:[39m[49m 
[0m[49m[39m  483, 483[0m:[39m[49m ```json
