[0m[49m[38;5;10m+    1645[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1646[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    1647[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1648[0m:[38;5;10m[49m     // Step 5B: assemble the tool surface.
[0m[49m[38;5;10m+    1649[0m:[38;5;10m[49m     tools = available_tools_for_session({
[0m[49m[38;5;10m+    1650[0m:[38;5;10m[49m         speaker_role: speaker_role,
[0m[49m[38;5;10m+    1651[0m:[38;5;10m[49m         speaker_proxy_scope: speaker_proxy_scope,
[0m[49m[38;5;10m+    1652[0m:[38;5;10m[49m         consent_record: context_bundle.consent_record
