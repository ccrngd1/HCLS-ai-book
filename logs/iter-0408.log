[0m[49m[38;5;10m+    1734[0m:[38;5;10m[49m         cited_sources: structured_output.cited_sources,
[0m[49m[38;5;10m+    1735[0m:[38;5;10m[49m         provenance_journal: context_bundle.provenance_summary,
