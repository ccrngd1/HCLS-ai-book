[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m     "length_cm": 3.21,
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m     "width_cm": 1.89,
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m     "perimeter_cm": 8.94,
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m     "circularity": 0.744
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m   },
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m   "confidence": 0.89,
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m   "scale_factor_px_per_cm": 42.3,
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m   "marker_detected": true,
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m   "healing_trajectory": {
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m     "previous_area_cm2": 5.12,
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m     "area_change_pct": -7.6,
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m     "days_since_last": 7,
