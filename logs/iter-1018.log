[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m     "slot_durations": {
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m       "new_patient": 45,
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m       "follow_up_complex": 30,
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m       "follow_up_simple": 20,
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m       "procedure": 40,
