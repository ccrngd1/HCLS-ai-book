[0m[49m[38;5;10m+    1127[0m:[38;5;10m[49m         language: conversation.language,
[0m[49m[38;5;10m+    1128[0m:[38;5;10m[49m         started_at: conversation.started_at,
[0m[49m[38;5;10m+    1129[0m:[38;5;10m[49m         closed_at: now(),
[0m[49m[38;5;10m+    1130[0m:[38;5;10m[49m         close_reason: close_reason,
