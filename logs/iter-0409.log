[0m[49m[38;5;10m+    1143[0m:[38;5;10m[49m         model_and_prompt_versions:
[0m[49m[38;5;10m+    1144[0m:[38;5;10m[49m             conversation.runtime_versions,
[0m[49m[38;5;10m+    1145[0m:[38;5;10m[49m         per_cohort_demographics:
[0m[49m[38;5;10m+    1146[0m:[38;5;10m[49m             conversation.captured_demographics
[0m[49m[38;5;10m+    1147[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    1148[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1149[0m:[38;5;10m[49m     // Step 7B: persist with Object Lock retention.
[0m[49m[38;5;10m+    1150[0m:[38;5;10m[49m     persist_audit_record({
[0m[49m[38;5;10m+    1151[0m:[38;5;10m[49m         record: audit_record,
