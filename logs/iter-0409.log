[0m[49m[38;5;10m+    1153[0m:[38;5;10m[49m         prefix: build_partition_prefix(conversation),
[0m[49m[38;5;10m+    1154[0m:[38;5;10m[49m         retention: institutional_research_retention_policy(
[0m[49m[38;5;10m+    1155[0m:[38;5;10m[49m             conversation.trial_id),
[0m[49m[38;5;10m+    1156[0m:[38;5;10m[49m         kms_key: research_audit_key
[0m[49m[38;5;10m+    1157[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    1158[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1159[0m:[38;5;10m[49m     // Step 7C: stream lifecycle and analytics events.
[0m[49m[38;5;10m+    1160[0m:[38;5;10m[49m     stream_to_firehose([
[0m[49m[38;5;10m+    1161[0m:[38;5;10m[49m         recruitment_funnel_event(conversation),
[0m[49m[38;5;10m+    1162[0m:[38;5;10m[49m         per_cohort_counters(conversation),
[0m[49m[38;5;10m+    1163[0m:[38;5;10m[49m         eligibility_evaluation_outcomes(conversation),
[0m[49m[38;5;10m+    1164[0m:[38;5;10m[49m         handoff_outcome_event(conversation)
[0m[49m[38;5;10m+    1165[0m:[38;5;10m[49m     ])
[0m[49m[38;5;10m+    1166[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1167[0m:[38;5;10m[49m     // Step 7D: emit terminal lifecycle event.
[0m[49m[38;5;10m+    1168[0m:[38;5;10m[49m     emit_event("conversation_closed", {
[0m[49m[38;5;10m+    1169[0m:[38;5;10m[49m         conversation_id: conversation.id,
[0m[49m[38;5;10m+    1170[0m:[38;5;10m[49m         trial_id: conversation.trial_id,
[0m[49m[38;5;10m+    1171[0m:[38;5;10m[49m         close_reason: close_reason,
[0m[49m[38;5;10m+    1172[0m:[38;5;10m[49m         outcome: conversation.terminal_outcome
[0m[49m[38;5;10m+    1173[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    1174[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1175[0m:[38;5;10m[49m     return audit_record
[0m[49m[38;5;10m+    1176[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    1177[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1178[0m:[38;5;10m[49m What can go wrong if you skip or shortcut this: the IRB inspection fails because the audit chain is incomplete. The diversity-action-plan reporting fails because the per-cohort funnel is not instrumented. The recruitment-funnel analysis is impossible because the events are not streamed. The trial sponsor's data-quality review fails because the conversation transcripts are not preserved. The audit record is the regulatory artifact; it is not optional.
[0m[49m[38;5;10m+    1179[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1180[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    1181[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1182[0m:[38;5;10m[49m **Step 8: Run trial-state and trial-amendment lifecycle workflows in Step Functions.** The trial-state and amendment workflows are out-of-band orchestrations that run separately from the conversation runtime but are critical to keeping the conversation runtime correct.
[0m[49m[38;5;10m+    1183[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1184[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    1185[0m:[38;5;10m[49m WORKFLOW publish_trial(trial_id):
[0m[49m[38;5;10m+    1186[0m:[38;5;10m[49m     // 1. validate IRB-approved content bundle
[0m[49m[38;5;10m+    1187[0m:[38;5;10m[49m     validate_irb_content_bundle(trial_id)
[0m[49m[38;5;10m+    1188[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1189[0m:[38;5;10m[49m     // 2. publish to per-trial Bedrock Knowledge Base
[0m[49m[38;5;10m+    1190[0m:[38;5;10m[49m     publish_to_knowledge_base(trial_id)
[0m[49m[38;5;10m+    1191[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1192[0m:[38;5;10m[49m     // 3. index FAQ corpus to OpenSearch
[0m[49m[38;5;10m+    1193[0m:[38;5;10m[49m     index_faq_corpus(trial_id)
[0m[49m[38;5;10m+    1194[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1195[0m:[38;5;10m[49m     // 4. publish eligibility-criteria set with tier metadata
[0m[49m[38;5;10m+    1196[0m:[38;5;10m[49m     publish_eligibility_criteria(trial_id)
[0m[49m[38;5;10m+    1197[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1198[0m:[38;5;10m[49m     // 5. update trial-state to open
[0m[49m[38;5;10m+    1199[0m:[38;5;10m[49m     update_trial_state(trial_id, "open")
[0m[49m[38;5;10m+    1200[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1201[0m:[38;5;10m[49m     // 6. emit lifecycle event
[0m[49m[38;5;10m+    1202[0m:[38;5;10m[49m     emit_event("trial_published", {trial_id})
[0m[49m[38;5;10m+    1203[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1204[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1205[0m:[38;5;10m[49m WORKFLOW publish_amendment(trial_id, amendment_id):
[0m[49m[38;5;10m+    1206[0m:[38;5;10m[49m     // 1. validate IRB-approved amendment bundle
[0m[49m[38;5;10m+    1207[0m:[38;5;10m[49m     validate_irb_amendment_bundle(trial_id, amendment_id)
[0m[49m[38;5;10m+    1208[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1209[0m:[38;5;10m[49m     // 2. classify amendment scope
[0m[49m[38;5;10m+    1210[0m:[38;5;10m[49m     scope = classify_amendment_scope(amendment_id)
[0m[49m[38;5;10m+    1211[0m:[38;5;10m[49m         // values: editorial, eligibility, visit_schedule,
[0m[49m[38;5;10m+    1212[0m:[38;5;10m[49m         // safety, recruitment_language
[0m[49m[38;5;10m+    1213[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1214[0m:[38;5;10m[49m     // 3. publish updated content to Knowledge Base, with new
[0m[49m[38;5;10m+    1215[0m:[38;5;10m[49m     //    version stamp; previous version preserved
[0m[49m[38;5;10m+    1216[0m:[38;5;10m[49m     publish_amendment_content(trial_id, amendment_id)
[0m[49m[38;5;10m+    1217[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1218[0m:[38;5;10m[49m     // 4. update trial-state to amendment_published
[0m[49m[38;5;10m+    1219[0m:[38;5;10m[49m     update_trial_state(trial_id, "amendment_published")
[0m[49m[38;5;10m+    1220[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1221[0m:[38;5;10m[49m     // 5. orchestrate in-flight conversation transitions
[0m[49m[38;5;10m+    1222[0m:[38;5;10m[49m     //    per the IRB-approved amendment-transition plan
[0m[49m[38;5;10m+    1223[0m:[38;5;10m[49m     IF scope IN ["eligibility", "visit_schedule",
[0m[49m[38;5;10m+    1224[0m:[38;5;10m[49m                  "safety", "recruitment_language"]:
[0m[49m[38;5;10m+    1225[0m:[38;5;10m[49m         invoke_in_flight_amendment_transition(trial_id,
[0m[49m[38;5;10m+    1226[0m:[38;5;10m[49m                                               amendment_id)
[0m[49m[38;5;10m+    1227[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1228[0m:[38;5;10m[49m     // 6. emit lifecycle event
[0m[49m[38;5;10m+    1229[0m:[38;5;10m[49m     emit_event("amendment_published",
[0m[49m[38;5;10m+    1230[0m:[38;5;10m[49m                {trial_id, amendment_id, scope})
[0m[49m[38;5;10m+    1231[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1232[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1233[0m:[38;5;10m[49m WORKFLOW pause_recruitment(trial_id, pause_reason):
[0m[49m[38;5;10m+    1234[0m:[38;5;10m[49m     update_trial_state(trial_id, "paused", pause_reason)
[0m[49m[38;5;10m+    1235[0m:[38;5;10m[49m     notify_in_flight_conversations_per_pause_plan(trial_id)
[0m[49m[38;5;10m+    1236[0m:[38;5;10m[49m     notify_coordinator_team(trial_id, pause_reason)
[0m[49m[38;5;10m+    1237[0m:[38;5;10m[49m     emit_event("recruitment_paused",
[0m[49m[38;5;10m+    1238[0m:[38;5;10m[49m                {trial_id, pause_reason})
[0m[49m[38;5;10m+    1239[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1240[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1241[0m:[38;5;10m[49m WORKFLOW close_recruitment(trial_id, close_reason):
[0m[49m[38;5;10m+    1242[0m:[38;5;10m[49m     update_trial_state(trial_id, "closed", close_reason)
[0m[49m[38;5;10m+    1243[0m:[38;5;10m[49m     drain_in_flight_conversations_per_closure_plan(trial_id)
[0m[49m[38;5;10m+    1244[0m:[38;5;10m[49m     archive_per_trial_records(trial_id)
[0m[49m[38;5;10m+    1245[0m:[38;5;10m[49m     emit_event("recruitment_closed",
[0m[49m[38;5;10m+    1246[0m:[38;5;10m[49m                {trial_id, close_reason})
[0m[49m[38;5;10m+    1247[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    1248[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1249[0m:[38;5;10m[49m What can go wrong if you skip or shortcut this: the assistant runs against stale content because the publish-and-amendment workflows are not orchestrated. In-flight conversations are not handled when amendments land. Closed trials still accept conversations because the state was not updated. Coordinator teams are surprised by amendment-driven changes because the lifecycle event is not emitted. The lifecycle workflows are the off-conversation backbone that keeps the conversation runtime correct.
[0m[49m[38;5;10m+    1250[0m:[38;5;10m[49m 
