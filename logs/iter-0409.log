[0m[49m[38;5;10m+    1133[0m:[38;5;10m[49m         faq_turns: conversation.faq_turns,
[0m[49m[38;5;10m+    1134[0m:[38;5;10m[49m         prescreen: conversation.prescreen,
[0m[49m[38;5;10m+    1135[0m:[38;5;10m[49m         handoff: conversation.handoff_packet,
[0m[49m[38;5;10m+    1136[0m:[38;5;10m[49m         emergency_events: conversation.emergency_events,
[0m[49m[38;5;10m+    1137[0m:[38;5;10m[49m         scope_violation_flags:
[0m[49m[38;5;10m+    1138[0m:[38;5;10m[49m             conversation.scope_violation_flags,
[0m[49m[38;5;10m+    1139[0m:[38;5;10m[49m         out_of_corpus_questions:
