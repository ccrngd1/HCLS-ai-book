[0m[49m[38;5;10m+    1077[0m:[38;5;10m[49m             "domestic_violence_disclosure",
[0m[49m[38;5;10m+    1078[0m:[38;5;10m[49m             "child_abuse_disclosure",
[0m[49m[38;5;10m+    1079[0m:[38;5;10m[49m             "elder_abuse_disclosure",
[0m[49m[38;5;10m+    1080[0m:[38;5;10m[49m             "severe_distress"
[0m[49m[38;5;10m+    1081[0m:[38;5;10m[49m         ]
[0m[49m[38;5;10m+    1082[0m:[38;5;10m[49m     })
