[0m[49m[38;5;10m+      298[0m:[38;5;10m[49m **Step 6: Post-deployment monitoring and automatic rollback.** After a template goes active, monitor actual clinic performance against the simulation predictions. Pull real throughput, wait times, and overtime data from the EHR for 1-2 weeks and compare against the `simulation_proposed` metrics stored in DynamoDB. If performance deviates beyond configured thresholds, automatically roll back to the previous template version. DynamoDB's version history makes rollback straightforward: query for the most recent item where `status = "active"` and `version < current_version`, flip its status back to "active," and mark the current template as "rolled_back."
[0m[49m[38;5;10m+      299[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      300[0m:[38;5;10m[49m ```pseudocode
[0m[49m[38;5;10m+      301[0m:[38;5;10m[49m FUNCTION monitor_and_rollback(provider_id, monitoring_window_days = 14):
[0m[49m[38;5;10m+      302[0m:[38;5;10m[49m     // Retrieve the active template and its expected performance
[0m[49m[38;5;10m+      303[0m:[38;5;10m[49m     active_template = query DynamoDB table "template-store":
[0m[49m[38;5;10m+      304[0m:[38;5;10m[49m         WHERE provider_id = provider_id AND status = "active"
[0m[49m[38;5;10m+      305[0m:[38;5;10m[49m         ORDER BY version DESC, LIMIT 1
[0m[49m[38;5;10m+      306[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      307[0m:[38;5;10m[49m     expected = active_template.simulation_proposed
[0m[49m[38;5;10m+      308[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      309[0m:[38;5;10m[49m     // Pull actual performance from EHR data over the monitoring window
[0m[49m[38;5;10m+      310[0m:[38;5;10m[49m     actual_data = extract_scheduling_data(
[0m[49m[38;5;10m+      311[0m:[38;5;10m[49m         start_date = active_template.approved_at,
[0m[49m[38;5;10m+      312[0m:[38;5;10m[49m         end_date   = active_template.approved_at + monitoring_window_days
[0m[49m[38;5;10m+      313[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+      314[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      315[0m:[38;5;10m[49m     actual_metrics = {
[0m[49m[38;5;10m+      316[0m:[38;5;10m[49m         mean_throughput: average(actual_data.patients_per_session),
[0m[49m[38;5;10m+      317[0m:[38;5;10m[49m         mean_wait: average(actual_data.patient_wait_minutes),
[0m[49m[38;5;10m+      318[0m:[38;5;10m[49m         overtime_prob: count(sessions_with_overtime) / total_sessions
[0m[49m[38;5;10m+      319[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+      320[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      321[0m:[38;5;10m[49m     // Check deviation thresholds
[0m[49m[38;5;10m+      322[0m:[38;5;10m[49m     wait_deviation = (actual_metrics.mean_wait - expected.mean_wait) / expected.mean_wait
[0m[49m[38;5;10m+      323[0m:[38;5;10m[49m     overtime_deviation = actual_metrics.overtime_prob - expected.overtime_prob
[0m[49m[38;5;10m+      324[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      325[0m:[38;5;10m[49m     IF wait_deviation > 0.50 OR overtime_deviation > 0.10:
[0m[49m[38;5;10m+      326[0m:[38;5;10m[49m         // Performance has deviated unacceptably. Roll back.
[0m[49m[38;5;10m+      327[0m:[38;5;10m[49m         
[0m[49m[38;5;10m+      328[0m:[38;5;10m[49m         // Find previous active version in DynamoDB
[0m[49m[38;5;10m+      329[0m:[38;5;10m[49m         previous_version = query DynamoDB table "template-store":
[0m[49m[38;5;10m+      330[0m:[38;5;10m[49m             WHERE provider_id = provider_id
[0m[49m[38;5;10m+      331[0m:[38;5;10m[49m             AND version < active_template.version
[0m[49m[38;5;10m+      332[0m:[38;5;10m[49m             AND status IN ("rolled_back_from", "previously_active")
[0m[49m[38;5;10m+      333[0m:[38;5;10m[49m             ORDER BY version DESC, LIMIT 1
[0m[49m[38;5;10m+      334[0m:[38;5;10m[49m         
[0m[49m[38;5;10m+      335[0m:[38;5;10m[49m         // Swap statuses using a DynamoDB TransactWriteItems call
[0m[49m[38;5;10m+      336[0m:[38;5;10m[49m         // to ensure atomicity (both updates succeed or neither does)
[0m[49m[38;5;10m+      337[0m:[38;5;10m[49m         transact_write:
[0m[49m[38;5;10m+      338[0m:[38;5;10m[49m             UPDATE active_template: SET status = "rolled_back",
[0m[49m[38;5;10m+      339[0m:[38;5;10m[49m                                        rolled_back_at = current UTC timestamp,
[0m[49m[38;5;10m+      340[0m:[38;5;10m[49m                                        rollback_reason = "wait_deviation={wait_deviation}, overtime_deviation={overtime_deviation}"
[0m[49m[38;5;10m+      341[0m:[38;5;10m[49m             UPDATE previous_version: SET status = "active"
[0m[49m[38;5;10m+      342[0m:[38;5;10m[49m         
[0m[49m[38;5;10m+      343[0m:[38;5;10m[49m         // Push the previous template back to the EHR
[0m[49m[38;5;10m+      344[0m:[38;5;10m[49m         push_template_to_ehr(provider_id, previous_version.template)
[0m[49m[38;5;10m+      345[0m:[38;5;10m[49m         
[0m[49m[38;5;10m+      346[0m:[38;5;10m[49m         // Alert operations
[0m[49m[38;5;10m+      347[0m:[38;5;10m[49m         send notification:
[0m[49m[38;5;10m+      348[0m:[38;5;10m[49m             to = operations_team_endpoint
[0m[49m[38;5;10m+      349[0m:[38;5;10m[49m             subject = "Template rollback triggered"
[0m[49m[38;5;10m+      350[0m:[38;5;10m[49m             body = "Review in the dashboard: {dashboard_url}"
[0m[49m[38;5;10m+      351[0m:[38;5;10m[49m         
[0m[49m[38;5;10m+      352[0m:[38;5;10m[49m         RETURN "rolled_back"
[0m[49m[38;5;10m+      353[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      354[0m:[38;5;10m[49m     ELSE:
[0m[49m[38;5;10m+      355[0m:[38;5;10m[49m         // Performance within acceptable bounds. Mark monitoring complete.
[0m[49m[38;5;10m+      356[0m:[38;5;10m[49m         UPDATE active_template in DynamoDB:
[0m[49m[38;5;10m+      357[0m:[38;5;10m[49m             SET monitoring_status = "passed",
[0m[49m[38;5;10m+      358[0m:[38;5;10m[49m                 actual_metrics = actual_metrics
[0m[49m[38;5;10m+      359[0m:[38;5;10m[49m         
[0m[49m[38;5;10m+      360[0m:[38;5;10m[49m         RETURN "monitoring_passed"
[0m[49m[38;5;10m+      361[0m:[38;5;10m[49m ```
