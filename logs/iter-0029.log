[0m[49m[38;5;10m+     875[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     876[0m:[38;5;10m[49m def _append_turn(session_id: str, turn: dict) -> None:
[0m[49m[38;5;10m+     877[0m:[38;5;10m[49m     """Append a turn record to the conversation-metadata table."""
[0m[49m[38;5;10m+     878[0m:[38;5;10m[49m     table = dynamodb.Table(CONVERSATION_METADATA_TABLE)
[0m[49m[38;5;10m+     879[0m:[38;5;10m[49m     item = {
[0m[49m[38;5;10m+     880[0m:[38;5;10m[49m         "session_id": session_id,
