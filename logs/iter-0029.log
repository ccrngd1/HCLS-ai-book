[0m[49m[38;5;10m+     793[0m:[38;5;10m[49m             screening_result=screening_result,
[0m[49m[38;5;10m+     794[0m:[38;5;10m[49m             attach_greeting=attach_greeting,
[0m[49m[38;5;10m+     795[0m:[38;5;10m[49m             language=language)
[0m[49m[38;5;10m+     796[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     797[0m:[38;5;10m[49m     # Step 1E: continue to intent classification.
[0m[49m[38;5;10m+     798[0m:[38;5;10m[49m     return _handle_in_scope_message(
[0m[49m[38;5;10m+     799[0m:[38;5;10m[49m         session_id=session_id,
