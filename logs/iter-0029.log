[0m[49m[38;5;10m+     801[0m:[38;5;10m[49m         user_message=user_message,
[0m[49m[38;5;10m+     802[0m:[38;5;10m[49m         auth_context=auth_context,
[0m[49m[38;5;10m+     803[0m:[38;5;10m[49m         attach_greeting=attach_greeting,
[0m[49m[38;5;10m+     804[0m:[38;5;10m[49m         language=language)
[0m[49m[38;5;10m+     805[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     806[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     807[0m:[38;5;10m[49m def _get_or_create_session(channel: str,
[0m[49m[38;5;10m+     808[0m:[38;5;10m[49m                             channel_session_id: str,
[0m[49m[38;5;10m+     809[0m:[38;5;10m[49m                             auth_context: dict,
[0m[49m[38;5;10m+     810[0m:[38;5;10m[49m                             language: str) -> dict:
[0m[49m[38;5;10m+     811[0m:[38;5;10m[49m     """Look up the active conversation or create a new one."""
[0m[49m[38;5;10m+     812[0m:[38;5;10m[49m     session_key = f"{channel}#{channel_session_id}"
