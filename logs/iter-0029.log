[0m[49m[38;5;10m+     824[0m:[38;5;10m[49m     if item:
[0m[49m[38;5;10m+     825[0m:[38;5;10m[49m         item["message_count"] = (
[0m[49m[38;5;10m+     826[0m:[38;5;10m[49m             int(item.get("message_count", 0)) + 1)
[0m[49m[38;5;10m+     827[0m:[38;5;10m[49m         table.put_item(Item=_to_decimal(item))
[0m[49m[38;5;10m+     828[0m:[38;5;10m[49m         return _from_decimal(item)
[0m[49m[38;5;10m+     829[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     830[0m:[38;5;10m[49m     # Brand-new session.
[0m[49m[38;5;10m+     831[0m:[38;5;10m[49m     new_session = {
[0m[49m[38;5;10m+     832[0m:[38;5;10m[49m         "session_key":         session_key,
[0m[49m[38;5;10m+     833[0m:[38;5;10m[49m         "session_id":          str(uuid.uuid4()),
