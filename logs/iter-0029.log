[0m[49m[38;5;10m+     708[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     709[0m:[38;5;10m[49m     redacted = dict(arguments)
[0m[49m[38;5;10m+     710[0m:[38;5;10m[49m     sensitive_keys = {
[0m[49m[38;5;10m+     711[0m:[38;5;10m[49m         "name", "date_of_birth", "confirmation_factor",
[0m[49m[38;5;10m+     712[0m:[38;5;10m[49m         "phone", "ssn", "mrn", "patient_id",
[0m[49m[38;5;10m+     713[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     714[0m:[38;5;10m[49m     for key in list(redacted.keys()):
[0m[49m[38;5;10m+     715[0m:[38;5;10m[49m         if key in sensitive_keys:
[0m[49m[38;5;10m+     716[0m:[38;5;10m[49m             redacted[key] = "[REDACTED]"
[0m[49m[38;5;10m+     717[0m:[38;5;10m[49m     return redacted
[0m[49m[38;5;10m+     718[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     719[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     720[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     721[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     722[0m:[38;5;10m[49m ## Step 1: Receive the Message and Run Input Safety Screening
[0m[49m[38;5;10m+     723[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     724[0m:[38;5;10m[49m *The pseudocode calls this `receive_message(channel, channel_session_id, user_message, auth_context)`. A patient opens the chat widget and types a question. The handler creates a session if one does not exist, plays the greeting and disclosure on the first turn, persists the user's message into the conversation-metadata table, and runs the input-screening primitive. Refill-context crisis signals (overdose disclosure, misuse, self-harm) take precedence over everything else. A patient saying "I took double yesterday because I was upset" while asking about a refill must not have that signal lost in the refill flow.*
[0m[49m[38;5;10m+     725[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     726[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     727[0m:[38;5;10m[49m def receive_message(channel: str,
[0m[49m[38;5;10m+     728[0m:[38;5;10m[49m                     channel_session_id: str,
[0m[49m[38;5;10m+     729[0m:[38;5;10m[49m                     user_message: str,
[0m[49m[38;5;10m+     730[0m:[38;5;10m[49m                     auth_context: Optional[dict] = None,
[0m[49m[38;5;10m+     731[0m:[38;5;10m[49m                     language: str = "en-US") -> dict:
[0m[49m[38;5;10m+     732[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     733[0m:[38;5;10m[49m     Entry point for an inbound chat message.
[0m[49m[38;5;10m+     734[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     735[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     736[0m:[38;5;10m[49m         channel:             Channel identifier (web_chat, in_app,
[0m[49m[38;5;10m+     737[0m:[38;5;10m[49m                              portal_embed, sms, voice).
[0m[49m[38;5;10m+     738[0m:[38;5;10m[49m         channel_session_id:  Stable identifier from the channel.
[0m[49m[38;5;10m+     739[0m:[38;5;10m[49m         user_message:        The patient's typed message.
[0m[49m[38;5;10m+     740[0m:[38;5;10m[49m         auth_context:        Optional dict with `authenticated`
[0m[49m[38;5;10m+     741[0m:[38;5;10m[49m                              (bool) and `patient_id` (str) when the
[0m[49m[38;5;10m+     742[0m:[38;5;10m[49m                              patient arrives through an authenticated
[0m[49m[38;5;10m+     743[0m:[38;5;10m[49m                              portal-embed channel.
[0m[49m[38;5;10m+     744[0m:[38;5;10m[49m         language:            Detected or declared language.
[0m[49m[38;5;10m+     745[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     746[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     747[0m:[38;5;10m[49m         A dict with the response to send to the user.
[0m[49m[38;5;10m+     748[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     749[0m:[38;5;10m[49m     auth_context = auth_context or {"authenticated": False}
[0m[49m[38;5;10m+     750[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     751[0m:[38;5;10m[49m     # Step 1A: identify or create the session.
[0m[49m[38;5;10m+     752[0m:[38;5;10m[49m     session = _get_or_create_session(
[0m[49m[38;5;10m+     753[0m:[38;5;10m[49m         channel=channel,
[0m[49m[38;5;10m+     754[0m:[38;5;10m[49m         channel_session_id=channel_session_id,
[0m[49m[38;5;10m+     755[0m:[38;5;10m[49m         auth_context=auth_context,
[0m[49m[38;5;10m+     756[0m:[38;5;10m[49m         language=language)
[0m[49m[38;5;10m+     757[0m:[38;5;10m[49m     session_id = session["session_id"]
[0m[49m[38;5;10m+     758[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     759[0m:[38;5;10m[49m     # Step 1B: on the first message, send the greeting and
[0m[49m[38;5;10m+     760[0m:[38;5;10m[49m     # disclosure. The disclosure tells the patient this is a
