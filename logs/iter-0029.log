[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m ## Configuration and Constants
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m Everything that is configuration rather than logic lives here. Resource names, model IDs, the refill protocol, the identity-verification policy, the per-intent target assurance levels, the persona and refusal templates, and the validation thresholds are what you would change between environments.
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m import re
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m import uuid
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m from collections import defaultdict
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m from datetime import datetime, timedelta, timezone
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m from typing import Optional
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m # Structured logging. In production, ship JSON-formatted records to
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m # CloudWatch Logs Insights for cross-call investigation. Conversation
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m # logs are PHI by association: the user's question may name specific
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m # medications, doses, or symptoms. Log structural metadata only
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m # (session_id, intent, tool name, tool latency, tool outcome,
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m # identity-verification path), never raw user utterances, never raw
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m # generated responses, never tool arguments that contain identifiers,
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m # never the patient name or DOB collected during identity verification,
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m # never specific medication names or dose values. The full transcripts
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m # and full tool calls live in the audit pipeline (Firehose plus
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m # Object-Lock S3) with appropriate access controls.
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m # Adaptive retry handles throttling from Bedrock, DynamoDB,
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m # EventBridge, Firehose, CloudWatch, S3, Comprehend Medical, and
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m # Secrets Manager. The refill-bot response window is tight: the
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m # patient is staring at the chat widget waiting on a medication
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m # action. A retry storm that adds 5 seconds is operationally worse
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m # than a fast failure with a graceful degraded-mode message. Cap
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m # the retries and let the graceful-failure path handle the fall-back.
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m     retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m # Module-level clients. Reused across Lambda invocations in warm
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m # containers so each invocation does not pay the connection cost.
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m REGION = "us-east-1"
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m bedrock_runtime       = boto3.client("bedrock-runtime",
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m bedrock_agent_runtime = boto3.client("bedrock-agent-runtime",
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m comprehend_medical    = boto3.client("comprehendmedical",
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m dynamodb              = boto3.resource("dynamodb",
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m eventbridge_client    = boto3.client("events",
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m firehose_client       = boto3.client("firehose",
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m cloudwatch_client     = boto3.client("cloudwatch",
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m s3_client             = boto3.client("s3",
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m secrets_client        = boto3.client("secretsmanager",
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m # --- Resource Names ---
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m # Fill these in with your actual resource names. The demo prints
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m # what it would write rather than failing if the resources do not
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m # exist; see run_demo() at the bottom.
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m CONVERSATION_STATE_TABLE      = "refill-bot-conversation-state"
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m CONVERSATION_METADATA_TABLE   = "refill-bot-conversation-metadata"
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m TOOL_CALL_LEDGER_TABLE        = "refill-bot-tool-call-ledger"
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m COSIGNATURE_QUEUE_TABLE       = "refill-bot-cosignature-queue"
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m REFILL_EVENT_BUS_NAME         = "refill-bot-events-bus"
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m AUDIT_ARCHIVE_FIREHOSE_NAME   = "refill-bot-audit-archive"
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m REFILL_EVENT_JOURNAL_BUCKET   = "refill-bot-event-journal"
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m CLOUDWATCH_NAMESPACE          = "RefillBot"
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m # Bedrock Knowledge Base ID for medication-information corpus and
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m # patient-facing protocol phrasings.
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m KNOWLEDGE_BASE_ID             = "KB_PLACEHOLDER_ID"
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m # Bedrock Guardrail for restricted-topic filtering. Configure in
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m # the Bedrock console with restricted topics for clinical-advice,
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m # dose-change-recommendation, medication-discontinuation-guidance,
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m # and controlled-substance-auto-approval at minimum. Pin to a
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m # specific version, not DRAFT, in production.
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m GUARDRAIL_ID                  = "GUARDRAIL_PLACEHOLDER_ID"
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m GUARDRAIL_VERSION             = "1"
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m # Deploy-time guardrail. Any blank resource name is a deploy-time
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m # bug, not a runtime surprise.
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m for _name, _value in [
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m     ("CONVERSATION_STATE_TABLE",     CONVERSATION_STATE_TABLE),
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m     ("CONVERSATION_METADATA_TABLE",  CONVERSATION_METADATA_TABLE),
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m     ("TOOL_CALL_LEDGER_TABLE",       TOOL_CALL_LEDGER_TABLE),
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m     ("COSIGNATURE_QUEUE_TABLE",      COSIGNATURE_QUEUE_TABLE),
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m     ("REFILL_EVENT_BUS_NAME",        REFILL_EVENT_BUS_NAME),
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m     ("AUDIT_ARCHIVE_FIREHOSE_NAME",  AUDIT_ARCHIVE_FIREHOSE_NAME),
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m     ("REFILL_EVENT_JOURNAL_BUCKET",  REFILL_EVENT_JOURNAL_BUCKET),
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m     ("CLOUDWATCH_NAMESPACE",         CLOUDWATCH_NAMESPACE),
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m     ("KNOWLEDGE_BASE_ID",            KNOWLEDGE_BASE_ID),
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m     ("GUARDRAIL_ID",                 GUARDRAIL_ID),
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m     ("GUARDRAIL_VERSION",            GUARDRAIL_VERSION),
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m ]:
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m     assert _value, f"{_name} must be set before deploying."
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m # --- Versioning ---
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m # Every conversation turn carries the model version, the prompt
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m # version, the Knowledge Base version, the Guardrail version, and
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m # (most importantly) the active refill-protocol version. This is
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m # how a future audit reconstructs which protocol authorized a
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m # particular refill action.
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m PROMPT_VERSION                = "refill-bot-prompt-v3.1"
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m AGENT_VERSION                 = "refill-agent-v2.4"
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m ACTIVE_PROTOCOL_VERSION       = "refill-protocol-v4.2"
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m INSTITUTION_ID                = "riverside-clinic"
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m INSTITUTION_DISPLAY_NAME      = "Riverside Clinic"
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m # --- Model IDs ---
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m # Two model roles. Intent classification and medication-resolution
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m # disambiguation are cheap per-turn tasks where a smaller model
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m # earns its keep. The orchestration model decides which tool to
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m # call when, with what arguments; that work benefits from a
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m # stronger model with strong tool-use support.
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m #
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m # If your region requires cross-region inference, use the inference
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m # profile ID (e.g., "us.anthropic.claude-3-5-haiku-20241022-v1:0").
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m # TODO: verify the exact model IDs available in your region and
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m # account; Bedrock model availability evolves over time.
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m INTENT_CLASSIFIER_MODEL_ID    = "anthropic.claude-3-5-haiku-20241022-v1:0"
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m ORCHESTRATION_MODEL_ID        = "anthropic.claude-3-5-sonnet-20241022-v2:0"
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m # --- Pipeline Tuning ---
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m # Below this confidence, we ask a clarifying question rather than
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m # acting on the classification. Keep this on the conservative side;
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m # better to ask than to misroute.
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m INTENT_CONFIDENCE_THRESHOLD     = Decimal("0.65")
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m # Below this confidence on medication resolution, ask the patient
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m # to clarify rather than acting on the wrong medication.
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m MED_RESOLUTION_CONFIDENCE_THRESHOLD = Decimal("0.80")
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m # Co-signature SLA. Most institutions choose 24-72 hours for
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m # asynchronous prescriber co-signature on auto-approved refills.
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m COSIGNATURE_SLA_HOURS           = 48
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m # Many institutions require authenticated sessions for any refill
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m # transmission. Set this to False to allow unauthenticated paths
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m # for refill actions (most institutions do not).
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m REQUIRE_AUTHENTICATED_FOR_REFILL = True
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m # --- Intents ---
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m REFILL_INTENTS = [
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     "request_refill",
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m     "check_refill_status",
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m     "cancel_refill_request",
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m     "medication_question",
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m # Mapping of out-of-scope intents to handoff targets.
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m OUT_OF_SCOPE_INTENTS = {
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m     "clinical_question":     "nurse_triage",
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m     "medication_change":     "nurse_triage",
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m     "scheduling_request":    "scheduling_bot",
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m     "general_question":      "faq_bot",
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m     "out_of_scope":          "live_agent",
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m # --- Identity Verification Policy ---
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m # Maps (intent, authenticated_session) to a required assurance
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m # level. Refills generally have a higher floor than scheduling.
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m # The privacy officer owns this policy in production; this Python
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m # dict is a placeholder for what is normally a versioned
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m # governance artifact stored in Parameter Store or a dedicated
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m # policy service.
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m #
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m # Assurance levels:
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m #   "authenticated": patient logged in via portal; trust the
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m #                    session-bound patient_id directly.
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m #   "basic":         name plus DOB plus one confirmation factor
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m #                    (last 4 of phone, ZIP code, or one-time code).
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m #                    Generally insufficient for refill actions
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m #                    when REQUIRE_AUTHENTICATED_FOR_REFILL is True.
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m #   "step_up":       basic plus a one-time code to a verified
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m #                    channel; used for higher-risk actions like
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m #                    early refills or controlled-substance routing.
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m IDENTITY_POLICY = {
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m     "request_refill": [
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m         (lambda ctx: ctx.get("authenticated"), "authenticated"),
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m         (lambda ctx: True, "step_up"),
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m     ],
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m     "cancel_refill_request": [
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m         (lambda ctx: ctx.get("authenticated"), "authenticated"),
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m         (lambda ctx: True, "step_up"),
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m     ],
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m     "check_refill_status": [
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m         (lambda ctx: ctx.get("authenticated"), "authenticated"),
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m         (lambda ctx: True, "basic"),
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m     ],
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m     "medication_question": [
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m         (lambda ctx: ctx.get("authenticated"), "authenticated"),
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m         (lambda ctx: True, "basic"),
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m     ],
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m ASSURANCE_MATCH_THRESHOLDS = {
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m     "authenticated": Decimal("0.0"),  # already authenticated
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m     "basic":         Decimal("0.85"),
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m     "step_up":       Decimal("0.95"),
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m # --- Refill Protocol (illustrative) ---
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m # In production this is encoded as a versioned policy artifact
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m # reviewed by clinical leadership, not as a Python dict. Each
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m # medication class has explicit auto-approval criteria, monitoring
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m # requirements, dosing rules, and exceptions. The dict below is a
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m # starter for the demo only. The protocol cleanup is the single
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m # highest-leverage operational investment for the bot's quality.
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m REFILL_PROTOCOL = {
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m     "metformin": {
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m         "class":              "biguanide",
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m         "auto_approvable":    True,
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m         "monitoring_required": "a1c_within_365_days",
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m         "monitoring_max_days": 365,
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m         "max_days_supply":    90,
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m         "early_refill_threshold_days": 7,
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m     "lisinopril": {
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m         "class":              "ace_inhibitor",
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m         "auto_approvable":    True,
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m         "monitoring_required": "creatinine_within_365_days",
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m         "monitoring_max_days": 365,
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m         "max_days_supply":    90,
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m         "early_refill_threshold_days": 7,
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m     "atorvastatin": {
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m         "class":              "statin",
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m         "auto_approvable":    True,
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m         "monitoring_required": "lipid_panel_within_365_days",
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m         "monitoring_max_days": 365,
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m         "max_days_supply":    90,
