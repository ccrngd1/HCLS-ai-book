[0m[49m[38;5;10m+     771[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     772[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     773[0m:[38;5;10m[49m     # Step 1C: persist the user's turn.
[0m[49m[38;5;10m+     774[0m:[38;5;10m[49m     _append_turn(
