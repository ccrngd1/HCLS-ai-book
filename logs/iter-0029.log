[0m[49m[38;5;10m+     844[0m:[38;5;10m[49m             "authenticated"
[0m[49m[38;5;10m+     845[0m:[38;5;10m[49m             if auth_context.get("authenticated") else None),
[0m[49m[38;5;10m+     846[0m:[38;5;10m[49m         # Versions stamped per session for audit reproducibility.
