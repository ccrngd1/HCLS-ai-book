[0m[49m[38;5;10m+    2575[0m:[38;5;10m[49m def _write_refill_journal(record: dict) -> None:
[0m[49m[38;5;10m+    2576[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2577[0m:[38;5;10m[49m     Write a durable refill-event-journal record. The journal is
