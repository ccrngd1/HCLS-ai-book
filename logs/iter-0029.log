[0m[49m[38;5;10m+     691[0m:[38;5;10m[49m             "tool":            tool,
[0m[49m[38;5;10m+     692[0m:[38;5;10m[49m             "arguments_summary": _redact_tool_args(arguments),
[0m[49m[38;5;10m+     693[0m:[38;5;10m[49m             "result_summary":  result_summary,
[0m[49m[38;5;10m+     694[0m:[38;5;10m[49m             "latency_ms":      latency_ms,
[0m[49m[38;5;10m+     695[0m:[38;5;10m[49m             "outcome":         outcome,
