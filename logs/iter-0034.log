[0m[49m[38;5;10m+     841[0m:[38;5;10m[49m **Step 1: Receive the chat message, bootstrap or resume the session, and run input safety screening.** Same primitive as the previous chapter 11 recipes. Crisis detection is especially important during intake because the bot is asking about how the patient is feeling, what medications they are taking, what their family history looks like, and how they are sleeping. Intake conversations are dense disclosure surfaces. Skip the screening and a crisis signal lands silently in the structured packet.
[0m[49m[38;5;10m+     842[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     843[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     844[0m:[38;5;10m[49m ON receive_message(channel, channel_session_id,
[0m[49m[38;5;10m+     845[0m:[38;5;10m[49m                   user_message, auth_context,
[0m[49m[38;5;10m+     846[0m:[38;5;10m[49m                   encounter_token):
[0m[49m[38;5;10m+     847[0m:[38;5;10m[49m     // Step 1A: identify or create the session.
[0m[49m[38;5;10m+     848[0m:[38;5;10m[49m     // Resume if the patient is returning to a partial
[0m[49m[38;5;10m+     849[0m:[38;5;10m[49m     // session (the partial-state table holds the
[0m[49m[38;5;10m+     850[0m:[38;5;10m[49m     // resumable conversation position).
[0m[49m[38;5;10m+     851[0m:[38;5;10m[49m     session = conversation_state_table.get_or_create({
[0m[49m[38;5;10m+     852[0m:[38;5;10m[49m         channel: channel,
[0m[49m[38;5;10m+     853[0m:[38;5;10m[49m         channel_session_id: channel_session_id,
[0m[49m[38;5;10m+     854[0m:[38;5;10m[49m         auth_context: auth_context,
[0m[49m[38;5;10m+     855[0m:[38;5;10m[49m         encounter_token: encounter_token
[0m[49m[38;5;10m+     856[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+     857[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     858[0m:[38;5;10m[49m     partial = intake_partial_state_table.get(
[0m[49m[38;5;10m+     859[0m:[38;5;10m[49m         encounter_id: session.encounter_id,
[0m[49m[38;5;10m+     860[0m:[38;5;10m[49m         patient_id: auth_context.patient_id)
[0m[49m[38;5;10m+     861[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     862[0m:[38;5;10m[49m     IF session.message_count == 0 AND partial:
[0m[49m[38;5;10m+     863[0m:[38;5;10m[49m         // Returning patient resuming a partial intake.
[0m[49m[38;5;10m+     864[0m:[38;5;10m[49m         attach_resume_greeting = true
[0m[49m[38;5;10m+     865[0m:[38;5;10m[49m         session.protocol_position = partial.protocol_position
[0m[49m[38;5;10m+     866[0m:[38;5;10m[49m         session.captured_findings = partial.captured_findings
[0m[49m[38;5;10m+     867[0m:[38;5;10m[49m     ELSE IF session.message_count == 0:
[0m[49m[38;5;10m+     868[0m:[38;5;10m[49m         // Brand-new session.
[0m[49m[38;5;10m+     869[0m:[38;5;10m[49m         attach_initial_greeting = true
[0m[49m[38;5;10m+     870[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     871[0m:[38;5;10m[49m     // Step 1B: persist the user's message.
[0m[49m[38;5;10m+     872[0m:[38;5;10m[49m     conversation_metadata_table.append_turn(
[0m[49m[38;5;10m+     873[0m:[38;5;10m[49m         session_id: session.id,
[0m[49m[38;5;10m+     874[0m:[38;5;10m[49m         turn: {
