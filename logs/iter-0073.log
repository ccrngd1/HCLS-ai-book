[0m[48;2;40;67;43m[39m+    1482[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Faithfulness score on generated note [38;2;192;197;206m|[38;2;192;197;206m n/a [38;2;192;197;206m|[38;2;192;197;206m 0.88-0.96 [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    1483[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Edit distance (draft to signed) median word fraction [38;2;192;197;206m|[38;2;192;197;206m n/a [38;2;192;197;206m|[38;2;192;197;206m 0.05-0.20 [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    1484[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Structured-extraction acceptance rate [38;2;192;197;206m|[38;2;192;197;206m n/a [38;2;192;197;206m|[38;2;192;197;206m 70-90% [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    1485[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Per-visit AWS infrastructure cost [38;2;192;197;206m|[38;2;192;197;206m n/a [38;2;192;197;206m|[38;2;192;197;206m $0.20-1.50 [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    1486[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Sustained adoption at three months [38;2;192;197;206m|[38;2;192;197;206m n/a [38;2;192;197;206m|[38;2;192;197;206m 60-85% of telehealth visits use the feature [38;2;192;197;206m|[K
