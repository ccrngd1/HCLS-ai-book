[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m │                                                           │
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m │   [Per-operational-item tracking record]                  │
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m │    - Item_id, episode_id, patient_id                      │
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m │    - Item_type (referral, appointment, test_order,        │
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m │      result_return, prior_auth, dme_delivery,             │
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m │      home_health_visit, medication_pickup, enrollment,    │
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m │      consent_signature, transportation_arrangement)       │
