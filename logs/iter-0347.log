[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m │      complexity                                           │
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m │                                                           │
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m │   [Episode definition application]                        │
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m │    - Episode-type playbook applied                        │
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m │    - Operational-items list instantiated                  │
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m │    - Expected timelines computed                          │
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m │    - Responsible parties assigned                         │
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m │    - Closed-loop tracking activated                       │
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m │                                                           │
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m │   [Episode state transitions]                             │
