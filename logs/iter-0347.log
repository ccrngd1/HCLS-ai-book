[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m └───────────────────────────────────────────────────────────┘
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m ┌────────── CHANNEL ENTRY WITH DISCLOSURE ─────────────────┐
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m │                                                           │
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m │   [Patient-initiated entry]                               │
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m │    - In-app chat                                          │
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m │    - Web chat                                             │
