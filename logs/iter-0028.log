[0m[49m[38;5;10m+    1539[0m:[38;5;10m[49m             session_id: session_id,
[0m[49m[38;5;10m+    1540[0m:[38;5;10m[49m             decision: {
[0m[49m[38;5;10m+    1541[0m:[38;5;10m[49m                 disposition:
[0m[49m[38;5;10m+    1542[0m:[38;5;10m[49m                     "route_with_clinical_question",
[0m[49m[38;5;10m+    1543[0m:[38;5;10m[49m                 rules_fired: ["eprescribe_validation_rejected"],
[0m[49m[38;5;10m+    1544[0m:[38;5;10m[49m                 data_consulted: { failure: failure },
[0m[49m[38;5;10m+    1545[0m:[38;5;10m[49m                 protocol_version: ACTIVE_PROTOCOL_VERSION
[0m[49m[38;5;10m+    1546[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    1547[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1548[0m:[38;5;10m[49m     IF failure.outcome == "transmission_error":
[0m[49m[38;5;10m+    1549[0m:[38;5;10m[49m         // Generic transmission failure. Queue for
[0m[49m[38;5;10m+    1550[0m:[38;5;10m[49m         // retry, surface to clinical, tell the
