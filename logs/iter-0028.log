[0m[49m[38;5;10m+    1573[0m:[38;5;10m[49m     // Step 9A: standard checks from recipes 11.1
[0m[49m[38;5;10m+    1574[0m:[38;5;10m[49m     // and 11.2.
[0m[49m[38;5;10m+    1575[0m:[38;5;10m[49m     standard_check = standard_output_screen.evaluate(
[0m[49m[38;5;10m+    1576[0m:[38;5;10m[49m         response: response,
[0m[49m[38;5;10m+    1577[0m:[38;5;10m[49m         session_context: session_context_for(
[0m[49m[38;5;10m+    1578[0m:[38;5;10m[49m             session_id))
[0m[49m[38;5;10m+    1579[0m:[38;5;10m[49m 
