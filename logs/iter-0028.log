[0m[49m[38;5;10m+    1590[0m:[38;5;10m[49m             find_supporting_tool_call(
[0m[49m[38;5;10m+    1591[0m:[38;5;10m[49m                 claim: claim,
[0m[49m[38;5;10m+    1592[0m:[38;5;10m[49m                 tool_call_history: tool_call_history)
[0m[49m[38;5;10m+    1593[0m:[38;5;10m[49m 
