[0m[49m[38;5;10m+    1030[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    1031[0m:[38;5;10m[49m             "classification": "premature_ventricular_complex",
[0m[49m[38;5;10m+    1032[0m:[38;5;10m[49m             "confidence": min(0.95, 0.6 + max_val * 0.1),
[0m[49m[38;5;10m+    1033[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1034[0m:[38;5;10m[49m 
