[0m[49m[38;5;10m+    1018[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1019[0m:[38;5;10m[49m     if not window:
[0m[49m[38;5;10m+    1020[0m:[38;5;10m[49m         return {"classification": "normal_sinus_rhythm", "confidence": 0.5}
[0m[49m[38;5;10m+    1021[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1022[0m:[38;5;10m[49m     # Use simple heuristics to simulate model behavior.
[0m[49m[38;5;10m+    1023[0m:[38;5;10m[49m     max_val = max(window)
[0m[49m[38;5;10m+    1024[0m:[38;5;10m[49m     min_val = min(window)
[0m[49m[38;5;10m+    1025[0m:[38;5;10m[49m     amp_range = max_val - min_val
[0m[49m[38;5;10m+    1026[0m:[38;5;10m[49m     variance = statistics.variance(window) if len(window) > 1 else 0
