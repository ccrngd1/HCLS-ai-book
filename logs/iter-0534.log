[0m[49m[38;5;10m+    1038[0m:[38;5;10m[49m             "classification": "atrial_fibrillation",
[0m[49m[38;5;10m+    1039[0m:[38;5;10m[49m             "confidence": min(0.92, 0.5 + variance * 3),
[0m[49m[38;5;10m+    1040[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1041[0m:[38;5;10m[49m 
