[0m[49m[38;5;10m+      95[0m:[38;5;10m[49m TIMESTREAM_TABLE_METRICS = "system-metrics"
[0m[49m[38;5;10m+      96[0m:[38;5;10m[49m SNS_ALERT_TOPIC_ARN = "arn:aws:sns:us-east-1:123456789012:clinical-waveform-alerts"
[0m[49m[38;5;10m+      97[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      98[0m:[38;5;10m[49m # --- Waveform Processing Parameters ---
[0m[49m[38;5;10m+      99[0m:[38;5;10m[49m # These vary by waveform type. The demo focuses on ECG Lead II.
[0m[49m[38;5;10m+     100[0m:[38;5;10m[49m WAVEFORM_CONFIG = {
[0m[49m[38;5;10m+     101[0m:[38;5;10m[49m     "ecg_lead_ii": {
[0m[49m[38;5;10m+     102[0m:[38;5;10m[49m         "sample_rate": 250,           # Hz
[0m[49m[38;5;10m+     103[0m:[38;5;10m[49m         "bandpass_low": 0.5,          # Hz (removes baseline wander)
[0m[49m[38;5;10m+     104[0m:[38;5;10m[49m         "bandpass_high": 40.0,        # Hz (removes muscle artifact, keeps morphology)
[0m[49m[38;5;10m+     105[0m:[38;5;10m[49m         "notch_freq": 60.0,           # Hz (powerline interference, 60 Hz in US)
[0m[49m[38;5;10m+     106[0m:[38;5;10m[49m         "window_seconds": 10,         # seconds per analysis window
[0m[49m[38;5;10m+     107[0m:[38;5;10m[49m         "window_overlap": 0.5,        # 50% overlap between consecutive windows
[0m[49m[38;5;10m+     108[0m:[38;5;10m[49m         "quality_threshold": 0.7,     # SQI below this = reject segment
[0m[49m[38;5;10m+     109[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+     110[0m:[38;5;10m[49m     "eeg_fp1": {
[0m[49m[38;5;10m+     111[0m:[38;5;10m[49m         "sample_rate": 256,
[0m[49m[38;5;10m+     112[0m:[38;5;10m[49m         "bandpass_low": 0.5,
[0m[49m[38;5;10m+     113[0m:[38;5;10m[49m         "bandpass_high": 50.0,
[0m[49m[38;5;10m+     114[0m:[38;5;10m[49m         "notch_freq": 60.0,
[0m[49m[38;5;10m+     115[0m:[38;5;10m[49m         "window_seconds": 30,
[0m[49m[38;5;10m+     116[0m:[38;5;10m[49m         "window_overlap": 0.5,
[0m[49m[38;5;10m+     117[0m:[38;5;10m[49m         "quality_threshold": 0.6,
[0m[49m[38;5;10m+     118[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+     119[0m:[38;5;10m[49m     "art_bp": {
[0m[49m[38;5;10m+     120[0m:[38;5;10m[49m         "sample_rate": 125,
[0m[49m[38;5;10m+     121[0m:[38;5;10m[49m         "bandpass_low": 0.1,
[0m[49m[38;5;10m+     122[0m:[38;5;10m[49m         "bandpass_high": 20.0,
[0m[49m[38;5;10m+     123[0m:[38;5;10m[49m         "notch_freq": 60.0,
[0m[49m[38;5;10m+     124[0m:[38;5;10m[49m         "window_seconds": 60,
[0m[49m[38;5;10m+     125[0m:[38;5;10m[49m         "window_overlap": 0.5,
[0m[49m[38;5;10m+     126[0m:[38;5;10m[49m         "quality_threshold": 0.65,
[0m[49m[38;5;10m+     127[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+     128[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     129[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     130[0m:[38;5;10m[49m # --- Alert Logic Parameters ---
[0m[49m[38;5;10m+     131[0m:[38;5;10m[49m # Persistence thresholds: how many consecutive windows must agree
[0m[49m[38;5;10m+     132[0m:[38;5;10m[49m # before generating an alert. Higher = fewer false alarms but
[0m[49m[38;5;10m+     133[0m:[38;5;10m[49m # slower detection. Tune per condition based on clinical urgency.
[0m[49m[38;5;10m+     134[0m:[38;5;10m[49m PERSISTENCE_THRESHOLDS = {
[0m[49m[38;5;10m+     135[0m:[38;5;10m[49m     "ventricular_tachycardia": 2,   # urgent: alert fast
[0m[49m[38;5;10m+     136[0m:[38;5;10m[49m     "ventricular_fibrillation": 1,  # critical: alert immediately
[0m[49m[38;5;10m+     137[0m:[38;5;10m[49m     "atrial_fibrillation": 5,       # less urgent: need more certainty
[0m[49m[38;5;10m+     138[0m:[38;5;10m[49m     "bradycardia": 4,
[0m[49m[38;5;10m+     139[0m:[38;5;10m[49m     "asystole": 1,                  # critical: alert immediately
[0m[49m[38;5;10m+     140[0m:[38;5;10m[49m     "premature_ventricular_complex": 8,  # only alert on frequent PVCs
[0m[49m[38;5;10m+     141[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     142[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     143[0m:[38;5;10m[49m # Confidence threshold: minimum model confidence to count toward
[0m[49m[38;5;10m+     144[0m:[38;5;10m[49m # persistence. Below this, the classification is too uncertain.
[0m[49m[38;5;10m+     145[0m:[38;5;10m[49m ALERT_CONFIDENCE_THRESHOLD = 0.75
[0m[49m[38;5;10m+     146[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     147[0m:[38;5;10m[49m # Cooldown: minutes after an alert before the same condition
[0m[49m[38;5;10m+     148[0m:[38;5;10m[49m # can re-alert for the same patient. Prevents alert storms.
[0m[49m[38;5;10m+     149[0m:[38;5;10m[49m COOLDOWN_MINUTES = {
[0m[49m[38;5;10m+     150[0m:[38;5;10m[49m     "ventricular_tachycardia": 5,
[0m[49m[38;5;10m+     151[0m:[38;5;10m[49m     "ventricular_fibrillation": 2,
[0m[49m[38;5;10m+     152[0m:[38;5;10m[49m     "atrial_fibrillation": 30,
[0m[49m[38;5;10m+     153[0m:[38;5;10m[49m     "bradycardia": 15,
[0m[49m[38;5;10m+     154[0m:[38;5;10m[49m     "premature_ventricular_complex": 60,
[0m[49m[38;5;10m+     155[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     156[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     157[0m:[38;5;10m[49m # Clinical severity levels for alert routing.
[0m[49m[38;5;10m+     158[0m:[38;5;10m[49m SEVERITY_MAP = {
[0m[49m[38;5;10m+     159[0m:[38;5;10m[49m     "ventricular_fibrillation": "CRITICAL",
[0m[49m[38;5;10m+     160[0m:[38;5;10m[49m     "asystole": "CRITICAL",
[0m[49m[38;5;10m+     161[0m:[38;5;10m[49m     "ventricular_tachycardia": "HIGH",
[0m[49m[38;5;10m+     162[0m:[38;5;10m[49m     "bradycardia": "MEDIUM",
[0m[49m[38;5;10m+     163[0m:[38;5;10m[49m     "atrial_fibrillation": "MEDIUM",
[0m[49m[38;5;10m+     164[0m:[38;5;10m[49m     "premature_ventricular_complex": "LOW",
[0m[49m[38;5;10m+     165[0m:[38;5;10m[49m     "normal_sinus_rhythm": "NONE",
[0m[49m[38;5;10m+     166[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     167[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     168[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     169[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     170[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     171[0m:[38;5;10m[49m ## Step 1: Waveform Ingestion
[0m[49m[38;5;10m+     172[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     173[0m:[38;5;10m[49m This step receives waveform samples from bedside monitors and pushes them into Kinesis for downstream processing. In production, a device integration engine handles the HL7/IEEE 11073 protocol translation. Here we simulate the ingestion of pre-digitized samples.
[0m[49m[38;5;10m+     174[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     175[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     176[0m:[38;5;10m[49m # ─────────────────────────────────────────────────────────────────────
[0m[49m[38;5;10m+     177[0m:[38;5;10m[49m # STEP 1: Ingest waveform samples into Kinesis and archive to S3.
[0m[49m[38;5;10m+     178[0m:[38;5;10m[49m # Maps to pseudocode Step 1 in the main recipe.
[0m[49m[38;5;10m+     179[0m:[38;5;10m[49m # In production, a device integration engine (e.g., Capsule Medical
[0m[49m[38;5;10m+     180[0m:[38;5;10m[49m # Device Information System, Bernoulli Health, or a custom HL7v2/
[0m[49m[38;5;10m+     181[0m:[38;5;10m[49m # IEEE 11073 adapter) translates proprietary monitor protocols into
[0m[49m[38;5;10m+     182[0m:[38;5;10m[49m # structured records and pushes them here.
[0m[49m[38;5;10m+     183[0m:[38;5;10m[49m # ─────────────────────────────────────────────────────────────────────
[0m[49m[38;5;10m+     184[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     185[0m:[38;5;10m[49m def ingest_waveform_batch(patient_id, waveform_type, timestamp,
[0m[49m[38;5;10m+     186[0m:[38;5;10m[49m                           samples, kinesis=None, s3=None):
[0m[49m[38;5;10m+     187[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     188[0m:[38;5;10m[49m     Push a batch of waveform samples to Kinesis and archive to S3.
[0m[49m[38;5;10m+     189[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     190[0m:[38;5;10m[49m     Parameters
[0m[49m[38;5;10m+     191[0m:[38;5;10m[49m     ----------
[0m[49m[38;5;10m+     192[0m:[38;5;10m[49m     patient_id : str
[0m[49m[38;5;10m+     193[0m:[38;5;10m[49m         Unique patient identifier for this ICU stay.
[0m[49m[38;5;10m+     194[0m:[38;5;10m[49m     waveform_type : str
[0m[49m[38;5;10m+     195[0m:[38;5;10m[49m         Signal type key (e.g., "ecg_lead_ii", "art_bp", "eeg_fp1").
[0m[49m[38;5;10m+     196[0m:[38;5;10m[49m     timestamp : str
[0m[49m[38;5;10m+     197[0m:[38;5;10m[49m         ISO 8601 timestamp of the first sample in this batch.
[0m[49m[38;5;10m+     198[0m:[38;5;10m[49m     samples : list[float]
[0m[49m[38;5;10m+     199[0m:[38;5;10m[49m         Raw ADC values from the bedside monitor.
[0m[49m[38;5;10m+     200[0m:[38;5;10m[49m     kinesis : mock or real Kinesis client
[0m[49m[38;5;10m+     201[0m:[38;5;10m[49m     s3 : mock or real S3 client
[0m[49m[38;5;10m+     202[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     203[0m:[38;5;10m[49m     kin = kinesis or kinesis_client
[0m[49m[38;5;10m+     204[0m:[38;5;10m[49m     s3c = s3 or s3_client
[0m[49m[38;5;10m+     205[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     206[0m:[38;5;10m[49m     config = WAVEFORM_CONFIG[waveform_type]
[0m[49m[38;5;10m+     207[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     208[0m:[38;5;10m[49m     record = {
[0m[49m[38;5;10m+     209[0m:[38;5;10m[49m         "patient_id": patient_id,
[0m[49m[38;5;10m+     210[0m:[38;5;10m[49m         "waveform_type": waveform_type,
[0m[49m[38;5;10m+     211[0m:[38;5;10m[49m         "timestamp": timestamp,
[0m[49m[38;5;10m+     212[0m:[38;5;10m[49m         "sample_rate": config["sample_rate"],
[0m[49m[38;5;10m+     213[0m:[38;5;10m[49m         "values": samples,
[0m[49m[38;5;10m+     214[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     215[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     216[0m:[38;5;10m[49m     # Kinesis partition key = patient + waveform type.
[0m[49m[38;5;10m+     217[0m:[38;5;10m[49m     # Guarantees ordering: all ECG samples from one patient
[0m[49m[38;5;10m+     218[0m:[38;5;10m[49m     # arrive in sequence within the same shard.
[0m[49m[38;5;10m+     219[0m:[38;5;10m[49m     partition_key = f"{patient_id}:{waveform_type}"
[0m[49m[38;5;10m+     220[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     221[0m:[38;5;10m[49m     kin.put_record(
[0m[49m[38;5;10m+     222[0m:[38;5;10m[49m         StreamName=KINESIS_STREAM,
[0m[49m[38;5;10m+     223[0m:[38;5;10m[49m         Data=json.dumps(record).encode("utf-8"),
[0m[49m[38;5;10m+     224[0m:[38;5;10m[49m         PartitionKey=partition_key,
[0m[49m[38;5;10m+     225[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     226[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     227[0m:[38;5;10m[49m     # Archive raw data to S3 for long-term retention, retraining,
[0m[49m[38;5;10m+     228[0m:[38;5;10m[49m     # and regulatory audit. Time-partitioned key structure enables
[0m[49m[38;5;10m+     229[0m:[38;5;10m[49m     # efficient retrieval by patient and time range.
[0m[49m[38;5;10m+     230[0m:[38;5;10m[49m     ts_parsed = datetime.fromisoformat(timestamp.replace("Z", "+00:00"))
[0m[49m[38;5;10m+     231[0m:[38;5;10m[49m     s3_key = (
[0m[49m[38;5;10m+     232[0m:[38;5;10m[49m         f"{patient_id}/{waveform_type}/"
[0m[49m[38;5;10m+     233[0m:[38;5;10m[49m         f"{ts_parsed.strftime('%Y-%m-%d')}/"
[0m[49m[38;5;10m+     234[0m:[38;5;10m[49m         f"{ts_parsed.strftime('%H')}/"
[0m[49m[38;5;10m+     235[0m:[38;5;10m[49m         f"{ts_parsed.strftime('%H%M%S')}-{uuid.uuid4().hex[:8]}.json"
[0m[49m[38;5;10m+     236[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     237[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     238[0m:[38;5;10m[49m     s3c.put_object(
[0m[49m[38;5;10m+     239[0m:[38;5;10m[49m         Bucket=S3_ARCHIVE_BUCKET,
[0m[49m[38;5;10m+     240[0m:[38;5;10m[49m         Key=s3_key,
[0m[49m[38;5;10m+     241[0m:[38;5;10m[49m         Body=json.dumps(record).encode("utf-8"),
[0m[49m[38;5;10m+     242[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     243[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     244[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+     245[0m:[38;5;10m[49m         "Ingested %d samples for %s/%s at %s",
[0m[49m[38;5;10m+     246[0m:[38;5;10m[49m         len(samples), patient_id, waveform_type, timestamp,
[0m[49m[38;5;10m+     247[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     248[0m:[38;5;10m[49m     return record
[0m[49m[38;5;10m+     249[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     250[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     251[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     252[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     253[0m:[38;5;10m[49m ## Step 2: Preprocessing and Quality Control
[0m[49m[38;5;10m+     254[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     255[0m:[38;5;10m[49m Raw waveform data is noisy. This step applies bandpass filtering, notch filtering, computes a signal quality index, and rejects segments below the quality threshold. Segments that pass are segmented into fixed-length analysis windows for the classifier.
[0m[49m[38;5;10m+     256[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     257[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     258[0m:[38;5;10m[49m # ─────────────────────────────────────────────────────────────────────
[0m[49m[38;5;10m+     259[0m:[38;5;10m[49m # STEP 2: Preprocess waveforms and gate on signal quality.
[0m[49m[38;5;10m+     260[0m:[38;5;10m[49m # Maps to pseudocode Step 2 in the main recipe.
[0m[49m[38;5;10m+     261[0m:[38;5;10m[49m # In production, this runs on ECS/Fargate containers consuming
[0m[49m[38;5;10m+     262[0m:[38;5;10m[49m # from Kinesis, not Lambda (cold starts are unacceptable for
[0m[49m[38;5;10m+     263[0m:[38;5;10m[49m # real-time waveform processing at 250 Hz).
[0m[49m[38;5;10m+     264[0m:[38;5;10m[49m # ─────────────────────────────────────────────────────────────────────
[0m[49m[38;5;10m+     265[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     266[0m:[38;5;10m[49m def apply_bandpass_filter(samples, low_hz, high_hz, sample_rate):
[0m[49m[38;5;10m+     267[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     268[0m:[38;5;10m[49m     Simplified bandpass filter using a moving-average approximation.
[0m[49m[38;5;10m+     269[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     270[0m:[38;5;10m[49m     Production replacement: scipy.signal.butter + scipy.signal.filtfilt
[0m[49m[38;5;10m+     271[0m:[38;5;10m[49m     with a 4th-order Butterworth filter. The scipy version provides
[0m[49m[38;5;10m+     272[0m:[38;5;10m[49m     proper frequency-domain characteristics and zero-phase distortion.
[0m[49m[38;5;10m+     273[0m:[38;5;10m[49m     This demo approximation removes DC offset and very high frequency
[0m[49m[38;5;10m+     274[0m:[38;5;10m[49m     noise but does not have sharp cutoff characteristics.
[0m[49m[38;5;10m+     275[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     276[0m:[38;5;10m[49m     # Remove DC offset (approximates high-pass at ~low_hz).
[0m[49m[38;5;10m+     277[0m:[38;5;10m[49m     # A real high-pass at 0.5 Hz with 250 Hz sampling needs a
[0m[49m[38;5;10m+     278[0m:[38;5;10m[49m     # filter with ~500-sample kernel. We approximate with a
[0m[49m[38;5;10m+     279[0m:[38;5;10m[49m     # simple mean subtraction per window.
[0m[49m[38;5;10m+     280[0m:[38;5;10m[49m     mean_val = statistics.mean(samples)
[0m[49m[38;5;10m+     281[0m:[38;5;10m[49m     centered = [s - mean_val for s in samples]
[0m[49m[38;5;10m+     282[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     283[0m:[38;5;10m[49m     # Simple moving average for low-pass (approximates low_hz cutoff).
[0m[49m[38;5;10m+     284[0m:[38;5;10m[49m     # Window size inversely proportional to cutoff frequency.
[0m[49m[38;5;10m+     285[0m:[38;5;10m[49m     window_size = max(1, int(sample_rate / high_hz))
[0m[49m[38;5;10m+     286[0m:[38;5;10m[49m     if window_size >= len(centered):
[0m[49m[38;5;10m+     287[0m:[38;5;10m[49m         return centered
[0m[49m[38;5;10m+     288[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     289[0m:[38;5;10m[49m     smoothed = []
[0m[49m[38;5;10m+     290[0m:[38;5;10m[49m     for i in range(len(centered)):
[0m[49m[38;5;10m+     291[0m:[38;5;10m[49m         start = max(0, i - window_size // 2)
[0m[49m[38;5;10m+     292[0m:[38;5;10m[49m         end = min(len(centered), i + window_size // 2 + 1)
[0m[49m[38;5;10m+     293[0m:[38;5;10m[49m         smoothed.append(statistics.mean(centered[start:end]))
[0m[49m[38;5;10m+     294[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     295[0m:[38;5;10m[49m     return smoothed
[0m[49m[38;5;10m+     296[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     297[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     298[0m:[38;5;10m[49m def apply_notch_filter(samples, notch_freq, sample_rate):
[0m[49m[38;5;10m+     299[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     300[0m:[38;5;10m[49m     Simplified notch filter that attenuates a specific frequency.
[0m[49m[38;5;10m+     301[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     302[0m:[38;5;10m[49m     Production replacement: scipy.signal.iirnotch + filtfilt.
[0m[49m[38;5;10m+     303[0m:[38;5;10m[49m     The real version removes 60 Hz (or 50 Hz) powerline interference
[0m[49m[38;5;10m+     304[0m:[38;5;10m[49m     with a narrow stopband that preserves surrounding frequencies.
[0m[49m[38;5;10m+     305[0m:[38;5;10m[49m     This demo just subtracts an estimated sinusoidal component.
[0m[49m[38;5;10m+     306[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     307[0m:[38;5;10m[49m     # Estimate and subtract the powerline component.
[0m[49m[38;5;10m+     308[0m:[38;5;10m[49m     # In practice, adaptive notch filters track the exact frequency
[0m[49m[38;5;10m+     309[0m:[38;5;10m[49m     # (which drifts slightly from nominal 60 Hz).
[0m[49m[38;5;10m+     310[0m:[38;5;10m[49m     n = len(samples)
[0m[49m[38;5;10m+     311[0m:[38;5;10m[49m     if n == 0:
[0m[49m[38;5;10m+     312[0m:[38;5;10m[49m         return samples
[0m[49m[38;5;10m+     313[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     314[0m:[38;5;10m[49m     # Estimate amplitude of the notch frequency component via
[0m[49m[38;5;10m+     315[0m:[38;5;10m[49m     # a simple correlation with a reference sinusoid.
[0m[49m[38;5;10m+     316[0m:[38;5;10m[49m     ref_sin = [math.sin(2 * math.pi * notch_freq * i / sample_rate)
[0m[49m[38;5;10m+     317[0m:[38;5;10m[49m                for i in range(n)]
[0m[49m[38;5;10m+     318[0m:[38;5;10m[49m     ref_cos = [math.cos(2 * math.pi * notch_freq * i / sample_rate)
[0m[49m[38;5;10m+     319[0m:[38;5;10m[49m                for i in range(n)]
[0m[49m[38;5;10m+     320[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     321[0m:[38;5;10m[49m     sin_corr = sum(s * r for s, r in zip(samples, ref_sin)) / n
[0m[49m[38;5;10m+     322[0m:[38;5;10m[49m     cos_corr = sum(s * r for s, r in zip(samples, ref_cos)) / n
[0m[49m[38;5;10m+     323[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     324[0m:[38;5;10m[49m     # Subtract the estimated interference.
[0m[49m[38;5;10m+     325[0m:[38;5;10m[49m     filtered = [
[0m[49m[38;5;10m+     326[0m:[38;5;10m[49m         samples[i] - 2 * (sin_corr * ref_sin[i] + cos_corr * ref_cos[i])
[0m[49m[38;5;10m+     327[0m:[38;5;10m[49m         for i in range(n)
[0m[49m[38;5;10m+     328[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+     329[0m:[38;5;10m[49m     return filtered
[0m[49m[38;5;10m+     330[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     331[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     332[0m:[38;5;10m[49m def compute_signal_quality_index(samples, waveform_type, sample_rate):
[0m[49m[38;5;10m+     333[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     334[0m:[38;5;10m[49m     Compute a 0-1 signal quality index combining multiple metrics.
[0m[49m[38;5;10m+     335[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     336[0m:[38;5;10m[49m     Production replacement: a multi-metric SQI that includes
[0m[49m[38;5;10m+     337[0m:[38;5;10m[49m     template-matching correlation (bSQI), spectral distribution
[0m[49m[38;5;10m+     338[0m:[38;5;10m[49m     analysis (pSQI), kurtosis (kSQI), and a learned artifact
[0m[49m[38;5;10m+     339[0m:[38;5;10m[49m     classifier trained on annotated ICU waveform segments.
[0m[49m[38;5;10m+     340[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     341[0m:[38;5;10m[49m     if not samples or len(samples) < sample_rate:
[0m[49m[38;5;10m+     342[0m:[38;5;10m[49m         return 0.0
[0m[49m[38;5;10m+     343[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     344[0m:[38;5;10m[49m     # Metric 1: Amplitude range check.
[0m[49m[38;5;10m+     345[0m:[38;5;10m[49m     # Physiological ECG is typically +/- 2 mV (ADC units vary).
[0m[49m[38;5;10m+     346[0m:[38;5;10m[49m     # Signals outside physiological bounds indicate saturation or
[0m[49m[38;5;10m+     347[0m:[38;5;10m[49m     # electrode issues.
[0m[49m[38;5;10m+     348[0m:[38;5;10m[49m     amp_range = max(samples) - min(samples)
[0m[49m[38;5;10m+     349[0m:[38;5;10m[49m     if waveform_type == "ecg_lead_ii":
[0m[49m[38;5;10m+     350[0m:[38;5;10m[49m         # Expect amplitude range between 0.5 and 5.0 mV-equivalent
[0m[49m[38;5;10m+     351[0m:[38;5;10m[49m         amp_score = 1.0 if 0.3 < amp_range < 6.0 else 0.3
[0m[49m[38;5;10m+     352[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+     353[0m:[38;5;10m[49m         amp_score = 1.0 if amp_range > 0.01 else 0.2
[0m[49m[38;5;10m+     354[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     355[0m:[38;5;10m[49m     # Metric 2: Flatline detection.
[0m[49m[38;5;10m+     356[0m:[38;5;10m[49m     # If the signal variance is near zero, the electrode is likely off.
[0m[49m[38;5;10m+     357[0m:[38;5;10m[49m     variance = statistics.variance(samples) if len(samples) > 1 else 0
[0m[49m[38;5;10m+     358[0m:[38;5;10m[49m     flatline_score = 0.1 if variance < 0.001 else 1.0
[0m[49m[38;5;10m+     359[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     360[0m:[38;5;10m[49m     # Metric 3: High-frequency noise power.
[0m[49m[38;5;10m+     361[0m:[38;5;10m[49m     # Excessive high-frequency content indicates EMG contamination
[0m[49m[38;5;10m+     362[0m:[38;5;10m[49m     # or electrical interference that the filters did not remove.
[0m[49m[38;5;10m+     363[0m:[38;5;10m[49m     # Approximate by looking at sample-to-sample differences.
[0m[49m[38;5;10m+     364[0m:[38;5;10m[49m     diffs = [abs(samples[i] - samples[i - 1])
[0m[49m[38;5;10m+     365[0m:[38;5;10m[49m              for i in range(1, len(samples))]
[0m[49m[38;5;10m+     366[0m:[38;5;10m[49m     mean_diff = statistics.mean(diffs) if diffs else 0
[0m[49m[38;5;10m+     367[0m:[38;5;10m[49m     # Normalize against expected physiological rate of change.
[0m[49m[38;5;10m+     368[0m:[38;5;10m[49m     noise_score = max(0.0, 1.0 - (mean_diff / 2.0))
[0m[49m[38;5;10m+     369[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     370[0m:[38;5;10m[49m     # Metric 4: Saturation detection.
[0m[49m[38;5;10m+     371[0m:[38;5;10m[49m     # Count samples at the extreme values (ADC clipping).
[0m[49m[38;5;10m+     372[0m:[38;5;10m[49m     if amp_range > 0:
[0m[49m[38;5;10m+     373[0m:[38;5;10m[49m         max_val = max(samples)
[0m[49m[38;5;10m+     374[0m:[38;5;10m[49m         min_val = min(samples)
[0m[49m[38;5;10m+     375[0m:[38;5;10m[49m         sat_count = sum(1 for s in samples
[0m[49m[38;5;10m+     376[0m:[38;5;10m[49m                         if abs(s - max_val) < 0.01 or abs(s - min_val) < 0.01)
[0m[49m[38;5;10m+     377[0m:[38;5;10m[49m         sat_ratio = sat_count / len(samples)
[0m[49m[38;5;10m+     378[0m:[38;5;10m[49m         sat_score = max(0.0, 1.0 - (sat_ratio * 10))
[0m[49m[38;5;10m+     379[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+     380[0m:[38;5;10m[49m         sat_score = 0.1
[0m[49m[38;5;10m+     381[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     382[0m:[38;5;10m[49m     # Combine metrics with equal weighting.
[0m[49m[38;5;10m+     383[0m:[38;5;10m[49m     # Production systems learn optimal weights from annotated data.
[0m[49m[38;5;10m+     384[0m:[38;5;10m[49m     sqi = (amp_score + flatline_score + noise_score + sat_score) / 4.0
[0m[49m[38;5;10m+     385[0m:[38;5;10m[49m     return round(min(1.0, max(0.0, sqi)), 3)
[0m[49m[38;5;10m+     386[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     387[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     388[0m:[38;5;10m[49m def segment_into_windows(samples, window_size, overlap):
[0m[49m[38;5;10m+     389[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     390[0m:[38;5;10m[49m     Split a sample array into fixed-length overlapping windows.
[0m[49m[38;5;10m+     391[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     392[0m:[38;5;10m[49m     Parameters
[0m[49m[38;5;10m+     393[0m:[38;5;10m[49m     ----------
[0m[49m[38;5;10m+     394[0m:[38;5;10m[49m     samples : list[float]
[0m[49m[38;5;10m+     395[0m:[38;5;10m[49m         Filtered waveform samples.
[0m[49m[38;5;10m+     396[0m:[38;5;10m[49m     window_size : int
[0m[49m[38;5;10m+     397[0m:[38;5;10m[49m         Number of samples per window.
[0m[49m[38;5;10m+     398[0m:[38;5;10m[49m     overlap : float
[0m[49m[38;5;10m+     399[0m:[38;5;10m[49m         Fraction of overlap between consecutive windows (0.0 to 0.9).
[0m[49m[38;5;10m+     400[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     401[0m:[38;5;10m[49m     step = int(window_size * (1.0 - overlap))
[0m[49m[38;5;10m+     402[0m:[38;5;10m[49m     if step < 1:
[0m[49m[38;5;10m+     403[0m:[38;5;10m[49m         step = 1
[0m[49m[38;5;10m+     404[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     405[0m:[38;5;10m[49m     windows = []
[0m[49m[38;5;10m+     406[0m:[38;5;10m[49m     for start in range(0, len(samples) - window_size + 1, step):
[0m[49m[38;5;10m+     407[0m:[38;5;10m[49m         windows.append(samples[start:start + window_size])
[0m[49m[38;5;10m+     408[0m:[38;5;10m[49m     return windows
[0m[49m[38;5;10m+     409[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     410[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     411[0m:[38;5;10m[49m def preprocess_waveform(raw_record):
[0m[49m[38;5;10m+     412[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     413[0m:[38;5;10m[49m     Full preprocessing pipeline: filter, score quality, segment.
[0m[49m[38;5;10m+     414[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     415[0m:[38;5;10m[49m     Returns None if the segment fails the quality gate.
[0m[49m[38;5;10m+     416[0m:[38;5;10m[49m     Returns a dict with clean windows and metadata if it passes.
[0m[49m[38;5;10m+     417[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     418[0m:[38;5;10m[49m     waveform_type = raw_record["waveform_type"]
[0m[49m[38;5;10m+     419[0m:[38;5;10m[49m     config = WAVEFORM_CONFIG[waveform_type]
[0m[49m[38;5;10m+     420[0m:[38;5;10m[49m     samples = raw_record["values"]
[0m[49m[38;5;10m+     421[0m:[38;5;10m[49m     sample_rate = config["sample_rate"]
[0m[49m[38;5;10m+     422[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     423[0m:[38;5;10m[49m     # Step 2a: Bandpass filter.
[0m[49m[38;5;10m+     424[0m:[38;5;10m[49m     filtered = apply_bandpass_filter(
[0m[49m[38;5;10m+     425[0m:[38;5;10m[49m         samples, config["bandpass_low"], config["bandpass_high"], sample_rate)
[0m[49m[38;5;10m+     426[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     427[0m:[38;5;10m[49m     # Step 2b: Notch filter for powerline interference.
[0m[49m[38;5;10m+     428[0m:[38;5;10m[49m     filtered = apply_notch_filter(filtered, config["notch_freq"], sample_rate)
[0m[49m[38;5;10m+     429[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     430[0m:[38;5;10m[49m     # Step 2c: Signal quality index.
[0m[49m[38;5;10m+     431[0m:[38;5;10m[49m     sqi = compute_signal_quality_index(filtered, waveform_type, sample_rate)
[0m[49m[38;5;10m+     432[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     433[0m:[38;5;10m[49m     # Step 2d: Quality gate.
[0m[49m[38;5;10m+     434[0m:[38;5;10m[49m     if sqi < config["quality_threshold"]:
[0m[49m[38;5;10m+     435[0m:[38;5;10m[49m         logger.info(
[0m[49m[38;5;10m+     436[0m:[38;5;10m[49m             "Quality rejection: patient=%s type=%s sqi=%.3f (threshold=%.2f)",
[0m[49m[38;5;10m+     437[0m:[38;5;10m[49m             raw_record["patient_id"], waveform_type, sqi,
[0m[49m[38;5;10m+     438[0m:[38;5;10m[49m             config["quality_threshold"],
[0m[49m[38;5;10m+     439[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     440[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+     441[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     442[0m:[38;5;10m[49m     # Step 2e: Segment into analysis windows.
[0m[49m[38;5;10m+     443[0m:[38;5;10m[49m     window_samples = int(config["window_seconds"] * sample_rate)
[0m[49m[38;5;10m+     444[0m:[38;5;10m[49m     windows = segment_into_windows(
[0m[49m[38;5;10m+     445[0m:[38;5;10m[49m         filtered, window_samples, config["window_overlap"])
[0m[49m[38;5;10m+     446[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     447[0m:[38;5;10m[49m     if not windows:
[0m[49m[38;5;10m+     448[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+     449[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     450[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     451[0m:[38;5;10m[49m         "patient_id": raw_record["patient_id"],
[0m[49m[38;5;10m+     452[0m:[38;5;10m[49m         "waveform_type": waveform_type,
[0m[49m[38;5;10m+     453[0m:[38;5;10m[49m         "timestamp": raw_record["timestamp"],
[0m[49m[38;5;10m+     454[0m:[38;5;10m[49m         "windows": windows,
[0m[49m[38;5;10m+     455[0m:[38;5;10m[49m         "sqi_score": sqi,
[0m[49m[38;5;10m+     456[0m:[38;5;10m[49m         "sample_rate": sample_rate,
[0m[49m[38;5;10m+     457[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     458[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     459[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     460[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     461[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     462[0m:[38;5;10m[49m ## Step 3: Model Inference
[0m[49m[38;5;10m+     463[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     464[0m:[38;5;10m[49m Clean waveform windows are sent to the SageMaker endpoint for classification. The model returns a rhythm label and confidence score for each window. In production, this is a trained deep learning model (CNN or transformer). The demo uses a mock classifier that simulates realistic output patterns.
[0m[49m[38;5;10m+     465[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     466[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     467[0m:[38;5;10m[49m # ─────────────────────────────────────────────────────────────────────
[0m[49m[38;5;10m+     468[0m:[38;5;10m[49m # STEP 3: Classify waveform windows via SageMaker endpoint.
[0m[49m[38;5;10m+     469[0m:[38;5;10m[49m # Maps to pseudocode Step 3 in the main recipe.
[0m[49m[38;5;10m+     470[0m:[38;5;10m[49m # In production, the endpoint hosts a trained 1D CNN or transformer
[0m[49m[38;5;10m+     471[0m:[38;5;10m[49m # model on a GPU instance (ml.g4dn.xlarge). Inference latency
[0m[49m[38;5;10m+     472[0m:[38;5;10m[49m # target: < 150 ms per window for real-time monitoring.
[0m[49m[38;5;10m+     473[0m:[38;5;10m[49m # ─────────────────────────────────────────────────────────────────────
[0m[49m[38;5;10m+     474[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     475[0m:[38;5;10m[49m def classify_waveform_windows(preprocessed, classifier=None):
[0m[49m[38;5;10m+     476[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     477[0m:[38;5;10m[49m     Send each analysis window to the classification model.
[0m[49m[38;5;10m+     478[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     479[0m:[38;5;10m[49m     Parameters
[0m[49m[38;5;10m+     480[0m:[38;5;10m[49m     ----------
[0m[49m[38;5;10m+     481[0m:[38;5;10m[49m     preprocessed : dict
[0m[49m[38;5;10m+     482[0m:[38;5;10m[49m         Output from preprocess_waveform() with clean windows.
[0m[49m[38;5;10m+     483[0m:[38;5;10m[49m     classifier : callable, optional
[0m[49m[38;5;10m+     484[0m:[38;5;10m[49m         Mock classifier for demo. Production uses sagemaker_runtime.
[0m[49m[38;5;10m+     485[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     486[0m:[38;5;10m[49m     Returns list of per-window classification results.
[0m[49m[38;5;10m+     487[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     488[0m:[38;5;10m[49m     results = []
[0m[49m[38;5;10m+     489[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     490[0m:[38;5;10m[49m     for idx, window in enumerate(preprocessed["windows"]):
[0m[49m[38;5;10m+     491[0m:[38;5;10m[49m         # In production, invoke the SageMaker endpoint:
[0m[49m[38;5;10m+     492[0m:[38;5;10m[49m         #
[0m[49m[38;5;10m+     493[0m:[38;5;10m[49m         # response = sagemaker_runtime.invoke_endpoint(
[0m[49m[38;5;10m+     494[0m:[38;5;10m[49m         #     EndpointName=SAGEMAKER_ENDPOINT,
[0m[49m[38;5;10m+     495[0m:[38;5;10m[49m         #     ContentType="application/json",
[0m[49m[38;5;10m+     496[0m:[38;5;10m[49m         #     Body=json.dumps({
[0m[49m[38;5;10m+     497[0m:[38;5;10m[49m         #         "waveform_type": preprocessed["waveform_type"],
[0m[49m[38;5;10m+     498[0m:[38;5;10m[49m         #         "sample_rate": preprocessed["sample_rate"],
[0m[49m[38;5;10m+     499[0m:[38;5;10m[49m         #         "values": window,
[0m[49m[38;5;10m+     500[0m:[38;5;10m[49m         #         "signal_quality": preprocessed["sqi_score"],
[0m[49m[38;5;10m+     501[0m:[38;5;10m[49m         #     }),
[0m[49m[38;5;10m+     502[0m:[38;5;10m[49m         # )
[0m[49m[38;5;10m+     503[0m:[38;5;10m[49m         # prediction = json.loads(response["Body"].read())
[0m[49m[38;5;10m+     504[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     505[0m:[38;5;10m[49m         # Demo: use mock classifier.
[0m[49m[38;5;10m+     506[0m:[38;5;10m[49m         if classifier:
[0m[49m[38;5;10m+     507[0m:[38;5;10m[49m             prediction = classifier(window, preprocessed["waveform_type"])
[0m[49m[38;5;10m+     508[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+     509[0m:[38;5;10m[49m             # Fallback: everything is normal sinus rhythm.
[0m[49m[38;5;10m+     510[0m:[38;5;10m[49m             prediction = {
[0m[49m[38;5;10m+     511[0m:[38;5;10m[49m                 "classification": "normal_sinus_rhythm",
[0m[49m[38;5;10m+     512[0m:[38;5;10m[49m                 "confidence": 0.95,
[0m[49m[38;5;10m+     513[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+     514[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     515[0m:[38;5;10m[49m         # Compute the timestamp for this specific window.
[0m[49m[38;5;10m+     516[0m:[38;5;10m[49m         # Each window starts at an offset from the batch timestamp.
[0m[49m[38;5;10m+     517[0m:[38;5;10m[49m         config = WAVEFORM_CONFIG[preprocessed["waveform_type"]]
[0m[49m[38;5;10m+     518[0m:[38;5;10m[49m         step_seconds = config["window_seconds"] * (1.0 - config["window_overlap"])
[0m[49m[38;5;10m+     519[0m:[38;5;10m[49m         window_offset = timedelta(seconds=idx * step_seconds)
[0m[49m[38;5;10m+     520[0m:[38;5;10m[49m         base_ts = datetime.fromisoformat(
[0m[49m[38;5;10m+     521[0m:[38;5;10m[49m             preprocessed["timestamp"].replace("Z", "+00:00"))
[0m[49m[38;5;10m+     522[0m:[38;5;10m[49m         window_ts = (base_ts + window_offset).isoformat()
[0m[49m[38;5;10m+     523[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     524[0m:[38;5;10m[49m         results.append({
[0m[49m[38;5;10m+     525[0m:[38;5;10m[49m             "window_index": idx,
[0m[49m[38;5;10m+     526[0m:[38;5;10m[49m             "classification": prediction["classification"],
[0m[49m[38;5;10m+     527[0m:[38;5;10m[49m             "confidence": prediction["confidence"],
[0m[49m[38;5;10m+     528[0m:[38;5;10m[49m             "window_timestamp": window_ts,
[0m[49m[38;5;10m+     529[0m:[38;5;10m[49m             "signal_quality": preprocessed["sqi_score"],
[0m[49m[38;5;10m+     530[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     531[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     532[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     533[0m:[38;5;10m[49m         "patient_id": preprocessed["patient_id"],
[0m[49m[38;5;10m+     534[0m:[38;5;10m[49m         "waveform_type": preprocessed["waveform_type"],
[0m[49m[38;5;10m+     535[0m:[38;5;10m[49m         "results": results,
[0m[49m[38;5;10m+     536[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     537[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     538[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     539[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     540[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     541[0m:[38;5;10m[49m ## Step 4: Post-Processing and Alert Logic
[0m[49m[38;5;10m+     542[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     543[0m:[38;5;10m[49m Raw model outputs are not clinical alerts. This step applies persistence thresholds (multiple consecutive windows must agree), checks patient context (known conditions are suppressed), enforces cooldown periods, and routes actionable alerts to SNS.
[0m[49m[38;5;10m+     544[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     545[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     546[0m:[38;5;10m[49m # ─────────────────────────────────────────────────────────────────────
[0m[49m[38;5;10m+     547[0m:[38;5;10m[49m # STEP 4: Apply clinical alert logic with suppression rules.
[0m[49m[38;5;10m+     548[0m:[38;5;10m[49m # Maps to pseudocode Step 4 in the main recipe.
[0m[49m[38;5;10m+     549[0m:[38;5;10m[49m # This is where you control your false alarm rate. Get this wrong
[0m[49m[38;5;10m+     550[0m:[38;5;10m[49m # and clinicians will disable your system within a week.
[0m[49m[38;5;10m+     551[0m:[38;5;10m[49m # ─────────────────────────────────────────────────────────────────────
[0m[49m[38;5;10m+     552[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     553[0m:[38;5;10m[49m # In-memory state for the demo. Production uses DynamoDB or Redis
[0m[49m[38;5;10m+     554[0m:[38;5;10m[49m # for cross-invocation state persistence.
[0m[49m[38;5;10m+     555[0m:[38;5;10m[49m _alert_cooldowns = {}       # {(patient_id, classification): expiry_datetime}
[0m[49m[38;5;10m+     556[0m:[38;5;10m[49m _detection_history = defaultdict(list)  # {patient_id: [recent classifications]}
[0m[49m[38;5;10m+     557[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     558[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     559[0m:[38;5;10m[49m def load_patient_context(patient_id):
[0m[49m[38;5;10m+     560[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     561[0m:[38;5;10m[49m     Load patient-specific context for alert suppression.
[0m[49m[38;5;10m+     562[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     563[0m:[38;5;10m[49m     Production replacement: query the EHR (via FHIR API or HL7 ADT
[0m[49m[38;5;10m+     564[0m:[38;5;10m[49m     feed) for active diagnoses, pacemaker status, medication list,
[0m[49m[38;5;10m+     565[0m:[38;5;10m[49m     and care team preferences. A patient with documented chronic
[0m[49m[38;5;10m+     566[0m:[38;5;10m[49m     atrial fibrillation should not receive repeated AFib alerts.
[0m[49m[38;5;10m+     567[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     568[0m:[38;5;10m[49m     # Demo: hardcoded patient contexts for illustration.
[0m[49m[38;5;10m+     569[0m:[38;5;10m[49m     known_contexts = {
[0m[49m[38;5;10m+     570[0m:[38;5;10m[49m         "ICU-BED-07": {
[0m[49m[38;5;10m+     571[0m:[38;5;10m[49m             "known_conditions": [],  # no known arrhythmias
[0m[49m[38;5;10m+     572[0m:[38;5;10m[49m             "has_pacemaker": False,
[0m[49m[38;5;10m+     573[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+     574[0m:[38;5;10m[49m         "ICU-BED-12": {
[0m[49m[38;5;10m+     575[0m:[38;5;10m[49m             "known_conditions": ["atrial_fibrillation"],  # chronic AFib
[0m[49m[38;5;10m+     576[0m:[38;5;10m[49m             "has_pacemaker": True,
[0m[49m[38;5;10m+     577[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+     578[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     579[0m:[38;5;10m[49m     return known_contexts.get(
[0m[49m[38;5;10m+     580[0m:[38;5;10m[49m         patient_id,
[0m[49m[38;5;10m+     581[0m:[38;5;10m[49m         {"known_conditions": [], "has_pacemaker": False},
[0m[49m[38;5;10m+     582[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     583[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     584[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     585[0m:[38;5;10m[49m def is_in_cooldown(patient_id, classification):
[0m[49m[38;5;10m+     586[0m:[38;5;10m[49m     """Check if this patient/condition pair is in cooldown."""
[0m[49m[38;5;10m+     587[0m:[38;5;10m[49m     key = (patient_id, classification)
[0m[49m[38;5;10m+     588[0m:[38;5;10m[49m     if key in _alert_cooldowns:
[0m[49m[38;5;10m+     589[0m:[38;5;10m[49m         if datetime.now(timezone.utc) < _alert_cooldowns[key]:
[0m[49m[38;5;10m+     590[0m:[38;5;10m[49m             return True
[0m[49m[38;5;10m+     591[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+     592[0m:[38;5;10m[49m             del _alert_cooldowns[key]
[0m[49m[38;5;10m+     593[0m:[38;5;10m[49m     return False
[0m[49m[38;5;10m+     594[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     595[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     596[0m:[38;5;10m[49m def set_cooldown(patient_id, classification):
[0m[49m[38;5;10m+     597[0m:[38;5;10m[49m     """Set cooldown after generating an alert."""
[0m[49m[38;5;10m+     598[0m:[38;5;10m[49m     minutes = COOLDOWN_MINUTES.get(classification, 15)
[0m[49m[38;5;10m+     599[0m:[38;5;10m[49m     key = (patient_id, classification)
[0m[49m[38;5;10m+     600[0m:[38;5;10m[49m     _alert_cooldowns[key] = (
[0m[49m[38;5;10m+     601[0m:[38;5;10m[49m         datetime.now(timezone.utc) + timedelta(minutes=minutes))
[0m[49m[38;5;10m+     602[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     603[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     604[0m:[38;5;10m[49m def count_consecutive(results, classification, min_confidence):
[0m[49m[38;5;10m+     605[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     606[0m:[38;5;10m[49m     Count the longest run of consecutive windows matching the
[0m[49m[38;5;10m+     607[0m:[38;5;10m[49m     given classification at or above the confidence threshold.
[0m[49m[38;5;10m+     608[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     609[0m:[38;5;10m[49m     max_run = 0
[0m[49m[38;5;10m+     610[0m:[38;5;10m[49m     current_run = 0
[0m[49m[38;5;10m+     611[0m:[38;5;10m[49m     for r in results:
[0m[49m[38;5;10m+     612[0m:[38;5;10m[49m         if (r["classification"] == classification
[0m[49m[38;5;10m+     613[0m:[38;5;10m[49m                 and r["confidence"] >= min_confidence):
[0m[49m[38;5;10m+     614[0m:[38;5;10m[49m             current_run += 1
[0m[49m[38;5;10m+     615[0m:[38;5;10m[49m             max_run = max(max_run, current_run)
[0m[49m[38;5;10m+     616[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+     617[0m:[38;5;10m[49m             current_run = 0
[0m[49m[38;5;10m+     618[0m:[38;5;10m[49m     return max_run
[0m[49m[38;5;10m+     619[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     620[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     621[0m:[38;5;10m[49m def apply_alert_logic(classification_results, sns=None):
[0m[49m[38;5;10m+     622[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     623[0m:[38;5;10m[49m     Apply persistence, suppression, and cooldown rules.
[0m[49m[38;5;10m+     624[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     625[0m:[38;5;10m[49m     Returns a list of generated alerts (may be empty).
[0m[49m[38;5;10m+     626[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     627[0m:[38;5;10m[49m     patient_id = classification_results["patient_id"]
[0m[49m[38;5;10m+     628[0m:[38;5;10m[49m     results = classification_results["results"]
[0m[49m[38;5;10m+     629[0m:[38;5;10m[49m     context = load_patient_context(patient_id)
[0m[49m[38;5;10m+     630[0m:[38;5;10m[49m     alerts_generated = []
[0m[49m[38;5;10m+     631[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     632[0m:[38;5;10m[49m     # Find all unique non-normal classifications in this batch.
[0m[49m[38;5;10m+     633[0m:[38;5;10m[49m     unique_classes = set(
[0m[49m[38;5;10m+     634[0m:[38;5;10m[49m         r["classification"] for r in results
[0m[49m[38;5;10m+     635[0m:[38;5;10m[49m         if r["classification"] != "normal_sinus_rhythm"
[0m[49m[38;5;10m+     636[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     637[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     638[0m:[38;5;10m[49m     for classification in unique_classes:
[0m[49m[38;5;10m+     639[0m:[38;5;10m[49m         # Count consecutive high-confidence detections.
[0m[49m[38;5;10m+     640[0m:[38;5;10m[49m         consecutive = count_consecutive(
[0m[49m[38;5;10m+     641[0m:[38;5;10m[49m             results, classification, ALERT_CONFIDENCE_THRESHOLD)
[0m[49m[38;5;10m+     642[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     643[0m:[38;5;10m[49m         # Check persistence threshold.
[0m[49m[38;5;10m+     644[0m:[38;5;10m[49m         threshold = PERSISTENCE_THRESHOLDS.get(classification, 6)
[0m[49m[38;5;10m+     645[0m:[38;5;10m[49m         if consecutive < threshold:
[0m[49m[38;5;10m+     646[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     647[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     648[0m:[38;5;10m[49m         # Check suppression: known conditions.
[0m[49m[38;5;10m+     649[0m:[38;5;10m[49m         if classification in context["known_conditions"]:
[0m[49m[38;5;10m+     650[0m:[38;5;10m[49m             logger.info(
[0m[49m[38;5;10m+     651[0m:[38;5;10m[49m                 "Suppressed alert: patient=%s condition=%s reason=known_condition",
[0m[49m[38;5;10m+     652[0m:[38;5;10m[49m                 patient_id, classification,
[0m[49m[38;5;10m+     653[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+     654[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     655[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     656[0m:[38;5;10m[49m         # Check cooldown.
[0m[49m[38;5;10m+     657[0m:[38;5;10m[49m         if is_in_cooldown(patient_id, classification):
[0m[49m[38;5;10m+     658[0m:[38;5;10m[49m             logger.info(
[0m[49m[38;5;10m+     659[0m:[38;5;10m[49m                 "Suppressed alert: patient=%s condition=%s reason=cooldown",
[0m[49m[38;5;10m+     660[0m:[38;5;10m[49m                 patient_id, classification,
[0m[49m[38;5;10m+     661[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+     662[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     663[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     664[0m:[38;5;10m[49m         # Generate alert.
[0m[49m[38;5;10m+     665[0m:[38;5;10m[49m         matching = [r for r in results
[0m[49m[38;5;10m+     666[0m:[38;5;10m[49m                     if r["classification"] == classification
[0m[49m[38;5;10m+     667[0m:[38;5;10m[49m                     and r["confidence"] >= ALERT_CONFIDENCE_THRESHOLD]
[0m[49m[38;5;10m+     668[0m:[38;5;10m[49m         avg_confidence = statistics.mean(r["confidence"] for r in matching)
[0m[49m[38;5;10m+     669[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     670[0m:[38;5;10m[49m         alert = {
[0m[49m[38;5;10m+     671[0m:[38;5;10m[49m             "alert_id": str(uuid.uuid4()),
[0m[49m[38;5;10m+     672[0m:[38;5;10m[49m             "patient_id": patient_id,
[0m[49m[38;5;10m+     673[0m:[38;5;10m[49m             "classification": classification,
[0m[49m[38;5;10m+     674[0m:[38;5;10m[49m             "severity": SEVERITY_MAP.get(classification, "MEDIUM"),
[0m[49m[38;5;10m+     675[0m:[38;5;10m[49m             "confidence": round(avg_confidence, 3),
[0m[49m[38;5;10m+     676[0m:[38;5;10m[49m             "consecutive_windows": consecutive,
[0m[49m[38;5;10m+     677[0m:[38;5;10m[49m             "onset_time": matching[0]["window_timestamp"],
[0m[49m[38;5;10m+     678[0m:[38;5;10m[49m             "generated_at": datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+     679[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+     680[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     681[0m:[38;5;10m[49m         # Publish to SNS.
[0m[49m[38;5;10m+     682[0m:[38;5;10m[49m         sns_client_to_use = sns or sns_client
[0m[49m[38;5;10m+     683[0m:[38;5;10m[49m         sns_client_to_use.publish(
[0m[49m[38;5;10m+     684[0m:[38;5;10m[49m             TopicArn=SNS_ALERT_TOPIC_ARN,
[0m[49m[38;5;10m+     685[0m:[38;5;10m[49m             Message=json.dumps(alert),
[0m[49m[38;5;10m+     686[0m:[38;5;10m[49m             MessageAttributes={
[0m[49m[38;5;10m+     687[0m:[38;5;10m[49m                 "severity": {
[0m[49m[38;5;10m+     688[0m:[38;5;10m[49m                     "DataType": "String",
[0m[49m[38;5;10m+     689[0m:[38;5;10m[49m                     "StringValue": alert["severity"],
[0m[49m[38;5;10m+     690[0m:[38;5;10m[49m                 },
[0m[49m[38;5;10m+     691[0m:[38;5;10m[49m                 "patient_id": {
[0m[49m[38;5;10m+     692[0m:[38;5;10m[49m                     "DataType": "String",
[0m[49m[38;5;10m+     693[0m:[38;5;10m[49m                     "StringValue": patient_id,
[0m[49m[38;5;10m+     694[0m:[38;5;10m[49m                 },
[0m[49m[38;5;10m+     695[0m:[38;5;10m[49m                 "condition": {
[0m[49m[38;5;10m+     696[0m:[38;5;10m[49m                     "DataType": "String",
[0m[49m[38;5;10m+     697[0m:[38;5;10m[49m                     "StringValue": classification,
[0m[49m[38;5;10m+     698[0m:[38;5;10m[49m                 },
[0m[49m[38;5;10m+     699[0m:[38;5;10m[49m             },
[0m[49m[38;5;10m+     700[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     701[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     702[0m:[38;5;10m[49m         # Set cooldown.
[0m[49m[38;5;10m+     703[0m:[38;5;10m[49m         set_cooldown(patient_id, classification)
[0m[49m[38;5;10m+     704[0m:[38;5;10m[49m         alerts_generated.append(alert)
[0m[49m[38;5;10m+     705[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     706[0m:[38;5;10m[49m         logger.info(
[0m[49m[38;5;10m+     707[0m:[38;5;10m[49m             "ALERT generated: patient=%s condition=%s severity=%s confidence=%.3f",
[0m[49m[38;5;10m+     708[0m:[38;5;10m[49m             patient_id, classification, alert["severity"], avg_confidence,
[0m[49m[38;5;10m+     709[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     710[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     711[0m:[38;5;10m[49m     return alerts_generated
[0m[49m[38;5;10m+     712[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     713[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     714[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     715[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     716[0m:[38;5;10m[49m ## Step 5: Store Results
[0m[49m[38;5;10m+     717[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     718[0m:[38;5;10m[49m Every classification (alerting and non-alerting) is stored in Timestream for retrospective analysis, model performance monitoring, and clinical research. System-level metrics (quality rejection rates, alert rates, latency) go to a separate metrics table.
[0m[49m[38;5;10m+     719[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     720[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     721[0m:[38;5;10m[49m # ─────────────────────────────────────────────────────────────────────
[0m[49m[38;5;10m+     722[0m:[38;5;10m[49m # STEP 5: Store all classifications and metrics to Timestream.
[0m[49m[38;5;10m+     723[0m:[38;5;10m[49m # Maps to pseudocode Step 5 in the main recipe.
[0m[49m[38;5;10m+     724[0m:[38;5;10m[49m # Timestream's time-partitioned storage makes "last N hours"
[0m[49m[38;5;10m+     725[0m:[38;5;10m[49m # queries fast for clinical review and operational dashboards.
[0m[49m[38;5;10m+     726[0m:[38;5;10m[49m # ─────────────────────────────────────────────────────────────────────
[0m[49m[38;5;10m+     727[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     728[0m:[38;5;10m[49m def store_classifications(classification_results, alerts_generated,
[0m[49m[38;5;10m+     729[0m:[38;5;10m[49m                           timestream=None):
[0m[49m[38;5;10m+     730[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     731[0m:[38;5;10m[49m     Write all per-window classifications to Timestream.
[0m[49m[38;5;10m+     732[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     733[0m:[38;5;10m[49m     Parameters
[0m[49m[38;5;10m+     734[0m:[38;5;10m[49m     ----------
[0m[49m[38;5;10m+     735[0m:[38;5;10m[49m     classification_results : dict
[0m[49m[38;5;10m+     736[0m:[38;5;10m[49m         Output from classify_waveform_windows().
[0m[49m[38;5;10m+     737[0m:[38;5;10m[49m     alerts_generated : list
[0m[49m[38;5;10m+     738[0m:[38;5;10m[49m         Output from apply_alert_logic().
[0m[49m[38;5;10m+     739[0m:[38;5;10m[49m     timestream : mock or real Timestream write client.
[0m[49m[38;5;10m+     740[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     741[0m:[38;5;10m[49m     ts = timestream  # mock for demo
[0m[49m[38;5;10m+     742[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     743[0m:[38;5;10m[49m     patient_id = classification_results["patient_id"]
[0m[49m[38;5;10m+     744[0m:[38;5;10m[49m     waveform_type = classification_results["waveform_type"]
[0m[49m[38;5;10m+     745[0m:[38;5;10m[49m     alert_ids = {a["classification"] for a in alerts_generated}
[0m[49m[38;5;10m+     746[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     747[0m:[38;5;10m[49m     records = []
[0m[49m[38;5;10m+     748[0m:[38;5;10m[49m     for result in classification_results["results"]:
[0m[49m[38;5;10m+     749[0m:[38;5;10m[49m         records.append({
[0m[49m[38;5;10m+     750[0m:[38;5;10m[49m             "Dimensions": [
[0m[49m[38;5;10m+     751[0m:[38;5;10m[49m                 {"Name": "patient_id", "Value": patient_id},
[0m[49m[38;5;10m+     752[0m:[38;5;10m[49m                 {"Name": "waveform_type", "Value": waveform_type},
[0m[49m[38;5;10m+     753[0m:[38;5;10m[49m                 {"Name": "classification", "Value": result["classification"]},
[0m[49m[38;5;10m+     754[0m:[38;5;10m[49m             ],
[0m[49m[38;5;10m+     755[0m:[38;5;10m[49m             "MeasureName": "classification_metrics",
[0m[49m[38;5;10m+     756[0m:[38;5;10m[49m             "MeasureValueType": "MULTI",
[0m[49m[38;5;10m+     757[0m:[38;5;10m[49m             "MeasureValues": [
[0m[49m[38;5;10m+     758[0m:[38;5;10m[49m                 {"Name": "confidence", "Value": str(result["confidence"]),
[0m[49m[38;5;10m+     759[0m:[38;5;10m[49m                  "Type": "DOUBLE"},
[0m[49m[38;5;10m+     760[0m:[38;5;10m[49m                 {"Name": "signal_quality", "Value": str(result["signal_quality"]),
[0m[49m[38;5;10m+     761[0m:[38;5;10m[49m                  "Type": "DOUBLE"},
[0m[49m[38;5;10m+     762[0m:[38;5;10m[49m                 {"Name": "alerted", "Value": str(
[0m[49m[38;5;10m+     763[0m:[38;5;10m[49m                     1 if result["classification"] in alert_ids else 0),
[0m[49m[38;5;10m+     764[0m:[38;5;10m[49m                  "Type": "BIGINT"},
[0m[49m[38;5;10m+     765[0m:[38;5;10m[49m             ],
[0m[49m[38;5;10m+     766[0m:[38;5;10m[49m             "Time": result["window_timestamp"],
[0m[49m[38;5;10m+     767[0m:[38;5;10m[49m             "TimeUnit": "MILLISECONDS",
[0m[49m[38;5;10m+     768[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     769[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     770[0m:[38;5;10m[49m     # Timestream accepts batches of up to 100 records.
[0m[49m[38;5;10m+     771[0m:[38;5;10m[49m     if ts:
[0m[49m[38;5;10m+     772[0m:[38;5;10m[49m         for i in range(0, len(records), 100):
[0m[49m[38;5;10m+     773[0m:[38;5;10m[49m             batch = records[i:i + 100]
[0m[49m[38;5;10m+     774[0m:[38;5;10m[49m             ts.write_records(
[0m[49m[38;5;10m+     775[0m:[38;5;10m[49m                 DatabaseName=TIMESTREAM_DB,
[0m[49m[38;5;10m+     776[0m:[38;5;10m[49m                 TableName=TIMESTREAM_TABLE_CLASSIFICATIONS,
[0m[49m[38;5;10m+     777[0m:[38;5;10m[49m                 Records=batch,
[0m[49m[38;5;10m+     778[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+     779[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+     780[0m:[38;5;10m[49m         logger.info(
[0m[49m[38;5;10m+     781[0m:[38;5;10m[49m             "Would write %d classification records to Timestream", len(records))
[0m[49m[38;5;10m+     782[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     783[0m:[38;5;10m[49m     return len(records)
[0m[49m[38;5;10m+     784[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     785[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     786[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     787[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     788[0m:[38;5;10m[49m ## Full Pipeline
[0m[49m[38;5;10m+     789[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     790[0m:[38;5;10m[49m Assembles all steps into a single callable function and runs the demo on synthetic ECG data.
[0m[49m[38;5;10m+     791[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     792[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     793[0m:[38;5;10m[49m # ─────────────────────────────────────────────────────────────────────
[0m[49m[38;5;10m+     794[0m:[38;5;10m[49m # FULL PIPELINE: End-to-end waveform analysis from ingestion to alert.
[0m[49m[38;5;10m+     795[0m:[38;5;10m[49m # ─────────────────────────────────────────────────────────────────────
[0m[49m[38;5;10m+     796[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     797[0m:[38;5;10m[49m def run_pipeline(raw_record, classifier=None, sns=None, timestream=None,
[0m[49m[38;5;10m+     798[0m:[38;5;10m[49m                  kinesis=None, s3=None):
[0m[49m[38;5;10m+     799[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     800[0m:[38;5;10m[49m     Run the complete waveform analysis pipeline on a single batch.
[0m[49m[38;5;10m+     801[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     802[0m:[38;5;10m[49m     Returns a dict summarizing what happened: classifications,
[0m[49m[38;5;10m+     803[0m:[38;5;10m[49m     alerts generated, and records stored.
[0m[49m[38;5;10m+     804[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     805[0m:[38;5;10m[49m     print(f"\n{'='*60}")
[0m[49m[38;5;10m+     806[0m:[38;5;10m[49m     print(f"  Processing: {raw_record['patient_id']} / "
[0m[49m[38;5;10m+     807[0m:[38;5;10m[49m           f"{raw_record['waveform_type']}")
[0m[49m[38;5;10m+     808[0m:[38;5;10m[49m     print(f"  Timestamp:  {raw_record['timestamp']}")
[0m[49m[38;5;10m+     809[0m:[38;5;10m[49m     print(f"  Samples:    {len(raw_record['values'])}")
[0m[49m[38;5;10m+     810[0m:[38;5;10m[49m     print(f"{'='*60}")
[0m[49m[38;5;10m+     811[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     812[0m:[38;5;10m[49m     # Step 1: Ingest (archive to S3, push to Kinesis).
[0m[49m[38;5;10m+     813[0m:[38;5;10m[49m     ingest_waveform_batch(
[0m[49m[38;5;10m+     814[0m:[38;5;10m[49m         raw_record["patient_id"],
[0m[49m[38;5;10m+     815[0m:[38;5;10m[49m         raw_record["waveform_type"],
[0m[49m[38;5;10m+     816[0m:[38;5;10m[49m         raw_record["timestamp"],
[0m[49m[38;5;10m+     817[0m:[38;5;10m[49m         raw_record["values"],
[0m[49m[38;5;10m+     818[0m:[38;5;10m[49m         kinesis=kinesis,
[0m[49m[38;5;10m+     819[0m:[38;5;10m[49m         s3=s3,
[0m[49m[38;5;10m+     820[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     821[0m:[38;5;10m[49m     print("  [Step 1] Ingested and archived.")
[0m[49m[38;5;10m+     822[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     823[0m:[38;5;10m[49m     # Step 2: Preprocess.
[0m[49m[38;5;10m+     824[0m:[38;5;10m[49m     preprocessed = preprocess_waveform(raw_record)
[0m[49m[38;5;10m+     825[0m:[38;5;10m[49m     if preprocessed is None:
[0m[49m[38;5;10m+     826[0m:[38;5;10m[49m         print("  [Step 2] REJECTED: signal quality below threshold.")
[0m[49m[38;5;10m+     827[0m:[38;5;10m[49m         return {"status": "rejected", "reason": "quality_gate"}
[0m[49m[38;5;10m+     828[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     829[0m:[38;5;10m[49m     print(f"  [Step 2] Preprocessed: SQI={preprocessed['sqi_score']:.3f}, "
[0m[49m[38;5;10m+     830[0m:[38;5;10m[49m           f"windows={len(preprocessed['windows'])}")
[0m[49m[38;5;10m+     831[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     832[0m:[38;5;10m[49m     # Step 3: Classify.
[0m[49m[38;5;10m+     833[0m:[38;5;10m[49m     classification_results = classify_waveform_windows(
[0m[49m[38;5;10m+     834[0m:[38;5;10m[49m         preprocessed, classifier=classifier)
[0m[49m[38;5;10m+     835[0m:[38;5;10m[49m     class_summary = defaultdict(int)
[0m[49m[38;5;10m+     836[0m:[38;5;10m[49m     for r in classification_results["results"]:
[0m[49m[38;5;10m+     837[0m:[38;5;10m[49m         class_summary[r["classification"]] += 1
[0m[49m[38;5;10m+     838[0m:[38;5;10m[49m     print(f"  [Step 3] Classified: {dict(class_summary)}")
[0m[49m[38;5;10m+     839[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     840[0m:[38;5;10m[49m     # Step 4: Alert logic.
[0m[49m[38;5;10m+     841[0m:[38;5;10m[49m     alerts = apply_alert_logic(classification_results, sns=sns)
[0m[49m[38;5;10m+     842[0m:[38;5;10m[49m     if alerts:
[0m[49m[38;5;10m+     843[0m:[38;5;10m[49m         for a in alerts:
[0m[49m[38;5;10m+     844[0m:[38;5;10m[49m             print(f"  [Step 4] ALERT: {a['classification']} "
[0m[49m[38;5;10m+     845[0m:[38;5;10m[49m                   f"(severity={a['severity']}, confidence={a['confidence']:.3f})")
[0m[49m[38;5;10m+     846[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+     847[0m:[38;5;10m[49m         print("  [Step 4] No alerts generated.")
[0m[49m[38;5;10m+     848[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     849[0m:[38;5;10m[49m     # Step 5: Store.
[0m[49m[38;5;10m+     850[0m:[38;5;10m[49m     records_stored = store_classifications(
[0m[49m[38;5;10m+     851[0m:[38;5;10m[49m         classification_results, alerts, timestream=timestream)
[0m[49m[38;5;10m+     852[0m:[38;5;10m[49m     print(f"  [Step 5] Stored {records_stored} records.")
[0m[49m[38;5;10m+     853[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     854[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     855[0m:[38;5;10m[49m         "status": "processed",
[0m[49m[38;5;10m+     856[0m:[38;5;10m[49m         "sqi": preprocessed["sqi_score"],
[0m[49m[38;5;10m+     857[0m:[38;5;10m[49m         "windows_classified": len(classification_results["results"]),
[0m[49m[38;5;10m+     858[0m:[38;5;10m[49m         "classifications": dict(class_summary),
[0m[49m[38;5;10m+     859[0m:[38;5;10m[49m         "alerts": alerts,
[0m[49m[38;5;10m+     860[0m:[38;5;10m[49m         "records_stored": records_stored,
[0m[49m[38;5;10m+     861[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     862[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     863[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     864[0m:[38;5;10m[49m # ─────────────────────────────────────────────────────────────────────
[0m[49m[38;5;10m+     865[0m:[38;5;10m[49m # MOCK INFRASTRUCTURE AND SYNTHETIC DATA
[0m[49m[38;5;10m+     866[0m:[38;5;10m[49m # ─────────────────────────────────────────────────────────────────────
[0m[49m[38;5;10m+     867[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     868[0m:[38;5;10m[49m class MockKinesisStream:
[0m[49m[38;5;10m+     869[0m:[38;5;10m[49m     """Captures put_record calls without a real Kinesis stream."""
[0m[49m[38;5;10m+     870[0m:[38;5;10m[49m     def __init__(self):
[0m[49m[38;5;10m+     871[0m:[38;5;10m[49m         self.records = []
[0m[49m[38;5;10m+     872[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     873[0m:[38;5;10m[49m     def put_record(self, **kwargs):
[0m[49m[38;5;10m+     874[0m:[38;5;10m[49m         self.records.append(kwargs)
[0m[49m[38;5;10m+     875[0m:[38;5;10m[49m         return {"ShardId": "shard-0", "SequenceNumber": str(len(self.records))}
[0m[49m[38;5;10m+     876[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     877[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     878[0m:[38;5;10m[49m class MockS3:
[0m[49m[38;5;10m+     879[0m:[38;5;10m[49m     """Captures put_object calls without a real S3 bucket."""
[0m[49m[38;5;10m+     880[0m:[38;5;10m[49m     def __init__(self):
[0m[49m[38;5;10m+     881[0m:[38;5;10m[49m         self.objects = {}
[0m[49m[38;5;10m+     882[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     883[0m:[38;5;10m[49m     def put_object(self, **kwargs):
[0m[49m[38;5;10m+     884[0m:[38;5;10m[49m         self.objects[kwargs["Key"]] = kwargs["Body"]
[0m[49m[38;5;10m+     885[0m:[38;5;10m[49m         return {"ETag": f"\"{uuid.uuid4().hex}\""}
[0m[49m[38;5;10m+     886[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     887[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     888[0m:[38;5;10m[49m class MockSNS:
[0m[49m[38;5;10m+     889[0m:[38;5;10m[49m     """Captures publish calls without a real SNS topic."""
[0m[49m[38;5;10m+     890[0m:[38;5;10m[49m     def __init__(self):
[0m[49m[38;5;10m+     891[0m:[38;5;10m[49m         self.messages = []
[0m[49m[38;5;10m+     892[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     893[0m:[38;5;10m[49m     def publish(self, **kwargs):
[0m[49m[38;5;10m+     894[0m:[38;5;10m[49m         self.messages.append(kwargs)
[0m[49m[38;5;10m+     895[0m:[38;5;10m[49m         return {"MessageId": str(uuid.uuid4())}
[0m[49m[38;5;10m+     896[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     897[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     898[0m:[38;5;10m[49m class MockTimestream:
[0m[49m[38;5;10m+     899[0m:[38;5;10m[49m     """Captures write_records calls without a real Timestream DB."""
