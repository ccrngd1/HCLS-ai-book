[0m[49m[38;5;10m+      80[0m:[38;5;10m[49m s3_client = boto3.client(
[0m[49m[38;5;10m+      81[0m:[38;5;10m[49m     "s3", region_name=REGION, config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+      82[0m:[38;5;10m[49m sagemaker_runtime = boto3.client(
[0m[49m[38;5;10m+      83[0m:[38;5;10m[49m     "sagemaker-runtime", region_name=REGION, config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+      84[0m:[38;5;10m[49m sns_client = boto3.client(
[0m[49m[38;5;10m+      85[0m:[38;5;10m[49m     "sns", region_name=REGION, config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+      86[0m:[38;5;10m[49m cloudwatch_client = boto3.client(
