[0m[49m[38;5;10m+      88[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      89[0m:[38;5;10m[49m # --- Resource Names ---
[0m[49m[38;5;10m+      90[0m:[38;5;10m[49m KINESIS_STREAM = "waveform-ingestion"
[0m[49m[38;5;10m+      91[0m:[38;5;10m[49m S3_ARCHIVE_BUCKET = "waveform-archive"
[0m[49m[38;5;10m+      92[0m:[38;5;10m[49m SAGEMAKER_ENDPOINT = "ecg-rhythm-classifier-v2"
[0m[49m[38;5;10m+      93[0m:[38;5;10m[49m TIMESTREAM_DB = "waveform-analytics"
