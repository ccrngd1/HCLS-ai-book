[0m[49m[38;5;10m+     908[0m:[38;5;10m[49m def generate_synthetic_ecg(duration_seconds, sample_rate, scenario="normal"):
[0m[49m[38;5;10m+     909[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     910[0m:[38;5;10m[49m     Generate synthetic ECG-like waveform data for demonstration.
[0m[49m[38;5;10m+     911[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     912[0m:[38;5;10m[49m     This is NOT a physiologically accurate ECG simulator. It produces
[0m[49m[38;5;10m+     913[0m:[38;5;10m[49m     a signal with periodic peaks (simulating QRS complexes) at a
[0m[49m[38;5;10m+     914[0m:[38;5;10m[49m     plausible heart rate, with noise and optional injected abnormalities.
[0m[49m[38;5;10m+     915[0m:[38;5;10m[49m     Real ECG simulators (e.g., ECGSYN from PhysioNet) produce much
[0m[49m[38;5;10m+     916[0m:[38;5;10m[49m     more realistic waveforms.
[0m[49m[38;5;10m+     917[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     918[0m:[38;5;10m[49m     Parameters
[0m[49m[38;5;10m+     919[0m:[38;5;10m[49m     ----------
[0m[49m[38;5;10m+     920[0m:[38;5;10m[49m     duration_seconds : int
[0m[49m[38;5;10m+     921[0m:[38;5;10m[49m         Length of the synthetic recording.
[0m[49m[38;5;10m+     922[0m:[38;5;10m[49m     sample_rate : int
[0m[49m[38;5;10m+     923[0m:[38;5;10m[49m         Samples per second.
[0m[49m[38;5;10m+     924[0m:[38;5;10m[49m     scenario : str
[0m[49m[38;5;10m+     925[0m:[38;5;10m[49m         "normal" = regular sinus rhythm
[0m[49m[38;5;10m+     926[0m:[38;5;10m[49m         "pvc" = normal with occasional PVCs
[0m[49m[38;5;10m+     927[0m:[38;5;10m[49m         "afib" = irregular rhythm simulating atrial fibrillation
[0m[49m[38;5;10m+     928[0m:[38;5;10m[49m         "noisy" = normal rhythm with heavy artifact contamination
[0m[49m[38;5;10m+     929[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     930[0m:[38;5;10m[49m     n_samples = duration_seconds * sample_rate
[0m[49m[38;5;10m+     931[0m:[38;5;10m[49m     samples = []
[0m[49m[38;5;10m+     932[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     933[0m:[38;5;10m[49m     if scenario == "normal":
[0m[49m[38;5;10m+     934[0m:[38;5;10m[49m         # Regular sinus rhythm at ~72 bpm.
[0m[49m[38;5;10m+     935[0m:[38;5;10m[49m         beat_interval = sample_rate * 60 // 72  # samples between beats
[0m[49m[38;5;10m+     936[0m:[38;5;10m[49m         for i in range(n_samples):
[0m[49m[38;5;10m+     937[0m:[38;5;10m[49m             phase = i % beat_interval
[0m[49m[38;5;10m+     938[0m:[38;5;10m[49m             # Simulate QRS complex as a sharp peak.
[0m[49m[38;5;10m+     939[0m:[38;5;10m[49m             if beat_interval * 0.3 < phase < beat_interval * 0.35:
[0m[49m[38;5;10m+     940[0m:[38;5;10m[49m                 samples.append(1.5 + random.gauss(0, 0.05))
[0m[49m[38;5;10m+     941[0m:[38;5;10m[49m             elif beat_interval * 0.35 <= phase < beat_interval * 0.38:
[0m[49m[38;5;10m+     942[0m:[38;5;10m[49m                 samples.append(-0.3 + random.gauss(0, 0.03))
[0m[49m[38;5;10m+     943[0m:[38;5;10m[49m             else:
[0m[49m[38;5;10m+     944[0m:[38;5;10m[49m                 samples.append(random.gauss(0, 0.08))
[0m[49m[38;5;10m+     945[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     946[0m:[38;5;10m[49m     elif scenario == "pvc":
[0m[49m[38;5;10m+     947[0m:[38;5;10m[49m         # Normal rhythm with PVCs injected every ~15 beats.
[0m[49m[38;5;10m+     948[0m:[38;5;10m[49m         beat_interval = sample_rate * 60 // 75
[0m[49m[38;5;10m+     949[0m:[38;5;10m[49m         beat_count = 0
[0m[49m[38;5;10m+     950[0m:[38;5;10m[49m         i = 0
[0m[49m[38;5;10m+     951[0m:[38;5;10m[49m         while i < n_samples:
[0m[49m[38;5;10m+     952[0m:[38;5;10m[49m             beat_count += 1
[0m[49m[38;5;10m+     953[0m:[38;5;10m[49m             is_pvc = (beat_count % 15 == 0)
[0m[49m[38;5;10m+     954[0m:[38;5;10m[49m             interval = int(beat_interval * 0.7) if is_pvc else beat_interval
[0m[49m[38;5;10m+     955[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     956[0m:[38;5;10m[49m             for j in range(min(interval, n_samples - i)):
[0m[49m[38;5;10m+     957[0m:[38;5;10m[49m                 phase = j / interval
[0m[49m[38;5;10m+     958[0m:[38;5;10m[49m                 if is_pvc:
[0m[49m[38;5;10m+     959[0m:[38;5;10m[49m                     # PVC: wider, taller, different morphology.
[0m[49m[38;5;10m+     960[0m:[38;5;10m[49m                     if 0.2 < phase < 0.35:
[0m[49m[38;5;10m+     961[0m:[38;5;10m[49m                         samples.append(2.5 + random.gauss(0, 0.1))
[0m[49m[38;5;10m+     962[0m:[38;5;10m[49m                     elif 0.35 <= phase < 0.5:
[0m[49m[38;5;10m+     963[0m:[38;5;10m[49m                         samples.append(-1.0 + random.gauss(0, 0.1))
[0m[49m[38;5;10m+     964[0m:[38;5;10m[49m                     else:
[0m[49m[38;5;10m+     965[0m:[38;5;10m[49m                         samples.append(random.gauss(0, 0.1))
[0m[49m[38;5;10m+     966[0m:[38;5;10m[49m                 else:
[0m[49m[38;5;10m+     967[0m:[38;5;10m[49m                     if 0.3 < phase < 0.35:
[0m[49m[38;5;10m+     968[0m:[38;5;10m[49m                         samples.append(1.5 + random.gauss(0, 0.05))
[0m[49m[38;5;10m+     969[0m:[38;5;10m[49m                     elif 0.35 <= phase < 0.38:
[0m[49m[38;5;10m+     970[0m:[38;5;10m[49m                         samples.append(-0.3 + random.gauss(0, 0.03))
[0m[49m[38;5;10m+     971[0m:[38;5;10m[49m                     else:
[0m[49m[38;5;10m+     972[0m:[38;5;10m[49m                         samples.append(random.gauss(0, 0.08))
[0m[49m[38;5;10m+     973[0m:[38;5;10m[49m                 i += 1
[0m[49m[38;5;10m+     974[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     975[0m:[38;5;10m[49m     elif scenario == "afib":
[0m[49m[38;5;10m+     976[0m:[38;5;10m[49m         # Irregular rhythm: variable R-R intervals, no clear P waves.
[0m[49m[38;5;10m+     977[0m:[38;5;10m[49m         i = 0
[0m[49m[38;5;10m+     978[0m:[38;5;10m[49m         while i < n_samples:
[0m[49m[38;5;10m+     979[0m:[38;5;10m[49m             # AFib: irregular beat intervals (60-120 bpm equivalent).
[0m[49m[38;5;10m+     980[0m:[38;5;10m[49m             beat_interval = int(sample_rate * random.uniform(0.5, 1.0))
[0m[49m[38;5;10m+     981[0m:[38;5;10m[49m             for j in range(min(beat_interval, n_samples - i)):
[0m[49m[38;5;10m+     982[0m:[38;5;10m[49m                 phase = j / beat_interval
[0m[49m[38;5;10m+     983[0m:[38;5;10m[49m                 if 0.28 < phase < 0.34:
[0m[49m[38;5;10m+     984[0m:[38;5;10m[49m                     samples.append(1.2 + random.gauss(0, 0.15))
[0m[49m[38;5;10m+     985[0m:[38;5;10m[49m                 elif 0.34 <= phase < 0.38:
[0m[49m[38;5;10m+     986[0m:[38;5;10m[49m                     samples.append(-0.2 + random.gauss(0, 0.1))
[0m[49m[38;5;10m+     987[0m:[38;5;10m[49m                 else:
[0m[49m[38;5;10m+     988[0m:[38;5;10m[49m                     # Fibrillatory baseline: more noise than sinus.
[0m[49m[38;5;10m+     989[0m:[38;5;10m[49m                     samples.append(random.gauss(0, 0.15))
[0m[49m[38;5;10m+     990[0m:[38;5;10m[49m                 i += 1
[0m[49m[38;5;10m+     991[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     992[0m:[38;5;10m[49m     elif scenario == "noisy":
[0m[49m[38;5;10m+     993[0m:[38;5;10m[49m         # Normal rhythm buried in heavy artifact.
[0m[49m[38;5;10m+     994[0m:[38;5;10m[49m         beat_interval = sample_rate * 60 // 72
[0m[49m[38;5;10m+     995[0m:[38;5;10m[49m         for i in range(n_samples):
[0m[49m[38;5;10m+     996[0m:[38;5;10m[49m             phase = i % beat_interval
[0m[49m[38;5;10m+     997[0m:[38;5;10m[49m             if beat_interval * 0.3 < phase < beat_interval * 0.35:
[0m[49m[38;5;10m+     998[0m:[38;5;10m[49m                 samples.append(1.5 + random.gauss(0, 0.5))
[0m[49m[38;5;10m+     999[0m:[38;5;10m[49m             else:
[0m[49m[38;5;10m+    1000[0m:[38;5;10m[49m                 # Heavy noise: simulates motion artifact.
[0m[49m[38;5;10m+    1001[0m:[38;5;10m[49m                 samples.append(random.gauss(0, 0.8))
[0m[49m[38;5;10m+    1002[0m:[38;5;10m[49m 
