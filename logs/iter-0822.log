[0m[49m[39m  415, 415[0m:[39m[49m       {"event": "gi_intolerance_metformin", "frequency": 0.17},
[0m[49m[39m  416, 416[0m:[39m[49m       {"event": "hypoglycemia_mild", "frequency": 0.06}
[0m[49m[39m  417, 417[0m:[39m[49m     ]
