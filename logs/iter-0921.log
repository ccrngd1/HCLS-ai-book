[0m[49m[38;5;10m+     154[0m:[38;5;10m[49m                       Example: "uploads/2026-05-15/OR3-case-morning.mp4"
[0m[49m[38;5;10m+     155[0m:[38;5;10m[49m         metadata: Dict with procedure_type, surgeon_id, procedure_date,
[0m[49m[38;5;10m+     156[0m:[38;5;10m[49m                   duration_seconds.
[0m[49m[38;5;10m+     157[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     158[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     159[0m:[38;5;10m[49m         procedure_id: Unique identifier linking all downstream artifacts.
[0m[49m[38;5;10m+     160[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     161[0m:[38;5;10m[49m     procedure_id = f"proc-{uuid.uuid4().hex[:12]}"
[0m[49m[38;5;10m+     162[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     163[0m:[38;5;10m[49m     # Register in the procedure tracking table.
[0m[49m[38;5;10m+     164[0m:[38;5;10m[49m     # Status progresses: ingested -> extracting_frames -> analyzing -> complete (or failed).
[0m[49m[38;5;10m+     165[0m:[38;5;10m[49m     registry_table = dynamodb.Table(PROCEDURE_REGISTRY_TABLE)
[0m[49m[38;5;10m+     166[0m:[38;5;10m[49m     registry_table.put_item(Item={
[0m[49m[38;5;10m+     167[0m:[38;5;10m[49m         "procedure_id": procedure_id,
[0m[49m[38;5;10m+     168[0m:[38;5;10m[49m         "status": "ingested",
[0m[49m[38;5;10m+     169[0m:[38;5;10m[49m         "procedure_type": metadata["procedure_type"],
[0m[49m[38;5;10m+     170[0m:[38;5;10m[49m         "surgeon_id": metadata["surgeon_id"],
[0m[49m[38;5;10m+     171[0m:[38;5;10m[49m         "procedure_date": metadata["procedure_date"],
[0m[49m[38;5;10m+     172[0m:[38;5;10m[49m         "video_duration_seconds": Decimal(str(metadata["duration_seconds"])),
[0m[49m[38;5;10m+     173[0m:[38;5;10m[49m         "video_s3_key": video_s3_key,
[0m[49m[38;5;10m+     174[0m:[38;5;10m[49m         "ingested_at": datetime.datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+     175[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+     176[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     177[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+     178[0m:[38;5;10m[49m         "Registered procedure %s: %s, %d seconds",
[0m[49m[38;5;10m+     179[0m:[38;5;10m[49m         procedure_id,
[0m[49m[38;5;10m+     180[0m:[38;5;10m[49m         metadata["procedure_type"],
[0m[49m[38;5;10m+     181[0m:[38;5;10m[49m         metadata["duration_seconds"],
[0m[49m[38;5;10m+     182[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     183[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     184[0m:[38;5;10m[49m     return procedure_id
[0m[49m[38;5;10m+     185[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     186[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     187[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     188[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     189[0m:[38;5;10m[49m ## Step 2: Frame Extraction with MediaConvert
[0m[49m[38;5;10m+     190[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     191[0m:[38;5;10m[49m *Maps to pseudocode Step 2: `extract_frames(procedure_id, video_key, sample_rate_fps)`. This step uses AWS Elemental MediaConvert to extract frames at the target sample rate. MediaConvert handles the variety of video formats and codecs that different OR recording systems produce, so you don't have to run FFmpeg on EC2.*
[0m[49m[38;5;10m+     192[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     193[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     194[0m:[38;5;10m[49m def create_frame_extraction_job(procedure_id: str, video_s3_key: str) -> str:
[0m[49m[38;5;10m+     195[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     196[0m:[38;5;10m[49m     Submit a MediaConvert job to extract frames from the surgical video.
[0m[49m[38;5;10m+     197[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     198[0m:[38;5;10m[49m     MediaConvert transcodes the video and outputs individual JPEG frames
[0m[49m[38;5;10m+     199[0m:[38;5;10m[49m     at the configured sample rate. This handles format normalization
[0m[49m[38;5;10m+     200[0m:[38;5;10m[49m     (different OR systems use different codecs) and frame rate conversion
[0m[49m[38;5;10m+     201[0m:[38;5;10m[49m     in a single managed operation.
[0m[49m[38;5;10m+     202[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     203[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     204[0m:[38;5;10m[49m         procedure_id: Links this job to the procedure record.
[0m[49m[38;5;10m+     205[0m:[38;5;10m[49m         video_s3_key: S3 key of the raw video in RAW_VIDEO_BUCKET.
[0m[49m[38;5;10m+     206[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     207[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     208[0m:[38;5;10m[49m         job_id: MediaConvert job ID for status polling.
[0m[49m[38;5;10m+     209[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     210[0m:[38;5;10m[49m     output_prefix = f"s3://{FRAMES_BUCKET}/{procedure_id}/frames/"
[0m[49m[38;5;10m+     211[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     212[0m:[38;5;10m[49m     # MediaConvert job settings for frame extraction.
[0m[49m[38;5;10m+     213[0m:[38;5;10m[49m     # The key trick: set the output frame rate to our sample rate (1 fps)
[0m[49m[38;5;10m+     214[0m:[38;5;10m[49m     # and output as individual JPEG files. MediaConvert handles the decimation.
[0m[49m[38;5;10m+     215[0m:[38;5;10m[49m     job_settings = {
[0m[49m[38;5;10m+     216[0m:[38;5;10m[49m         "Inputs": [{
[0m[49m[38;5;10m+     217[0m:[38;5;10m[49m             "FileInput": f"s3://{RAW_VIDEO_BUCKET}/{video_s3_key}",
[0m[49m[38;5;10m+     218[0m:[38;5;10m[49m             "VideoSelector": {},
[0m[49m[38;5;10m+     219[0m:[38;5;10m[49m             "AudioSelector": {"DefaultSelection": "DEFAULT"},
[0m[49m[38;5;10m+     220[0m:[38;5;10m[49m         }],
[0m[49m[38;5;10m+     221[0m:[38;5;10m[49m         "OutputGroups": [{
[0m[49m[38;5;10m+     222[0m:[38;5;10m[49m             "Name": "FrameExtraction",
[0m[49m[38;5;10m+     223[0m:[38;5;10m[49m             "OutputGroupSettings": {
[0m[49m[38;5;10m+     224[0m:[38;5;10m[49m                 "Type": "FILE_GROUP_SETTINGS",
[0m[49m[38;5;10m+     225[0m:[38;5;10m[49m                 "FileGroupSettings": {
[0m[49m[38;5;10m+     226[0m:[38;5;10m[49m                     "Destination": output_prefix,
[0m[49m[38;5;10m+     227[0m:[38;5;10m[49m                 },
[0m[49m[38;5;10m+     228[0m:[38;5;10m[49m             },
[0m[49m[38;5;10m+     229[0m:[38;5;10m[49m             "Outputs": [{
[0m[49m[38;5;10m+     230[0m:[38;5;10m[49m                 "VideoDescription": {
[0m[49m[38;5;10m+     231[0m:[38;5;10m[49m                     "Width": MODEL_INPUT_SIZE[0],
[0m[49m[38;5;10m+     232[0m:[38;5;10m[49m                     "Height": MODEL_INPUT_SIZE[1],
[0m[49m[38;5;10m+     233[0m:[38;5;10m[49m                     "CodecSettings": {
[0m[49m[38;5;10m+     234[0m:[38;5;10m[49m                         "Codec": "FRAME_CAPTURE",
[0m[49m[38;5;10m+     235[0m:[38;5;10m[49m                         "FrameCaptureSettings": {
[0m[49m[38;5;10m+     236[0m:[38;5;10m[49m                             "FramerateNumerator": SAMPLE_RATE_FPS,
[0m[49m[38;5;10m+     237[0m:[38;5;10m[49m                             "FramerateDenominator": 1,
[0m[49m[38;5;10m+     238[0m:[38;5;10m[49m                             "Quality": 80,
[0m[49m[38;5;10m+     239[0m:[38;5;10m[49m                         },
[0m[49m[38;5;10m+     240[0m:[38;5;10m[49m                     },
[0m[49m[38;5;10m+     241[0m:[38;5;10m[49m                 },
[0m[49m[38;5;10m+     242[0m:[38;5;10m[49m                 "ContainerSettings": {
[0m[49m[38;5;10m+     243[0m:[38;5;10m[49m                     "Container": "RAW",
[0m[49m[38;5;10m+     244[0m:[38;5;10m[49m                 },
[0m[49m[38;5;10m+     245[0m:[38;5;10m[49m             }],
[0m[49m[38;5;10m+     246[0m:[38;5;10m[49m         }],
[0m[49m[38;5;10m+     247[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     248[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     249[0m:[38;5;10m[49m     response = mediaconvert_client.create_job(
[0m[49m[38;5;10m+     250[0m:[38;5;10m[49m         Role=MEDIACONVERT_ROLE_ARN,
[0m[49m[38;5;10m+     251[0m:[38;5;10m[49m         Queue=MEDIACONVERT_QUEUE_ARN,
[0m[49m[38;5;10m+     252[0m:[38;5;10m[49m         Settings=job_settings,
[0m[49m[38;5;10m+     253[0m:[38;5;10m[49m         Tags={"procedure_id": procedure_id},
[0m[49m[38;5;10m+     254[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     255[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     256[0m:[38;5;10m[49m     job_id = response["Job"]["Id"]
[0m[49m[38;5;10m+     257[0m:[38;5;10m[49m     logger.info("Created MediaConvert job %s for procedure %s", job_id, procedure_id)
[0m[49m[38;5;10m+     258[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     259[0m:[38;5;10m[49m     return job_id
[0m[49m[38;5;10m+     260[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     261[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     262[0m:[38;5;10m[49m def filter_valid_frames(procedure_id: str) -> list:
[0m[49m[38;5;10m+     263[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     264[0m:[38;5;10m[49m     After frame extraction, filter out non-informative frames.
[0m[49m[38;5;10m+     265[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     266[0m:[38;5;10m[49m     Black frames (camera disconnected), completely white frames (lens fogging),
[0m[49m[38;5;10m+     267[0m:[38;5;10m[49m     and uniform-color frames (light source off) are useless for analysis.
[0m[49m[38;5;10m+     268[0m:[38;5;10m[49m     We detect these by checking pixel statistics.
[0m[49m[38;5;10m+     269[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     270[0m:[38;5;10m[49m     In this simplified version, we simulate the filtering logic since we don't
[0m[49m[38;5;10m+     271[0m:[38;5;10m[49m     have actual frame pixel data. In production, you'd load each JPEG from S3,
[0m[49m[38;5;10m+     272[0m:[38;5;10m[49m     compute mean/std of pixel values, and discard frames that fail the checks.
[0m[49m[38;5;10m+     273[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     274[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     275[0m:[38;5;10m[49m         procedure_id: Identifies which frames to filter.
[0m[49m[38;5;10m+     276[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     277[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     278[0m:[38;5;10m[49m         List of valid frame S3 keys.
[0m[49m[38;5;10m+     279[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     280[0m:[38;5;10m[49m     # List all extracted frames for this procedure.
[0m[49m[38;5;10m+     281[0m:[38;5;10m[49m     paginator = s3_client.get_paginator("list_objects_v2")
[0m[49m[38;5;10m+     282[0m:[38;5;10m[49m     frame_keys = []
[0m[49m[38;5;10m+     283[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     284[0m:[38;5;10m[49m     for page in paginator.paginate(
[0m[49m[38;5;10m+     285[0m:[38;5;10m[49m         Bucket=FRAMES_BUCKET,
[0m[49m[38;5;10m+     286[0m:[38;5;10m[49m         Prefix=f"{procedure_id}/frames/",
[0m[49m[38;5;10m+     287[0m:[38;5;10m[49m     ):
[0m[49m[38;5;10m+     288[0m:[38;5;10m[49m         for obj in page.get("Contents", []):
[0m[49m[38;5;10m+     289[0m:[38;5;10m[49m             if obj["Key"].endswith(".jpg") or obj["Key"].endswith(".jpeg"):
[0m[49m[38;5;10m+     290[0m:[38;5;10m[49m                 frame_keys.append(obj["Key"])
[0m[49m[38;5;10m+     291[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     292[0m:[38;5;10m[49m     frame_keys.sort()  # ensure temporal order
[0m[49m[38;5;10m+     293[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     294[0m:[38;5;10m[49m     # In production, you'd download each frame (or a sample) and check:
[0m[49m[38;5;10m+     295[0m:[38;5;10m[49m     #   mean_pixel < 10  -> black frame, skip
[0m[49m[38;5;10m+     296[0m:[38;5;10m[49m     #   std_pixel < 5    -> uniform frame (fog/cap), skip
[0m[49m[38;5;10m+     297[0m:[38;5;10m[49m     # For this example, we assume all frames pass (real filtering would
[0m[49m[38;5;10m+     298[0m:[38;5;10m[49m     # typically remove 2-5% of frames from a typical procedure).
[0m[49m[38;5;10m+     299[0m:[38;5;10m[49m     valid_frames = frame_keys
[0m[49m[38;5;10m+     300[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     301[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+     302[0m:[38;5;10m[49m         "Procedure %s: %d total frames, %d valid after filtering",
[0m[49m[38;5;10m+     303[0m:[38;5;10m[49m         procedure_id,
[0m[49m[38;5;10m+     304[0m:[38;5;10m[49m         len(frame_keys),
[0m[49m[38;5;10m+     305[0m:[38;5;10m[49m         len(valid_frames),
[0m[49m[38;5;10m+     306[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     307[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     308[0m:[38;5;10m[49m     # Write the manifest so downstream steps know which frames to process.
[0m[49m[38;5;10m+     309[0m:[38;5;10m[49m     manifest = {"procedure_id": procedure_id, "valid_frames": valid_frames}
[0m[49m[38;5;10m+     310[0m:[38;5;10m[49m     s3_client.put_object(
[0m[49m[38;5;10m+     311[0m:[38;5;10m[49m         Bucket=FRAMES_BUCKET,
[0m[49m[38;5;10m+     312[0m:[38;5;10m[49m         Key=f"{procedure_id}/manifest.json",
[0m[49m[38;5;10m+     313[0m:[38;5;10m[49m         Body=json.dumps(manifest),
[0m[49m[38;5;10m+     314[0m:[38;5;10m[49m         ContentType="application/json",
[0m[49m[38;5;10m+     315[0m:[38;5;10m[49m         ServerSideEncryption="aws:kms",
[0m[49m[38;5;10m+     316[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     317[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     318[0m:[38;5;10m[49m     return valid_frames
[0m[49m[38;5;10m+     319[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     320[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     321[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     322[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     323[0m:[38;5;10m[49m ## Step 3: Feature Extraction via SageMaker Batch Transform
[0m[49m[38;5;10m+     324[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     325[0m:[38;5;10m[49m *Maps to pseudocode Step 3: `extract_features(procedure_id, frame_manifest)`. Each valid frame passes through a CNN backbone (ResNet-50 fine-tuned on surgical video) to produce a compact feature vector. SageMaker Batch Transform handles this at scale without you managing GPU instances directly.*
[0m[49m[38;5;10m+     326[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     327[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     328[0m:[38;5;10m[49m import time
[0m[49m[38;5;10m+     329[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     330[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     331[0m:[38;5;10m[49m def launch_feature_extraction(procedure_id: str, valid_frames: list) -> str:
[0m[49m[38;5;10m+     332[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     333[0m:[38;5;10m[49m     Launch a SageMaker Batch Transform job to extract features from all frames.
[0m[49m[38;5;10m+     334[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     335[0m:[38;5;10m[49m     The feature extraction model is a ResNet-50 backbone (pretrained on ImageNet,
[0m[49m[38;5;10m+     336[0m:[38;5;10m[49m     fine-tuned on surgical video) with the final classification layer removed.
[0m[49m[38;5;10m+     337[0m:[38;5;10m[49m     It takes a 224x224 image and outputs a 2048-dimensional feature vector.
[0m[49m[38;5;10m+     338[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     339[0m:[38;5;10m[49m     Batch Transform processes all frames in parallel across the instance(s),
[0m[49m[38;5;10m+     340[0m:[38;5;10m[49m     writing feature vectors back to S3.
[0m[49m[38;5;10m+     341[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     342[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     343[0m:[38;5;10m[49m         procedure_id: Links this job to the procedure.
[0m[49m[38;5;10m+     344[0m:[38;5;10m[49m         valid_frames: List of S3 keys for frames to process.
[0m[49m[38;5;10m+     345[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     346[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     347[0m:[38;5;10m[49m         transform_job_name: For polling job status.
[0m[49m[38;5;10m+     348[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     349[0m:[38;5;10m[49m     sagemaker_client = boto3.client("sagemaker", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     350[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     351[0m:[38;5;10m[49m     transform_job_name = f"feat-{procedure_id}"
[0m[49m[38;5;10m+     352[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     353[0m:[38;5;10m[49m     # The input is the frames prefix in S3.
[0m[49m[38;5;10m+     354[0m:[38;5;10m[49m     # Batch Transform will process every object under this prefix.
[0m[49m[38;5;10m+     355[0m:[38;5;10m[49m     input_prefix = f"s3://{FRAMES_BUCKET}/{procedure_id}/frames/"
[0m[49m[38;5;10m+     356[0m:[38;5;10m[49m     output_prefix = f"s3://{FEATURES_BUCKET}/{procedure_id}/"
[0m[49m[38;5;10m+     357[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     358[0m:[38;5;10m[49m     sagemaker_client.create_transform_job(
[0m[49m[38;5;10m+     359[0m:[38;5;10m[49m         TransformJobName=transform_job_name,
[0m[49m[38;5;10m+     360[0m:[38;5;10m[49m         ModelName=SAGEMAKER_FEATURE_MODEL,
[0m[49m[38;5;10m+     361[0m:[38;5;10m[49m         TransformInput={
[0m[49m[38;5;10m+     362[0m:[38;5;10m[49m             "DataSource": {
[0m[49m[38;5;10m+     363[0m:[38;5;10m[49m                 "S3DataSource": {
[0m[49m[38;5;10m+     364[0m:[38;5;10m[49m                     "S3DataType": "S3Prefix",
[0m[49m[38;5;10m+     365[0m:[38;5;10m[49m                     "S3Uri": input_prefix,
[0m[49m[38;5;10m+     366[0m:[38;5;10m[49m                 },
[0m[49m[38;5;10m+     367[0m:[38;5;10m[49m             },
[0m[49m[38;5;10m+     368[0m:[38;5;10m[49m             "ContentType": "application/x-image",
[0m[49m[38;5;10m+     369[0m:[38;5;10m[49m             "SplitType": "None",  # each file is one input
[0m[49m[38;5;10m+     370[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+     371[0m:[38;5;10m[49m         TransformOutput={
[0m[49m[38;5;10m+     372[0m:[38;5;10m[49m             "S3OutputPath": output_prefix,
[0m[49m[38;5;10m+     373[0m:[38;5;10m[49m             "AssembleWith": "None",
[0m[49m[38;5;10m+     374[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+     375[0m:[38;5;10m[49m         TransformResources={
[0m[49m[38;5;10m+     376[0m:[38;5;10m[49m             "InstanceType": "ml.g5.xlarge",  # GPU instance for CNN inference
[0m[49m[38;5;10m+     377[0m:[38;5;10m[49m             "InstanceCount": 1,
[0m[49m[38;5;10m+     378[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+     379[0m:[38;5;10m[49m         MaxPayloadInMB=6,  # each frame is well under 6 MB
[0m[49m[38;5;10m+     380[0m:[38;5;10m[49m         BatchStrategy="SingleRecord",
[0m[49m[38;5;10m+     381[0m:[38;5;10m[49m         Tags=[{"Key": "procedure_id", "Value": procedure_id}],
[0m[49m[38;5;10m+     382[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     383[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     384[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+     385[0m:[38;5;10m[49m         "Launched feature extraction job %s for %d frames",
[0m[49m[38;5;10m+     386[0m:[38;5;10m[49m         transform_job_name,
[0m[49m[38;5;10m+     387[0m:[38;5;10m[49m         len(valid_frames),
[0m[49m[38;5;10m+     388[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     389[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     390[0m:[38;5;10m[49m     return transform_job_name
[0m[49m[38;5;10m+     391[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     392[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     393[0m:[38;5;10m[49m def wait_for_transform_job(job_name: str, poll_interval: int = 30) -> str:
[0m[49m[38;5;10m+     394[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     395[0m:[38;5;10m[49m     Poll a SageMaker Batch Transform job until it completes or fails.
[0m[49m[38;5;10m+     396[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     397[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     398[0m:[38;5;10m[49m         job_name: The transform job name.
[0m[49m[38;5;10m+     399[0m:[38;5;10m[49m         poll_interval: Seconds between status checks.
[0m[49m[38;5;10m+     400[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     401[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     402[0m:[38;5;10m[49m         Final job status: "Completed" or "Failed".
[0m[49m[38;5;10m+     403[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     404[0m:[38;5;10m[49m     sagemaker_client = boto3.client("sagemaker", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     405[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     406[0m:[38;5;10m[49m     while True:
[0m[49m[38;5;10m+     407[0m:[38;5;10m[49m         response = sagemaker_client.describe_transform_job(
[0m[49m[38;5;10m+     408[0m:[38;5;10m[49m             TransformJobName=job_name
[0m[49m[38;5;10m+     409[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     410[0m:[38;5;10m[49m         status = response["TransformJobStatus"]
[0m[49m[38;5;10m+     411[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     412[0m:[38;5;10m[49m         if status in ("Completed", "Failed", "Stopped"):
[0m[49m[38;5;10m+     413[0m:[38;5;10m[49m             logger.info("Transform job %s finished with status: %s", job_name, status)
[0m[49m[38;5;10m+     414[0m:[38;5;10m[49m             return status
[0m[49m[38;5;10m+     415[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     416[0m:[38;5;10m[49m         logger.info("Transform job %s status: %s, waiting...", job_name, status)
[0m[49m[38;5;10m+     417[0m:[38;5;10m[49m         time.sleep(poll_interval)
[0m[49m[38;5;10m+     418[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     419[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     420[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     421[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     422[0m:[38;5;10m[49m ## Step 4: Temporal Modeling and Multi-Task Prediction
[0m[49m[38;5;10m+     423[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     424[0m:[38;5;10m[49m *Maps to pseudocode Step 4: `temporal_prediction(procedure_id, features)`. This is where the system reasons across time. The sequence of frame features passes through a temporal model (transformer or TCN) that considers the full procedure context to predict phase, instruments, and events at each time point.*
[0m[49m[38;5;10m+     425[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     426[0m:[38;5;10m[49m In production, this would be another SageMaker endpoint or batch transform job running the temporal model. For this example, we simulate the temporal model's output to demonstrate the downstream pipeline.
[0m[49m[38;5;10m+     427[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     428[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     429[0m:[38;5;10m[49m def run_temporal_prediction(procedure_id: str, num_frames: int) -> dict:
[0m[49m[38;5;10m+     430[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     431[0m:[38;5;10m[49m     Run temporal model inference on the feature sequence.
[0m[49m[38;5;10m+     432[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     433[0m:[38;5;10m[49m     In production, this loads the feature vectors from S3, sends them to a
[0m[49m[38;5;10m+     434[0m:[38;5;10m[49m     SageMaker endpoint running the temporal model (transformer or TCN), and
[0m[49m[38;5;10m+     435[0m:[38;5;10m[49m     gets back per-frame predictions for phase, instruments, and events.
[0m[49m[38;5;10m+     436[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     437[0m:[38;5;10m[49m     For this example, we generate synthetic predictions that look like a
[0m[49m[38;5;10m+     438[0m:[38;5;10m[49m     realistic cholecystectomy. The structure of the output is what matters
[0m[49m[38;5;10m+     439[0m:[38;5;10m[49m     for understanding the downstream pipeline.
[0m[49m[38;5;10m+     440[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     441[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     442[0m:[38;5;10m[49m         procedure_id: Identifies which features to load.
[0m[49m[38;5;10m+     443[0m:[38;5;10m[49m         num_frames: Number of frames in the sequence (at SAMPLE_RATE_FPS).
[0m[49m[38;5;10m+     444[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     445[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     446[0m:[38;5;10m[49m         Dict with phase_predictions, instrument_predictions, event_predictions.
[0m[49m[38;5;10m+     447[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     448[0m:[38;5;10m[49m     # In production, you'd load features and call the temporal model:
[0m[49m[38;5;10m+     449[0m:[38;5;10m[49m     #
[0m[49m[38;5;10m+     450[0m:[38;5;10m[49m     #   features = np.load(f"s3://{FEATURES_BUCKET}/{procedure_id}/features.npy")
[0m[49m[38;5;10m+     451[0m:[38;5;10m[49m     #   endpoint_response = sagemaker_runtime.invoke_endpoint(
[0m[49m[38;5;10m+     452[0m:[38;5;10m[49m     #       EndpointName=SAGEMAKER_TEMPORAL_MODEL,
[0m[49m[38;5;10m+     453[0m:[38;5;10m[49m     #       Body=features.tobytes(),
[0m[49m[38;5;10m+     454[0m:[38;5;10m[49m     #       ContentType="application/x-npy",
[0m[49m[38;5;10m+     455[0m:[38;5;10m[49m     #   )
[0m[49m[38;5;10m+     456[0m:[38;5;10m[49m     #   predictions = parse_response(endpoint_response)
[0m[49m[38;5;10m+     457[0m:[38;5;10m[49m     #
[0m[49m[38;5;10m+     458[0m:[38;5;10m[49m     # Instead, we generate synthetic predictions for a ~47-minute cholecystectomy.
[0m[49m[38;5;10m+     459[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     460[0m:[38;5;10m[49m     np.random.seed(42)  # reproducible synthetic data
[0m[49m[38;5;10m+     461[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     462[0m:[38;5;10m[49m     # Simulate phase predictions.
[0m[49m[38;5;10m+     463[0m:[38;5;10m[49m     # A typical cholecystectomy has phases of varying duration.
[0m[49m[38;5;10m+     464[0m:[38;5;10m[49m     # We assign frames to phases proportionally.
[0m[49m[38;5;10m+     465[0m:[38;5;10m[49m     phase_proportions = [0.065, 0.15, 0.26, 0.065, 0.31, 0.15]
[0m[49m[38;5;10m+     466[0m:[38;5;10m[49m     phase_boundaries = np.cumsum([int(p * num_frames) for p in phase_proportions])
[0m[49m[38;5;10m+     467[0m:[38;5;10m[49m     phase_boundaries[-1] = num_frames  # ensure we cover all frames
[0m[49m[38;5;10m+     468[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     469[0m:[38;5;10m[49m     phase_predictions = np.zeros(num_frames, dtype=int)
[0m[49m[38;5;10m+     470[0m:[38;5;10m[49m     phase_confidences = np.zeros(num_frames)
[0m[49m[38;5;10m+     471[0m:[38;5;10m[49m     start = 0
[0m[49m[38;5;10m+     472[0m:[38;5;10m[49m     for phase_idx, end in enumerate(phase_boundaries):
[0m[49m[38;5;10m+     473[0m:[38;5;10m[49m         phase_predictions[start:end] = phase_idx
[0m[49m[38;5;10m+     474[0m:[38;5;10m[49m         # High confidence in the middle of phases, lower at boundaries.
[0m[49m[38;5;10m+     475[0m:[38;5;10m[49m         for f in range(start, end):
[0m[49m[38;5;10m+     476[0m:[38;5;10m[49m             dist_from_boundary = min(f - start, end - f - 1)
[0m[49m[38;5;10m+     477[0m:[38;5;10m[49m             # Confidence ramps up from 0.7 at boundaries to 0.95 in the middle.
[0m[49m[38;5;10m+     478[0m:[38;5;10m[49m             phase_confidences[f] = min(0.95, 0.70 + 0.25 * (dist_from_boundary / 30))
[0m[49m[38;5;10m+     479[0m:[38;5;10m[49m         start = end
[0m[49m[38;5;10m+     480[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     481[0m:[38;5;10m[49m     # Add some noise at phase boundaries (realistic: models struggle at transitions).
[0m[49m[38;5;10m+     482[0m:[38;5;10m[49m     for boundary in phase_boundaries[:-1]:
[0m[49m[38;5;10m+     483[0m:[38;5;10m[49m         noise_range = min(5, num_frames - boundary)
[0m[49m[38;5;10m+     484[0m:[38;5;10m[49m         for offset in range(-3, noise_range):
[0m[49m[38;5;10m+     485[0m:[38;5;10m[49m             idx = boundary + offset
[0m[49m[38;5;10m+     486[0m:[38;5;10m[49m             if 0 <= idx < num_frames:
[0m[49m[38;5;10m+     487[0m:[38;5;10m[49m                 if np.random.random() < 0.3:
[0m[49m[38;5;10m+     488[0m:[38;5;10m[49m                     # Flip to adjacent phase with low confidence.
[0m[49m[38;5;10m+     489[0m:[38;5;10m[49m                     phase_predictions[idx] = max(0, phase_predictions[idx] - 1)
[0m[49m[38;5;10m+     490[0m:[38;5;10m[49m                     phase_confidences[idx] = 0.45 + np.random.random() * 0.2
[0m[49m[38;5;10m+     491[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     492[0m:[38;5;10m[49m     # Simulate instrument predictions (multi-label, per frame).
[0m[49m[38;5;10m+     493[0m:[38;5;10m[49m     # Grasper is almost always present. Others appear in specific phases.
[0m[49m[38;5;10m+     494[0m:[38;5;10m[49m     instrument_predictions = np.zeros((num_frames, len(INSTRUMENT_CLASSES)))
[0m[49m[38;5;10m+     495[0m:[38;5;10m[49m     # Grasper: present ~90% of the time.
[0m[49m[38;5;10m+     496[0m:[38;5;10m[49m     instrument_predictions[:, 0] = (np.random.random(num_frames) < 0.90).astype(float)
[0m[49m[38;5;10m+     497[0m:[38;5;10m[49m     # Hook cautery: present during dissection phases (phases 1, 2, 4).
[0m[49m[38;5;10m+     498[0m:[38;5;10m[49m     for phase_idx in [1, 2, 4]:
[0m[49m[38;5;10m+     499[0m:[38;5;10m[49m         mask = phase_predictions == phase_idx
[0m[49m[38;5;10m+     500[0m:[38;5;10m[49m         instrument_predictions[mask, 1] = (np.random.random(mask.sum()) < 0.75).astype(float)
[0m[49m[38;5;10m+     501[0m:[38;5;10m[49m     # Clip applier: present during clipping phase (phase 3).
[0m[49m[38;5;10m+     502[0m:[38;5;10m[49m     mask = phase_predictions == 3
[0m[49m[38;5;10m+     503[0m:[38;5;10m[49m     instrument_predictions[mask, 3] = (np.random.random(mask.sum()) < 0.85).astype(float)
[0m[49m[38;5;10m+     504[0m:[38;5;10m[49m     # Scissors: brief appearances during clipping.
[0m[49m[38;5;10m+     505[0m:[38;5;10m[49m     instrument_predictions[mask, 2] = (np.random.random(mask.sum()) < 0.4).astype(float)
[0m[49m[38;5;10m+     506[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     507[0m:[38;5;10m[49m     instrument_confidences = np.clip(
[0m[49m[38;5;10m+     508[0m:[38;5;10m[49m         instrument_predictions * (0.7 + np.random.random((num_frames, len(INSTRUMENT_CLASSES))) * 0.25),
[0m[49m[38;5;10m+     509[0m:[38;5;10m[49m         0, 1,
[0m[49m[38;5;10m+     510[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     511[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     512[0m:[38;5;10m[49m     # Simulate event detections (sparse, specific moments).
[0m[49m[38;5;10m+     513[0m:[38;5;10m[49m     event_predictions = []
[0m[49m[38;5;10m+     514[0m:[38;5;10m[49m     # Minor bleeding during Calot's triangle dissection.
[0m[49m[38;5;10m+     515[0m:[38;5;10m[49m     calot_start = int(phase_boundaries[1])
[0m[49m[38;5;10m+     516[0m:[38;5;10m[49m     calot_end = int(phase_boundaries[2])
[0m[49m[38;5;10m+     517[0m:[38;5;10m[49m     bleeding_frame = calot_start + int((calot_end - calot_start) * 0.4)
[0m[49m[38;5;10m+     518[0m:[38;5;10m[49m     event_predictions.append({
[0m[49m[38;5;10m+     519[0m:[38;5;10m[49m         "event_type": "bleeding_minor",
[0m[49m[38;5;10m+     520[0m:[38;5;10m[49m         "frame": bleeding_frame,
[0m[49m[38;5;10m+     521[0m:[38;5;10m[49m         "confidence": 0.72,
[0m[49m[38;5;10m+     522[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+     523[0m:[38;5;10m[49m     # Clip placements during clipping phase.
[0m[49m[38;5;10m+     524[0m:[38;5;10m[49m     clip_start = int(phase_boundaries[2])
[0m[49m[38;5;10m+     525[0m:[38;5;10m[49m     clip_end = int(phase_boundaries[3])
[0m[49m[38;5;10m+     526[0m:[38;5;10m[49m     clip_frame_1 = clip_start + int((clip_end - clip_start) * 0.3)
[0m[49m[38;5;10m+     527[0m:[38;5;10m[49m     clip_frame_2 = clip_start + int((clip_end - clip_start) * 0.6)
[0m[49m[38;5;10m+     528[0m:[38;5;10m[49m     event_predictions.append({
[0m[49m[38;5;10m+     529[0m:[38;5;10m[49m         "event_type": "clip_placement",
[0m[49m[38;5;10m+     530[0m:[38;5;10m[49m         "frame": clip_frame_1,
[0m[49m[38;5;10m+     531[0m:[38;5;10m[49m         "confidence": 0.96,
[0m[49m[38;5;10m+     532[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+     533[0m:[38;5;10m[49m     event_predictions.append({
[0m[49m[38;5;10m+     534[0m:[38;5;10m[49m         "event_type": "clip_placement",
[0m[49m[38;5;10m+     535[0m:[38;5;10m[49m         "frame": clip_frame_2,
[0m[49m[38;5;10m+     536[0m:[38;5;10m[49m         "confidence": 0.94,
[0m[49m[38;5;10m+     537[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+     538[0m:[38;5;10m[49m     # Specimen extraction near the end.
[0m[49m[38;5;10m+     539[0m:[38;5;10m[49m     extract_start = int(phase_boundaries[4])
[0m[49m[38;5;10m+     540[0m:[38;5;10m[49m     event_predictions.append({
[0m[49m[38;5;10m+     541[0m:[38;5;10m[49m         "event_type": "specimen_extraction",
[0m[49m[38;5;10m+     542[0m:[38;5;10m[49m         "frame": extract_start + 60,
[0m[49m[38;5;10m+     543[0m:[38;5;10m[49m         "confidence": 0.88,
[0m[49m[38;5;10m+     544[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+     545[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     546[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     547[0m:[38;5;10m[49m         "phase_predictions": phase_predictions,
[0m[49m[38;5;10m+     548[0m:[38;5;10m[49m         "phase_confidences": phase_confidences,
[0m[49m[38;5;10m+     549[0m:[38;5;10m[49m         "instrument_predictions": instrument_predictions,
[0m[49m[38;5;10m+     550[0m:[38;5;10m[49m         "instrument_confidences": instrument_confidences,
[0m[49m[38;5;10m+     551[0m:[38;5;10m[49m         "event_predictions": event_predictions,
[0m[49m[38;5;10m+     552[0m:[38;5;10m[49m         "num_frames": num_frames,
[0m[49m[38;5;10m+     553[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     554[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     555[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     556[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     557[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     558[0m:[38;5;10m[49m ## Step 5: Temporal Post-Processing
[0m[49m[38;5;10m+     559[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     560[0m:[38;5;10m[49m *Maps to pseudocode Step 5: `post_process(raw_predictions, sample_rate_fps)`. Raw per-frame predictions are noisy at phase boundaries. This step applies median filtering, minimum duration constraints, and instrument gap-filling to produce a clean, usable timeline.*
[0m[49m[38;5;10m+     561[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     562[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     563[0m:[38;5;10m[49m def median_filter_1d(signal: np.ndarray, window: int) -> np.ndarray:
[0m[49m[38;5;10m+     564[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     565[0m:[38;5;10m[49m     Apply a 1D median filter to smooth phase predictions.
[0m[49m[38;5;10m+     566[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     567[0m:[38;5;10m[49m     Median filtering is ideal for phase smoothing because it removes
[0m[49m[38;5;10m+     568[0m:[38;5;10m[49m     isolated outlier frames (single-frame phase flickers) without
[0m[49m[38;5;10m+     569[0m:[38;5;10m[49m     blurring the actual transitions. A mean filter would create
[0m[49m[38;5;10m+     570[0m:[38;5;10m[49m     impossible fractional phase values.
[0m[49m[38;5;10m+     571[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     572[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     573[0m:[38;5;10m[49m         signal: 1D array of integer phase labels.
[0m[49m[38;5;10m+     574[0m:[38;5;10m[49m         window: Filter window size (must be odd for symmetric filtering).
[0m[49m[38;5;10m+     575[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     576[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     577[0m:[38;5;10m[49m         Smoothed signal with same shape.
[0m[49m[38;5;10m+     578[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     579[0m:[38;5;10m[49m     if window % 2 == 0:
[0m[49m[38;5;10m+     580[0m:[38;5;10m[49m         window += 1  # ensure odd window
[0m[49m[38;5;10m+     581[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     582[0m:[38;5;10m[49m     padded = np.pad(signal, window // 2, mode="edge")
[0m[49m[38;5;10m+     583[0m:[38;5;10m[49m     result = np.zeros_like(signal)
[0m[49m[38;5;10m+     584[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     585[0m:[38;5;10m[49m     for i in range(len(signal)):
[0m[49m[38;5;10m+     586[0m:[38;5;10m[49m         result[i] = int(np.median(padded[i:i + window]))
[0m[49m[38;5;10m+     587[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     588[0m:[38;5;10m[49m     return result
[0m[49m[38;5;10m+     589[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     590[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     591[0m:[38;5;10m[49m def enforce_min_phase_duration(phases: np.ndarray, min_frames: int) -> np.ndarray:
[0m[49m[38;5;10m+     592[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     593[0m:[38;5;10m[49m     Merge short phase segments into their longer neighbors.
[0m[49m[38;5;10m+     594[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     595[0m:[38;5;10m[49m     No surgical phase lasts less than 30 seconds. If the model predicts
[0m[49m[38;5;10m+     596[0m:[38;5;10m[49m     a 5-second phase segment, it's almost certainly a misclassification.
[0m[49m[38;5;10m+     597[0m:[38;5;10m[49m     We merge it into whichever adjacent phase is longer.
[0m[49m[38;5;10m+     598[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     599[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     600[0m:[38;5;10m[49m         phases: 1D array of phase labels (already median-filtered).
[0m[49m[38;5;10m+     601[0m:[38;5;10m[49m         min_frames: Minimum segment length in frames.
[0m[49m[38;5;10m+     602[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     603[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     604[0m:[38;5;10m[49m         Phases with short segments merged.
[0m[49m[38;5;10m+     605[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     606[0m:[38;5;10m[49m     result = phases.copy()
[0m[49m[38;5;10m+     607[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     608[0m:[38;5;10m[49m     # Identify contiguous segments.
[0m[49m[38;5;10m+     609[0m:[38;5;10m[49m     changes = np.where(np.diff(result) != 0)[0] + 1
[0m[49m[38;5;10m+     610[0m:[38;5;10m[49m     boundaries = np.concatenate([[0], changes, [len(result)]])
[0m[49m[38;5;10m+     611[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     612[0m:[38;5;10m[49m     for i in range(len(boundaries) - 1):
[0m[49m[38;5;10m+     613[0m:[38;5;10m[49m         seg_start = boundaries[i]
[0m[49m[38;5;10m+     614[0m:[38;5;10m[49m         seg_end = boundaries[i + 1]
[0m[49m[38;5;10m+     615[0m:[38;5;10m[49m         seg_length = seg_end - seg_start
[0m[49m[38;5;10m+     616[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     617[0m:[38;5;10m[49m         if seg_length < min_frames:
[0m[49m[38;5;10m+     618[0m:[38;5;10m[49m             # This segment is too short. Merge into the longer neighbor.
[0m[49m[38;5;10m+     619[0m:[38;5;10m[49m             left_length = seg_start - boundaries[max(0, i - 1)] if i > 0 else 0
[0m[49m[38;5;10m+     620[0m:[38;5;10m[49m             right_length = boundaries[min(len(boundaries) - 1, i + 2)] - seg_end if i < len(boundaries) - 2 else 0
[0m[49m[38;5;10m+     621[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     622[0m:[38;5;10m[49m             if left_length >= right_length and i > 0:
[0m[49m[38;5;10m+     623[0m:[38;5;10m[49m                 # Merge into left neighbor.
[0m[49m[38;5;10m+     624[0m:[38;5;10m[49m                 result[seg_start:seg_end] = result[seg_start - 1]
[0m[49m[38;5;10m+     625[0m:[38;5;10m[49m             elif i < len(boundaries) - 2:
[0m[49m[38;5;10m+     626[0m:[38;5;10m[49m                 # Merge into right neighbor.
[0m[49m[38;5;10m+     627[0m:[38;5;10m[49m                 result[seg_start:seg_end] = result[seg_end]
[0m[49m[38;5;10m+     628[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     629[0m:[38;5;10m[49m     return result
[0m[49m[38;5;10m+     630[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     631[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     632[0m:[38;5;10m[49m def post_process_predictions(raw_predictions: dict) -> dict:
[0m[49m[38;5;10m+     633[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     634[0m:[38;5;10m[49m     Clean up raw model predictions into a usable procedure timeline.
[0m[49m[38;5;10m+     635[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     636[0m:[38;5;10m[49m     Applies:
[0m[49m[38;5;10m+     637[0m:[38;5;10m[49m     1. Median filtering to remove single-frame phase flickers.
[0m[49m[38;5;10m+     638[0m:[38;5;10m[49m     2. Minimum duration enforcement to eliminate impossibly short phases.
[0m[49m[38;5;10m+     639[0m:[38;5;10m[49m     3. Instrument gap-filling to handle brief occlusions.
[0m[49m[38;5;10m+     640[0m:[38;5;10m[49m     4. Timeline construction with start/end timestamps.
[0m[49m[38;5;10m+     641[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     642[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     643[0m:[38;5;10m[49m         raw_predictions: Output from run_temporal_prediction().
[0m[49m[38;5;10m+     644[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     645[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     646[0m:[38;5;10m[49m         Dict with phase_timeline, instrument_log, and events.
[0m[49m[38;5;10m+     647[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     648[0m:[38;5;10m[49m     num_frames = raw_predictions["num_frames"]
[0m[49m[38;5;10m+     649[0m:[38;5;10m[49m     phases = raw_predictions["phase_predictions"].copy()
[0m[49m[38;5;10m+     650[0m:[38;5;10m[49m     phase_confs = raw_predictions["phase_confidences"].copy()
[0m[49m[38;5;10m+     651[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     652[0m:[38;5;10m[49m     # Step 5a: Median filter to remove phase flickers.
[0m[49m[38;5;10m+     653[0m:[38;5;10m[49m     phases = median_filter_1d(phases, PHASE_SMOOTH_WINDOW)
[0m[49m[38;5;10m+     654[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     655[0m:[38;5;10m[49m     # Step 5b: Enforce minimum phase duration.
[0m[49m[38;5;10m+     656[0m:[38;5;10m[49m     min_frames = MIN_PHASE_DURATION_SEC * SAMPLE_RATE_FPS
[0m[49m[38;5;10m+     657[0m:[38;5;10m[49m     phases = enforce_min_phase_duration(phases, min_frames)
[0m[49m[38;5;10m+     658[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     659[0m:[38;5;10m[49m     # Step 5c: Build phase timeline from contiguous segments.
[0m[49m[38;5;10m+     660[0m:[38;5;10m[49m     phase_timeline = []
[0m[49m[38;5;10m+     661[0m:[38;5;10m[49m     changes = np.where(np.diff(phases) != 0)[0] + 1
[0m[49m[38;5;10m+     662[0m:[38;5;10m[49m     boundaries = np.concatenate([[0], changes, [num_frames]])
[0m[49m[38;5;10m+     663[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     664[0m:[38;5;10m[49m     for i in range(len(boundaries) - 1):
[0m[49m[38;5;10m+     665[0m:[38;5;10m[49m         seg_start = boundaries[i]
[0m[49m[38;5;10m+     666[0m:[38;5;10m[49m         seg_end = boundaries[i + 1]
[0m[49m[38;5;10m+     667[0m:[38;5;10m[49m         phase_idx = int(phases[seg_start])
[0m[49m[38;5;10m+     668[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     669[0m:[38;5;10m[49m         # Average confidence across the segment.
[0m[49m[38;5;10m+     670[0m:[38;5;10m[49m         seg_confidence = float(np.mean(phase_confs[seg_start:seg_end]))
[0m[49m[38;5;10m+     671[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     672[0m:[38;5;10m[49m         phase_timeline.append({
[0m[49m[38;5;10m+     673[0m:[38;5;10m[49m             "phase_name": CHOLECYSTECTOMY_PHASES[phase_idx],
[0m[49m[38;5;10m+     674[0m:[38;5;10m[49m             "start_time": float(seg_start / SAMPLE_RATE_FPS),
[0m[49m[38;5;10m+     675[0m:[38;5;10m[49m             "end_time": float(seg_end / SAMPLE_RATE_FPS),
[0m[49m[38;5;10m+     676[0m:[38;5;10m[49m             "duration": float((seg_end - seg_start) / SAMPLE_RATE_FPS),
[0m[49m[38;5;10m+     677[0m:[38;5;10m[49m             "confidence": round(seg_confidence, 3),
[0m[49m[38;5;10m+     678[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     679[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     680[0m:[38;5;10m[49m     # Step 5d: Build instrument usage log.
[0m[49m[38;5;10m+     681[0m:[38;5;10m[49m     # For each instrument, find contiguous presence intervals.
[0m[49m[38;5;10m+     682[0m:[38;5;10m[49m     instrument_log = []
[0m[49m[38;5;10m+     683[0m:[38;5;10m[49m     inst_preds = raw_predictions["instrument_predictions"]
[0m[49m[38;5;10m+     684[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     685[0m:[38;5;10m[49m     for inst_idx, inst_name in enumerate(INSTRUMENT_CLASSES):
[0m[49m[38;5;10m+     686[0m:[38;5;10m[49m         presence = inst_preds[:, inst_idx] > 0.5
[0m[49m[38;5;10m+     687[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     688[0m:[38;5;10m[49m         # Gap-fill: brief absences are likely occlusion.
[0m[49m[38;5;10m+     689[0m:[38;5;10m[49m         gap_fill_frames = INSTRUMENT_GAP_FILL_SEC * SAMPLE_RATE_FPS
[0m[49m[38;5;10m+     690[0m:[38;5;10m[49m         filled = presence.copy()
[0m[49m[38;5;10m+     691[0m:[38;5;10m[49m         # Find gaps (False runs) shorter than threshold and fill them.
[0m[49m[38;5;10m+     692[0m:[38;5;10m[49m         in_gap = False
[0m[49m[38;5;10m+     693[0m:[38;5;10m[49m         gap_start = 0
[0m[49m[38;5;10m+     694[0m:[38;5;10m[49m         for f in range(len(filled)):
[0m[49m[38;5;10m+     695[0m:[38;5;10m[49m             if not filled[f] and not in_gap:
[0m[49m[38;5;10m+     696[0m:[38;5;10m[49m                 in_gap = True
[0m[49m[38;5;10m+     697[0m:[38;5;10m[49m                 gap_start = f
[0m[49m[38;5;10m+     698[0m:[38;5;10m[49m             elif filled[f] and in_gap:
[0m[49m[38;5;10m+     699[0m:[38;5;10m[49m                 if f - gap_start < gap_fill_frames:
[0m[49m[38;5;10m+     700[0m:[38;5;10m[49m                     filled[gap_start:f] = True
[0m[49m[38;5;10m+     701[0m:[38;5;10m[49m                 in_gap = False
[0m[49m[38;5;10m+     702[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     703[0m:[38;5;10m[49m         # Extract intervals where instrument is present.
[0m[49m[38;5;10m+     704[0m:[38;5;10m[49m         changes_inst = np.where(np.diff(filled.astype(int)) != 0)[0] + 1
[0m[49m[38;5;10m+     705[0m:[38;5;10m[49m         inst_boundaries = np.concatenate([[0], changes_inst, [num_frames]])
[0m[49m[38;5;10m+     706[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     707[0m:[38;5;10m[49m         for i in range(len(inst_boundaries) - 1):
[0m[49m[38;5;10m+     708[0m:[38;5;10m[49m             seg_start = inst_boundaries[i]
[0m[49m[38;5;10m+     709[0m:[38;5;10m[49m             seg_end = inst_boundaries[i + 1]
[0m[49m[38;5;10m+     710[0m:[38;5;10m[49m             if filled[seg_start]:
[0m[49m[38;5;10m+     711[0m:[38;5;10m[49m                 instrument_log.append({
[0m[49m[38;5;10m+     712[0m:[38;5;10m[49m                     "instrument": inst_name,
[0m[49m[38;5;10m+     713[0m:[38;5;10m[49m                     "start_time": float(seg_start / SAMPLE_RATE_FPS),
[0m[49m[38;5;10m+     714[0m:[38;5;10m[49m                     "end_time": float(seg_end / SAMPLE_RATE_FPS),
[0m[49m[38;5;10m+     715[0m:[38;5;10m[49m                     "duration": float((seg_end - seg_start) / SAMPLE_RATE_FPS),
[0m[49m[38;5;10m+     716[0m:[38;5;10m[49m                 })
[0m[49m[38;5;10m+     717[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     718[0m:[38;5;10m[49m     # Step 5e: Convert event frame indices to timestamps.
[0m[49m[38;5;10m+     719[0m:[38;5;10m[49m     events = []
[0m[49m[38;5;10m+     720[0m:[38;5;10m[49m     for event in raw_predictions["event_predictions"]:
[0m[49m[38;5;10m+     721[0m:[38;5;10m[49m         timestamp = event["frame"] / SAMPLE_RATE_FPS
[0m[49m[38;5;10m+     722[0m:[38;5;10m[49m         # Find which phase this event falls in.
[0m[49m[38;5;10m+     723[0m:[38;5;10m[49m         phase_context = "unknown"
[0m[49m[38;5;10m+     724[0m:[38;5;10m[49m         for phase in phase_timeline:
[0m[49m[38;5;10m+     725[0m:[38;5;10m[49m             if phase["start_time"] <= timestamp < phase["end_time"]:
[0m[49m[38;5;10m+     726[0m:[38;5;10m[49m                 phase_context = phase["phase_name"]
[0m[49m[38;5;10m+     727[0m:[38;5;10m[49m                 break
[0m[49m[38;5;10m+     728[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     729[0m:[38;5;10m[49m         events.append({
[0m[49m[38;5;10m+     730[0m:[38;5;10m[49m             "event_type": event["event_type"],
[0m[49m[38;5;10m+     731[0m:[38;5;10m[49m             "timestamp": float(timestamp),
[0m[49m[38;5;10m+     732[0m:[38;5;10m[49m             "confidence": event["confidence"],
[0m[49m[38;5;10m+     733[0m:[38;5;10m[49m             "phase_context": phase_context,
[0m[49m[38;5;10m+     734[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     735[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     736[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     737[0m:[38;5;10m[49m         "phase_timeline": phase_timeline,
[0m[49m[38;5;10m+     738[0m:[38;5;10m[49m         "instrument_log": instrument_log,
[0m[49m[38;5;10m+     739[0m:[38;5;10m[49m         "events": events,
[0m[49m[38;5;10m+     740[0m:[38;5;10m[49m         "total_duration": float(num_frames / SAMPLE_RATE_FPS),
[0m[49m[38;5;10m+     741[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     742[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     743[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     744[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     745[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     746[0m:[38;5;10m[49m ## Step 6: Store Results in DynamoDB and OpenSearch
[0m[49m[38;5;10m+     747[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     748[0m:[38;5;10m[49m *Maps to pseudocode Step 6: `store_results(procedure_id, analysis_results)`. The structured analysis goes to two places: DynamoDB for fast procedure-level lookups, and OpenSearch for cross-procedure search queries.*
[0m[49m[38;5;10m+     749[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     750[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     751[0m:[38;5;10m[49m import requests
[0m[49m[38;5;10m+     752[0m:[38;5;10m[49m from requests_aws4auth import AWS4Auth
[0m[49m[38;5;10m+     753[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     754[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     755[0m:[38;5;10m[49m def store_results_dynamodb(procedure_id: str, metadata: dict, analysis: dict) -> None:
[0m[49m[38;5;10m+     756[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     757[0m:[38;5;10m[49m     Write the full procedure analysis to DynamoDB.
[0m[49m[38;5;10m+     758[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     759[0m:[38;5;10m[49m     This supports the primary access pattern: "give me everything about
[0m[49m[38;5;10m+     760[0m:[38;5;10m[49m     procedure X." The phase timeline, instrument log, and events all live
[0m[49m[38;5;10m+     761[0m:[38;5;10m[49m     in a single item for fast retrieval.
[0m[49m[38;5;10m+     762[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     763[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     764[0m:[38;5;10m[49m         procedure_id: Partition key for the record.
[0m[49m[38;5;10m+     765[0m:[38;5;10m[49m         metadata: Procedure metadata (type, surgeon, date).
[0m[49m[38;5;10m+     766[0m:[38;5;10m[49m         analysis: Output from post_process_predictions().
[0m[49m[38;5;10m+     767[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     768[0m:[38;5;10m[49m     table = dynamodb.Table(PROCEDURE_INDEX_TABLE)
[0m[49m[38;5;10m+     769[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     770[0m:[38;5;10m[49m     # DynamoDB doesn't accept Python floats. Convert all numeric values to Decimal.
[0m[49m[38;5;10m+     771[0m:[38;5;10m[49m     # This is a common gotcha that will crash your Lambda at 2am if you forget.
[0m[49m[38;5;10m+     772[0m:[38;5;10m[49m     def decimalize(obj):
[0m[49m[38;5;10m+     773[0m:[38;5;10m[49m         if isinstance(obj, float):
[0m[49m[38;5;10m+     774[0m:[38;5;10m[49m             return Decimal(str(round(obj, 4)))
[0m[49m[38;5;10m+     775[0m:[38;5;10m[49m         if isinstance(obj, dict):
[0m[49m[38;5;10m+     776[0m:[38;5;10m[49m             return {k: decimalize(v) for k, v in obj.items()}
[0m[49m[38;5;10m+     777[0m:[38;5;10m[49m         if isinstance(obj, list):
[0m[49m[38;5;10m+     778[0m:[38;5;10m[49m             return [decimalize(item) for item in obj]
[0m[49m[38;5;10m+     779[0m:[38;5;10m[49m         return obj
[0m[49m[38;5;10m+     780[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     781[0m:[38;5;10m[49m     record = decimalize({
[0m[49m[38;5;10m+     782[0m:[38;5;10m[49m         "procedure_id": procedure_id,
[0m[49m[38;5;10m+     783[0m:[38;5;10m[49m         "status": "analyzed",
[0m[49m[38;5;10m+     784[0m:[38;5;10m[49m         "analyzed_at": datetime.datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+     785[0m:[38;5;10m[49m         "procedure_type": metadata["procedure_type"],
[0m[49m[38;5;10m+     786[0m:[38;5;10m[49m         "surgeon_id": metadata["surgeon_id"],
[0m[49m[38;5;10m+     787[0m:[38;5;10m[49m         "procedure_date": metadata["procedure_date"],
[0m[49m[38;5;10m+     788[0m:[38;5;10m[49m         "total_duration": analysis["total_duration"],
[0m[49m[38;5;10m+     789[0m:[38;5;10m[49m         "phase_timeline": analysis["phase_timeline"],
[0m[49m[38;5;10m+     790[0m:[38;5;10m[49m         "instrument_log": analysis["instrument_log"],
[0m[49m[38;5;10m+     791[0m:[38;5;10m[49m         "events": analysis["events"],
[0m[49m[38;5;10m+     792[0m:[38;5;10m[49m         "model_version": "cholec-phase-v2.3",
[0m[49m[38;5;10m+     793[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+     794[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     795[0m:[38;5;10m[49m     table.put_item(Item=record)
[0m[49m[38;5;10m+     796[0m:[38;5;10m[49m     logger.info("Stored analysis for procedure %s in DynamoDB", procedure_id)
[0m[49m[38;5;10m+     797[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     798[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     799[0m:[38;5;10m[49m def index_results_opensearch(procedure_id: str, metadata: dict, analysis: dict) -> None:
[0m[49m[38;5;10m+     800[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     801[0m:[38;5;10m[49m     Index the procedure analysis in OpenSearch for cross-procedure search.
[0m[49m[38;5;10m+     802[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     803[0m:[38;5;10m[49m     This supports queries like "find all procedures where bleeding occurred
[0m[49m[38;5;10m+     804[0m:[38;5;10m[49m     during Calot's triangle dissection" or "show me cases where the clipping
[0m[49m[38;5;10m+     805[0m:[38;5;10m[49m     phase took longer than 5 minutes."
[0m[49m[38;5;10m+     806[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     807[0m:[38;5;10m[49m     We index phases and events as separate documents so they're independently
[0m[49m[38;5;10m+     808[0m:[38;5;10m[49m     searchable with their own timestamps and attributes.
[0m[49m[38;5;10m+     809[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     810[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     811[0m:[38;5;10m[49m         procedure_id: Links documents back to the procedure.
[0m[49m[38;5;10m+     812[0m:[38;5;10m[49m         metadata: Procedure metadata for filtering.
[0m[49m[38;5;10m+     813[0m:[38;5;10m[49m         analysis: Output from post_process_predictions().
[0m[49m[38;5;10m+     814[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     815[0m:[38;5;10m[49m     # In production, use requests-aws4auth for SigV4 signing to the
[0m[49m[38;5;10m+     816[0m:[38;5;10m[49m     # VPC-internal OpenSearch domain. This example shows the structure.
[0m[49m[38;5;10m+     817[0m:[38;5;10m[49m     #
[0m[49m[38;5;10m+     818[0m:[38;5;10m[49m     # credentials = boto3.Session().get_credentials()
[0m[49m[38;5;10m+     819[0m:[38;5;10m[49m     # auth = AWS4Auth(
[0m[49m[38;5;10m+     820[0m:[38;5;10m[49m     #     credentials.access_key,
[0m[49m[38;5;10m+     821[0m:[38;5;10m[49m     #     credentials.secret_key,
[0m[49m[38;5;10m+     822[0m:[38;5;10m[49m     #     "us-east-1",
[0m[49m[38;5;10m+     823[0m:[38;5;10m[49m     #     "es",
[0m[49m[38;5;10m+     824[0m:[38;5;10m[49m     #     session_token=credentials.token,
[0m[49m[38;5;10m+     825[0m:[38;5;10m[49m     # )
[0m[49m[38;5;10m+     826[0m:[38;5;10m[49m     # headers = {"Content-Type": "application/json"}
[0m[49m[38;5;10m+     827[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     828[0m:[38;5;10m[49m     # Index each phase as a searchable document.
[0m[49m[38;5;10m+     829[0m:[38;5;10m[49m     for phase in analysis["phase_timeline"]:
[0m[49m[38;5;10m+     830[0m:[38;5;10m[49m         doc = {
[0m[49m[38;5;10m+     831[0m:[38;5;10m[49m             "procedure_id": procedure_id,
[0m[49m[38;5;10m+     832[0m:[38;5;10m[49m             "procedure_type": metadata["procedure_type"],
[0m[49m[38;5;10m+     833[0m:[38;5;10m[49m             "surgeon_id": metadata["surgeon_id"],
[0m[49m[38;5;10m+     834[0m:[38;5;10m[49m             "procedure_date": metadata["procedure_date"],
[0m[49m[38;5;10m+     835[0m:[38;5;10m[49m             "phase_name": phase["phase_name"],
[0m[49m[38;5;10m+     836[0m:[38;5;10m[49m             "start_time": phase["start_time"],
[0m[49m[38;5;10m+     837[0m:[38;5;10m[49m             "end_time": phase["end_time"],
[0m[49m[38;5;10m+     838[0m:[38;5;10m[49m             "duration": phase["duration"],
[0m[49m[38;5;10m+     839[0m:[38;5;10m[49m             "confidence": phase["confidence"],
[0m[49m[38;5;10m+     840[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+     841[0m:[38;5;10m[49m         # In production:
[0m[49m[38;5;10m+     842[0m:[38;5;10m[49m         # requests.post(
[0m[49m[38;5;10m+     843[0m:[38;5;10m[49m         #     f"{OPENSEARCH_DOMAIN}/procedure-phases/_doc",
[0m[49m[38;5;10m+     844[0m:[38;5;10m[49m         #     json=doc, auth=auth, headers=headers,
[0m[49m[38;5;10m+     845[0m:[38;5;10m[49m         # )
[0m[49m[38;5;10m+     846[0m:[38;5;10m[49m         logger.info("Indexed phase: %s (%.0fs)", phase["phase_name"], phase["duration"])
[0m[49m[38;5;10m+     847[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     848[0m:[38;5;10m[49m     # Index each event as a searchable document.
[0m[49m[38;5;10m+     849[0m:[38;5;10m[49m     for event in analysis["events"]:
[0m[49m[38;5;10m+     850[0m:[38;5;10m[49m         doc = {
[0m[49m[38;5;10m+     851[0m:[38;5;10m[49m             "procedure_id": procedure_id,
[0m[49m[38;5;10m+     852[0m:[38;5;10m[49m             "procedure_type": metadata["procedure_type"],
[0m[49m[38;5;10m+     853[0m:[38;5;10m[49m             "surgeon_id": metadata["surgeon_id"],
[0m[49m[38;5;10m+     854[0m:[38;5;10m[49m             "procedure_date": metadata["procedure_date"],
[0m[49m[38;5;10m+     855[0m:[38;5;10m[49m             "event_type": event["event_type"],
[0m[49m[38;5;10m+     856[0m:[38;5;10m[49m             "timestamp": event["timestamp"],
[0m[49m[38;5;10m+     857[0m:[38;5;10m[49m             "confidence": event["confidence"],
[0m[49m[38;5;10m+     858[0m:[38;5;10m[49m             "phase_context": event["phase_context"],
[0m[49m[38;5;10m+     859[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+     860[0m:[38;5;10m[49m         # In production:
[0m[49m[38;5;10m+     861[0m:[38;5;10m[49m         # requests.post(
[0m[49m[38;5;10m+     862[0m:[38;5;10m[49m         #     f"{OPENSEARCH_DOMAIN}/procedure-events/_doc",
[0m[49m[38;5;10m+     863[0m:[38;5;10m[49m         #     json=doc, auth=auth, headers=headers,
[0m[49m[38;5;10m+     864[0m:[38;5;10m[49m         # )
[0m[49m[38;5;10m+     865[0m:[38;5;10m[49m         logger.info("Indexed event: %s at %.0fs", event["event_type"], event["timestamp"])
[0m[49m[38;5;10m+     866[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     867[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+     868[0m:[38;5;10m[49m         "Indexed %d phases and %d events for procedure %s",
[0m[49m[38;5;10m+     869[0m:[38;5;10m[49m         len(analysis["phase_timeline"]),
[0m[49m[38;5;10m+     870[0m:[38;5;10m[49m         len(analysis["events"]),
[0m[49m[38;5;10m+     871[0m:[38;5;10m[49m         procedure_id,
[0m[49m[38;5;10m+     872[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     873[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     874[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     875[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     876[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     877[0m:[38;5;10m[49m ## Putting It All Together
[0m[49m[38;5;10m+     878[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     879[0m:[38;5;10m[49m Here's the full pipeline assembled into a single function. In production, each step would be a separate Lambda function orchestrated by Step Functions, with error handling and retries at each stage. This version runs sequentially to show the complete flow.
[0m[49m[38;5;10m+     880[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     881[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     882[0m:[38;5;10m[49m def analyze_surgical_video(video_s3_key: str, metadata: dict) -> dict:
[0m[49m[38;5;10m+     883[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     884[0m:[38;5;10m[49m     Run the full surgical video analysis pipeline for one procedure.
[0m[49m[38;5;10m+     885[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     886[0m:[38;5;10m[49m     In a Step Functions deployment, each step would be a separate state
[0m[49m[38;5;10m+     887[0m:[38;5;10m[49m     with its own error handling, retries, and timeout. This function
[0m[49m[38;5;10m+     888[0m:[38;5;10m[49m     shows the logical flow as a single callable.
[0m[49m[38;5;10m+     889[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     890[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     891[0m:[38;5;10m[49m         video_s3_key: S3 key of the raw surgical video.
[0m[49m[38;5;10m+     892[0m:[38;5;10m[49m         metadata: Dict with procedure_type, surgeon_id, procedure_date,
[0m[49m[38;5;10m+     893[0m:[38;5;10m[49m                   duration_seconds.
[0m[49m[38;5;10m+     894[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     895[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     896[0m:[38;5;10m[49m         The complete analysis result.
[0m[49m[38;5;10m+     897[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     898[0m:[38;5;10m[49m     print(f"\n{'='*60}")
[0m[49m[38;5;10m+     899[0m:[38;5;10m[49m     print(f"SURGICAL VIDEO ANALYSIS PIPELINE")
[0m[49m[38;5;10m+     900[0m:[38;5;10m[49m     print(f"{'='*60}")
[0m[49m[38;5;10m+     901[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     902[0m:[38;5;10m[49m     # Step 1: Register the procedure.
[0m[49m[38;5;10m+     903[0m:[38;5;10m[49m     print("\n[Step 1] Ingesting video and registering procedure...")
[0m[49m[38;5;10m+     904[0m:[38;5;10m[49m     procedure_id = ingest_video(video_s3_key, metadata)
[0m[49m[38;5;10m+     905[0m:[38;5;10m[49m     print(f"  Procedure ID: {procedure_id}")
[0m[49m[38;5;10m+     906[0m:[38;5;10m[49m     print(f"  Type: {metadata['procedure_type']}")
[0m[49m[38;5;10m+     907[0m:[38;5;10m[49m     print(f"  Duration: {metadata['duration_seconds']}s ({metadata['duration_seconds']/60:.1f} min)")
[0m[49m[38;5;10m+     908[0m:[38;5;10m[49m 
