[0m[49m[38;5;10m+     972[0m:[38;5;10m[49m if __name__ == "__main__":
[0m[49m[38;5;10m+     973[0m:[38;5;10m[49m     result = analyze_surgical_video(
[0m[49m[38;5;10m+     974[0m:[38;5;10m[49m         video_s3_key="uploads/2026-05-15/OR3-cholecystectomy-morning.mp4",
[0m[49m[38;5;10m+     975[0m:[38;5;10m[49m         metadata={
[0m[49m[38;5;10m+     976[0m:[38;5;10m[49m             "procedure_type": "laparoscopic_cholecystectomy",
[0m[49m[38;5;10m+     977[0m:[38;5;10m[49m             "surgeon_id": "surgeon-dr-chen",
[0m[49m[38;5;10m+     978[0m:[38;5;10m[49m             "procedure_date": "2026-05-15",
[0m[49m[38;5;10m+     979[0m:[38;5;10m[49m             "duration_seconds": 2847,  # ~47 minutes
[0m[49m[38;5;10m+     980[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+     981[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     982[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     983[0m:[38;5;10m[49m     # Pretty-print the analysis result.
[0m[49m[38;5;10m+     984[0m:[38;5;10m[49m     print(json.dumps(result["analysis"], indent=2, default=str))
