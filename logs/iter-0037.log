[0m[48;2;40;67;43m[39m+     3[0m:[39m[48;2;24;38;30m [38;2;235;203;139m**[38;2;235;203;139mReviewed by:[38;2;235;203;139m**[38;2;192;197;206m Technical Expert Panel (Security, Architecture, Networking, Voice)[K
[0m[48;2;40;67;43m[39m+     4[0m:[39m[48;2;24;38;30m [38;2;235;203;139m**[38;2;235;203;139mDate:[38;2;235;203;139m**[38;2;192;197;206m 2026-05-15[K
[0m[48;2;40;67;43m[39m+     5[0m:[39m[48;2;24;38;30m [38;2;235;203;139m**[38;2;235;203;139mRecipe file:[38;2;235;203;139m**[38;2;192;197;206m [38;2;163;190;140m`[38;2;163;190;140mchapter03.08-readmission-risk-anomaly-detection.md[38;2;163;190;140m`[K
[0m[48;2;40;67;43m[39m+     6[0m:[39m[48;2;24;38;30m [K
