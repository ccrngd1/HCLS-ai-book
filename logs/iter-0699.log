[0m[49m[39m  367, 410[0m:[39m[49m             // Financial counselor outreach for larger balances.
[0m[49m[39m  368, 411[0m:[39m[49m             IF amount > 500:
[0m[49m[39m  369, 412[0m:[39m[49m                 route_to_queue("financial_counselor_outreach", balance_id)
[0m[49m[39m  370, 413[0m:[39m[49m             ELSE:
[0m[49m[39m  371, 414[0m:[39m[49m                 route_to_queue("payment_plan_offer", balance_id)
[0m[49m[39m  372, 415[0m:[39m[49m 
[0m[49m[39m  373, 416[0m:[39m[49m         ELSE:
[0m[49m[39m  374, 417[0m:[39m[49m             // Low propensity: likely unable to pay.
[0m[49m[39m  375, 418[0m:[39m[49m             // Screen for financial assistance eligibility early.
