[0m[49m[38;5;10m+      395[0m:[38;5;10m[49m         // strategy rather than relying on a weak prediction.
[0m[49m[38;5;10m+      396[0m:[38;5;10m[49m         IF prediction.cold_start == true:
[0m[49m[38;5;10m+      397[0m:[38;5;10m[49m             route_to_queue("new_patient_default", balance_id)
[0m[49m[38;5;10m+      398[0m:[38;5;10m[49m             log_decision(balance_id, patient_id, score, "new_patient_default")
[0m[49m[38;5;10m+      399[0m:[38;5;10m[49m             CONTINUE
[0m[49m[38;5;10m+      400[0m:[38;5;10m[49m 
[0m[49m[39m  358, 401[0m:[39m[49m         IF score >= HIGH_THRESHOLD:
[0m[49m[39m  359, 402[0m:[39m[49m             // High propensity: standard statement cadence.
[0m[49m[39m  360, 403[0m:[39m[49m             // These patients typically pay without special intervention.
[0m[49m[39m  361, 404[0m:[39m[49m             // Don't waste outreach resources here.
