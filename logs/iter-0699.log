[0m[49m[39m  349, 385[0m:[39m[49m 
[0m[49m[39m  350, 386[0m:[39m[49m FUNCTION apply_collection_strategy(balance_predictions):
[0m[49m[39m  351, 387[0m:[39m[49m     // Read today's predictions and route each balance to the right queue.
[0m[49m[39m  352, 388[0m:[39m[49m     FOR each prediction in balance_predictions:
[0m[49m[39m  353, 389[0m:[39m[49m         score      = prediction.propensity_score
[0m[49m[39m  354, 390[0m:[39m[49m         balance_id = prediction.balance_id
[0m[49m[39m  355, 391[0m:[39m[49m         patient_id = prediction.patient_id
[0m[49m[39m  356, 392[0m:[39m[49m         amount     = prediction.balance_amount
[0m[49m[39m  357, 393[0m:[39m[49m 
