[0m[49m[39m  295, 312[0m:[39m[49m     raw_predictions = score_with_model(job.model_artifact, calibration_set)
[0m[49m[39m  296, 313[0m:[39m[49m     calibration_model = fit_platt_scaling(raw_predictions, calibration_set.labels)
[0m[49m[39m  297, 314[0m:[39m[49m 
