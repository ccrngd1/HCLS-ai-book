[0m[49m[38;5;10m+      342[0m:[38;5;10m[49m         output_path:            "s3://ml-data/predictions/propensity-to-pay/{date}/",
[0m[49m[38;5;10m+      343[0m:[38;5;10m[49m         instance_type:          "ml.m5.xlarge",
[0m[49m[38;5;10m+      344[0m:[38;5;10m[49m         instance_count:         1,
[0m[49m[38;5;10m+      345[0m:[38;5;10m[49m         content_type:           "text/csv",
