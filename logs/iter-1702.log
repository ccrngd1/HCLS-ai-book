[0m[49m[38;5;10m+      879[0m:[38;5;10m[49m     IF reviewer_alias IN get_conflict_of_interest_list(candidate_pair_id):
[0m[49m[38;5;10m+      880[0m:[38;5;10m[49m         REJECT "reviewer has conflict of interest"
[0m[49m[38;5;10m+      881[0m:[38;5;10m[49m 
