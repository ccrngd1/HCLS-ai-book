[0m[49m[38;5;10m+      848[0m:[38;5;10m[49m ```pseudocode
[0m[49m[38;5;10m+      849[0m:[38;5;10m[49m // Real-time onboarding event validation:
[0m[49m[38;5;10m+      850[0m:[38;5;10m[49m FUNCTION validate_onboarding_event(event):
[0m[49m[38;5;10m+      851[0m:[38;5;10m[49m     // The event envelope must carry a producer signature:
[0m[49m[38;5;10m+      852[0m:[38;5;10m[49m     // source_system, source_record_id, event_id, signed_payload.
[0m[49m[38;5;10m+      853[0m:[38;5;10m[49m     // The candidate-generator Lambda validates the signature
[0m[49m[38;5;10m+      854[0m:[38;5;10m[49m     // against the producing system's registered signing key
[0m[49m[38;5;10m+      855[0m:[38;5;10m[49m     // before processing.
[0m[49m[38;5;10m+      856[0m:[38;5;10m[49m     IF NOT verify_envelope_signature(event.signed_payload,
[0m[49m[38;5;10m+      857[0m:[38;5;10m[49m                                       event.source_system):
[0m[49m[38;5;10m+      858[0m:[38;5;10m[49m         log_metric("InvalidEnvelopeSignature", 1)
[0m[49m[38;5;10m+      859[0m:[38;5;10m[49m         REJECT event
[0m[49m[38;5;10m+      860[0m:[38;5;10m[49m     RETURN event.payload
[0m[49m[38;5;10m+      861[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      862[0m:[38;5;10m[49m // attach_npi caller validation:
[0m[49m[38;5;10m+      863[0m:[38;5;10m[49m FUNCTION validate_attach_caller(decision_metadata):
[0m[49m[38;5;10m+      864[0m:[38;5;10m[49m     // The decision_metadata.invocation_source must match the
[0m[49m[38;5;10m+      865[0m:[38;5;10m[49m     // calling Lambda's execution role. Accepted sources:
[0m[49m[38;5;10m+      866[0m:[38;5;10m[49m     //   auto_attach_pipeline, review_queue_decision, batch_match_pipeline
[0m[49m[38;5;10m+      867[0m:[38;5;10m[49m     allowed_sources = get_allowed_sources_for_role(current_execution_role)
[0m[49m[38;5;10m+      868[0m:[38;5;10m[49m     IF decision_metadata.invocation_source NOT IN allowed_sources:
[0m[49m[38;5;10m+      869[0m:[38;5;10m[49m         log_metric("AttachCallerMismatch", 1)
[0m[49m[38;5;10m+      870[0m:[38;5;10m[49m         REJECT "invocation_source does not match execution role"
[0m[49m[38;5;10m+      871[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      872[0m:[38;5;10m[49m // Review-queue decision validation:
[0m[49m[38;5;10m+      873[0m:[38;5;10m[49m FUNCTION validate_review_decision(reviewer_alias, candidate_pair_id):
[0m[49m[38;5;10m+      874[0m:[38;5;10m[49m     // The named reviewer must have the pair in their assigned queue
[0m[49m[38;5;10m+      875[0m:[38;5;10m[49m     // and must not be in the conflict-of-interest list.
[0m[49m[38;5;10m+      876[0m:[38;5;10m[49m     assigned_pairs = get_assigned_queue(reviewer_alias)
[0m[49m[38;5;10m+      877[0m:[38;5;10m[49m     IF candidate_pair_id NOT IN assigned_pairs:
