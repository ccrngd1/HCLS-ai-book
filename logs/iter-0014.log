[0m[48;2;40;67;43m[39m+    415[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAmazon S3[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m Hosts raw address extracts, standardized records, household-membership tables, geocode cache, SDOH-joined records, and drift archives [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    416[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAmazon DynamoDB[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m Stores the current standardized address per patient per role ([38;2;163;190;140m`[38;2;163;190;140mpatient-address[38;2;163;190;140m`[38;2;192;197;206m) and the patient-to-household mappings ([38;2;163;190;140m`[38;2;163;190;140mhousehold-membership[38;2;163;190;140m`[38;2;192;197;206m) for low-latency real-time access [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    417[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAWS Lambda[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m Per-record standardization on registration-time events, household-inference for affected groups on address change, drift-detection on refresh cycles, real-time API handler [38;2;192;197;206m|[K
