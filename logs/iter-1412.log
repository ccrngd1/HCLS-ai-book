[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m         "severity": "alert",
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m         "message": "Multi-parameter pattern consistent with cardiac decompensation",
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m         "recommended": "Cardiac assessment. Consider BNP, echocardiogram, diuretic adjustment.",
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m ## Mocks for Local Demonstration
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m These mocks replace real AWS services so you can run the full pipeline locally. In production, swap each mock for its real boto3 client call.
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m # --- In-Memory Mocks ---
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m # These simulate AWS services for local execution.
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m class MockKinesis:
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m     """Simulates Kinesis PutRecord. Stores events in a list."""
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m     def __init__(self):
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m         self.records = []
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m     def put_record(self, StreamName, Data, PartitionKey):
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m         self.records.append({
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m             "StreamName": StreamName,
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m             "Data": json.loads(Data),
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m             "PartitionKey": PartitionKey,
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m         return {"ShardId": "shard-0001", "SequenceNumber": str(len(self.records))}
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m class MockDynamoDB:
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m     """Simulates DynamoDB GetItem/PutItem against an in-memory dict."""
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m     def __init__(self):
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m         self.items = {}
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m     def get_item(self, TableName, Key):
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m         pk = Key.get("patient_id", {}).get("S", "")
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m         if pk in self.items:
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m             return {"Item": self.items[pk]}
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m         return {}
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m     def put_item(self, TableName, Item):
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m         pk = Item.get("patient_id", {}).get("S", "")
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m         self.items[pk] = Item
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m         return {}
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m class MockTimestream:
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m     """Simulates Timestream WriteRecords. Stores records in a list."""
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m     def __init__(self):
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m         self.records = []
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m     def write_records(self, DatabaseName, TableName, Records, CommonAttributes):
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m         for record in Records:
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m             self.records.append({**CommonAttributes, **record})
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m         return {"RecordsIngested": {"Total": len(Records)}}
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m class MockSNS:
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m     """Simulates SNS Publish. Stores messages in a list."""
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m     def __init__(self):
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m         self.messages = []
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m     def publish(self, TopicArn, Message, Subject, MessageAttributes=None):
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m         self.messages.append({
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m             "TopicArn": TopicArn,
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m             "Subject": Subject,
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m             "Message": json.loads(Message),
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m         return {"MessageId": str(uuid.uuid4())}
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m # Instantiate mocks for the demo.
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m mock_kinesis = MockKinesis()
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m mock_dynamodb = MockDynamoDB()
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m mock_timestream = MockTimestream()
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m mock_sns = MockSNS()
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m ## Step 1: Ingest Vital Sign Event
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m *The pseudocode calls this `ingest_vital_sign(source_event)`. It normalizes an incoming reading from any source into a standard event format and writes it to the streaming layer, partitioned by patient ID.*
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m def ingest_vital_sign(source_event: dict) -> dict:
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m     Normalize an incoming vital sign reading and write it to the stream.
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m     Different sources send data in wildly different shapes. A bedside monitor
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m     sends numeric arrays every second. A nurse's EHR entry sends a single
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m     observation with free-text context. This function unifies them into one
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m     consistent format so downstream processing never has to worry about source
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m     variability.
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m         source_event: Raw event from any source (monitor, EHR, device).
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m             Expected keys: patient_id, timestamp (ISO string or datetime),
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m             parameter (HR, SBP, DBP, RR, SpO2, Temp), value (numeric),
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m             source_type, measurement_method (optional).
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m         The normalized event dict that was placed onto the stream.
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m     # Normalize timestamp to UTC ISO-8601.
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m     ts = source_event.get("timestamp")
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m     if isinstance(ts, datetime):
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m         ts_iso = ts.astimezone(timezone.utc).isoformat()
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m         ts_iso = ts  # assume already ISO string
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m     normalized = {
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m         "patient_id": source_event["patient_id"],
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m         "timestamp": ts_iso,
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m         "parameter": source_event["parameter"],
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m         "value": float(source_event["value"]),
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m         "source_type": source_event.get("source_type", "nursing_assessment"),
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m         "measurement_method": source_event.get("measurement_method", "non_invasive"),
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m         "confidence": source_event.get("confidence", 1.0),
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     # Write to Kinesis, partitioned by patient_id so all readings
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m     # for one patient arrive at the same shard in order.
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m     mock_kinesis.put_record(
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m         StreamName=KINESIS_STREAM_NAME,
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m         Data=json.dumps(normalized),
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m         PartitionKey=normalized["patient_id"],
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m         "Ingested %s reading for patient %s",
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m         normalized["parameter"],
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m         normalized["patient_id"],
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m     return normalized
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m ## Step 2: Retrieve and Update Patient State
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m *The pseudocode calls this `update_patient_state(vital_event)`. It fetches the patient's rolling state from DynamoDB, updates baselines using an exponential moving average, and appends the new reading to the per-parameter rolling window.*
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m # In-memory patient state store for the demo. In production, this is DynamoDB.
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m PATIENT_STATES = {}
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m # Maximum readings to keep in the rolling window per parameter.
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m MAX_WINDOW_SIZE = 60  # covers ~60 minutes of 1-min data or ~10 hours of q10min data
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m def update_patient_state(vital_event: dict) -> dict:
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m     Retrieve the patient's current state, update baselines and rolling window.
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m     The patient state holds everything we need to compute trajectories:
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m     - baselines: per-parameter EMA mean and rolling std
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m     - last_readings: per-parameter window of recent (value, timestamp) tuples
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m     - alert_history: recent alerts for cooldown logic
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m     - baseline_stable: whether we have enough history to trust our baselines
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m         vital_event: Normalized vital sign event from Step 1.
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m         The updated patient state dict.
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m     pid = vital_event["patient_id"]
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m     param = vital_event["parameter"]
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m     value = vital_event["value"]
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m     ts = datetime.fromisoformat(vital_event["timestamp"])
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m     # Fetch or initialize state.
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m     if pid not in PATIENT_STATES:
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m         PATIENT_STATES[pid] = {
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m             "patient_id": pid,
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m             "admitted_at": ts,
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m             "baselines": {},
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m             "last_readings": defaultdict(list),
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m             "alert_history": [],
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m             "baseline_stable": False,
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m     state = PATIENT_STATES[pid]
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m     # Append to rolling window for this parameter.
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m     state["last_readings"][param].append({"value": value, "timestamp": ts})
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m     # Trim window to max size.
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m     if len(state["last_readings"][param]) > MAX_WINDOW_SIZE:
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m         state["last_readings"][param] = state["last_readings"][param][-MAX_WINDOW_SIZE:]
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m     # Update baseline using exponential moving average.
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m     # Alpha = 0.05 means the baseline moves slowly, resisting short-term spikes.
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m     if param in state["baselines"]:
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m         old_mean = state["baselines"][param]["mean"]
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m         old_std = state["baselines"][param]["std"]
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m         state["baselines"][param]["mean"] = (
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m             (1 - BASELINE_ALPHA) * old_mean + BASELINE_ALPHA * value
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m         deviation = abs(value - state["baselines"][param]["mean"])
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m         state["baselines"][param]["std"] = (
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m             (1 - BASELINE_ALPHA) * old_std + BASELINE_ALPHA * deviation
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m         state["baselines"][param] = {"mean": value, "std": 0.0}
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m     # Check if baseline has stabilized (4+ hours of data).
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m     hours_since_admission = (ts - state["admitted_at"]).total_seconds() / 3600.0
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m     if hours_since_admission >= BASELINE_STABILIZATION_HOURS:
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m         state["baseline_stable"] = True
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m     return state
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m ## Step 3: Compute Trajectory Features
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m *The pseudocode calls this `compute_trajectory(state, parameter)`. It computes slope via linear regression, acceleration as the change in slope between the early and late halves of the window, deviation from baseline in standard deviations, and variability as the coefficient of variation.*
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m def _linear_regression_slope(times: list, values: list) -> float:
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m     Compute the slope of a simple linear regression (least-squares fit).
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m     This is the core math for trajectory estimation. The slope tells us
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m     the rate of change in units-per-minute.
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m     Uses the closed-form formula: slope = (n*sum(xy) - sum(x)*sum(y)) /
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m                                           (n*sum(x^2) - (sum(x))^2)
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m         times: List of time offsets in minutes from the first reading.
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m         values: List of corresponding vital sign values.
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m         Slope in units-per-minute. Positive = rising, negative = falling.
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m     n = len(times)
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m     if n < 2:
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m         return 0.0
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m     sum_x = sum(times)
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m     sum_y = sum(values)
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m     sum_xy = sum(t * v for t, v in zip(times, values))
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m     sum_x2 = sum(t * t for t in times)
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m     denominator = n * sum_x2 - sum_x * sum_x
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m     if denominator == 0:
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m         return 0.0
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m     return (n * sum_xy - sum_x * sum_y) / denominator
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m def compute_trajectory(state: dict, parameter: str) -> dict:
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m     Compute trajectory features for a single vital sign parameter.
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m     Returns slope (units/min), acceleration (change in slope), deviation
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m     from patient baseline (in sigma), and variability (coefficient of variation).
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m         state: The patient's current state dict.
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m         parameter: Which vital sign to analyze (HR, SBP, etc.)
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m         Trajectory dict with slope, acceleration, deviation, variability,
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m         current value, baseline, and window duration.
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m         Returns None if insufficient data.
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m     readings = state["last_readings"].get(parameter, [])
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m     if len(readings) < 3:
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m         return None  # Not enough data for trajectory estimation.
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m     # Build time and value arrays.
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m     t0 = readings[0]["timestamp"]
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m     times = [(r["timestamp"] - t0).total_seconds() / 60.0 for r in readings]
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m     values = [r["value"] for r in readings]
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m     # Overall slope via linear regression.
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m     slope = _linear_regression_slope(times, values)
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m     # Acceleration: compare slope of first half vs second half.
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m     mid = len(readings) // 2
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m     early_slope = _linear_regression_slope(times[:mid], values[:mid])
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m     late_slope = _linear_regression_slope(times[mid:], values[mid:])
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m     acceleration = late_slope - early_slope
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m     # Deviation from patient-specific baseline (in standard deviations).
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m     current_value = values[-1]
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m     baseline = state["baselines"].get(parameter, {"mean": current_value, "std": 1.0})
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m     baseline_mean = baseline["mean"]
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m     baseline_std = baseline["std"]
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m     if baseline_std > 0:
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m         deviation = (current_value - baseline_mean) / baseline_std
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m         deviation = 0.0
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m     # Variability: coefficient of variation over the window.
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m     window_mean = mean(values) if values else 0
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m     window_std = stdev(values) if len(values) >= 2 else 0
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m     variability = window_std / window_mean if window_mean > 0 else 0
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m     window_minutes = times[-1] if times else 0
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m         "parameter": parameter,
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m         "slope": slope,
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m         "acceleration": acceleration,
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m         "deviation": deviation,
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m         "variability": variability,
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m         "current": current_value,
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m         "baseline": baseline_mean,
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m         "window_minutes": window_minutes,
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m ## Step 4: Multi-Parameter Correlation Check
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m *The pseudocode calls this `check_multi_parameter_patterns(all_trajectories)`. It checks whether the current set of trajectories matches any known deterioration signature by evaluating the direction conditions for required and supporting parameters.*
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m def _check_condition(trajectory: dict, condition: str) -> bool:
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m     Evaluate whether a trajectory meets a condition string.
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m     Conditions:
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m       - "rising": slope > 0 (parameter is increasing)
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m       - "falling": slope < 0 (parameter is decreasing)
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m       - "deviating": absolute deviation > 1.5 sigma from baseline
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m         trajectory: Trajectory dict from compute_trajectory().
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m         condition: One of "rising", "falling", "deviating".
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m         True if the condition is met.
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m     if trajectory is None:
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m         return False
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m     if condition == "rising":
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m         return trajectory["slope"] > 0
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m     elif condition == "falling":
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m         return trajectory["slope"] < 0
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m     elif condition == "deviating":
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m         return abs(trajectory["deviation"]) > 1.5
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m     return False
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m def check_multi_parameter_patterns(all_trajectories: dict) -> list:
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m     Check all trajectories against known deterioration signatures.
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m     This is where multi-parameter correlation dramatically improves
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m     specificity. Instead of alerting on "HR trending up" alone, we alert
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m     on "HR trending up AND RR trending up AND SBP trending down," which
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m     matches the early sepsis signature.
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m         all_trajectories: Dict mapping parameter name to trajectory dict.
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m         List of matched pattern dicts, each containing pattern name,
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m         severity, clinical message, and evidence.
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m     matched = []
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m     for pattern_name, signature in DETERIORATION_SIGNATURES.items():
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m         required_met = 0
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m         supporting_met = 0
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m         # Check required conditions.
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m         for param, condition in signature["required"].items():
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m             traj = all_trajectories.get(param)
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m             if _check_condition(traj, condition):
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m                 required_met += 1
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m         # Check supporting conditions.
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m         for param, condition in signature["supporting"].items():
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m             traj = all_trajectories.get(param)
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m             if _check_condition(traj, condition):
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m                 supporting_met += 1
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m         # Pattern matches if minimum thresholds are met.
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m         if (required_met >= signature["min_required"]
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m                 and supporting_met >= signature["min_supporting"]):
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m             matched.append({
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m                 "pattern": pattern_name,
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m                 "severity": signature["severity"],
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m                 "message": signature["message"],
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m                 "recommended": signature["recommended"],
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m                 "evidence": {
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m                     "required_met": required_met,
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m                     "supporting_met": supporting_met,
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m                 },
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m     return matched
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m ## Step 5: Alert Evaluation and Suppression
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m *The pseudocode calls this `evaluate_alert(patient_state, trajectories, pattern_matches)`. It applies suppression logic: baseline stabilization check, cooldown period, medication effects, and artifact detection. Only alerts that pass all gates fire.*
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m def evaluate_alert(
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m     patient_state: dict,
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m     all_trajectories: dict,
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m     pattern_matches: list,
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m     Decide whether to fire, suppress, or downgrade an alert.
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m     This is arguably the most important function in the pipeline.
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m     A technically correct alert that fires too often is worse than
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m     no alert at all because clinical staff will ignore the entire system.
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m     Suppression reasons:
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m     - Baseline not yet stable (first hours of admission)
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m     - Same pattern alerted within cooldown window
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m     - Probable measurement artifact (high variability in a very short window)
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m         patient_state: Current patient state dict.
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m         all_trajectories: Dict of parameter -> trajectory dict.
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m         pattern_matches: List of matched deterioration patterns from Step 4.
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m         Decision dict with "action" (none, suppress, watch, alert, alarm)
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m         and supporting details.
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m     now = datetime.now(timezone.utc)
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m     # Suppression check 1: baseline not yet stable.
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m     if not patient_state.get("baseline_stable", False):
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m         return {"action": "suppress", "reason": "Baseline still stabilizing"}
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m     # Suppression check 2: recent alert cooldown.
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m     if pattern_matches:
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m         for recent_alert in patient_state.get("alert_history", []):
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m             if recent_alert.get("pattern") == pattern_matches[0]["pattern"]:
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m                 elapsed = (now - recent_alert["timestamp"]).total_seconds() / 60.0
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m                 if elapsed < ALERT_COOLDOWN_MINUTES:
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m                     return {
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m                         "action": "suppress",
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m                         "reason": f"Same alert within {ALERT_COOLDOWN_MINUTES}min cooldown",
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m                     }
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m     # Suppression check 3: artifact detection.
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m     # If any parameter has very high variability in a window under 2 minutes,
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m     # it's likely a measurement artifact (probe slip, patient movement).
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m     for param, traj in all_trajectories.items():
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m         if traj is None:
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m         if (traj["variability"] > ARTIFACT_VARIABILITY_THRESHOLD
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m                 and traj["window_minutes"] < 2):
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m             return {"action": "suppress", "reason": f"Probable artifact in {param}"}
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m     # Multi-parameter pattern detected: use the pattern's severity.
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m     if pattern_matches:
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m         # Use the highest severity among matched patterns.
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m         severities = {"watch": 0, "alert": 1, "alarm": 2}
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m         best = max(pattern_matches, key=lambda p: severities.get(p["severity"], 0))
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m             "action": best["severity"],
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m             "patterns": pattern_matches,
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m             "trajectories": all_trajectories,
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m     # No multi-parameter pattern. Check for single-parameter deviation.
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m     for param, traj in all_trajectories.items():
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m         if traj is None:
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m         threshold = SLOPE_THRESHOLDS.get(param, 0.05)
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m         if (abs(traj["deviation"]) > SINGLE_PARAM_DEVIATION_THRESHOLD
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m                 and abs(traj["slope"]) > threshold):
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m             return {
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m                 "action": "watch",
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m                 "reason": f"{param} deviating {traj['deviation']:.1f} sigma with slope {traj['slope']:.4f}/min",
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m                 "trajectories": all_trajectories,
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m     return {"action": "none"}
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m ## Step 6: Persist Trajectory Metrics and Route Alerts
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m *The pseudocode calls this `persist_and_route(patient_state, trajectories, alert_decision)`. It stores all trajectory metrics in Timestream (regardless of alert status) and routes active alerts to SNS for clinical delivery.*
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m def persist_and_route(
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m     patient_state: dict,
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m     all_trajectories: dict,
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m     alert_decision: dict,
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m ) -> None:
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m     Store trajectory metrics in Timestream and route alerts via SNS.
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m     Every trajectory computation is stored for retrospective analysis,
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m     even when no alert fires. The "show me this patient's trajectories
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m     for the 12 hours before the code" query is one of the most valuable
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m     uses of this data.
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m         patient_state: Current patient state dict.
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m         all_trajectories: Dict of parameter -> trajectory dict.
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m         alert_decision: Decision dict from evaluate_alert().
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m     pid = patient_state["patient_id"]
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m     now = datetime.now(timezone.utc)
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m     now_ms = str(int(now.timestamp() * 1000))
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m     # --- Persist to Timestream (always) ---
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m     timestream_records = []
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m     for param, traj in all_trajectories.items():
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m         if traj is None:
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m         timestream_records.append({
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m             "Dimensions": [
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m                 {"Name": "patient_id", "Value": pid},
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m                 {"Name": "parameter", "Value": param},
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m             ],
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m             "MeasureName": "trajectory",
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m             "MeasureValues": [
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m                 {"Name": "slope", "Value": f"{traj['slope']:.6f}", "Type": "DOUBLE"},
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m                 {"Name": "acceleration", "Value": f"{traj['acceleration']:.6f}", "Type": "DOUBLE"},
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m                 {"Name": "deviation", "Value": f"{traj['deviation']:.2f}", "Type": "DOUBLE"},
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m                 {"Name": "variability", "Value": f"{traj['variability']:.4f}", "Type": "DOUBLE"},
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m                 {"Name": "current", "Value": f"{traj['current']:.1f}", "Type": "DOUBLE"},
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m                 {"Name": "baseline", "Value": f"{traj['baseline']:.1f}", "Type": "DOUBLE"},
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m             ],
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m             "MeasureValueType": "MULTI",
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m             "Time": now_ms,
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m             "TimeUnit": "MILLISECONDS",
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m     if timestream_records:
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m         mock_timestream.write_records(
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m             DatabaseName=TIMESTREAM_DB_NAME,
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m             TableName=TIMESTREAM_TABLE_NAME,
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m             Records=timestream_records,
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m             CommonAttributes={},
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m     # --- Route alerts ---
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m     action = alert_decision.get("action", "none")
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m     if action in ("none", "suppress"):
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m         logger.info("Patient %s: %s (%s)", pid, action,
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m                     alert_decision.get("reason", ""))
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m         return
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m     if action == "watch":
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m         # Update patient dashboard status. No active paging.
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m         logger.info("Patient %s: WATCH - %s", pid, alert_decision.get("reason", ""))
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m         return
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m     if action in ("alert", "alarm"):
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m         # Build the alert payload for clinical delivery via SNS.
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m         patterns = alert_decision.get("patterns", [])
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m         primary_pattern = patterns[0] if patterns else {}
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m         # Format trajectories for clinical display.
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m         traj_display = {}
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m         for param, traj in all_trajectories.items():
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m             if traj is None:
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m             traj_display[param] = {
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m                 "current": round(traj["current"], 1),
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m                 "baseline": round(traj["baseline"], 1),
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m                 "slope_per_hour": round(traj["slope"] * 60, 2),
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m                 "deviation_sigma": round(traj["deviation"], 1),
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m                 "window_hours": round(traj["window_minutes"] / 60, 1),
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m         alert_payload = {
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m             "patient_id": pid,
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m             "alert_timestamp": now.isoformat(),
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m             "severity": action,
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m             "pattern": primary_pattern.get("pattern", "single_parameter"),
[0m[49m[38;5;10m+    717[0m:[38;5;10m[49m             "summary": primary_pattern.get("message", alert_decision.get("reason", "")),
[0m[49m[38;5;10m+    718[0m:[38;5;10m[49m             "recommended_action": primary_pattern.get("recommended", "Assess patient."),
[0m[49m[38;5;10m+    719[0m:[38;5;10m[49m             "trajectories": traj_display,
[0m[49m[38;5;10m+    720[0m:[38;5;10m[49m             "alert_id": f"ALT-{now.strftime('%Y%m%d-%H%M%S')}-{pid.replace('-', '')}",
[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m         mock_sns.publish(
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m             TopicArn=SNS_TOPIC_ARN,
[0m[49m[38;5;10m+    725[0m:[38;5;10m[49m             Subject=f"[{action.upper()}] Trajectory alert: {pid}",
[0m[49m[38;5;10m+    726[0m:[38;5;10m[49m             Message=json.dumps(alert_payload, indent=2),
[0m[49m[38;5;10m+    727[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    728[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    729[0m:[38;5;10m[49m         # Record in alert history for cooldown logic.
[0m[49m[38;5;10m+    730[0m:[38;5;10m[49m         patient_state["alert_history"].append({
[0m[49m[38;5;10m+    731[0m:[38;5;10m[49m             "pattern": primary_pattern.get("pattern"),
[0m[49m[38;5;10m+    732[0m:[38;5;10m[49m             "timestamp": now,
[0m[49m[38;5;10m+    733[0m:[38;5;10m[49m             "severity": action,
[0m[49m[38;5;10m+    734[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    735[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    736[0m:[38;5;10m[49m         logger.info(
[0m[49m[38;5;10m+    737[0m:[38;5;10m[49m             "Patient %s: %s fired - %s",
[0m[49m[38;5;10m+    738[0m:[38;5;10m[49m             pid, action.upper(), primary_pattern.get("pattern", ""),
[0m[49m[38;5;10m+    739[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    740[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    741[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    742[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    743[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    744[0m:[38;5;10m[49m ## Putting It All Together
[0m[49m[38;5;10m+    745[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    746[0m:[38;5;10m[49m Here is the full pipeline assembled into a single function that processes one vital sign event end-to-end.
[0m[49m[38;5;10m+    747[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    748[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    749[0m:[38;5;10m[49m def process_vital_sign(source_event: dict) -> dict:
[0m[49m[38;5;10m+    750[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    751[0m:[38;5;10m[49m     Run the full vital sign trajectory pipeline for one incoming reading.
[0m[49m[38;5;10m+    752[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    753[0m:[38;5;10m[49m     In production, this function would be invoked by a Lambda triggered
[0m[49m[38;5;10m+    754[0m:[38;5;10m[49m     from Kinesis (for intermittent floor data) or embedded in a Flink
[0m[49m[38;5;10m+    755[0m:[38;5;10m[49m     application (for continuous ICU data).
[0m[49m[38;5;10m+    756[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    757[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    758[0m:[38;5;10m[49m         source_event: Raw vital sign event from any source.
[0m[49m[38;5;10m+    759[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    760[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    761[0m:[38;5;10m[49m         The alert decision dict (action, reason, trajectories if relevant).
[0m[49m[38;5;10m+    762[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    763[0m:[38;5;10m[49m     # Step 1: Normalize and ingest.
[0m[49m[38;5;10m+    764[0m:[38;5;10m[49m     normalized = ingest_vital_sign(source_event)
[0m[49m[38;5;10m+    765[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    766[0m:[38;5;10m[49m     # Step 2: Update patient state (baselines, rolling window).
[0m[49m[38;5;10m+    767[0m:[38;5;10m[49m     state = update_patient_state(normalized)
[0m[49m[38;5;10m+    768[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    769[0m:[38;5;10m[49m     # Step 3: Compute trajectory for the parameter that just arrived,
[0m[49m[38;5;10m+    770[0m:[38;5;10m[49m     # plus any other parameters with recent data (for correlation).
[0m[49m[38;5;10m+    771[0m:[38;5;10m[49m     all_trajectories = {}
[0m[49m[38;5;10m+    772[0m:[38;5;10m[49m     for param in state["last_readings"]:
[0m[49m[38;5;10m+    773[0m:[38;5;10m[49m         traj = compute_trajectory(state, param)
[0m[49m[38;5;10m+    774[0m:[38;5;10m[49m         if traj is not None:
[0m[49m[38;5;10m+    775[0m:[38;5;10m[49m             all_trajectories[param] = traj
[0m[49m[38;5;10m+    776[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    777[0m:[38;5;10m[49m     # Step 4: Check multi-parameter patterns.
[0m[49m[38;5;10m+    778[0m:[38;5;10m[49m     pattern_matches = check_multi_parameter_patterns(all_trajectories)
[0m[49m[38;5;10m+    779[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    780[0m:[38;5;10m[49m     # Step 5: Evaluate alert with suppression logic.
[0m[49m[38;5;10m+    781[0m:[38;5;10m[49m     alert_decision = evaluate_alert(state, all_trajectories, pattern_matches)
[0m[49m[38;5;10m+    782[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    783[0m:[38;5;10m[49m     # Step 6: Persist trajectory metrics and route alerts.
[0m[49m[38;5;10m+    784[0m:[38;5;10m[49m     persist_and_route(state, all_trajectories, alert_decision)
[0m[49m[38;5;10m+    785[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    786[0m:[38;5;10m[49m     return alert_decision
[0m[49m[38;5;10m+    787[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    788[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    789[0m:[38;5;10m[49m # --- Demo: Simulate a sepsis deterioration ---
[0m[49m[38;5;10m+    790[0m:[38;5;10m[49m def run_demo():
[0m[49m[38;5;10m+    791[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    792[0m:[38;5;10m[49m     Generate synthetic vital signs for two patients:
[0m[49m[38;5;10m+    793[0m:[38;5;10m[49m     - Patient A: gradual sepsis trajectory over 8 hours
[0m[49m[38;5;10m+    794[0m:[38;5;10m[49m     - Patient B: stable patient with normal variation
[0m[49m[38;5;10m+    795[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    796[0m:[38;5;10m[49m     Shows how the pipeline detects the coordinated deterioration in Patient A
[0m[49m[38;5;10m+    797[0m:[38;5;10m[49m     while leaving Patient B alone.
[0m[49m[38;5;10m+    798[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    799[0m:[38;5;10m[49m     print("=" * 70)
[0m[49m[38;5;10m+    800[0m:[38;5;10m[49m     print("VITAL SIGN TRAJECTORY MONITORING - DEMO")
[0m[49m[38;5;10m+    801[0m:[38;5;10m[49m     print("=" * 70)
[0m[49m[38;5;10m+    802[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    803[0m:[38;5;10m[49m     base_time = datetime(2026, 3, 15, 6, 0, 0, tzinfo=timezone.utc)
[0m[49m[38;5;10m+    804[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    805[0m:[38;5;10m[49m     # --- Patient A: gradual sepsis trajectory ---
[0m[49m[38;5;10m+    806[0m:[38;5;10m[49m     # HR starts at 74 and rises ~3 bpm/hr.
[0m[49m[38;5;10m+    807[0m:[38;5;10m[49m     # RR starts at 16 and rises ~0.8/hr.
[0m[49m[38;5;10m+    808[0m:[38;5;10m[49m     # SBP starts at 128 and falls ~2 mmHg/hr.
[0m[49m[38;5;10m+    809[0m:[38;5;10m[49m     print("\n--- Patient A: Sepsis Trajectory (8 hours of q30min vitals) ---\n")
[0m[49m[38;5;10m+    810[0m:[38;5;10m[49m     for i in range(16):  # 16 readings over 8 hours (every 30 min)
[0m[49m[38;5;10m+    811[0m:[38;5;10m[49m         hours = i * 0.5
[0m[49m[38;5;10m+    812[0m:[38;5;10m[49m         ts = base_time + timedelta(hours=hours)
[0m[49m[38;5;10m+    813[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    814[0m:[38;5;10m[49m         # Simulated gradual deterioration with some noise.
[0m[49m[38;5;10m+    815[0m:[38;5;10m[49m         import random
[0m[49m[38;5;10m+    816[0m:[38;5;10m[49m         random.seed(42 + i)
[0m[49m[38;5;10m+    817[0m:[38;5;10m[49m         hr = 74 + (3.0 * hours) + random.uniform(-1, 1)
[0m[49m[38;5;10m+    818[0m:[38;5;10m[49m         rr = 16 + (0.8 * hours) + random.uniform(-0.5, 0.5)
[0m[49m[38;5;10m+    819[0m:[38;5;10m[49m         sbp = 128 - (2.0 * hours) + random.uniform(-2, 2)
[0m[49m[38;5;10m+    820[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    821[0m:[38;5;10m[49m         for param, val in [("HR", hr), ("RR", rr), ("SBP", sbp)]:
[0m[49m[38;5;10m+    822[0m:[38;5;10m[49m             result = process_vital_sign({
[0m[49m[38;5;10m+    823[0m:[38;5;10m[49m                 "patient_id": "P-00847291",
[0m[49m[38;5;10m+    824[0m:[38;5;10m[49m                 "timestamp": ts,
[0m[49m[38;5;10m+    825[0m:[38;5;10m[49m                 "parameter": param,
[0m[49m[38;5;10m+    826[0m:[38;5;10m[49m                 "value": val,
[0m[49m[38;5;10m+    827[0m:[38;5;10m[49m                 "source_type": "nursing_assessment",
[0m[49m[38;5;10m+    828[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    829[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    830[0m:[38;5;10m[49m         # Print status every 2 hours.
[0m[49m[38;5;10m+    831[0m:[38;5;10m[49m         if i % 4 == 3:
[0m[49m[38;5;10m+    832[0m:[38;5;10m[49m             state = PATIENT_STATES["P-00847291"]
[0m[49m[38;5;10m+    833[0m:[38;5;10m[49m             hr_traj = compute_trajectory(state, "HR")
[0m[49m[38;5;10m+    834[0m:[38;5;10m[49m             print(f"  Hour {hours:.0f}: HR={hr:.0f}, RR={rr:.0f}, SBP={sbp:.0f}")
[0m[49m[38;5;10m+    835[0m:[38;5;10m[49m             if hr_traj:
[0m[49m[38;5;10m+    836[0m:[38;5;10m[49m                 print(f"    HR slope: {hr_traj['slope']*60:.2f} bpm/hr, "
[0m[49m[38;5;10m+    837[0m:[38;5;10m[49m                       f"deviation: {hr_traj['deviation']:.1f} sigma")
[0m[49m[38;5;10m+    838[0m:[38;5;10m[49m             print(f"    Alert decision: {result['action']}")
[0m[49m[38;5;10m+    839[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    840[0m:[38;5;10m[49m     # --- Patient B: stable patient ---
[0m[49m[38;5;10m+    841[0m:[38;5;10m[49m     print("\n--- Patient B: Stable Patient (8 hours of q30min vitals) ---\n")
[0m[49m[38;5;10m+    842[0m:[38;5;10m[49m     for i in range(16):
[0m[49m[38;5;10m+    843[0m:[38;5;10m[49m         hours = i * 0.5
[0m[49m[38;5;10m+    844[0m:[38;5;10m[49m         ts = base_time + timedelta(hours=hours)
[0m[49m[38;5;10m+    845[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    846[0m:[38;5;10m[49m         random.seed(100 + i)
[0m[49m[38;5;10m+    847[0m:[38;5;10m[49m         hr = 72 + random.uniform(-2, 2)
[0m[49m[38;5;10m+    848[0m:[38;5;10m[49m         rr = 14 + random.uniform(-1, 1)
[0m[49m[38;5;10m+    849[0m:[38;5;10m[49m         sbp = 122 + random.uniform(-3, 3)
[0m[49m[38;5;10m+    850[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    851[0m:[38;5;10m[49m         for param, val in [("HR", hr), ("RR", rr), ("SBP", sbp)]:
[0m[49m[38;5;10m+    852[0m:[38;5;10m[49m             result = process_vital_sign({
[0m[49m[38;5;10m+    853[0m:[38;5;10m[49m                 "patient_id": "P-00123456",
[0m[49m[38;5;10m+    854[0m:[38;5;10m[49m                 "timestamp": ts,
[0m[49m[38;5;10m+    855[0m:[38;5;10m[49m                 "parameter": param,
[0m[49m[38;5;10m+    856[0m:[38;5;10m[49m                 "value": val,
[0m[49m[38;5;10m+    857[0m:[38;5;10m[49m                 "source_type": "nursing_assessment",
[0m[49m[38;5;10m+    858[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    859[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    860[0m:[38;5;10m[49m     print(f"  Patient B final decision: {result['action']} (expected: none)")
[0m[49m[38;5;10m+    861[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    862[0m:[38;5;10m[49m     # --- Summary ---
[0m[49m[38;5;10m+    863[0m:[38;5;10m[49m     print("\n" + "=" * 70)
[0m[49m[38;5;10m+    864[0m:[38;5;10m[49m     print("RESULTS SUMMARY")
[0m[49m[38;5;10m+    865[0m:[38;5;10m[49m     print("=" * 70)
[0m[49m[38;5;10m+    866[0m:[38;5;10m[49m     print(f"\nKinesis records written: {len(mock_kinesis.records)}")
[0m[49m[38;5;10m+    867[0m:[38;5;10m[49m     print(f"Timestream records stored: {len(mock_timestream.records)}")
[0m[49m[38;5;10m+    868[0m:[38;5;10m[49m     print(f"SNS alerts published: {len(mock_sns.messages)}")
[0m[49m[38;5;10m+    869[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    870[0m:[38;5;10m[49m     if mock_sns.messages:
[0m[49m[38;5;10m+    871[0m:[38;5;10m[49m         print("\nAlert details:")
[0m[49m[38;5;10m+    872[0m:[38;5;10m[49m         for msg in mock_sns.messages:
[0m[49m[38;5;10m+    873[0m:[38;5;10m[49m             payload = msg["Message"]
[0m[49m[38;5;10m+    874[0m:[38;5;10m[49m             print(f"  [{payload['severity'].upper()}] {payload['pattern']}")
[0m[49m[38;5;10m+    875[0m:[38;5;10m[49m             print(f"    {payload['summary']}")
[0m[49m[38;5;10m+    876[0m:[38;5;10m[49m             print(f"    Recommended: {payload['recommended_action']}")
[0m[49m[38;5;10m+    877[0m:[38;5;10m[49m             print(f"    Trajectories:")
[0m[49m[38;5;10m+    878[0m:[38;5;10m[49m             for p, t in payload["trajectories"].items():
[0m[49m[38;5;10m+    879[0m:[38;5;10m[49m                 print(f"      {p}: current={t['current']}, baseline={t['baseline']}, "
[0m[49m[38;5;10m+    880[0m:[38;5;10m[49m                       f"slope={t['slope_per_hour']}/hr, dev={t['deviation_sigma']}σ")
[0m[49m[38;5;10m+    881[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    882[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    883[0m:[38;5;10m[49m if __name__ == "__main__":
[0m[49m[38;5;10m+    884[0m:[38;5;10m[49m     run_demo()
[0m[49m[38;5;10m+    885[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    886[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    887[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    888[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    889[0m:[38;5;10m[49m ## The Gap Between This and Production
[0m[49m[38;5;10m+    890[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    891[0m:[38;5;10m[49m This example works. Run it and you will see the pipeline detect Patient A's sepsis trajectory while leaving Patient B alone. But there is meaningful distance between "works in a script" and "runs in an ICU monitoring real patients." Here is where that gap lives:
[0m[49m[38;5;10m+    892[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    893[0m:[38;5;10m[49m **Real streaming infrastructure.** The demo processes events sequentially in memory. Production uses Kinesis Data Streams for ingestion and either Lambda (floor patients with intermittent vitals) or Apache Flink via Kinesis Data Analytics (ICU patients with continuous monitoring). Flink handles the stateful windowed computations with exactly-once semantics, maintaining per-patient state without external database calls on every event.
[0m[49m[38;5;10m+    894[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    895[0m:[38;5;10m[49m **HL7/FHIR integration.** Real vital signs arrive via HL7v2 ADT/OBX messages from bedside monitors or FHIR Observation resources from the EHR. The normalization step in production must parse HL7 segments, map device-specific parameter codes to standard names, handle unit conversions (Fahrenheit to Celsius, inches of mercury to mmHg), and deal with the reality that different monitors report different parameter sets.
[0m[49m[38;5;10m+    896[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    897[0m:[38;5;10m[49m **Medication administration awareness.** The demo omits medication-aware suppression entirely. In production, you need a feed from the Medication Administration Record (MAR). When a patient receives a beta-blocker and their HR drops, that is the drug working, not deterioration. Without this, your system will cry wolf after every Metoprolol dose. This integration alone is typically a 3-6 month project.
[0m[49m[38;5;10m+    898[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    899[0m:[38;5;10m[49m **Apache Flink for continuous monitoring.** For ICU patients where data arrives every second, you cannot afford a DynamoDB read/write on every event. A Flink application maintains per-patient state in memory with periodic checkpointing, computes rolling statistics over configurable windows, and only emits events downstream when trajectory features change significantly. The demo's per-event architecture is fine for floor patients with q4h vitals but will not scale to ICU data density.
[0m[49m[38;5;10m+    900[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    901[0m:[38;5;10m[49m **Robust statistics.** The demo uses simple linear regression for slope estimation. Production should use robust methods like Theil-Sen estimation (resistant to outliers) or weighted least squares (weighting recent readings more heavily). For irregularly sampled data, a Kalman filter provides proper handling of varying time gaps between observations.
[0m[49m[38;5;10m+    902[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    903[0m:[38;5;10m[49m **DynamoDB design.** The demo uses a simple patient_id key. Production needs a composite key design supporting queries like "all patients on Unit 4B with active watch or alert status" for the unit dashboard. A GSI on unit + alert_status enables this. TTL automatically expires state records for discharged patients.
[0m[49m[38;5;10m+    904[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    905[0m:[38;5;10m[49m **Timestream query patterns.** Storing trajectory metrics in Timestream enables powerful temporal queries: "Show me this patient's HR slope over the last 24 hours" or "Find all patients whose SpO2 deviation exceeded 2 sigma in the last shift." Production systems build CloudWatch dashboards on top of Timestream scheduled queries for unit-level situational awareness.
[0m[49m[38;5;10m+    906[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    907[0m:[38;5;10m[49m **Error handling and dead-letter queues.** If trajectory computation fails for one patient, it must not affect other patients. Production Lambda functions wrap each patient's processing in try/except blocks, send failures to a DLQ for retry, and emit CloudWatch metrics on error rates. A spike in processing errors triggers an operational alarm (distinct from clinical alerts).
[0m[49m[38;5;10m+    908[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    909[0m:[38;5;10m[49m **IAM least-privilege.** The trajectory-processor Lambda needs `kinesis:GetRecords` (read from stream), `dynamodb:GetItem`/`PutItem` (patient state), `timestream:WriteRecords` (metrics), but NOT `sns:Publish` (that belongs to the alert-evaluator Lambda). Each Lambda gets exactly the permissions it needs, scoped to specific resource ARNs. Not `dynamodb:*`. Not `AdministratorAccess`.
[0m[49m[38;5;10m+    910[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    911[0m:[38;5;10m[49m **VPC and network isolation.** Vital signs are PHI. In production, all Lambda functions and the Flink application run inside a VPC with private subnets. VPC endpoints for DynamoDB, Timestream, SNS, and CloudWatch Logs keep traffic on the AWS backbone. The Kinesis stream uses interface endpoints. No PHI traverses the public internet.
[0m[49m[38;5;10m+    912[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    913[0m:[38;5;10m[49m **Encryption.** Production uses KMS customer-managed keys for the Kinesis stream (server-side encryption), DynamoDB table (encryption at rest), Timestream database (encryption at rest), and SNS topic (encrypted messages). Key rotation enabled. CloudTrail logs every key usage for the HIPAA audit trail.
[0m[49m[38;5;10m+    914[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    915[0m:[38;5;10m[49m **Alert delivery confirmation.** When SNS publishes a clinical alert, production tracks whether it was delivered and acknowledged. If a nurse does not acknowledge an alert within a configured window, the system escalates to the charge nurse. This requires a delivery tracking mechanism (SNS delivery status logging + a separate Lambda checking acknowledgment state).
[0m[49m[38;5;10m+    916[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    917[0m:[38;5;10m[49m **Clinical display integration.** The demo prints to stdout. Production integrates with the EHR (via SMART on FHIR or CDS Hooks), the unit's patient status board, and the paging system. Each integration has its own latency characteristics and failure modes.
[0m[49m[38;5;10m+    918[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    919[0m:[38;5;10m[49m **Testing.** There are no tests here. A production pipeline has unit tests for `compute_trajectory` (with known synthetic data), integration tests for the full pipeline with MIMIC-III derived scenarios, and a validation suite that compares trajectory alerts against historical rapid response events to measure sensitivity and specificity. Never use real patient data in test fixtures.
[0m[49m[38;5;10m+    920[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    921[0m:[38;5;10m[49m **Tuning and feedback.** Production systems log every alert decision (fire, suppress, and why) for retrospective analysis. Clinical teams review false positives and missed events monthly, adjusting thresholds, cooldown windows, and deterioration signatures based on their patient population. The configuration constants at the top of this file are starting points. They will need tuning per unit, per acuity level, and over time.
[0m[49m[38;5;10m+    922[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    923[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    924[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    925[0m:[38;5;10m[49m *Part of the Healthcare AI/ML Cookbook. See [Recipe 12.7](chapter12.07-vital-sign-trajectory-monitoring.md) for the full architectural walkthrough, pseudocode, deterioration signatures, and honest take on why alert fatigue is the real enemy.*
