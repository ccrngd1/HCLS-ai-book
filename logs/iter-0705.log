[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m     "has_substance_use_dx",
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m     "has_transportation_barrier",
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m     "lives_alone",
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m     "insurance_type_encoded",
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m     "hcc_risk_score",
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m     "rx_adherence_ratio",
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m # Insurance type encoding. Must be consistent between training and inference.
