[49m[38;5;10m+      1[0m:[38;5;10m[49m # Recipe 7.4: Python Implementation Example
[0m[49m[38;5;10m+      2[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      3[0m:[38;5;10m[49m > **Heads up:** This is a deliberately simple, illustrative implementation of the concepts from Recipe 7.4. It shows one way you could build an ED visit prediction pipeline using boto3 and SageMaker. It is not production-ready. There's no error handling, no retry logic, no input validation, and the synthetic data is intentionally small. The feature engineering is simplified. The model is basic. Think of it as the sketchpad version: useful for understanding the shape of the solution, not something you'd deploy to a care management team on Monday morning. Consider it a starting point, not a destination.
[0m[49m[38;5;10m+      4[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      5[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+      6[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      7[0m:[38;5;10m[49m ## Setup
[0m[49m[38;5;10m+      8[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      9[0m:[38;5;10m[49m You'll need the AWS SDK for Python and a few data science libraries:
[0m[49m[38;5;10m+     10[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     11[0m:[38;5;10m[49m ```bash
[0m[49m[38;5;10m+     12[0m:[38;5;10m[49m pip install boto3 pandas numpy sagemaker scikit-learn
[0m[49m[38;5;10m+     13[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     14[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     15[0m:[38;5;10m[49m Your environment needs credentials configured (via environment variables, an instance profile, or `~/.aws/credentials`). The IAM role or user needs permissions for SageMaker (training jobs, endpoints, batch transform), S3 (read/write to your ML data bucket), DynamoDB (PutItem, Query), and Lambda (if deploying the scoring trigger).
[0m[49m[38;5;10m+     16[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     17[0m:[38;5;10m[49m For SageMaker specifically, you'll need a SageMaker execution role that the training and transform jobs assume. This role needs S3 access to your data bucket and permission to write CloudWatch logs.
[0m[49m[38;5;10m+     18[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     19[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     20[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     21[0m:[38;5;10m[49m ## Config and Constants
[0m[49m[38;5;10m+     22[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     23[0m:[38;5;10m[49m Before we get to the steps, here's the configuration that drives the pipeline. ED visit prediction is fundamentally about combining clinical signals (diagnoses, utilization history, medication patterns) with social and behavioral signals (transportation access, housing stability, engagement patterns) to estimate who will show up in the emergency department in the next 30 to 90 days.
[0m[49m[38;5;10m+     24[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     25[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     26[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+     27[0m:[38;5;10m[49m import datetime
[0m[49m[38;5;10m+     28[0m:[38;5;10m[49m from datetime import timezone
[0m[49m[38;5;10m+     29[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+     30[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     31[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+     32[0m:[38;5;10m[49m import numpy as np
[0m[49m[38;5;10m+     33[0m:[38;5;10m[49m import pandas as pd
[0m[49m[38;5;10m+     34[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+     35[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     36[0m:[38;5;10m[49m # Structured logging. In production, use JSON-formatted output for
[0m[49m[38;5;10m+     37[0m:[38;5;10m[49m # CloudWatch Logs Insights queries. Never log PHI field values.
[0m[49m[38;5;10m+     38[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+     39[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+     40[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     41[0m:[38;5;10m[49m # Retry configuration for AWS API calls.
[0m[49m[38;5;10m+     42[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+     43[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     44[0m:[38;5;10m[49m # S3 bucket and prefixes for the ML pipeline.
[0m[49m[38;5;10m+     45[0m:[38;5;10m[49m # In production, these come from environment variables or SSM Parameter Store.
[0m[49m[38;5;10m+     46[0m:[38;5;10m[49m ML_BUCKET = "my-ed-prediction-pipeline"
[0m[49m[38;5;10m+     47[0m:[38;5;10m[49m FEATURES_PREFIX = "features/current/"
[0m[49m[38;5;10m+     48[0m:[38;5;10m[49m TRAINING_PREFIX = "features/training/"
[0m[49m[38;5;10m+     49[0m:[38;5;10m[49m MODELS_PREFIX = "models/ed-visit/"
[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m PREDICTIONS_PREFIX = "predictions/"
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m # DynamoDB table for storing risk scores.
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m PREDICTIONS_TABLE = "ed-visit-predictions"
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m # SageMaker configuration.
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m SAGEMAKER_ROLE = "arn:aws:iam::123456789012:role/SageMakerExecutionRole"
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m TRAINING_INSTANCE_TYPE = "ml.m5.xlarge"
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m TRANSFORM_INSTANCE_TYPE = "ml.m5.large"
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m # Prediction window: how far ahead are we predicting?
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m # 30 days is the most common for ED prediction because it aligns with
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m # care management outreach cycles. 90 days is used for population health
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m # stratification. We'll use 30 here.
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m PREDICTION_WINDOW_DAYS = 30
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m # Risk tier thresholds. These drive the care management workflow.
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m # High-risk patients get proactive outreach (nurse call, care plan review).
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m # Medium-risk patients get automated engagement (portal messages, reminders).
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m # Low-risk patients get standard care.
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m #
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m # These thresholds are operational decisions, not model decisions.
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m # Tune based on your care management team's capacity. If you have 5 care
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m # managers covering 10,000 patients, you need a high threshold to keep the
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m # caseload manageable. If you have 20, you can lower it.
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m HIGH_RISK_THRESHOLD = 0.65
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m MEDIUM_RISK_THRESHOLD = 0.35
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m # XGBoost hyperparameters for training.
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m # ED visit prediction typically has a 10-20% positive rate depending on
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m # your population. scale_pos_weight compensates for class imbalance.
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m XGBOOST_PARAMS = {
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m     "objective": "binary:logistic",
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m     "eval_metric": "auc",
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m     "num_round": "300",
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m     "max_depth": "7",
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m     "eta": "0.05",
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m     "subsample": "0.8",
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m     "colsample_bytree": "0.7",
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m     "min_child_weight": "5",
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m     "scale_pos_weight": "6.0",  # adjust for your actual ED visit rate
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m                                  # formula: (1 - ed_rate) / ed_rate
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m                                  # for 14% ED rate: 0.86/0.14 ≈ 6.1
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m # Feature columns the model expects, in order.
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m # This must match exactly what the training data provides.
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m FEATURE_COLUMNS = [
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m     "ed_visits_last_12m",
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m     "ed_visits_last_3m",
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m     "inpatient_admits_last_12m",
