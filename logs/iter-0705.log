[0m[49m[38;5;10m+    759[0m:[38;5;10m[49m     # Step 6: Compute risk drivers for high and medium risk patients.
[0m[49m[38;5;10m+    760[0m:[38;5;10m[49m     logger.info("Step 6: Computing risk drivers")
[0m[49m[38;5;10m+    761[0m:[38;5;10m[49m     at_risk = predictions[predictions["risk_tier"].isin(["high", "medium"])]
[0m[49m[38;5;10m+    762[0m:[38;5;10m[49m     at_risk_features = df.iloc[at_risk.index]
[0m[49m[38;5;10m+    763[0m:[38;5;10m[49m     risk_drivers = compute_risk_drivers(at_risk_features, at_risk)
[0m[49m[38;5;10m+    764[0m:[38;5;10m[49m 
