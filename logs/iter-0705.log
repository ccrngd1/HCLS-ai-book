[0m[49m[38;5;10m+    774[0m:[38;5;10m[49m         "low_risk_count": int((predictions["risk_tier"] == "low").sum()),
[0m[49m[38;5;10m+    775[0m:[38;5;10m[49m         "mean_probability": float(predictions["ed_probability"].mean()),
[0m[49m[38;5;10m+    776[0m:[38;5;10m[49m         "prediction_window_days": PREDICTION_WINDOW_DAYS,
[0m[49m[38;5;10m+    777[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    778[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    779[0m:[38;5;10m[49m     logger.info("Pipeline complete. Summary: %s", summary)
[0m[49m[38;5;10m+    780[0m:[38;5;10m[49m     return summary, predictions, risk_drivers
[0m[49m[38;5;10m+    781[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    782[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    783[0m:[38;5;10m[49m # Run the pipeline.
[0m[49m[38;5;10m+    784[0m:[38;5;10m[49m if __name__ == "__main__":
[0m[49m[38;5;10m+    785[0m:[38;5;10m[49m     import json
[0m[49m[38;5;10m+    786[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    787[0m:[38;5;10m[49m     summary, predictions, risk_drivers = run_ed_prediction_pipeline(retrain=False)
[0m[49m[38;5;10m+    788[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    789[0m:[38;5;10m[49m     print("\n=== ED Visit Prediction Pipeline Results ===\n")
[0m[49m[38;5;10m+    790[0m:[38;5;10m[49m     print(json.dumps(summary, indent=2))
[0m[49m[38;5;10m+    791[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    792[0m:[38;5;10m[49m     print("\n=== Top 10 Highest Risk Patients ===\n")
[0m[49m[38;5;10m+    793[0m:[38;5;10m[49m     top_10 = predictions.nlargest(10, "ed_probability")
[0m[49m[38;5;10m+    794[0m:[38;5;10m[49m     for _, row in top_10.iterrows():
[0m[49m[38;5;10m+    795[0m:[38;5;10m[49m         print(f"  {row['patient_id']}: probability={row['ed_probability']:.3f} "
[0m[49m[38;5;10m+    796[0m:[38;5;10m[49m               f"tier={row['risk_tier']}")
[0m[49m[38;5;10m+    797[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    798[0m:[38;5;10m[49m     print("\n=== Risk Drivers (first 5 high-risk patients) ===\n")
[0m[49m[38;5;10m+    799[0m:[38;5;10m[49m     for _, row in risk_drivers.head(5).iterrows():
[0m[49m[38;5;10m+    800[0m:[38;5;10m[49m         print(f"  {row['patient_id']}:")
[0m[49m[38;5;10m+    801[0m:[38;5;10m[49m         for driver in row["risk_drivers"]:
[0m[49m[38;5;10m+    802[0m:[38;5;10m[49m             print(f"    - {driver}")
[0m[49m[38;5;10m+    803[0m:[38;5;10m[49m         print()
