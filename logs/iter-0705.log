[0m[49m[38;5;10m+    739[0m:[38;5;10m[49m         + 0.8 * df["ed_visits_last_12m"]
[0m[49m[38;5;10m+    740[0m:[38;5;10m[49m         + 1.2 * df["ed_visits_last_3m"]
[0m[49m[38;5;10m+    741[0m:[38;5;10m[49m         + 0.4 * df["inpatient_admits_last_12m"]
[0m[49m[38;5;10m+    742[0m:[38;5;10m[49m         + 0.15 * df["chronic_condition_count"]
[0m[49m[38;5;10m+    743[0m:[38;5;10m[49m         + 0.2 * df["missed_appointments_last_6m"]
[0m[49m[38;5;10m+    744[0m:[38;5;10m[49m         + 0.6 * df["has_behavioral_health_dx"]
[0m[49m[38;5;10m+    745[0m:[38;5;10m[49m         + 0.9 * df["has_substance_use_dx"]
[0m[49m[38;5;10m+    746[0m:[38;5;10m[49m         + 0.5 * df["has_transportation_barrier"]
[0m[49m[38;5;10m+    747[0m:[38;5;10m[49m         - 1.5 * df["rx_adherence_ratio"]
[0m[49m[38;5;10m+    748[0m:[38;5;10m[49m     )))
