[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m │    - Patient's preferred contact method                   │
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m │    - Patient's stated preferences                         │
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m │    - Bot's structured summary                             │
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m │                                                           │
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m │   [Bridge-and-stay pattern]                               │
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m │    - Bot bridges to human within the platform             │
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m │    - Bot stays present until human has joined             │
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m │    - Patient does not start over                          │
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m │           │                                               │
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m │           ▼                                               │
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m │   [Output: handoff event with structured payload to       │
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m │    appropriate target, conversation continuity preserved] │
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m │                                                           │
