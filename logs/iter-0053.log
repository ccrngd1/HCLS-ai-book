[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m │      measured by prescription fills)                      │
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m │    - Per-protocol outcome calculation                     │
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m │    - Per-cohort outcome calculation                       │
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m │    - Feed signals back to care-plan-template revision     │
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m │      process                                              │
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m │           │                                               │
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m │           ▼                                               │
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m │   [Output: care-team visibility into coach activities;    │
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m │    outcome metrics for clinical and operational review]   │
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m │                                                           │
