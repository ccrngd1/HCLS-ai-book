[0m[49m[38;5;10m+    1156[0m:[38;5;10m[49m     logger.info("Step 3: Generating candidate pairs")
[0m[49m[38;5;10m+    1157[0m:[38;5;10m[49m     candidates = generate_candidate_pairs(
[0m[49m[38;5;10m+    1158[0m:[38;5;10m[49m         entities, preprocessed["sentences"], preprocessed["full_text"]
[0m[49m[38;5;10m+    1159[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    1160[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1161[0m:[38;5;10m[49m     # Step 4: Classify temporal relations for each candidate pair.
[0m[49m[38;5;10m+    1162[0m:[38;5;10m[49m     logger.info("Step 4: Classifying temporal relations")
[0m[49m[38;5;10m+    1163[0m:[38;5;10m[49m     classified = classify_relations(
