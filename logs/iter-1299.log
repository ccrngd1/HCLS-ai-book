[0m[49m[38;5;10m+    1165[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    1166[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1167[0m:[38;5;10m[49m     # Step 5: Build temporal graph with constraint propagation.
[0m[49m[38;5;10m+    1168[0m:[38;5;10m[49m     logger.info("Step 5: Building temporal graph")
[0m[49m[38;5;10m+    1169[0m:[38;5;10m[49m     graph = build_temporal_graph(
