[0m[49m[38;5;10m+    1171[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    1172[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1173[0m:[38;5;10m[49m     # Step 6: Generate the patient timeline.
[0m[49m[38;5;10m+    1174[0m:[38;5;10m[49m     logger.info("Step 6: Generating timeline")
[0m[49m[38;5;10m+    1175[0m:[38;5;10m[49m     timeline = generate_timeline(graph, preprocessed)
[0m[49m[38;5;10m+    1176[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1177[0m:[38;5;10m[49m     # Store the result.
[0m[49m[38;5;10m+    1178[0m:[38;5;10m[49m     logger.info("Storing timeline in DynamoDB")
[0m[49m[38;5;10m+    1179[0m:[38;5;10m[49m     store_timeline(timeline)
[0m[49m[38;5;10m+    1180[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1181[0m:[38;5;10m[49m     logger.info("Done. %d events on timeline.", timeline["event_count"])
