[0m[49m[38;5;10m+    1144[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1145[0m:[38;5;10m[49m     # Step 1: Preprocess and segment.
[0m[49m[38;5;10m+    1146[0m:[38;5;10m[49m     logger.info("Step 1: Preprocessing note")
[0m[49m[38;5;10m+    1147[0m:[38;5;10m[49m     preprocessed = preprocess_note(note_text, document_metadata)
[0m[49m[38;5;10m+    1148[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1149[0m:[38;5;10m[49m     # Step 2: Detect clinical events and temporal expressions.
[0m[49m[38;5;10m+    1150[0m:[38;5;10m[49m     logger.info("Step 2: Detecting temporal entities")
[0m[49m[38;5;10m+    1151[0m:[38;5;10m[49m     entities = detect_temporal_entities(preprocessed)
[0m[49m[38;5;10m+    1152[0m:[38;5;10m[49m     logger.info("  Events: %d, Temporal expressions: %d",
[0m[49m[38;5;10m+    1153[0m:[38;5;10m[49m                len(entities["events"]), len(entities["temporal_expressions"]))
[0m[49m[38;5;10m+    1154[0m:[38;5;10m[49m 
