[0m[49m[38;5;10m+     134[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     135[0m:[38;5;10m[49m # Maximum sentence distance for candidate pair generation.
[0m[49m[38;5;10m+     136[0m:[38;5;10m[49m # Pairs farther apart than this are unlikely to have a direct temporal relationship.
[0m[49m[38;5;10m+     137[0m:[38;5;10m[49m MAX_SENTENCE_DISTANCE = 3
[0m[49m[38;5;10m+     138[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     139[0m:[38;5;10m[49m # SageMaker endpoint for temporal relation classification.
[0m[49m[38;5;10m+     140[0m:[38;5;10m[49m SAGEMAKER_ENDPOINT_NAME = "temporal-relation-classifier"
[0m[49m[38;5;10m+     141[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     142[0m:[38;5;10m[49m # DynamoDB table for patient timelines.
[0m[49m[38;5;10m+     143[0m:[38;5;10m[49m TIMELINE_TABLE_NAME = "patient-timelines"
[0m[49m[38;5;10m+     144[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     145[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     146[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     147[0m:[38;5;10m[49m 
