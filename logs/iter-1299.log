[0m[49m[38;5;10m+     205[0m:[38;5;10m[49m ## Step 1: Preprocess and Segment the Clinical Note
[0m[49m[38;5;10m+     206[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     207[0m:[38;5;10m[49m *The pseudocode calls this `preprocess_note(note_text, document_metadata)`. It identifies the document timestamp (anchor for relative expressions), segments by section, and splits into sentences. Without this step, "two days ago" has no anchor point and section-based temporal context is lost.*
[0m[49m[38;5;10m+     208[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     209[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     210[0m:[38;5;10m[49m def parse_doc_time(authored_datetime_str):
[0m[49m[38;5;10m+     211[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     212[0m:[38;5;10m[49m     Parse the document authored timestamp into a Python datetime object.
[0m[49m[38;5;10m+     213[0m:[38;5;10m[49m     This is the anchor for all relative temporal expressions in the note.
[0m[49m[38;5;10m+     214[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     215[0m:[38;5;10m[49m     Clinical notes are often authored hours after events occur (batch charting).
[0m[49m[38;5;10m+     216[0m:[38;5;10m[49m     The authored timestamp, not the encounter date, is the correct anchor for
[0m[49m[38;5;10m+     217[0m:[38;5;10m[49m     expressions like "yesterday" or "two days ago."
[0m[49m[38;5;10m+     218[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     219[0m:[38;5;10m[49m     # Handle ISO 8601 with Z suffix or timezone offset.
[0m[49m[38;5;10m+     220[0m:[38;5;10m[49m     if authored_datetime_str.endswith("Z"):
[0m[49m[38;5;10m+     221[0m:[38;5;10m[49m         authored_datetime_str = authored_datetime_str[:-1] + "+00:00"
[0m[49m[38;5;10m+     222[0m:[38;5;10m[49m     return datetime.datetime.fromisoformat(authored_datetime_str)
[0m[49m[38;5;10m+     223[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     224[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     225[0m:[38;5;10m[49m def segment_sections(note_text):
[0m[49m[38;5;10m+     226[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     227[0m:[38;5;10m[49m     Split a clinical note into sections based on header patterns.
[0m[49m[38;5;10m+     228[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     229[0m:[38;5;10m[49m     Clinical section headers are typically: all-caps lines, lines ending with colon,
[0m[49m[38;5;10m+     230[0m:[38;5;10m[49m     or short lines that match known section names. Each section carries implicit
[0m[49m[38;5;10m+     231[0m:[38;5;10m[49m     temporal context (historical vs. current vs. future).
[0m[49m[38;5;10m+     232[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     233[0m:[38;5;10m[49m     sections = []
[0m[49m[38;5;10m+     234[0m:[38;5;10m[49m     current_header = "UNKNOWN"
[0m[49m[38;5;10m+     235[0m:[38;5;10m[49m     current_content_lines = []
[0m[49m[38;5;10m+     236[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     237[0m:[38;5;10m[49m     for line in note_text.split("\n"):
[0m[49m[38;5;10m+     238[0m:[38;5;10m[49m         stripped = line.strip()
[0m[49m[38;5;10m+     239[0m:[38;5;10m[49m         if not stripped:
[0m[49m[38;5;10m+     240[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     241[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     242[0m:[38;5;10m[49m         # Detect section headers: all-caps ending with colon, or known header names.
[0m[49m[38;5;10m+     243[0m:[38;5;10m[49m         is_header = False
[0m[49m[38;5;10m+     244[0m:[38;5;10m[49m         if stripped.endswith(":") and len(stripped) < 60:
[0m[49m[38;5;10m+     245[0m:[38;5;10m[49m             # Could be a section header. Check if it's mostly uppercase or a known name.
[0m[49m[38;5;10m+     246[0m:[38;5;10m[49m             header_text = stripped.rstrip(":").strip()
[0m[49m[38;5;10m+     247[0m:[38;5;10m[49m             if header_text.isupper() or header_text.lower() in SECTION_TEMPORAL_CONTEXT:
[0m[49m[38;5;10m+     248[0m:[38;5;10m[49m                 is_header = True
[0m[49m[38;5;10m+     249[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     250[0m:[38;5;10m[49m         if is_header:
[0m[49m[38;5;10m+     251[0m:[38;5;10m[49m             # Save the previous section if it has content.
[0m[49m[38;5;10m+     252[0m:[38;5;10m[49m             if current_content_lines:
[0m[49m[38;5;10m+     253[0m:[38;5;10m[49m                 temporal_ctx = SECTION_TEMPORAL_CONTEXT.get(
[0m[49m[38;5;10m+     254[0m:[38;5;10m[49m                     current_header.lower().rstrip(":"), "UNKNOWN"
[0m[49m[38;5;10m+     255[0m:[38;5;10m[49m                 )
[0m[49m[38;5;10m+     256[0m:[38;5;10m[49m                 sections.append({
[0m[49m[38;5;10m+     257[0m:[38;5;10m[49m                     "header": current_header,
[0m[49m[38;5;10m+     258[0m:[38;5;10m[49m                     "content": "\n".join(current_content_lines),
[0m[49m[38;5;10m+     259[0m:[38;5;10m[49m                     "temporal_context": temporal_ctx,
[0m[49m[38;5;10m+     260[0m:[38;5;10m[49m                 })
[0m[49m[38;5;10m+     261[0m:[38;5;10m[49m             current_header = stripped.rstrip(":")
[0m[49m[38;5;10m+     262[0m:[38;5;10m[49m             current_content_lines = []
[0m[49m[38;5;10m+     263[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+     264[0m:[38;5;10m[49m             current_content_lines.append(stripped)
[0m[49m[38;5;10m+     265[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     266[0m:[38;5;10m[49m     # Don't forget the last section.
[0m[49m[38;5;10m+     267[0m:[38;5;10m[49m     if current_content_lines:
[0m[49m[38;5;10m+     268[0m:[38;5;10m[49m         temporal_ctx = SECTION_TEMPORAL_CONTEXT.get(
[0m[49m[38;5;10m+     269[0m:[38;5;10m[49m             current_header.lower().rstrip(":"), "UNKNOWN"
[0m[49m[38;5;10m+     270[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     271[0m:[38;5;10m[49m         sections.append({
[0m[49m[38;5;10m+     272[0m:[38;5;10m[49m             "header": current_header,
[0m[49m[38;5;10m+     273[0m:[38;5;10m[49m             "content": "\n".join(current_content_lines),
[0m[49m[38;5;10m+     274[0m:[38;5;10m[49m             "temporal_context": temporal_ctx,
[0m[49m[38;5;10m+     275[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     276[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     277[0m:[38;5;10m[49m     return sections
[0m[49m[38;5;10m+     278[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     279[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     280[0m:[38;5;10m[49m def split_sentences(text):
[0m[49m[38;5;10m+     281[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     282[0m:[38;5;10m[49m     Split clinical text into sentences.
[0m[49m[38;5;10m+     283[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     284[0m:[38;5;10m[49m     Clinical text has non-standard sentence boundaries: abbreviations with periods
[0m[49m[38;5;10m+     285[0m:[38;5;10m[49m     (e.g., "pt."), numbered lists, lab values with decimals, and dosages.
[0m[49m[38;5;10m+     286[0m:[38;5;10m[49m     This is a simplified splitter. Production systems use clinical-specific
[0m[49m[38;5;10m+     287[0m:[38;5;10m[49m     sentence tokenizers (like those in spaCy with clinical models).
[0m[49m[38;5;10m+     288[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     289[0m:[38;5;10m[49m     # Split on period followed by space and uppercase, or newlines.
[0m[49m[38;5;10m+     290[0m:[38;5;10m[49m     # This is intentionally simple. A real system uses a trained tokenizer.
[0m[49m[38;5;10m+     291[0m:[38;5;10m[49m     sentences = re.split(r'(?<=[.!?])\s+(?=[A-Z])', text)
[0m[49m[38;5;10m+     292[0m:[38;5;10m[49m     # Also split on newlines that start new thoughts.
[0m[49m[38;5;10m+     293[0m:[38;5;10m[49m     expanded = []
[0m[49m[38;5;10m+     294[0m:[38;5;10m[49m     for sent in sentences:
[0m[49m[38;5;10m+     295[0m:[38;5;10m[49m         sub_sents = [s.strip() for s in sent.split("\n") if s.strip()]
[0m[49m[38;5;10m+     296[0m:[38;5;10m[49m         expanded.extend(sub_sents)
[0m[49m[38;5;10m+     297[0m:[38;5;10m[49m     return expanded
[0m[49m[38;5;10m+     298[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     299[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     300[0m:[38;5;10m[49m def preprocess_note(note_text, document_metadata):
[0m[49m[38;5;10m+     301[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     302[0m:[38;5;10m[49m     Step 1: Preprocess and segment the clinical note.
[0m[49m[38;5;10m+     303[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     304[0m:[38;5;10m[49m     Returns structured data needed by all downstream steps:
[0m[49m[38;5;10m+     305[0m:[38;5;10m[49m     the document timestamp, sections with temporal context, and sentence list.
[0m[49m[38;5;10m+     306[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     307[0m:[38;5;10m[49m     doc_time = parse_doc_time(document_metadata["authored_datetime"])
[0m[49m[38;5;10m+     308[0m:[38;5;10m[49m     sections = segment_sections(note_text)
[0m[49m[38;5;10m+     309[0m:[38;5;10m[49m     sentences = split_sentences(note_text)
[0m[49m[38;5;10m+     310[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     311[0m:[38;5;10m[49m     logger.info("Preprocessed note: %d sections, %d sentences", len(sections), len(sentences))
[0m[49m[38;5;10m+     312[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     313[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     314[0m:[38;5;10m[49m         "doc_time": doc_time,
[0m[49m[38;5;10m+     315[0m:[38;5;10m[49m         "sections": sections,
[0m[49m[38;5;10m+     316[0m:[38;5;10m[49m         "sentences": sentences,
[0m[49m[38;5;10m+     317[0m:[38;5;10m[49m         "full_text": note_text,
[0m[49m[38;5;10m+     318[0m:[38;5;10m[49m         "metadata": document_metadata,
[0m[49m[38;5;10m+     319[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     320[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     321[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     322[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     323[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     324[0m:[38;5;10m[49m ## Step 2: Detect Clinical Events and Temporal Expressions
[0m[49m[38;5;10m+     325[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     326[0m:[38;5;10m[49m *The pseudocode calls this `detect_temporal_entities(preprocessed_note)`. This step uses Comprehend Medical for clinical event detection and a rule-based parser for temporal expression recognition. The rule-based parser handles the clinical-specific patterns (POD#2, HD5, relative expressions) that general-purpose temporal parsers miss.*
[0m[49m[38;5;10m+     327[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     328[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     329[0m:[38;5;10m[49m def detect_events_with_comprehend(note_text):
[0m[49m[38;5;10m+     330[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     331[0m:[38;5;10m[49m     Call Amazon Comprehend Medical to detect clinical entities that represent events.
[0m[49m[38;5;10m+     332[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     333[0m:[38;5;10m[49m     Events are things that happened at a point in time: diagnoses, procedures,
[0m[49m[38;5;10m+     334[0m:[38;5;10m[49m     medication starts/stops, symptoms, tests. Static attributes (body parts,
[0m[49m[38;5;10m+     335[0m:[38;5;10m[49m     anatomical locations) are not events and get filtered out.
[0m[49m[38;5;10m+     336[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     337[0m:[38;5;10m[49m     Comprehend Medical's DetectEntitiesV2 returns entities with categories
[0m[49m[38;5;10m+     338[0m:[38;5;10m[49m     like MEDICAL_CONDITION, MEDICATION, TEST_TREATMENT_PROCEDURE, and attributes
[0m[49m[38;5;10m+     339[0m:[38;5;10m[49m     including temporal traits (PAST_HISTORY, OCCURRENCE).
[0m[49m[38;5;10m+     340[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     341[0m:[38;5;10m[49m     # Comprehend Medical has a 20,000 character limit per request.
[0m[49m[38;5;10m+     342[0m:[38;5;10m[49m     # For this example, we truncate. Production systems split at sentence boundaries.
[0m[49m[38;5;10m+     343[0m:[38;5;10m[49m     text_to_analyze = note_text[:20000]
[0m[49m[38;5;10m+     344[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     345[0m:[38;5;10m[49m     response = comprehend_medical_client.detect_entities_v2(Text=text_to_analyze)
[0m[49m[38;5;10m+     346[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     347[0m:[38;5;10m[49m     events = []
[0m[49m[38;5;10m+     348[0m:[38;5;10m[49m     for entity in response.get("Entities", []):
[0m[49m[38;5;10m+     349[0m:[38;5;10m[49m         # Filter by confidence.
[0m[49m[38;5;10m+     350[0m:[38;5;10m[49m         if entity.get("Score", 0) < ENTITY_CONFIDENCE_THRESHOLD:
[0m[49m[38;5;10m+     351[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     352[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     353[0m:[38;5;10m[49m         # Filter to event-like categories.
[0m[49m[38;5;10m+     354[0m:[38;5;10m[49m         # MEDICAL_CONDITION, TEST_TREATMENT_PROCEDURE, and MEDICATION are events.
[0m[49m[38;5;10m+     355[0m:[38;5;10m[49m         # ANATOMY and PROTECTED_HEALTH_INFORMATION are not.
[0m[49m[38;5;10m+     356[0m:[38;5;10m[49m         category = entity.get("Category", "")
[0m[49m[38;5;10m+     357[0m:[38;5;10m[49m         if category not in ("MEDICAL_CONDITION", "TEST_TREATMENT_PROCEDURE", "MEDICATION"):
[0m[49m[38;5;10m+     358[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     359[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     360[0m:[38;5;10m[49m         # Extract temporal traits if present.
[0m[49m[38;5;10m+     361[0m:[38;5;10m[49m         # Comprehend Medical detects: PAST_HISTORY, OCCURRENCE, FUTURE, NEGATION.
[0m[49m[38;5;10m+     362[0m:[38;5;10m[49m         traits = [t["Name"] for t in entity.get("Traits", [])]
[0m[49m[38;5;10m+     363[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     364[0m:[38;5;10m[49m         events.append({
[0m[49m[38;5;10m+     365[0m:[38;5;10m[49m             "id": f"EVT-{entity['BeginOffset']:05d}",
[0m[49m[38;5;10m+     366[0m:[38;5;10m[49m             "text": entity["Text"],
[0m[49m[38;5;10m+     367[0m:[38;5;10m[49m             "category": category,
[0m[49m[38;5;10m+     368[0m:[38;5;10m[49m             "type": entity.get("Type", "UNKNOWN"),
[0m[49m[38;5;10m+     369[0m:[38;5;10m[49m             "begin_offset": entity["BeginOffset"],
[0m[49m[38;5;10m+     370[0m:[38;5;10m[49m             "end_offset": entity["EndOffset"],
[0m[49m[38;5;10m+     371[0m:[38;5;10m[49m             "confidence": entity["Score"],
[0m[49m[38;5;10m+     372[0m:[38;5;10m[49m             "traits": traits,
[0m[49m[38;5;10m+     373[0m:[38;5;10m[49m             "entity_type": "EVENT",
[0m[49m[38;5;10m+     374[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     375[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     376[0m:[38;5;10m[49m     logger.info("Detected %d clinical events via Comprehend Medical", len(events))
[0m[49m[38;5;10m+     377[0m:[38;5;10m[49m     return events
[0m[49m[38;5;10m+     378[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     379[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     380[0m:[38;5;10m[49m def recognize_temporal_expressions(note_text, doc_time):
[0m[49m[38;5;10m+     381[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     382[0m:[38;5;10m[49m     Rule-based temporal expression recognition for clinical text.
[0m[49m[38;5;10m+     383[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     384[0m:[38;5;10m[49m     This covers the clinical-specific patterns that general NLP tools
[0m[49m[38;5;10m+     385[0m:[38;5;10m[49m     (HeidelTime, SUTime) don't handle out of the box: POD#N, HD#N,
[0m[49m[38;5;10m+     386[0m:[38;5;10m[49m     relative expressions anchored to document time, and perioperative markers.
[0m[49m[38;5;10m+     387[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     388[0m:[38;5;10m[49m     Each recognized expression gets normalized to an ISO 8601 date
[0m[49m[38;5;10m+     389[0m:[38;5;10m[49m     (or date range) anchored to the document creation timestamp.
[0m[49m[38;5;10m+     390[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     391[0m:[38;5;10m[49m     temporal_exprs = []
[0m[49m[38;5;10m+     392[0m:[38;5;10m[49m     expr_id_counter = 0
[0m[49m[38;5;10m+     393[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     394[0m:[38;5;10m[49m     for pattern_str, pattern_type in CLINICAL_TEMPORAL_PATTERNS:
[0m[49m[38;5;10m+     395[0m:[38;5;10m[49m         for match in re.finditer(pattern_str, note_text, re.IGNORECASE):
[0m[49m[38;5;10m+     396[0m:[38;5;10m[49m             expr_id_counter += 1
[0m[49m[38;5;10m+     397[0m:[38;5;10m[49m             raw_text = match.group(0)
[0m[49m[38;5;10m+     398[0m:[38;5;10m[49m             begin_offset = match.start()
[0m[49m[38;5;10m+     399[0m:[38;5;10m[49m             end_offset = match.end()
[0m[49m[38;5;10m+     400[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     401[0m:[38;5;10m[49m             # Normalize based on pattern type.
[0m[49m[38;5;10m+     402[0m:[38;5;10m[49m             normalized = normalize_temporal_expression(
[0m[49m[38;5;10m+     403[0m:[38;5;10m[49m                 match, pattern_type, doc_time, note_text
[0m[49m[38;5;10m+     404[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+     405[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     406[0m:[38;5;10m[49m             temporal_exprs.append({
[0m[49m[38;5;10m+     407[0m:[38;5;10m[49m                 "id": f"TIMEX-{expr_id_counter:03d}",
[0m[49m[38;5;10m+     408[0m:[38;5;10m[49m                 "text": raw_text,
[0m[49m[38;5;10m+     409[0m:[38;5;10m[49m                 "begin_offset": begin_offset,
[0m[49m[38;5;10m+     410[0m:[38;5;10m[49m                 "end_offset": end_offset,
[0m[49m[38;5;10m+     411[0m:[38;5;10m[49m                 "pattern_type": pattern_type,
[0m[49m[38;5;10m+     412[0m:[38;5;10m[49m                 "normalized": normalized,
[0m[49m[38;5;10m+     413[0m:[38;5;10m[49m                 "entity_type": "TEMPORAL_EXPRESSION",
[0m[49m[38;5;10m+     414[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+     415[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     416[0m:[38;5;10m[49m     logger.info("Recognized %d temporal expressions", len(temporal_exprs))
[0m[49m[38;5;10m+     417[0m:[38;5;10m[49m     return temporal_exprs
[0m[49m[38;5;10m+     418[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     419[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     420[0m:[38;5;10m[49m def normalize_temporal_expression(match, pattern_type, doc_time, full_text):
[0m[49m[38;5;10m+     421[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     422[0m:[38;5;10m[49m     Normalize a temporal expression to an ISO 8601 date or date range.
[0m[49m[38;5;10m+     423[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     424[0m:[38;5;10m[49m     This is the core of temporal anchoring: turning "2 days ago" or "POD#1"
[0m[49m[38;5;10m+     425[0m:[38;5;10m[49m     into an actual calendar date that can be placed on a timeline.
[0m[49m[38;5;10m+     426[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     427[0m:[38;5;10m[49m     try:
[0m[49m[38;5;10m+     428[0m:[38;5;10m[49m         if pattern_type == "month_day":
[0m[49m[38;5;10m+     429[0m:[38;5;10m[49m             month_name = match.group(1)
[0m[49m[38;5;10m+     430[0m:[38;5;10m[49m             day = int(match.group(2))
[0m[49m[38;5;10m+     431[0m:[38;5;10m[49m             year = int(match.group(3)) if match.group(3) else doc_time.year
[0m[49m[38;5;10m+     432[0m:[38;5;10m[49m             month_num = datetime.datetime.strptime(month_name, "%B").month
[0m[49m[38;5;10m+     433[0m:[38;5;10m[49m             return datetime.datetime(year, month_num, day, tzinfo=timezone.utc).isoformat()
[0m[49m[38;5;10m+     434[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     435[0m:[38;5;10m[49m         elif pattern_type == "slash_date":
[0m[49m[38;5;10m+     436[0m:[38;5;10m[49m             month = int(match.group(1))
[0m[49m[38;5;10m+     437[0m:[38;5;10m[49m             day = int(match.group(2))
[0m[49m[38;5;10m+     438[0m:[38;5;10m[49m             year = int(match.group(3))
[0m[49m[38;5;10m+     439[0m:[38;5;10m[49m             if year < 100:
[0m[49m[38;5;10m+     440[0m:[38;5;10m[49m                 year += 2000
[0m[49m[38;5;10m+     441[0m:[38;5;10m[49m             return datetime.datetime(year, month, day, tzinfo=timezone.utc).isoformat()
[0m[49m[38;5;10m+     442[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     443[0m:[38;5;10m[49m         elif pattern_type == "relative":
[0m[49m[38;5;10m+     444[0m:[38;5;10m[49m             quantity = int(match.group(1))
[0m[49m[38;5;10m+     445[0m:[38;5;10m[49m             unit = match.group(2).lower()
[0m[49m[38;5;10m+     446[0m:[38;5;10m[49m             direction = match.group(3).lower()
[0m[49m[38;5;10m+     447[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     448[0m:[38;5;10m[49m             delta_map = {
[0m[49m[38;5;10m+     449[0m:[38;5;10m[49m                 "day": timedelta(days=quantity),
[0m[49m[38;5;10m+     450[0m:[38;5;10m[49m                 "hour": timedelta(hours=quantity),
[0m[49m[38;5;10m+     451[0m:[38;5;10m[49m                 "week": timedelta(weeks=quantity),
[0m[49m[38;5;10m+     452[0m:[38;5;10m[49m                 "month": timedelta(days=quantity * 30),  # approximate
[0m[49m[38;5;10m+     453[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+     454[0m:[38;5;10m[49m             delta = delta_map.get(unit, timedelta(days=quantity))
[0m[49m[38;5;10m+     455[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     456[0m:[38;5;10m[49m             if direction in ("ago", "before", "prior"):
[0m[49m[38;5;10m+     457[0m:[38;5;10m[49m                 resolved = doc_time - delta
[0m[49m[38;5;10m+     458[0m:[38;5;10m[49m             else:
[0m[49m[38;5;10m+     459[0m:[38;5;10m[49m                 resolved = doc_time + delta
[0m[49m[38;5;10m+     460[0m:[38;5;10m[49m             return resolved.isoformat()
[0m[49m[38;5;10m+     461[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     462[0m:[38;5;10m[49m         elif pattern_type == "pod":
[0m[49m[38;5;10m+     463[0m:[38;5;10m[49m             pod_num = int(match.group(1))
[0m[49m[38;5;10m+     464[0m:[38;5;10m[49m             # POD anchors to a surgery date. In a real system, you'd look up
[0m[49m[38;5;10m+     465[0m:[38;5;10m[49m             # the surgery date from the note. Here we search for it in context.
[0m[49m[38;5;10m+     466[0m:[38;5;10m[49m             surgery_date = find_surgery_date_in_context(full_text, doc_time)
[0m[49m[38;5;10m+     467[0m:[38;5;10m[49m             if surgery_date:
[0m[49m[38;5;10m+     468[0m:[38;5;10m[49m                 resolved = surgery_date + timedelta(days=pod_num)
[0m[49m[38;5;10m+     469[0m:[38;5;10m[49m                 return resolved.isoformat()
[0m[49m[38;5;10m+     470[0m:[38;5;10m[49m             return f"POD+{pod_num}"  # unresolved, relative only
[0m[49m[38;5;10m+     471[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     472[0m:[38;5;10m[49m         elif pattern_type == "hospital_day":
[0m[49m[38;5;10m+     473[0m:[38;5;10m[49m             hd_num = int(match.group(1))
[0m[49m[38;5;10m+     474[0m:[38;5;10m[49m             # Anchor to admission date. Search note for admission date.
[0m[49m[38;5;10m+     475[0m:[38;5;10m[49m             admission_date = find_admission_date_in_context(full_text, doc_time)
[0m[49m[38;5;10m+     476[0m:[38;5;10m[49m             if admission_date:
[0m[49m[38;5;10m+     477[0m:[38;5;10m[49m                 resolved = admission_date + timedelta(days=hd_num - 1)
[0m[49m[38;5;10m+     478[0m:[38;5;10m[49m                 return resolved.isoformat()
[0m[49m[38;5;10m+     479[0m:[38;5;10m[49m             return f"HD+{hd_num}"
[0m[49m[38;5;10m+     480[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     481[0m:[38;5;10m[49m         elif pattern_type == "perioperative":
[0m[49m[38;5;10m+     482[0m:[38;5;10m[49m             prefix = match.group(1).lower()
[0m[49m[38;5;10m+     483[0m:[38;5;10m[49m             # "postoperatively" = after surgery, "preoperatively" = before surgery
[0m[49m[38;5;10m+     484[0m:[38;5;10m[49m             return f"{'POST' if prefix == 'post' else 'PRE'}_SURGERY"
[0m[49m[38;5;10m+     485[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     486[0m:[38;5;10m[49m         elif pattern_type == "day_of_life":
[0m[49m[38;5;10m+     487[0m:[38;5;10m[49m             dol = int(match.group(1))
[0m[49m[38;5;10m+     488[0m:[38;5;10m[49m             return f"DOL+{dol}"
[0m[49m[38;5;10m+     489[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     490[0m:[38;5;10m[49m         elif pattern_type == "transplant_day":
[0m[49m[38;5;10m+     491[0m:[38;5;10m[49m             t_day = int(match.group(1))
[0m[49m[38;5;10m+     492[0m:[38;5;10m[49m             return f"T+{t_day}"
[0m[49m[38;5;10m+     493[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     494[0m:[38;5;10m[49m     except (ValueError, TypeError):
[0m[49m[38;5;10m+     495[0m:[38;5;10m[49m         pass
[0m[49m[38;5;10m+     496[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     497[0m:[38;5;10m[49m     return None  # Could not normalize
[0m[49m[38;5;10m+     498[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     499[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     500[0m:[38;5;10m[49m def find_surgery_date_in_context(note_text, doc_time):
[0m[49m[38;5;10m+     501[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     502[0m:[38;5;10m[49m     Search the note for an explicit surgery date to anchor POD references.
[0m[49m[38;5;10m+     503[0m:[38;5;10m[49m     Looks for patterns like "cholecystectomy performed on March 6" or
[0m[49m[38;5;10m+     504[0m:[38;5;10m[49m     "surgery on 3/6/2024".
[0m[49m[38;5;10m+     505[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     506[0m:[38;5;10m[49m     # Look for "performed on [date]" or "surgery on [date]"
[0m[49m[38;5;10m+     507[0m:[38;5;10m[49m     date_pattern = r"(?:performed|surgery|operation)\s+(?:on\s+)?(January|February|March|April|May|June|July|August|September|October|November|December)\s+(\d{1,2}),?\s*(\d{4})?"
[0m[49m[38;5;10m+     508[0m:[38;5;10m[49m     match = re.search(date_pattern, note_text, re.IGNORECASE)
[0m[49m[38;5;10m+     509[0m:[38;5;10m[49m     if match:
[0m[49m[38;5;10m+     510[0m:[38;5;10m[49m         month_name = match.group(1)
[0m[49m[38;5;10m+     511[0m:[38;5;10m[49m         day = int(match.group(2))
[0m[49m[38;5;10m+     512[0m:[38;5;10m[49m         year = int(match.group(3)) if match.group(3) else doc_time.year
[0m[49m[38;5;10m+     513[0m:[38;5;10m[49m         month_num = datetime.datetime.strptime(month_name, "%B").month
[0m[49m[38;5;10m+     514[0m:[38;5;10m[49m         return datetime.datetime(year, month_num, day, tzinfo=timezone.utc)
[0m[49m[38;5;10m+     515[0m:[38;5;10m[49m     return None
[0m[49m[38;5;10m+     516[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     517[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     518[0m:[38;5;10m[49m def find_admission_date_in_context(note_text, doc_time):
[0m[49m[38;5;10m+     519[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     520[0m:[38;5;10m[49m     Search the note for an explicit admission date to anchor HD references.
[0m[49m[38;5;10m+     521[0m:[38;5;10m[49m     Looks for patterns like "Admission Date: March 3, 2024" or
[0m[49m[38;5;10m+     522[0m:[38;5;10m[49m     "admitted on 3/3/2024".
[0m[49m[38;5;10m+     523[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     524[0m:[38;5;10m[49m     # Look for "Admission Date:" header pattern.
[0m[49m[38;5;10m+     525[0m:[38;5;10m[49m     pattern = r"Admission\s+Date:\s*(January|February|March|April|May|June|July|August|September|October|November|December)\s+(\d{1,2}),?\s*(\d{4})?"
[0m[49m[38;5;10m+     526[0m:[38;5;10m[49m     match = re.search(pattern, note_text, re.IGNORECASE)
[0m[49m[38;5;10m+     527[0m:[38;5;10m[49m     if match:
[0m[49m[38;5;10m+     528[0m:[38;5;10m[49m         month_name = match.group(1)
[0m[49m[38;5;10m+     529[0m:[38;5;10m[49m         day = int(match.group(2))
[0m[49m[38;5;10m+     530[0m:[38;5;10m[49m         year = int(match.group(3)) if match.group(3) else doc_time.year
[0m[49m[38;5;10m+     531[0m:[38;5;10m[49m         month_num = datetime.datetime.strptime(month_name, "%B").month
[0m[49m[38;5;10m+     532[0m:[38;5;10m[49m         return datetime.datetime(year, month_num, day, tzinfo=timezone.utc)
[0m[49m[38;5;10m+     533[0m:[38;5;10m[49m     return None
[0m[49m[38;5;10m+     534[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     535[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     536[0m:[38;5;10m[49m def detect_temporal_entities(preprocessed_note):
[0m[49m[38;5;10m+     537[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     538[0m:[38;5;10m[49m     Step 2: Detect clinical events and temporal expressions.
[0m[49m[38;5;10m+     539[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     540[0m:[38;5;10m[49m     Combines Comprehend Medical entity detection (for clinical events)
[0m[49m[38;5;10m+     541[0m:[38;5;10m[49m     with rule-based temporal expression recognition (for time references).
[0m[49m[38;5;10m+     542[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     543[0m:[38;5;10m[49m     events = detect_events_with_comprehend(preprocessed_note["full_text"])
[0m[49m[38;5;10m+     544[0m:[38;5;10m[49m     temporal_expressions = recognize_temporal_expressions(
[0m[49m[38;5;10m+     545[0m:[38;5;10m[49m         preprocessed_note["full_text"],
[0m[49m[38;5;10m+     546[0m:[38;5;10m[49m         preprocessed_note["doc_time"],
[0m[49m[38;5;10m+     547[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     548[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     549[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     550[0m:[38;5;10m[49m         "events": events,
[0m[49m[38;5;10m+     551[0m:[38;5;10m[49m         "temporal_expressions": temporal_expressions,
[0m[49m[38;5;10m+     552[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     553[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     554[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     555[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     556[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     557[0m:[38;5;10m[49m ## Step 3: Generate Candidate Pairs
[0m[49m[38;5;10m+     558[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     559[0m:[38;5;10m[49m *The pseudocode calls this `generate_candidate_pairs(events, temporal_expressions, sentences)`. With N entities, the full pairwise space is N*(N-1)/2. For a note with 50 entities, that's 1,225 pairs. Most are irrelevant. This step applies heuristics to select only pairs likely to have a meaningful temporal relationship, reducing classification workload by 80-90%.*
[0m[49m[38;5;10m+     560[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     561[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     562[0m:[38;5;10m[49m def find_sentence_index(offset, sentences, full_text):
[0m[49m[38;5;10m+     563[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     564[0m:[38;5;10m[49m     Given a character offset into the full text, find which sentence it belongs to.
[0m[49m[38;5;10m+     565[0m:[38;5;10m[49m     Returns the sentence index (0-based).
[0m[49m[38;5;10m+     566[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     567[0m:[38;5;10m[49m     current_pos = 0
[0m[49m[38;5;10m+     568[0m:[38;5;10m[49m     for idx, sent in enumerate(sentences):
[0m[49m[38;5;10m+     569[0m:[38;5;10m[49m         sent_start = full_text.find(sent, current_pos)
[0m[49m[38;5;10m+     570[0m:[38;5;10m[49m         if sent_start == -1:
[0m[49m[38;5;10m+     571[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     572[0m:[38;5;10m[49m         sent_end = sent_start + len(sent)
[0m[49m[38;5;10m+     573[0m:[38;5;10m[49m         if sent_start <= offset < sent_end:
[0m[49m[38;5;10m+     574[0m:[38;5;10m[49m             return idx
[0m[49m[38;5;10m+     575[0m:[38;5;10m[49m         current_pos = sent_end
[0m[49m[38;5;10m+     576[0m:[38;5;10m[49m     return -1
[0m[49m[38;5;10m+     577[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     578[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     579[0m:[38;5;10m[49m def find_temporal_signal_between(entity_a, entity_b, full_text):
[0m[49m[38;5;10m+     580[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     581[0m:[38;5;10m[49m     Check if there's a temporal signal word between two entities.
[0m[49m[38;5;10m+     582[0m:[38;5;10m[49m     If found, return the signal word and its implied relation.
[0m[49m[38;5;10m+     583[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     584[0m:[38;5;10m[49m     # Get the text between the two entities.
[0m[49m[38;5;10m+     585[0m:[38;5;10m[49m     start = min(entity_a["end_offset"], entity_b["end_offset"])
[0m[49m[38;5;10m+     586[0m:[38;5;10m[49m     end = max(entity_a["begin_offset"], entity_b["begin_offset"])
[0m[49m[38;5;10m+     587[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     588[0m:[38;5;10m[49m     if end <= start:
[0m[49m[38;5;10m+     589[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+     590[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     591[0m:[38;5;10m[49m     between_text = full_text[start:end].lower()
[0m[49m[38;5;10m+     592[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     593[0m:[38;5;10m[49m     for signal, relation in TEMPORAL_SIGNALS.items():
[0m[49m[38;5;10m+     594[0m:[38;5;10m[49m         if signal in between_text:
[0m[49m[38;5;10m+     595[0m:[38;5;10m[49m             return {"signal": signal, "implied_relation": relation}
[0m[49m[38;5;10m+     596[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     597[0m:[38;5;10m[49m     return None
[0m[49m[38;5;10m+     598[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     599[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     600[0m:[38;5;10m[49m def generate_candidate_pairs(entities, sentences, full_text):
[0m[49m[38;5;10m+     601[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     602[0m:[38;5;10m[49m     Step 3: Generate candidate entity pairs for temporal relation classification.
[0m[49m[38;5;10m+     603[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     604[0m:[38;5;10m[49m     Applies filtering heuristics to reduce the pairwise space:
[0m[49m[38;5;10m+     605[0m:[38;5;10m[49m     1. Same-sentence pairs (highest probability of explicit relationship)
[0m[49m[38;5;10m+     606[0m:[38;5;10m[49m     2. Adjacent-sentence pairs (narrative flow implies ordering)
[0m[49m[38;5;10m+     607[0m:[38;5;10m[49m     3. Pairs with temporal signal words between them
[0m[49m[38;5;10m+     608[0m:[38;5;10m[49m     4. Event-to-nearest-temporal-expression pairs
[0m[49m[38;5;10m+     609[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     610[0m:[38;5;10m[49m     Returns a list of candidate pairs with their heuristic source.
[0m[49m[38;5;10m+     611[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     612[0m:[38;5;10m[49m     all_entities = entities["events"] + entities["temporal_expressions"]
[0m[49m[38;5;10m+     613[0m:[38;5;10m[49m     candidates = []
[0m[49m[38;5;10m+     614[0m:[38;5;10m[49m     seen_pairs = set()
[0m[49m[38;5;10m+     615[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     616[0m:[38;5;10m[49m     # Precompute sentence indices for all entities.
[0m[49m[38;5;10m+     617[0m:[38;5;10m[49m     for ent in all_entities:
[0m[49m[38;5;10m+     618[0m:[38;5;10m[49m         ent["sentence_idx"] = find_sentence_index(
[0m[49m[38;5;10m+     619[0m:[38;5;10m[49m             ent["begin_offset"], sentences, full_text
[0m[49m[38;5;10m+     620[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     621[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     622[0m:[38;5;10m[49m     for i, entity_a in enumerate(all_entities):
[0m[49m[38;5;10m+     623[0m:[38;5;10m[49m         for j, entity_b in enumerate(all_entities):
[0m[49m[38;5;10m+     624[0m:[38;5;10m[49m             if i >= j:
[0m[49m[38;5;10m+     625[0m:[38;5;10m[49m                 continue  # avoid duplicates and self-pairs
[0m[49m[38;5;10m+     626[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     627[0m:[38;5;10m[49m             pair_key = (entity_a["id"], entity_b["id"])
[0m[49m[38;5;10m+     628[0m:[38;5;10m[49m             if pair_key in seen_pairs:
[0m[49m[38;5;10m+     629[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+     630[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     631[0m:[38;5;10m[49m             sent_a = entity_a.get("sentence_idx", -1)
[0m[49m[38;5;10m+     632[0m:[38;5;10m[49m             sent_b = entity_b.get("sentence_idx", -1)
[0m[49m[38;5;10m+     633[0m:[38;5;10m[49m             sentence_distance = abs(sent_a - sent_b) if sent_a >= 0 and sent_b >= 0 else 999
[0m[49m[38;5;10m+     634[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     635[0m:[38;5;10m[49m             # Heuristic 1: Same sentence.
[0m[49m[38;5;10m+     636[0m:[38;5;10m[49m             if sentence_distance == 0:
[0m[49m[38;5;10m+     637[0m:[38;5;10m[49m                 candidates.append((entity_a, entity_b, "same_sentence"))
[0m[49m[38;5;10m+     638[0m:[38;5;10m[49m                 seen_pairs.add(pair_key)
[0m[49m[38;5;10m+     639[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+     640[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     641[0m:[38;5;10m[49m             # Heuristic 2: Adjacent sentences (within MAX_SENTENCE_DISTANCE).
[0m[49m[38;5;10m+     642[0m:[38;5;10m[49m             if sentence_distance <= MAX_SENTENCE_DISTANCE:
[0m[49m[38;5;10m+     643[0m:[38;5;10m[49m                 candidates.append((entity_a, entity_b, "adjacent"))
[0m[49m[38;5;10m+     644[0m:[38;5;10m[49m                 seen_pairs.add(pair_key)
[0m[49m[38;5;10m+     645[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+     646[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     647[0m:[38;5;10m[49m             # Heuristic 3: Temporal signal word between them.
[0m[49m[38;5;10m+     648[0m:[38;5;10m[49m             signal = find_temporal_signal_between(entity_a, entity_b, full_text)
[0m[49m[38;5;10m+     649[0m:[38;5;10m[49m             if signal:
[0m[49m[38;5;10m+     650[0m:[38;5;10m[49m                 candidates.append((entity_a, entity_b, "signal_connected"))
[0m[49m[38;5;10m+     651[0m:[38;5;10m[49m                 seen_pairs.add(pair_key)
[0m[49m[38;5;10m+     652[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+     653[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     654[0m:[38;5;10m[49m             # Heuristic 4: Event paired with nearest temporal expression.
[0m[49m[38;5;10m+     655[0m:[38;5;10m[49m             if (entity_a["entity_type"] == "EVENT" and
[0m[49m[38;5;10m+     656[0m:[38;5;10m[49m                 entity_b["entity_type"] == "TEMPORAL_EXPRESSION"):
[0m[49m[38;5;10m+     657[0m:[38;5;10m[49m                 if sentence_distance <= MAX_SENTENCE_DISTANCE + 1:
[0m[49m[38;5;10m+     658[0m:[38;5;10m[49m                     candidates.append((entity_a, entity_b, "nearest_anchor"))
[0m[49m[38;5;10m+     659[0m:[38;5;10m[49m                     seen_pairs.add(pair_key)
[0m[49m[38;5;10m+     660[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     661[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+     662[0m:[38;5;10m[49m         "Generated %d candidate pairs from %d entities",
[0m[49m[38;5;10m+     663[0m:[38;5;10m[49m         len(candidates), len(all_entities)
[0m[49m[38;5;10m+     664[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     665[0m:[38;5;10m[49m     return candidates
[0m[49m[38;5;10m+     666[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     667[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     668[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     669[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     670[0m:[38;5;10m[49m ## Step 4: Classify Temporal Relations
[0m[49m[38;5;10m+     671[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     672[0m:[38;5;10m[49m *The pseudocode calls this `classify_relations(candidate_pairs, full_text, sections)`. For each candidate pair, we build a context window and send it to the trained temporal relation classifier. The classifier predicts BEFORE, AFTER, OVERLAP, CONTAINS, or NONE with a confidence score. Low-confidence predictions are excluded from the final graph.*
[0m[49m[38;5;10m+     673[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     674[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     675[0m:[38;5;10m[49m def build_context_window(entity_a, entity_b, full_text, window_chars=300):
[0m[49m[38;5;10m+     676[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     677[0m:[38;5;10m[49m     Build a text context window around an entity pair for classification.
[0m[49m[38;5;10m+     678[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     679[0m:[38;5;10m[49m     The context includes the text of both entities, surrounding text, and
[0m[49m[38;5;10m+     680[0m:[38;5;10m[49m     special markers to indicate which spans are the target entities.
[0m[49m[38;5;10m+     681[0m:[38;5;10m[49m     The classifier needs this context to determine the temporal relationship.
[0m[49m[38;5;10m+     682[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     683[0m:[38;5;10m[49m     # Find the broader span encompassing both entities.
[0m[49m[38;5;10m+     684[0m:[38;5;10m[49m     start = min(entity_a["begin_offset"], entity_b["begin_offset"])
[0m[49m[38;5;10m+     685[0m:[38;5;10m[49m     end = max(entity_a["end_offset"], entity_b["end_offset"])
[0m[49m[38;5;10m+     686[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     687[0m:[38;5;10m[49m     # Expand the window for context.
[0m[49m[38;5;10m+     688[0m:[38;5;10m[49m     context_start = max(0, start - window_chars)
[0m[49m[38;5;10m+     689[0m:[38;5;10m[49m     context_end = min(len(full_text), end + window_chars)
[0m[49m[38;5;10m+     690[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     691[0m:[38;5;10m[49m     context = full_text[context_start:context_end]
[0m[49m[38;5;10m+     692[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     693[0m:[38;5;10m[49m     # Mark the entities in the context for the classifier.
[0m[49m[38;5;10m+     694[0m:[38;5;10m[49m     # Using the [E1]...[/E1] and [E2]...[/E2] convention from relation extraction literature.
[0m[49m[38;5;10m+     695[0m:[38;5;10m[49m     # Adjust offsets relative to context window.
[0m[49m[38;5;10m+     696[0m:[38;5;10m[49m     a_start_rel = entity_a["begin_offset"] - context_start
[0m[49m[38;5;10m+     697[0m:[38;5;10m[49m     a_end_rel = entity_a["end_offset"] - context_start
[0m[49m[38;5;10m+     698[0m:[38;5;10m[49m     b_start_rel = entity_b["begin_offset"] - context_start
[0m[49m[38;5;10m+     699[0m:[38;5;10m[49m     b_end_rel = entity_b["end_offset"] - context_start
[0m[49m[38;5;10m+     700[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     701[0m:[38;5;10m[49m     # Insert markers (order matters: insert from end to start to preserve offsets).
[0m[49m[38;5;10m+     702[0m:[38;5;10m[49m     marked = list(context)
[0m[49m[38;5;10m+     703[0m:[38;5;10m[49m     insertions = sorted([
[0m[49m[38;5;10m+     704[0m:[38;5;10m[49m         (a_start_rel, "[E1]"),
[0m[49m[38;5;10m+     705[0m:[38;5;10m[49m         (a_end_rel, "[/E1]"),
[0m[49m[38;5;10m+     706[0m:[38;5;10m[49m         (b_start_rel, "[E2]"),
[0m[49m[38;5;10m+     707[0m:[38;5;10m[49m         (b_end_rel, "[/E2]"),
[0m[49m[38;5;10m+     708[0m:[38;5;10m[49m     ], key=lambda x: x[0], reverse=True)
[0m[49m[38;5;10m+     709[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     710[0m:[38;5;10m[49m     for pos, marker in insertions:
[0m[49m[38;5;10m+     711[0m:[38;5;10m[49m         if 0 <= pos <= len(marked):
[0m[49m[38;5;10m+     712[0m:[38;5;10m[49m             marked.insert(pos, marker)
[0m[49m[38;5;10m+     713[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     714[0m:[38;5;10m[49m     return "".join(marked)
[0m[49m[38;5;10m+     715[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     716[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     717[0m:[38;5;10m[49m def classify_with_sagemaker(formatted_input):
[0m[49m[38;5;10m+     718[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     719[0m:[38;5;10m[49m     Call the SageMaker endpoint to classify the temporal relation between two entities.
[0m[49m[38;5;10m+     720[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     721[0m:[38;5;10m[49m     The endpoint hosts a fine-tuned model (e.g., ClinicalBERT) trained on temporal
[0m[49m[38;5;10m+     722[0m:[38;5;10m[49m     relation annotated data. It accepts marked-up text and returns a relation
[0m[49m[38;5;10m+     723[0m:[38;5;10m[49m     label with confidence score.
[0m[49m[38;5;10m+     724[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     725[0m:[38;5;10m[49m     In production, this is where the heavy lifting happens. The model has learned
[0m[49m[38;5;10m+     726[0m:[38;5;10m[49m     from annotated clinical text which contextual cues indicate BEFORE vs. AFTER
[0m[49m[38;5;10m+     727[0m:[38;5;10m[49m     vs. OVERLAP relationships.
[0m[49m[38;5;10m+     728[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     729[0m:[38;5;10m[49m     payload = json.dumps({"text": formatted_input})
[0m[49m[38;5;10m+     730[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     731[0m:[38;5;10m[49m     response = sagemaker_runtime_client.invoke_endpoint(
[0m[49m[38;5;10m+     732[0m:[38;5;10m[49m         EndpointName=SAGEMAKER_ENDPOINT_NAME,
[0m[49m[38;5;10m+     733[0m:[38;5;10m[49m         ContentType="application/json",
[0m[49m[38;5;10m+     734[0m:[38;5;10m[49m         Body=payload,
[0m[49m[38;5;10m+     735[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     736[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     737[0m:[38;5;10m[49m     result = json.loads(response["Body"].read().decode("utf-8"))
[0m[49m[38;5;10m+     738[0m:[38;5;10m[49m     # Expected response: {"label": "BEFORE", "confidence": 0.87}
[0m[49m[38;5;10m+     739[0m:[38;5;10m[49m     return result
[0m[49m[38;5;10m+     740[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     741[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     742[0m:[38;5;10m[49m def classify_with_rules(entity_a, entity_b, full_text):
[0m[49m[38;5;10m+     743[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     744[0m:[38;5;10m[49m     Rule-based temporal relation classification for cases with explicit signals.
[0m[49m[38;5;10m+     745[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     746[0m:[38;5;10m[49m     Before calling the ML model, check for obvious cases:
[0m[49m[38;5;10m+     747[0m:[38;5;10m[49m     1. Explicit temporal signal word between entities
[0m[49m[38;5;10m+     748[0m:[38;5;10m[49m     2. Entity anchored to a resolved temporal expression
[0m[49m[38;5;10m+     749[0m:[38;5;10m[49m     3. Narrative ordering within the same section
[0m[49m[38;5;10m+     750[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     751[0m:[38;5;10m[49m     Returns a prediction dict or None if rules don't apply.
[0m[49m[38;5;10m+     752[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     753[0m:[38;5;10m[49m     # Check for temporal signal words between the entities.
[0m[49m[38;5;10m+     754[0m:[38;5;10m[49m     signal = find_temporal_signal_between(entity_a, entity_b, full_text)
[0m[49m[38;5;10m+     755[0m:[38;5;10m[49m     if signal:
[0m[49m[38;5;10m+     756[0m:[38;5;10m[49m         # Determine direction: is entity_a before or after the signal word?
[0m[49m[38;5;10m+     757[0m:[38;5;10m[49m         if entity_a["begin_offset"] < entity_b["begin_offset"]:
[0m[49m[38;5;10m+     758[0m:[38;5;10m[49m             relation = signal["implied_relation"]
[0m[49m[38;5;10m+     759[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+     760[0m:[38;5;10m[49m             # Entities are in reverse order relative to signal.
[0m[49m[38;5;10m+     761[0m:[38;5;10m[49m             # Flip the relation.
[0m[49m[38;5;10m+     762[0m:[38;5;10m[49m             flip = {"BEFORE": "AFTER", "AFTER": "BEFORE",
[0m[49m[38;5;10m+     763[0m:[38;5;10m[49m                     "OVERLAP": "OVERLAP", "CONTAINS": "CONTAINS"}
[0m[49m[38;5;10m+     764[0m:[38;5;10m[49m             relation = flip.get(signal["implied_relation"], signal["implied_relation"])
[0m[49m[38;5;10m+     765[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     766[0m:[38;5;10m[49m         return {"label": relation, "confidence": 0.85, "source": "rule_signal"}
[0m[49m[38;5;10m+     767[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     768[0m:[38;5;10m[49m     # Check if both entities have resolved temporal expressions we can compare.
[0m[49m[38;5;10m+     769[0m:[38;5;10m[49m     if (entity_a.get("entity_type") == "TEMPORAL_EXPRESSION" and
[0m[49m[38;5;10m+     770[0m:[38;5;10m[49m         entity_b.get("entity_type") == "TEMPORAL_EXPRESSION"):
[0m[49m[38;5;10m+     771[0m:[38;5;10m[49m         norm_a = entity_a.get("normalized")
[0m[49m[38;5;10m+     772[0m:[38;5;10m[49m         norm_b = entity_b.get("normalized")
[0m[49m[38;5;10m+     773[0m:[38;5;10m[49m         if norm_a and norm_b and "T" in str(norm_a) and "T" in str(norm_b):
[0m[49m[38;5;10m+     774[0m:[38;5;10m[49m             try:
[0m[49m[38;5;10m+     775[0m:[38;5;10m[49m                 dt_a = datetime.datetime.fromisoformat(norm_a)
[0m[49m[38;5;10m+     776[0m:[38;5;10m[49m                 dt_b = datetime.datetime.fromisoformat(norm_b)
[0m[49m[38;5;10m+     777[0m:[38;5;10m[49m                 if dt_a < dt_b:
[0m[49m[38;5;10m+     778[0m:[38;5;10m[49m                     return {"label": "BEFORE", "confidence": 0.95, "source": "rule_date"}
[0m[49m[38;5;10m+     779[0m:[38;5;10m[49m                 elif dt_a > dt_b:
[0m[49m[38;5;10m+     780[0m:[38;5;10m[49m                     return {"label": "AFTER", "confidence": 0.95, "source": "rule_date"}
[0m[49m[38;5;10m+     781[0m:[38;5;10m[49m                 else:
[0m[49m[38;5;10m+     782[0m:[38;5;10m[49m                     return {"label": "OVERLAP", "confidence": 0.90, "source": "rule_date"}
[0m[49m[38;5;10m+     783[0m:[38;5;10m[49m             except (ValueError, TypeError):
[0m[49m[38;5;10m+     784[0m:[38;5;10m[49m                 pass
[0m[49m[38;5;10m+     785[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     786[0m:[38;5;10m[49m     return None  # No rule applies; defer to ML model.
[0m[49m[38;5;10m+     787[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     788[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     789[0m:[38;5;10m[49m def classify_relations(candidate_pairs, full_text, sections):
[0m[49m[38;5;10m+     790[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     791[0m:[38;5;10m[49m     Step 4: Classify temporal relationships for all candidate pairs.
[0m[49m[38;5;10m+     792[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     793[0m:[38;5;10m[49m     Uses a hybrid approach: rule-based classification for obvious cases
[0m[49m[38;5;10m+     794[0m:[38;5;10m[49m     (explicit signal words, resolved dates), ML model for ambiguous cases.
[0m[49m[38;5;10m+     795[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     796[0m:[38;5;10m[49m     classified = []
[0m[49m[38;5;10m+     797[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     798[0m:[38;5;10m[49m     for entity_a, entity_b, pair_type in candidate_pairs:
[0m[49m[38;5;10m+     799[0m:[38;5;10m[49m         # Try rule-based classification first (fast, high precision).
[0m[49m[38;5;10m+     800[0m:[38;5;10m[49m         rule_result = classify_with_rules(entity_a, entity_b, full_text)
[0m[49m[38;5;10m+     801[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     802[0m:[38;5;10m[49m         if rule_result and rule_result["confidence"] >= RELATION_CONFIDENCE_THRESHOLD:
[0m[49m[38;5;10m+     803[0m:[38;5;10m[49m             prediction = rule_result
[0m[49m[38;5;10m+     804[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+     805[0m:[38;5;10m[49m             # Fall back to ML model for ambiguous cases.
[0m[49m[38;5;10m+     806[0m:[38;5;10m[49m             context_window = build_context_window(entity_a, entity_b, full_text)
[0m[49m[38;5;10m+     807[0m:[38;5;10m[49m             prediction = classify_with_sagemaker(context_window)
[0m[49m[38;5;10m+     808[0m:[38;5;10m[49m             prediction["source"] = "ml_model"
[0m[49m[38;5;10m+     809[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     810[0m:[38;5;10m[49m         # Apply confidence threshold.
[0m[49m[38;5;10m+     811[0m:[38;5;10m[49m         if prediction.get("confidence", 0) >= RELATION_CONFIDENCE_THRESHOLD:
[0m[49m[38;5;10m+     812[0m:[38;5;10m[49m             if prediction["label"] != "NONE":
[0m[49m[38;5;10m+     813[0m:[38;5;10m[49m                 classified.append({
[0m[49m[38;5;10m+     814[0m:[38;5;10m[49m                     "entity_a": entity_a,
[0m[49m[38;5;10m+     815[0m:[38;5;10m[49m                     "entity_b": entity_b,
[0m[49m[38;5;10m+     816[0m:[38;5;10m[49m                     "relation": prediction["label"],
[0m[49m[38;5;10m+     817[0m:[38;5;10m[49m                     "confidence": prediction["confidence"],
[0m[49m[38;5;10m+     818[0m:[38;5;10m[49m                     "source": prediction.get("source", "unknown"),
[0m[49m[38;5;10m+     819[0m:[38;5;10m[49m                     "pair_type": pair_type,
[0m[49m[38;5;10m+     820[0m:[38;5;10m[49m                 })
[0m[49m[38;5;10m+     821[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     822[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+     823[0m:[38;5;10m[49m         "Classified %d temporal relations (from %d candidates)",
[0m[49m[38;5;10m+     824[0m:[38;5;10m[49m         len(classified), len(candidate_pairs)
[0m[49m[38;5;10m+     825[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     826[0m:[38;5;10m[49m     return classified
[0m[49m[38;5;10m+     827[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     828[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     829[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     830[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     831[0m:[38;5;10m[49m ## Step 5: Build the Temporal Graph and Propagate Constraints
[0m[49m[38;5;10m+     832[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     833[0m:[38;5;10m[49m *The pseudocode calls this `build_temporal_graph(classified_relations, events, temporal_expressions)`. This step assembles classified relations into a directed graph, applies transitivity to infer additional relations, and detects/resolves inconsistencies (cycles). If A BEFORE B and B BEFORE C, we can infer A BEFORE C without the classifier having to see that pair directly.*
[0m[49m[38;5;10m+     834[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     835[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     836[0m:[38;5;10m[49m def build_temporal_graph(classified_relations, events, temporal_expressions):
[0m[49m[38;5;10m+     837[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     838[0m:[38;5;10m[49m     Step 5: Build a temporal graph from classified relations.
[0m[49m[38;5;10m+     839[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     840[0m:[38;5;10m[49m     Nodes are events and temporal expressions.
[0m[49m[38;5;10m+     841[0m:[38;5;10m[49m     Edges are temporal relations with confidence scores.
[0m[49m[38;5;10m+     842[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     843[0m:[38;5;10m[49m     After building the initial graph from classifier output, apply:
[0m[49m[38;5;10m+     844[0m:[38;5;10m[49m     1. Transitive closure (if A BEFORE B and B BEFORE C, infer A BEFORE C)
[0m[49m[38;5;10m+     845[0m:[38;5;10m[49m     2. Cycle detection (contradictions in the BEFORE/AFTER subgraph)
[0m[49m[38;5;10m+     846[0m:[38;5;10m[49m     3. Cycle resolution (remove lowest-confidence edge)
[0m[49m[38;5;10m+     847[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     848[0m:[38;5;10m[49m     # Build adjacency representation.
[0m[49m[38;5;10m+     849[0m:[38;5;10m[49m     # nodes[id] = entity data
[0m[49m[38;5;10m+     850[0m:[38;5;10m[49m     # edges = list of (from_id, to_id, relation, confidence)
[0m[49m[38;5;10m+     851[0m:[38;5;10m[49m     nodes = {}
[0m[49m[38;5;10m+     852[0m:[38;5;10m[49m     edges = []
[0m[49m[38;5;10m+     853[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     854[0m:[38;5;10m[49m     for event in events:
[0m[49m[38;5;10m+     855[0m:[38;5;10m[49m         nodes[event["id"]] = event
[0m[49m[38;5;10m+     856[0m:[38;5;10m[49m     for texpr in temporal_expressions:
[0m[49m[38;5;10m+     857[0m:[38;5;10m[49m         nodes[texpr["id"]] = texpr
[0m[49m[38;5;10m+     858[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     859[0m:[38;5;10m[49m     for rel in classified_relations:
[0m[49m[38;5;10m+     860[0m:[38;5;10m[49m         edges.append({
[0m[49m[38;5;10m+     861[0m:[38;5;10m[49m             "from": rel["entity_a"]["id"],
[0m[49m[38;5;10m+     862[0m:[38;5;10m[49m             "to": rel["entity_b"]["id"],
[0m[49m[38;5;10m+     863[0m:[38;5;10m[49m             "relation": rel["relation"],
[0m[49m[38;5;10m+     864[0m:[38;5;10m[49m             "confidence": rel["confidence"],
[0m[49m[38;5;10m+     865[0m:[38;5;10m[49m             "inferred": False,
[0m[49m[38;5;10m+     866[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     867[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     868[0m:[38;5;10m[49m     # Transitive closure for BEFORE relations.
[0m[49m[38;5;10m+     869[0m:[38;5;10m[49m     # If A BEFORE B and B BEFORE C, add A BEFORE C.
[0m[49m[38;5;10m+     870[0m:[38;5;10m[49m     before_edges = [e for e in edges if e["relation"] == "BEFORE"]
[0m[49m[38;5;10m+     871[0m:[38;5;10m[49m     inferred_edges = []
[0m[49m[38;5;10m+     872[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     873[0m:[38;5;10m[49m     # Build a quick adjacency map for BEFORE relations.
[0m[49m[38;5;10m+     874[0m:[38;5;10m[49m     before_map = defaultdict(set)  # from_id -> set of to_ids
[0m[49m[38;5;10m+     875[0m:[38;5;10m[49m     for e in before_edges:
[0m[49m[38;5;10m+     876[0m:[38;5;10m[49m         before_map[e["from"]].add(e["to"])
[0m[49m[38;5;10m+     877[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     878[0m:[38;5;10m[49m     # One pass of transitivity (not full closure, but catches immediate chains).
[0m[49m[38;5;10m+     879[0m:[38;5;10m[49m     for a_id, b_ids in before_map.items():
[0m[49m[38;5;10m+     880[0m:[38;5;10m[49m         for b_id in list(b_ids):
[0m[49m[38;5;10m+     881[0m:[38;5;10m[49m             for c_id in before_map.get(b_id, set()):
[0m[49m[38;5;10m+     882[0m:[38;5;10m[49m                 if c_id != a_id and c_id not in before_map[a_id]:
[0m[49m[38;5;10m+     883[0m:[38;5;10m[49m                     inferred_edges.append({
[0m[49m[38;5;10m+     884[0m:[38;5;10m[49m                         "from": a_id,
[0m[49m[38;5;10m+     885[0m:[38;5;10m[49m                         "to": c_id,
[0m[49m[38;5;10m+     886[0m:[38;5;10m[49m                         "relation": "BEFORE",
[0m[49m[38;5;10m+     887[0m:[38;5;10m[49m                         "confidence": 0.60,  # lower confidence for inferred relations
[0m[49m[38;5;10m+     888[0m:[38;5;10m[49m                         "inferred": True,
[0m[49m[38;5;10m+     889[0m:[38;5;10m[49m                     })
[0m[49m[38;5;10m+     890[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     891[0m:[38;5;10m[49m     edges.extend(inferred_edges)
[0m[49m[38;5;10m+     892[0m:[38;5;10m[49m     logger.info("Inferred %d transitive relations", len(inferred_edges))
[0m[49m[38;5;10m+     893[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     894[0m:[38;5;10m[49m     # Cycle detection in the BEFORE/AFTER subgraph.
[0m[49m[38;5;10m+     895[0m:[38;5;10m[49m     # A cycle means contradictory temporal ordering (A before B before C before A).
[0m[49m[38;5;10m+     896[0m:[38;5;10m[49m     removed_edges = detect_and_resolve_cycles(edges)
[0m[49m[38;5;10m+     897[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     898[0m:[38;5;10m[49m     # Remove flagged edges.
[0m[49m[38;5;10m+     899[0m:[38;5;10m[49m     edges = [e for e in edges if e not in removed_edges]
[0m[49m[38;5;10m+     900[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     901[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     902[0m:[38;5;10m[49m         "nodes": nodes,
[0m[49m[38;5;10m+     903[0m:[38;5;10m[49m         "edges": edges,
[0m[49m[38;5;10m+     904[0m:[38;5;10m[49m         "removed_for_consistency": removed_edges,
[0m[49m[38;5;10m+     905[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     906[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     907[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     908[0m:[38;5;10m[49m def detect_and_resolve_cycles(edges):
[0m[49m[38;5;10m+     909[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     910[0m:[38;5;10m[49m     Detect cycles in the BEFORE/AFTER subgraph and remove the weakest edge.
[0m[49m[38;5;10m+     911[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     912[0m:[38;5;10m[49m     Uses a simple DFS-based cycle detection. In production, you'd want
[0m[49m[38;5;10m+     913[0m:[38;5;10m[49m     a more sophisticated approach that considers the entire graph structure,
[0m[49m[38;5;10m+     914[0m:[38;5;10m[49m     but this handles the common case of a single contradictory classification.
[0m[49m[38;5;10m+     915[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     916[0m:[38;5;10m[49m     # Build directed adjacency for BEFORE relations only.
[0m[49m[38;5;10m+     917[0m:[38;5;10m[49m     # AFTER(A,B) is equivalent to BEFORE(B,A) for cycle detection.
[0m[49m[38;5;10m+     918[0m:[38;5;10m[49m     adj = defaultdict(list)
[0m[49m[38;5;10m+     919[0m:[38;5;10m[49m     edge_lookup = {}
[0m[49m[38;5;10m+     920[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     921[0m:[38;5;10m[49m     for edge in edges:
[0m[49m[38;5;10m+     922[0m:[38;5;10m[49m         if edge["relation"] == "BEFORE":
[0m[49m[38;5;10m+     923[0m:[38;5;10m[49m             adj[edge["from"]].append(edge["to"])
[0m[49m[38;5;10m+     924[0m:[38;5;10m[49m             edge_lookup[(edge["from"], edge["to"])] = edge
[0m[49m[38;5;10m+     925[0m:[38;5;10m[49m         elif edge["relation"] == "AFTER":
[0m[49m[38;5;10m+     926[0m:[38;5;10m[49m             adj[edge["to"]].append(edge["from"])
[0m[49m[38;5;10m+     927[0m:[38;5;10m[49m             edge_lookup[(edge["to"], edge["from"])] = edge
[0m[49m[38;5;10m+     928[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     929[0m:[38;5;10m[49m     # Simple cycle detection via DFS.
[0m[49m[38;5;10m+     930[0m:[38;5;10m[49m     visited = set()
[0m[49m[38;5;10m+     931[0m:[38;5;10m[49m     in_stack = set()
[0m[49m[38;5;10m+     932[0m:[38;5;10m[49m     removed = []
[0m[49m[38;5;10m+     933[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     934[0m:[38;5;10m[49m     def dfs(node, path):
[0m[49m[38;5;10m+     935[0m:[38;5;10m[49m         if node in in_stack:
[0m[49m[38;5;10m+     936[0m:[38;5;10m[49m             # Found a cycle. Remove the lowest-confidence edge in the cycle.
[0m[49m[38;5;10m+     937[0m:[38;5;10m[49m             cycle_start = path.index(node)
[0m[49m[38;5;10m+     938[0m:[38;5;10m[49m             cycle_path = path[cycle_start:]
[0m[49m[38;5;10m+     939[0m:[38;5;10m[49m             cycle_edges = []
[0m[49m[38;5;10m+     940[0m:[38;5;10m[49m             for k in range(len(cycle_path) - 1):
[0m[49m[38;5;10m+     941[0m:[38;5;10m[49m                 key = (cycle_path[k], cycle_path[k + 1])
[0m[49m[38;5;10m+     942[0m:[38;5;10m[49m                 if key in edge_lookup:
[0m[49m[38;5;10m+     943[0m:[38;5;10m[49m                     cycle_edges.append(edge_lookup[key])
[0m[49m[38;5;10m+     944[0m:[38;5;10m[49m             if cycle_edges:
[0m[49m[38;5;10m+     945[0m:[38;5;10m[49m                 weakest = min(cycle_edges, key=lambda e: e["confidence"])
[0m[49m[38;5;10m+     946[0m:[38;5;10m[49m                 removed.append(weakest)
[0m[49m[38;5;10m+     947[0m:[38;5;10m[49m                 logger.info("Cycle detected, removing edge: %s -> %s (conf %.2f)",
[0m[49m[38;5;10m+     948[0m:[38;5;10m[49m                            weakest["from"], weakest["to"], weakest["confidence"])
[0m[49m[38;5;10m+     949[0m:[38;5;10m[49m             return
[0m[49m[38;5;10m+     950[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     951[0m:[38;5;10m[49m         if node in visited:
[0m[49m[38;5;10m+     952[0m:[38;5;10m[49m             return
[0m[49m[38;5;10m+     953[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     954[0m:[38;5;10m[49m         visited.add(node)
[0m[49m[38;5;10m+     955[0m:[38;5;10m[49m         in_stack.add(node)
[0m[49m[38;5;10m+     956[0m:[38;5;10m[49m         for neighbor in adj.get(node, []):
[0m[49m[38;5;10m+     957[0m:[38;5;10m[49m             dfs(neighbor, path + [neighbor])
[0m[49m[38;5;10m+     958[0m:[38;5;10m[49m         in_stack.discard(node)
[0m[49m[38;5;10m+     959[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     960[0m:[38;5;10m[49m     for node in adj:
[0m[49m[38;5;10m+     961[0m:[38;5;10m[49m         if node not in visited:
[0m[49m[38;5;10m+     962[0m:[38;5;10m[49m             dfs(node, [node])
[0m[49m[38;5;10m+     963[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     964[0m:[38;5;10m[49m     return removed
[0m[49m[38;5;10m+     965[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     966[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     967[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     968[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     969[0m:[38;5;10m[49m ## Step 6: Generate the Patient Timeline
[0m[49m[38;5;10m+     970[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     971[0m:[38;5;10m[49m *The pseudocode calls this `generate_timeline(temporal_graph, doc_time)`. This flattens the temporal graph into a linear timeline. Events anchored to absolute dates get placed precisely. Events with only relative relationships get placed in order relative to their anchors. The output is what downstream systems consume: a chronological sequence of events with timestamps and confidence scores.*
[0m[49m[38;5;10m+     972[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     973[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     974[0m:[38;5;10m[49m def generate_timeline(temporal_graph, preprocessed_note):
[0m[49m[38;5;10m+     975[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     976[0m:[38;5;10m[49m     Step 6: Flatten the temporal graph into a patient timeline.
[0m[49m[38;5;10m+     977[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     978[0m:[38;5;10m[49m     Two passes:
[0m[49m[38;5;10m+     979[0m:[38;5;10m[49m     1. Anchor events with absolute timestamps (from resolved temporal expressions)
[0m[49m[38;5;10m+     980[0m:[38;5;10m[49m     2. Propagate timestamps to unanchored events using graph relationships
[0m[49m[38;5;10m+     981[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     982[0m:[38;5;10m[49m     nodes = temporal_graph["nodes"]
[0m[49m[38;5;10m+     983[0m:[38;5;10m[49m     edges = temporal_graph["edges"]
[0m[49m[38;5;10m+     984[0m:[38;5;10m[49m     doc_time = preprocessed_note["doc_time"]
[0m[49m[38;5;10m+     985[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     986[0m:[38;5;10m[49m     # First pass: assign absolute timestamps where possible.
[0m[49m[38;5;10m+     987[0m:[38;5;10m[49m     # Events linked to resolved temporal expressions get precise timestamps.
[0m[49m[38;5;10m+     988[0m:[38;5;10m[49m     timestamps = {}  # node_id -> datetime
[0m[49m[38;5;10m+     989[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     990[0m:[38;5;10m[49m     # Temporal expressions that resolved to ISO dates already have timestamps.
[0m[49m[38;5;10m+     991[0m:[38;5;10m[49m     for node_id, node in nodes.items():
[0m[49m[38;5;10m+     992[0m:[38;5;10m[49m         if node.get("entity_type") == "TEMPORAL_EXPRESSION":
[0m[49m[38;5;10m+     993[0m:[38;5;10m[49m             normalized = node.get("normalized")
[0m[49m[38;5;10m+     994[0m:[38;5;10m[49m             if normalized and "T" in str(normalized):
[0m[49m[38;5;10m+     995[0m:[38;5;10m[49m                 try:
[0m[49m[38;5;10m+     996[0m:[38;5;10m[49m                     timestamps[node_id] = datetime.datetime.fromisoformat(normalized)
[0m[49m[38;5;10m+     997[0m:[38;5;10m[49m                 except (ValueError, TypeError):
[0m[49m[38;5;10m+     998[0m:[38;5;10m[49m                     pass
[0m[49m[38;5;10m+     999[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1000[0m:[38;5;10m[49m     # Propagate timestamps from temporal expressions to connected events.
[0m[49m[38;5;10m+    1001[0m:[38;5;10m[49m     for edge in edges:
[0m[49m[38;5;10m+    1002[0m:[38;5;10m[49m         if edge["relation"] in ("OVERLAP", "CONTAINS") and edge["to"] in timestamps:
[0m[49m[38;5;10m+    1003[0m:[38;5;10m[49m             if edge["from"] not in timestamps:
[0m[49m[38;5;10m+    1004[0m:[38;5;10m[49m                 timestamps[edge["from"]] = timestamps[edge["to"]]
[0m[49m[38;5;10m+    1005[0m:[38;5;10m[49m         if edge["relation"] in ("OVERLAP", "CONTAINS") and edge["from"] in timestamps:
[0m[49m[38;5;10m+    1006[0m:[38;5;10m[49m             if edge["to"] not in timestamps:
[0m[49m[38;5;10m+    1007[0m:[38;5;10m[49m                 timestamps[edge["to"]] = timestamps[edge["from"]]
[0m[49m[38;5;10m+    1008[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1009[0m:[38;5;10m[49m     # Second pass: infer timestamps for unanchored events using BEFORE/AFTER ordering.
[0m[49m[38;5;10m+    1010[0m:[38;5;10m[49m     # Simple heuristic: if A BEFORE B and B has a timestamp, A gets timestamp - 1 day.
[0m[49m[38;5;10m+    1011[0m:[38;5;10m[49m     for edge in sorted(edges, key=lambda e: e["confidence"], reverse=True):
[0m[49m[38;5;10m+    1012[0m:[38;5;10m[49m         if edge["relation"] == "BEFORE" and edge["to"] in timestamps:
[0m[49m[38;5;10m+    1013[0m:[38;5;10m[49m             if edge["from"] not in timestamps:
[0m[49m[38;5;10m+    1014[0m:[38;5;10m[49m                 timestamps[edge["from"]] = timestamps[edge["to"]] - timedelta(hours=12)
[0m[49m[38;5;10m+    1015[0m:[38;5;10m[49m         elif edge["relation"] == "AFTER" and edge["from"] in timestamps:
[0m[49m[38;5;10m+    1016[0m:[38;5;10m[49m             if edge["to"] not in timestamps:
[0m[49m[38;5;10m+    1017[0m:[38;5;10m[49m                 timestamps[edge["to"]] = timestamps[edge["from"]] + timedelta(hours=12)
[0m[49m[38;5;10m+    1018[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1019[0m:[38;5;10m[49m     # Build the timeline entries (events only, not raw temporal expressions).
[0m[49m[38;5;10m+    1020[0m:[38;5;10m[49m     timeline = []
[0m[49m[38;5;10m+    1021[0m:[38;5;10m[49m     for node_id, node in nodes.items():
[0m[49m[38;5;10m+    1022[0m:[38;5;10m[49m         if node.get("entity_type") != "EVENT":
[0m[49m[38;5;10m+    1023[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    1024[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1025[0m:[38;5;10m[49m         ts = timestamps.get(node_id)
[0m[49m[38;5;10m+    1026[0m:[38;5;10m[49m         timeline.append({
[0m[49m[38;5;10m+    1027[0m:[38;5;10m[49m             "event_id": node_id,
[0m[49m[38;5;10m+    1028[0m:[38;5;10m[49m             "event_text": node["text"],
[0m[49m[38;5;10m+    1029[0m:[38;5;10m[49m             "event_type": node.get("type", "UNKNOWN"),
[0m[49m[38;5;10m+    1030[0m:[38;5;10m[49m             "timestamp": ts.isoformat() if ts else None,
[0m[49m[38;5;10m+    1031[0m:[38;5;10m[49m             "timestamp_type": "ABSOLUTE" if ts and node_id in timestamps else "RELATIVE_ONLY",
[0m[49m[38;5;10m+    1032[0m:[38;5;10m[49m             "confidence": node.get("confidence", 0),
[0m[49m[38;5;10m+    1033[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    1034[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1035[0m:[38;5;10m[49m     # Sort: events with timestamps first (chronologically), then unanchored events.
[0m[49m[38;5;10m+    1036[0m:[38;5;10m[49m     timeline.sort(key=lambda e: (
[0m[49m[38;5;10m+    1037[0m:[38;5;10m[49m         0 if e["timestamp"] else 1,
[0m[49m[38;5;10m+    1038[0m:[38;5;10m[49m         e["timestamp"] or "",
[0m[49m[38;5;10m+    1039[0m:[38;5;10m[49m     ))
[0m[49m[38;5;10m+    1040[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1041[0m:[38;5;10m[49m     # Compute summary statistics.
[0m[49m[38;5;10m+    1042[0m:[38;5;10m[49m     anchored_count = sum(1 for e in timeline if e["timestamp_type"] == "ABSOLUTE")
[0m[49m[38;5;10m+    1043[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1044[0m:[38;5;10m[49m     result = {
[0m[49m[38;5;10m+    1045[0m:[38;5;10m[49m         "patient_id": preprocessed_note["metadata"]["patient_id"],
[0m[49m[38;5;10m+    1046[0m:[38;5;10m[49m         "document_id": preprocessed_note["metadata"]["document_id"],
[0m[49m[38;5;10m+    1047[0m:[38;5;10m[49m         "doc_time": doc_time.isoformat(),
[0m[49m[38;5;10m+    1048[0m:[38;5;10m[49m         "timeline": timeline,
[0m[49m[38;5;10m+    1049[0m:[38;5;10m[49m         "event_count": len(timeline),
[0m[49m[38;5;10m+    1050[0m:[38;5;10m[49m         "anchored_count": anchored_count,
[0m[49m[38;5;10m+    1051[0m:[38;5;10m[49m         "inferred_count": len(timeline) - anchored_count,
[0m[49m[38;5;10m+    1052[0m:[38;5;10m[49m         "temporal_relations": [
[0m[49m[38;5;10m+    1053[0m:[38;5;10m[49m             {
[0m[49m[38;5;10m+    1054[0m:[38;5;10m[49m                 "from": e["from"],
[0m[49m[38;5;10m+    1055[0m:[38;5;10m[49m                 "to": e["to"],
[0m[49m[38;5;10m+    1056[0m:[38;5;10m[49m                 "relation": e["relation"],
[0m[49m[38;5;10m+    1057[0m:[38;5;10m[49m                 "confidence": e["confidence"],
[0m[49m[38;5;10m+    1058[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    1059[0m:[38;5;10m[49m             for e in edges if not e.get("inferred")
[0m[49m[38;5;10m+    1060[0m:[38;5;10m[49m         ],
[0m[49m[38;5;10m+    1061[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1062[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1063[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    1064[0m:[38;5;10m[49m         "Generated timeline: %d events (%d anchored, %d inferred)",
[0m[49m[38;5;10m+    1065[0m:[38;5;10m[49m         result["event_count"], result["anchored_count"], result["inferred_count"]
[0m[49m[38;5;10m+    1066[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    1067[0m:[38;5;10m[49m     return result
[0m[49m[38;5;10m+    1068[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    1069[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1070[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    1071[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1072[0m:[38;5;10m[49m ## Storing the Timeline in DynamoDB
[0m[49m[38;5;10m+    1073[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1074[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    1075[0m:[38;5;10m[49m def store_timeline(timeline_result):
[0m[49m[38;5;10m+    1076[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1077[0m:[38;5;10m[49m     Write the extracted timeline to DynamoDB for downstream consumption.
[0m[49m[38;5;10m+    1078[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1079[0m:[38;5;10m[49m     Indexed by patient_id (partition key) and document_id (sort key) so you can
[0m[49m[38;5;10m+    1080[0m:[38;5;10m[49m     query all timelines for a patient or retrieve a specific document's timeline.
[0m[49m[38;5;10m+    1081[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1082[0m:[38;5;10m[49m     table = dynamodb.Table(TIMELINE_TABLE_NAME)
[0m[49m[38;5;10m+    1083[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1084[0m:[38;5;10m[49m     # DynamoDB requires Decimal for numeric values, not float.
[0m[49m[38;5;10m+    1085[0m:[38;5;10m[49m     item = {
[0m[49m[38;5;10m+    1086[0m:[38;5;10m[49m         "patient_id": timeline_result["patient_id"],
[0m[49m[38;5;10m+    1087[0m:[38;5;10m[49m         "document_id": timeline_result["document_id"],
[0m[49m[38;5;10m+    1088[0m:[38;5;10m[49m         "doc_time": timeline_result["doc_time"],
[0m[49m[38;5;10m+    1089[0m:[38;5;10m[49m         "extraction_timestamp": datetime.datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    1090[0m:[38;5;10m[49m         "event_count": timeline_result["event_count"],
[0m[49m[38;5;10m+    1091[0m:[38;5;10m[49m         "anchored_count": timeline_result["anchored_count"],
[0m[49m[38;5;10m+    1092[0m:[38;5;10m[49m         "inferred_count": timeline_result["inferred_count"],
[0m[49m[38;5;10m+    1093[0m:[38;5;10m[49m         "timeline": json.loads(
[0m[49m[38;5;10m+    1094[0m:[38;5;10m[49m             json.dumps(timeline_result["timeline"]),
[0m[49m[38;5;10m+    1095[0m:[38;5;10m[49m         ),
[0m[49m[38;5;10m+    1096[0m:[38;5;10m[49m         "temporal_relations": json.loads(
