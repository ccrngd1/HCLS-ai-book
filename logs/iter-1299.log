[0m[49m[38;5;10m+    1098[0m:[38;5;10m[49m         ),
[0m[49m[38;5;10m+    1099[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1100[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1101[0m:[38;5;10m[49m     # Convert any float values to Decimal for DynamoDB compatibility.
[0m[49m[38;5;10m+    1102[0m:[38;5;10m[49m     item = convert_floats_to_decimal(item)
[0m[49m[38;5;10m+    1103[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1104[0m:[38;5;10m[49m     table.put_item(Item=item)
[0m[49m[38;5;10m+    1105[0m:[38;5;10m[49m     logger.info("Stored timeline for %s / %s", item["patient_id"], item["document_id"])
[0m[49m[38;5;10m+    1106[0m:[38;5;10m[49m     return item
[0m[49m[38;5;10m+    1107[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1108[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1109[0m:[38;5;10m[49m def convert_floats_to_decimal(obj):
[0m[49m[38;5;10m+    1110[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1111[0m:[38;5;10m[49m     Recursively convert float values to Decimal for DynamoDB.
[0m[49m[38;5;10m+    1112[0m:[38;5;10m[49m     DynamoDB's put_item raises TypeError on raw Python floats.
[0m[49m[38;5;10m+    1113[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1114[0m:[38;5;10m[49m     if isinstance(obj, float):
[0m[49m[38;5;10m+    1115[0m:[38;5;10m[49m         return Decimal(str(round(obj, 6)))
[0m[49m[38;5;10m+    1116[0m:[38;5;10m[49m     elif isinstance(obj, dict):
[0m[49m[38;5;10m+    1117[0m:[38;5;10m[49m         return {k: convert_floats_to_decimal(v) for k, v in obj.items()}
[0m[49m[38;5;10m+    1118[0m:[38;5;10m[49m     elif isinstance(obj, list):
[0m[49m[38;5;10m+    1119[0m:[38;5;10m[49m         return [convert_floats_to_decimal(item) for item in obj]
[0m[49m[38;5;10m+    1120[0m:[38;5;10m[49m     return obj
[0m[49m[38;5;10m+    1121[0m:[38;5;10m[49m ```
