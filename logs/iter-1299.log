[49m[38;5;10m+       1[0m:[38;5;10m[49m # Recipe 8.9: Python Implementation Example
[0m[49m[38;5;10m+       2[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+       3[0m:[38;5;10m[49m > **Heads up:** This is a deliberately simple, illustrative implementation of the pseudocode walkthrough from Recipe 8.9. It shows one way you could translate temporal relationship extraction concepts into working Python code. It is not production-ready. The temporal expression parser is rule-based and covers common clinical patterns but not all of them, the relation classifier is simulated via a SageMaker endpoint call pattern, and the graph construction uses basic transitivity without full Allen's interval algebra. Think of it as a sketch: useful for understanding the shape of the solution, not something you'd deploy against a live clinical NLP pipeline on Monday morning. Consider it a starting point, not a destination.
[0m[49m[38;5;10m+       4[0m:[38;5;10m[49m >
[0m[49m[38;5;10m+       5[0m:[38;5;10m[49m > This recipe uses Amazon Comprehend Medical for entity/event detection, a custom SageMaker endpoint for temporal relation classification, and DynamoDB for timeline storage. The pipeline follows the six-step architecture from the main recipe: preprocess, detect temporal entities, generate candidate pairs, classify relations, build graph, and generate timeline.
[0m[49m[38;5;10m+       6[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+       7[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+       8[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+       9[0m:[38;5;10m[49m ## Setup
[0m[49m[38;5;10m+      10[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      11[0m:[38;5;10m[49m You'll need the AWS SDK for Python and a few standard libraries:
[0m[49m[38;5;10m+      12[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      13[0m:[38;5;10m[49m ```bash
[0m[49m[38;5;10m+      14[0m:[38;5;10m[49m pip install boto3
[0m[49m[38;5;10m+      15[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+      16[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      17[0m:[38;5;10m[49m Your environment needs credentials configured (via environment variables, an instance profile, or `~/.aws/credentials`). The IAM role or user needs:
[0m[49m[38;5;10m+      18[0m:[38;5;10m[49m - `comprehendmedical:DetectEntitiesV2`
[0m[49m[38;5;10m+      19[0m:[38;5;10m[49m - `sagemaker:InvokeEndpoint`
[0m[49m[38;5;10m+      20[0m:[38;5;10m[49m - `s3:GetObject`
[0m[49m[38;5;10m+      21[0m:[38;5;10m[49m - `s3:PutObject`
[0m[49m[38;5;10m+      22[0m:[38;5;10m[49m - `dynamodb:PutItem`
[0m[49m[38;5;10m+      23[0m:[38;5;10m[49m - `dynamodb:Query`
[0m[49m[38;5;10m+      24[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      25[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+      26[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      27[0m:[38;5;10m[49m ## Configuration and Constants
[0m[49m[38;5;10m+      28[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      29[0m:[38;5;10m[49m Everything that's really configuration lives up front. The temporal patterns, signal words, and thresholds are the pieces that change between institutions. Your neurologists write differently than your surgeons, and both write differently than the training corpus that produced these defaults.
[0m[49m[38;5;10m+      30[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      31[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+      32[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+      33[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+      34[0m:[38;5;10m[49m import re
[0m[49m[38;5;10m+      35[0m:[38;5;10m[49m import datetime
[0m[49m[38;5;10m+      36[0m:[38;5;10m[49m from datetime import timezone, timedelta
[0m[49m[38;5;10m+      37[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+      38[0m:[38;5;10m[49m from collections import defaultdict
[0m[49m[38;5;10m+      39[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      40[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+      41[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+      42[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      43[0m:[38;5;10m[49m # Structured logging. Never log PHI (entity text, patient IDs, note content).
[0m[49m[38;5;10m+      44[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+      45[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+      46[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      47[0m:[38;5;10m[49m # Retry configuration for AWS API calls under load.
[0m[49m[38;5;10m+      48[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+      49[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      50[0m:[38;5;10m[49m # Module-level clients reused across Lambda invocations.
[0m[49m[38;5;10m+      51[0m:[38;5;10m[49m comprehend_medical_client = boto3.client("comprehendmedical", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+      52[0m:[38;5;10m[49m sagemaker_runtime_client = boto3.client("sagemaker-runtime", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+      53[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb")
[0m[49m[38;5;10m+      54[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      55[0m:[38;5;10m[49m # ---------- Temporal Relationship Labels ----------
[0m[49m[38;5;10m+      56[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      57[0m:[38;5;10m[49m # The relation types our classifier predicts.
[0m[49m[38;5;10m+      58[0m:[38;5;10m[49m # In practice most systems collapse the TimeML set into these four plus NONE.
[0m[49m[38;5;10m+      59[0m:[38;5;10m[49m TEMPORAL_RELATIONS = ["BEFORE", "AFTER", "OVERLAP", "CONTAINS", "NONE"]
[0m[49m[38;5;10m+      60[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      61[0m:[38;5;10m[49m # ---------- Temporal Expression Patterns ----------
[0m[49m[38;5;10m+      62[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      63[0m:[38;5;10m[49m # Clinical-specific temporal patterns that general NLP tools miss.
[0m[49m[38;5;10m+      64[0m:[38;5;10m[49m # Each pattern maps to a function that resolves the match to a date offset.
[0m[49m[38;5;10m+      65[0m:[38;5;10m[49m # These cover the most common clinical temporal conventions.
[0m[49m[38;5;10m+      66[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      67[0m:[38;5;10m[49m CLINICAL_TEMPORAL_PATTERNS = [
[0m[49m[38;5;10m+      68[0m:[38;5;10m[49m     # POD#N: Postoperative Day N (e.g., "POD#2", "POD 3", "POD#1")
[0m[49m[38;5;10m+      69[0m:[38;5;10m[49m     (r"POD\s*#?\s*(\d+)", "pod"),
[0m[49m[38;5;10m+      70[0m:[38;5;10m[49m     # HD#N: Hospital Day N (e.g., "HD3", "HD 5", "hospital day 7")
[0m[49m[38;5;10m+      71[0m:[38;5;10m[49m     (r"(?:HD|hospital\s+day)\s*#?\s*(\d+)", "hospital_day"),
[0m[49m[38;5;10m+      72[0m:[38;5;10m[49m     # DOL#N: Day of Life (neonates)
[0m[49m[38;5;10m+      73[0m:[38;5;10m[49m     (r"DOL\s*#?\s*(\d+)", "day_of_life"),
[0m[49m[38;5;10m+      74[0m:[38;5;10m[49m     # T+N: Days post-transplant
[0m[49m[38;5;10m+      75[0m:[38;5;10m[49m     (r"T\s*\+\s*(\d+)", "transplant_day"),
[0m[49m[38;5;10m+      76[0m:[38;5;10m[49m     # "N days/hours/weeks ago" or "N days/hours/weeks later"
[0m[49m[38;5;10m+      77[0m:[38;5;10m[49m     (r"(\d+)\s+(day|hour|week|month)s?\s+(ago|later|after|before|prior)", "relative"),
[0m[49m[38;5;10m+      78[0m:[38;5;10m[49m     # "postoperatively" / "preoperatively"
[0m[49m[38;5;10m+      79[0m:[38;5;10m[49m     (r"(pre|post)\s*-?\s*operatively", "perioperative"),
[0m[49m[38;5;10m+      80[0m:[38;5;10m[49m     # Explicit dates: Month Day, Year or MM/DD/YYYY
[0m[49m[38;5;10m+      81[0m:[38;5;10m[49m     (r"(January|February|March|April|May|June|July|August|September|October|November|December)\s+(\d{1,2}),?\s*(\d{4})?", "month_day"),
[0m[49m[38;5;10m+      82[0m:[38;5;10m[49m     (r"(\d{1,2})/(\d{1,2})/(\d{2,4})", "slash_date"),
[0m[49m[38;5;10m+      83[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+      84[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      85[0m:[38;5;10m[49m # Temporal signal words that indicate a relationship between two events.
[0m[49m[38;5;10m+      86[0m:[38;5;10m[49m # These are the lexical cues that make temporal ordering explicit.
[0m[49m[38;5;10m+      87[0m:[38;5;10m[49m TEMPORAL_SIGNALS = {
[0m[49m[38;5;10m+      88[0m:[38;5;10m[49m     "before": "BEFORE",
[0m[49m[38;5;10m+      89[0m:[38;5;10m[49m     "prior to": "BEFORE",
[0m[49m[38;5;10m+      90[0m:[38;5;10m[49m     "preceding": "BEFORE",
[0m[49m[38;5;10m+      91[0m:[38;5;10m[49m     "before the": "BEFORE",
[0m[49m[38;5;10m+      92[0m:[38;5;10m[49m     "after": "AFTER",
[0m[49m[38;5;10m+      93[0m:[38;5;10m[49m     "following": "AFTER",
[0m[49m[38;5;10m+      94[0m:[38;5;10m[49m     "subsequently": "AFTER",
[0m[49m[38;5;10m+      95[0m:[38;5;10m[49m     "then": "AFTER",
[0m[49m[38;5;10m+      96[0m:[38;5;10m[49m     "later": "AFTER",
[0m[49m[38;5;10m+      97[0m:[38;5;10m[49m     "post": "AFTER",
[0m[49m[38;5;10m+      98[0m:[38;5;10m[49m     "during": "OVERLAP",
[0m[49m[38;5;10m+      99[0m:[38;5;10m[49m     "while": "OVERLAP",
[0m[49m[38;5;10m+     100[0m:[38;5;10m[49m     "at the same time": "OVERLAP",
[0m[49m[38;5;10m+     101[0m:[38;5;10m[49m     "concurrent": "OVERLAP",
[0m[49m[38;5;10m+     102[0m:[38;5;10m[49m     "throughout": "CONTAINS",
[0m[49m[38;5;10m+     103[0m:[38;5;10m[49m     "during the course of": "CONTAINS",
[0m[49m[38;5;10m+     104[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     105[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     106[0m:[38;5;10m[49m # ---------- Section Temporal Context ----------
[0m[49m[38;5;10m+     107[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     108[0m:[38;5;10m[49m # Clinical note sections carry implicit temporal semantics.
[0m[49m[38;5;10m+     109[0m:[38;5;10m[49m # Events in "Past Medical History" are historical; events in "Assessment" are current.
[0m[49m[38;5;10m+     110[0m:[38;5;10m[49m SECTION_TEMPORAL_CONTEXT = {
[0m[49m[38;5;10m+     111[0m:[38;5;10m[49m     "history of present illness": "NARRATIVE",  # past-to-present story
[0m[49m[38;5;10m+     112[0m:[38;5;10m[49m     "hpi": "NARRATIVE",
[0m[49m[38;5;10m+     113[0m:[38;5;10m[49m     "past medical history": "HISTORICAL",
[0m[49m[38;5;10m+     114[0m:[38;5;10m[49m     "pmh": "HISTORICAL",
[0m[49m[38;5;10m+     115[0m:[38;5;10m[49m     "past surgical history": "HISTORICAL",
[0m[49m[38;5;10m+     116[0m:[38;5;10m[49m     "psh": "HISTORICAL",
[0m[49m[38;5;10m+     117[0m:[38;5;10m[49m     "family history": "HISTORICAL",
[0m[49m[38;5;10m+     118[0m:[38;5;10m[49m     "social history": "HISTORICAL",
[0m[49m[38;5;10m+     119[0m:[38;5;10m[49m     "assessment": "CURRENT",
[0m[49m[38;5;10m+     120[0m:[38;5;10m[49m     "assessment and plan": "CURRENT",
[0m[49m[38;5;10m+     121[0m:[38;5;10m[49m     "plan": "FUTURE",
[0m[49m[38;5;10m+     122[0m:[38;5;10m[49m     "discharge instructions": "FUTURE",
[0m[49m[38;5;10m+     123[0m:[38;5;10m[49m     "hospital course": "NARRATIVE",
[0m[49m[38;5;10m+     124[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     125[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     126[0m:[38;5;10m[49m # ---------- Thresholds ----------
[0m[49m[38;5;10m+     127[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     128[0m:[38;5;10m[49m # Relation classification confidence threshold.
[0m[49m[38;5;10m+     129[0m:[38;5;10m[49m # Below this, the relation is excluded from the temporal graph.
[0m[49m[38;5;10m+     130[0m:[38;5;10m[49m RELATION_CONFIDENCE_THRESHOLD = 0.70
