[0m[49m[38;5;10m+     102[0m:[38;5;10m[49m     "target_update_freq": 100,  # sync target network every N iterations
[0m[49m[38;5;10m+     103[0m:[38;5;10m[49m     "tau": 0.005,               # soft update coefficient
[0m[49m[38;5;10m+     104[0m:[38;5;10m[49m     "hidden_dims": [256, 256],  # Q-network hidden layer sizes
