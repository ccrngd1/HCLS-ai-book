[0m[49m[38;5;10m+      74[0m:[38;5;10m[49m     "pao2_fio2_ratio",
[0m[49m[38;5;10m+      75[0m:[38;5;10m[49m     "urine_output_4h",
[0m[49m[38;5;10m+      76[0m:[38;5;10m[49m     "cumulative_fluid_balance",
[0m[49m[38;5;10m+      77[0m:[38;5;10m[49m     "gcs_score",
[0m[49m[38;5;10m+      78[0m:[38;5;10m[49m     "sofa_score",
[0m[49m[38;5;10m+      79[0m:[38;5;10m[49m     "hours_since_admission",
[0m[49m[38;5;10m+      80[0m:[38;5;10m[49m     "age",
[0m[49m[38;5;10m+      81[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+      82[0m:[38;5;10m[49m STATE_DIM = len(STATE_FEATURES)
[0m[49m[38;5;10m+      83[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      84[0m:[38;5;10m[49m # Reward configuration.
[0m[49m[38;5;10m+      85[0m:[38;5;10m[49m # Terminal rewards are large to dominate the cumulative sum.
[0m[49m[38;5;10m+      86[0m:[38;5;10m[49m # Intermediate rewards provide denser signal during training.
[0m[49m[38;5;10m+      87[0m:[38;5;10m[49m REWARD_CONFIG = {
[0m[49m[38;5;10m+      88[0m:[38;5;10m[49m     "survival_reward": 15.0,
[0m[49m[38;5;10m+      89[0m:[38;5;10m[49m     "death_penalty": -15.0,
[0m[49m[38;5;10m+      90[0m:[38;5;10m[49m     "sofa_improvement_bonus": 0.5,   # per point of SOFA decrease
[0m[49m[38;5;10m+      91[0m:[38;5;10m[49m     "sofa_worsening_penalty": -0.5,  # per point of SOFA increase
[0m[49m[38;5;10m+      92[0m:[38;5;10m[49m     "lactate_clearance_bonus": 0.25, # per mmol/L decrease in lactate
[0m[49m[38;5;10m+      93[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+      94[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      95[0m:[38;5;10m[49m # Training hyperparameters for Conservative Q-Learning.
[0m[49m[38;5;10m+      96[0m:[38;5;10m[49m CQL_CONFIG = {
