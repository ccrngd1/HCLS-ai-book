[0m[49m[38;5;10m+     127[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     128[0m:[38;5;10m[49m ## Step 1: Trajectory Construction
[0m[49m[38;5;10m+     129[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     130[0m:[38;5;10m[49m *Maps to pseudocode Step 1 in the main recipe. This takes raw patient time-series data and constructs the (state, action, reward, next_state) tuples that the RL algorithm learns from.*
[0m[49m[38;5;10m+     131[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     132[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     133[0m:[38;5;10m[49m def discretize_action(iv_fluid_ml: float, vasopressor_dose: float) -> int:
[0m[49m[38;5;10m+     134[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     135[0m:[38;5;10m[49m     Map continuous treatment values to a discrete action ID (0-24).
[0m[49m[38;5;10m+     136[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     137[0m:[38;5;10m[49m     The action space is a 5x5 grid: 5 fluid levels x 5 vasopressor levels.
[0m[49m[38;5;10m+     138[0m:[38;5;10m[49m     Action ID = fluid_level * 5 + vaso_level.
[0m[49m[38;5;10m+     139[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     140[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     141[0m:[38;5;10m[49m         iv_fluid_ml: Total IV fluid administered in this 4-hour window (mL).
[0m[49m[38;5;10m+     142[0m:[38;5;10m[49m         vasopressor_dose: Max norepinephrine-equivalent dose (mcg/kg/min).
[0m[49m[38;5;10m+     143[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     144[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     145[0m:[38;5;10m[49m         Integer action ID from 0 to 24.
[0m[49m[38;5;10m+     146[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     147[0m:[38;5;10m[49m     # Find which bin the fluid volume falls into.
[0m[49m[38;5;10m+     148[0m:[38;5;10m[49m     # np.digitize returns the index of the bin: 0 means below first threshold,
[0m[49m[38;5;10m+     149[0m:[38;5;10m[49m     # len(bins) means above the last threshold.
[0m[49m[38;5;10m+     150[0m:[38;5;10m[49m     fluid_level = int(np.digitize(iv_fluid_ml, FLUID_BINS_ML)) - 1
[0m[49m[38;5;10m+     151[0m:[38;5;10m[49m     fluid_level = max(0, min(fluid_level, NUM_FLUID_LEVELS - 1))
[0m[49m[38;5;10m+     152[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     153[0m:[38;5;10m[49m     vaso_level = int(np.digitize(vasopressor_dose, VASOPRESSOR_BINS_MCG)) - 1
[0m[49m[38;5;10m+     154[0m:[38;5;10m[49m     vaso_level = max(0, min(vaso_level, NUM_VASO_LEVELS - 1))
[0m[49m[38;5;10m+     155[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     156[0m:[38;5;10m[49m     return fluid_level * NUM_VASO_LEVELS + vaso_level
[0m[49m[38;5;10m+     157[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     158[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     159[0m:[38;5;10m[49m def decode_action(action_id: int) -> Tuple[int, int]:
[0m[49m[38;5;10m+     160[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     161[0m:[38;5;10m[49m     Reverse of discretize_action: given an action ID, return (fluid_level, vaso_level).
[0m[49m[38;5;10m+     162[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     163[0m:[38;5;10m[49m     fluid_level = action_id // NUM_VASO_LEVELS
[0m[49m[38;5;10m+     164[0m:[38;5;10m[49m     vaso_level = action_id % NUM_VASO_LEVELS
[0m[49m[38;5;10m+     165[0m:[38;5;10m[49m     return fluid_level, vaso_level
[0m[49m[38;5;10m+     166[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     167[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     168[0m:[38;5;10m[49m def compute_reward(
[0m[49m[38;5;10m+     169[0m:[38;5;10m[49m     current_sofa: float,
[0m[49m[38;5;10m+     170[0m:[38;5;10m[49m     next_sofa: float,
[0m[49m[38;5;10m+     171[0m:[38;5;10m[49m     current_lactate: float,
[0m[49m[38;5;10m+     172[0m:[38;5;10m[49m     next_lactate: float,
[0m[49m[38;5;10m+     173[0m:[38;5;10m[49m     is_terminal: bool,
[0m[49m[38;5;10m+     174[0m:[38;5;10m[49m     survived: bool,
[0m[49m[38;5;10m+     175[0m:[38;5;10m[49m ) -> float:
[0m[49m[38;5;10m+     176[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     177[0m:[38;5;10m[49m     Compute the reward for a single transition.
[0m[49m[38;5;10m+     178[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     179[0m:[38;5;10m[49m     Combines terminal outcome (survival/death) with intermediate signals
[0m[49m[38;5;10m+     180[0m:[38;5;10m[49m     (SOFA score changes, lactate clearance). The terminal reward dominates
[0m[49m[38;5;10m+     181[0m:[38;5;10m[49m     the cumulative sum, but intermediate rewards help the algorithm learn
[0m[49m[38;5;10m+     182[0m:[38;5;10m[49m     which actions lead toward improvement vs. deterioration.
[0m[49m[38;5;10m+     183[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     184[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     185[0m:[38;5;10m[49m         current_sofa: SOFA score at current time step.
[0m[49m[38;5;10m+     186[0m:[38;5;10m[49m         next_sofa: SOFA score at next time step.
[0m[49m[38;5;10m+     187[0m:[38;5;10m[49m         current_lactate: Lactate at current time step (mmol/L).
[0m[49m[38;5;10m+     188[0m:[38;5;10m[49m         next_lactate: Lactate at next time step (mmol/L).
[0m[49m[38;5;10m+     189[0m:[38;5;10m[49m         is_terminal: Whether this is the last time step for this patient.
[0m[49m[38;5;10m+     190[0m:[38;5;10m[49m         survived: Whether the patient survived (only meaningful if is_terminal).
[0m[49m[38;5;10m+     191[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     192[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     193[0m:[38;5;10m[49m         Float reward value.
[0m[49m[38;5;10m+     194[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     195[0m:[38;5;10m[49m     reward = 0.0
[0m[49m[38;5;10m+     196[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     197[0m:[38;5;10m[49m     if is_terminal:
[0m[49m[38;5;10m+     198[0m:[38;5;10m[49m         # Terminal reward: the big signal.
[0m[49m[38;5;10m+     199[0m:[38;5;10m[49m         reward += REWARD_CONFIG["survival_reward"] if survived else REWARD_CONFIG["death_penalty"]
[0m[49m[38;5;10m+     200[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+     201[0m:[38;5;10m[49m         # Intermediate rewards: SOFA improvement/worsening.
[0m[49m[38;5;10m+     202[0m:[38;5;10m[49m         sofa_change = current_sofa - next_sofa  # positive = improvement
[0m[49m[38;5;10m+     203[0m:[38;5;10m[49m         if sofa_change > 0:
[0m[49m[38;5;10m+     204[0m:[38;5;10m[49m             reward += sofa_change * REWARD_CONFIG["sofa_improvement_bonus"]
[0m[49m[38;5;10m+     205[0m:[38;5;10m[49m         elif sofa_change < 0:
[0m[49m[38;5;10m+     206[0m:[38;5;10m[49m             reward += abs(sofa_change) * REWARD_CONFIG["sofa_worsening_penalty"]
[0m[49m[38;5;10m+     207[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     208[0m:[38;5;10m[49m         # Lactate clearance bonus.
[0m[49m[38;5;10m+     209[0m:[38;5;10m[49m         lactate_change = current_lactate - next_lactate  # positive = clearance
[0m[49m[38;5;10m+     210[0m:[38;5;10m[49m         if lactate_change > 0:
[0m[49m[38;5;10m+     211[0m:[38;5;10m[49m             reward += lactate_change * REWARD_CONFIG["lactate_clearance_bonus"]
[0m[49m[38;5;10m+     212[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     213[0m:[38;5;10m[49m     return reward
[0m[49m[38;5;10m+     214[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     215[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     216[0m:[38;5;10m[49m def build_trajectory(patient_data: Dict) -> List[Dict]:
[0m[49m[38;5;10m+     217[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     218[0m:[38;5;10m[49m     Convert a single patient's time-series data into a trajectory of
[0m[49m[38;5;10m+     219[0m:[38;5;10m[49m     (state, action, reward, next_state) tuples.
[0m[49m[38;5;10m+     220[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     221[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     222[0m:[38;5;10m[49m         patient_data: Dictionary with keys:
[0m[49m[38;5;10m+     223[0m:[38;5;10m[49m             - "time_steps": list of dicts, each containing state features + treatment info
[0m[49m[38;5;10m+     224[0m:[38;5;10m[49m             - "survived": bool indicating 90-day survival
[0m[49m[38;5;10m+     225[0m:[38;5;10m[49m             - "patient_id": anonymized identifier
[0m[49m[38;5;10m+     226[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     227[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     228[0m:[38;5;10m[49m         List of transition dicts, each with keys: state, action, reward, next_state, done.
[0m[49m[38;5;10m+     229[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     230[0m:[38;5;10m[49m     time_steps = patient_data["time_steps"]
[0m[49m[38;5;10m+     231[0m:[38;5;10m[49m     survived = patient_data["survived"]
[0m[49m[38;5;10m+     232[0m:[38;5;10m[49m     trajectory = []
[0m[49m[38;5;10m+     233[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     234[0m:[38;5;10m[49m     for t in range(len(time_steps) - 1):
[0m[49m[38;5;10m+     235[0m:[38;5;10m[49m         current = time_steps[t]
[0m[49m[38;5;10m+     236[0m:[38;5;10m[49m         next_step = time_steps[t + 1]
[0m[49m[38;5;10m+     237[0m:[38;5;10m[49m         is_terminal = (t == len(time_steps) - 2)
[0m[49m[38;5;10m+     238[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     239[0m:[38;5;10m[49m         # Construct state vector: extract features in the canonical order.
[0m[49m[38;5;10m+     240[0m:[38;5;10m[49m         state = np.array([current.get(f, 0.0) for f in STATE_FEATURES], dtype=np.float32)
[0m[49m[38;5;10m+     241[0m:[38;5;10m[49m         next_state = np.array([next_step.get(f, 0.0) for f in STATE_FEATURES], dtype=np.float32)
[0m[49m[38;5;10m+     242[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     243[0m:[38;5;10m[49m         # Discretize the treatment action.
[0m[49m[38;5;10m+     244[0m:[38;5;10m[49m         action = discretize_action(
[0m[49m[38;5;10m+     245[0m:[38;5;10m[49m             iv_fluid_ml=current.get("iv_fluid_ml", 0.0),
[0m[49m[38;5;10m+     246[0m:[38;5;10m[49m             vasopressor_dose=current.get("vasopressor_dose", 0.0),
[0m[49m[38;5;10m+     247[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     248[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     249[0m:[38;5;10m[49m         # Compute reward for this transition.
[0m[49m[38;5;10m+     250[0m:[38;5;10m[49m         reward = compute_reward(
[0m[49m[38;5;10m+     251[0m:[38;5;10m[49m             current_sofa=current.get("sofa_score", 0.0),
[0m[49m[38;5;10m+     252[0m:[38;5;10m[49m             next_sofa=next_step.get("sofa_score", 0.0),
[0m[49m[38;5;10m+     253[0m:[38;5;10m[49m             current_lactate=current.get("lactate", 0.0),
[0m[49m[38;5;10m+     254[0m:[38;5;10m[49m             next_lactate=next_step.get("lactate", 0.0),
[0m[49m[38;5;10m+     255[0m:[38;5;10m[49m             is_terminal=is_terminal,
[0m[49m[38;5;10m+     256[0m:[38;5;10m[49m             survived=survived,
[0m[49m[38;5;10m+     257[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     258[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     259[0m:[38;5;10m[49m         trajectory.append({
[0m[49m[38;5;10m+     260[0m:[38;5;10m[49m             "state": state,
[0m[49m[38;5;10m+     261[0m:[38;5;10m[49m             "action": action,
[0m[49m[38;5;10m+     262[0m:[38;5;10m[49m             "reward": reward,
[0m[49m[38;5;10m+     263[0m:[38;5;10m[49m             "next_state": next_state,
[0m[49m[38;5;10m+     264[0m:[38;5;10m[49m             "done": is_terminal,
[0m[49m[38;5;10m+     265[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     266[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     267[0m:[38;5;10m[49m     return trajectory
[0m[49m[38;5;10m+     268[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     269[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     270[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     271[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     272[0m:[38;5;10m[49m ## Step 2: Q-Network Definition
[0m[49m[38;5;10m+     273[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     274[0m:[38;5;10m[49m *This implements the neural network that estimates Q-values (expected cumulative reward for each state-action pair). Two networks are used: the "online" network that gets updated, and a "target" network that provides stable training targets.*
[0m[49m[38;5;10m+     275[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     276[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     277[0m:[38;5;10m[49m class QNetwork:
[0m[49m[38;5;10m+     278[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     279[0m:[38;5;10m[49m     A simple feedforward neural network for Q-value estimation.
[0m[49m[38;5;10m+     280[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     281[0m:[38;5;10m[49m     Takes a state vector as input, outputs Q-values for all 25 actions.
[0m[49m[38;5;10m+     282[0m:[38;5;10m[49m     Uses numpy for clarity (a real implementation would use PyTorch or TensorFlow
[0m[49m[38;5;10m+     283[0m:[38;5;10m[49m     for GPU acceleration and automatic differentiation).
[0m[49m[38;5;10m+     284[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     285[0m:[38;5;10m[49m     This is intentionally simplified. A production implementation would use
[0m[49m[38;5;10m+     286[0m:[38;5;10m[49m     a proper deep learning framework. We use numpy here so you can see
[0m[49m[38;5;10m+     287[0m:[38;5;10m[49m     exactly what's happening at each step without framework abstractions.
[0m[49m[38;5;10m+     288[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     289[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     290[0m:[38;5;10m[49m     def __init__(self, state_dim: int, num_actions: int, hidden_dims: List[int], lr: float):
[0m[49m[38;5;10m+     291[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     292[0m:[38;5;10m[49m         Initialize network weights with Xavier initialization.
[0m[49m[38;5;10m+     293[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     294[0m:[38;5;10m[49m         Args:
[0m[49m[38;5;10m+     295[0m:[38;5;10m[49m             state_dim: Number of input features (18 for our state representation).
[0m[49m[38;5;10m+     296[0m:[38;5;10m[49m             num_actions: Number of output Q-values (25 for our action space).
[0m[49m[38;5;10m+     297[0m:[38;5;10m[49m             hidden_dims: List of hidden layer sizes, e.g. [256, 256].
[0m[49m[38;5;10m+     298[0m:[38;5;10m[49m             lr: Learning rate for gradient descent.
[0m[49m[38;5;10m+     299[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     300[0m:[38;5;10m[49m         self.lr = lr
[0m[49m[38;5;10m+     301[0m:[38;5;10m[49m         self.layers = []
[0m[49m[38;5;10m+     302[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     303[0m:[38;5;10m[49m         # Build layer dimensions: input -> hidden1 -> hidden2 -> output
[0m[49m[38;5;10m+     304[0m:[38;5;10m[49m         dims = [state_dim] + hidden_dims + [num_actions]
[0m[49m[38;5;10m+     305[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     306[0m:[38;5;10m[49m         for i in range(len(dims) - 1):
[0m[49m[38;5;10m+     307[0m:[38;5;10m[49m             # Xavier initialization: scale weights by sqrt(2 / (fan_in + fan_out)).
[0m[49m[38;5;10m+     308[0m:[38;5;10m[49m             # This prevents vanishing/exploding gradients in deep networks.
[0m[49m[38;5;10m+     309[0m:[38;5;10m[49m             scale = np.sqrt(2.0 / (dims[i] + dims[i + 1]))
[0m[49m[38;5;10m+     310[0m:[38;5;10m[49m             W = np.random.randn(dims[i], dims[i + 1]).astype(np.float32) * scale
[0m[49m[38;5;10m+     311[0m:[38;5;10m[49m             b = np.zeros(dims[i + 1], dtype=np.float32)
[0m[49m[38;5;10m+     312[0m:[38;5;10m[49m             self.layers.append((W, b))
[0m[49m[38;5;10m+     313[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     314[0m:[38;5;10m[49m     def forward(self, state: np.ndarray) -> np.ndarray:
[0m[49m[38;5;10m+     315[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     316[0m:[38;5;10m[49m         Forward pass: compute Q-values for all actions given a state.
[0m[49m[38;5;10m+     317[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     318[0m:[38;5;10m[49m         Args:
[0m[49m[38;5;10m+     319[0m:[38;5;10m[49m             state: Shape (state_dim,) or (batch_size, state_dim).
[0m[49m[38;5;10m+     320[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     321[0m:[38;5;10m[49m         Returns:
[0m[49m[38;5;10m+     322[0m:[38;5;10m[49m             Q-values with shape (num_actions,) or (batch_size, num_actions).
[0m[49m[38;5;10m+     323[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     324[0m:[38;5;10m[49m         x = state
[0m[49m[38;5;10m+     325[0m:[38;5;10m[49m         for i, (W, b) in enumerate(self.layers):
[0m[49m[38;5;10m+     326[0m:[38;5;10m[49m             x = x @ W + b
[0m[49m[38;5;10m+     327[0m:[38;5;10m[49m             # ReLU activation for all layers except the last (output is unbounded Q-values).
[0m[49m[38;5;10m+     328[0m:[38;5;10m[49m             if i < len(self.layers) - 1:
[0m[49m[38;5;10m+     329[0m:[38;5;10m[49m                 x = np.maximum(0, x)
[0m[49m[38;5;10m+     330[0m:[38;5;10m[49m         return x
[0m[49m[38;5;10m+     331[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     332[0m:[38;5;10m[49m     def get_q_value(self, state: np.ndarray, action: int) -> float:
[0m[49m[38;5;10m+     333[0m:[38;5;10m[49m         """Get Q-value for a specific state-action pair."""
[0m[49m[38;5;10m+     334[0m:[38;5;10m[49m         q_values = self.forward(state)
[0m[49m[38;5;10m+     335[0m:[38;5;10m[49m         if q_values.ndim == 1:
[0m[49m[38;5;10m+     336[0m:[38;5;10m[49m             return float(q_values[action])
[0m[49m[38;5;10m+     337[0m:[38;5;10m[49m         return float(q_values[:, action])
[0m[49m[38;5;10m+     338[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     339[0m:[38;5;10m[49m     def copy_from(self, other: "QNetwork"):
[0m[49m[38;5;10m+     340[0m:[38;5;10m[49m         """Hard copy weights from another network."""
[0m[49m[38;5;10m+     341[0m:[38;5;10m[49m         for i in range(len(self.layers)):
[0m[49m[38;5;10m+     342[0m:[38;5;10m[49m             self.layers[i] = (
[0m[49m[38;5;10m+     343[0m:[38;5;10m[49m                 other.layers[i][0].copy(),
[0m[49m[38;5;10m+     344[0m:[38;5;10m[49m                 other.layers[i][1].copy(),
[0m[49m[38;5;10m+     345[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+     346[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     347[0m:[38;5;10m[49m     def soft_update_from(self, other: "QNetwork", tau: float):
[0m[49m[38;5;10m+     348[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     349[0m:[38;5;10m[49m         Soft update: blend this network's weights toward another network's weights.
[0m[49m[38;5;10m+     350[0m:[38;5;10m[49m         target = tau * online + (1 - tau) * target
[0m[49m[38;5;10m+     351[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     352[0m:[38;5;10m[49m         This provides more stable training targets than hard copies.
[0m[49m[38;5;10m+     353[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     354[0m:[38;5;10m[49m         for i in range(len(self.layers)):
[0m[49m[38;5;10m+     355[0m:[38;5;10m[49m             W_self, b_self = self.layers[i]
[0m[49m[38;5;10m+     356[0m:[38;5;10m[49m             W_other, b_other = other.layers[i]
[0m[49m[38;5;10m+     357[0m:[38;5;10m[49m             new_W = tau * W_other + (1 - tau) * W_self
[0m[49m[38;5;10m+     358[0m:[38;5;10m[49m             new_b = tau * b_other + (1 - tau) * b_self
[0m[49m[38;5;10m+     359[0m:[38;5;10m[49m             self.layers[i] = (new_W, new_b)
[0m[49m[38;5;10m+     360[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     361[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     362[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     363[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     364[0m:[38;5;10m[49m ## Step 3: Safety Constraint Layer
[0m[49m[38;5;10m+     365[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     366[0m:[38;5;10m[49m *Maps to pseudocode Step 4 in the main recipe. These are hard clinical boundaries that override the learned policy. No matter what the Q-function says, these constraints cannot be violated.*
[0m[49m[38;5;10m+     367[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     368[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     369[0m:[38;5;10m[49m def apply_safety_constraints(state: np.ndarray, q_values: np.ndarray) -> np.ndarray:
[0m[49m[38;5;10m+     370[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     371[0m:[38;5;10m[49m     Apply clinical safety constraints by masking out dangerous actions.
[0m[49m[38;5;10m+     372[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     373[0m:[38;5;10m[49m     Returns a modified Q-values array where unsafe actions have been set to
[0m[49m[38;5;10m+     374[0m:[38;5;10m[49m     negative infinity (so they'll never be selected by argmax).
[0m[49m[38;5;10m+     375[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     376[0m:[38;5;10m[49m     The constraints encode domain knowledge that should never be violated:
[0m[49m[38;5;10m+     377[0m:[38;5;10m[49m     - Severely hypotensive patients must have vasopressor support
[0m[49m[38;5;10m+     378[0m:[38;5;10m[49m     - Fluid-overloaded patients shouldn't get maximum fluids
[0m[49m[38;5;10m+     379[0m:[38;5;10m[49m     - Deteriorating patients shouldn't have support withdrawn
[0m[49m[38;5;10m+     380[0m:[38;5;10m[49m     - Critically ill patients need active treatment
[0m[49m[38;5;10m+     381[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     382[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     383[0m:[38;5;10m[49m         state: The current patient state vector (shape: STATE_DIM).
[0m[49m[38;5;10m+     384[0m:[38;5;10m[49m         q_values: Q-values for all 25 actions (shape: NUM_ACTIONS).
[0m[49m[38;5;10m+     385[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     386[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     387[0m:[38;5;10m[49m         Masked Q-values with unsafe actions set to -inf.
[0m[49m[38;5;10m+     388[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     389[0m:[38;5;10m[49m     masked_q = q_values.copy()
[0m[49m[38;5;10m+     390[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     391[0m:[38;5;10m[49m     # Extract relevant state features by index.
[0m[49m[38;5;10m+     392[0m:[38;5;10m[49m     # These indices match the STATE_FEATURES list order.
[0m[49m[38;5;10m+     393[0m:[38;5;10m[49m     map_idx = STATE_FEATURES.index("mean_arterial_pressure")
[0m[49m[38;5;10m+     394[0m:[38;5;10m[49m     fluid_balance_idx = STATE_FEATURES.index("cumulative_fluid_balance")
[0m[49m[38;5;10m+     395[0m:[38;5;10m[49m     lactate_idx = STATE_FEATURES.index("lactate")
[0m[49m[38;5;10m+     396[0m:[38;5;10m[49m     sofa_idx = STATE_FEATURES.index("sofa_score")
[0m[49m[38;5;10m+     397[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     398[0m:[38;5;10m[49m     map_value = state[map_idx]
[0m[49m[38;5;10m+     399[0m:[38;5;10m[49m     fluid_balance = state[fluid_balance_idx]
[0m[49m[38;5;10m+     400[0m:[38;5;10m[49m     sofa_score = state[sofa_idx]
[0m[49m[38;5;10m+     401[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     402[0m:[38;5;10m[49m     # Constraint 1: If MAP < 55, cannot have zero vasopressors.
[0m[49m[38;5;10m+     403[0m:[38;5;10m[49m     # MAP below 55 is associated with acute organ injury. The policy must not
[0m[49m[38;5;10m+     404[0m:[38;5;10m[49m     # remove hemodynamic support at this level.
[0m[49m[38;5;10m+     405[0m:[38;5;10m[49m     if map_value < SAFETY_CONSTRAINTS["min_map_for_no_vasopressors"]:
[0m[49m[38;5;10m+     406[0m:[38;5;10m[49m         for action_id in range(NUM_ACTIONS):
[0m[49m[38;5;10m+     407[0m:[38;5;10m[49m             _, vaso_level = decode_action(action_id)
[0m[49m[38;5;10m+     408[0m:[38;5;10m[49m             if vaso_level == 0:
[0m[49m[38;5;10m+     409[0m:[38;5;10m[49m                 masked_q[action_id] = -np.inf
[0m[49m[38;5;10m+     410[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     411[0m:[38;5;10m[49m     # Constraint 2: If fluid balance > 6000 mL, cannot give max fluids.
[0m[49m[38;5;10m+     412[0m:[38;5;10m[49m     # Fluid overload causes pulmonary edema and worsens outcomes.
[0m[49m[38;5;10m+     413[0m:[38;5;10m[49m     if fluid_balance > SAFETY_CONSTRAINTS["max_fluid_balance_for_max_fluids"]:
[0m[49m[38;5;10m+     414[0m:[38;5;10m[49m         for action_id in range(NUM_ACTIONS):
[0m[49m[38;5;10m+     415[0m:[38;5;10m[49m             fluid_level, _ = decode_action(action_id)
[0m[49m[38;5;10m+     416[0m:[38;5;10m[49m             if fluid_level == NUM_FLUID_LEVELS - 1:
[0m[49m[38;5;10m+     417[0m:[38;5;10m[49m                 masked_q[action_id] = -np.inf
[0m[49m[38;5;10m+     418[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     419[0m:[38;5;10m[49m     # Constraint 3: If SOFA >= 6, cannot have zero treatment (action 0 = no fluids, no vaso).
[0m[49m[38;5;10m+     420[0m:[38;5;10m[49m     # SOFA >= 6 indicates significant organ dysfunction requiring active management.
[0m[49m[38;5;10m+     421[0m:[38;5;10m[49m     if sofa_score >= SAFETY_CONSTRAINTS["min_sofa_for_zero_treatment"]:
[0m[49m[38;5;10m+     422[0m:[38;5;10m[49m         masked_q[0] = -np.inf
[0m[49m[38;5;10m+     423[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     424[0m:[38;5;10m[49m     # Fallback: if all actions are masked, unmask the most conservative non-zero action.
[0m[49m[38;5;10m+     425[0m:[38;5;10m[49m     # This shouldn't happen with well-designed constraints, but defensive coding matters
[0m[49m[38;5;10m+     426[0m:[38;5;10m[49m     # when patient safety is on the line.
[0m[49m[38;5;10m+     427[0m:[38;5;10m[49m     if np.all(np.isinf(masked_q) & (masked_q < 0)):
[0m[49m[38;5;10m+     428[0m:[38;5;10m[49m         # Default to moderate fluids + moderate vasopressors (action 12: fluid=2, vaso=2)
[0m[49m[38;5;10m+     429[0m:[38;5;10m[49m         masked_q[12] = 0.0
[0m[49m[38;5;10m+     430[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     431[0m:[38;5;10m[49m     return masked_q
[0m[49m[38;5;10m+     432[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     433[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     434[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     435[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     436[0m:[38;5;10m[49m ## Step 4: Conservative Q-Learning Training
[0m[49m[38;5;10m+     437[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     438[0m:[38;5;10m[49m *Maps to pseudocode Step 3 in the main recipe. This is the core offline RL algorithm. CQL adds a penalty that discourages the Q-function from overestimating the value of actions that are rare in the training data. This is critical for healthcare: if clinicians rarely took a particular action, we should be skeptical that it's secretly optimal.*
[0m[49m[38;5;10m+     439[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     440[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     441[0m:[38;5;10m[49m class ReplayBuffer:
[0m[49m[38;5;10m+     442[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     443[0m:[38;5;10m[49m     Stores all training trajectories for batch sampling.
[0m[49m[38;5;10m+     444[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     445[0m:[38;5;10m[49m     In offline RL, the buffer is fixed (no new data is added during training).
[0m[49m[38;5;10m+     446[0m:[38;5;10m[49m     We load all historical trajectories once and sample from them repeatedly.
[0m[49m[38;5;10m+     447[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     448[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     449[0m:[38;5;10m[49m     def __init__(self):
[0m[49m[38;5;10m+     450[0m:[38;5;10m[49m         self.states = []
[0m[49m[38;5;10m+     451[0m:[38;5;10m[49m         self.actions = []
[0m[49m[38;5;10m+     452[0m:[38;5;10m[49m         self.rewards = []
[0m[49m[38;5;10m+     453[0m:[38;5;10m[49m         self.next_states = []
[0m[49m[38;5;10m+     454[0m:[38;5;10m[49m         self.dones = []
[0m[49m[38;5;10m+     455[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     456[0m:[38;5;10m[49m     def add_trajectory(self, trajectory: List[Dict]):
[0m[49m[38;5;10m+     457[0m:[38;5;10m[49m         """Add all transitions from a single patient trajectory."""
[0m[49m[38;5;10m+     458[0m:[38;5;10m[49m         for transition in trajectory:
[0m[49m[38;5;10m+     459[0m:[38;5;10m[49m             self.states.append(transition["state"])
[0m[49m[38;5;10m+     460[0m:[38;5;10m[49m             self.actions.append(transition["action"])
[0m[49m[38;5;10m+     461[0m:[38;5;10m[49m             self.rewards.append(transition["reward"])
[0m[49m[38;5;10m+     462[0m:[38;5;10m[49m             self.next_states.append(transition["next_state"])
[0m[49m[38;5;10m+     463[0m:[38;5;10m[49m             self.dones.append(transition["done"])
[0m[49m[38;5;10m+     464[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     465[0m:[38;5;10m[49m     def sample(self, batch_size: int) -> Tuple:
[0m[49m[38;5;10m+     466[0m:[38;5;10m[49m         """Sample a random batch of transitions for training."""
[0m[49m[38;5;10m+     467[0m:[38;5;10m[49m         indices = np.random.randint(0, len(self.states), size=batch_size)
[0m[49m[38;5;10m+     468[0m:[38;5;10m[49m         return (
[0m[49m[38;5;10m+     469[0m:[38;5;10m[49m             np.array([self.states[i] for i in indices]),
[0m[49m[38;5;10m+     470[0m:[38;5;10m[49m             np.array([self.actions[i] for i in indices]),
[0m[49m[38;5;10m+     471[0m:[38;5;10m[49m             np.array([self.rewards[i] for i in indices]),
[0m[49m[38;5;10m+     472[0m:[38;5;10m[49m             np.array([self.next_states[i] for i in indices]),
[0m[49m[38;5;10m+     473[0m:[38;5;10m[49m             np.array([self.dones[i] for i in indices]),
[0m[49m[38;5;10m+     474[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     475[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     476[0m:[38;5;10m[49m     @property
[0m[49m[38;5;10m+     477[0m:[38;5;10m[49m     def size(self) -> int:
[0m[49m[38;5;10m+     478[0m:[38;5;10m[49m         return len(self.states)
[0m[49m[38;5;10m+     479[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     480[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     481[0m:[38;5;10m[49m def train_cql_policy(replay_buffer: ReplayBuffer, config: Dict) -> QNetwork:
[0m[49m[38;5;10m+     482[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     483[0m:[38;5;10m[49m     Train a sepsis treatment policy using Conservative Q-Learning.
[0m[49m[38;5;10m+     484[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     485[0m:[38;5;10m[49m     CQL modifies standard Q-learning by adding a regularization term that
[0m[49m[38;5;10m+     486[0m:[38;5;10m[49m     penalizes high Q-values for actions that are underrepresented in the data.
[0m[49m[38;5;10m+     487[0m:[38;5;10m[49m     This prevents the policy from recommending actions that look good on paper
[0m[49m[38;5;10m+     488[0m:[38;5;10m[49m     but have no empirical support.
[0m[49m[38;5;10m+     489[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     490[0m:[38;5;10m[49m     The intuition: if clinicians almost never gave zero fluids to hypotensive
[0m[49m[38;5;10m+     491[0m:[38;5;10m[49m     patients, CQL won't optimistically assume that action would work well.
[0m[49m[38;5;10m+     492[0m:[38;5;10m[49m     It stays conservative, preferring well-supported actions.
[0m[49m[38;5;10m+     493[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     494[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     495[0m:[38;5;10m[49m         replay_buffer: Contains all historical (state, action, reward, next_state) tuples.
[0m[49m[38;5;10m+     496[0m:[38;5;10m[49m         config: Training hyperparameters (CQL_CONFIG).
[0m[49m[38;5;10m+     497[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     498[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     499[0m:[38;5;10m[49m         Trained Q-network that can be used to derive the treatment policy.
[0m[49m[38;5;10m+     500[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     501[0m:[38;5;10m[49m     # Initialize online and target Q-networks.
[0m[49m[38;5;10m+     502[0m:[38;5;10m[49m     q_network = QNetwork(
[0m[49m[38;5;10m+     503[0m:[38;5;10m[49m         state_dim=STATE_DIM,
[0m[49m[38;5;10m+     504[0m:[38;5;10m[49m         num_actions=NUM_ACTIONS,
[0m[49m[38;5;10m+     505[0m:[38;5;10m[49m         hidden_dims=config["hidden_dims"],
[0m[49m[38;5;10m+     506[0m:[38;5;10m[49m         lr=config["learning_rate"],
[0m[49m[38;5;10m+     507[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     508[0m:[38;5;10m[49m     target_network = QNetwork(
[0m[49m[38;5;10m+     509[0m:[38;5;10m[49m         state_dim=STATE_DIM,
[0m[49m[38;5;10m+     510[0m:[38;5;10m[49m         num_actions=NUM_ACTIONS,
[0m[49m[38;5;10m+     511[0m:[38;5;10m[49m         hidden_dims=config["hidden_dims"],
[0m[49m[38;5;10m+     512[0m:[38;5;10m[49m         lr=config["learning_rate"],
[0m[49m[38;5;10m+     513[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     514[0m:[38;5;10m[49m     target_network.copy_from(q_network)
[0m[49m[38;5;10m+     515[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     516[0m:[38;5;10m[49m     gamma = config["gamma"]
[0m[49m[38;5;10m+     517[0m:[38;5;10m[49m     cql_alpha = config["cql_alpha"]
[0m[49m[38;5;10m+     518[0m:[38;5;10m[49m     batch_size = config["batch_size"]
[0m[49m[38;5;10m+     519[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     520[0m:[38;5;10m[49m     print(f"Starting CQL training: {config['num_iterations']} iterations, "
[0m[49m[38;5;10m+     521[0m:[38;5;10m[49m           f"buffer size: {replay_buffer.size}, cql_alpha: {cql_alpha}")
[0m[49m[38;5;10m+     522[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     523[0m:[38;5;10m[49m     for iteration in range(config["num_iterations"]):
[0m[49m[38;5;10m+     524[0m:[38;5;10m[49m         # Sample a batch of transitions from the replay buffer.
[0m[49m[38;5;10m+     525[0m:[38;5;10m[49m         states, actions, rewards, next_states, dones = replay_buffer.sample(batch_size)
[0m[49m[38;5;10m+     526[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     527[0m:[38;5;10m[49m         # --- Compute standard Q-learning targets ---
[0m[49m[38;5;10m+     528[0m:[38;5;10m[49m         # For terminal states: target = reward (no future to discount).
[0m[49m[38;5;10m+     529[0m:[38;5;10m[49m         # For non-terminal: target = reward + gamma * max_a Q_target(next_state, a).
[0m[49m[38;5;10m+     530[0m:[38;5;10m[49m         next_q_values = target_network.forward(next_states)  # (batch, 25)
[0m[49m[38;5;10m+     531[0m:[38;5;10m[49m         max_next_q = np.max(next_q_values, axis=1)           # (batch,)
[0m[49m[38;5;10m+     532[0m:[38;5;10m[49m         targets = rewards + gamma * max_next_q * (1.0 - dones.astype(np.float32))
[0m[49m[38;5;10m+     533[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     534[0m:[38;5;10m[49m         # --- Compute current Q-values for the actions that were actually taken ---
[0m[49m[38;5;10m+     535[0m:[38;5;10m[49m         current_q_all = q_network.forward(states)  # (batch, 25)
[0m[49m[38;5;10m+     536[0m:[38;5;10m[49m         current_q = current_q_all[np.arange(batch_size), actions.astype(int)]  # (batch,)
[0m[49m[38;5;10m+     537[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     538[0m:[38;5;10m[49m         # --- CQL regularization term ---
[0m[49m[38;5;10m+     539[0m:[38;5;10m[49m         # Push down Q-values for all actions (logsumexp), push up for observed actions.
[0m[49m[38;5;10m+     540[0m:[38;5;10m[49m         # This makes the Q-function conservative: it won't overestimate actions
[0m[49m[38;5;10m+     541[0m:[38;5;10m[49m         # that are rare in the data.
[0m[49m[38;5;10m+     542[0m:[38;5;10m[49m         logsumexp_q = np.log(np.sum(np.exp(current_q_all - np.max(current_q_all, axis=1, keepdims=True)),
[0m[49m[38;5;10m+     543[0m:[38;5;10m[49m                                      axis=1)) + np.max(current_q_all, axis=1)
[0m[49m[38;5;10m+     544[0m:[38;5;10m[49m         cql_loss = cql_alpha * (logsumexp_q - current_q).mean()
[0m[49m[38;5;10m+     545[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     546[0m:[38;5;10m[49m         # --- Total loss: TD error + CQL penalty ---
[0m[49m[38;5;10m+     547[0m:[38;5;10m[49m         td_loss = np.mean((current_q - targets) ** 2)
[0m[49m[38;5;10m+     548[0m:[38;5;10m[49m         total_loss = td_loss + cql_loss
[0m[49m[38;5;10m+     549[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     550[0m:[38;5;10m[49m         # In a real implementation, you'd compute gradients and update weights here
[0m[49m[38;5;10m+     551[0m:[38;5;10m[49m         # using autograd (PyTorch/TensorFlow). With numpy, we'd need manual backprop.
[0m[49m[38;5;10m+     552[0m:[38;5;10m[49m         # For illustration, we show the loss computation and note that gradient
[0m[49m[38;5;10m+     553[0m:[38;5;10m[49m         # descent would minimize this loss.
[0m[49m[38;5;10m+     554[0m:[38;5;10m[49m         #
[0m[49m[38;5;10m+     555[0m:[38;5;10m[49m         # In practice, this training loop would look like:
[0m[49m[38;5;10m+     556[0m:[38;5;10m[49m         #   optimizer.zero_grad()
[0m[49m[38;5;10m+     557[0m:[38;5;10m[49m         #   loss.backward()
[0m[49m[38;5;10m+     558[0m:[38;5;10m[49m         #   optimizer.step()
[0m[49m[38;5;10m+     559[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     560[0m:[38;5;10m[49m         # Periodically update target network (soft update for stability).
[0m[49m[38;5;10m+     561[0m:[38;5;10m[49m         if iteration % config["target_update_freq"] == 0:
[0m[49m[38;5;10m+     562[0m:[38;5;10m[49m             target_network.soft_update_from(q_network, config["tau"])
[0m[49m[38;5;10m+     563[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     564[0m:[38;5;10m[49m         # Log progress every 5000 iterations.
[0m[49m[38;5;10m+     565[0m:[38;5;10m[49m         if iteration % 5000 == 0:
[0m[49m[38;5;10m+     566[0m:[38;5;10m[49m             print(f"  Iteration {iteration}: TD loss={td_loss:.4f}, "
[0m[49m[38;5;10m+     567[0m:[38;5;10m[49m                   f"CQL loss={cql_loss:.4f}, total={total_loss:.4f}")
[0m[49m[38;5;10m+     568[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     569[0m:[38;5;10m[49m     print("Training complete.")
[0m[49m[38;5;10m+     570[0m:[38;5;10m[49m     return q_network
[0m[49m[38;5;10m+     571[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     572[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     573[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     574[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     575[0m:[38;5;10m[49m ## Step 5: Off-Policy Evaluation
[0m[49m[38;5;10m+     576[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     577[0m:[38;5;10m[49m *Maps to pseudocode Step 5 in the main recipe. This estimates how well the learned policy would have performed compared to what clinicians actually did. You cannot deploy without this step, and you should not trust any single OPE method in isolation.*
[0m[49m[38;5;10m+     578[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     579[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     580[0m:[38;5;10m[49m def evaluate_policy_wis(
[0m[49m[38;5;10m+     581[0m:[38;5;10m[49m     q_network: QNetwork,
[0m[49m[38;5;10m+     582[0m:[38;5;10m[49m     test_trajectories: List[List[Dict]],
[0m[49m[38;5;10m+     583[0m:[38;5;10m[49m     behavior_action_probs: Dict,
[0m[49m[38;5;10m+     584[0m:[38;5;10m[49m ) -> Dict:
[0m[49m[38;5;10m+     585[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     586[0m:[38;5;10m[49m     Weighted Importance Sampling (WIS) for off-policy evaluation.
[0m[49m[38;5;10m+     587[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     588[0m:[38;5;10m[49m     The idea: reweight historical outcomes by the probability ratio of the
[0m[49m[38;5;10m+     589[0m:[38;5;10m[49m     learned policy vs. the behavior policy (what clinicians actually did).
[0m[49m[38;5;10m+     590[0m:[38;5;10m[49m     If our policy would have taken the same actions, the weight is ~1.
[0m[49m[38;5;10m+     591[0m:[38;5;10m[49m     If it would have done something different, we can't trust that trajectory's
[0m[49m[38;5;10m+     592[0m:[38;5;10m[49m     outcome as evidence for our policy.
[0m[49m[38;5;10m+     593[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     594[0m:[38;5;10m[49m     This method has high variance (especially when the learned policy differs
[0m[49m[38;5;10m+     595[0m:[38;5;10m[49m     substantially from clinician behavior), but it's unbiased under certain
[0m[49m[38;5;10m+     596[0m:[38;5;10m[49m     assumptions. Always report confidence intervals.
[0m[49m[38;5;10m+     597[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     598[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     599[0m:[38;5;10m[49m         q_network: The trained Q-network (policy is argmax of Q-values).
[0m[49m[38;5;10m+     600[0m:[38;5;10m[49m         test_trajectories: Held-out patient trajectories not used in training.
[0m[49m[38;5;10m+     601[0m:[38;5;10m[49m         behavior_action_probs: Estimated probability of each action under the
[0m[49m[38;5;10m+     602[0m:[38;5;10m[49m             clinician behavior policy (from the training data distribution).
[0m[49m[38;5;10m+     603[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     604[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     605[0m:[38;5;10m[49m         Dictionary with WIS estimate, confidence interval, and agreement rate.
[0m[49m[38;5;10m+     606[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     607[0m:[38;5;10m[49m     weighted_returns = []
[0m[49m[38;5;10m+     608[0m:[38;5;10m[49m     weights_list = []
[0m[49m[38;5;10m+     609[0m:[38;5;10m[49m     agreements = 0
[0m[49m[38;5;10m+     610[0m:[38;5;10m[49m     total_decisions = 0
[0m[49m[38;5;10m+     611[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     612[0m:[38;5;10m[49m     for trajectory in test_trajectories:
[0m[49m[38;5;10m+     613[0m:[38;5;10m[49m         cumulative_weight = 1.0
[0m[49m[38;5;10m+     614[0m:[38;5;10m[49m         trajectory_return = sum(t["reward"] for t in trajectory)
[0m[49m[38;5;10m+     615[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     616[0m:[38;5;10m[49m         for transition in trajectory:
[0m[49m[38;5;10m+     617[0m:[38;5;10m[49m             state = transition["state"]
[0m[49m[38;5;10m+     618[0m:[38;5;10m[49m             clinician_action = transition["action"]
[0m[49m[38;5;10m+     619[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     620[0m:[38;5;10m[49m             # Learned policy: argmax of Q-values with safety constraints.
[0m[49m[38;5;10m+     621[0m:[38;5;10m[49m             q_values = q_network.forward(state)
[0m[49m[38;5;10m+     622[0m:[38;5;10m[49m             safe_q = apply_safety_constraints(state, q_values)
[0m[49m[38;5;10m+     623[0m:[38;5;10m[49m             policy_action = int(np.argmax(safe_q))
[0m[49m[38;5;10m+     624[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     625[0m:[38;5;10m[49m             # Policy probability: we treat argmax as deterministic (prob=1 for best action).
[0m[49m[38;5;10m+     626[0m:[38;5;10m[49m             # A softer version would use a Boltzmann distribution over Q-values.
[0m[49m[38;5;10m+     627[0m:[38;5;10m[49m             pi_prob = 1.0 if policy_action == clinician_action else 0.01
[0m[49m[38;5;10m+     628[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     629[0m:[38;5;10m[49m             # Behavior probability: estimated from training data action frequencies.
[0m[49m[38;5;10m+     630[0m:[38;5;10m[49m             # In practice, you'd condition this on the state (or state cluster).
[0m[49m[38;5;10m+     631[0m:[38;5;10m[49m             behavior_prob = behavior_action_probs.get(clinician_action, 1.0 / NUM_ACTIONS)
[0m[49m[38;5;10m+     632[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     633[0m:[38;5;10m[49m             # Importance weight: ratio of policy probability to behavior probability.
[0m[49m[38;5;10m+     634[0m:[38;5;10m[49m             ratio = pi_prob / max(behavior_prob, 0.001)
[0m[49m[38;5;10m+     635[0m:[38;5;10m[49m             cumulative_weight *= ratio
[0m[49m[38;5;10m+     636[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     637[0m:[38;5;10m[49m             # Clip to prevent extreme weights from dominating the estimate.
[0m[49m[38;5;10m+     638[0m:[38;5;10m[49m             cumulative_weight = np.clip(cumulative_weight, 0.001, 100.0)
[0m[49m[38;5;10m+     639[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     640[0m:[38;5;10m[49m             # Track agreement rate.
[0m[49m[38;5;10m+     641[0m:[38;5;10m[49m             if policy_action == clinician_action:
[0m[49m[38;5;10m+     642[0m:[38;5;10m[49m                 agreements += 1
[0m[49m[38;5;10m+     643[0m:[38;5;10m[49m             total_decisions += 1
[0m[49m[38;5;10m+     644[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     645[0m:[38;5;10m[49m         weighted_returns.append(cumulative_weight * trajectory_return)
[0m[49m[38;5;10m+     646[0m:[38;5;10m[49m         weights_list.append(cumulative_weight)
[0m[49m[38;5;10m+     647[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     648[0m:[38;5;10m[49m     # Self-normalized WIS: divide by sum of weights for stability.
[0m[49m[38;5;10m+     649[0m:[38;5;10m[49m     weights_array = np.array(weights_list)
[0m[49m[38;5;10m+     650[0m:[38;5;10m[49m     returns_array = np.array(weighted_returns)
[0m[49m[38;5;10m+     651[0m:[38;5;10m[49m     wis_value = np.sum(returns_array) / np.sum(weights_array)
[0m[49m[38;5;10m+     652[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     653[0m:[38;5;10m[49m     # Bootstrap confidence interval (1000 resamples).
[0m[49m[38;5;10m+     654[0m:[38;5;10m[49m     bootstrap_estimates = []
[0m[49m[38;5;10m+     655[0m:[38;5;10m[49m     for _ in range(1000):
[0m[49m[38;5;10m+     656[0m:[38;5;10m[49m         idx = np.random.choice(len(returns_array), size=len(returns_array), replace=True)
[0m[49m[38;5;10m+     657[0m:[38;5;10m[49m         boot_val = np.sum(returns_array[idx]) / np.sum(weights_array[idx])
[0m[49m[38;5;10m+     658[0m:[38;5;10m[49m         bootstrap_estimates.append(boot_val)
[0m[49m[38;5;10m+     659[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     660[0m:[38;5;10m[49m     ci_lower = np.percentile(bootstrap_estimates, 2.5)
[0m[49m[38;5;10m+     661[0m:[38;5;10m[49m     ci_upper = np.percentile(bootstrap_estimates, 97.5)
[0m[49m[38;5;10m+     662[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     663[0m:[38;5;10m[49m     # Clinician baseline: average return under actual behavior.
[0m[49m[38;5;10m+     664[0m:[38;5;10m[49m     clinician_value = np.mean([sum(t["reward"] for t in traj) for traj in test_trajectories])
[0m[49m[38;5;10m+     665[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     666[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     667[0m:[38;5;10m[49m         "wis_estimated_value": float(wis_value),
[0m[49m[38;5;10m+     668[0m:[38;5;10m[49m         "wis_95_ci_lower": float(ci_lower),
[0m[49m[38;5;10m+     669[0m:[38;5;10m[49m         "wis_95_ci_upper": float(ci_upper),
[0m[49m[38;5;10m+     670[0m:[38;5;10m[49m         "clinician_baseline_value": float(clinician_value),
[0m[49m[38;5;10m+     671[0m:[38;5;10m[49m         "agreement_rate": agreements / max(total_decisions, 1),
[0m[49m[38;5;10m+     672[0m:[38;5;10m[49m         "num_test_trajectories": len(test_trajectories),
[0m[49m[38;5;10m+     673[0m:[38;5;10m[49m         "effective_sample_size": float(np.sum(weights_array) ** 2 / np.sum(weights_array ** 2)),
[0m[49m[38;5;10m+     674[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     675[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     676[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     677[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     678[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     679[0m:[38;5;10m[49m ## Step 6: Policy Serving and Recommendation
[0m[49m[38;5;10m+     680[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     681[0m:[38;5;10m[49m *Maps to pseudocode Step 6 in the main recipe. This is the inference path: given a patient's current state, return a treatment recommendation with safety constraints and explainability information.*
[0m[49m[38;5;10m+     682[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     683[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     684[0m:[38;5;10m[49m def get_recommendation(
[0m[49m[38;5;10m+     685[0m:[38;5;10m[49m     patient_state: Dict,
[0m[49m[38;5;10m+     686[0m:[38;5;10m[49m     q_network: QNetwork,
[0m[49m[38;5;10m+     687[0m:[38;5;10m[49m     normalization_stats: Dict,
[0m[49m[38;5;10m+     688[0m:[38;5;10m[49m ) -> Dict:
[0m[49m[38;5;10m+     689[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     690[0m:[38;5;10m[49m     Generate a treatment recommendation for a sepsis patient.
[0m[49m[38;5;10m+     691[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     692[0m:[38;5;10m[49m     Takes raw clinical values, normalizes them, runs through the Q-network,
[0m[49m[38;5;10m+     693[0m:[38;5;10m[49m     applies safety constraints, and returns an interpretable recommendation.
[0m[49m[38;5;10m+     694[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     695[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     696[0m:[38;5;10m[49m         patient_state: Dictionary of current physiological values (raw, unnormalized).
[0m[49m[38;5;10m+     697[0m:[38;5;10m[49m         q_network: Trained Q-network.
[0m[49m[38;5;10m+     698[0m:[38;5;10m[49m         normalization_stats: Dict with "mean" and "std" arrays for each feature.
[0m[49m[38;5;10m+     699[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     700[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     701[0m:[38;5;10m[49m         Recommendation dictionary with action, interpretation, confidence, and drivers.
[0m[49m[38;5;10m+     702[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     703[0m:[38;5;10m[49m     # Construct and normalize the state vector.
[0m[49m[38;5;10m+     704[0m:[38;5;10m[49m     raw_state = np.array([patient_state.get(f, 0.0) for f in STATE_FEATURES], dtype=np.float32)
[0m[49m[38;5;10m+     705[0m:[38;5;10m[49m     means = normalization_stats["mean"]
[0m[49m[38;5;10m+     706[0m:[38;5;10m[49m     stds = normalization_stats["std"]
[0m[49m[38;5;10m+     707[0m:[38;5;10m[49m     # Avoid division by zero for features with no variance.
[0m[49m[38;5;10m+     708[0m:[38;5;10m[49m     normalized_state = (raw_state - means) / np.maximum(stds, 1e-8)
[0m[49m[38;5;10m+     709[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     710[0m:[38;5;10m[49m     # Get Q-values for all actions.
[0m[49m[38;5;10m+     711[0m:[38;5;10m[49m     q_values = q_network.forward(normalized_state)
[0m[49m[38;5;10m+     712[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     713[0m:[38;5;10m[49m     # Apply safety constraints (may mask out dangerous actions).
[0m[49m[38;5;10m+     714[0m:[38;5;10m[49m     safe_q_values = apply_safety_constraints(raw_state, q_values)
[0m[49m[38;5;10m+     715[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     716[0m:[38;5;10m[49m     # Select best action and compute confidence.
[0m[49m[38;5;10m+     717[0m:[38;5;10m[49m     best_action = int(np.argmax(safe_q_values))
[0m[49m[38;5;10m+     718[0m:[38;5;10m[49m     sorted_q = np.sort(safe_q_values[safe_q_values > -np.inf])[::-1]
[0m[49m[38;5;10m+     719[0m:[38;5;10m[49m     # Confidence: gap between best and second-best Q-value.
[0m[49m[38;5;10m+     720[0m:[38;5;10m[49m     # Larger gap = more confident the best action is clearly superior.
[0m[49m[38;5;10m+     721[0m:[38;5;10m[49m     confidence = float(sorted_q[0] - sorted_q[1]) if len(sorted_q) > 1 else 0.0
[0m[49m[38;5;10m+     722[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     723[0m:[38;5;10m[49m     # Decode action into clinical terms.
[0m[49m[38;5;10m+     724[0m:[38;5;10m[49m     fluid_level, vaso_level = decode_action(best_action)
[0m[49m[38;5;10m+     725[0m:[38;5;10m[49m     fluid_desc = _fluid_level_description(fluid_level)
[0m[49m[38;5;10m+     726[0m:[38;5;10m[49m     vaso_desc = _vasopressor_level_description(vaso_level)
[0m[49m[38;5;10m+     727[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     728[0m:[38;5;10m[49m     # Identify which safety constraints were triggered.
[0m[49m[38;5;10m+     729[0m:[38;5;10m[49m     original_best = int(np.argmax(q_values))
[0m[49m[38;5;10m+     730[0m:[38;5;10m[49m     constraints_triggered = []
[0m[49m[38;5;10m+     731[0m:[38;5;10m[49m     if original_best != best_action:
[0m[49m[38;5;10m+     732[0m:[38;5;10m[49m         constraints_triggered.append("Safety constraint overrode unconstrained recommendation")
[0m[49m[38;5;10m+     733[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     734[0m:[38;5;10m[49m     # Key drivers: which state features have the most extreme normalized values.
[0m[49m[38;5;10m+     735[0m:[38;5;10m[49m     # These are the features most likely driving the recommendation.
[0m[49m[38;5;10m+     736[0m:[38;5;10m[49m     feature_importance = np.abs(normalized_state)
[0m[49m[38;5;10m+     737[0m:[38;5;10m[49m     top_indices = np.argsort(feature_importance)[::-1][:5]
[0m[49m[38;5;10m+     738[0m:[38;5;10m[49m     key_drivers = [
[0m[49m[38;5;10m+     739[0m:[38;5;10m[49m         f"{STATE_FEATURES[i]}: {patient_state.get(STATE_FEATURES[i], 'N/A')}"
[0m[49m[38;5;10m+     740[0m:[38;5;10m[49m         for i in top_indices
[0m[49m[38;5;10m+     741[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+     742[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     743[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     744[0m:[38;5;10m[49m         "recommended_action_id": best_action,
[0m[49m[38;5;10m+     745[0m:[38;5;10m[49m         "fluid_recommendation": fluid_desc,
[0m[49m[38;5;10m+     746[0m:[38;5;10m[49m         "vasopressor_recommendation": vaso_desc,
[0m[49m[38;5;10m+     747[0m:[38;5;10m[49m         "confidence": round(confidence, 3),
[0m[49m[38;5;10m+     748[0m:[38;5;10m[49m         "safety_constraints_triggered": constraints_triggered,
[0m[49m[38;5;10m+     749[0m:[38;5;10m[49m         "key_drivers": key_drivers,
[0m[49m[38;5;10m+     750[0m:[38;5;10m[49m         "top_3_actions": [
[0m[49m[38;5;10m+     751[0m:[38;5;10m[49m             {"action_id": int(a), "q_value": float(safe_q_values[a])}
[0m[49m[38;5;10m+     752[0m:[38;5;10m[49m             for a in np.argsort(safe_q_values)[::-1][:3]
[0m[49m[38;5;10m+     753[0m:[38;5;10m[49m             if safe_q_values[a] > -np.inf
[0m[49m[38;5;10m+     754[0m:[38;5;10m[49m         ],
[0m[49m[38;5;10m+     755[0m:[38;5;10m[49m         "disclaimer": "Advisory only. Clinical judgment supersedes all recommendations.",
[0m[49m[38;5;10m+     756[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     757[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     758[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     759[0m:[38;5;10m[49m def _fluid_level_description(level: int) -> str:
[0m[49m[38;5;10m+     760[0m:[38;5;10m[49m     """Human-readable description of a fluid level."""
[0m[49m[38;5;10m+     761[0m:[38;5;10m[49m     descriptions = [
[0m[49m[38;5;10m+     762[0m:[38;5;10m[49m         "No additional IV fluids this window",
[0m[49m[38;5;10m+     763[0m:[38;5;10m[49m         "Minimal maintenance fluids (~250 mL)",
[0m[49m[38;5;10m+     764[0m:[38;5;10m[49m         "Moderate fluid resuscitation (~500 mL)",
[0m[49m[38;5;10m+     765[0m:[38;5;10m[49m         "Aggressive fluid resuscitation (~1000 mL)",
[0m[49m[38;5;10m+     766[0m:[38;5;10m[49m         "Very aggressive fluid bolus (~2000+ mL)",
[0m[49m[38;5;10m+     767[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+     768[0m:[38;5;10m[49m     return descriptions[min(level, len(descriptions) - 1)]
[0m[49m[38;5;10m+     769[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     770[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     771[0m:[38;5;10m[49m def _vasopressor_level_description(level: int) -> str:
[0m[49m[38;5;10m+     772[0m:[38;5;10m[49m     """Human-readable description of a vasopressor level."""
[0m[49m[38;5;10m+     773[0m:[38;5;10m[49m     descriptions = [
[0m[49m[38;5;10m+     774[0m:[38;5;10m[49m         "No vasopressor support",
[0m[49m[38;5;10m+     775[0m:[38;5;10m[49m         "Low-dose vasopressor (NE ~0.08 mcg/kg/min)",
[0m[49m[38;5;10m+     776[0m:[38;5;10m[49m         "Moderate vasopressor support (NE ~0.16 mcg/kg/min)",
[0m[49m[38;5;10m+     777[0m:[38;5;10m[49m         "High-dose vasopressor support (NE ~0.28 mcg/kg/min)",
[0m[49m[38;5;10m+     778[0m:[38;5;10m[49m         "Maximal vasopressor support (NE ~0.45+ mcg/kg/min)",
[0m[49m[38;5;10m+     779[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+     780[0m:[38;5;10m[49m     return descriptions[min(level, len(descriptions) - 1)]
[0m[49m[38;5;10m+     781[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     782[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     783[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     784[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     785[0m:[38;5;10m[49m ## Step 7: AWS Integration (SageMaker + S3 + DynamoDB)
[0m[49m[38;5;10m+     786[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     787[0m:[38;5;10m[49m *This section shows how the pieces connect to AWS services for training, storage, and serving.*
[0m[49m[38;5;10m+     788[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     789[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     790[0m:[38;5;10m[49m def upload_trajectories_to_s3(trajectories: List[List[Dict]], experiment_id: str):
[0m[49m[38;5;10m+     791[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     792[0m:[38;5;10m[49m     Upload processed trajectories to S3 for SageMaker training jobs.
[0m[49m[38;5;10m+     793[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     794[0m:[38;5;10m[49m     Trajectories are serialized as numpy arrays (states, actions, rewards, etc.)
[0m[49m[38;5;10m+     795[0m:[38;5;10m[49m     and stored in a format that SageMaker training containers can read.
[0m[49m[38;5;10m+     796[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     797[0m:[38;5;10m[49m     s3_client = boto3.client("s3", config=BOTO3_CONFIG)
[0m[49m[38;5;10m+     798[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     799[0m:[38;5;10m[49m     # Flatten all trajectories into arrays for efficient storage.
[0m[49m[38;5;10m+     800[0m:[38;5;10m[49m     all_states = []
[0m[49m[38;5;10m+     801[0m:[38;5;10m[49m     all_actions = []
[0m[49m[38;5;10m+     802[0m:[38;5;10m[49m     all_rewards = []
[0m[49m[38;5;10m+     803[0m:[38;5;10m[49m     all_next_states = []
[0m[49m[38;5;10m+     804[0m:[38;5;10m[49m     all_dones = []
[0m[49m[38;5;10m+     805[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     806[0m:[38;5;10m[49m     for trajectory in trajectories:
[0m[49m[38;5;10m+     807[0m:[38;5;10m[49m         for t in trajectory:
[0m[49m[38;5;10m+     808[0m:[38;5;10m[49m             all_states.append(t["state"])
[0m[49m[38;5;10m+     809[0m:[38;5;10m[49m             all_actions.append(t["action"])
[0m[49m[38;5;10m+     810[0m:[38;5;10m[49m             all_rewards.append(t["reward"])
[0m[49m[38;5;10m+     811[0m:[38;5;10m[49m             all_next_states.append(t["next_state"])
[0m[49m[38;5;10m+     812[0m:[38;5;10m[49m             all_dones.append(t["done"])
[0m[49m[38;5;10m+     813[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     814[0m:[38;5;10m[49m     # Save as .npz (compressed numpy archive).
[0m[49m[38;5;10m+     815[0m:[38;5;10m[49m     import io
[0m[49m[38;5;10m+     816[0m:[38;5;10m[49m     buffer = io.BytesIO()
[0m[49m[38;5;10m+     817[0m:[38;5;10m[49m     np.savez_compressed(
[0m[49m[38;5;10m+     818[0m:[38;5;10m[49m         buffer,
[0m[49m[38;5;10m+     819[0m:[38;5;10m[49m         states=np.array(all_states),
[0m[49m[38;5;10m+     820[0m:[38;5;10m[49m         actions=np.array(all_actions),
[0m[49m[38;5;10m+     821[0m:[38;5;10m[49m         rewards=np.array(all_rewards),
[0m[49m[38;5;10m+     822[0m:[38;5;10m[49m         next_states=np.array(all_next_states),
[0m[49m[38;5;10m+     823[0m:[38;5;10m[49m         dones=np.array(all_dones),
[0m[49m[38;5;10m+     824[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     825[0m:[38;5;10m[49m     buffer.seek(0)
[0m[49m[38;5;10m+     826[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     827[0m:[38;5;10m[49m     key = f"{TRAJECTORY_PREFIX}{experiment_id}/trajectories.npz"
[0m[49m[38;5;10m+     828[0m:[38;5;10m[49m     s3_client.put_object(
[0m[49m[38;5;10m+     829[0m:[38;5;10m[49m         Bucket=S3_BUCKET,
[0m[49m[38;5;10m+     830[0m:[38;5;10m[49m         Key=key,
[0m[49m[38;5;10m+     831[0m:[38;5;10m[49m         Body=buffer.getvalue(),
[0m[49m[38;5;10m+     832[0m:[38;5;10m[49m         ServerSideEncryption="aws:kms",  # PHI requires KMS encryption
[0m[49m[38;5;10m+     833[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     834[0m:[38;5;10m[49m     print(f"Uploaded {len(all_states)} transitions to s3://{S3_BUCKET}/{key}")
[0m[49m[38;5;10m+     835[0m:[38;5;10m[49m     return f"s3://{S3_BUCKET}/{key}"
[0m[49m[38;5;10m+     836[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     837[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     838[0m:[38;5;10m[49m def log_recommendation_to_dynamodb(patient_id: str, recommendation: Dict):
[0m[49m[38;5;10m+     839[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     840[0m:[38;5;10m[49m     Log every recommendation to DynamoDB for audit trail and outcome tracking.
[0m[49m[38;5;10m+     841[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     842[0m:[38;5;10m[49m     Every recommendation the system generates must be logged, regardless of
[0m[49m[38;5;10m+     843[0m:[38;5;10m[49m     whether the clinician follows it. This enables:
[0m[49m[38;5;10m+     844[0m:[38;5;10m[49m     - Regulatory audit (who saw what recommendation, when)
[0m[49m[38;5;10m+     845[0m:[38;5;10m[49m     - Outcome tracking (did following/ignoring recommendations correlate with outcomes?)
[0m[49m[38;5;10m+     846[0m:[38;5;10m[49m     - Model monitoring (is the recommendation distribution shifting over time?)
[0m[49m[38;5;10m+     847[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     848[0m:[38;5;10m[49m     dynamodb = boto3.resource("dynamodb", config=BOTO3_CONFIG)
[0m[49m[38;5;10m+     849[0m:[38;5;10m[49m     table = dynamodb.Table(AUDIT_TABLE)
[0m[49m[38;5;10m+     850[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     851[0m:[38;5;10m[49m     # DynamoDB requires Decimal for numeric types (not float).
[0m[49m[38;5;10m+     852[0m:[38;5;10m[49m     item = {
[0m[49m[38;5;10m+     853[0m:[38;5;10m[49m         "recommendation_id": str(uuid.uuid4()),
[0m[49m[38;5;10m+     854[0m:[38;5;10m[49m         "patient_id": patient_id,
[0m[49m[38;5;10m+     855[0m:[38;5;10m[49m         "timestamp": int(time.time()),
[0m[49m[38;5;10m+     856[0m:[38;5;10m[49m         "recommended_action": recommendation["recommended_action_id"],
[0m[49m[38;5;10m+     857[0m:[38;5;10m[49m         "fluid_recommendation": recommendation["fluid_recommendation"],
[0m[49m[38;5;10m+     858[0m:[38;5;10m[49m         "vasopressor_recommendation": recommendation["vasopressor_recommendation"],
[0m[49m[38;5;10m+     859[0m:[38;5;10m[49m         "confidence": Decimal(str(round(recommendation["confidence"], 4))),
[0m[49m[38;5;10m+     860[0m:[38;5;10m[49m         "safety_constraints_triggered": recommendation["safety_constraints_triggered"],
[0m[49m[38;5;10m+     861[0m:[38;5;10m[49m         "key_drivers": recommendation["key_drivers"],
[0m[49m[38;5;10m+     862[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     863[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     864[0m:[38;5;10m[49m     table.put_item(Item=item)
[0m[49m[38;5;10m+     865[0m:[38;5;10m[49m     # PHI Safety: Never log the raw patient state values to the audit table.
[0m[49m[38;5;10m+     866[0m:[38;5;10m[49m     # Log only the recommendation and metadata.
[0m[49m[38;5;10m+     867[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     868[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     869[0m:[38;5;10m[49m def publish_evaluation_metrics(eval_results: Dict, experiment_id: str):
[0m[49m[38;5;10m+     870[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     871[0m:[38;5;10m[49m     Publish off-policy evaluation metrics to CloudWatch for monitoring.
[0m[49m[38;5;10m+     872[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     873[0m:[38;5;10m[49m     These metrics let you track policy quality over time as you retrain
[0m[49m[38;5;10m+     874[0m:[38;5;10m[49m     with new data. Alert on significant drops in estimated value or
[0m[49m[38;5;10m+     875[0m:[38;5;10m[49m     agreement rate.
[0m[49m[38;5;10m+     876[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     877[0m:[38;5;10m[49m     cloudwatch = boto3.client("cloudwatch", config=BOTO3_CONFIG)
[0m[49m[38;5;10m+     878[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     879[0m:[38;5;10m[49m     metrics = [
[0m[49m[38;5;10m+     880[0m:[38;5;10m[49m         {
[0m[49m[38;5;10m+     881[0m:[38;5;10m[49m             "MetricName": "WISEstimatedValue",
[0m[49m[38;5;10m+     882[0m:[38;5;10m[49m             "Value": eval_results["wis_estimated_value"],
[0m[49m[38;5;10m+     883[0m:[38;5;10m[49m             "Unit": "None",
[0m[49m[38;5;10m+     884[0m:[38;5;10m[49m             "Dimensions": [{"Name": "ExperimentId", "Value": experiment_id}],
[0m[49m[38;5;10m+     885[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+     886[0m:[38;5;10m[49m         {
[0m[49m[38;5;10m+     887[0m:[38;5;10m[49m             "MetricName": "ClinicianAgreementRate",
[0m[49m[38;5;10m+     888[0m:[38;5;10m[49m             "Value": eval_results["agreement_rate"],
[0m[49m[38;5;10m+     889[0m:[38;5;10m[49m             "Unit": "None",
[0m[49m[38;5;10m+     890[0m:[38;5;10m[49m             "Dimensions": [{"Name": "ExperimentId", "Value": experiment_id}],
[0m[49m[38;5;10m+     891[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+     892[0m:[38;5;10m[49m         {
[0m[49m[38;5;10m+     893[0m:[38;5;10m[49m             "MetricName": "EffectiveSampleSize",
[0m[49m[38;5;10m+     894[0m:[38;5;10m[49m             "Value": eval_results["effective_sample_size"],
[0m[49m[38;5;10m+     895[0m:[38;5;10m[49m             "Unit": "Count",
[0m[49m[38;5;10m+     896[0m:[38;5;10m[49m             "Dimensions": [{"Name": "ExperimentId", "Value": experiment_id}],
[0m[49m[38;5;10m+     897[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+     898[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+     899[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     900[0m:[38;5;10m[49m     cloudwatch.put_metric_data(
[0m[49m[38;5;10m+     901[0m:[38;5;10m[49m         Namespace="SepsisRL/PolicyEvaluation",
[0m[49m[38;5;10m+     902[0m:[38;5;10m[49m         MetricData=metrics,
[0m[49m[38;5;10m+     903[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     904[0m:[38;5;10m[49m     print(f"Published {len(metrics)} evaluation metrics to CloudWatch")
[0m[49m[38;5;10m+     905[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     906[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     907[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     908[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     909[0m:[38;5;10m[49m ## Full Pipeline
