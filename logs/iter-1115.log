[0m[49m[38;5;10m+      17[0m:[38;5;10m[49m ## Configuration and Constants
[0m[49m[38;5;10m+      18[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      19[0m:[38;5;10m[49m These define the sepsis MDP (Markov Decision Process) parameters. The action discretization bins, state features, and reward structure are all clinical decisions that should be made with intensivists, not by an engineer alone. The values here follow the standard formulation from Komorowski et al. (2018) and subsequent literature.
[0m[49m[38;5;10m+      20[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      21[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+      22[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+      23[0m:[38;5;10m[49m import time
[0m[49m[38;5;10m+      24[0m:[38;5;10m[49m import uuid
[0m[49m[38;5;10m+      25[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+      26[0m:[38;5;10m[49m from typing import Dict, List, Optional, Tuple
[0m[49m[38;5;10m+      27[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      28[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+      29[0m:[38;5;10m[49m import numpy as np
[0m[49m[38;5;10m+      30[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+      31[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      32[0m:[38;5;10m[49m # ============================================================================
[0m[49m[38;5;10m+      33[0m:[38;5;10m[49m # MDP CONFIGURATION
[0m[49m[38;5;10m+      34[0m:[38;5;10m[49m # ============================================================================
[0m[49m[38;5;10m+      35[0m:[38;5;10m[49m # These parameters define the sepsis treatment MDP. The action bins are based
[0m[49m[38;5;10m+      36[0m:[38;5;10m[49m # on clinical practice patterns (not arbitrary quantiles). The state features
[0m[49m[38;5;10m+      37[0m:[38;5;10m[49m # are the standard set from the sepsis RL literature. Changing these requires
[0m[49m[38;5;10m+      38[0m:[38;5;10m[49m # retraining the entire policy.
[0m[49m[38;5;10m+      39[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      40[0m:[38;5;10m[49m # Action space: 5 fluid levels x 5 vasopressor levels = 25 discrete actions.
[0m[49m[38;5;10m+      41[0m:[38;5;10m[49m # Each bin boundary represents a clinically meaningful threshold.
[0m[49m[38;5;10m+      42[0m:[38;5;10m[49m FLUID_BINS_ML = [0, 250, 500, 1000, 2000]  # mL per 4-hour window
[0m[49m[38;5;10m+      43[0m:[38;5;10m[49m # 0: no fluids
[0m[49m[38;5;10m+      44[0m:[38;5;10m[49m # 250: minimal maintenance
[0m[49m[38;5;10m+      45[0m:[38;5;10m[49m # 500: moderate resuscitation
[0m[49m[38;5;10m+      46[0m:[38;5;10m[49m # 1000: aggressive resuscitation
[0m[49m[38;5;10m+      47[0m:[38;5;10m[49m # 2000+: very aggressive bolus
[0m[49m[38;5;10m+      48[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      49[0m:[38;5;10m[49m VASOPRESSOR_BINS_MCG = [0.0, 0.08, 0.16, 0.28, 0.45]  # norepinephrine equiv mcg/kg/min
[0m[49m[38;5;10m+      50[0m:[38;5;10m[49m # 0: no vasopressors
[0m[49m[38;5;10m+      51[0m:[38;5;10m[49m # 0.08: low-dose support
[0m[49m[38;5;10m+      52[0m:[38;5;10m[49m # 0.16: moderate support
[0m[49m[38;5;10m+      53[0m:[38;5;10m[49m # 0.28: high-dose support
[0m[49m[38;5;10m+      54[0m:[38;5;10m[49m # 0.45+: maximal support
[0m[49m[38;5;10m+      55[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      56[0m:[38;5;10m[49m NUM_FLUID_LEVELS = 5
[0m[49m[38;5;10m+      57[0m:[38;5;10m[49m NUM_VASO_LEVELS = 5
[0m[49m[38;5;10m+      58[0m:[38;5;10m[49m NUM_ACTIONS = NUM_FLUID_LEVELS * NUM_VASO_LEVELS  # 25
[0m[49m[38;5;10m+      59[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      60[0m:[38;5;10m[49m # State features: the physiological variables we track at each 4-hour time step.
[0m[49m[38;5;10m+      61[0m:[38;5;10m[49m # Order matters because the neural network expects a fixed input shape.
[0m[49m[38;5;10m+      62[0m:[38;5;10m[49m STATE_FEATURES = [
[0m[49m[38;5;10m+      63[0m:[38;5;10m[49m     "heart_rate",
[0m[49m[38;5;10m+      64[0m:[38;5;10m[49m     "mean_arterial_pressure",
[0m[49m[38;5;10m+      65[0m:[38;5;10m[49m     "temperature",
[0m[49m[38;5;10m+      66[0m:[38;5;10m[49m     "respiratory_rate",
[0m[49m[38;5;10m+      67[0m:[38;5;10m[49m     "spo2",
