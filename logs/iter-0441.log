[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m s3_client          = boto3.client("s3",
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m                                   region_name=REGION,
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m                                   config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m dynamodb           = boto3.resource("dynamodb",
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m                                     region_name=REGION,
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m                                     config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m eventbridge_client = boto3.client("events",
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m                                   region_name=REGION,
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m                                   config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m glue_client        = boto3.client("glue",
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m                                   region_name=REGION,
