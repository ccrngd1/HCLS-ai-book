[49m[38;5;10m+    719[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    720[0m:[38;5;10m[49m ## Step 1: Prepare and Shape the Consumption Data
[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m The pipeline starts by collapsing raw consumption transactions into one row per (facility, sku, date), filling in zeros for missing days, joining the SKU master, applying any successor-mapping for renamed SKUs, and attaching calendar features and exogenous signals. This is the unsexy 60% of the work that production teams underestimate. The same step in production lives in a Glue job that reads multi-source consumption (materials management, OR case-cart, pharmacy) from S3 and writes the modeling-ready dataset back to a curated S3 prefix. The demo runs the same logic in-memory on the synthetic dataset.
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    725[0m:[38;5;10m[49m def prepare_consumption_data(consumption_dataset: dict) -> dict:
[0m[49m[38;5;10m+    726[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    727[0m:[38;5;10m[49m     Step 1: produce a per-SKU, per-day consumption table
[0m[49m[38;5;10m+    728[0m:[38;5;10m[49m     with calendar features and the scheduled-cases
[0m[49m[38;5;10m+    729[0m:[38;5;10m[49m     exogenous signal joined in. Returns a dict keyed by
[0m[49m[38;5;10m+    730[0m:[38;5;10m[49m     sku_id with arrays the trainer uses.
[0m[49m[38;5;10m+    731[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    732[0m:[38;5;10m[49m     Production callers run this as an AWS Glue job and
[0m[49m[38;5;10m+    733[0m:[38;5;10m[49m     write the output to a curated S3 prefix; the trainer
[0m[49m[38;5;10m+    734[0m:[38;5;10m[49m     reads the prepared frames back from S3.
[0m[49m[38;5;10m+    735[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    736[0m:[38;5;10m[49m     facility_id      = consumption_dataset["facility_id"]
[0m[49m[38;5;10m+    737[0m:[38;5;10m[49m     dates            = consumption_dataset["dates"]
[0m[49m[38;5;10m+    738[0m:[38;5;10m[49m     consumption      = consumption_dataset["consumption"]
[0m[49m[38;5;10m+    739[0m:[38;5;10m[49m     sku_master       = consumption_dataset["sku_master"]
[0m[49m[38;5;10m+    740[0m:[38;5;10m[49m     scheduled_cases  = dict(consumption_dataset["scheduled_cases"])
[0m[49m[38;5;10m+    741[0m:[38;5;10m[49m     holiday_calendar = set(consumption_dataset["holiday_calendar"])
[0m[49m[38;5;10m+    742[0m:[38;5;10m[49m     sku_master_index = {s["sku_id"]: s for s in sku_master}
[0m[49m[38;5;10m+    743[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    744[0m:[38;5;10m[49m     # Group raw transactions by (sku_id, date). The synthetic
[0m[49m[38;5;10m+    745[0m:[38;5;10m[49m     # data is already at one transaction per day per SKU; real
[0m[49m[38;5;10m+    746[0m:[38;5;10m[49m     # data has multiple transactions per SKU per day that we
[0m[49m[38;5;10m+    747[0m:[38;5;10m[49m     # sum up here.
[0m[49m[38;5;10m+    748[0m:[38;5;10m[49m     grouped = defaultdict(int)
[0m[49m[38;5;10m+    749[0m:[38;5;10m[49m     for row in consumption:
[0m[49m[38;5;10m+    750[0m:[38;5;10m[49m         grouped[(row["sku_id"], row["date"])] += row["quantity"]
[0m[49m[38;5;10m+    751[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    752[0m:[38;5;10m[49m     # Walk every (sku, date) cell so missing days become
[0m[49m[38;5;10m+    753[0m:[38;5;10m[49m     # explicit zeros. Treat absent transactions as zero
[0m[49m[38;5;10m+    754[0m:[38;5;10m[49m     # consumption rather than a gap; the safer default for
[0m[49m[38;5;10m+    755[0m:[38;5;10m[49m     # forecasting is "no consumption recorded" rather than
[0m[49m[38;5;10m+    756[0m:[38;5;10m[49m     # "we don't know."
[0m[49m[38;5;10m+    757[0m:[38;5;10m[49m     prepared = {}
[0m[49m[38;5;10m+    758[0m:[38;5;10m[49m     for sku in sku_master:
[0m[49m[38;5;10m+    759[0m:[38;5;10m[49m         sku_id = sku["sku_id"]
[0m[49m[38;5;10m+    760[0m:[38;5;10m[49m         quantities  = []
[0m[49m[38;5;10m+    761[0m:[38;5;10m[49m         day_of_week = []
[0m[49m[38;5;10m+    762[0m:[38;5;10m[49m         is_holiday  = []
[0m[49m[38;5;10m+    763[0m:[38;5;10m[49m         sched_cases = []
[0m[49m[38;5;10m+    764[0m:[38;5;10m[49m         for d in dates:
[0m[49m[38;5;10m+    765[0m:[38;5;10m[49m             qty = grouped.get((sku_id, d), 0)
[0m[49m[38;5;10m+    766[0m:[38;5;10m[49m             quantities.append(qty)
[0m[49m[38;5;10m+    767[0m:[38;5;10m[49m             day_of_week.append(d.weekday())
[0m[49m[38;5;10m+    768[0m:[38;5;10m[49m             is_holiday.append(d in holiday_calendar)
[0m[49m[38;5;10m+    769[0m:[38;5;10m[49m             sched_cases.append(scheduled_cases.get(d, 0.0))
[0m[49m[38;5;10m+    770[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    771[0m:[38;5;10m[49m         prepared[sku_id] = {
[0m[49m[38;5;10m+    772[0m:[38;5;10m[49m             "facility_id":          facility_id,
[0m[49m[38;5;10m+    773[0m:[38;5;10m[49m             "sku_id":               sku_id,
[0m[49m[38;5;10m+    774[0m:[38;5;10m[49m             "dates":                list(dates),
[0m[49m[38;5;10m+    775[0m:[38;5;10m[49m             "quantities":           np.array(quantities,
[0m[49m[38;5;10m+    776[0m:[38;5;10m[49m                                               dtype=float),
[0m[49m[38;5;10m+    777[0m:[38;5;10m[49m             "day_of_week":          np.array(day_of_week),
[0m[49m[38;5;10m+    778[0m:[38;5;10m[49m             "is_holiday":           np.array(is_holiday,
[0m[49m[38;5;10m+    779[0m:[38;5;10m[49m                                               dtype=bool),
[0m[49m[38;5;10m+    780[0m:[38;5;10m[49m             "scheduled_cases":      np.array(sched_cases,
[0m[49m[38;5;10m+    781[0m:[38;5;10m[49m                                               dtype=float),
[0m[49m[38;5;10m+    782[0m:[38;5;10m[49m             "sku_master":           sku_master_index[sku_id],
[0m[49m[38;5;10m+    783[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    784[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    785[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    786[0m:[38;5;10m[49m         "prepare_consumption_data: %s SKUs, %s days, "
[0m[49m[38;5;10m+    787[0m:[38;5;10m[49m         "facility=%s",
[0m[49m[38;5;10m+    788[0m:[38;5;10m[49m         len(prepared), len(dates), facility_id)
[0m[49m[38;5;10m+    789[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    790[0m:[38;5;10m[49m         "facility_id":      facility_id,
[0m[49m[38;5;10m+    791[0m:[38;5;10m[49m         "dates":            list(dates),
[0m[49m[38;5;10m+    792[0m:[38;5;10m[49m         "prepared_skus":    prepared,
[0m[49m[38;5;10m+    793[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    794[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    795[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    796[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    797[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    798[0m:[38;5;10m[49m ## Step 2: Segment SKUs by Demand Pattern
[0m[49m[38;5;10m+    799[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    800[0m:[38;5;10m[49m Segmentation is the routing primitive that decides which model family fits each SKU. A single Prophet model on every SKU produces nonsense for the long tail of intermittent items; a single Croston model on every SKU under-models the smooth high-volume items. The four-corner classification using ADI and CV² gets you 90% of the way to the right per-SKU routing, with a procedure-driven override flag in the master data for the SKUs whose demand is a near-direct function of case volume.
[0m[49m[38;5;10m+    801[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    802[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    803[0m:[38;5;10m[49m def segment_skus(prepared: dict) -> dict:
[0m[49m[38;5;10m+    804[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    805[0m:[38;5;10m[49m     Step 2: classify each SKU into a segment label using
[0m[49m[38;5;10m+    806[0m:[38;5;10m[49m     the Average Demand Interval (ADI) and the Coefficient
[0m[49m[38;5;10m+    807[0m:[38;5;10m[49m     of Variation Squared on non-zero demand sizes (CV2).
[0m[49m[38;5;10m+    808[0m:[38;5;10m[49m     Returns a dict keyed by sku_id with the segment label
[0m[49m[38;5;10m+    809[0m:[38;5;10m[49m     plus the raw metrics for diagnostics.
[0m[49m[38;5;10m+    810[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    811[0m:[38;5;10m[49m     segments = {}
[0m[49m[38;5;10m+    812[0m:[38;5;10m[49m     for sku_id, frame in prepared["prepared_skus"].items():
[0m[49m[38;5;10m+    813[0m:[38;5;10m[49m         master = frame["sku_master"]
[0m[49m[38;5;10m+    814[0m:[38;5;10m[49m         qty    = frame["quantities"]
[0m[49m[38;5;10m+    815[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    816[0m:[38;5;10m[49m         # Procedure-driven override: SKUs flagged in the
[0m[49m[38;5;10m+    817[0m:[38;5;10m[49m         # master route to the per-case-usage model regardless
[0m[49m[38;5;10m+    818[0m:[38;5;10m[49m         # of the demand-pattern metrics.
[0m[49m[38;5;10m+    819[0m:[38;5;10m[49m         if master.get("is_procedure_driven"):
[0m[49m[38;5;10m+    820[0m:[38;5;10m[49m             segments[sku_id] = {
[0m[49m[38;5;10m+    821[0m:[38;5;10m[49m                 "segment":   SEGMENT_PROCEDURE_DRIVEN,
[0m[49m[38;5;10m+    822[0m:[38;5;10m[49m                 "adi":       None,
[0m[49m[38;5;10m+    823[0m:[38;5;10m[49m                 "cv2":       None,
[0m[49m[38;5;10m+    824[0m:[38;5;10m[49m                 "n_days":    len(qty),
[0m[49m[38;5;10m+    825[0m:[38;5;10m[49m                 "n_nonzero": int(np.sum(qty > 0)),
[0m[49m[38;5;10m+    826[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    827[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    828[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    829[0m:[38;5;10m[49m         n_days     = len(qty)
[0m[49m[38;5;10m+    830[0m:[38;5;10m[49m         non_zero   = qty[qty > 0]
[0m[49m[38;5;10m+    831[0m:[38;5;10m[49m         n_nonzero  = len(non_zero)
[0m[49m[38;5;10m+    832[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    833[0m:[38;5;10m[49m         # SKUs with too little non-zero history are routed to
[0m[49m[38;5;10m+    834[0m:[38;5;10m[49m         # the cold-start segment so the pipeline applies a
[0m[49m[38;5;10m+    835[0m:[38;5;10m[49m         # configured starting par rather than fitting a model
[0m[49m[38;5;10m+    836[0m:[38;5;10m[49m         # on five data points.
[0m[49m[38;5;10m+    837[0m:[38;5;10m[49m         if n_nonzero < 10:
[0m[49m[38;5;10m+    838[0m:[38;5;10m[49m             segments[sku_id] = {
[0m[49m[38;5;10m+    839[0m:[38;5;10m[49m                 "segment":   SEGMENT_NEW_SKU,
[0m[49m[38;5;10m+    840[0m:[38;5;10m[49m                 "adi":       None,
[0m[49m[38;5;10m+    841[0m:[38;5;10m[49m                 "cv2":       None,
[0m[49m[38;5;10m+    842[0m:[38;5;10m[49m                 "n_days":    n_days,
