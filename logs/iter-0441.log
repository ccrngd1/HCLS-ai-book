[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m # --- Resource names ---
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m CONSUMPTION_BUCKET           = "supply-forecast-consumption"
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m MODEL_ARTIFACT_BUCKET        = "supply-forecast-models"
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m FORECAST_OUTPUT_BUCKET       = "supply-forecast-output"
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m SKU_FORECAST_TABLE           = "supply-forecast-current"
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m SKU_FORECAST_HISTORY_TABLE   = "supply-forecast-history"
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m FORECAST_EVENT_BUS_NAME      = "supply-forecast-events"
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m CONSUMPTION_GLUE_JOB_NAME    = "supply-consumption-etl"
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m PIPELINE_STATE_MACHINE_ARN   = "PIPELINE_SM_ARN_PLACEHOLDER"
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m CLOUDWATCH_NAMESPACE         = "SupplyInventoryForecast"
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m # --- Forecasting horizons and operational parameters ---
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m # The recipe targets a 90-day forecast horizon for materials
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m # management. Most operational lead times are days to weeks,
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m # so the lead-time aggregation is shorter than the horizon.
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m FORECAST_HORIZON_DAYS        = 90
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m DEFAULT_LEAD_TIME_DAYS       = 5
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m DEFAULT_SERVICE_LEVEL        = Decimal("0.95")  # 95%
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m DEFAULT_HOLDING_COST_USD     = Decimal("0.50")  # per unit per year
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m DEFAULT_ORDER_COST_USD       = Decimal("25.0")  # per order placed
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m # --- Segmentation thresholds (Syntetos et al. four-corner) ---
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m # Average Demand Interval (ADI): mean gap in days between
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m # non-zero demand days. Coefficient of Variation Squared
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m # (CV2): variance over mean-squared on non-zero demand
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m # sizes. The 1.32 / 0.49 cutoffs are the standard literature
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m # defaults; tune to the facility's data.
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m ADI_INTERMITTENT_THRESHOLD   = 1.32
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m CV2_ERRATIC_THRESHOLD        = 0.49
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m # --- Segment labels ---
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m SEGMENT_SMOOTH               = "smooth"
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m SEGMENT_INTERMITTENT         = "intermittent"
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m SEGMENT_ERRATIC              = "erratic"
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m SEGMENT_LUMPY                = "lumpy"
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m SEGMENT_PROCEDURE_DRIVEN     = "procedure_driven"
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m SEGMENT_NEW_SKU              = "new_sku_cold_start"
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m # --- Per-segment model-selection table ---
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m # Maps each segment to the model family the trainer uses.
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m # Production replaces the demo's hand-rolled models with
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m # Prophet / statsmodels / SageMaker DeepAR; the segment
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m # routing is the architectural primitive.
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m SEGMENT_TO_MODEL = {
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m     SEGMENT_SMOOTH:           "ets_holt_winters",
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m     SEGMENT_INTERMITTENT:     "syntetos_boylan",
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m     SEGMENT_ERRATIC:          "croston",
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m     SEGMENT_LUMPY:            "category_rollup",
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m     SEGMENT_PROCEDURE_DRIVEN: "case_volume_times_usage_rate",
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m     SEGMENT_NEW_SKU:          "fixed_starting_par",
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m # --- Z-score lookup for the safety-stock formula ---
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m # safety_stock = z * sqrt(lead_time_days) * sigma_daily
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m # Production deployments configure per-SKU service-level
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m # targets keyed off clinical importance; the table below
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m # is the operational default.
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m SERVICE_LEVEL_Z_SCORE = {
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m     Decimal("0.80"): Decimal("0.84"),
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m     Decimal("0.90"): Decimal("1.28"),
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m     Decimal("0.95"): Decimal("1.65"),
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m     Decimal("0.97"): Decimal("1.88"),
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m     Decimal("0.99"): Decimal("2.33"),
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m     Decimal("0.995"): Decimal("2.58"),
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m # --- Quality-gate thresholds ---
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m # Reject a newly-trained model if it materially regresses
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m # against the current production model for the same segment.
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m QUALITY_REGRESSION_TOLERANCE = Decimal("1.20")  # +20%
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m # --- Holdout window for backtesting ---
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m HOLDOUT_DAYS                 = 90
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m # --- Forecast-record vocabulary for the operational consumer ---
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m FORECAST_DISPOSITION_OK             = "OK"
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m FORECAST_DISPOSITION_QUALITY_FAILED = "QUALITY_FAILED"
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m FORECAST_DISPOSITION_COLD_START     = "COLD_START_FALLBACK"
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m FORECAST_DISPOSITION_REGIME_BREAK   = "REGIME_BREAK_HOLD"
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m # --- Deploy-time guardrail. Any blank resource name is a
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m #     deploy-time bug, not a runtime surprise. ---
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m for _name, _value in [
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m     ("CONSUMPTION_BUCKET",         CONSUMPTION_BUCKET),
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m     ("MODEL_ARTIFACT_BUCKET",      MODEL_ARTIFACT_BUCKET),
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m     ("FORECAST_OUTPUT_BUCKET",     FORECAST_OUTPUT_BUCKET),
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m     ("SKU_FORECAST_TABLE",         SKU_FORECAST_TABLE),
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m     ("SKU_FORECAST_HISTORY_TABLE", SKU_FORECAST_HISTORY_TABLE),
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m     ("FORECAST_EVENT_BUS_NAME",    FORECAST_EVENT_BUS_NAME),
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m     ("CONSUMPTION_GLUE_JOB_NAME",  CONSUMPTION_GLUE_JOB_NAME),
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m ]:
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m     if not _value:
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m         raise RuntimeError(
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m             f"Resource name {_name} is empty. "
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m             f"Configure deployment-time values.")
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m ## Shared Helpers
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m A few utilities used across the steps. Keeping them together so each step's code stays focused on the pattern it teaches.
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m def _to_decimal(obj):
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m     Recursively convert floats to Decimal for DynamoDB.
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m     DynamoDB rejects Python float values; every numeric
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m     field has to pass through Decimal on the way in.
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m     if isinstance(obj, float):
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m         if math.isnan(obj) or math.isinf(obj):
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m             # DynamoDB also rejects NaN and Inf. Substitute
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m             # zero and let the caller decide whether the
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m             # absence-of-data should be treated as a quality
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m             # failure separately.
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m             return Decimal("0")
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m         return Decimal(str(obj))
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m     if isinstance(obj, np.floating):
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m         return _to_decimal(float(obj))
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m     if isinstance(obj, np.integer):
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m         return int(obj)
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m     if isinstance(obj, dict):
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m         return {k: _to_decimal(v) for k, v in obj.items()}
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m     if isinstance(obj, list):
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m         return [_to_decimal(v) for v in obj]
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m     return obj
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m def _from_decimal(obj):
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m     """Inverse of _to_decimal for JSON serialization."""
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m     if isinstance(obj, Decimal):
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m         if obj % 1 == 0:
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m             return int(obj)
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m         return float(obj)
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m     if isinstance(obj, dict):
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m         return {k: _from_decimal(v) for k, v in obj.items()}
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m     if isinstance(obj, list):
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m         return [_from_decimal(v) for v in obj]
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m     return obj
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m def _now_iso() -> str:
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m     """Current UTC time in ISO-8601 format."""
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m     return datetime.now(timezone.utc).isoformat()
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m def _today() -> date:
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m     """Current UTC date."""
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m     return datetime.now(timezone.utc).date()
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m def _service_level_z(service_level: Decimal) -> Decimal:
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m     """Look up the z-score for a target service level. Falls
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m     back to the closest defined level if the exact value is
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m     not in the table; production deployments either inverse-
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m     normal-CDF compute the z-score directly or maintain a
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m     finer-grained table."""
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m     if service_level in SERVICE_LEVEL_Z_SCORE:
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m         return SERVICE_LEVEL_Z_SCORE[service_level]
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m     closest = min(
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m         SERVICE_LEVEL_Z_SCORE.keys(),
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m         key=lambda s: abs(s - service_level))
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m     return SERVICE_LEVEL_Z_SCORE[closest]
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m def _emit_event(detail_type: str, detail: dict) -> None:
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m     Emit an EventBridge event. Wrapped in try/except so a
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m     transient EventBridge failure does not block the
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m     pipeline. Production downstream consumers use the
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m     suggested idempotency keys (run_id, segment_label,
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m     facility_id+sku_id+forecast_date_from) to deduplicate
