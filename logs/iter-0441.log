[0m[49m[38;5;10m+    1582[0m:[38;5;10m[49m     s3_uri = write_forecast_artifact_to_s3(records, run_id)
[0m[49m[38;5;10m+    1583[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1584[0m:[38;5;10m[49m     # Step 5: deliver to DynamoDB for the materials-management
[0m[49m[38;5;10m+    1585[0m:[38;5;10m[49m     # dashboard and ERP integration.
[0m[49m[38;5;10m+    1586[0m:[38;5;10m[49m     load_counts = load_forecasts_to_dynamodb(records)
