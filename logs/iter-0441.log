[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m     for sku in sku_master:
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m         sku_id = sku["sku_id"]
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m         if sku_id == "GLOVE-NITRILE-MED-100CT":
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m             # Smooth high-volume. Weekly seasonality, mild
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m             # annual seasonality, modest noise.
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m             base = 14.0
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m             weekly = np.array([
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m                 1.10, 1.15, 1.10, 1.05, 1.00, 0.55, 0.40])
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m             annual = (
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m                 1.0 + 0.04 * np.sin(2 * np.pi * day_indices / 365.0))
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m             noise = rng.normal(0.0, 1.2, size=days)
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m             qty = np.maximum(
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m                 0, np.round(base * weekly[day_of_week]
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m                              * annual + noise))
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m         elif sku_id == "ALCOHOL-PREP-PAD-200CT":
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m             # Smooth. Slightly less weekend drop because of
