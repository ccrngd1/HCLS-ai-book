[0m[49m[38;5;10m+    1636[0m:[38;5;10m[49m         cv2 = info["cv2"]
[0m[49m[38;5;10m+    1637[0m:[38;5;10m[49m         adi_text = f"{adi:.2f}" if adi is not None else "n/a"
[0m[49m[38;5;10m+    1638[0m:[38;5;10m[49m         cv2_text = f"{cv2:.2f}" if cv2 is not None else "n/a"
[0m[49m[38;5;10m+    1639[0m:[38;5;10m[49m         print(f"  {sku_id:35s} segment={info['segment']:18s} "
[0m[49m[38;5;10m+    1640[0m:[38;5;10m[49m                f"ADI={adi_text:>5s} CV2={cv2_text:>5s} "
