[0m[49m[38;5;10m+    1474[0m:[38;5;10m[49m     # unprocessed items internally. Production code prefers
[0m[49m[38;5;10m+    1475[0m:[38;5;10m[49m     # this over the low-level batch_write_item because the
[0m[49m[38;5;10m+    1476[0m:[38;5;10m[49m     # resource-level batch_writer handles the
[0m[49m[38;5;10m+    1477[0m:[38;5;10m[49m     # UnprocessedItems loop for you.
[0m[49m[38;5;10m+    1478[0m:[38;5;10m[49m     with current_table.batch_writer() as current_batch, \
[0m[49m[38;5;10m+    1479[0m:[38;5;10m[49m          history_table.batch_writer() as history_batch:
[0m[49m[38;5;10m+    1480[0m:[38;5;10m[49m         for record in records:
[0m[49m[38;5;10m+    1481[0m:[38;5;10m[49m             decimal_record = _to_decimal(record)
[0m[49m[38;5;10m+    1482[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1483[0m:[38;5;10m[49m             # The CURRENT record is what the operational
[0m[49m[38;5;10m+    1484[0m:[38;5;10m[49m             # dashboards query. One per facility_sku_id.
[0m[49m[38;5;10m+    1485[0m:[38;5;10m[49m             current_batch.put_item(Item=decimal_record)
[0m[49m[38;5;10m+    1486[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1487[0m:[38;5;10m[49m             # The HISTORY record is keyed on
[0m[49m[38;5;10m+    1488[0m:[38;5;10m[49m             # (facility_sku_id, generated_at) so prior
[0m[49m[38;5;10m+    1489[0m:[38;5;10m[49m             # forecasts remain queryable for audit and
[0m[49m[38;5;10m+    1490[0m:[38;5;10m[49m             # backtest analysis.
[0m[49m[38;5;10m+    1491[0m:[38;5;10m[49m             history_record = dict(decimal_record)
[0m[49m[38;5;10m+    1492[0m:[38;5;10m[49m             history_table_key = {
[0m[49m[38;5;10m+    1493[0m:[38;5;10m[49m                 "facility_sku_id": history_record["facility_sku_id"],
[0m[49m[38;5;10m+    1494[0m:[38;5;10m[49m                 "generated_at":    history_record["generated_at"],
[0m[49m[38;5;10m+    1495[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    1496[0m:[38;5;10m[49m             history_batch.put_item(Item={
[0m[49m[38;5;10m+    1497[0m:[38;5;10m[49m                 **history_record,
[0m[49m[38;5;10m+    1498[0m:[38;5;10m[49m                 **history_table_key,
[0m[49m[38;5;10m+    1499[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    1500[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1501[0m:[38;5;10m[49m             counts[record["disposition"]] += 1
[0m[49m[38;5;10m+    1502[0m:[38;5;10m[49m             counts["total"] += 1
