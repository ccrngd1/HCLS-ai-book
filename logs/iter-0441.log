[0m[49m[38;5;10m+    1592[0m:[38;5;10m[49m         "records_loaded": load_counts.get("total", 0),
[0m[49m[38;5;10m+    1593[0m:[38;5;10m[49m         "s3_uri":         s3_uri,
[0m[49m[38;5;10m+    1594[0m:[38;5;10m[49m     })
