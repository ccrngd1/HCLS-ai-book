[0m[49m[38;5;10m+    1642[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1643[0m:[38;5;10m[49m     print("\n" + "-" * 64)
[0m[49m[38;5;10m+    1644[0m:[38;5;10m[49m     print("Sample forecast records (one per SKU):")
[0m[49m[38;5;10m+    1645[0m:[38;5;10m[49m     print("-" * 64)
[0m[49m[38;5;10m+    1646[0m:[38;5;10m[49m     for record in result["records"]:
[0m[49m[38;5;10m+    1647[0m:[38;5;10m[49m         print(json.dumps(_from_decimal({
[0m[49m[38;5;10m+    1648[0m:[38;5;10m[49m             "sku_id":              record["sku_id"],
[0m[49m[38;5;10m+    1649[0m:[38;5;10m[49m             "segment":             record["segment"],
[0m[49m[38;5;10m+    1650[0m:[38;5;10m[49m             "mean_demand_horizon": round(
[0m[49m[38;5;10m+    1651[0m:[38;5;10m[49m                 record["mean_demand_horizon"], 1),
[0m[49m[38;5;10m+    1652[0m:[38;5;10m[49m             "lower_bound":         round(
[0m[49m[38;5;10m+    1653[0m:[38;5;10m[49m                 record["lower_bound"], 1),
[0m[49m[38;5;10m+    1654[0m:[38;5;10m[49m             "upper_bound":         round(
[0m[49m[38;5;10m+    1655[0m:[38;5;10m[49m                 record["upper_bound"], 1),
[0m[49m[38;5;10m+    1656[0m:[38;5;10m[49m             "reorder_point":       record["reorder_point"],
[0m[49m[38;5;10m+    1657[0m:[38;5;10m[49m             "order_quantity":      record["order_quantity"],
