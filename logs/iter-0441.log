[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m                 1.0 + 0.02 * np.sin(2 * np.pi * day_indices / 365.0))
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m             noise = rng.normal(0.0, 0.6, size=days)
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m             qty = np.maximum(
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m                 0, np.round(base * weekly[day_of_week]
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m                              * annual + noise))
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m         elif sku_id == "FLU-VAX-DOSE-IM":
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m             # Strong annual seasonality, near-zero off-season,
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m             # spikes in fall.
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m             offset = np.array([
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m                 math.sin(2 * math.pi * (i + 90) / 365.0)
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m                 for i in range(days)])
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m             seasonal = np.maximum(0, offset)
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m             base = 90.0 * seasonal
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m             noise = rng.normal(0.0, 6.0, size=days)
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m             qty = np.maximum(0, np.round(base + noise))
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m         elif sku_id == "ORTHO-STAPLE-CARTRIDGE-MED":
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m             # Procedure-driven. Demand is per-case usage
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m             # times a fraction of scheduled cases that need
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m             # this specific cartridge size.
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m             fraction_using = 0.32
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m             qty = np.round(
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m                 scheduled_cases * fraction_using
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m                 * float(sku["usage_per_case"])
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m                 + rng.normal(0.0, 0.6, size=days))
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m             qty = np.maximum(0, qty)
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m         elif sku_id == "RARE-SURGICAL-KIT-X":
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m             # Intermittent / lumpy. Used on ~5% of weekdays,
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m             # 1-3 units per use.
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m             uses = rng.random(size=days) < 0.04
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m             uses[day_of_week >= 5] = False
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m             qty = np.where(
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m                 uses, rng.integers(1, 4, size=days), 0)
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m         elif sku_id == "CENTRAL-LINE-KIT-A":
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m             # Erratic-to-smooth. Daily usage 0-3 with some
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m             # multi-use spikes.
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m             base_lambda = np.where(day_of_week < 5, 1.6, 0.5)
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m             qty = rng.poisson(lam=base_lambda)
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m             qty = rng.poisson(lam=1.0, size=days)
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m         for d, q in zip(dates, qty):
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m             consumption.append({
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m                 "date":         d,
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m                 "facility_id":  facility_id,
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m                 "sku_id":       sku_id,
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m                 "quantity":     int(q),
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m     # US holiday calendar fragment for the demo. Production
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m     # uses a maintained holiday-calendar library or a per-
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m     # facility configuration that includes local hospital
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m     # closures, scheduled OR shutdowns for system upgrades,
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m     # and similar.
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m     holiday_calendar = [
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m         date(d.year, 1, 1)   for d in dates] + \
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m         [date(d.year, 7, 4)  for d in dates] + \
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m         [date(d.year, 12, 25) for d in dates]
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m     holiday_calendar = sorted(set(holiday_calendar))
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m         "facility_id":      facility_id,
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m         "start_date":       start_date,
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m         "end_date":         dates[-1],
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m         "dates":            dates,
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m         "consumption":      consumption,
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m         "sku_master":       sku_master,
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m         "scheduled_cases":  list(zip(dates, scheduled_cases)),
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m         "holiday_calendar": holiday_calendar,
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m ```
