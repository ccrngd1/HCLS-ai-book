[0m[49m[38;5;10m+    1025[0m:[38;5;10m[49m     for t in range(period, n):
[0m[49m[38;5;10m+    1026[0m:[38;5;10m[49m         s_index = t % period
[0m[49m[38;5;10m+    1027[0m:[38;5;10m[49m         prior_seasonal = seasonal[s_index]
[0m[49m[38;5;10m+    1028[0m:[38;5;10m[49m         new_level = (
[0m[49m[38;5;10m+    1029[0m:[38;5;10m[49m             alpha * (quantities[t] - prior_seasonal)
[0m[49m[38;5;10m+    1030[0m:[38;5;10m[49m             + (1 - alpha) * (level + trend))
[0m[49m[38;5;10m+    1031[0m:[38;5;10m[49m         new_trend = (
[0m[49m[38;5;10m+    1032[0m:[38;5;10m[49m             beta * (new_level - level)
[0m[49m[38;5;10m+    1033[0m:[38;5;10m[49m             + (1 - beta) * trend)
[0m[49m[38;5;10m+    1034[0m:[38;5;10m[49m         new_seasonal = (
[0m[49m[38;5;10m+    1035[0m:[38;5;10m[49m             gamma * (quantities[t] - new_level)
[0m[49m[38;5;10m+    1036[0m:[38;5;10m[49m             + (1 - gamma) * prior_seasonal)
[0m[49m[38;5;10m+    1037[0m:[38;5;10m[49m         level, trend = new_level, new_trend
[0m[49m[38;5;10m+    1038[0m:[38;5;10m[49m         seasonal[s_index] = new_seasonal
[0m[49m[38;5;10m+    1039[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1040[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    1041[0m:[38;5;10m[49m         "type":      "holt_winters",
[0m[49m[38;5;10m+    1042[0m:[38;5;10m[49m         "level":     float(level),
[0m[49m[38;5;10m+    1043[0m:[38;5;10m[49m         "trend":     float(trend),
[0m[49m[38;5;10m+    1044[0m:[38;5;10m[49m         "seasonal":  seasonal.tolist(),
[0m[49m[38;5;10m+    1045[0m:[38;5;10m[49m         "period":    period,
[0m[49m[38;5;10m+    1046[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1047[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1048[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1049[0m:[38;5;10m[49m def _fit_croston(quantities, alpha=0.20):
[0m[49m[38;5;10m+    1050[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1051[0m:[38;5;10m[49m     Croston's method for intermittent demand. Decomposes
[0m[49m[38;5;10m+    1052[0m:[38;5;10m[49m     demand into demand-size when non-zero and inter-arrival
[0m[49m[38;5;10m+    1053[0m:[38;5;10m[49m     time between non-zero demands; smooths each.
[0m[49m[38;5;10m+    1054[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1055[0m:[38;5;10m[49m     n = len(quantities)
[0m[49m[38;5;10m+    1056[0m:[38;5;10m[49m     if n == 0:
[0m[49m[38;5;10m+    1057[0m:[38;5;10m[49m         return {"type": "constant", "value": 0.0}
[0m[49m[38;5;10m+    1058[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1059[0m:[38;5;10m[49m     # Find the indices of non-zero demand.
[0m[49m[38;5;10m+    1060[0m:[38;5;10m[49m     nonzero_indices = np.where(quantities > 0)[0]
[0m[49m[38;5;10m+    1061[0m:[38;5;10m[49m     if len(nonzero_indices) == 0:
[0m[49m[38;5;10m+    1062[0m:[38;5;10m[49m         return {"type": "constant", "value": 0.0}
[0m[49m[38;5;10m+    1063[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1064[0m:[38;5;10m[49m     # Initial size and interval estimates.
[0m[49m[38;5;10m+    1065[0m:[38;5;10m[49m     z = float(quantities[nonzero_indices[0]])  # first non-zero
[0m[49m[38;5;10m+    1066[0m:[38;5;10m[49m     p = float(nonzero_indices[0]) + 1.0         # interval
[0m[49m[38;5;10m+    1067[0m:[38;5;10m[49m     last_nonzero_t = nonzero_indices[0]
[0m[49m[38;5;10m+    1068[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1069[0m:[38;5;10m[49m     for i, t in enumerate(nonzero_indices[1:], start=1):
[0m[49m[38;5;10m+    1070[0m:[38;5;10m[49m         interval = float(t - last_nonzero_t)
[0m[49m[38;5;10m+    1071[0m:[38;5;10m[49m         z = alpha * float(quantities[t]) + (1 - alpha) * z
[0m[49m[38;5;10m+    1072[0m:[38;5;10m[49m         p = alpha * interval + (1 - alpha) * p
[0m[49m[38;5;10m+    1073[0m:[38;5;10m[49m         last_nonzero_t = t
[0m[49m[38;5;10m+    1074[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1075[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    1076[0m:[38;5;10m[49m         "type":         "croston",
[0m[49m[38;5;10m+    1077[0m:[38;5;10m[49m         "demand_size":  z,
[0m[49m[38;5;10m+    1078[0m:[38;5;10m[49m         "interval":     p,
[0m[49m[38;5;10m+    1079[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1080[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1081[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1082[0m:[38;5;10m[49m def _fit_syntetos_boylan(quantities, alpha=0.20):
[0m[49m[38;5;10m+    1083[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1084[0m:[38;5;10m[49m     Syntetos-Boylan approximation. Same structure as
[0m[49m[38;5;10m+    1085[0m:[38;5;10m[49m     Croston but with a bias-correction factor of
[0m[49m[38;5;10m+    1086[0m:[38;5;10m[49m     (1 - alpha / 2) applied to the demand-rate estimate.
[0m[49m[38;5;10m+    1087[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1088[0m:[38;5;10m[49m     croston = _fit_croston(quantities, alpha=alpha)
[0m[49m[38;5;10m+    1089[0m:[38;5;10m[49m     if croston["type"] != "croston":
[0m[49m[38;5;10m+    1090[0m:[38;5;10m[49m         return croston
[0m[49m[38;5;10m+    1091[0m:[38;5;10m[49m     correction = (1.0 - alpha / 2.0)
[0m[49m[38;5;10m+    1092[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    1093[0m:[38;5;10m[49m         "type":         "syntetos_boylan",
[0m[49m[38;5;10m+    1094[0m:[38;5;10m[49m         "demand_size":  croston["demand_size"],
[0m[49m[38;5;10m+    1095[0m:[38;5;10m[49m         "interval":     croston["interval"],
[0m[49m[38;5;10m+    1096[0m:[38;5;10m[49m         "correction":   correction,
[0m[49m[38;5;10m+    1097[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1098[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1099[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1100[0m:[38;5;10m[49m def _fit_simple_average(quantities, window=28):
[0m[49m[38;5;10m+    1101[0m:[38;5;10m[49m     """Fallback for the lumpy segment. Production uses a
[0m[49m[38;5;10m+    1102[0m:[38;5;10m[49m     hierarchical-reconciliation rollup; the demo applies a
[0m[49m[38;5;10m+    1103[0m:[38;5;10m[49m     trailing-average smoother and surfaces a wider
[0m[49m[38;5;10m+    1104[0m:[38;5;10m[49m     prediction interval."""
[0m[49m[38;5;10m+    1105[0m:[38;5;10m[49m     n = len(quantities)
[0m[49m[38;5;10m+    1106[0m:[38;5;10m[49m     if n == 0:
[0m[49m[38;5;10m+    1107[0m:[38;5;10m[49m         return {"type": "constant", "value": 0.0}
[0m[49m[38;5;10m+    1108[0m:[38;5;10m[49m     tail = quantities[-min(window, n):]
[0m[49m[38;5;10m+    1109[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    1110[0m:[38;5;10m[49m         "type":  "trailing_mean",
[0m[49m[38;5;10m+    1111[0m:[38;5;10m[49m         "value": float(np.mean(tail)),
[0m[49m[38;5;10m+    1112[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1113[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1114[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1115[0m:[38;5;10m[49m def _fit_procedure_driven(quantities, scheduled_cases, master):
[0m[49m[38;5;10m+    1116[0m:[38;5;10m[49m     """Two-stage model: estimate per-case usage rate from
[0m[49m[38;5;10m+    1117[0m:[38;5;10m[49m     the training window, then forecast = case_forecast *
[0m[49m[38;5;10m+    1118[0m:[38;5;10m[49m     usage_rate."""
[0m[49m[38;5;10m+    1119[0m:[38;5;10m[49m     cases_total = float(np.sum(scheduled_cases))
[0m[49m[38;5;10m+    1120[0m:[38;5;10m[49m     qty_total   = float(np.sum(quantities))
[0m[49m[38;5;10m+    1121[0m:[38;5;10m[49m     if cases_total > 0:
[0m[49m[38;5;10m+    1122[0m:[38;5;10m[49m         usage_rate = qty_total / cases_total
[0m[49m[38;5;10m+    1123[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    1124[0m:[38;5;10m[49m         # Fall back to the master's documented per-case
[0m[49m[38;5;10m+    1125[0m:[38;5;10m[49m         # usage if scheduled-cases is sparse.
[0m[49m[38;5;10m+    1126[0m:[38;5;10m[49m         usage_rate = float(master.get("usage_per_case", 1.0))
[0m[49m[38;5;10m+    1127[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    1128[0m:[38;5;10m[49m         "type":               "procedure_driven",
[0m[49m[38;5;10m+    1129[0m:[38;5;10m[49m         "usage_rate_per_case": usage_rate,
[0m[49m[38;5;10m+    1130[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1131[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1132[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1133[0m:[38;5;10m[49m def _fit_cold_start_par(quantities, master):
[0m[49m[38;5;10m+    1134[0m:[38;5;10m[49m     """Configured starting par for new SKUs. Production
[0m[49m[38;5;10m+    1135[0m:[38;5;10m[49m     options also include borrowing demand from the
[0m[49m[38;5;10m+    1136[0m:[38;5;10m[49m     predecessor SKU via the master successor map or from
[0m[49m[38;5;10m+    1137[0m:[38;5;10m[49m     a similar SKU via item-category clustering."""
[0m[49m[38;5;10m+    1138[0m:[38;5;10m[49m     if len(quantities) == 0:
[0m[49m[38;5;10m+    1139[0m:[38;5;10m[49m         starting = 1.0
[0m[49m[38;5;10m+    1140[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    1141[0m:[38;5;10m[49m         starting = float(np.mean(quantities)) if \
[0m[49m[38;5;10m+    1142[0m:[38;5;10m[49m             np.mean(quantities) > 0 else 1.0
[0m[49m[38;5;10m+    1143[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    1144[0m:[38;5;10m[49m         "type":        "cold_start_par",
[0m[49m[38;5;10m+    1145[0m:[38;5;10m[49m         "daily_value": starting,
[0m[49m[38;5;10m+    1146[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1147[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1148[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1149[0m:[38;5;10m[49m def model_predict(model, horizon: int,
[0m[49m[38;5;10m+    1150[0m:[38;5;10m[49m                    day_of_week=None,
[0m[49m[38;5;10m+    1151[0m:[38;5;10m[49m                    scheduled_cases=None) -> tuple:
[0m[49m[38;5;10m+    1152[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1153[0m:[38;5;10m[49m     Produce a horizon-length point forecast plus a per-day
[0m[49m[38;5;10m+    1154[0m:[38;5;10m[49m     standard-deviation estimate. Returns (point_array,
[0m[49m[38;5;10m+    1155[0m:[38;5;10m[49m     sigma_per_day).
[0m[49m[38;5;10m+    1156[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1157[0m:[38;5;10m[49m     mtype = model["type"]
[0m[49m[38;5;10m+    1158[0m:[38;5;10m[49m     if mtype == "holt_winters":
[0m[49m[38;5;10m+    1159[0m:[38;5;10m[49m         level     = model["level"]
[0m[49m[38;5;10m+    1160[0m:[38;5;10m[49m         trend     = model["trend"]
[0m[49m[38;5;10m+    1161[0m:[38;5;10m[49m         seasonal  = np.array(model["seasonal"])
[0m[49m[38;5;10m+    1162[0m:[38;5;10m[49m         period    = model["period"]
[0m[49m[38;5;10m+    1163[0m:[38;5;10m[49m         forecast  = np.array([
[0m[49m[38;5;10m+    1164[0m:[38;5;10m[49m             max(0.0,
[0m[49m[38;5;10m+    1165[0m:[38;5;10m[49m                 level + (h + 1) * trend
[0m[49m[38;5;10m+    1166[0m:[38;5;10m[49m                 + seasonal[(day_of_week[h] if day_of_week
[0m[49m[38;5;10m+    1167[0m:[38;5;10m[49m                               is not None else h) % period])
[0m[49m[38;5;10m+    1168[0m:[38;5;10m[49m             for h in range(horizon)
[0m[49m[38;5;10m+    1169[0m:[38;5;10m[49m         ])
[0m[49m[38;5;10m+    1170[0m:[38;5;10m[49m         # Demo-grade sigma proxy: the absolute trend plus a
[0m[49m[38;5;10m+    1171[0m:[38;5;10m[49m         # fraction of the level. Production uses the
[0m[49m[38;5;10m+    1172[0m:[38;5;10m[49m         # backtest residual sigma directly.
[0m[49m[38;5;10m+    1173[0m:[38;5;10m[49m         sigma_per_day = float(
[0m[49m[38;5;10m+    1174[0m:[38;5;10m[49m             max(1.0, 0.10 * level + 1.5 * abs(trend)))
[0m[49m[38;5;10m+    1175[0m:[38;5;10m[49m         return forecast, sigma_per_day
[0m[49m[38;5;10m+    1176[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1177[0m:[38;5;10m[49m     if mtype in ("croston", "syntetos_boylan"):
[0m[49m[38;5;10m+    1178[0m:[38;5;10m[49m         z = model["demand_size"]
[0m[49m[38;5;10m+    1179[0m:[38;5;10m[49m         p = model["interval"]
[0m[49m[38;5;10m+    1180[0m:[38;5;10m[49m         rate = (z / p) if p > 0 else 0.0
[0m[49m[38;5;10m+    1181[0m:[38;5;10m[49m         if mtype == "syntetos_boylan":
[0m[49m[38;5;10m+    1182[0m:[38;5;10m[49m             rate = rate * model["correction"]
[0m[49m[38;5;10m+    1183[0m:[38;5;10m[49m         forecast = np.full(horizon, max(0.0, rate))
[0m[49m[38;5;10m+    1184[0m:[38;5;10m[49m         # Sigma proxy for intermittent series: scale with
[0m[49m[38;5;10m+    1185[0m:[38;5;10m[49m         # the demand-size variance approximation.
[0m[49m[38;5;10m+    1186[0m:[38;5;10m[49m         sigma_per_day = float(max(1.0, z * math.sqrt(p)))
[0m[49m[38;5;10m+    1187[0m:[38;5;10m[49m         return forecast, sigma_per_day
[0m[49m[38;5;10m+    1188[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1189[0m:[38;5;10m[49m     if mtype == "trailing_mean":
[0m[49m[38;5;10m+    1190[0m:[38;5;10m[49m         v = model["value"]
[0m[49m[38;5;10m+    1191[0m:[38;5;10m[49m         forecast = np.full(horizon, max(0.0, v))
[0m[49m[38;5;10m+    1192[0m:[38;5;10m[49m         sigma_per_day = float(max(1.0, 0.5 * v + 1.0))
[0m[49m[38;5;10m+    1193[0m:[38;5;10m[49m         return forecast, sigma_per_day
[0m[49m[38;5;10m+    1194[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1195[0m:[38;5;10m[49m     if mtype == "procedure_driven":
[0m[49m[38;5;10m+    1196[0m:[38;5;10m[49m         rate = model["usage_rate_per_case"]
[0m[49m[38;5;10m+    1197[0m:[38;5;10m[49m         if scheduled_cases is None or \
[0m[49m[38;5;10m+    1198[0m:[38;5;10m[49m                 len(scheduled_cases) < horizon:
[0m[49m[38;5;10m+    1199[0m:[38;5;10m[49m             cases = np.zeros(horizon)
[0m[49m[38;5;10m+    1200[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    1201[0m:[38;5;10m[49m             cases = np.asarray(scheduled_cases[:horizon],
[0m[49m[38;5;10m+    1202[0m:[38;5;10m[49m                                 dtype=float)
[0m[49m[38;5;10m+    1203[0m:[38;5;10m[49m         forecast = np.maximum(0.0, cases * rate)
[0m[49m[38;5;10m+    1204[0m:[38;5;10m[49m         sigma_per_day = float(max(1.0,
[0m[49m[38;5;10m+    1205[0m:[38;5;10m[49m                                     0.30 * float(np.mean(forecast))
[0m[49m[38;5;10m+    1206[0m:[38;5;10m[49m                                     + 1.0))
[0m[49m[38;5;10m+    1207[0m:[38;5;10m[49m         return forecast, sigma_per_day
[0m[49m[38;5;10m+    1208[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1209[0m:[38;5;10m[49m     if mtype == "cold_start_par":
[0m[49m[38;5;10m+    1210[0m:[38;5;10m[49m         v = model["daily_value"]
[0m[49m[38;5;10m+    1211[0m:[38;5;10m[49m         forecast = np.full(horizon, max(0.0, v))
[0m[49m[38;5;10m+    1212[0m:[38;5;10m[49m         sigma_per_day = float(max(1.0, 1.0 * v + 1.0))
[0m[49m[38;5;10m+    1213[0m:[38;5;10m[49m         return forecast, sigma_per_day
[0m[49m[38;5;10m+    1214[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1215[0m:[38;5;10m[49m     if mtype == "constant":
[0m[49m[38;5;10m+    1216[0m:[38;5;10m[49m         v = float(model["value"])
