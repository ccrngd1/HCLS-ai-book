[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m     retries={"max_attempts": 5, "mode": "adaptive"})
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m 
