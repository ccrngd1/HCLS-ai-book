[0m[49m[38;5;9m- 265     [0m:[38;5;9m[49m     years=[2022, 2023, 2024, 2025]
[0m[49m[38;5;9m- 266     [0m:[38;5;9m[49m )
[0m[49m[38;5;9m- 267     [0m:[38;5;9m[49m 
