[0m[49m[38;5;10m+      222[0m:[38;5;10m[49m FUNCTION build_demand_zones(patient_origin_data, demographic_projections, service_lines):
[0m[49m[38;5;10m+      223[0m:[38;5;10m[49m     // Define geographic demand zones from patient origin patterns.
[0m[49m[38;5;10m+      224[0m:[38;5;10m[49m     // Each zone represents a geographic area with estimable demand.
[0m[49m[38;5;10m+      225[0m:[38;5;10m[49m     // Typically ZIP codes or census tracts, depending on data granularity.
[0m[49m[38;5;10m+      226[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      227[0m:[38;5;10m[49m     zones = extract unique geographic units from patient_origin_data
[0m[49m[38;5;10m+      228[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      229[0m:[38;5;10m[49m     // For each zone, calculate current demand by service line.
[0m[49m[38;5;10m+      230[0m:[38;5;10m[49m     // "Demand" here means total utilization (your patients + competitor patients).
[0m[49m[38;5;10m+      231[0m:[38;5;10m[49m     // Your patient origin data shows YOUR volume; you need market share estimates
[0m[49m[38;5;10m+      232[0m:[38;5;10m[49m     // to infer total market demand.
[0m[49m[38;5;10m+      233[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      234[0m:[38;5;10m[49m     FOR each zone in zones:
[0m[49m[38;5;10m+      235[0m:[38;5;10m[49m         FOR each service_line in service_lines:
[0m[49m[38;5;10m+      236[0m:[38;5;10m[49m             // Current volume from your system
[0m[49m[38;5;10m+      237[0m:[38;5;10m[49m             your_volume = count patients from zone using service_line
[0m[49m[38;5;10m+      238[0m:[38;5;10m[49m             
[0m[49m[38;5;10m+      239[0m:[38;5;10m[49m             // Estimate total market demand using market share
[0m[49m[38;5;10m+      240[0m:[38;5;10m[49m             // Market share comes from claims data or state discharge databases
[0m[49m[38;5;10m+      241[0m:[38;5;10m[49m             estimated_market_share = lookup market share for zone, service_line
[0m[49m[38;5;10m+      242[0m:[38;5;10m[49m             total_demand_current = your_volume / estimated_market_share
[0m[49m[38;5;10m+      243[0m:[38;5;10m[49m             
[0m[49m[38;5;10m+      244[0m:[38;5;10m[49m             // Project forward using demographic growth rates
[0m[49m[38;5;10m+      245[0m:[38;5;10m[49m             // Different service lines grow at different rates
[0m[49m[38;5;10m+      246[0m:[38;5;10m[49m             // (e.g., joint replacement grows faster in aging populations)
[0m[49m[38;5;10m+      247[0m:[38;5;10m[49m             growth_rate = lookup growth rate for zone, service_line from demographic_projections
[0m[49m[38;5;10m+      248[0m:[38;5;10m[49m             
[0m[49m[38;5;10m+      249[0m:[38;5;10m[49m             FOR each year in planning_horizon:
[0m[49m[38;5;10m+      250[0m:[38;5;10m[49m                 projected_demand[zone][service_line][year] = 
[0m[49m[38;5;10m+      251[0m:[38;5;10m[49m                     total_demand_current * (1 + growth_rate) ^ year
[0m[49m[38;5;10m+      252[0m:[38;5;10m[49m     
