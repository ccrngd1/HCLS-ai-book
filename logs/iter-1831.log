[38;5;141m> [0mNow fix L29 (A2 - HIGH): Add distribution shift detection mechanism. I'll add this after the off-policy evaluation section (Step 5), before Step 6:[0m[0m
I'll modify the following file: [38;5;141mchapter15.04-architecture.md[0m[38;5;244m (using tool: write)[0m

[49m[38;5;9m- 384     [0m:[38;5;9m[49m **Step 6: Clinical decision support interface.**
[0m[49m[38;5;10m+      384[0m:[38;5;10m[49m **Step 5b: Distribution shift detection.** The policy was trained on historical data. At inference time, you will encounter patient states the training data never covered. Blindly serving recommendations for out-of-distribution (OOD) states is dangerous. You need a mechanism to detect when a patient's state is far from anything the model trained on, suppress low-confidence recommendations, and alert operators when OOD rates climb.
[0m[49m[38;5;10m+      385[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      386[0m:[38;5;10m[49m The approach: during training, compute the mean and covariance of the state feature vectors across all training transitions. At inference time, compute the Mahalanobis distance between the incoming state and the training distribution. States with high Mahalanobis distance are OOD. The threshold can be calibrated on the training set (e.g., 99th percentile of training distances).
[0m[49m[38;5;10m+      387[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      388[0m:[38;5;10m[49m ```pseudocode
[0m[49m[38;5;10m+      389[0m:[38;5;10m[49m FUNCTION compute_training_distribution(all_training_states):
[0m[49m[38;5;10m+      390[0m:[38;5;10m[49m     // Compute multivariate statistics from training data.
[0m[49m[38;5;10m+      391[0m:[38;5;10m[49m     // These are stored alongside the model artifact for use at inference time.
[0m[49m[38;5;10m+      392[0m:[38;5;10m[49m     mean_vector = mean(all_training_states, axis=0)        // shape: (state_dim,)
[0m[49m[38;5;10m+      393[0m:[38;5;10m[49m     covariance_matrix = covariance(all_training_states)    // shape: (state_dim, state_dim)
[0m[49m[38;5;10m+      394[0m:[38;5;10m[49m     // Regularize covariance to ensure invertibility (add small diagonal).
[0m[49m[38;5;10m+      395[0m:[38;5;10m[49m     covariance_matrix += 1e-6 * identity_matrix(state_dim)
[0m[49m[38;5;10m+      396[0m:[38;5;10m[49m     inverse_covariance = invert(covariance_matrix)
[0m[49m[38;5;10m+      397[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      398[0m:[38;5;10m[49m     // Compute Mahalanobis distances for all training states to set threshold.
[0m[49m[38;5;10m+      399[0m:[38;5;10m[49m     training_distances = []
[0m[49m[38;5;10m+      400[0m:[38;5;10m[49m     FOR each state in all_training_states:
[0m[49m[38;5;10m+      401[0m:[38;5;10m[49m         diff = state - mean_vector
[0m[49m[38;5;10m+      402[0m:[38;5;10m[49m         distance = sqrt(diff^T @ inverse_covariance @ diff)
[0m[49m[38;5;10m+      403[0m:[38;5;10m[49m         training_distances.append(distance)
[0m[49m[38;5;10m+      404[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      405[0m:[38;5;10m[49m     // Use 99th percentile as OOD threshold.
[0m[49m[38;5;10m+      406[0m:[38;5;10m[49m     ood_threshold = percentile(training_distances, 99)
[0m[49m[38;5;10m+      407[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      408[0m:[38;5;10m[49m     RETURN {mean_vector, inverse_covariance, ood_threshold}
[0m[49m[38;5;10m+      409[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      410[0m:[38;5;10m[49m FUNCTION check_distribution_shift(state, distribution_stats):
[0m[49m[38;5;10m+      411[0m:[38;5;10m[49m     diff = state - distribution_stats.mean_vector
[0m[49m[38;5;10m+      412[0m:[38;5;10m[49m     mahalanobis_distance = sqrt(diff^T @ distribution_stats.inverse_covariance @ diff)
[0m[49m[38;5;10m+      413[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      414[0m:[38;5;10m[49m     is_ood = (mahalanobis_distance > distribution_stats.ood_threshold)
[0m[49m[38;5;10m+      415[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      416[0m:[38;5;10m[49m     // Publish OOD metrics to CloudWatch.
[0m[49m[38;5;10m+      417[0m:[38;5;10m[49m     publish_metric("SepsisRL/DistributionShift", "MahalanobisDistance", mahalanobis_distance)
[0m[49m[38;5;10m+      418[0m:[38;5;10m[49m     publish_metric("SepsisRL/DistributionShift", "OODFlag", 1 if is_ood else 0)
[0m[49m[38;5;10m+      419[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      420[0m:[38;5;10m[49m     IF is_ood:
[0m[49m[38;5;10m+      421[0m:[38;5;10m[49m         // Suppress recommendation confidence. Don't remove it entirely
[0m[49m[38;5;10m+      422[0m:[38;5;10m[49m         // (clinician may still find it informative), but flag clearly.
[0m[49m[38;5;10m+      423[0m:[38;5;10m[49m         RETURN {
[0m[49m[38;5;10m+      424[0m:[38;5;10m[49m             "ood_detected": true,
[0m[49m[38;5;10m+      425[0m:[38;5;10m[49m             "mahalanobis_distance": mahalanobis_distance,
[0m[49m[38;5;10m+      426[0m:[38;5;10m[49m             "suppress_confidence": true,
[0m[49m[38;5;10m+      427[0m:[38;5;10m[49m             "warning": "Patient state is outside the training distribution. Recommendation confidence is low."
[0m[49m[38;5;10m+      428[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+      429[0m:[38;5;10m[49m     ELSE:
[0m[49m[38;5;10m+      430[0m:[38;5;10m[49m         RETURN {"ood_detected": false, "mahalanobis_distance": mahalanobis_distance}
[0m[49m[38;5;10m+      431[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      432[0m:[38;5;10m[49m // CloudWatch Alarm: track rolling OOD percentage.
[0m[49m[38;5;10m+      433[0m:[38;5;10m[49m // If >5% of recommendations in a 24-hour window are OOD, alert the team.
[0m[49m[38;5;10m+      434[0m:[38;5;10m[49m // Rising OOD rates indicate population drift or a data pipeline issue.
[0m[49m[38;5;10m+      435[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+      436[0m:[38;5;10m[49m 
