[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m     # Persist the snapshot to S3 partitioned by date and hour so
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m     # the inference Step Functions execution and any downstream
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m     # backtest jobs can read it without paying the FHIR-search
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m     # cost a second time.
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m     s3_key = (f"snapshots/year={snapshot_ts.year:04d}/"
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m               f"month={snapshot_ts.month:02d}/"
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m               f"day={snapshot_ts.day:02d}/"
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m               f"hour={snapshot_ts.hour:02d}/"
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m               f"snapshot-{uuid.uuid4().hex[:8]}.json")
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m     s3.put_object(Bucket=bucket, Key=s3_key,
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m                   Body=json.dumps(state_records, default=str))
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m         "Snapshotted %d active encounters across %d units",
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m         len(state_records),
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m         len({r["current_unit"] for r in state_records}))
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m     return state_records
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m def current_census_by_unit(state_records):
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m     """Count occupants per unit at snapshot time."""
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m     by_unit = defaultdict(int)
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m     for r in state_records:
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m         by_unit[r["current_unit"]] += 1
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m     return dict(by_unit)
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m ## Step 2: Forecast Inflows by Source, Service, and Unit
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m For each forecast hour and each candidate admit unit, the pipeline produces an expected admission count plus a sample distribution suitable for Monte Carlo composition. Different sources use different methods: ED-driven and direct admits run through a Poisson model, the OR schedule is read deterministically and multiplied by show-rate, the transfer queue contributes a near-term known quantity plus a Poisson tail. Unit assignment runs through a multinomial classifier given the admission's source.
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m class PoissonInflowModel:
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m     """Pedagogical Poisson sampler for hourly admission counts.
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m     Production fits a real Poisson regression (statsmodels GLM
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m     with the Poisson family) on calendar features (hour of day,
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m     day of week, month), weather features, and current-state
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m     features (ED census, ED holds), then samples from the fitted
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m     rate per hour. The demo uses a static rate per source, with
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m     a small day-of-week multiplier so Mondays look busier than
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m     Sundays.
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m     name = "poisson_inflow"
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m     def __init__(self, hourly_rate, day_of_week_multipliers=None):
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m         self.hourly_rate = hourly_rate
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m         self.day_of_week_multipliers = day_of_week_multipliers or {}
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m     def sample_count(self, target_ts, rng):
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m         """Sample one admission count for one hour."""
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m         dow = target_ts.weekday()    # 0 = Monday
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m         multiplier = self.day_of_week_multipliers.get(dow, 1.0)
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m         rate = self.hourly_rate * multiplier
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m         # Poisson sampling via the Knuth algorithm; production uses
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m         # numpy.random.Generator.poisson which is faster and more
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m         # correct for large rates.
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m         l = math.exp(-rate)
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m         k = 0
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m         p = 1.0
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m         while True:
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m             k += 1
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m             p *= rng.random()
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m             if p <= l:
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m                 return k - 1
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m class MultinomialUnitAssigner:
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m     """Pedagogical multinomial unit-assignment classifier.
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m     Production fits a real multinomial classifier (scikit-learn
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m     LogisticRegression(multi_class='multinomial') or SageMaker
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m     XGBoost) on admission features (chief complaint, diagnosis,
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m     service line, ED disposition). The demo encodes a static
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m     probability table per source.
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m     name = "unit_assigner"
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m     def __init__(self, probability_table):
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m         self.probability_table = probability_table
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m     def sample_unit(self, admission_source, rng):
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m         probs = self.probability_table.get(admission_source, {})
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m         if not probs:
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m             return None
[0m[49m[38;5;10m+    717[0m:[38;5;10m[49m         units = list(probs.keys())
[0m[49m[38;5;10m+    718[0m:[38;5;10m[49m         weights = [probs[u] for u in units]
[0m[49m[38;5;10m+    719[0m:[38;5;10m[49m         return rng.choices(units, weights=weights, k=1)[0]
[0m[49m[38;5;10m+    720[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m def forecast_inflows(snapshot_ts, horizon_hours, n_samples,
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m                      or_schedule, transfer_queue, ed_board,
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m                      inflow_models, unit_assigner,
[0m[49m[38;5;10m+    725[0m:[38;5;10m[49m                      s3, bucket, run_id, rng_seed=SYNTHETIC_RANDOM_SEED):
[0m[49m[38;5;10m+    726[0m:[38;5;10m[49m     """Step 2: Sample per-source admission counts, assign to units.
[0m[49m[38;5;10m+    727[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    728[0m:[38;5;10m[49m     See pseudocode Step 2 in the main recipe. Returns a 3-D array
[0m[49m[38;5;10m+    729[0m:[38;5;10m[49m     shaped [n_samples, horizon_hours, n_units] of admission counts.
[0m[49m[38;5;10m+    730[0m:[38;5;10m[49m     Index ordering uses sorted unit codes so the composition step
[0m[49m[38;5;10m+    731[0m:[38;5;10m[49m     can join cleanly.
[0m[49m[38;5;10m+    732[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    733[0m:[38;5;10m[49m     rng = random.Random(rng_seed)
[0m[49m[38;5;10m+    734[0m:[38;5;10m[49m     unit_codes = sorted(UNIT_CATALOG.keys())
[0m[49m[38;5;10m+    735[0m:[38;5;10m[49m     unit_index = {u: i for i, u in enumerate(unit_codes)}
[0m[49m[38;5;10m+    736[0m:[38;5;10m[49m     n_units = len(unit_codes)
[0m[49m[38;5;10m+    737[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    738[0m:[38;5;10m[49m     # 3-D grid of admission counts.
[0m[49m[38;5;10m+    739[0m:[38;5;10m[49m     inflow_samples = [
[0m[49m[38;5;10m+    740[0m:[38;5;10m[49m         [[0 for _ in range(n_units)] for _ in range(horizon_hours)]
[0m[49m[38;5;10m+    741[0m:[38;5;10m[49m         for _ in range(n_samples)
[0m[49m[38;5;10m+    742[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    743[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    744[0m:[38;5;10m[49m     # 2a. ED-driven and direct admits: Poisson per source, then
[0m[49m[38;5;10m+    745[0m:[38;5;10m[49m     # sample the unit assignment from the per-source classifier.
[0m[49m[38;5;10m+    746[0m:[38;5;10m[49m     poisson_sources = ["ed_admit", "direct_admit", "transfer_in"]
[0m[49m[38;5;10m+    747[0m:[38;5;10m[49m     for sample_id in range(n_samples):
[0m[49m[38;5;10m+    748[0m:[38;5;10m[49m         for hour_offset in range(horizon_hours):
[0m[49m[38;5;10m+    749[0m:[38;5;10m[49m             target_ts = snapshot_ts + timedelta(hours=hour_offset)
[0m[49m[38;5;10m+    750[0m:[38;5;10m[49m             for source in poisson_sources:
[0m[49m[38;5;10m+    751[0m:[38;5;10m[49m                 count = inflow_models[source].sample_count(target_ts, rng)
[0m[49m[38;5;10m+    752[0m:[38;5;10m[49m                 for _ in range(count):
[0m[49m[38;5;10m+    753[0m:[38;5;10m[49m                     unit_code = unit_assigner.sample_unit(source, rng)
[0m[49m[38;5;10m+    754[0m:[38;5;10m[49m                     if unit_code is not None:
[0m[49m[38;5;10m+    755[0m:[38;5;10m[49m                         inflow_samples[sample_id][hour_offset][
[0m[49m[38;5;10m+    756[0m:[38;5;10m[49m                             unit_index[unit_code]] += 1
[0m[49m[38;5;10m+    757[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    758[0m:[38;5;10m[49m     # 2b. ED tracking board: pending admits expected to land in
[0m[49m[38;5;10m+    759[0m:[38;5;10m[49m     # the next 1-3 hours with high probability. Production uses
[0m[49m[38;5;10m+    760[0m:[38;5;10m[49m     # the ED's tracking-board admit-decision timestamps and
[0m[49m[38;5;10m+    761[0m:[38;5;10m[49m     # ED-to-floor latency. The demo treats each board entry as
[0m[49m[38;5;10m+    762[0m:[38;5;10m[49m     # a Bernoulli draw against a fixed probability.
[0m[49m[38;5;10m+    763[0m:[38;5;10m[49m     for sample_id in range(n_samples):
[0m[49m[38;5;10m+    764[0m:[38;5;10m[49m         for ed_entry in ed_board:
[0m[49m[38;5;10m+    765[0m:[38;5;10m[49m             if rng.random() < 0.92:    # very likely to admit
[0m[49m[38;5;10m+    766[0m:[38;5;10m[49m                 # Land the admit between hour 0 and hour 2.
[0m[49m[38;5;10m+    767[0m:[38;5;10m[49m                 hour = rng.randint(0, min(2, horizon_hours - 1))
[0m[49m[38;5;10m+    768[0m:[38;5;10m[49m                 unit_code = ed_entry["expected_target_unit"]
[0m[49m[38;5;10m+    769[0m:[38;5;10m[49m                 if unit_code in unit_index:
[0m[49m[38;5;10m+    770[0m:[38;5;10m[49m                     inflow_samples[sample_id][hour][unit_index[unit_code]] += 1
[0m[49m[38;5;10m+    771[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    772[0m:[38;5;10m[49m     # 2c. OR schedule: deterministic show-rate-weighted admits.
[0m[49m[38;5;10m+    773[0m:[38;5;10m[49m     # Each scheduled case lands in the post-op unit at scheduled_end
[0m[49m[38;5;10m+    774[0m:[38;5;10m[49m     # + PACU delay, with a Bernoulli draw against the show probability
[0m[49m[38;5;10m+    775[0m:[38;5;10m[49m     # to capture cancellations.
[0m[49m[38;5;10m+    776[0m:[38;5;10m[49m     for sample_id in range(n_samples):
[0m[49m[38;5;10m+    777[0m:[38;5;10m[49m         for case in or_schedule:
[0m[49m[38;5;10m+    778[0m:[38;5;10m[49m             if rng.random() < case["show_probability"]:
[0m[49m[38;5;10m+    779[0m:[38;5;10m[49m                 end_ts = datetime.fromisoformat(case["scheduled_end_ts"])
[0m[49m[38;5;10m+    780[0m:[38;5;10m[49m                 admit_ts = end_ts + timedelta(hours=case["pacu_delay_hours"])
[0m[49m[38;5;10m+    781[0m:[38;5;10m[49m                 hour_offset = int((admit_ts - snapshot_ts).total_seconds() / 3600)
[0m[49m[38;5;10m+    782[0m:[38;5;10m[49m                 if 0 <= hour_offset < horizon_hours:
[0m[49m[38;5;10m+    783[0m:[38;5;10m[49m                     unit_code = case["target_unit"]
[0m[49m[38;5;10m+    784[0m:[38;5;10m[49m                     if unit_code in unit_index:
[0m[49m[38;5;10m+    785[0m:[38;5;10m[49m                         inflow_samples[sample_id][hour_offset][
[0m[49m[38;5;10m+    786[0m:[38;5;10m[49m                             unit_index[unit_code]] += 1
[0m[49m[38;5;10m+    787[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    788[0m:[38;5;10m[49m     # 2d. Transfer queue: known near-term transfers with a small
[0m[49m[38;5;10m+    789[0m:[38;5;10m[49m     # Bernoulli draw against the chance the transfer falls through
[0m[49m[38;5;10m+    790[0m:[38;5;10m[49m     # (sending hospital reroutes, accepting unit declines, weather).
[0m[49m[38;5;10m+    791[0m:[38;5;10m[49m     for sample_id in range(n_samples):
[0m[49m[38;5;10m+    792[0m:[38;5;10m[49m         for xfer in transfer_queue:
[0m[49m[38;5;10m+    793[0m:[38;5;10m[49m             if rng.random() < 0.85:
[0m[49m[38;5;10m+    794[0m:[38;5;10m[49m                 eta = datetime.fromisoformat(xfer["expected_arrival_ts"])
[0m[49m[38;5;10m+    795[0m:[38;5;10m[49m                 hour_offset = int((eta - snapshot_ts).total_seconds() / 3600)
[0m[49m[38;5;10m+    796[0m:[38;5;10m[49m                 if 0 <= hour_offset < horizon_hours:
[0m[49m[38;5;10m+    797[0m:[38;5;10m[49m                     unit_code = xfer["target_unit"]
[0m[49m[38;5;10m+    798[0m:[38;5;10m[49m                     if unit_code in unit_index:
[0m[49m[38;5;10m+    799[0m:[38;5;10m[49m                         inflow_samples[sample_id][hour_offset][
[0m[49m[38;5;10m+    800[0m:[38;5;10m[49m                             unit_index[unit_code]] += 1
[0m[49m[38;5;10m+    801[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    802[0m:[38;5;10m[49m     # Persist the inflow samples to S3 so the Lambda Monte Carlo
[0m[49m[38;5;10m+    803[0m:[38;5;10m[49m     # composition can read them as input. The shape is bulky
[0m[49m[38;5;10m+    804[0m:[38;5;10m[49m     # (n_samples * horizon * n_units), so production typically
[0m[49m[38;5;10m+    805[0m:[38;5;10m[49m     # writes Parquet; the demo writes JSON for readability.
[0m[49m[38;5;10m+    806[0m:[38;5;10m[49m     s3_key = (f"inflows/run_id={run_id}/"
[0m[49m[38;5;10m+    807[0m:[38;5;10m[49m               f"snapshot_ts={snapshot_ts.isoformat()}/inflows.json")
[0m[49m[38;5;10m+    808[0m:[38;5;10m[49m     s3.put_object(Bucket=bucket, Key=s3_key,
[0m[49m[38;5;10m+    809[0m:[38;5;10m[49m                   Body=json.dumps({
[0m[49m[38;5;10m+    810[0m:[38;5;10m[49m                       "inflow_samples": inflow_samples,
[0m[49m[38;5;10m+    811[0m:[38;5;10m[49m                       "unit_codes":     unit_codes,
[0m[49m[38;5;10m+    812[0m:[38;5;10m[49m                   }))
