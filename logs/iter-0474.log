[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m def generate_synthetic_inputs(now_dt, seed=SYNTHETIC_RANDOM_SEED):
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m     """Generate synthetic inputs for the census pipeline.
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m     Production reads the current state from Amazon HealthLake (or
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m     a continuously-updated S3 mirror), the OR schedule from the
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m     surgical scheduling system, the transfer queue from the
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m     transfer center system, and the ED tracking board from the
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m     ED tracking system. The demo synthesizes a realistic-shaped
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m     set of these so you can see the pipeline behave end-to-end.
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m     Returns a dict with:
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m       - encounters: list of currently-admitted patient encounters
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m       - or_schedule: list of scheduled surgical cases
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m       - transfer_queue: list of inbound transfer requests
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m       - ed_board: list of pending ED admit holds
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m     rng = random.Random(seed)
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m     # --- Currently admitted patients (the snapshot population) ---
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m     # Distribute ~360 occupied beds across the 5 units so the
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m     # hospital starts at ~87% utilization. Hospital census never
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m     # actually runs at 100%; somewhere between 80% and 92% is the
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m     # operationally interesting band.
