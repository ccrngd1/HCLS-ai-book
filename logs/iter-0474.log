[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m     if isinstance(value, Decimal):
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m         return value
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m     if isinstance(value, bool):
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m         # bool is a subclass of int in Python; route it explicitly
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m         # so True does not become Decimal('1') unexpectedly.
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m         return value
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m     if isinstance(value, (int, float)):
