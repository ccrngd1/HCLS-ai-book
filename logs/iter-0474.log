[0m[49m[38;5;10m+     986[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     987[0m:[38;5;10m[49m def _percentile(values, pct):
[0m[49m[38;5;10m+     988[0m:[38;5;10m[49m     """Compute the pct percentile of a list of numbers."""
[0m[49m[38;5;10m+     989[0m:[38;5;10m[49m     if not values:
[0m[49m[38;5;10m+     990[0m:[38;5;10m[49m         return 0.0
[0m[49m[38;5;10m+     991[0m:[38;5;10m[49m     sorted_vals = sorted(values)
[0m[49m[38;5;10m+     992[0m:[38;5;10m[49m     k = (len(sorted_vals) - 1) * (pct / 100.0)
[0m[49m[38;5;10m+     993[0m:[38;5;10m[49m     lo = int(k)
