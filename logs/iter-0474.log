[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m # Adaptive retry handles throttling from S3, DynamoDB, EventBridge,
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m # CloudWatch, HealthLake, and SageMaker. The inference pipeline
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m # runs every 15 to 60 minutes; transient failures should retry
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m # quickly so a stuck dependency does not cascade into a missed
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m # cycle. The forecast going stale by twenty minutes is materially
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m # worse than running with a slightly degraded compute path.
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m     retries={"max_attempts": 5, "mode": "adaptive"})
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m # Module-level clients. Reused across function calls within the
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m # pipeline so each call does not pay the connection cost. The
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m # demo wires up MockS3 / MockTable / MockEventBus / MockCloudWatch /
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m # MockHealthLake via run_demo() and never touches these real
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m # handles; they are staged here so production wiring is a one-line
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m # swap. boto3 client and resource construction is lazy (no network
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m # call until first use), so the unused handles are free at import.
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m REGION = "us-east-1"
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m s3_client          = boto3.client("s3",
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m                                   region_name=REGION,
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m                                   config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m dynamodb           = boto3.resource("dynamodb",
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m                                     region_name=REGION,
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m                                     config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m healthlake_client  = boto3.client("healthlake",
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m                                   region_name=REGION,
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m                                   config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m eventbridge_client = boto3.client("events",
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m                                   region_name=REGION,
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m                                   config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m cloudwatch_client  = boto3.client("cloudwatch",
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m                                   region_name=REGION,
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m                                   config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m sagemaker_runtime  = boto3.client("sagemaker-runtime",
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m                                   region_name=REGION,
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m                                   config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m lambda_client      = boto3.client("lambda",
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m                                   region_name=REGION,
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m                                   config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m # --- Resource Names ---
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m # Fill these in with your actual resource names. The demo prints
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m # what it would write rather than failing if the resources do
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m # not exist; see run_demo() at the bottom.
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m HEALTHLAKE_DATASTORE_ID    = "inpatient-fhir-datastore"
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m RAW_ADT_BUCKET             = "census-forecast-raw-adt"
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m OR_SCHEDULE_BUCKET         = "census-forecast-or-schedule"
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m TRANSFER_QUEUE_BUCKET      = "census-forecast-transfer-queue"
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m ED_BOARD_BUCKET            = "census-forecast-ed-board"
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m SNAPSHOT_BUCKET            = "census-forecast-snapshots"
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m INFLOW_FORECAST_BUCKET     = "census-forecast-inflows"
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m OUTFLOW_FORECAST_BUCKET    = "census-forecast-outflows"
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m SAMPLE_TRAJECTORY_BUCKET   = "census-forecast-trajectories"
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m MODEL_ARTIFACT_BUCKET      = "census-forecast-models"
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m CENSUS_FORECAST_TABLE      = "census-forecasts"
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m CENSUS_EVENT_BUS_NAME      = "census-forecast-events-bus"
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m CLOUDWATCH_NAMESPACE       = "HospitalCensusForecast"
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m # --- Versioning ---
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m # Every forecast record carries the model versions and the rule
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m # version active at the time of generation. This is how a future
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m # audit reconstructs which inflow model, which survival model,
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m # and which overflow configuration produced which forecast on
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m # which cycle. The combined identifier is also useful when the
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m # bed-management team asks "are we still on the model that was
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m # in production three weeks ago".
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m PIPELINE_VERSION       = "census-pipeline-v1.0"
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m INFLOW_MODEL_VERSION   = "inflow-poisson-v1"
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m SURVIVAL_MODEL_VERSION = "outflow-exp-v1"
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m ASSIGNER_MODEL_VERSION = "unit-assigner-v1"
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m OVERFLOW_RULES_VERSION = "overflow-rules-2026-05"
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m # --- Forecast Horizon and Cadence ---
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m # The demo's horizon is 24 hours. Production runs the pipeline
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m # every 15 to 60 minutes (the cadence is operational policy) and
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m # typically forecasts 4-to-72 hours forward. The horizon is the
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m # inference-time choice; the model itself does not encode a
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m # specific horizon.
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m FORECAST_HORIZON_HOURS    = 24
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m DEFAULT_MONTE_CARLO_SAMPLES = 200    # production uses 500 to 1000
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m # --- Hospital Map ---
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m # The demo's 412-bed community hospital. Production reads the unit
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m # map from a configuration store the bed-management team owns; the
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m # unit codes here are illustrative.
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m UNIT_CATALOG = {
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m     "ed-hold":      {"display": "ED Holding",        "capacity": 12},
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m     "tele-3-east":  {"display": "Telemetry 3 East",  "capacity": 28},
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m     "medsurg-4-w":  {"display": "Med-Surg 4 West",   "capacity": 36},
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m     "ortho-5-n":    {"display": "Orthopedic 5 North","capacity": 24},
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m     "stepdown-icu": {"display": "Step-Down ICU",     "capacity": 16},
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m # --- Overflow Rules ---
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m # When a unit's projected occupancy exceeds capacity in a Monte
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m # Carlo sample, the overflow logic redistributes the excess to the
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m # designated overflow targets in priority order. Production reads
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m # this from a configuration store the bed-management team owns.
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m OVERFLOW_RULES = {
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m     "ed-hold":      ["medsurg-4-w", "tele-3-east"],
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m     "tele-3-east":  ["stepdown-icu", "medsurg-4-w"],
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m     "medsurg-4-w":  ["ortho-5-n", "tele-3-east"],
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m     "ortho-5-n":    ["medsurg-4-w"],
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m     "stepdown-icu": ["tele-3-east"],
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m # --- Inflow Rates ---
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m # Per-source hourly admission Poisson rates. Production fits these
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m # from historical ADT data with calendar, weather, and current-ED
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m # state features; the demo uses a static rate per source so the
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m # example stays readable. The rates are calibrated so the synthetic
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m # 412-bed hospital sees ~50 admissions per day, which is the right
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m # order of magnitude for a community hospital.
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m HOURLY_INFLOW_RATES = {
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m     "ed_admit":     0.95,    # ED-driven admissions per hour
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m     "direct_admit": 0.20,    # office or clinic direct admits per hour
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m     "transfer_in":  0.05,    # outside-facility transfers per hour
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m # --- Unit Assignment ---
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m # Probability distribution over admission units conditional on the
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m # admission source. Production fits these from historical ADT
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m # joined with EHR diagnosis and disposition; the demo encodes
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m # realistic-shaped distributions per source. Surgical post-op
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m # admits do not use this table because the OR schedule already
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m # specifies the target unit.
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m UNIT_ASSIGNMENT_PROBABILITIES = {
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m     "ed_admit": {
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m         "tele-3-east":  0.30,
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m         "medsurg-4-w":  0.45,
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m         "ortho-5-n":    0.05,
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m         "stepdown-icu": 0.10,
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m         "ed-hold":      0.10,
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m     "direct_admit": {
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m         "tele-3-east":  0.20,
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m         "medsurg-4-w":  0.55,
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m         "ortho-5-n":    0.10,
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m         "stepdown-icu": 0.10,
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m         "ed-hold":      0.05,
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m     "transfer_in": {
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m         "tele-3-east":  0.20,
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m         "medsurg-4-w":  0.30,
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m         "ortho-5-n":    0.10,
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m         "stepdown-icu": 0.40,
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m         "ed-hold":      0.00,
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m # --- Hour-of-Day Discharge Pattern ---
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m # Hospitals discharge 70-80% of their volume between 10:00 and 18:00
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m # with a peak around 13:00-15:00. The pattern below is the relative
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m # discharge intensity per hour of day; the survival model's per-hour
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m # probability gets multiplied by this factor so the discharge times
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m # concentrate during the day. Production fits this from historical
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m # discharge timestamps; the demo uses a typical bell-shaped pattern.
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m HOUR_OF_DAY_DISCHARGE_INTENSITY = {
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m     0:  0.05, 1:  0.05, 2:  0.05, 3:  0.05, 4:  0.05, 5:  0.05,
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m     6:  0.10, 7:  0.20, 8:  0.40, 9:  0.70, 10: 1.20, 11: 1.50,
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m     12: 1.60, 13: 1.80, 14: 1.70, 15: 1.50, 16: 1.20, 17: 0.90,
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m     18: 0.60, 19: 0.40, 20: 0.20, 21: 0.10, 22: 0.05, 23: 0.05,
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m # --- Service Lines ---
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m # Per-service-line baseline length-of-stay parameters. The
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m # survival model uses these as its prior; production fits a
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m # proper survival regression that learns from history.
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m SERVICE_LINE_LOS_HOURS = {
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m     "medicine":       96.0,    # 4 days
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m     "cardiology":     72.0,    # 3 days
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m     "orthopedics":    60.0,    # 2.5 days post-joint-replacement
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m     "general_surgery":48.0,    # 2 days
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     "neurology":      120.0,   # 5 days
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m     "icu_stepdown":   72.0,    # 3 days in step-down
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m # Discharge-order multiplier. A patient with a discharge order
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m # entered has a hazard rate roughly 6x the patient without one;
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m # this is the single most important feature in real survival
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m # models for hospital discharge.
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m DISCHARGE_ORDER_HAZARD_MULTIPLIER = 6.0
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m 
