[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m def snapshot_current_state(snapshot_ts, healthlake, s3, bucket):
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m     """Step 1: Capture currently-admitted patients and per-patient features.
