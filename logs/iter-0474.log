[0m[49m[38;5;10m+    876[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    877[0m:[38;5;10m[49m             stage_multiplier = 2.2
[0m[49m[38;5;10m+    878[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    879[0m:[38;5;10m[49m         # The discharge order is the strongest single feature.
[0m[49m[38;5;10m+    880[0m:[38;5;10m[49m         order_multiplier = (
[0m[49m[38;5;10m+    881[0m:[38;5;10m[49m             self.discharge_order_multiplier
[0m[49m[38;5;10m+    882[0m:[38;5;10m[49m             if features.get("discharge_order_entered") else 1.0)
[0m[49m[38;5;10m+    883[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    884[0m:[38;5;10m[49m         # Hour-of-day pattern. Discharges concentrate during the
[0m[49m[38;5;10m+    885[0m:[38;5;10m[49m         # day; overnight discharges are minimal.
[0m[49m[38;5;10m+    886[0m:[38;5;10m[49m         hour_multiplier = self.hour_of_day_intensity.get(
[0m[49m[38;5;10m+    887[0m:[38;5;10m[49m             target_hour_of_day, 1.0)
[0m[49m[38;5;10m+    888[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    889[0m:[38;5;10m[49m         return (baseline_hazard
[0m[49m[38;5;10m+    890[0m:[38;5;10m[49m                 * stage_multiplier
[0m[49m[38;5;10m+    891[0m:[38;5;10m[49m                 * order_multiplier
[0m[49m[38;5;10m+    892[0m:[38;5;10m[49m                 * hour_multiplier)
[0m[49m[38;5;10m+    893[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    894[0m:[38;5;10m[49m     def discharge_probability_per_hour(self, features, snapshot_ts,
[0m[49m[38;5;10m+    895[0m:[38;5;10m[49m                                         horizon_hours):
[0m[49m[38;5;10m+    896[0m:[38;5;10m[49m         """Return the per-hour discharge probability over the horizon.
[0m[49m[38;5;10m+    897[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    898[0m:[38;5;10m[49m         Standard exponential survival: P(discharge in hour h) =
[0m[49m[38;5;10m+    899[0m:[38;5;10m[49m         S(h) * (1 - exp(-hazard(h))), where S(h) is the survival
[0m[49m[38;5;10m+    900[0m:[38;5;10m[49m         function (probability of not having discharged by hour h).
[0m[49m[38;5;10m+    901[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+    902[0m:[38;5;10m[49m         per_hour = []
[0m[49m[38;5;10m+    903[0m:[38;5;10m[49m         survival = 1.0
[0m[49m[38;5;10m+    904[0m:[38;5;10m[49m         for hour_offset in range(horizon_hours):
