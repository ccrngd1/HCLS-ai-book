[0m[49m[38;5;10m+    913[0m:[38;5;10m[49m             per_hour.append(marginal)
[0m[49m[38;5;10m+    914[0m:[38;5;10m[49m             survival *= (1.0 - p_discharge_this_hour)
[0m[49m[38;5;10m+    915[0m:[38;5;10m[49m         return per_hour, survival
