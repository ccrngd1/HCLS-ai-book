[0m[49m[38;5;10m+     123[0m:[38;5;10m[49m      "why": "Proportion of days covered (PDC). Low adherence means escalation may not help."},
[0m[49m[38;5;10m+     124[0m:[38;5;10m[49m     {"name": "appointment_adherence", "min": 0, "max": 1.0,
[0m[49m[38;5;10m+     125[0m:[38;5;10m[49m      "why": "Fraction of scheduled visits attended. Proxy for engagement."},
[0m[49m[38;5;10m+     126[0m:[38;5;10m[49m     # Comorbidity burden
[0m[49m[38;5;10m+     127[0m:[38;5;10m[49m     {"name": "comorbidity_count", "min": 0, "max": 10,
[0m[49m[38;5;10m+     128[0m:[38;5;10m[49m      "why": "Number of active comorbidities. More = more conservative targets."},
[0m[49m[38;5;10m+     129[0m:[38;5;10m[49m     {"name": "diabetes_duration_years", "min": 0, "max": 40,
[0m[49m[38;5;10m+     130[0m:[38;5;10m[49m      "why": "Longer duration = more beta-cell loss = harder to control with orals."},
[0m[49m[38;5;10m+     131[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+     132[0m:[38;5;10m[49m NUM_STATE_FEATURES = len(STATE_FEATURES)
[0m[49m[38;5;10m+     133[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     134[0m:[38;5;10m[49m # --- Safety Constraints ---
[0m[49m[38;5;10m+     135[0m:[38;5;10m[49m # Hard rules that override the RL policy. These encode clinical guidelines
[0m[49m[38;5;10m+     136[0m:[38;5;10m[49m # and contraindications that should never be violated.
[0m[49m[38;5;10m+     137[0m:[38;5;10m[49m SAFETY_CONSTRAINTS = {
[0m[49m[38;5;10m+     138[0m:[38;5;10m[49m     # Never escalate more than 2 levels at once (e.g., lifestyle -> triple oral is too aggressive)
[0m[49m[38;5;10m+     139[0m:[38;5;10m[49m     "max_escalation_steps": 2,
[0m[49m[38;5;10m+     140[0m:[38;5;10m[49m     # Never de-escalate more than 1 level at once (avoid rebound hyperglycemia)
[0m[49m[38;5;10m+     141[0m:[38;5;10m[49m     "max_deescalation_steps": 1,
[0m[49m[38;5;10m+     142[0m:[38;5;10m[49m     # Minimum time on current treatment before changing (give it time to work)
[0m[49m[38;5;10m+     143[0m:[38;5;10m[49m     "min_months_before_change": 3,
[0m[49m[38;5;10m+     144[0m:[38;5;10m[49m     # Don't escalate if adherence is below this (fix adherence first)
[0m[49m[38;5;10m+     145[0m:[38;5;10m[49m     "min_adherence_for_escalation": 0.6,
[0m[49m[38;5;10m+     146[0m:[38;5;10m[49m     # Metformin contraindicated below this eGFR
[0m[49m[38;5;10m+     147[0m:[38;5;10m[49m     "metformin_egfr_floor": 30,
[0m[49m[38;5;10m+     148[0m:[38;5;10m[49m     # SGLT2 less effective below this eGFR
[0m[49m[38;5;10m+     149[0m:[38;5;10m[49m     "sglt2_egfr_floor": 45,
[0m[49m[38;5;10m+     150[0m:[38;5;10m[49m     # Don't use insulin-heavy regimens if severe hypo history + age > 75
[0m[49m[38;5;10m+     151[0m:[38;5;10m[49m     "insulin_age_hypo_limit": 75,
[0m[49m[38;5;10m+     152[0m:[38;5;10m[49m     # If HbA1c is already at target, don't escalate
[0m[49m[38;5;10m+     153[0m:[38;5;10m[49m     "no_escalation_at_target": True,
[0m[49m[38;5;10m+     154[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     155[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     156[0m:[38;5;10m[49m # --- Reward Function Parameters ---
[0m[49m[38;5;10m+     157[0m:[38;5;10m[49m # The reward encodes what "good diabetes management" means over time.
[0m[49m[38;5;10m+     158[0m:[38;5;10m[49m # Key insight: chronic disease reward is multi-objective. You want low HbA1c
[0m[49m[38;5;10m+     159[0m:[38;5;10m[49m # BUT also low hypoglycemia, good tolerability, and minimal treatment burden.
[0m[49m[38;5;10m+     160[0m:[38;5;10m[49m REWARD_PARAMS = {
[0m[49m[38;5;10m+     161[0m:[38;5;10m[49m     "at_target_reward": 10.0,         # HbA1c at individualized target
[0m[49m[38;5;10m+     162[0m:[38;5;10m[49m     "improving_bonus": 3.0,           # HbA1c trending down toward target
[0m[49m[38;5;10m+     163[0m:[38;5;10m[49m     "above_target_penalty_scale": -2.0,  # per 0.5% above target
[0m[49m[38;5;10m+     164[0m:[38;5;10m[49m     "dangerous_high_penalty": -15.0,  # HbA1c > 10%
[0m[49m[38;5;10m+     165[0m:[38;5;10m[49m     "over_treatment_penalty": -8.0,   # HbA1c < 5.5% (too aggressive)
[0m[49m[38;5;10m+     166[0m:[38;5;10m[49m     "hypo_event_penalty": -5.0,       # per hypoglycemic episode
[0m[49m[38;5;10m+     167[0m:[38;5;10m[49m     "severe_hypo_penalty": -20.0,     # severe hypoglycemia (catastrophic)
[0m[49m[38;5;10m+     168[0m:[38;5;10m[49m     "treatment_burden_scale": -0.5,   # per escalation level (prefer simpler regimens)
[0m[49m[38;5;10m+     169[0m:[38;5;10m[49m     "unnecessary_escalation": -3.0,   # escalating when already at target
[0m[49m[38;5;10m+     170[0m:[38;5;10m[49m     "adherence_mismatch": -4.0,       # escalating when adherence is poor
[0m[49m[38;5;10m+     171[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     172[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     173[0m:[38;5;10m[49m # --- AWS Resource Names ---
[0m[49m[38;5;10m+     174[0m:[38;5;10m[49m SAGEMAKER_ENDPOINT = "chronic-dm-rl-policy-v1"
[0m[49m[38;5;10m+     175[0m:[38;5;10m[49m DYNAMODB_TABLE = "patient-diabetes-state"
[0m[49m[38;5;10m+     176[0m:[38;5;10m[49m S3_TRAINING_BUCKET = "chronic-dm-rl-training"
[0m[49m[38;5;10m+     177[0m:[38;5;10m[49m S3_EPISODE_PREFIX = "episodes/dm-type2/"
[0m[49m[38;5;10m+     178[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     179[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     180[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     181[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     182[0m:[38;5;10m[49m ## Step 1: Reward Function
[0m[49m[38;5;10m+     183[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     184[0m:[38;5;10m[49m *The reward function is the most consequential design decision. Chronic disease RL has a fundamentally different reward structure than acute care: outcomes unfold over months, multiple objectives compete, and treatment burden itself is a cost. You can't just optimize HbA1c; you have to balance glycemic control against hypoglycemia risk, side effects, and regimen complexity.*
[0m[49m[38;5;10m+     185[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     186[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     187[0m:[38;5;10m[49m def compute_reward(
[0m[49m[38;5;10m+     188[0m:[38;5;10m[49m     hba1c: float,
[0m[49m[38;5;10m+     189[0m:[38;5;10m[49m     target_hba1c: float,
[0m[49m[38;5;10m+     190[0m:[38;5;10m[49m     hypo_events: int,
[0m[49m[38;5;10m+     191[0m:[38;5;10m[49m     severe_hypo: bool,
[0m[49m[38;5;10m+     192[0m:[38;5;10m[49m     treatment_level: int,
[0m[49m[38;5;10m+     193[0m:[38;5;10m[49m     previous_treatment_level: int,
[0m[49m[38;5;10m+     194[0m:[38;5;10m[49m     adherence: float,
[0m[49m[38;5;10m+     195[0m:[38;5;10m[49m ) -> float:
[0m[49m[38;5;10m+     196[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     197[0m:[38;5;10m[49m     Compute the reward for a quarterly treatment outcome.
[0m[49m[38;5;10m+     198[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     199[0m:[38;5;10m[49m     This is multi-objective by design. A perfect HbA1c achieved through
[0m[49m[38;5;10m+     200[0m:[38;5;10m[49m     aggressive insulin that causes frequent hypoglycemia is NOT a good outcome.
[0m[49m[38;5;10m+     201[0m:[38;5;10m[49m     A slightly elevated HbA1c on a simple oral regimen with no side effects
[0m[49m[38;5;10m+     202[0m:[38;5;10m[49m     might be better for that patient's quality of life.
[0m[49m[38;5;10m+     203[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     204[0m:[38;5;10m[49m     The reward function encodes these trade-offs:
[0m[49m[38;5;10m+     205[0m:[38;5;10m[49m     1. Primary: Is HbA1c at the individualized target?
[0m[49m[38;5;10m+     206[0m:[38;5;10m[49m     2. Safety: Any hypoglycemia events? (heavily penalized)
[0m[49m[38;5;10m+     207[0m:[38;5;10m[49m     3. Burden: Is the treatment regimen more complex than necessary?
[0m[49m[38;5;10m+     208[0m:[38;5;10m[49m     4. Appropriateness: Did we escalate when adherence was the real problem?
[0m[49m[38;5;10m+     209[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     210[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     211[0m:[38;5;10m[49m         hba1c: Current HbA1c measurement (%).
[0m[49m[38;5;10m+     212[0m:[38;5;10m[49m         target_hba1c: Individualized target for this patient (%).
[0m[49m[38;5;10m+     213[0m:[38;5;10m[49m         hypo_events: Number of hypoglycemic episodes this quarter.
[0m[49m[38;5;10m+     214[0m:[38;5;10m[49m         severe_hypo: Whether any severe hypoglycemia occurred.
[0m[49m[38;5;10m+     215[0m:[38;5;10m[49m         treatment_level: Current treatment action index (0-7).
[0m[49m[38;5;10m+     216[0m:[38;5;10m[49m         previous_treatment_level: Treatment level at start of quarter.
[0m[49m[38;5;10m+     217[0m:[38;5;10m[49m         adherence: Medication adherence proportion (0-1).
[0m[49m[38;5;10m+     218[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     219[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     220[0m:[38;5;10m[49m         Float reward value. Higher is better.
[0m[49m[38;5;10m+     221[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     222[0m:[38;5;10m[49m     reward = 0.0
[0m[49m[38;5;10m+     223[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     224[0m:[38;5;10m[49m     # --- Glycemic control component ---
[0m[49m[38;5;10m+     225[0m:[38;5;10m[49m     if hba1c < HBA1C_DANGEROUS_LOW:
[0m[49m[38;5;10m+     226[0m:[38;5;10m[49m         # Over-treated. HbA1c this low in a type 2 patient means the regimen
[0m[49m[38;5;10m+     227[0m:[38;5;10m[49m         # is too aggressive. High risk of hypoglycemia.
[0m[49m[38;5;10m+     228[0m:[38;5;10m[49m         reward += REWARD_PARAMS["over_treatment_penalty"]
[0m[49m[38;5;10m+     229[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     230[0m:[38;5;10m[49m     elif abs(hba1c - target_hba1c) <= 0.3:
[0m[49m[38;5;10m+     231[0m:[38;5;10m[49m         # At target (within 0.3% tolerance). This is the goal state.
[0m[49m[38;5;10m+     232[0m:[38;5;10m[49m         reward += REWARD_PARAMS["at_target_reward"]
[0m[49m[38;5;10m+     233[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     234[0m:[38;5;10m[49m     elif hba1c > HBA1C_DANGEROUS_HIGH:
[0m[49m[38;5;10m+     235[0m:[38;5;10m[49m         # Dangerously high. Microvascular damage accumulating.
[0m[49m[38;5;10m+     236[0m:[38;5;10m[49m         reward += REWARD_PARAMS["dangerous_high_penalty"]
[0m[49m[38;5;10m+     237[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     238[0m:[38;5;10m[49m     elif hba1c > target_hba1c:
[0m[49m[38;5;10m+     239[0m:[38;5;10m[49m         # Above target but not dangerous. Scaled penalty.
[0m[49m[38;5;10m+     240[0m:[38;5;10m[49m         overshoot = hba1c - target_hba1c
[0m[49m[38;5;10m+     241[0m:[38;5;10m[49m         reward += REWARD_PARAMS["above_target_penalty_scale"] * (overshoot / 0.5)
[0m[49m[38;5;10m+     242[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     243[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+     244[0m:[38;5;10m[49m         # Below target but not dangerously low. Mild positive.
[0m[49m[38;5;10m+     245[0m:[38;5;10m[49m         reward += REWARD_PARAMS["at_target_reward"] * 0.5
[0m[49m[38;5;10m+     246[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     247[0m:[38;5;10m[49m     # --- Hypoglycemia component ---
[0m[49m[38;5;10m+     248[0m:[38;5;10m[49m     # Each hypo event is penalized. Severe hypo gets a massive penalty.
[0m[49m[38;5;10m+     249[0m:[38;5;10m[49m     # This makes the agent deeply afraid of over-treatment.
[0m[49m[38;5;10m+     250[0m:[38;5;10m[49m     reward += REWARD_PARAMS["hypo_event_penalty"] * hypo_events
[0m[49m[38;5;10m+     251[0m:[38;5;10m[49m     if severe_hypo:
[0m[49m[38;5;10m+     252[0m:[38;5;10m[49m         reward += REWARD_PARAMS["severe_hypo_penalty"]
[0m[49m[38;5;10m+     253[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     254[0m:[38;5;10m[49m     # --- Treatment burden component ---
[0m[49m[38;5;10m+     255[0m:[38;5;10m[49m     # Prefer simpler regimens when outcomes are equivalent.
[0m[49m[38;5;10m+     256[0m:[38;5;10m[49m     # A patient controlled on metformin alone is better off than one
[0m[49m[38;5;10m+     257[0m:[38;5;10m[49m     # controlled on triple therapy, all else being equal.
[0m[49m[38;5;10m+     258[0m:[38;5;10m[49m     reward += REWARD_PARAMS["treatment_burden_scale"] * treatment_level
[0m[49m[38;5;10m+     259[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     260[0m:[38;5;10m[49m     # --- Appropriateness penalties ---
[0m[49m[38;5;10m+     261[0m:[38;5;10m[49m     escalated = treatment_level > previous_treatment_level
[0m[49m[38;5;10m+     262[0m:[38;5;10m[49m     if escalated and hba1c <= target_hba1c + 0.3:
[0m[49m[38;5;10m+     263[0m:[38;5;10m[49m         # Escalated when already at target. Unnecessary complexity.
[0m[49m[38;5;10m+     264[0m:[38;5;10m[49m         reward += REWARD_PARAMS["unnecessary_escalation"]
[0m[49m[38;5;10m+     265[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     266[0m:[38;5;10m[49m     if escalated and adherence < SAFETY_CONSTRAINTS["min_adherence_for_escalation"]:
[0m[49m[38;5;10m+     267[0m:[38;5;10m[49m         # Escalated when the patient isn't taking their current meds.
[0m[49m[38;5;10m+     268[0m:[38;5;10m[49m         # The problem is adherence, not pharmacology.
[0m[49m[38;5;10m+     269[0m:[38;5;10m[49m         reward += REWARD_PARAMS["adherence_mismatch"]
[0m[49m[38;5;10m+     270[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     271[0m:[38;5;10m[49m     return round(reward, 2)
[0m[49m[38;5;10m+     272[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     273[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     274[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     275[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     276[0m:[38;5;10m[49m ## Step 2: State Construction
[0m[49m[38;5;10m+     277[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     278[0m:[38;5;10m[49m *Transforms raw patient data from the longitudinal record into a normalized state vector. Chronic disease state is richer than acute care because you have years of history and lifestyle factors that matter enormously for treatment response.*
[0m[49m[38;5;10m+     279[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     280[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     281[0m:[38;5;10m[49m def normalize_feature(value: float, feature_def: dict) -> float:
[0m[49m[38;5;10m+     282[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     283[0m:[38;5;10m[49m     Normalize a raw clinical value to [0, 1] using defined bounds.
[0m[49m[38;5;10m+     284[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     285[0m:[38;5;10m[49m     Clipping to bounds handles physiologically extreme values gracefully.
[0m[49m[38;5;10m+     286[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     287[0m:[38;5;10m[49m     min_val = feature_def["min"]
[0m[49m[38;5;10m+     288[0m:[38;5;10m[49m     max_val = feature_def["max"]
[0m[49m[38;5;10m+     289[0m:[38;5;10m[49m     clipped = max(min_val, min(max_val, value))
[0m[49m[38;5;10m+     290[0m:[38;5;10m[49m     if max_val == min_val:
[0m[49m[38;5;10m+     291[0m:[38;5;10m[49m         return 0.5
[0m[49m[38;5;10m+     292[0m:[38;5;10m[49m     return (clipped - min_val) / (max_val - min_val)
[0m[49m[38;5;10m+     293[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     294[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     295[0m:[38;5;10m[49m def construct_state_vector(patient_data: dict) -> np.ndarray:
[0m[49m[38;5;10m+     296[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     297[0m:[38;5;10m[49m     Build a normalized state vector from patient's current clinical state.
[0m[49m[38;5;10m+     298[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     299[0m:[38;5;10m[49m     Missing values get midpoint imputation. In production, you'd use the
[0m[49m[38;5;10m+     300[0m:[38;5;10m[49m     last known value with a staleness indicator, or a learned imputation
[0m[49m[38;5;10m+     301[0m:[38;5;10m[49m     model trained on the same population.
[0m[49m[38;5;10m+     302[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     303[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     304[0m:[38;5;10m[49m         patient_data: Dict mapping feature names to current values.
[0m[49m[38;5;10m+     305[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     306[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     307[0m:[38;5;10m[49m         numpy array of shape (NUM_STATE_FEATURES,) with values in [0, 1].
[0m[49m[38;5;10m+     308[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     309[0m:[38;5;10m[49m     state = np.zeros(NUM_STATE_FEATURES, dtype=np.float32)
[0m[49m[38;5;10m+     310[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     311[0m:[38;5;10m[49m     for i, feature_def in enumerate(STATE_FEATURES):
[0m[49m[38;5;10m+     312[0m:[38;5;10m[49m         name = feature_def["name"]
[0m[49m[38;5;10m+     313[0m:[38;5;10m[49m         if name in patient_data and patient_data[name] is not None:
[0m[49m[38;5;10m+     314[0m:[38;5;10m[49m             state[i] = normalize_feature(patient_data[name], feature_def)
[0m[49m[38;5;10m+     315[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+     316[0m:[38;5;10m[49m             state[i] = 0.5
[0m[49m[38;5;10m+     317[0m:[38;5;10m[49m             logger.warning("Missing feature '%s', using midpoint imputation", name)
[0m[49m[38;5;10m+     318[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     319[0m:[38;5;10m[49m     return state
[0m[49m[38;5;10m+     320[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     321[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     322[0m:[38;5;10m[49m def compute_individualized_target(patient_data: dict) -> float:
[0m[49m[38;5;10m+     323[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     324[0m:[38;5;10m[49m     Determine the individualized HbA1c target for this patient.
[0m[49m[38;5;10m+     325[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     326[0m:[38;5;10m[49m     ADA guidelines recommend relaxed targets for:
[0m[49m[38;5;10m+     327[0m:[38;5;10m[49m     - Elderly patients (> 75 years)
[0m[49m[38;5;10m+     328[0m:[38;5;10m[49m     - Patients with multiple comorbidities
[0m[49m[38;5;10m+     329[0m:[38;5;10m[49m     - Patients with history of severe hypoglycemia
[0m[49m[38;5;10m+     330[0m:[38;5;10m[49m     - Patients with limited life expectancy
[0m[49m[38;5;10m+     331[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     332[0m:[38;5;10m[49m     This is a simplified version. Real clinical decision-making considers
[0m[49m[38;5;10m+     333[0m:[38;5;10m[49m     many more factors and involves shared decision-making with the patient.
[0m[49m[38;5;10m+     334[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     335[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     336[0m:[38;5;10m[49m         patient_data: Patient's clinical state.
[0m[49m[38;5;10m+     337[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     338[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     339[0m:[38;5;10m[49m         Individualized HbA1c target (%).
[0m[49m[38;5;10m+     340[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     341[0m:[38;5;10m[49m     target = HBA1C_TARGET  # Start with standard 7.0%
[0m[49m[38;5;10m+     342[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     343[0m:[38;5;10m[49m     age = patient_data.get("age", 50)
[0m[49m[38;5;10m+     344[0m:[38;5;10m[49m     comorbidities = patient_data.get("comorbidity_count", 0)
[0m[49m[38;5;10m+     345[0m:[38;5;10m[49m     severe_hypo = patient_data.get("severe_hypo_ever", 0)
[0m[49m[38;5;10m+     346[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     347[0m:[38;5;10m[49m     # Relax target for elderly
[0m[49m[38;5;10m+     348[0m:[38;5;10m[49m     if age > 75:
[0m[49m[38;5;10m+     349[0m:[38;5;10m[49m         target = max(target, 7.5)
[0m[49m[38;5;10m+     350[0m:[38;5;10m[49m     if age > 80:
[0m[49m[38;5;10m+     351[0m:[38;5;10m[49m         target = max(target, 8.0)
[0m[49m[38;5;10m+     352[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     353[0m:[38;5;10m[49m     # Relax for high comorbidity burden
[0m[49m[38;5;10m+     354[0m:[38;5;10m[49m     if comorbidities >= 5:
[0m[49m[38;5;10m+     355[0m:[38;5;10m[49m         target = max(target, 7.5)
[0m[49m[38;5;10m+     356[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     357[0m:[38;5;10m[49m     # Relax if history of severe hypoglycemia
[0m[49m[38;5;10m+     358[0m:[38;5;10m[49m     if severe_hypo:
[0m[49m[38;5;10m+     359[0m:[38;5;10m[49m         target = max(target, 7.5)
[0m[49m[38;5;10m+     360[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     361[0m:[38;5;10m[49m     return min(target, HBA1C_RELAXED_TARGET)
[0m[49m[38;5;10m+     362[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     363[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     364[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     365[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     366[0m:[38;5;10m[49m ## Step 3: Safety Constraint Layer
[0m[49m[38;5;10m+     367[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     368[0m:[38;5;10m[49m *The safety layer enforces clinical guidelines and contraindications that override the RL policy. In chronic disease management, these constraints encode years of clinical trial evidence about what treatment transitions are safe and appropriate.*
[0m[49m[38;5;10m+     369[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     370[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     371[0m:[38;5;10m[49m def apply_safety_constraints(
[0m[49m[38;5;10m+     372[0m:[38;5;10m[49m     recommended_action: int,
[0m[49m[38;5;10m+     373[0m:[38;5;10m[49m     patient_data: dict,
[0m[49m[38;5;10m+     374[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+     375[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     376[0m:[38;5;10m[49m     Apply clinical safety constraints to the RL policy's treatment recommendation.
[0m[49m[38;5;10m+     377[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     378[0m:[38;5;10m[49m     Chronic disease constraints are different from acute care. They're less about
[0m[49m[38;5;10m+     379[0m:[38;5;10m[49m     preventing immediate harm and more about preventing inappropriate treatment
[0m[49m[38;5;10m+     380[0m:[38;5;10m[49m     transitions that waste time, cause side effects, or ignore the real problem.
[0m[49m[38;5;10m+     381[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     382[0m:[38;5;10m[49m     The constraints encode:
[0m[49m[38;5;10m+     383[0m:[38;5;10m[49m     1. Maximum escalation/de-escalation speed
[0m[49m[38;5;10m+     384[0m:[38;5;10m[49m     2. Minimum time on current treatment before switching
[0m[49m[38;5;10m+     385[0m:[38;5;10m[49m     3. Contraindications based on renal function
[0m[49m[38;5;10m+     386[0m:[38;5;10m[49m     4. Adherence-gating (don't escalate if patient isn't taking current meds)
[0m[49m[38;5;10m+     387[0m:[38;5;10m[49m     5. Age/frailty-based insulin avoidance
[0m[49m[38;5;10m+     388[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     389[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     390[0m:[38;5;10m[49m         recommended_action: Treatment action index the RL policy wants.
[0m[49m[38;5;10m+     391[0m:[38;5;10m[49m         patient_data: Current patient state (raw values).
[0m[49m[38;5;10m+     392[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     393[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     394[0m:[38;5;10m[49m         Dict with final_action, original_recommendation, and activated constraints.
[0m[49m[38;5;10m+     395[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     396[0m:[38;5;10m[49m     current_level = int(patient_data.get("current_treatment_level", 0))
[0m[49m[38;5;10m+     397[0m:[38;5;10m[49m     safe_action = recommended_action
[0m[49m[38;5;10m+     398[0m:[38;5;10m[49m     activated = []
[0m[49m[38;5;10m+     399[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     400[0m:[38;5;10m[49m     # Constraint 1: Maximum escalation speed.
[0m[49m[38;5;10m+     401[0m:[38;5;10m[49m     # Don't jump from lifestyle to insulin in one step. Patients need time
[0m[49m[38;5;10m+     402[0m:[38;5;10m[49m     # to adjust, and intermediate options may work.
[0m[49m[38;5;10m+     403[0m:[38;5;10m[49m     max_up = SAFETY_CONSTRAINTS["max_escalation_steps"]
[0m[49m[38;5;10m+     404[0m:[38;5;10m[49m     if safe_action > current_level + max_up:
[0m[49m[38;5;10m+     405[0m:[38;5;10m[49m         safe_action = current_level + max_up
[0m[49m[38;5;10m+     406[0m:[38;5;10m[49m         activated.append(
[0m[49m[38;5;10m+     407[0m:[38;5;10m[49m             f"max_escalation: capped at +{max_up} steps "
[0m[49m[38;5;10m+     408[0m:[38;5;10m[49m             f"(wanted {recommended_action}, got {safe_action})"
[0m[49m[38;5;10m+     409[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     410[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     411[0m:[38;5;10m[49m     # Constraint 2: Maximum de-escalation speed.
[0m[49m[38;5;10m+     412[0m:[38;5;10m[49m     # Don't drop multiple levels at once; rebound hyperglycemia is real.
[0m[49m[38;5;10m+     413[0m:[38;5;10m[49m     max_down = SAFETY_CONSTRAINTS["max_deescalation_steps"]
[0m[49m[38;5;10m+     414[0m:[38;5;10m[49m     if safe_action < current_level - max_down:
[0m[49m[38;5;10m+     415[0m:[38;5;10m[49m         safe_action = current_level - max_down
[0m[49m[38;5;10m+     416[0m:[38;5;10m[49m         activated.append(
[0m[49m[38;5;10m+     417[0m:[38;5;10m[49m             f"max_deescalation: capped at -{max_down} steps"
[0m[49m[38;5;10m+     418[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     419[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     420[0m:[38;5;10m[49m     # Constraint 3: Minimum time before changing.
[0m[49m[38;5;10m+     421[0m:[38;5;10m[49m     # HbA1c takes 3 months to reflect a treatment change. Switching sooner
[0m[49m[38;5;10m+     422[0m:[38;5;10m[49m     # means you never saw the effect of the current regimen.
[0m[49m[38;5;10m+     423[0m:[38;5;10m[49m     months_on_current = patient_data.get("months_on_current_treatment", 0)
[0m[49m[38;5;10m+     424[0m:[38;5;10m[49m     min_months = SAFETY_CONSTRAINTS["min_months_before_change"]
[0m[49m[38;5;10m+     425[0m:[38;5;10m[49m     if safe_action != current_level and months_on_current < min_months:
[0m[49m[38;5;10m+     426[0m:[38;5;10m[49m         safe_action = current_level
[0m[49m[38;5;10m+     427[0m:[38;5;10m[49m         activated.append(
[0m[49m[38;5;10m+     428[0m:[38;5;10m[49m             f"min_duration_hold: only {months_on_current} months on current "
[0m[49m[38;5;10m+     429[0m:[38;5;10m[49m             f"(need {min_months}), holding"
[0m[49m[38;5;10m+     430[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     431[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     432[0m:[38;5;10m[49m     # Constraint 4: Adherence gating.
[0m[49m[38;5;10m+     433[0m:[38;5;10m[49m     # If the patient isn't taking their current medications, adding more
[0m[49m[38;5;10m+     434[0m:[38;5;10m[49m     # medications won't help. Fix adherence first.
[0m[49m[38;5;10m+     435[0m:[38;5;10m[49m     adherence = patient_data.get("medication_adherence", 1.0)
[0m[49m[38;5;10m+     436[0m:[38;5;10m[49m     min_adherence = SAFETY_CONSTRAINTS["min_adherence_for_escalation"]
[0m[49m[38;5;10m+     437[0m:[38;5;10m[49m     if safe_action > current_level and adherence < min_adherence:
[0m[49m[38;5;10m+     438[0m:[38;5;10m[49m         safe_action = current_level
[0m[49m[38;5;10m+     439[0m:[38;5;10m[49m         activated.append(
[0m[49m[38;5;10m+     440[0m:[38;5;10m[49m             f"adherence_gate: adherence={adherence:.0%} < {min_adherence:.0%}, "
[0m[49m[38;5;10m+     441[0m:[38;5;10m[49m             f"holding (address adherence first)"
[0m[49m[38;5;10m+     442[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     443[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     444[0m:[38;5;10m[49m     # Constraint 5: Renal contraindications.
[0m[49m[38;5;10m+     445[0m:[38;5;10m[49m     egfr = patient_data.get("egfr", 90)
[0m[49m[38;5;10m+     446[0m:[38;5;10m[49m     # Metformin contraindicated below eGFR 30
[0m[49m[38;5;10m+     447[0m:[38;5;10m[49m     if safe_action >= 1 and egfr < SAFETY_CONSTRAINTS["metformin_egfr_floor"]:
[0m[49m[38;5;10m+     448[0m:[38;5;10m[49m         # Can't use metformin-containing regimens. Skip to insulin if needed.
[0m[49m[38;5;10m+     449[0m:[38;5;10m[49m         if safe_action <= 5:
[0m[49m[38;5;10m+     450[0m:[38;5;10m[49m             safe_action = 0  # Fall back to lifestyle (or direct to insulin)
[0m[49m[38;5;10m+     451[0m:[38;5;10m[49m             activated.append(
[0m[49m[38;5;10m+     452[0m:[38;5;10m[49m                 f"metformin_contraindicated: eGFR={egfr}, "
[0m[49m[38;5;10m+     453[0m:[38;5;10m[49m                 f"metformin-based regimens unavailable"
[0m[49m[38;5;10m+     454[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+     455[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     456[0m:[38;5;10m[49m     # SGLT2 less effective below eGFR 45
[0m[49m[38;5;10m+     457[0m:[38;5;10m[49m     if safe_action in [2, 5] and egfr < SAFETY_CONSTRAINTS["sglt2_egfr_floor"]:
[0m[49m[38;5;10m+     458[0m:[38;5;10m[49m         # Switch SGLT2-containing regimens to alternatives
[0m[49m[38;5;10m+     459[0m:[38;5;10m[49m         if safe_action == 2:
[0m[49m[38;5;10m+     460[0m:[38;5;10m[49m             safe_action = 3  # Use GLP-1 instead of SGLT2
[0m[49m[38;5;10m+     461[0m:[38;5;10m[49m         elif safe_action == 5:
[0m[49m[38;5;10m+     462[0m:[38;5;10m[49m             safe_action = 4  # Use DPP-4 instead of triple with SGLT2
[0m[49m[38;5;10m+     463[0m:[38;5;10m[49m         activated.append(
[0m[49m[38;5;10m+     464[0m:[38;5;10m[49m             f"sglt2_renal_limit: eGFR={egfr}, SGLT2 less effective, "
[0m[49m[38;5;10m+     465[0m:[38;5;10m[49m             f"switched to alternative"
[0m[49m[38;5;10m+     466[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     467[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     468[0m:[38;5;10m[49m     # Constraint 6: Insulin avoidance in elderly with hypo history.
[0m[49m[38;5;10m+     469[0m:[38;5;10m[49m     age = patient_data.get("age", 50)
[0m[49m[38;5;10m+     470[0m:[38;5;10m[49m     severe_hypo = patient_data.get("severe_hypo_ever", 0)
[0m[49m[38;5;10m+     471[0m:[38;5;10m[49m     if safe_action >= 6 and age > SAFETY_CONSTRAINTS["insulin_age_hypo_limit"] and severe_hypo:
[0m[49m[38;5;10m+     472[0m:[38;5;10m[49m         safe_action = min(safe_action, 5)  # Cap at maximum oral therapy
[0m[49m[38;5;10m+     473[0m:[38;5;10m[49m         activated.append(
[0m[49m[38;5;10m+     474[0m:[38;5;10m[49m             f"insulin_safety_cap: age={age}, severe hypo history, "
[0m[49m[38;5;10m+     475[0m:[38;5;10m[49m             f"avoiding insulin regimens"
[0m[49m[38;5;10m+     476[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     477[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     478[0m:[38;5;10m[49m     # Constraint 7: Don't escalate if already at target.
[0m[49m[38;5;10m+     479[0m:[38;5;10m[49m     if SAFETY_CONSTRAINTS["no_escalation_at_target"]:
[0m[49m[38;5;10m+     480[0m:[38;5;10m[49m         hba1c = patient_data.get("hba1c_current", 7.0)
[0m[49m[38;5;10m+     481[0m:[38;5;10m[49m         target = compute_individualized_target(patient_data)
[0m[49m[38;5;10m+     482[0m:[38;5;10m[49m         if safe_action > current_level and hba1c <= target + 0.3:
[0m[49m[38;5;10m+     483[0m:[38;5;10m[49m             safe_action = current_level
[0m[49m[38;5;10m+     484[0m:[38;5;10m[49m             activated.append(
[0m[49m[38;5;10m+     485[0m:[38;5;10m[49m                 f"at_target_hold: HbA1c={hba1c:.1f}% within target "
[0m[49m[38;5;10m+     486[0m:[38;5;10m[49m                 f"({target:.1f}%), no escalation needed"
[0m[49m[38;5;10m+     487[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+     488[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     489[0m:[38;5;10m[49m     # Floor at 0 (can't go below lifestyle only)
[0m[49m[38;5;10m+     490[0m:[38;5;10m[49m     safe_action = max(0, safe_action)
[0m[49m[38;5;10m+     491[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     492[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     493[0m:[38;5;10m[49m         "final_action": safe_action,
[0m[49m[38;5;10m+     494[0m:[38;5;10m[49m         "final_treatment": TREATMENT_ACTIONS[safe_action]["name"],
[0m[49m[38;5;10m+     495[0m:[38;5;10m[49m         "original_recommendation": recommended_action,
[0m[49m[38;5;10m+     496[0m:[38;5;10m[49m         "original_treatment": TREATMENT_ACTIONS[recommended_action]["name"],
[0m[49m[38;5;10m+     497[0m:[38;5;10m[49m         "constraints_activated": activated,
[0m[49m[38;5;10m+     498[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     499[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     500[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     501[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     502[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     503[0m:[38;5;10m[49m ## Step 4: Episode Construction from Longitudinal Records
[0m[49m[38;5;10m+     504[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     505[0m:[38;5;10m[49m *Transforms years of patient treatment history into RL episodes. This is where chronic disease RL gets hard: you're working with sparse, irregularly-spaced observations over multi-year horizons. A single patient might have 20 quarterly observations spanning 5 years of treatment.*
[0m[49m[38;5;10m+     506[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     507[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     508[0m:[38;5;10m[49m def build_episode_from_patient_history(patient_record: dict) -> list:
[0m[49m[38;5;10m+     509[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     510[0m:[38;5;10m[49m     Convert a patient's longitudinal diabetes record into an RL episode.
