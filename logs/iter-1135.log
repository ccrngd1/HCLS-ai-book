[0m[49m[38;5;10m+     545[0m:[38;5;10m[49m         next_visit = visits[i + 1]
[0m[49m[38;5;10m+     546[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     547[0m:[38;5;10m[49m         # Build state from current visit
[0m[49m[38;5;10m+     548[0m:[38;5;10m[49m         hba1c_current = current_visit.get("hba1c", 7.0)
