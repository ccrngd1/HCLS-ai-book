[0m[49m[38;5;10m+    1037[0m:[38;5;10m[49m if __name__ == "__main__":
[0m[49m[38;5;10m+    1038[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    1039[0m:[38;5;10m[49m     print("DEMO: Chronic Disease Treatment Personalization")
[0m[49m[38;5;10m+    1040[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    1041[0m:[38;5;10m[49m     print("\nThis demo shows the recommendation pipeline structure.")
[0m[49m[38;5;10m+    1042[0m:[38;5;10m[49m     print("Without trained policy and AWS resources, we'll use a mock.\n")
[0m[49m[38;5;10m+    1043[0m:[38;5;10m[49m 
