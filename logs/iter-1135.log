[0m[49m[38;5;10m+    1015[0m:[38;5;10m[49m         "recommended_treatment": safe_result["final_treatment"],
[0m[49m[38;5;10m+    1016[0m:[38;5;10m[49m         "treatment_change": safe_result["final_treatment"] != current_treatment,
[0m[49m[38;5;10m+    1017[0m:[38;5;10m[49m         "confidence": policy_result["confidence"],
