[0m[49m[38;5;10m+    1020[0m:[38;5;10m[49m             "hba1c_trend": f"{patient_data['hba1c_trend']:+.2f}% per quarter",
[0m[49m[38;5;10m+    1021[0m:[38;5;10m[49m             "hypo_events": visit_data.get("hypo_events", 0),
[0m[49m[38;5;10m+    1022[0m:[38;5;10m[49m             "adherence": f"{patient_data['medication_adherence']:.0%}",
[0m[49m[38;5;10m+    1023[0m:[38;5;10m[49m             "policy_raw_recommendation": policy_result["recommended_treatment"],
[0m[49m[38;5;10m+    1024[0m:[38;5;10m[49m             "constraints_activated": safe_result["constraints_activated"],
[0m[49m[38;5;10m+    1025[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    1026[0m:[38;5;10m[49m         "clinician_action": "PENDING",
[0m[49m[38;5;10m+    1027[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1028[0m:[38;5;10m[49m 
