[0m[49m[38;5;10m+     552[0m:[38;5;10m[49m         state_data = {
[0m[49m[38;5;10m+     553[0m:[38;5;10m[49m             "hba1c_current": hba1c_current,
[0m[49m[38;5;10m+     554[0m:[38;5;10m[49m             "hba1c_prev_quarter": hba1c_prev,
[0m[49m[38;5;10m+     555[0m:[38;5;10m[49m             "hba1c_trend": hba1c_trend,
[0m[49m[38;5;10m+     556[0m:[38;5;10m[49m             "hypo_events_quarter": current_visit.get("hypo_events", 0),
[0m[49m[38;5;10m+     557[0m:[38;5;10m[49m             "severe_hypo_ever": patient_info.get("severe_hypo_ever", 0),
[0m[49m[38;5;10m+     558[0m:[38;5;10m[49m             "current_treatment_level": current_visit.get("treatment_level", 0),
[0m[49m[38;5;10m+     559[0m:[38;5;10m[49m             "months_on_current_treatment": current_visit.get("months_on_treatment", 3),
[0m[49m[38;5;10m+     560[0m:[38;5;10m[49m             "age": patient_info.get("age", 55),
[0m[49m[38;5;10m+     561[0m:[38;5;10m[49m             "bmi": current_visit.get("bmi", 28),
[0m[49m[38;5;10m+     562[0m:[38;5;10m[49m             "egfr": current_visit.get("egfr", 80),
[0m[49m[38;5;10m+     563[0m:[38;5;10m[49m             "cardiovascular_risk": patient_info.get("cv_risk", 0),
[0m[49m[38;5;10m+     564[0m:[38;5;10m[49m             "heart_failure": patient_info.get("heart_failure", 0),
[0m[49m[38;5;10m+     565[0m:[38;5;10m[49m             "medication_adherence": current_visit.get("adherence", 0.8),
[0m[49m[38;5;10m+     566[0m:[38;5;10m[49m             "appointment_adherence": patient_info.get("appt_adherence", 0.9),
[0m[49m[38;5;10m+     567[0m:[38;5;10m[49m             "comorbidity_count": patient_info.get("comorbidity_count", 2),
[0m[49m[38;5;10m+     568[0m:[38;5;10m[49m             "diabetes_duration_years": patient_info.get("diabetes_duration", 5),
[0m[49m[38;5;10m+     569[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+     570[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     571[0m:[38;5;10m[49m         state_vector = construct_state_vector(state_data)
[0m[49m[38;5;10m+     572[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     573[0m:[38;5;10m[49m         # Action: what treatment the clinician chose at this visit
[0m[49m[38;5;10m+     574[0m:[38;5;10m[49m         action = current_visit.get("treatment_level", 0)
[0m[49m[38;5;10m+     575[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     576[0m:[38;5;10m[49m         # Reward: based on outcome at the NEXT visit
[0m[49m[38;5;10m+     577[0m:[38;5;10m[49m         # This is the key temporal structure: the reward for today's decision
[0m[49m[38;5;10m+     578[0m:[38;5;10m[49m         # isn't observed until 3 months later.
[0m[49m[38;5;10m+     579[0m:[38;5;10m[49m         target = compute_individualized_target(state_data)
[0m[49m[38;5;10m+     580[0m:[38;5;10m[49m         next_hba1c = next_visit.get("hba1c", 7.0)
[0m[49m[38;5;10m+     581[0m:[38;5;10m[49m         next_hypo = next_visit.get("hypo_events", 0)
[0m[49m[38;5;10m+     582[0m:[38;5;10m[49m         next_severe = next_visit.get("severe_hypo", False)
[0m[49m[38;5;10m+     583[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     584[0m:[38;5;10m[49m         reward = compute_reward(
[0m[49m[38;5;10m+     585[0m:[38;5;10m[49m             hba1c=next_hba1c,
[0m[49m[38;5;10m+     586[0m:[38;5;10m[49m             target_hba1c=target,
[0m[49m[38;5;10m+     587[0m:[38;5;10m[49m             hypo_events=next_hypo,
[0m[49m[38;5;10m+     588[0m:[38;5;10m[49m             severe_hypo=next_severe,
[0m[49m[38;5;10m+     589[0m:[38;5;10m[49m             treatment_level=action,
[0m[49m[38;5;10m+     590[0m:[38;5;10m[49m             previous_treatment_level=prev_visit.get("treatment_level", 0),
[0m[49m[38;5;10m+     591[0m:[38;5;10m[49m             adherence=current_visit.get("adherence", 0.8),
[0m[49m[38;5;10m+     592[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     593[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     594[0m:[38;5;10m[49m         # Next state
[0m[49m[38;5;10m+     595[0m:[38;5;10m[49m         next_state_data = {
[0m[49m[38;5;10m+     596[0m:[38;5;10m[49m             **state_data,
[0m[49m[38;5;10m+     597[0m:[38;5;10m[49m             "hba1c_current": next_hba1c,
[0m[49m[38;5;10m+     598[0m:[38;5;10m[49m             "hba1c_prev_quarter": hba1c_current,
[0m[49m[38;5;10m+     599[0m:[38;5;10m[49m             "hba1c_trend": (next_hba1c - hba1c_current) / DECISION_INTERVAL_MONTHS,
[0m[49m[38;5;10m+     600[0m:[38;5;10m[49m             "hypo_events_quarter": next_hypo,
[0m[49m[38;5;10m+     601[0m:[38;5;10m[49m             "current_treatment_level": action,
[0m[49m[38;5;10m+     602[0m:[38;5;10m[49m             "months_on_current_treatment": next_visit.get("months_on_treatment", 3),
[0m[49m[38;5;10m+     603[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+     604[0m:[38;5;10m[49m         next_state_vector = construct_state_vector(next_state_data)
[0m[49m[38;5;10m+     605[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     606[0m:[38;5;10m[49m         episode.append({
