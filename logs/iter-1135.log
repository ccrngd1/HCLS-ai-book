[0m[49m[38;5;10m+    1030[0m:[38;5;10m[49m     print(f"\n  RECOMMENDATION: {safe_result['final_treatment']} ({change_str})")
[0m[49m[38;5;10m+    1031[0m:[38;5;10m[49m     print(f"{'='*60}\n")
