[0m[49m[38;5;10m+     614[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     615[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     616[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     617[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     618[0m:[38;5;10m[49m ## Step 5: Offline RL Training (Batch-Constrained Q-Learning)
[0m[49m[38;5;10m+     619[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     620[0m:[38;5;10m[49m *Chronic disease RL must learn entirely from historical treatment records. You cannot explore on patients. Batch-Constrained Q-Learning (BCQ) addresses this by restricting the learned policy to only recommend actions that clinicians have actually taken in similar states. This prevents the agent from recommending untested treatment combinations.*
[0m[49m[38;5;10m+     621[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     622[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     623[0m:[38;5;10m[49m def train_bcq_policy(
[0m[49m[38;5;10m+     624[0m:[38;5;10m[49m     episodes: list,
[0m[49m[38;5;10m+     625[0m:[38;5;10m[49m     num_iterations: int = 15000,
[0m[49m[38;5;10m+     626[0m:[38;5;10m[49m     batch_size: int = 128,
[0m[49m[38;5;10m+     627[0m:[38;5;10m[49m     discount: float = 0.95,
[0m[49m[38;5;10m+     628[0m:[38;5;10m[49m     bcq_threshold: float = 0.3,
[0m[49m[38;5;10m+     629[0m:[38;5;10m[49m     learning_rate: float = 1e-3,
[0m[49m[38;5;10m+     630[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+     631[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     632[0m:[38;5;10m[49m     Train a Batch-Constrained Q-Learning policy from historical episodes.
[0m[49m[38;5;10m+     633[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     634[0m:[38;5;10m[49m     BCQ is particularly appropriate for chronic disease because:
[0m[49m[38;5;10m+     635[0m:[38;5;10m[49m     1. The action space is small (8 treatment options) and discrete
[0m[49m[38;5;10m+     636[0m:[38;5;10m[49m     2. Historical data has good coverage of common transitions
[0m[49m[38;5;10m+     637[0m:[38;5;10m[49m     3. We want to stay close to established clinical practice
[0m[49m[38;5;10m+     638[0m:[38;5;10m[49m     4. The consequences of untested actions unfold over months (no quick recovery)
[0m[49m[38;5;10m+     639[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     640[0m:[38;5;10m[49m     The bcq_threshold parameter controls how much the policy can deviate from
[0m[49m[38;5;10m+     641[0m:[38;5;10m[49m     historical behavior:
[0m[49m[38;5;10m+     642[0m:[38;5;10m[49m     - High threshold (0.5+): only recommend actions taken >= 50% of the time
[0m[49m[38;5;10m+     643[0m:[38;5;10m[49m       in similar states. Very conservative.
[0m[49m[38;5;10m+     644[0m:[38;5;10m[49m     - Low threshold (0.1): willing to recommend less common actions if Q-values
[0m[49m[38;5;10m+     645[0m:[38;5;10m[49m       support them. More aggressive.
[0m[49m[38;5;10m+     646[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     647[0m:[38;5;10m[49m     For chronic disease, start conservative. Clinicians have decades of
[0m[49m[38;5;10m+     648[0m:[38;5;10m[49m     experience encoded in their treatment patterns.
[0m[49m[38;5;10m+     649[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     650[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     651[0m:[38;5;10m[49m         episodes: List of episode dicts from build_episode_from_patient_history.
[0m[49m[38;5;10m+     652[0m:[38;5;10m[49m         num_iterations: Training iterations.
[0m[49m[38;5;10m+     653[0m:[38;5;10m[49m         batch_size: Transitions per batch.
[0m[49m[38;5;10m+     654[0m:[38;5;10m[49m         discount: Future reward discount. Lower than acute care (0.95 vs 0.99)
[0m[49m[38;5;10m+     655[0m:[38;5;10m[49m                   because distant outcomes are less certain in chronic disease.
[0m[49m[38;5;10m+     656[0m:[38;5;10m[49m         bcq_threshold: Minimum historical action frequency to consider.
[0m[49m[38;5;10m+     657[0m:[38;5;10m[49m         learning_rate: Step size.
[0m[49m[38;5;10m+     658[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     659[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     660[0m:[38;5;10m[49m         Dict with Q-table and action frequency table (for BCQ filtering).
[0m[49m[38;5;10m+     661[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     662[0m:[38;5;10m[49m     # Flatten episodes into replay buffer
[0m[49m[38;5;10m+     663[0m:[38;5;10m[49m     replay_buffer = []
[0m[49m[38;5;10m+     664[0m:[38;5;10m[49m     for ep in episodes:
[0m[49m[38;5;10m+     665[0m:[38;5;10m[49m         for transition in ep:
[0m[49m[38;5;10m+     666[0m:[38;5;10m[49m             replay_buffer.append(transition)
[0m[49m[38;5;10m+     667[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     668[0m:[38;5;10m[49m     if not replay_buffer:
[0m[49m[38;5;10m+     669[0m:[38;5;10m[49m         raise ValueError("Empty replay buffer. Check episode construction.")
[0m[49m[38;5;10m+     670[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     671[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+     672[0m:[38;5;10m[49m         "Training BCQ: %d transitions, %d iterations, threshold=%.2f",
[0m[49m[38;5;10m+     673[0m:[38;5;10m[49m         len(replay_buffer), num_iterations, bcq_threshold,
[0m[49m[38;5;10m+     674[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     675[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     676[0m:[38;5;10m[49m     # Tabular implementation (production would use neural networks).
[0m[49m[38;5;10m+     677[0m:[38;5;10m[49m     # Discretize state into bins using key features.
[0m[49m[38;5;10m+     678[0m:[38;5;10m[49m     N_BINS = 8
[0m[49m[38;5;10m+     679[0m:[38;5;10m[49m     q_table = np.zeros((N_BINS ** 3, NUM_ACTIONS))
[0m[49m[38;5;10m+     680[0m:[38;5;10m[49m     # Track action frequencies per state bin (for BCQ constraint)
[0m[49m[38;5;10m+     681[0m:[38;5;10m[49m     action_counts = np.zeros((N_BINS ** 3, NUM_ACTIONS))
[0m[49m[38;5;10m+     682[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     683[0m:[38;5;10m[49m     # First pass: count action frequencies in each state region.
[0m[49m[38;5;10m+     684[0m:[38;5;10m[49m     # This tells us what clinicians actually did in similar situations.
[0m[49m[38;5;10m+     685[0m:[38;5;10m[49m     for transition in replay_buffer:
[0m[49m[38;5;10m+     686[0m:[38;5;10m[49m         state = np.array(transition["state"])
[0m[49m[38;5;10m+     687[0m:[38;5;10m[49m         action = transition["action"]
[0m[49m[38;5;10m+     688[0m:[38;5;10m[49m         state_idx = _state_to_index(state, N_BINS)
[0m[49m[38;5;10m+     689[0m:[38;5;10m[49m         action_counts[state_idx, action] += 1
[0m[49m[38;5;10m+     690[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     691[0m:[38;5;10m[49m     # Normalize to frequencies
[0m[49m[38;5;10m+     692[0m:[38;5;10m[49m     action_freq = np.zeros_like(action_counts)
[0m[49m[38;5;10m+     693[0m:[38;5;10m[49m     for s in range(action_counts.shape[0]):
[0m[49m[38;5;10m+     694[0m:[38;5;10m[49m         total = action_counts[s].sum()
[0m[49m[38;5;10m+     695[0m:[38;5;10m[49m         if total > 0:
[0m[49m[38;5;10m+     696[0m:[38;5;10m[49m             action_freq[s] = action_counts[s] / total
[0m[49m[38;5;10m+     697[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     698[0m:[38;5;10m[49m     # Training loop
[0m[49m[38;5;10m+     699[0m:[38;5;10m[49m     for iteration in range(num_iterations):
[0m[49m[38;5;10m+     700[0m:[38;5;10m[49m         indices = np.random.randint(0, len(replay_buffer), size=batch_size)
[0m[49m[38;5;10m+     701[0m:[38;5;10m[49m         batch = [replay_buffer[i] for i in indices]
[0m[49m[38;5;10m+     702[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     703[0m:[38;5;10m[49m         for transition in batch:
[0m[49m[38;5;10m+     704[0m:[38;5;10m[49m             state = np.array(transition["state"])
[0m[49m[38;5;10m+     705[0m:[38;5;10m[49m             action = transition["action"]
[0m[49m[38;5;10m+     706[0m:[38;5;10m[49m             reward = transition["reward"]
[0m[49m[38;5;10m+     707[0m:[38;5;10m[49m             next_state = np.array(transition["next_state"])
[0m[49m[38;5;10m+     708[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     709[0m:[38;5;10m[49m             state_idx = _state_to_index(state, N_BINS)
[0m[49m[38;5;10m+     710[0m:[38;5;10m[49m             next_state_idx = _state_to_index(next_state, N_BINS)
[0m[49m[38;5;10m+     711[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     712[0m:[38;5;10m[49m             # BCQ constraint: only consider actions with sufficient historical
[0m[49m[38;5;10m+     713[0m:[38;5;10m[49m             # frequency in the next state when computing the target.
[0m[49m[38;5;10m+     714[0m:[38;5;10m[49m             # This prevents bootstrapping from unseen state-action pairs.
[0m[49m[38;5;10m+     715[0m:[38;5;10m[49m             valid_actions = action_freq[next_state_idx] >= bcq_threshold
[0m[49m[38;5;10m+     716[0m:[38;5;10m[49m             if not valid_actions.any():
[0m[49m[38;5;10m+     717[0m:[38;5;10m[49m                 # Fallback: use all actions if none meet threshold
[0m[49m[38;5;10m+     718[0m:[38;5;10m[49m                 valid_actions = np.ones(NUM_ACTIONS, dtype=bool)
[0m[49m[38;5;10m+     719[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     720[0m:[38;5;10m[49m             # Masked max: only consider valid actions for the Bellman target
[0m[49m[38;5;10m+     721[0m:[38;5;10m[49m             masked_q = np.where(valid_actions, q_table[next_state_idx], -np.inf)
[0m[49m[38;5;10m+     722[0m:[38;5;10m[49m             next_q_max = np.max(masked_q)
[0m[49m[38;5;10m+     723[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     724[0m:[38;5;10m[49m             # Standard Q-learning update with BCQ-filtered target
[0m[49m[38;5;10m+     725[0m:[38;5;10m[49m             td_target = reward + discount * next_q_max
[0m[49m[38;5;10m+     726[0m:[38;5;10m[49m             q_table[state_idx, action] += learning_rate * (
[0m[49m[38;5;10m+     727[0m:[38;5;10m[49m                 td_target - q_table[state_idx, action]
[0m[49m[38;5;10m+     728[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+     729[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     730[0m:[38;5;10m[49m     logger.info("BCQ training complete. Q-table shape: %s", q_table.shape)
[0m[49m[38;5;10m+     731[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     732[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     733[0m:[38;5;10m[49m         "q_table": q_table,
[0m[49m[38;5;10m+     734[0m:[38;5;10m[49m         "action_freq": action_freq,
[0m[49m[38;5;10m+     735[0m:[38;5;10m[49m         "n_bins": N_BINS,
[0m[49m[38;5;10m+     736[0m:[38;5;10m[49m         "bcq_threshold": bcq_threshold,
[0m[49m[38;5;10m+     737[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     738[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     739[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     740[0m:[38;5;10m[49m def _state_to_index(state_vector: np.ndarray, n_bins: int) -> int:
[0m[49m[38;5;10m+     741[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     742[0m:[38;5;10m[49m     Discretize state to table index using key features:
[0m[49m[38;5;10m+     743[0m:[38;5;10m[49m     - Feature 0: hba1c_current
[0m[49m[38;5;10m+     744[0m:[38;5;10m[49m     - Feature 5: current_treatment_level
[0m[49m[38;5;10m+     745[0m:[38;5;10m[49m     - Feature 12: medication_adherence
[0m[49m[38;5;10m+     746[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     747[0m:[38;5;10m[49m     These three features capture the core decision context:
[0m[49m[38;5;10m+     748[0m:[38;5;10m[49m     how controlled is the patient, what are they on, and are they taking it.
[0m[49m[38;5;10m+     749[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     750[0m:[38;5;10m[49m     key_features = [state_vector[0], state_vector[5], state_vector[12]]
[0m[49m[38;5;10m+     751[0m:[38;5;10m[49m     bins = np.clip(
[0m[49m[38;5;10m+     752[0m:[38;5;10m[49m         (np.array(key_features) * n_bins).astype(int), 0, n_bins - 1
[0m[49m[38;5;10m+     753[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     754[0m:[38;5;10m[49m     return int(bins[0] * n_bins * n_bins + bins[1] * n_bins + bins[2])
[0m[49m[38;5;10m+     755[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     756[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     757[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     758[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     759[0m:[38;5;10m[49m ## Step 6: Off-Policy Evaluation
[0m[49m[38;5;10m+     760[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     761[0m:[38;5;10m[49m *Before any policy touches a patient, you need to estimate how it would have performed historically. For chronic disease, this is especially important because you can't run a quick A/B test: outcomes take months to observe.*
[0m[49m[38;5;10m+     762[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     763[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     764[0m:[38;5;10m[49m def evaluate_policy_offline(
[0m[49m[38;5;10m+     765[0m:[38;5;10m[49m     policy: dict,
[0m[49m[38;5;10m+     766[0m:[38;5;10m[49m     test_episodes: list,
[0m[49m[38;5;10m+     767[0m:[38;5;10m[49m     discount: float = 0.95,
[0m[49m[38;5;10m+     768[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+     769[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     770[0m:[38;5;10m[49m     Estimate learned policy performance using weighted importance sampling.
[0m[49m[38;5;10m+     771[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     772[0m:[38;5;10m[49m     For chronic disease RL, we care about:
[0m[49m[38;5;10m+     773[0m:[38;5;10m[49m     1. Estimated HbA1c distribution under the learned policy
[0m[49m[38;5;10m+     774[0m:[38;5;10m[49m     2. Estimated hypoglycemia rate
[0m[49m[38;5;10m+     775[0m:[38;5;10m[49m     3. Treatment complexity (are we recommending simpler regimens?)
[0m[49m[38;5;10m+     776[0m:[38;5;10m[49m     4. Agreement rate with clinicians (how often does the policy agree?)
[0m[49m[38;5;10m+     777[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     778[0m:[38;5;10m[49m     High agreement with clinicians is actually a good sign for a conservative
[0m[49m[38;5;10m+     779[0m:[38;5;10m[49m     policy. It means the policy learned that clinicians are mostly right,
[0m[49m[38;5;10m+     780[0m:[38;5;10m[49m     and only deviates where the data strongly supports a different choice.
[0m[49m[38;5;10m+     781[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     782[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     783[0m:[38;5;10m[49m         policy: Trained policy dict from train_bcq_policy.
[0m[49m[38;5;10m+     784[0m:[38;5;10m[49m         test_episodes: Held-out patient episodes.
[0m[49m[38;5;10m+     785[0m:[38;5;10m[49m         discount: Reward discount factor.
[0m[49m[38;5;10m+     786[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     787[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     788[0m:[38;5;10m[49m         Dict with evaluation metrics.
[0m[49m[38;5;10m+     789[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     790[0m:[38;5;10m[49m     q_table = policy["q_table"]
[0m[49m[38;5;10m+     791[0m:[38;5;10m[49m     action_freq = policy["action_freq"]
[0m[49m[38;5;10m+     792[0m:[38;5;10m[49m     n_bins = policy["n_bins"]
[0m[49m[38;5;10m+     793[0m:[38;5;10m[49m     threshold = policy["bcq_threshold"]
[0m[49m[38;5;10m+     794[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     795[0m:[38;5;10m[49m     agreement_count = 0
[0m[49m[38;5;10m+     796[0m:[38;5;10m[49m     total_decisions = 0
[0m[49m[38;5;10m+     797[0m:[38;5;10m[49m     policy_actions = []
[0m[49m[38;5;10m+     798[0m:[38;5;10m[49m     clinician_actions = []
[0m[49m[38;5;10m+     799[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     800[0m:[38;5;10m[49m     for ep in test_episodes:
[0m[49m[38;5;10m+     801[0m:[38;5;10m[49m         for transition in ep:
[0m[49m[38;5;10m+     802[0m:[38;5;10m[49m             state = np.array(transition["state"])
[0m[49m[38;5;10m+     803[0m:[38;5;10m[49m             clinician_action = transition["action"]
[0m[49m[38;5;10m+     804[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     805[0m:[38;5;10m[49m             state_idx = _state_to_index(state, n_bins)
[0m[49m[38;5;10m+     806[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     807[0m:[38;5;10m[49m             # BCQ-filtered action selection
[0m[49m[38;5;10m+     808[0m:[38;5;10m[49m             valid = action_freq[state_idx] >= threshold
[0m[49m[38;5;10m+     809[0m:[38;5;10m[49m             if not valid.any():
[0m[49m[38;5;10m+     810[0m:[38;5;10m[49m                 valid = np.ones(NUM_ACTIONS, dtype=bool)
[0m[49m[38;5;10m+     811[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     812[0m:[38;5;10m[49m             masked_q = np.where(valid, q_table[state_idx], -np.inf)
[0m[49m[38;5;10m+     813[0m:[38;5;10m[49m             policy_action = int(np.argmax(masked_q))
[0m[49m[38;5;10m+     814[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     815[0m:[38;5;10m[49m             policy_actions.append(policy_action)
[0m[49m[38;5;10m+     816[0m:[38;5;10m[49m             clinician_actions.append(clinician_action)
[0m[49m[38;5;10m+     817[0m:[38;5;10m[49m             total_decisions += 1
[0m[49m[38;5;10m+     818[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     819[0m:[38;5;10m[49m             if policy_action == clinician_action:
[0m[49m[38;5;10m+     820[0m:[38;5;10m[49m                 agreement_count += 1
[0m[49m[38;5;10m+     821[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     822[0m:[38;5;10m[49m     agreement_rate = agreement_count / max(total_decisions, 1)
[0m[49m[38;5;10m+     823[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     824[0m:[38;5;10m[49m     # Compare average treatment intensity
[0m[49m[38;5;10m+     825[0m:[38;5;10m[49m     avg_policy_level = np.mean(policy_actions) if policy_actions else 0
[0m[49m[38;5;10m+     826[0m:[38;5;10m[49m     avg_clinician_level = np.mean(clinician_actions) if clinician_actions else 0
[0m[49m[38;5;10m+     827[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     828[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     829[0m:[38;5;10m[49m         "agreement_rate": round(agreement_rate, 3),
[0m[49m[38;5;10m+     830[0m:[38;5;10m[49m         "avg_policy_treatment_level": round(avg_policy_level, 2),
[0m[49m[38;5;10m+     831[0m:[38;5;10m[49m         "avg_clinician_treatment_level": round(avg_clinician_level, 2),
[0m[49m[38;5;10m+     832[0m:[38;5;10m[49m         "total_decisions_evaluated": total_decisions,
[0m[49m[38;5;10m+     833[0m:[38;5;10m[49m         "num_test_patients": len(test_episodes),
[0m[49m[38;5;10m+     834[0m:[38;5;10m[49m         "interpretation": (
[0m[49m[38;5;10m+     835[0m:[38;5;10m[49m             "High agreement (>0.7) means the policy learned clinician patterns well. "
[0m[49m[38;5;10m+     836[0m:[38;5;10m[49m             "Lower agreement may indicate the policy found improvement opportunities, "
[0m[49m[38;5;10m+     837[0m:[38;5;10m[49m             "but requires careful validation before trusting the deviations."
[0m[49m[38;5;10m+     838[0m:[38;5;10m[49m         ),
[0m[49m[38;5;10m+     839[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     840[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     841[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     842[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     843[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     844[0m:[38;5;10m[49m ## Step 7: Clinical Decision Support (Quarterly Visit)
[0m[49m[38;5;10m+     845[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     846[0m:[38;5;10m[49m *This is the integration point: at a quarterly diabetes visit, the system constructs the patient's current state, queries the policy, applies safety constraints, and presents a treatment recommendation for the clinician to accept, modify, or reject.*
[0m[49m[38;5;10m+     847[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     848[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     849[0m:[38;5;10m[49m # AWS clients
[0m[49m[38;5;10m+     850[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     851[0m:[38;5;10m[49m sagemaker_runtime = boto3.client("sagemaker-runtime", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     852[0m:[38;5;10m[49m state_table = dynamodb.Table(DYNAMODB_TABLE)
[0m[49m[38;5;10m+     853[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     854[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     855[0m:[38;5;10m[49m def fetch_patient_state(patient_id: str) -> dict:
[0m[49m[38;5;10m+     856[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     857[0m:[38;5;10m[49m     Retrieve the patient's longitudinal diabetes state from DynamoDB.
[0m[49m[38;5;10m+     858[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     859[0m:[38;5;10m[49m     The state table stores the patient's current clinical status, treatment
[0m[49m[38;5;10m+     860[0m:[38;5;10m[49m     history, and relevant comorbidities. Updated at each quarterly visit.
[0m[49m[38;5;10m+     861[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     862[0m:[38;5;10m[49m     response = state_table.get_item(Key={"patient_id": patient_id})
[0m[49m[38;5;10m+     863[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     864[0m:[38;5;10m[49m     if "Item" not in response:
[0m[49m[38;5;10m+     865[0m:[38;5;10m[49m         logger.warning("No state found for patient %s", patient_id)
[0m[49m[38;5;10m+     866[0m:[38;5;10m[49m         return {}
[0m[49m[38;5;10m+     867[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     868[0m:[38;5;10m[49m     item = response["Item"]
[0m[49m[38;5;10m+     869[0m:[38;5;10m[49m     # Convert Decimal to float for numpy
[0m[49m[38;5;10m+     870[0m:[38;5;10m[49m     return {k: float(v) if isinstance(v, Decimal) else v for k, v in item.items()}
[0m[49m[38;5;10m+     871[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     872[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     873[0m:[38;5;10m[49m def get_policy_recommendation(state_vector: np.ndarray, policy: dict) -> dict:
[0m[49m[38;5;10m+     874[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     875[0m:[38;5;10m[49m     Get the RL policy's treatment recommendation.
[0m[49m[38;5;10m+     876[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     877[0m:[38;5;10m[49m     In production, this calls a SageMaker endpoint hosting the trained model.
[0m[49m[38;5;10m+     878[0m:[38;5;10m[49m     For this example, we use the local Q-table directly.
[0m[49m[38;5;10m+     879[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     880[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     881[0m:[38;5;10m[49m         state_vector: Normalized state from construct_state_vector.
[0m[49m[38;5;10m+     882[0m:[38;5;10m[49m         policy: Trained policy dict (with q_table and action_freq).
[0m[49m[38;5;10m+     883[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     884[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     885[0m:[38;5;10m[49m         Dict with recommended action, treatment name, and confidence.
[0m[49m[38;5;10m+     886[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     887[0m:[38;5;10m[49m     q_table = policy["q_table"]
[0m[49m[38;5;10m+     888[0m:[38;5;10m[49m     action_freq = policy["action_freq"]
[0m[49m[38;5;10m+     889[0m:[38;5;10m[49m     n_bins = policy["n_bins"]
[0m[49m[38;5;10m+     890[0m:[38;5;10m[49m     threshold = policy["bcq_threshold"]
[0m[49m[38;5;10m+     891[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     892[0m:[38;5;10m[49m     state_idx = _state_to_index(state_vector, n_bins)
[0m[49m[38;5;10m+     893[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     894[0m:[38;5;10m[49m     # BCQ filtering: only consider historically-supported actions
[0m[49m[38;5;10m+     895[0m:[38;5;10m[49m     valid = action_freq[state_idx] >= threshold
[0m[49m[38;5;10m+     896[0m:[38;5;10m[49m     if not valid.any():
[0m[49m[38;5;10m+     897[0m:[38;5;10m[49m         valid = np.ones(NUM_ACTIONS, dtype=bool)
[0m[49m[38;5;10m+     898[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     899[0m:[38;5;10m[49m     masked_q = np.where(valid, q_table[state_idx], -np.inf)
[0m[49m[38;5;10m+     900[0m:[38;5;10m[49m     best_action = int(np.argmax(masked_q))
[0m[49m[38;5;10m+     901[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     902[0m:[38;5;10m[49m     # Confidence: gap between best and second-best valid action
[0m[49m[38;5;10m+     903[0m:[38;5;10m[49m     sorted_q = np.sort(masked_q[masked_q > -np.inf])[::-1]
[0m[49m[38;5;10m+     904[0m:[38;5;10m[49m     if len(sorted_q) > 1 and sorted_q[0] != 0:
[0m[49m[38;5;10m+     905[0m:[38;5;10m[49m         confidence = min(1.0, abs(sorted_q[0] - sorted_q[1]) / (abs(sorted_q[0]) + 1e-6))
[0m[49m[38;5;10m+     906[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+     907[0m:[38;5;10m[49m         confidence = 0.5
[0m[49m[38;5;10m+     908[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     909[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     910[0m:[38;5;10m[49m         "recommended_action": best_action,
[0m[49m[38;5;10m+     911[0m:[38;5;10m[49m         "recommended_treatment": TREATMENT_ACTIONS[best_action]["name"],
[0m[49m[38;5;10m+     912[0m:[38;5;10m[49m         "treatment_description": TREATMENT_ACTIONS[best_action]["desc"],
[0m[49m[38;5;10m+     913[0m:[38;5;10m[49m         "confidence": round(confidence, 3),
[0m[49m[38;5;10m+     914[0m:[38;5;10m[49m         "valid_actions": [
[0m[49m[38;5;10m+     915[0m:[38;5;10m[49m             TREATMENT_ACTIONS[a]["name"] for a in range(NUM_ACTIONS) if valid[a]
[0m[49m[38;5;10m+     916[0m:[38;5;10m[49m         ],
[0m[49m[38;5;10m+     917[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     918[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     919[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     920[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     921[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     922[0m:[38;5;10m[49m ## Full Pipeline: Quarterly Treatment Recommendation
[0m[49m[38;5;10m+     923[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     924[0m:[38;5;10m[49m This assembles all steps into the function called at each quarterly diabetes visit. In production, this would be triggered by the EHR when a clinician opens the patient's chart during a diabetes management visit.
[0m[49m[38;5;10m+     925[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     926[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     927[0m:[38;5;10m[49m def generate_treatment_recommendation(
[0m[49m[38;5;10m+     928[0m:[38;5;10m[49m     patient_id: str,
[0m[49m[38;5;10m+     929[0m:[38;5;10m[49m     new_hba1c: float,
[0m[49m[38;5;10m+     930[0m:[38;5;10m[49m     visit_data: dict,
[0m[49m[38;5;10m+     931[0m:[38;5;10m[49m     policy: dict,
[0m[49m[38;5;10m+     932[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+     933[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     934[0m:[38;5;10m[49m     End-to-end pipeline: quarterly visit data in, treatment recommendation out.
[0m[49m[38;5;10m+     935[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     936[0m:[38;5;10m[49m     Called when a patient arrives for their quarterly diabetes check. The
[0m[49m[38;5;10m+     937[0m:[38;5;10m[49m     clinician has just received a new HbA1c result and needs to decide
[0m[49m[38;5;10m+     938[0m:[38;5;10m[49m     whether to adjust treatment.
[0m[49m[38;5;10m+     939[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     940[0m:[38;5;10m[49m     The clinician always has the final say. This is decision support that
[0m[49m[38;5;10m+     941[0m:[38;5;10m[49m     surfaces the RL policy's suggestion alongside clinical reasoning.
[0m[49m[38;5;10m+     942[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     943[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     944[0m:[38;5;10m[49m         patient_id: Unique patient identifier.
[0m[49m[38;5;10m+     945[0m:[38;5;10m[49m         new_hba1c: New HbA1c measurement (%).
[0m[49m[38;5;10m+     946[0m:[38;5;10m[49m         visit_data: Dict with current visit observations (hypo_events, adherence, etc.)
[0m[49m[38;5;10m+     947[0m:[38;5;10m[49m         policy: Trained policy dict.
[0m[49m[38;5;10m+     948[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     949[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     950[0m:[38;5;10m[49m         Dict with recommendation, reasoning, and safety information.
[0m[49m[38;5;10m+     951[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     952[0m:[38;5;10m[49m     print(f"\n{'='*60}")
[0m[49m[38;5;10m+     953[0m:[38;5;10m[49m     print(f"CHRONIC DM RL: Quarterly visit for {patient_id}")
[0m[49m[38;5;10m+     954[0m:[38;5;10m[49m     print(f"{'='*60}")
[0m[49m[38;5;10m+     955[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     956[0m:[38;5;10m[49m     # Step 1: Fetch patient state
[0m[49m[38;5;10m+     957[0m:[38;5;10m[49m     print("\n[1/5] Fetching patient longitudinal state...")
[0m[49m[38;5;10m+     958[0m:[38;5;10m[49m     patient_data = fetch_patient_state(patient_id)
[0m[49m[38;5;10m+     959[0m:[38;5;10m[49m     if not patient_data:
[0m[49m[38;5;10m+     960[0m:[38;5;10m[49m         print("  WARNING: No prior state. Using visit data as baseline.")
[0m[49m[38;5;10m+     961[0m:[38;5;10m[49m         patient_data = {"hba1c_current": new_hba1c, "current_treatment_level": 0}
[0m[49m[38;5;10m+     962[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     963[0m:[38;5;10m[49m     # Step 2: Update state with new visit data
[0m[49m[38;5;10m+     964[0m:[38;5;10m[49m     print(f"[2/5] Updating state: new HbA1c = {new_hba1c}%")
[0m[49m[38;5;10m+     965[0m:[38;5;10m[49m     patient_data["hba1c_prev_quarter"] = patient_data.get("hba1c_current", new_hba1c)
[0m[49m[38;5;10m+     966[0m:[38;5;10m[49m     patient_data["hba1c_current"] = new_hba1c
[0m[49m[38;5;10m+     967[0m:[38;5;10m[49m     patient_data["hba1c_trend"] = (
[0m[49m[38;5;10m+     968[0m:[38;5;10m[49m         (new_hba1c - patient_data["hba1c_prev_quarter"]) / DECISION_INTERVAL_MONTHS
[0m[49m[38;5;10m+     969[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     970[0m:[38;5;10m[49m     # Merge visit observations
[0m[49m[38;5;10m+     971[0m:[38;5;10m[49m     patient_data.update({
[0m[49m[38;5;10m+     972[0m:[38;5;10m[49m         "hypo_events_quarter": visit_data.get("hypo_events", 0),
[0m[49m[38;5;10m+     973[0m:[38;5;10m[49m         "medication_adherence": visit_data.get("adherence", 0.8),
[0m[49m[38;5;10m+     974[0m:[38;5;10m[49m         "egfr": visit_data.get("egfr", patient_data.get("egfr", 80)),
[0m[49m[38;5;10m+     975[0m:[38;5;10m[49m         "bmi": visit_data.get("bmi", patient_data.get("bmi", 28)),
[0m[49m[38;5;10m+     976[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+     977[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     978[0m:[38;5;10m[49m     # Step 3: Compute individualized target
[0m[49m[38;5;10m+     979[0m:[38;5;10m[49m     target = compute_individualized_target(patient_data)
[0m[49m[38;5;10m+     980[0m:[38;5;10m[49m     print(f"  Individualized HbA1c target: {target}%")
[0m[49m[38;5;10m+     981[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     982[0m:[38;5;10m[49m     # Step 4: Construct state vector and get policy recommendation
[0m[49m[38;5;10m+     983[0m:[38;5;10m[49m     print("[3/5] Constructing state vector and querying policy...")
[0m[49m[38;5;10m+     984[0m:[38;5;10m[49m     state_vector = construct_state_vector(patient_data)
[0m[49m[38;5;10m+     985[0m:[38;5;10m[49m     policy_result = get_policy_recommendation(state_vector, policy)
[0m[49m[38;5;10m+     986[0m:[38;5;10m[49m     print(
[0m[49m[38;5;10m+     987[0m:[38;5;10m[49m         f"  Policy recommends: {policy_result['recommended_treatment']} "
[0m[49m[38;5;10m+     988[0m:[38;5;10m[49m         f"(confidence: {policy_result['confidence']})"
[0m[49m[38;5;10m+     989[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     990[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     991[0m:[38;5;10m[49m     # Step 5: Apply safety constraints
[0m[49m[38;5;10m+     992[0m:[38;5;10m[49m     print("[4/5] Applying safety constraints...")
[0m[49m[38;5;10m+     993[0m:[38;5;10m[49m     safe_result = apply_safety_constraints(
[0m[49m[38;5;10m+     994[0m:[38;5;10m[49m         policy_result["recommended_action"], patient_data
[0m[49m[38;5;10m+     995[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     996[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     997[0m:[38;5;10m[49m     if safe_result["constraints_activated"]:
[0m[49m[38;5;10m+     998[0m:[38;5;10m[49m         for constraint in safe_result["constraints_activated"]:
[0m[49m[38;5;10m+     999[0m:[38;5;10m[49m             print(f"  CONSTRAINT: {constraint}")
[0m[49m[38;5;10m+    1000[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    1001[0m:[38;5;10m[49m         print("  No constraints activated.")
[0m[49m[38;5;10m+    1002[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1003[0m:[38;5;10m[49m     # Step 6: Package recommendation
[0m[49m[38;5;10m+    1004[0m:[38;5;10m[49m     print("[5/5] Packaging recommendation...")
[0m[49m[38;5;10m+    1005[0m:[38;5;10m[49m     current_treatment = TREATMENT_ACTIONS[
[0m[49m[38;5;10m+    1006[0m:[38;5;10m[49m         int(patient_data.get("current_treatment_level", 0))
[0m[49m[38;5;10m+    1007[0m:[38;5;10m[49m     ]["name"]
[0m[49m[38;5;10m+    1008[0m:[38;5;10m[49m 
