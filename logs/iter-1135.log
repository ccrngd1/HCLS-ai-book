[0m[49m[38;5;10m+     519[0m:[38;5;10m[49m     - Irregular visit spacing (not everyone comes back in exactly 3 months)
[0m[49m[38;5;10m+     520[0m:[38;5;10m[49m     - Missing labs (HbA1c not drawn every visit)
[0m[49m[38;5;10m+     521[0m:[38;5;10m[49m     - Treatment changes between visits (patient stopped meds on their own)
[0m[49m[38;5;10m+     522[0m:[38;5;10m[49m     - Confounders (patient started exercising AND changed meds)
[0m[49m[38;5;10m+     523[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     524[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     525[0m:[38;5;10m[49m         patient_record: Dict with keys:
[0m[49m[38;5;10m+     526[0m:[38;5;10m[49m             - "visits": list of quarterly visit records, each containing:
[0m[49m[38;5;10m+     527[0m:[38;5;10m[49m                 - "hba1c", "hypo_events", "treatment_level", "adherence",
[0m[49m[38;5;10m+     528[0m:[38;5;10m[49m                   "egfr", "bmi", "age", "comorbidities", etc.
[0m[49m[38;5;10m+     529[0m:[38;5;10m[49m             - "patient_info": static demographics
[0m[49m[38;5;10m+     530[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     531[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     532[0m:[38;5;10m[49m         List of transition dicts: {state, action, reward, next_state}
[0m[49m[38;5;10m+     533[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     534[0m:[38;5;10m[49m     visits = patient_record.get("visits", [])
[0m[49m[38;5;10m+     535[0m:[38;5;10m[49m     patient_info = patient_record.get("patient_info", {})
[0m[49m[38;5;10m+     536[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     537[0m:[38;5;10m[49m     if len(visits) < 3:
[0m[49m[38;5;10m+     538[0m:[38;5;10m[49m         return []  # Need at least 3 visits for state + action + outcome
[0m[49m[38;5;10m+     539[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     540[0m:[38;5;10m[49m     episode = []
[0m[49m[38;5;10m+     541[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     542[0m:[38;5;10m[49m     for i in range(1, len(visits) - 1):
[0m[49m[38;5;10m+     543[0m:[38;5;10m[49m         prev_visit = visits[i - 1]
