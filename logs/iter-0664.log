[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m     logger.info("Features: %d (reduced to %d PCA components)", len(feature_cols), X_reduced.shape[1])
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m     logger.info("Optimal K: %d", best_k)
