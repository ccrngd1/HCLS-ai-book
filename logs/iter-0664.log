[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m     for _ in range(subtype_sizes[0]):
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m         records.append({
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m             "age": rng.normal(62, 8),
