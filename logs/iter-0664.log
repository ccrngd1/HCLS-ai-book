[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m             "bnp": rng.normal(800, 300),
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m             "creatinine": rng.normal(0.9, 0.2),  # normal kidneys
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m             "hemoglobin": rng.normal(14.0, 1.2),  # normal
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m             "hba1c": rng.normal(5.5, 0.4),  # not diabetic
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m             "sodium": rng.normal(139, 2),
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m             "potassium": rng.normal(4.2, 0.3),
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m             "heart_rate": rng.normal(85, 15),
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m             "systolic_bp": rng.normal(118, 12),
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m             "has_diabetes": 0,
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m             "has_hypertension": rng.choice([0, 1], p=[0.75, 0.25]),
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m             "has_cad": 0,
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m             "has_ckd": 0,
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m             "has_afib": rng.choice([0, 1], p=[0.7, 0.3]),
