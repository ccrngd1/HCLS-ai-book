[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m             "sodium": rng.normal(134, 4),  # slightly low
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m             "potassium": rng.normal(4.8, 0.6),
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m             "heart_rate": rng.normal(72, 10),
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m             "systolic_bp": rng.normal(130, 20),
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m             "has_diabetes": rng.choice([0, 1], p=[0.4, 0.6]),
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m             "has_hypertension": rng.choice([0, 1], p=[0.15, 0.85]),
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m             "has_cad": rng.choice([0, 1], p=[0.4, 0.6]),
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m             "has_ckd": 1,
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m             "has_afib": rng.choice([0, 1], p=[0.3, 0.7]),
