[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m     logger.info("Generated synthetic cohort: %d patients, %d features", len(df), len(df.columns) - 1)
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m     return df
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m ## Step 2: Preprocess and Reduce Dimensions
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m *Maps to pseudocode Steps 2-3. Standardize features so clustering isn't dominated by high-magnitude variables, then apply PCA to reduce dimensionality while preserving meaningful variance.*
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m def preprocess_and_reduce(df, variance_threshold=VARIANCE_THRESHOLD):
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m     Standardize features and apply PCA for dimensionality reduction.
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m     Why standardize? BNP ranges from 0 to 5000+. Ejection fraction ranges
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m     from 5 to 75. Without scaling, BNP would dominate every distance
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m     calculation and you'd find "BNP subtypes" rather than meaningful phenotypes.
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m     Why PCA? With 18 features, clustering works fine directly. But in a real
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m     scenario with 50-100 features, the curse of dimensionality makes distance
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m     metrics unreliable. PCA compresses to the directions of maximum variance.
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m     # Separate features from the ground truth label (which we won't use for clustering)
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m     feature_cols = [c for c in df.columns if c != "true_subtype"]
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m     X = df[feature_cols].values
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m     # Standardize: zero mean, unit variance for each feature
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m     scaler = StandardScaler()
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m     X_scaled = scaler.fit_transform(X)
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m     # PCA: find how many components capture the target variance
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m     pca = PCA(random_state=RANDOM_SEED)
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m     pca.fit(X_scaled)
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m     cumulative_variance = np.cumsum(pca.explained_variance_ratio_)
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m     n_components = np.searchsorted(cumulative_variance, variance_threshold) + 1
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m         "PCA: %d components capture %.1f%% of variance (from %d original features)",
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m         n_components, cumulative_variance[n_components - 1] * 100, X_scaled.shape[1]
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m     # Transform to reduced space
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m     pca_reduced = PCA(n_components=n_components, random_state=RANDOM_SEED)
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m     X_reduced = pca_reduced.fit_transform(X_scaled)
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m     return X_scaled, X_reduced, scaler, pca_reduced, feature_cols
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m ## Step 3: Multi-Algorithm Clustering
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m *Maps to pseudocode Step 4. Run K-means, GMM, and hierarchical clustering across a range of K values. Record internal validation metrics for each. The goal is to find values of K where multiple algorithms agree.*
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m def run_multi_algorithm_clustering(X_reduced, k_range=K_RANGE):
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m     Run three clustering algorithms across a range of K values.
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m     Why multiple algorithms? Each makes different assumptions about cluster shape.
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m     K-means assumes spherical clusters. GMM allows elliptical. Hierarchical
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m     builds a tree. If all three find similar groupings at K=4, that's stronger
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m     evidence than any single algorithm alone.
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m     Returns a list of result dicts, one per K value, with labels and metrics
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m     for each algorithm.
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m     results = []
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m     for k in k_range:
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m         k_result = {"k": k, "algorithms": {}}
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m         # K-means: fast, spherical cluster assumption
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m         kmeans = KMeans(n_clusters=k, random_state=RANDOM_SEED, n_init=10)
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m         kmeans_labels = kmeans.fit_predict(X_reduced)
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m         kmeans_sil = silhouette_score(X_reduced, kmeans_labels)
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m         k_result["algorithms"]["kmeans"] = {
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m             "labels": kmeans_labels,
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m             "silhouette": kmeans_sil,
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m         # Gaussian Mixture Model: elliptical clusters, probabilistic assignments
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m         gmm = GaussianMixture(n_components=k, random_state=RANDOM_SEED, n_init=3)
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m         gmm_labels = gmm.fit_predict(X_reduced)
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m         gmm_sil = silhouette_score(X_reduced, gmm_labels)
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m         gmm_bic = gmm.bic(X_reduced)  # lower BIC = better fit/complexity tradeoff
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m         k_result["algorithms"]["gmm"] = {
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m             "labels": gmm_labels,
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m             "silhouette": gmm_sil,
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m             "bic": gmm_bic,
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m         # Hierarchical (Ward linkage): builds dendrogram, cut at K
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m         hier = AgglomerativeClustering(n_clusters=k, linkage="ward")
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m         hier_labels = hier.fit_predict(X_reduced)
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m         hier_sil = silhouette_score(X_reduced, hier_labels)
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m         k_result["algorithms"]["hierarchical"] = {
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m             "labels": hier_labels,
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m             "silhouette": hier_sil,
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m         results.append(k_result)
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m         logger.info(
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m             "K=%d | Silhouette: KMeans=%.3f, GMM=%.3f, Hier=%.3f | GMM BIC=%.0f",
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m             k, kmeans_sil, gmm_sil, hier_sil, gmm_bic
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m     return results
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m ## Step 4: Consensus Clustering
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m *Maps to pseudocode Step 5. This is the gold standard for disease subtype discovery. Run clustering 100 times on bootstrap resamples and track which patients consistently end up together. Stable co-clustering across resamples is evidence of genuine structure.*
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m def consensus_clustering(X_scaled, k, n_iterations=CONSENSUS_ITERATIONS,
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m                          subsample_fraction=SUBSAMPLE_FRACTION):
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m     Build a consensus matrix by repeatedly clustering bootstrap subsamples.
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m     The consensus matrix entry (i, j) represents the fraction of times
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m     patient i and patient j ended up in the same cluster across all iterations
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m     where both were sampled. Values near 1.0 mean "always together." Values
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m     near 0.0 mean "never together." Values near 0.5 mean "unstable" (boundary
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m     patients who bounce between clusters depending on who else is in the sample).
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m     We then cluster the consensus matrix itself to get final assignments.
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m     n_patients = X_scaled.shape[0]
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m     co_cluster_count = np.zeros((n_patients, n_patients))
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m     co_occurrence_count = np.zeros((n_patients, n_patients))
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m     rng = np.random.default_rng(RANDOM_SEED)
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m     for iteration in range(n_iterations):
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m         # Bootstrap: sample 80% of patients
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m         n_sample = int(n_patients * subsample_fraction)
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m         indices = rng.choice(n_patients, size=n_sample, replace=False)
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m         indices.sort()
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m         # Cluster the subsample
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m         subsample = X_scaled[indices]
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m         kmeans = KMeans(n_clusters=k, random_state=iteration, n_init=5)
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m         labels = kmeans.fit_predict(subsample)
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m         # Update co-clustering counts for all pairs in this subsample
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m         for i_idx in range(n_sample):
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m             for j_idx in range(i_idx + 1, n_sample):
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m                 pi, pj = indices[i_idx], indices[j_idx]
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m                 co_occurrence_count[pi, pj] += 1
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m                 co_occurrence_count[pj, pi] += 1
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m                 if labels[i_idx] == labels[j_idx]:
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m                     co_cluster_count[pi, pj] += 1
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m                     co_cluster_count[pj, pi] += 1
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m     # Compute consensus matrix (avoid division by zero)
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m     with np.errstate(divide="ignore", invalid="ignore"):
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m         consensus_matrix = np.divide(co_cluster_count, co_occurrence_count)
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m         consensus_matrix = np.nan_to_num(consensus_matrix, nan=0.0)
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m     # Set diagonal to 1 (a patient always co-clusters with itself)
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m     np.fill_diagonal(consensus_matrix, 1.0)
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m     # Cluster the consensus matrix using hierarchical clustering
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m     # Distance = 1 - consensus (patients always together have distance 0)
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m     distance_matrix = 1.0 - consensus_matrix
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m     final_clustering = AgglomerativeClustering(
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m         n_clusters=k, metric="precomputed", linkage="average"
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m     final_labels = final_clustering.fit_predict(distance_matrix)
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m     # Compute PAC (Proportion of Ambiguous Clustering)
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m     # PAC = fraction of off-diagonal consensus values between 0.1 and 0.9
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m     off_diag = consensus_matrix[np.triu_indices_from(consensus_matrix, k=1)]
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m     pac = np.mean((off_diag > 0.1) & (off_diag < 0.9))
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m         "Consensus clustering (K=%d, %d iterations): PAC=%.3f (lower is more stable)",
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m         k, n_iterations, pac
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m     return final_labels, consensus_matrix, pac
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m ## Step 5: Clinical Validation and Characterization
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m *Maps to pseudocode Step 6. For each discovered cluster, compute the feature profile and compare to the overall population. In a real scenario, you'd also compare outcomes (mortality, readmission). Here we characterize by feature means and effect sizes.*
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m def characterize_clusters(df, feature_cols, labels):
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m     Generate interpretable profiles for each discovered cluster.
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m     For each cluster, compute the mean of every feature and the effect size
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m     (how many standard deviations the cluster mean differs from the population
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m     mean). Large positive effect sizes indicate defining characteristics.
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m     This is what you'd present to a clinician: "Cluster 2 is characterized by
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m     age 81 (+2.1 SD), creatinine 2.1 (+1.8 SD), hemoglobin 10.5 (-1.5 SD)."
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m     X = df[feature_cols].values
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m     overall_means = X.mean(axis=0)
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m     overall_stds = X.std(axis=0)
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m     n_clusters = len(np.unique(labels))
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m     characterization = {}
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m     for cluster_id in range(n_clusters):
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m         mask = labels == cluster_id
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m         cluster_data = X[mask]
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m         cluster_means = cluster_data.mean(axis=0)
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m         # Effect size: how far is this cluster's mean from the population mean,
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m         # measured in population standard deviations
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m         effect_sizes = (cluster_means - overall_means) / (overall_stds + 1e-8)
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m         # Top distinguishing features (largest absolute effect sizes)
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m         top_indices = np.argsort(np.abs(effect_sizes))[::-1][:5]
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m         top_features = [
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m             {"feature": feature_cols[i], "effect_size": round(float(effect_sizes[i]), 2)}
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m             for i in top_indices
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m         ]
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m         characterization[cluster_id] = {
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m             "size": int(mask.sum()),
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m             "fraction": round(float(mask.mean()), 3),
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m             "top_features": top_features,
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m         logger.info(
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m             "Cluster %d: n=%d (%.1f%%) | Top features: %s",
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m             cluster_id, mask.sum(), mask.mean() * 100,
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m             ", ".join(f"{f['feature']}({f['effect_size']:+.1f})" for f in top_features)
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m     return characterization
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m ## Step 6: Train Subtype Classifier
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m *Maps to pseudocode Step 7. Once you've validated the subtypes, train a supervised classifier so new patients can be assigned to a subtype without re-running the full clustering pipeline.*
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m def train_subtype_classifier(X_scaled, labels, feature_cols):
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m     Train a gradient boosting classifier to assign new patients to subtypes.
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m     Why gradient boosting? It handles mixed feature types well, provides
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m     feature importance rankings, and is robust to the moderate class imbalance
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m     typical in subtype discovery. The trained model can be deployed as a
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m     SageMaker endpoint for real-time assignment.
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m     X_train, X_test, y_train, y_test = train_test_split(
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m         X_scaled, labels, test_size=0.2, random_state=RANDOM_SEED, stratify=labels
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m     clf = GradientBoostingClassifier(
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m         n_estimators=200,
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m         max_depth=5,
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m         learning_rate=0.1,
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m         random_state=RANDOM_SEED,
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m     clf.fit(X_train, y_train)
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m     accuracy = clf.score(X_test, y_test)
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m     logger.info("Classifier accuracy: %.3f", accuracy)
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m     # Feature importance: which measurements drive subtype assignment?
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m     importance = sorted(
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m         zip(feature_cols, clf.feature_importances_),
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m         key=lambda x: x[1],
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m         reverse=True,
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m     logger.info("Top 5 features for classification: %s",
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m                 ", ".join(f"{name}({imp:.3f})" for name, imp in importance[:5]))
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m     return clf, accuracy, importance
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m ## Step 7: Store Subtype Assignments
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m *Writes validated subtype assignments to DynamoDB so downstream systems (care management, clinical decision support) can look up a patient's subtype in real time.*
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m def store_subtype_assignments(patient_ids, labels, characterization, table_name=SUBTYPE_TABLE):
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m     """
