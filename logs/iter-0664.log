[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m     df = pd.DataFrame(records)
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m     # Clip physiologically implausible values
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m     df["ejection_fraction"] = df["ejection_fraction"].clip(5, 75)
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m     df["bmi"] = df["bmi"].clip(15, 60)
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m     df["creatinine"] = df["creatinine"].clip(0.3, 8.0)
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m     df["hemoglobin"] = df["hemoglobin"].clip(6.0, 18.0)
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m     df["age"] = df["age"].clip(18, 100)
