[49m[38;5;10m+      1[0m:[38;5;10m[49m # Recipe 13.7: Python Implementation Example
[0m[49m[38;5;10m+      2[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      3[0m:[38;5;10m[49m > **Heads up:** This is a deliberately simplified, illustrative implementation of the pseudocode walkthrough from Recipe 13.7. It shows one way you could translate the disease-gene-drug relationship graph concepts into working Python code using boto3 and the Neptune openCypher endpoint. It is not production-ready. The real version of this system involves months of entity resolution work, clinical governance review, and integration testing against known pharmacogenomic cases. Consider this a starting point for understanding the shape of the solution, not something you'd connect to a clinical decision support system tomorrow.
[0m[49m[38;5;10m+      4[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      5[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+      6[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      7[0m:[38;5;10m[49m ## Setup
[0m[49m[38;5;10m+      8[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      9[0m:[38;5;10m[49m You'll need the AWS SDK for Python and a few supporting libraries:
[0m[49m[38;5;10m+     10[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     11[0m:[38;5;10m[49m ```bash
[0m[49m[38;5;10m+     12[0m:[38;5;10m[49m pip install boto3 requests gremlinpython
[0m[49m[38;5;10m+     13[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     14[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     15[0m:[38;5;10m[49m Your environment needs credentials configured (via environment variables, an instance profile, or `~/.aws/credentials`). The IAM role or user needs permissions for Neptune (via IAM auth or VPC-based access), S3 read/write, and Glue job execution.
[0m[49m[38;5;10m+     16[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     17[0m:[38;5;10m[49m Neptune doesn't use standard IAM actions like most AWS services. Access is controlled via VPC security groups and optionally IAM database authentication. Your Lambda or EC2 instance must be in the same VPC as the Neptune cluster.
[0m[49m[38;5;10m+     18[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     19[0m:[38;5;10m[49m For the openCypher queries in this example, you'll interact with Neptune's HTTPS endpoint directly using the `requests` library with SigV4 signing (if IAM auth is enabled) or plain HTTPS (if using VPC-only access).
[0m[49m[38;5;10m+     20[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     21[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     22[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     23[0m:[38;5;10m[49m ## Config and Constants
[0m[49m[38;5;10m+     24[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     25[0m:[38;5;10m[49m Before we get to the steps, here's the configuration that drives the system. These constants define evidence thresholds, source database locations, and the entity mapping rules that make multi-source integration possible.
[0m[49m[38;5;10m+     26[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     27[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     28[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+     29[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+     30[0m:[38;5;10m[49m import requests
[0m[49m[38;5;10m+     31[0m:[38;5;10m[49m from datetime import datetime, timezone
[0m[49m[38;5;10m+     32[0m:[38;5;10m[49m from typing import Optional
[0m[49m[38;5;10m+     33[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     34[0m:[38;5;10m[49m # =============================================================================
[0m[49m[38;5;10m+     35[0m:[38;5;10m[49m # CONFIGURATION
[0m[49m[38;5;10m+     36[0m:[38;5;10m[49m # =============================================================================
[0m[49m[38;5;10m+     37[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     38[0m:[38;5;10m[49m # Neptune cluster endpoint. This is your graph database.
[0m[49m[38;5;10m+     39[0m:[38;5;10m[49m # In production, this comes from environment variables or SSM Parameter Store.
[0m[49m[38;5;10m+     40[0m:[38;5;10m[49m NEPTUNE_ENDPOINT = "your-neptune-cluster.cluster-xxxxxxxxxxxx.us-east-1.neptune.amazonaws.com"
[0m[49m[38;5;10m+     41[0m:[38;5;10m[49m NEPTUNE_PORT = 8182
[0m[49m[38;5;10m+     42[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     43[0m:[38;5;10m[49m # The base URL for openCypher queries against Neptune.
[0m[49m[38;5;10m+     44[0m:[38;5;10m[49m # Neptune exposes openCypher via HTTPS POST to /openCypher.
[0m[49m[38;5;10m+     45[0m:[38;5;10m[49m NEPTUNE_OPENCYPHER_URL = f"https://{NEPTUNE_ENDPOINT}:{NEPTUNE_PORT}/openCypher"
[0m[49m[38;5;10m+     46[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     47[0m:[38;5;10m[49m # S3 bucket for staging source data and graph load files.
[0m[49m[38;5;10m+     48[0m:[38;5;10m[49m DATA_BUCKET = "your-pharmacogenomics-knowledge-graph"
[0m[49m[38;5;10m+     49[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m # Evidence level hierarchy. Higher index = stronger evidence.
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m # Only relationships at or above the configured threshold will drive clinical alerts.
[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m EVIDENCE_LEVELS = ["4", "3", "2B", "2A", "1B", "1A"]
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m # Default minimum evidence level for clinical decision support queries.
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m # "2A" means moderate evidence or above. Level 3 and 4 are informational only.
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m DEFAULT_EVIDENCE_THRESHOLD = "2A"
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m # CPIC pharmacogenes with established guidelines.
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m # These are the genes where diplotype-to-phenotype translation is well-defined.
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m CPIC_PHARMACOGENES = [
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m     "CYP2D6", "CYP2C19", "CYP2C9", "CYP3A5", "CYP2B6",
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m     "DPYD", "TPMT", "NUDT15", "UGT1A1", "SLCO1B1",
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m     "VKORC1", "IFNL3", "HLA-A", "HLA-B", "CYP4F2",
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m     "RYR1", "CACNA1S", "G6PD", "CYP2C cluster"
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m # Phenotype categories used across pharmacogenes.
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m # The specific phenotypes available depend on the gene.
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m METABOLIZER_PHENOTYPES = [
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m     "Ultra-rapid Metabolizer",
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m     "Rapid Metabolizer",
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m     "Normal Metabolizer",
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m     "Intermediate Metabolizer",
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m     "Poor Metabolizer"
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m # Strong CYP2D6 inhibitors that can cause phenoconversion.
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m # A genetically normal metabolizer taking one of these drugs
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m # effectively becomes a poor metabolizer for CYP2D6 substrates.
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m CYP2D6_STRONG_INHIBITORS = [
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m     "fluoxetine", "paroxetine", "bupropion", "quinidine", "cinacalcet"
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m # CYP2D6 moderate inhibitors (less dramatic phenoconversion).
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m CYP2D6_MODERATE_INHIBITORS = [
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m     "duloxetine", "sertraline", "terbinafine", "abiraterone"
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m ## Step 1: Source Data Ingestion
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m This step downloads and validates source database files. Each pharmacogenomics knowledge source publishes data in its own format and on its own schedule. We stage everything in S3 with version metadata for auditability.
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m # =============================================================================
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m # STEP 1: SOURCE DATA INGESTION
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m # =============================================================================
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m # Maps to pseudocode Step 1 in the main recipe.
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m # Downloads source database files, validates them, and stages in S3.
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m s3_client = boto3.client("s3")
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m def ingest_source(source_name: str, source_url: str, expected_record_count_min: int) -> str:
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m     Download a source database file and stage it in S3.
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m     We validate that the download is complete (not truncated) by checking
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m     that the record count meets a minimum threshold. A sudden drop in
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m     record count usually means a corrupted or partial download.
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m         source_name: Identifier for the source (e.g., "pharmgkb", "clinvar")
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m         source_url: URL to download the source data from
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m         expected_record_count_min: Minimum expected records. If fewer, something is wrong.
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m         S3 key where the validated source data was stored.
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m     # Download the source file.
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m     # In production, you'd handle retries, timeouts, and partial downloads.
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m     response = requests.get(source_url, timeout=300)
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m     response.raise_for_status()
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m     raw_data = response.content
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m     today = datetime.now(timezone.utc).strftime("%Y-%m-%d")
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m     # Basic validation: check that we got a reasonable amount of data.
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m     # A real implementation would also verify checksums if the source provides them.
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m     record_count = raw_data.count(b"\n")  # Rough line count for TSV/CSV sources
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m     if record_count < expected_record_count_min:
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m         raise ValueError(
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m             f"Source {source_name} returned only {record_count} records "
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m             f"(expected at least {expected_record_count_min}). "
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m             f"Possible truncated download."
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m     # Stage in S3 with metadata for traceability.
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m     s3_key = f"sources/{source_name}/{today}/{source_name}-raw.tsv"
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m     s3_client.put_object(
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m         Bucket=DATA_BUCKET,
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m         Key=s3_key,
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m         Body=raw_data,
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m         Metadata={
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m             "source": source_name,
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m             "download-date": today,
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m             "record-count": str(record_count),
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m         ServerSideEncryption="aws:kms",
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m     print(f"[Ingest] {source_name}: {record_count} records staged at s3://{DATA_BUCKET}/{s3_key}")
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m     return s3_key
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m ## Step 2: Entity Resolution
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m This is the hardest engineering step. Different sources use different identifiers for the same biological entity. PharmGKB calls a drug "tamoxifen" with accession PA451581. DrugBank calls it DB00675. RxNorm calls it 10324. They're all the same molecule. Your graph needs them to be one node.
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m # =============================================================================
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m # STEP 2: ENTITY RESOLUTION
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m # =============================================================================
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m # Maps to pseudocode Step 2 in the main recipe.
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m # Resolves identifiers across sources to canonical forms.
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m # Cross-reference tables for entity resolution.
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m # In production, these come from a maintained mapping database (or a service like UMLS).
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m # Here we show the structure with a few examples.
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m GENE_XREF = {
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m     # Maps various gene identifiers to a canonical form.
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m     # Key: (id_type, id_value), Value: canonical gene dict
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m     ("symbol", "CYP2D6"): {
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m         "canonical_id": "gene:1565",
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m         "symbol": "CYP2D6",
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m         "entrez_id": "1565",
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m         "ensembl_id": "ENSG00000100197",
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m         "hgnc_id": "HGNC:2625",
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m     ("symbol", "CYP2C19"): {
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m         "canonical_id": "gene:1557",
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m         "symbol": "CYP2C19",
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m         "entrez_id": "1557",
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m         "ensembl_id": "ENSG00000165841",
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m         "hgnc_id": "HGNC:2621",
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m DRUG_XREF = {
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m     # Maps drug identifiers to canonical form.
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m     ("name", "tamoxifen"): {
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m         "canonical_id": "drug:DB00675",
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m         "name": "Tamoxifen",
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m         "drugbank_id": "DB00675",
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m         "rxnorm_cui": "10324",
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m         "atc_code": "L02BA01",
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m     ("name", "omeprazole"): {
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m         "canonical_id": "drug:DB00338",
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m         "name": "Omeprazole",
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m         "drugbank_id": "DB00338",
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m         "rxnorm_cui": "7646",
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m         "atc_code": "A02BC01",
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m def resolve_gene(symbol: str = None, entrez_id: str = None) -> Optional[dict]:
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     Resolve a gene identifier to its canonical form.
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m     Tries symbol first, then entrez_id. Returns None if no mapping found
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m     (which means we need to add it to our cross-reference table).
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m     if symbol and ("symbol", symbol) in GENE_XREF:
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m         return GENE_XREF[("symbol", symbol)]
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m     if entrez_id and ("entrez_id", entrez_id) in GENE_XREF:
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m         return GENE_XREF[("entrez_id", entrez_id)]
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m     # Unresolved entity. In production, log this for manual review.
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m     print(f"[EntityResolution] WARNING: Could not resolve gene symbol={symbol} entrez={entrez_id}")
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m     return None
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m def resolve_drug(name: str = None, drugbank_id: str = None) -> Optional[dict]:
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m     Resolve a drug identifier to its canonical form.
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m     Drug name matching is case-insensitive because sources are inconsistent
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m     about capitalization.
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m     if name and ("name", name.lower()) in DRUG_XREF:
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m         return DRUG_XREF[("name", name.lower())]
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m     if drugbank_id and ("drugbank_id", drugbank_id) in DRUG_XREF:
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m         return DRUG_XREF[("drugbank_id", drugbank_id)]
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m     print(f"[EntityResolution] WARNING: Could not resolve drug name={name} dbid={drugbank_id}")
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m     return None
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m ## Step 3: Graph Construction (Neptune Bulk Load Format)
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m Transform resolved entities into Neptune's CSV bulk load format. Neptune expects specific CSV structures for nodes and edges, with headers that define property types.
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m # =============================================================================
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m # STEP 3: GRAPH CONSTRUCTION
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m # =============================================================================
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m # Maps to pseudocode Step 3 in the main recipe.
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m # Produces Neptune bulk load CSV files from resolved entities.
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m import csv
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m import io
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m def build_node_csv(nodes: list) -> str:
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m     Build a Neptune-compatible CSV for node loading.
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m     Neptune bulk load format for nodes:
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m     ~id, ~label, property1:type, property2:type, ...
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m     The ~id must be unique across all nodes. The ~label is the node type.
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m     Property types can be: String, Int, Long, Float, Double, Bool, Date.
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m     output = io.StringIO()
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m     writer = csv.writer(output)
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m     # Header row with Neptune's special column markers
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m     writer.writerow([
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m         "~id", "~label",
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m         "symbol:String", "name:String", "entrez_id:String",
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m         "rxnorm_cui:String", "therapeutic_class:String",
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m         "functional_status:String", "evidence_level:String"
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m     ])
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m     for node in nodes:
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m         writer.writerow([
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m             node["id"],
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m             node["label"],
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m             node.get("symbol", ""),
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m             node.get("name", ""),
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m             node.get("entrez_id", ""),
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m             node.get("rxnorm_cui", ""),
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m             node.get("therapeutic_class", ""),
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m             node.get("functional_status", ""),
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m             node.get("evidence_level", ""),
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m         ])
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m     return output.getvalue()
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m def build_edge_csv(edges: list) -> str:
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m     Build a Neptune-compatible CSV for edge loading.
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m     Neptune bulk load format for edges:
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m     ~id, ~from, ~to, ~label, property1:type, property2:type, ...
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m     ~from and ~to reference node ~id values.
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m     ~label is the relationship type.
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m     output = io.StringIO()
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m     writer = csv.writer(output)
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m     writer.writerow([
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m         "~id", "~from", "~to", "~label",
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m         "evidence_level:String", "source:String",
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m         "cpic_level:String", "clinical_annotation:String"
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m     ])
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m     for edge in edges:
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m         writer.writerow([
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m             edge["id"],
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m             edge["from_id"],
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m             edge["to_id"],
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m             edge["label"],
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m             edge.get("evidence_level", ""),
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m             edge.get("source", ""),
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m             edge.get("cpic_level", ""),
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m             edge.get("clinical_annotation", ""),
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m         ])
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m     return output.getvalue()
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m def upload_graph_load_files(nodes: list, edges: list, version: str) -> dict:
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m     Build CSV files and upload to S3 for Neptune bulk loading.
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m     Returns metadata about what was uploaded.
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m     node_csv = build_node_csv(nodes)
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m     edge_csv = build_edge_csv(edges)
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m     node_key = f"graph-loads/{version}/nodes.csv"
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m     edge_key = f"graph-loads/{version}/edges.csv"
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m     s3_client.put_object(
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m         Bucket=DATA_BUCKET,
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m         Key=node_key,
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m         Body=node_csv.encode("utf-8"),
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m         ServerSideEncryption="aws:kms",
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m     s3_client.put_object(
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m         Bucket=DATA_BUCKET,
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m         Key=edge_key,
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m         Body=edge_csv.encode("utf-8"),
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m         ServerSideEncryption="aws:kms",
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m     print(f"[GraphBuild] Uploaded {len(nodes)} nodes and {len(edges)} edges for version {version}")
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m     return {"node_count": len(nodes), "edge_count": len(edges), "version": version}
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m ## Step 4: Neptune Bulk Load
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m Trigger Neptune's bulk loader to ingest the CSV files from S3. This is how you load millions of nodes and edges efficiently (rather than one-by-one inserts).
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m # =============================================================================
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m # STEP 4: NEPTUNE BULK LOAD
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m # =============================================================================
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m # Maps to pseudocode Step 6d in the main recipe.
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m # Triggers Neptune's bulk loader to ingest graph data from S3.
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m import time
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m def trigger_neptune_bulk_load(version: str, neptune_load_role_arn: str) -> str:
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m     Start a Neptune bulk load job from S3.
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m     Neptune's bulk loader reads CSV files from S3 and creates nodes/edges
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m     in the graph. This is orders of magnitude faster than individual inserts
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m     for large datasets.
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m     The IAM role must have:
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m     - S3 read access to the source bucket
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m     - A trust policy allowing neptune.amazonaws.com to assume it
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m         version: Graph version identifier (determines S3 prefix)
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m         neptune_load_role_arn: IAM role ARN that Neptune assumes for S3 access
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m         Load job ID for status tracking.
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m     load_url = f"https://{NEPTUNE_ENDPOINT}:{NEPTUNE_PORT}/loader"
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m     payload = {
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m         "source": f"s3://{DATA_BUCKET}/graph-loads/{version}/",
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m         "format": "csv",
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m         "iamRoleArn": neptune_load_role_arn,
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m         "region": "us-east-1",
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m         "failOnError": "TRUE",
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m         "parallelism": "MEDIUM",
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m         "updateSingleCardinalityProperties": "TRUE",
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m     response = requests.post(load_url, json=payload)
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m     response.raise_for_status()
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m     load_id = response.json()["payload"]["loadId"]
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m     print(f"[BulkLoad] Started load job {load_id} for version {version}")
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m     return load_id
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m def wait_for_load_completion(load_id: str, timeout_seconds: int = 3600) -> dict:
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m     Poll Neptune loader status until the job completes or times out.
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m     Neptune bulk loads can take minutes to hours depending on data volume.
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m     For our pharmacogenomics graph (~2.5M nodes, ~15M edges), expect 45-90 minutes.
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m     status_url = f"https://{NEPTUNE_ENDPOINT}:{NEPTUNE_PORT}/loader/{load_id}"
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m     start_time = time.time()
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m     while time.time() - start_time < timeout_seconds:
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m         response = requests.get(status_url)
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m         status = response.json()["payload"]["overallStatus"]
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m         if status["status"] == "LOAD_COMPLETED":
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m             print(f"[BulkLoad] Load {load_id} completed successfully")
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m             return status
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m         elif status["status"] in ("LOAD_FAILED", "LOAD_CANCELLED_DUE_TO_ERRORS"):
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m             raise RuntimeError(f"Neptune load failed: {status}")
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m         # Poll every 30 seconds
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m         print(f"[BulkLoad] Status: {status['status']}. Waiting...")
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m         time.sleep(30)
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m     raise TimeoutError(f"Neptune load {load_id} did not complete within {timeout_seconds}s")
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m ## Step 5: Patient Pharmacogenomics Query
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m This is the clinical payoff. Given a patient's genetic variants and current medications, traverse the graph to find actionable pharmacogenomic findings.
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m # =============================================================================
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m # STEP 5: PATIENT PHARMACOGENOMICS QUERY
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m # =============================================================================
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m # Maps to pseudocode Step 5 in the main recipe.
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m # Queries the graph for a specific patient's actionable findings.
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m def execute_opencypher_query(query: str, parameters: dict = None) -> list:
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m     Execute an openCypher query against Neptune.
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m     Neptune's openCypher endpoint accepts queries via HTTPS POST.
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m     Parameters are passed separately (not interpolated into the query string)
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m     to prevent injection.
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m     In production with IAM auth enabled, you'd sign this request with SigV4.
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m     This example assumes VPC-only access without IAM auth for simplicity.
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m     payload = {"query": query}
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m     if parameters:
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m         payload["parameters"] = json.dumps(parameters)
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m     response = requests.post(NEPTUNE_OPENCYPHER_URL, json=payload)
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m     response.raise_for_status()
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m     return response.json().get("results", [])
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m def get_patient_phenotype(gene: str, diplotype: str) -> Optional[dict]:
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m     Look up the metabolizer phenotype for a given gene and diplotype.
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m     This traverses: Diplotype node -> results_in_phenotype -> Phenotype node.
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m     Example: CYP2D6 *4/*4 -> Poor Metabolizer
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m     query = """
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m         MATCH (p:Phenotype)<-[:results_in_phenotype]-(d:Diplotype)
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m         WHERE d.gene = $gene AND d.diplotype = $diplotype
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m         RETURN p.phenotype AS phenotype, p.activity_score_range AS activity_range
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m     results = execute_opencypher_query(query, {"gene": gene, "diplotype": diplotype})
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m     if results:
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m         return results[0]
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m     return None
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m def find_gene_drug_interactions(drug_rxnorm_cui: str, evidence_threshold: str) -> list:
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m     Find all gene interactions for a given drug, filtered by evidence level.
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m     This traverses: Gene -[metabolizes|targets|transports]-> Drug
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m     and returns only relationships at or above the evidence threshold.
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m     # Build the list of acceptable evidence levels (at or above threshold)
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m     threshold_index = EVIDENCE_LEVELS.index(evidence_threshold)
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m     acceptable_levels = EVIDENCE_LEVELS[threshold_index:]
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m     query = """
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m         MATCH (g:Gene)-[r]->(d:Drug)
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m         WHERE d.rxnorm_cui = $drug_cui
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m           AND r.evidence_level IN $levels
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m           AND type(r) IN ['metabolizes', 'targets', 'transports']
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m         RETURN g.symbol AS gene, type(r) AS relationship,
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m                r.evidence_level AS evidence, r.clinical_annotation AS annotation
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m     return execute_opencypher_query(query, {
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m         "drug_cui": drug_rxnorm_cui,
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m         "levels": acceptable_levels,
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m def get_recommendation(gene: str, phenotype: str, drug_rxnorm_cui: str) -> Optional[dict]:
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m     Get the CPIC recommendation for a specific gene-phenotype-drug combination.
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m     This traverses: Phenotype -[recommendation]-> Drug
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m     and returns the clinical action (use_alternative, dose_adjust, standard_dose).
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m     query = """
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m         MATCH (p:Phenotype)-[rec:recommendation]->(d:Drug)
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m         WHERE p.gene = $gene AND p.phenotype = $phenotype AND d.rxnorm_cui = $drug_cui
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m         RETURN rec.action AS action, rec.strength AS strength,
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m                rec.alternatives AS alternatives, rec.guideline_version AS guideline
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m     results = execute_opencypher_query(query, {
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m         "gene": gene,
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m         "phenotype": phenotype,
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m         "drug_cui": drug_rxnorm_cui,
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m     if results:
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m         return results[0]
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m     return None
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m def check_phenoconversion(current_medications: list, gene: str, genetic_phenotype: str) -> Optional[dict]:
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m     Check if concomitant medications cause phenoconversion for a given gene.
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m     Phenoconversion happens when a drug inhibits an enzyme so strongly that
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m     the patient's effective phenotype differs from their genetic phenotype.
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m     Example: A CYP2D6 Normal Metabolizer taking fluoxetine (strong CYP2D6 inhibitor)
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m     effectively becomes a Poor Metabolizer for CYP2D6 substrates.
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m     if gene != "CYP2D6":
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m         # For this example, we only model CYP2D6 phenoconversion.
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m         # Production systems would cover CYP2C19, CYP3A4, etc.
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m     med_names = [m["name"].lower() for m in current_medications]
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m     strong_inhibitors_present = [
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m         drug for drug in CYP2D6_STRONG_INHIBITORS if drug in med_names
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m     moderate_inhibitors_present = [
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m         drug for drug in CYP2D6_MODERATE_INHIBITORS if drug in med_names
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m     if strong_inhibitors_present:
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m         effective_phenotype = "Poor Metabolizer"
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m     elif moderate_inhibitors_present and genetic_phenotype in ("Normal Metabolizer", "Rapid Metabolizer"):
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m         effective_phenotype = "Intermediate Metabolizer"
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m         return None  # No phenoconversion detected
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m     if effective_phenotype != genetic_phenotype:
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m             "type": "phenoconversion_warning",
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m             "gene": gene,
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m             "genetic_phenotype": genetic_phenotype,
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m             "effective_phenotype": effective_phenotype,
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m             "inhibiting_drugs": strong_inhibitors_present + moderate_inhibitors_present,
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m             "clinical_note": (
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m                 f"Patient is genetically {genetic_phenotype} for {gene} "
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m                 f"but concomitant {strong_inhibitors_present or moderate_inhibitors_present} "
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m                 f"may result in effective {effective_phenotype} status"
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m             ),
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m     return None
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m def query_patient_pharmacogenomics(
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m     patient_variants: list,
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m     current_medications: list,
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m     evidence_threshold: str = DEFAULT_EVIDENCE_THRESHOLD,
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m     Main query function: given a patient's variants and medications,
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m     find all actionable pharmacogenomic findings.
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m     This is the function that a clinical decision support system would call.
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m         patient_variants: List of dicts with keys: gene, diplotype
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m             Example: [{"gene": "CYP2D6", "diplotype": "*4/*4"}, ...]
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m         current_medications: List of dicts with keys: name, rxnorm_cui
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m             Example: [{"name": "Tamoxifen", "rxnorm_cui": "10324"}, ...]
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m         evidence_threshold: Minimum evidence level for findings (default "2A")
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m         Dict with findings, metadata, and confidence information.
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m     findings = []
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m     # Step 5a: Determine patient phenotypes from their variants
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m     patient_phenotypes = {}
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m     for variant in patient_variants:
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m         gene = variant["gene"]
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m         diplotype = variant["diplotype"]
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m         phenotype_result = get_patient_phenotype(gene, diplotype)
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m         if phenotype_result:
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m             patient_phenotypes[gene] = phenotype_result["phenotype"]
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m             print(f"  {gene} {diplotype} -> {phenotype_result['phenotype']}")
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m     # Step 5b: Check each medication against patient phenotypes
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m     for medication in current_medications:
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m         interactions = find_gene_drug_interactions(
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m             medication["rxnorm_cui"], evidence_threshold
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m         for interaction in interactions:
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m             gene = interaction["gene"]
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m             if gene in patient_phenotypes:
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m                 phenotype = patient_phenotypes[gene]
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m                 recommendation = get_recommendation(
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m                     gene, phenotype, medication["rxnorm_cui"]
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m                 )
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m                 if recommendation and recommendation["action"] != "standard_dose":
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m                     findings.append({
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m                         "medication": medication["name"],
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m                         "gene": gene,
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m                         "patient_phenotype": phenotype,
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m                         "recommendation": recommendation["action"],
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m                         "strength": recommendation["strength"],
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m                         "alternatives": recommendation.get("alternatives", []),
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m                         "evidence_level": interaction["evidence"],
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m                         "guideline": recommendation.get("guideline", ""),
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m                         "clinical_context": interaction.get("annotation", ""),
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m                     })
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m     # Step 5c: Check for phenoconversion
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m     for gene, phenotype in patient_phenotypes.items():
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m         phenoconversion = check_phenoconversion(current_medications, gene, phenotype)
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m         if phenoconversion:
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m             findings.append(phenoconversion)
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m     # Sort by clinical urgency (actionable findings first, then info)
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m     findings.sort(key=lambda f: (
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m         0 if f.get("recommendation") == "use_alternative" else
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m         1 if f.get("recommendation") == "dose_adjust" else
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m         2
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m     ))
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m         "query_timestamp": datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m         "evidence_threshold_applied": evidence_threshold,
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m         "genes_with_phenotype": len(patient_phenotypes),
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m         "findings": findings,
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m         "medications_without_findings": [
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m             m["name"] for m in current_medications
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m             if not any(f.get("medication") == m["name"] for f in findings)
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m         ],
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m ## Full Pipeline: Putting It All Together
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m Here's how you'd run the complete query for a patient. This assembles all the steps above into a single callable flow.
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m # =============================================================================
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m # FULL PIPELINE
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m # =============================================================================
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m def run_patient_query_example():
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m     Demonstrate the full patient query flow.
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m     This assumes the graph is already loaded (Steps 1-4 have been run).
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m     In production, the graph update pipeline runs on a schedule via EventBridge
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m     and Step Functions. The patient query runs on-demand when triggered by
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m     the EHR or clinical decision support system.
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m     print("Disease-Gene-Drug Relationship Graph: Patient Query")
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m     # Example patient data.
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m     # In production, this comes from the lab's pharmacogenomic test results
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m     # and the patient's current medication list from the EHR.
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m     patient_variants = [
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m         {"gene": "CYP2D6", "diplotype": "*4/*4"},
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m         {"gene": "CYP2C19", "diplotype": "*1/*17"},
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m         {"gene": "CYP2C9", "diplotype": "*1/*1"},
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m         {"gene": "SLCO1B1", "diplotype": "*1/*1"},
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m         {"gene": "DPYD", "diplotype": "*1/*1"},
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m     current_medications = [
[0m[49m[38;5;10m+    717[0m:[38;5;10m[49m         {"name": "Tamoxifen", "rxnorm_cui": "10324"},
[0m[49m[38;5;10m+    718[0m:[38;5;10m[49m         {"name": "Omeprazole", "rxnorm_cui": "7646"},
[0m[49m[38;5;10m+    719[0m:[38;5;10m[49m         {"name": "Lisinopril", "rxnorm_cui": "29046"},
[0m[49m[38;5;10m+    720[0m:[38;5;10m[49m         {"name": "Metformin", "rxnorm_cui": "6809"},
[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m         {"name": "Atorvastatin", "rxnorm_cui": "83367"},
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m     print("\nPatient Variants:")
[0m[49m[38;5;10m+    725[0m:[38;5;10m[49m     for v in patient_variants:
[0m[49m[38;5;10m+    726[0m:[38;5;10m[49m         print(f"  {v['gene']}: {v['diplotype']}")
[0m[49m[38;5;10m+    727[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    728[0m:[38;5;10m[49m     print("\nCurrent Medications:")
[0m[49m[38;5;10m+    729[0m:[38;5;10m[49m     for m in current_medications:
[0m[49m[38;5;10m+    730[0m:[38;5;10m[49m         print(f"  {m['name']} (RxNorm: {m['rxnorm_cui']})")
[0m[49m[38;5;10m+    731[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    732[0m:[38;5;10m[49m     print("\nDetermining phenotypes...")
[0m[49m[38;5;10m+    733[0m:[38;5;10m[49m     results = query_patient_pharmacogenomics(
[0m[49m[38;5;10m+    734[0m:[38;5;10m[49m         patient_variants=patient_variants,
[0m[49m[38;5;10m+    735[0m:[38;5;10m[49m         current_medications=current_medications,
[0m[49m[38;5;10m+    736[0m:[38;5;10m[49m         evidence_threshold="2A",
[0m[49m[38;5;10m+    737[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    738[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    739[0m:[38;5;10m[49m     print(f"\nResults ({len(results['findings'])} findings):")
[0m[49m[38;5;10m+    740[0m:[38;5;10m[49m     print(json.dumps(results, indent=2, default=str))
