[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m # This must match exactly what the training data provides.
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m FEATURE_COLUMNS = [
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m     "no_show_rate_last_10",
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m     "lead_time_days",
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m     "day_of_week",
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m     "hour_of_day",
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m     "visit_type_encoded",
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m     "distance_miles",
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m     "insurance_type_encoded",
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m     "age",
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m     "days_since_last_visit",
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m     "prior_cancellations",
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m # Category encoding maps. In production, these come from your feature store
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m # or a shared config. They must be consistent between training and inference.
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m VISIT_TYPE_ENCODING = {
