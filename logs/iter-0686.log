[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m # DynamoDB table for storing predictions.
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m PREDICTIONS_TABLE = "appointment-predictions"
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m # SageMaker configuration.
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m SAGEMAKER_ROLE = "arn:aws:iam::123456789012:role/SageMakerExecutionRole"
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m TRAINING_INSTANCE_TYPE = "ml.m5.xlarge"
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m TRANSFORM_INSTANCE_TYPE = "ml.m5.large"
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m # Risk tier thresholds. These are operational decisions, not model decisions.
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m # Tune based on your reminder capacity and tolerance for false positives.
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m # A clinic with abundant staff for phone calls might lower the "high" threshold.
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m # A clinic with only automated SMS might raise it.
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m HIGH_RISK_THRESHOLD = 0.7    # above this: aggressive intervention (call + SMS + overbook flag)
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m MEDIUM_RISK_THRESHOLD = 0.4  # above this: automated reminder supplement
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m # XGBoost hyperparameters for training.
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m # These are reasonable defaults for a no-show dataset with 10K-500K rows.
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m XGBOOST_PARAMS = {
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m     "objective": "binary:logistic",
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m     "eval_metric": "auc",
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m     "num_round": "200",
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m     "max_depth": "6",
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m     "eta": "0.1",
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m     "subsample": "0.8",
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m     "colsample_bytree": "0.8",
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m     "scale_pos_weight": "5.5",  # adjust for your actual no-show rate
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m                                  # formula: (1 - no_show_rate) / no_show_rate
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m                                  # for 15% no-show: 0.85/0.15 ≈ 5.67
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m 
