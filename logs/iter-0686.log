[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m ## Step 1: Generate Synthetic Training Data
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m *The main recipe's Step 1 computes features from your scheduling system via a Glue job. Here, we generate synthetic data that mimics what that Glue job would produce. This lets you run the full pipeline without connecting to a real EHR.*
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m def generate_synthetic_appointments(n_appointments: int = 10000, seed: int = 42) -> pd.DataFrame:
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m     Generate synthetic appointment data with realistic no-show patterns.
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m     The synthetic data encodes the known correlations from no-show research:
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m     - Higher no-show rate for patients with prior no-shows
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m     - Higher no-show rate for longer lead times
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m     - Higher no-show rate for certain days/times
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m     - Higher no-show rate for follow-up vs. urgent visits
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m         n_appointments: Number of synthetic appointments to generate.
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m         seed: Random seed for reproducibility.
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m         DataFrame with feature columns and a binary 'no_show' target column.
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m     rng = np.random.default_rng(seed)
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m     # Generate base features from realistic distributions.
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m     # Each feature's distribution is based on what you'd see in a real
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m     # scheduling system for a mid-size outpatient practice.
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m     # Historical no-show rate: most patients have low rates, some have high.
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m     # Beta distribution gives us a nice right-skewed shape.
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m     no_show_rate_last_10 = rng.beta(a=2, b=8, size=n_appointments)
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m     # Lead time: days between booking and appointment.
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m     # Exponential-ish distribution: many same-week bookings, fewer 6+ weeks out.
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m     lead_time_days = rng.exponential(scale=14, size=n_appointments).astype(int)
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m     lead_time_days = np.clip(lead_time_days, 0, 90)
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m     # Day of week: uniform across weekdays (0=Mon through 4=Fri).
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m     day_of_week = rng.integers(0, 5, size=n_appointments)
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m     # Hour of day: clustered around business hours (8 AM to 5 PM).
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m     hour_of_day = rng.integers(8, 17, size=n_appointments)
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m     # Visit type: weighted toward follow-ups (most common in outpatient).
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m     visit_types = rng.choice(
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m         list(VISIT_TYPE_ENCODING.keys()),
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m         size=n_appointments,
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m         p=[0.15, 0.45, 0.20, 0.15, 0.05],
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m     visit_type_encoded = np.array([VISIT_TYPE_ENCODING[v] for v in visit_types])
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m     # Distance to clinic: log-normal distribution (most patients are close, some far).
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m     distance_miles = rng.lognormal(mean=1.5, sigma=0.8, size=n_appointments)
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m     distance_miles = np.clip(distance_miles, 0.5, 50.0)
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m     # Insurance type: weighted distribution.
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m     insurance_types = rng.choice(
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m         list(INSURANCE_TYPE_ENCODING.keys()),
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m         size=n_appointments,
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m         p=[0.45, 0.25, 0.15, 0.10, 0.05],
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m     insurance_type_encoded = np.array([INSURANCE_TYPE_ENCODING[i] for i in insurance_types])
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m     # Age: normal distribution centered around 45, clipped to realistic range.
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m     age = rng.normal(loc=45, scale=18, size=n_appointments).astype(int)
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m     age = np.clip(age, 2, 95)
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m     # Days since last visit: exponential (most patients seen recently, some lapsed).
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m     days_since_last_visit = rng.exponential(scale=60, size=n_appointments).astype(int)
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m     days_since_last_visit = np.clip(days_since_last_visit, 0, 730)
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m     # Prior cancellations in last year.
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m     prior_cancellations = rng.poisson(lam=0.8, size=n_appointments)
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m     # Now generate the target variable (no_show) based on realistic correlations.
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m     # The probability of no-show is a function of the features above.
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m     # This simulates the real-world relationship the model will learn.
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m     logit = (
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m         -2.0                                          # base rate (intercept)
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m         + 3.0 * no_show_rate_last_10                  # strongest predictor
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m         + 0.02 * lead_time_days                       # longer lead = higher risk
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m         + 0.1 * (day_of_week == 0).astype(float)      # Monday effect
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m         + 0.1 * (day_of_week == 4).astype(float)      # Friday effect
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m         + 0.3 * (visit_type_encoded == 1).astype(float)   # follow-ups no-show more
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m         - 0.5 * (visit_type_encoded == 3).astype(float)   # urgent visits no-show less
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m         + 0.01 * distance_miles                       # farther = higher risk
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m         + 0.3 * (insurance_type_encoded == 2).astype(float)  # access barriers
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m         + 0.005 * days_since_last_visit               # lapsed patients higher risk
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m         + 0.1 * prior_cancellations                   # cancellation history
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m         + rng.normal(0, 0.5, size=n_appointments)     # noise (human behavior is stochastic)
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m     # Convert logit to probability via sigmoid function.
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m     probability = 1.0 / (1.0 + np.exp(-logit))
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m     # Sample binary outcome from the probability.
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     no_show = rng.binomial(1, probability)
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m     # Assemble into a DataFrame.
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m     df = pd.DataFrame({
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m         "no_show_rate_last_10": np.round(no_show_rate_last_10, 3),
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m         "lead_time_days": lead_time_days,
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m         "day_of_week": day_of_week,
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m         "hour_of_day": hour_of_day,
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m         "visit_type_encoded": visit_type_encoded,
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m         "distance_miles": np.round(distance_miles, 1),
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m         "insurance_type_encoded": insurance_type_encoded,
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m         "age": age,
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m         "days_since_last_visit": days_since_last_visit,
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m         "prior_cancellations": prior_cancellations,
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m         "no_show": no_show,
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m         "Generated %d synthetic appointments. No-show rate: %.1f%%",
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m         n_appointments,
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m         100.0 * no_show.mean(),
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m     return df
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m ## Step 2: Upload Training Data to S3
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m *The Glue job in production writes features directly to S3. Here we upload our synthetic data in the CSV format that SageMaker's XGBoost expects: target column first, no header row.*
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m s3_client = boto3.client("s3", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m def upload_training_data(df: pd.DataFrame) -> str:
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m     Format and upload training data to S3 in SageMaker XGBoost format.
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m     SageMaker's built-in XGBoost expects CSV with:
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m     - No header row
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m     - Target variable in the first column
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m     - Feature columns following in order
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m         df: DataFrame with feature columns and 'no_show' target.
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m         The S3 URI where the training data was uploaded.
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m     # Reorder columns: target first, then features.
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m     # SageMaker XGBoost reads the first column as the label.
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m     columns_ordered = ["no_show"] + FEATURE_COLUMNS
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m     training_df = df[columns_ordered]
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m     # Convert to CSV without header or index.
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m     csv_buffer = training_df.to_csv(index=False, header=False)
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m     # Upload to S3.
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m     today = datetime.date.today().isoformat()
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m     s3_key = f"{TRAINING_PREFIX}{today}/train.csv"
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m     s3_client.put_object(
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m         Bucket=ML_BUCKET,
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m         Key=s3_key,
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m         Body=csv_buffer.encode("utf-8"),
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m         ServerSideEncryption="aws:kms",  # encrypt at rest with KMS
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m     s3_uri = f"s3://{ML_BUCKET}/{s3_key}"
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m     logger.info("Uploaded training data to %s (%d rows)", s3_uri, len(training_df))
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m     return s3_uri
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m ## Step 3: Train the Model with SageMaker
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m *The pseudocode calls this `train_model(training_data_path)`. It launches a SageMaker training job using the built-in XGBoost algorithm. SageMaker handles provisioning the instance, running training, and saving the model artifact to S3.*
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m import sagemaker
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m from sagemaker import image_uris
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m from sagemaker.inputs import TrainingInput
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m def train_noshow_model(training_data_uri: str) -> str:
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m     Launch a SageMaker training job for the no-show prediction model.
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m     Uses SageMaker's built-in XGBoost algorithm, which is optimized for
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m     tabular binary classification. The training job:
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m     1. Provisions an ml.m5.xlarge instance
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m     2. Downloads training data from S3
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m     3. Trains an XGBoost model with our hyperparameters
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m     4. Saves the model artifact back to S3
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m     5. Terminates the instance (you only pay for training time)
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m         training_data_uri: S3 URI of the training CSV file.
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m         S3 URI of the trained model artifact (.tar.gz).
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m     # Get the SageMaker session and determine the XGBoost container image
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m     # for our region. SageMaker maintains pre-built containers for each
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m     # supported algorithm and framework version.
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m     session = sagemaker.Session()
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m     region = session.boto_region_name
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m     xgboost_image = image_uris.retrieve(
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m         framework="xgboost",
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m         region=region,
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m         version="1.7-1",  # use a recent stable version
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m     # Create the Estimator: SageMaker's abstraction for a training job.
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m     # The estimator knows which container to use, what instance to run on,
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m     # where to put the output, and what hyperparameters to pass.
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m     today = datetime.date.today().isoformat()
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m     estimator = sagemaker.estimator.Estimator(
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m         image_uri=xgboost_image,
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m         role=SAGEMAKER_ROLE,
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m         instance_count=1,
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m         instance_type=TRAINING_INSTANCE_TYPE,
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m         output_path=f"s3://{ML_BUCKET}/{MODELS_PREFIX}",
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m         sagemaker_session=session,
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m         base_job_name=f"noshow-train-{today}",
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m         # Encrypt the training volume. PHI-adjacent data (appointment patterns)
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m         # should be encrypted even during transient training.
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m         volume_kms_key=None,  # in production: your KMS key ARN
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m     # Set hyperparameters. These are passed to the XGBoost container as
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m     # command-line arguments. All values must be strings.
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m     estimator.set_hyperparameters(**XGBOOST_PARAMS)
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m     # Define the training input channel. SageMaker downloads this data
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m     # to the training instance before starting the algorithm.
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m     train_input = TrainingInput(
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m         s3_data=training_data_uri,
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m         content_type="text/csv",
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m     # Launch the training job and wait for completion.
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m     # This typically takes 5-15 minutes for datasets under 500K rows:
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m     # ~2 min for instance provisioning, ~1-10 min for actual training,
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m     # ~1 min for model upload.
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m     logger.info("Starting SageMaker training job...")
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m     estimator.fit({"train": train_input}, wait=True)
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m     # The model artifact is a .tar.gz file in S3 containing the serialized
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m     # XGBoost model. We'll reference this path when creating batch transform jobs.
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m     model_artifact_uri = estimator.model_data
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m     logger.info("Training complete. Model artifact: %s", model_artifact_uri)
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m     return model_artifact_uri
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m ## Step 4: Score Upcoming Appointments with Batch Transform
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m *The pseudocode calls this `score_upcoming_appointments(model_path, features_path)`. Batch transform is the cost-effective choice when you need predictions once daily rather than continuously. SageMaker spins up an instance, loads the model, scores all rows in the input file, writes predictions to S3, and shuts down.*
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m def prepare_scoring_input(df: pd.DataFrame) -> str:
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m     Prepare upcoming appointments for batch scoring.
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m     Takes a DataFrame of upcoming appointments (with features computed but
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m     no target column) and uploads it to S3 in the format batch transform expects.
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m         df: DataFrame with feature columns for upcoming appointments.
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m             Must also contain 'appointment_id' for joining predictions back.
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m         S3 URI of the scoring input file.
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m     # Batch transform input: features only, no target column, no header.
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m     # We keep appointment_id separate so we can join predictions back later.
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m     scoring_df = df[FEATURE_COLUMNS]
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m     csv_buffer = scoring_df.to_csv(index=False, header=False)
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m     today = datetime.date.today().isoformat()
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m     s3_key = f"{FEATURES_PREFIX}{today}/scoring_input.csv"
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m     s3_client.put_object(
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m         Bucket=ML_BUCKET,
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m         Key=s3_key,
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m         Body=csv_buffer.encode("utf-8"),
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m         ServerSideEncryption="aws:kms",
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m     s3_uri = f"s3://{ML_BUCKET}/{s3_key}"
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m     logger.info("Uploaded scoring input to %s (%d appointments)", s3_uri, len(scoring_df))
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m     return s3_uri
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m def score_appointments(model_artifact_uri: str, scoring_input_uri: str) -> str:
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m     Run SageMaker batch transform to score all upcoming appointments.
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m     Batch transform is cheaper than a real-time endpoint for once-daily scoring:
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m     - No idle endpoint costs between scoring runs
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m     - Processes all appointments in one pass
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m     - Automatically handles instance provisioning and teardown
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m         model_artifact_uri: S3 URI of the trained model (.tar.gz).
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m         scoring_input_uri: S3 URI of the scoring input CSV.
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m         S3 URI prefix where predictions were written.
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m     session = sagemaker.Session()
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m     region = session.boto_region_name
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m     xgboost_image = image_uris.retrieve(
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m         framework="xgboost",
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m         region=region,
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m         version="1.7-1",
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m     # Create a SageMaker Model object from the trained artifact.
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m     # This tells SageMaker which container + model weights to use for inference.
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m     today = datetime.date.today().isoformat()
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m     model = sagemaker.model.Model(
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m         image_uri=xgboost_image,
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m         model_data=model_artifact_uri,
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m         role=SAGEMAKER_ROLE,
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m         sagemaker_session=session,
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m     # Configure and run the batch transform job.
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m     output_prefix = f"s3://{ML_BUCKET}/{PREDICTIONS_PREFIX}{today}/"
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m     transformer = model.transformer(
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m         instance_count=1,
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m         instance_type=TRANSFORM_INSTANCE_TYPE,
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m         output_path=output_prefix,
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m         accept="text/csv",
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m         strategy="MultiRecord",       # process multiple rows per request (faster)
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m         max_payload=6,                 # MB per request to the container
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m     logger.info("Starting batch transform job...")
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m     transformer.transform(
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m         data=scoring_input_uri,
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m         content_type="text/csv",
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m         split_type="Line",             # one row per line in the input
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m         wait=True,
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m     logger.info("Batch transform complete. Predictions at: %s", output_prefix)
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m     return output_prefix
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m ## Step 5: Store Predictions in DynamoDB
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m *The pseudocode calls this `store_predictions(predictions)`. We read the batch transform output from S3, pair each prediction with its appointment ID, classify into risk tiers, and write to DynamoDB for fast downstream access.*
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m def classify_risk(probability: float) -> str:
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m     Convert a continuous no-show probability into an actionable risk tier.
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m     These thresholds are operational decisions. They determine which
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m     appointments get extra outreach and which get flagged for overbooking.
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m     Tune them based on your reminder capacity and false-positive tolerance.
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m     if probability >= HIGH_RISK_THRESHOLD:
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m         return "high"
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m     elif probability >= MEDIUM_RISK_THRESHOLD:
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m         return "medium"
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m     return "low"
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m def store_predictions(
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m     predictions: list[float],
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m     appointment_ids: list[str],
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m     scheduled_dates: list[str],
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m     model_version: str = "v1.0.0",
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m ) -> int:
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m     Write scored predictions to DynamoDB for downstream consumption.
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m     Each record contains the appointment ID (primary key), the no-show
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m     probability, the risk tier, and metadata for auditability. The action
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m     engine and scheduling UI both read from this table.
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m         predictions: List of no-show probabilities (0.0 to 1.0).
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m         appointment_ids: Corresponding appointment IDs.
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m         scheduled_dates: Corresponding scheduled dates (ISO format strings).
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m         model_version: Version string for the model that produced these scores.
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m         Number of predictions stored.
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m     table = dynamodb.Table(PREDICTIONS_TABLE)
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m     scored_at = datetime.datetime.now(timezone.utc).isoformat()
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m     count = 0
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m     # Use batch_writer for efficient bulk writes.
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m     # DynamoDB batch_writer handles chunking into 25-item batches
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m     # and automatic retries for unprocessed items.
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m     with table.batch_writer() as batch:
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m         for appt_id, probability, sched_date in zip(
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m             appointment_ids, predictions, scheduled_dates
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m         ):
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m             risk_tier = classify_risk(probability)
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m             item = {
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m                 "appointment_id": appt_id,
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m                 "scheduled_date": sched_date,
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m                 # DynamoDB does not accept Python floats. Wrap in Decimal.
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m                 # str() first to avoid floating-point representation artifacts.
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m                 "no_show_probability": Decimal(str(round(probability, 4))),
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m                 "risk_tier": risk_tier,
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m                 "model_version": model_version,
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m                 "scored_at": scored_at,
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m             batch.put_item(Item=item)
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m             count += 1
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m     logger.info("Stored %d predictions in DynamoDB", count)
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m     return count
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m ## Step 6: Action Engine (Query and Intervene)
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m *The pseudocode calls this `run_action_engine(target_date)`. This Lambda function queries DynamoDB for high-risk appointments and triggers the appropriate intervention. In production, this sends real SMS/email via SNS/SES. Here we simulate the logic.*
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m sns_client = boto3.client("sns", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m def query_high_risk_appointments(target_date: str) -> list[dict]:
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m     Query DynamoDB for appointments on the target date that need intervention.
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m     Uses a Global Secondary Index on scheduled_date to efficiently find
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m     all appointments for a given day, then filters to actionable risk tiers.
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m         target_date: ISO date string (e.g., "2026-06-02").
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m         List of appointment prediction records with risk_tier "high" or "medium".
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m     table = dynamodb.Table(PREDICTIONS_TABLE)
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m     # Query using the scheduled_date GSI.
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m     # In production, this index must exist on the table.
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m     response = table.query(
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m         IndexName="scheduled-date-index",
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m         KeyConditionExpression=boto3.dynamodb.conditions.Key("scheduled_date").eq(target_date),
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m     items = response.get("Items", [])
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m     # Filter to actionable risk tiers.
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m     actionable = [
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m         item for item in items
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m         if item.get("risk_tier") in ("high", "medium")
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m         "Found %d actionable appointments for %s (of %d total)",
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m         len(actionable), target_date, len(items),
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m     return actionable
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m def run_action_engine(target_date: str) -> dict:
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m     Execute interventions for high-risk appointments on the target date.
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m     This is the function your Lambda handler calls. It:
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m     1. Queries predictions for the target date
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m     2. Separates into high-risk and medium-risk groups
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m     3. Triggers appropriate interventions for each group
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m     In production, "send_reminder" calls SNS (for SMS) or SES (for email).
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m     Here we log the actions that would be taken.
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m         target_date: ISO date string for the day to process.
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m         Summary of actions taken.
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m     actionable = query_high_risk_appointments(target_date)
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m     high_risk = [a for a in actionable if a["risk_tier"] == "high"]
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m     medium_risk = [a for a in actionable if a["risk_tier"] == "medium"]
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m     actions_taken = {"high_risk_interventions": 0, "medium_risk_interventions": 0}
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m     # High-risk: aggressive intervention.
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m     # In production: personal phone call + SMS + flag for overbooking.
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m     for appointment in high_risk:
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m         appt_id = appointment["appointment_id"]
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m         probability = float(appointment["no_show_probability"])
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m         logger.info(
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m             "HIGH RISK: %s (%.0f%% no-show probability). "
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m             "Actions: SMS reminder + staff notification + overbook flag.",
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m             appt_id, probability * 100,
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m         # In production, this publishes to an SNS topic that triggers
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m         # your reminder service. The message includes the appointment details
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m         # and a reschedule link.
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m         #
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m         # sns_client.publish(
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m         #     TopicArn="arn:aws:sns:us-east-1:123456789012:appointment-reminders",
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m         #     Message=json.dumps({
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m         #         "appointment_id": appt_id,
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m         #         "action": "high_risk_reminder",
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m         #         "include_reschedule_link": True,
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m         #     }),
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m         # )
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m         actions_taken["high_risk_interventions"] += 1
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m     # Medium-risk: automated reminder supplement.
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m     for appointment in medium_risk:
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m         appt_id = appointment["appointment_id"]
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m         probability = float(appointment["no_show_probability"])
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m         logger.info(
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m             "MEDIUM RISK: %s (%.0f%% no-show probability). "
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m             "Action: automated SMS reminder.",
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m             appt_id, probability * 100,
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m         actions_taken["medium_risk_interventions"] += 1
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m         "Action engine complete for %s. High-risk: %d, Medium-risk: %d",
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m         target_date,
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m         actions_taken["high_risk_interventions"],
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m         actions_taken["medium_risk_interventions"],
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m     return actions_taken
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m ## Putting It All Together
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m Here's the full pipeline assembled into a single callable function. In production, each step would be a separate component (Glue job, SageMaker training job, batch transform, Lambda), orchestrated by EventBridge. Here we run them sequentially to demonstrate the end-to-end flow.
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m def run_full_pipeline() -> dict:
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m     Run the complete no-show prediction pipeline end-to-end.
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m     This demonstrates the full flow:
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m     1. Generate synthetic data (replaces Glue feature engineering)
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m     2. Upload training data to S3
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m     3. Train the XGBoost model via SageMaker
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m     4. Prepare and score upcoming appointments
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m     5. Store predictions in DynamoDB
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m     6. Run the action engine for tomorrow's appointments
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m         Summary of the pipeline run.
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m     logger.info("=" * 60)
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m     logger.info("NO-SHOW PREDICTION PIPELINE - FULL RUN")
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m     logger.info("=" * 60)
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m     # Step 1: Generate synthetic training data.
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m     # In production, this is a Glue job pulling from your scheduling system.
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m     logger.info("\nStep 1: Generating synthetic training data...")
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m     training_data = generate_synthetic_appointments(n_appointments=10000)
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m     logger.info("  No-show rate in training data: %.1f%%", 100.0 * training_data["no_show"].mean())
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m     # Step 2: Upload training data to S3.
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m     logger.info("\nStep 2: Uploading training data to S3...")
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m     training_uri = upload_training_data(training_data)
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m     # Step 3: Train the model.
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m     logger.info("\nStep 3: Training XGBoost model via SageMaker...")
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m     model_uri = train_noshow_model(training_uri)
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m     # Step 4: Generate and score upcoming appointments.
[0m[49m[38;5;10m+    717[0m:[38;5;10m[49m     # In production, these come from your scheduling system for the next 48 hours.
[0m[49m[38;5;10m+    718[0m:[38;5;10m[49m     logger.info("\nStep 4: Scoring upcoming appointments...")
[0m[49m[38;5;10m+    719[0m:[38;5;10m[49m     upcoming = generate_synthetic_appointments(n_appointments=200, seed=99)
[0m[49m[38;5;10m+    720[0m:[38;5;10m[49m     # Remove the target column (we're predicting, not training).
[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m     upcoming_features = upcoming.drop(columns=["no_show"])
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m     # Add appointment IDs and scheduled dates for the prediction records.
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m     tomorrow = (datetime.date.today() + datetime.timedelta(days=1)).isoformat()
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m     upcoming_features["appointment_id"] = [f"APT-{i:05d}" for i in range(len(upcoming_features))]
