[0m[49m[39m  417, 420[0m:[39m[49m   "alert_type": "heart_rate_high",
[0m[49m[39m  418, 421[0m:[39m[49m   "threshold_before": 100,
[0m[49m[39m  419, 422[0m:[39m[49m   "threshold_after": 107,
