[0m[49m[38;5;10m+      167[0m:[38;5;10m[49m     // Extract what we need for quality assessment
[0m[49m[38;5;10m+      168[0m:[38;5;10m[49m     pixel_array = dicom_object.pixel_array          // the actual image data as a 2D numeric array
[0m[49m[38;5;10m+      169[0m:[38;5;10m[49m     modality    = dicom_object.Modality             // "CR", "CT", "MR", "DX", etc.
