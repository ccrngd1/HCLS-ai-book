[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m # Demand: how many nurses are needed per shift per day.
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m # In production, this comes from a census forecasting model (Recipe 12.5).
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m # For a 36-bed med-surg unit, typical staffing is 5 nurses on days, 4 on nights.
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m DEMAND = {
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m     "day": 5,
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m     "night": 4,
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m # At least one charge-certified nurse must be on every shift.
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m CHARGE_REQUIRED_PER_SHIFT = 1
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m # PTO blocks: nurses who are unavailable on specific days (0-indexed from period start).
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m PTO_BLOCKS = {
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m     "RN-003": [2, 3, 4],       # Priya is off days 2-4
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m     "RN-006": [0, 1, 6, 7],   # David is off days 0-1 and 6-7
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m # Schedule period: 7 days (one week). Production would typically be 14 days.
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m NUM_DAYS = 7
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m ## Step 1: Assemble the Optimization Problem
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m *The pseudocode calls this `assemble_scheduling_problem(schedule_period)`. It gathers all inputs into a single problem definition the solver can consume.*
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m def assemble_problem(staff, demand, num_days, pto_blocks):
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m     Package all scheduling inputs into a structured problem definition.
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m     In production, this function would pull from HR APIs, the demand forecasting
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m     service, and the constraint configuration store. Here we just organize the
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m     hardcoded data into the shape the solver expects.
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m         staff:      List of nurse dictionaries (roster)
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m         demand:     Dict of shift_name -> required headcount
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m         num_days:   Number of days in the scheduling period
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m         pto_blocks: Dict of nurse_id -> list of unavailable day indices
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m         A problem dict containing everything the solver needs.
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m     problem = {
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m         "staff": staff,
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m         "demand": demand,
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m         "num_days": num_days,
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m         "shifts": list(SHIFTS.keys()),
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m         "pto_blocks": pto_blocks,
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m         "hard_constraints": {
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m             "min_rest_hours": MIN_REST_HOURS,
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m             "max_hours_per_week": MAX_HOURS_PER_WEEK,
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m             "charge_required_per_shift": CHARGE_REQUIRED_PER_SHIFT,
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m         "soft_constraints": {
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m             "max_consecutive_days": MAX_CONSECUTIVE_DAYS,
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m             "penalty_weights": PENALTY_WEIGHTS,
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m         "Problem assembled: %d nurses, %d days, %d shifts/day, %d total slots to fill",
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m         len(staff), num_days, len(SHIFTS), sum(demand.values()) * num_days,
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m     return problem
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m ## Step 2: Formulate the CP-SAT Model
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m *The pseudocode calls this `formulate_optimization_model(problem)`. This is the intellectual core: translating business rules into mathematical constraints that the solver can reason about.*
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m def formulate_model(problem):
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m     Build the CP-SAT model with decision variables, hard constraints,
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m     soft constraints, and the objective function.
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m     The CP-SAT solver works with integer variables and linear constraints.
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m     Each nurse-shift-day combination is a boolean variable (0 or 1).
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m     Constraints are linear inequalities over those variables.
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m     The objective is a weighted sum of penalty terms we want to minimize.
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m         Tuple of (model, variables_dict) where variables_dict maps
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m         (nurse_id, shift, day) -> BoolVar for solution extraction.
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m     model = cp_model.CpModel()
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m     staff = problem["staff"]
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m     shifts = problem["shifts"]
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m     num_days = problem["num_days"]
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m     pto_blocks = problem["pto_blocks"]
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m     # ---------------------------------------------------------------
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m     # DECISION VARIABLES
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m     # x[(nurse_id, shift, day)] = 1 if nurse works that shift on that day
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m     # ---------------------------------------------------------------
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m     x = {}
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m     for nurse in staff:
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m         for shift in shifts:
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m             for day in range(num_days):
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m                 var_name = f"x_{nurse['id']}_{shift}_{day}"
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m                 x[(nurse["id"], shift, day)] = model.NewBoolVar(var_name)
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m     # ---------------------------------------------------------------
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m     # HARD CONSTRAINTS
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m     # ---------------------------------------------------------------
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m     # 1. Each nurse works at most one shift per day.
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m     #    You can't be on days AND nights simultaneously.
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m     for nurse in staff:
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m         for day in range(num_days):
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m             model.Add(
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m                 sum(x[(nurse["id"], shift, day)] for shift in shifts) <= 1
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m     # 2. Minimum rest between shifts.
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m     #    Night shift ends at 7 AM. Day shift starts at 7 AM.
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m     #    Gap is 0 hours, which violates the 11-hour minimum.
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m     #    So: if you work night on day D, you cannot work day on day D+1.
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m     for nurse in staff:
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m         for day in range(num_days - 1):
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m             # Night shift on day D conflicts with day shift on day D+1
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m             model.Add(
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m                 x[(nurse["id"], "night", day)] + x[(nurse["id"], "day", day + 1)] <= 1
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m     # 3. Demand coverage: enough nurses on every shift.
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m     for shift in shifts:
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m         for day in range(num_days):
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m             model.Add(
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m                 sum(x[(nurse["id"], shift, day)] for nurse in staff)
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m                 >= problem["demand"][shift]
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m     # 4. Charge nurse coverage: at least one charge-certified nurse per shift.
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m     charge_nurses = [n for n in staff if "charge" in n["certifications"]]
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m     for shift in shifts:
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m         for day in range(num_days):
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m             model.Add(
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m                 sum(x[(n["id"], shift, day)] for n in charge_nurses)
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m                 >= problem["hard_constraints"]["charge_required_per_shift"]
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m     # 5. PTO blocks: nurse is unavailable on approved days.
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m     for nurse_id, blocked_days in pto_blocks.items():
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m         for day in blocked_days:
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m             if day < num_days:
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m                 for shift in shifts:
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m                     model.Add(x[(nurse_id, shift, day)] == 0)
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m     # 6. Maximum hours per scheduling period (based on FTE).
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m     for nurse in staff:
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m         total_shifts = sum(
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m             x[(nurse["id"], shift, day)]
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m             for shift in shifts
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m             for day in range(num_days)
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m         # Each shift is 12 hours. Max shifts = max_hours / 12.
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m         max_shifts = nurse["max_hours_per_period"] // 12
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m         model.Add(total_shifts <= max_shifts)
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m     # ---------------------------------------------------------------
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m     # SOFT CONSTRAINTS (penalized in objective)
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m     # ---------------------------------------------------------------
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m     penalties = []
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m     # Overtime penalty: shifts beyond the contracted target.
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m     # Target shifts = FTE * days_in_period / 2 (since each shift covers half a day).
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m     # Anything above target incurs a penalty.
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m     for nurse in staff:
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m         target_shifts = int(nurse["fte"] * num_days * 12 / 24)  # expected shifts
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m         total_shifts = sum(
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m             x[(nurse["id"], shift, day)]
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m             for shift in shifts
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m             for day in range(num_days)
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m         # Create an auxiliary variable for overtime (shifts above target)
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m         overtime = model.NewIntVar(0, num_days, f"overtime_{nurse['id']}")
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m         model.Add(overtime >= total_shifts - target_shifts)
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m         model.Add(overtime >= 0)
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m         penalties.append(overtime * PENALTY_WEIGHTS["overtime"])
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m     # Weekend fairness: penalize deviation from average weekend shifts.
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m     # Identify weekend days (assuming day 5 = Saturday, day 6 = Sunday for a
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m     # Mon-start period). Adjust indices for your actual start day.
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m     weekend_days = [d for d in range(num_days) if d % 7 >= 5]
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m     if weekend_days:
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m         weekend_shifts_per_nurse = []
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m         for nurse in staff:
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m             ws = sum(
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m                 x[(nurse["id"], shift, day)]
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m                 for shift in shifts
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m                 for day in weekend_days
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m             weekend_shifts_per_nurse.append(ws)
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m         # Penalize each nurse's deviation from the minimum weekend count.
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m         # This encourages equitable distribution.
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m         min_weekends = model.NewIntVar(0, len(weekend_days) * 2, "min_weekends")
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m         model.AddMinEquality(min_weekends, weekend_shifts_per_nurse)
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m         for i, nurse in enumerate(staff):
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m             deviation = model.NewIntVar(0, len(weekend_days) * 2, f"wknd_dev_{nurse['id']}")
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m             model.Add(deviation >= weekend_shifts_per_nurse[i] - min_weekends)
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m             penalties.append(deviation * PENALTY_WEIGHTS["fairness"])
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m     # Preference violation: penalize assignments that don't match preferred shift.
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m     for nurse in staff:
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m         preferred = nurse.get("preference")
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m         if preferred and preferred in shifts:
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m             non_preferred = [s for s in shifts if s != preferred]
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m             for shift in non_preferred:
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m                 for day in range(num_days):
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m                     # Each assignment to a non-preferred shift incurs a penalty
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m                     penalties.append(
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m                         x[(nurse["id"], shift, day)] * PENALTY_WEIGHTS["preference_violation"]
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m                     )
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m     # Consecutive days penalty: penalize stretches longer than MAX_CONSECUTIVE_DAYS.
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m     for nurse in staff:
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m         for start_day in range(num_days - MAX_CONSECUTIVE_DAYS):
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m             # If a nurse works MAX_CONSECUTIVE_DAYS+1 consecutive days, penalize.
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m             window = MAX_CONSECUTIVE_DAYS + 1
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m             if start_day + window <= num_days:
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m                 days_worked_in_window = sum(
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m                     x[(nurse["id"], shift, day)]
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m                     for shift in shifts
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m                     for day in range(start_day, start_day + window)
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m                 )
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m                 # If all days in the window are worked, that's a violation.
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m                 excess = model.NewIntVar(0, window, f"consec_{nurse['id']}_{start_day}")
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m                 model.Add(excess >= days_worked_in_window - MAX_CONSECUTIVE_DAYS)
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m                 penalties.append(excess * PENALTY_WEIGHTS["consecutive_days"])
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m     # ---------------------------------------------------------------
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m     # OBJECTIVE: minimize total penalty
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m     # ---------------------------------------------------------------
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m     model.Minimize(sum(penalties))
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m         "Model formulated: %d variables, constraints added for %d nurses over %d days",
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m         len(x), len(staff), num_days,
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m     return model, x
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m ## Step 3: Solve and Extract the Schedule
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m *The pseudocode calls this `solve_and_extract(model, time_limit_seconds)`. We hand the model to CP-SAT and translate the solution back into a human-readable schedule.*
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m def solve_and_extract(model, x, problem):
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m     Run the CP-SAT solver and extract the schedule from variable assignments.
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m     The solver explores the solution space using propagation and search.
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m     It progressively finds better solutions until it proves optimality or
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m     hits the time limit. CP-SAT is particularly good at feasibility (finding
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m     any valid schedule) and handles the complex logical constraints of nurse
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m     scheduling naturally.
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m         Dict with status, schedule assignments, and quality metrics.
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m     solver = cp_model.CpSolver()
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m     solver.parameters.max_time_in_seconds = SOLVER_TIME_LIMIT_SECONDS
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m     # Use multiple threads for parallel search (if available).
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m     solver.parameters.num_search_workers = 4
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m     logger.info("Solving (time limit: %ds)...", SOLVER_TIME_LIMIT_SECONDS)
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m     status = solver.Solve(model)
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m     # Check solver status
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m     if status == cp_model.INFEASIBLE:
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m         logger.warning("Problem is INFEASIBLE. Constraints conflict.")
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m             "status": "infeasible",
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m             "message": "No valid schedule exists with current constraints. "
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m                        "Consider relaxing demand, adding staff, or removing PTO blocks.",
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m     if status not in (cp_model.OPTIMAL, cp_model.FEASIBLE):
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m         logger.error("Solver returned unexpected status: %s", status)
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m         return {"status": "error", "message": f"Solver status: {status}"}
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m     # Extract assignments from the solved model
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m     staff = problem["staff"]
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m     shifts = problem["shifts"]
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m     num_days = problem["num_days"]
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m     schedule = []
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m     for nurse in staff:
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m         nurse_shifts = []
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m         for day in range(num_days):
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m             for shift in shifts:
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m                 if solver.Value(x[(nurse["id"], shift, day)]) == 1:
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m                     nurse_shifts.append({
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m                         "day": day,
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m                         "shift": shift,
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m                         "duration_hours": SHIFTS[shift]["duration_hours"],
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m                     })
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m         if nurse_shifts:
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m             schedule.append({
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m                 "nurse_id": nurse["id"],
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m                 "nurse_name": nurse["name"],
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m                 "assignments": nurse_shifts,
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m                 "total_hours": sum(a["duration_hours"] for a in nurse_shifts),
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m                 "total_shifts": len(nurse_shifts),
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m     # Compute quality metrics
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m     total_hours = sum(entry["total_hours"] for entry in schedule)
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m     target_hours = sum(n["max_hours_per_period"] for n in staff)
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m     # Weekend shift distribution
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m     weekend_days = [d for d in range(num_days) if d % 7 >= 5]
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m     weekend_counts = []
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m     for nurse in staff:
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m         count = sum(
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m             1 for day in weekend_days for shift in shifts
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m             if solver.Value(x[(nurse["id"], shift, day)]) == 1
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m         weekend_counts.append(count)
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m     fairness_score = 0.0
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m     if weekend_counts and max(weekend_counts) > 0:
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m         # Fairness: 1.0 means perfectly equal, lower means less fair
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m         fairness_score = 1.0 - (max(weekend_counts) - min(weekend_counts)) / max(max(weekend_counts), 1)
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m     metrics = {
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m         "solver_status": "optimal" if status == cp_model.OPTIMAL else "feasible",
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m         "objective_value": solver.ObjectiveValue(),
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m         "solve_time_seconds": round(solver.WallTime(), 2),
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m         "total_shifts_assigned": sum(entry["total_shifts"] for entry in schedule),
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m         "total_shifts_required": sum(problem["demand"].values()) * num_days,
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m         "coverage_rate": (
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m             sum(entry["total_shifts"] for entry in schedule)
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m             / (sum(problem["demand"].values()) * num_days)
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m         ),
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m         "total_hours_assigned": total_hours,
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m         "fairness_score": round(fairness_score, 3),
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m         "weekend_shift_range": f"{min(weekend_counts)}-{max(weekend_counts)}" if weekend_counts else "n/a",
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m         "Solved in %.1fs. Status: %s. Objective: %.1f. Coverage: %.0f%%",
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m         metrics["solve_time_seconds"],
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m         metrics["solver_status"],
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m         metrics["objective_value"],
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m         metrics["coverage_rate"] * 100,
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m         "status": "solved",
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m         "schedule": schedule,
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m         "metrics": metrics,
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m ## Step 4: Handle Real-Time Call-Offs
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m *The pseudocode calls this `handle_calloff(calloff_event)`. When a nurse calls in sick, find the best available replacement fast.*
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m def handle_calloff(calloff_event, current_schedule, staff, pto_blocks):
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m     Find ranked coverage candidates when a nurse calls off.
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m     This doesn't re-run the full solver. Instead, it filters the staff roster
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m     to find eligible replacements and scores them by desirability (cost,
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m     fairness impact, historical patterns). In production, you'd also factor
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m     in historical acceptance rates and distance from the facility.
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m         calloff_event: Dict with nurse_id, day, shift of the gap.
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m         current_schedule: The solved schedule (list of nurse assignment dicts).
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m         staff: Full staff roster.
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m         pto_blocks: Current PTO blocks.
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m         Dict with gap details and ranked candidate list.
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m     gap_nurse = calloff_event["nurse_id"]
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m     gap_day = calloff_event["day"]
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m     gap_shift = calloff_event["shift"]
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m         "Call-off: %s on day %d, %s shift. Finding coverage...",
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m         gap_nurse, gap_day, gap_shift,
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m     # Build a lookup of who's already working on the gap day
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m     scheduled_on_gap_day = set()
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m     nurse_total_shifts = {}
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m     for entry in current_schedule:
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m         nurse_total_shifts[entry["nurse_id"]] = entry["total_shifts"]
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m         for assignment in entry["assignments"]:
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m             if assignment["day"] == gap_day:
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m                 scheduled_on_gap_day.add(entry["nurse_id"])
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m     # Also check the day before for rest-rule conflicts
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m     scheduled_night_before = set()
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m     if gap_shift == "day" and gap_day > 0:
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m         for entry in current_schedule:
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m             for assignment in entry["assignments"]:
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m                 if assignment["day"] == gap_day - 1 and assignment["shift"] == "night":
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m                     scheduled_night_before.add(entry["nurse_id"])
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m     # Find eligible candidates
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m     candidates = []
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m     for nurse in staff:
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m         nid = nurse["id"]
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m         # Skip the nurse who called off
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m         if nid == gap_nurse:
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m         # Skip if already scheduled that day
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m         if nid in scheduled_on_gap_day:
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m         # Skip if on PTO
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m         if gap_day in pto_blocks.get(nid, []):
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m         # Skip if rest rule would be violated (worked night before a day gap)
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m         if gap_shift == "day" and nid in scheduled_night_before:
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m         # Skip if at max hours
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m         current_shifts = nurse_total_shifts.get(nid, 0)
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m         max_shifts = nurse["max_hours_per_period"] // 12
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m         if current_shifts >= max_shifts:
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m         # Score the candidate (lower is better for cost; we'll negate for ranking)
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m         is_overtime = current_shifts >= int(nurse["fte"] * 7 * 12 / 24)
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m         prefers_this_shift = nurse.get("preference") == gap_shift
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m         # Simple scoring: prefer non-overtime, prefer matching preference,
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m         # prefer nurses with fewer total shifts (fairness).
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m         score = 0
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m         if not is_overtime:
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m             score += 50  # strong preference for non-overtime
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m         if prefers_this_shift:
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m             score += 20  # bonus for matching preference
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m         score += max(0, 30 - current_shifts * 5)  # fewer shifts = higher score (fairness)
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m         candidates.append({
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m             "nurse_id": nid,
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m             "nurse_name": nurse["name"],
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m             "score": score,
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m             "is_overtime": is_overtime,
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m             "current_shifts": current_shifts,
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m             "prefers_this_shift": prefers_this_shift,
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m     # Sort by score descending (best candidates first)
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m     candidates.sort(key=lambda c: c["score"], reverse=True)
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m     logger.info("Found %d eligible candidates for coverage.", len(candidates))
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m         "gap": {
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m             "nurse_id": gap_nurse,
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m             "day": gap_day,
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m             "shift": gap_shift,
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m         "candidates": candidates[:10],  # top 10
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m         "total_eligible": len(candidates),
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m ## Step 5: Store the Schedule in DynamoDB
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m *The pseudocode calls this `publish_schedule(schedule, schedule_type)`. Write the solved schedule to DynamoDB for downstream consumption.*
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m def store_schedule(result, schedule_period_start):
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m     Write the solved schedule to DynamoDB.
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m     Each assignment becomes a separate item, keyed by day and shift+nurse_id.
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m     This supports the two primary access patterns:
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m     - "Who's working on day X?" (query by partition key = day)
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m     - "What's nurse Y's schedule?" (scan with filter, or GSI on nurse_id)
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m         result: The output of solve_and_extract (contains schedule and metrics).
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m         schedule_period_start: ISO date string for the period start (e.g., "2026-06-08").
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m         Count of items written.
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m     if result["status"] != "solved":
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m         logger.warning("Cannot store schedule with status: %s", result["status"])
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m         return 0
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m     table = dynamodb.Table(SCHEDULE_TABLE_NAME)
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m     items_written = 0
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m     published_at = datetime.datetime.now(timezone.utc).isoformat()
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m     for entry in result["schedule"]:
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m         for assignment in entry["assignments"]:
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m             # Compute the actual date from the period start + day offset
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m             start_date = datetime.date.fromisoformat(schedule_period_start)
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m             actual_date = (start_date + datetime.timedelta(days=assignment["day"])).isoformat()
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m             item = {
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m                 # Partition key: the date (enables "who's working today?" queries)
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m                 "schedule_date": actual_date,
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m                 # Sort key: shift + nurse_id (unique per assignment)
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m                 "shift_nurse": f"{assignment['shift']}#{entry['nurse_id']}",
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m                 "nurse_id": entry["nurse_id"],
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m                 "nurse_name": entry["nurse_name"],
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m                 "shift": assignment["shift"],
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m                 "duration_hours": assignment["duration_hours"],
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m                 "published_at": published_at,
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m                 "schedule_type": "batch",
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m                 "period_start": schedule_period_start,
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m             # DynamoDB requires Decimal for numbers, not float.
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m             table.put_item(Item=item)
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m             items_written += 1
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m     # Store the metrics as a summary record
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m     metrics_item = {
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m         "schedule_date": f"METRICS#{schedule_period_start}",
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m         "shift_nurse": "SUMMARY",
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m         "metrics": json.loads(json.dumps(result["metrics"]), parse_float=Decimal),
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m         "published_at": published_at,
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m     table.put_item(Item=metrics_item)
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m     items_written += 1
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m     logger.info("Stored %d items in DynamoDB for period starting %s.", items_written, schedule_period_start)
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m     return items_written
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m ## Putting It All Together
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m Here's the full pipeline assembled into a single function. This is what your Lambda handler (or batch job) would call.
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m def generate_schedule(schedule_period_start="2026-06-08"):
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m     Run the full nurse staffing optimization pipeline.
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m     1. Assemble the problem (gather inputs)
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m     2. Formulate the CP-SAT model (translate to math)
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m     3. Solve and extract the schedule
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m     4. Store results in DynamoDB
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m         schedule_period_start: ISO date string for the first day of the period.
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    717[0m:[38;5;10m[49m         The solver result dict (status, schedule, metrics).
[0m[49m[38;5;10m+    718[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    719[0m:[38;5;10m[49m     print(f"=== Nurse Staffing Optimization ===")
[0m[49m[38;5;10m+    720[0m:[38;5;10m[49m     print(f"Period start: {schedule_period_start}")
[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m     print(f"Staff: {len(STAFF_ROSTER)} nurses")
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m     print(f"Demand: {DEMAND}")
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m     print()
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    725[0m:[38;5;10m[49m     # Step 1: Assemble the problem
[0m[49m[38;5;10m+    726[0m:[38;5;10m[49m     print("Step 1: Assembling problem definition...")
