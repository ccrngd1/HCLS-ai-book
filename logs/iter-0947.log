[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m ## Step 1: Parse Source Data (NPI Registry)
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m *The pseudocode calls this part of `ingest_provider_data(sources)`. Here we parse the NPPES NPI data file from S3. The real NPPES file is a massive CSV (~8GB) with 300+ columns. We extract the columns relevant to our graph: NPI, name, taxonomy codes, and practice addresses.*
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m s3_client = boto3.client("s3", region_name=AWS_REGION)
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m def parse_npi_file(bucket: str, key: str) -> list[dict]:
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m     Parse the NPPES NPI data file from S3 and extract provider records.
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m     The NPPES file is freely available from CMS. It contains every NPI
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m     registration in the US. We only care about individual providers
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m     (Entity Type 1), not organizations (Entity Type 2).
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m         bucket: S3 bucket containing the NPPES file
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m         key:    S3 object key for the NPPES CSV
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m         List of provider dicts with normalized fields ready for graph loading.
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m     logger.info("Downloading NPI file from s3://%s/%s", bucket, key)
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m     # Stream the file from S3 rather than loading it all into memory.
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m     # The full NPPES file is ~8GB. In production, use Glue or EMR
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m     # for this. Here we demonstrate the logic on a smaller extract.
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m     response = s3_client.get_object(Bucket=bucket, Key=key)
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m     content = response["Body"].read().decode("utf-8")
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m     reader = csv.DictReader(io.StringIO(content))
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m     providers = []
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m     for row in reader:
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m         # Only individual providers (Entity Type Code 1).
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m         # Type 2 is organizations. We model those separately.
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m         if row.get("Entity Type Code") != "1":
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m         npi = row.get("NPI", "").strip()
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m         if not npi:
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m         # Extract the primary taxonomy code. NPPES allows up to 15
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m         # taxonomy codes per provider. The one marked as primary
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m         # (via the "Is Primary" flag) is what we use for specialty assignment.
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m         primary_taxonomy = None
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m         for i in range(1, 16):
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m             code_col = f"Healthcare Provider Taxonomy Code_{i}"
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m             primary_col = f"Healthcare Provider Primary Taxonomy Switch_{i}"
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m             if row.get(primary_col) == "Y":
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m                 primary_taxonomy = row.get(code_col, "").strip()
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m                 break
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m         # If no primary flag is set, fall back to the first taxonomy code.
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m         if not primary_taxonomy:
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m             primary_taxonomy = row.get(
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m                 "Healthcare Provider Taxonomy Code_1", ""
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m             ).strip()
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m         # Build the provider record for our graph.
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m         provider = {
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m             "npi": npi,
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m             "first_name": row.get("Provider First Name", "").strip(),
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m             "last_name": row.get("Provider Last Name (Legal Name)", "").strip(),
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m             "gender": row.get("Provider Gender Code", "").strip(),
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m             "primary_taxonomy": primary_taxonomy,
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m             # Practice location address (first practice address in NPPES)
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m             "address_line1": row.get(
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m                 "Provider First Line Business Practice Location Address", ""
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m             ).strip(),
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m             "city": row.get(
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m                 "Provider Business Practice Location Address City Name", ""
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m             ).strip(),
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m             "state": row.get(
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m                 "Provider Business Practice Location Address State Name", ""
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m             ).strip(),
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m             "zip": row.get(
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m                 "Provider Business Practice Location Address Postal Code", ""
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m             ).strip()[:5],  # First 5 digits only
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m         providers.append(provider)
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m     logger.info("Parsed %d individual providers from NPI file", len(providers))
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m     return providers
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m ## Step 2: Build Neptune Bulk Load CSVs
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m *The pseudocode calls this `write_nodes_csv()` and `write_edges_csv()`. Neptune's bulk loader expects a specific CSV format: node files have `~id`, `~label`, and property columns; edge files have `~id`, `~from`, `~to`, `~label`, and property columns. We transform our parsed provider data into these formats.*
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m def build_provider_nodes_csv(providers: list[dict]) -> str:
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m     Transform provider records into Neptune bulk load CSV format for nodes.
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m     Neptune node CSV format:
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m     ~id, ~label, property1, property2, ...
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m     The ~id must be globally unique across all node types.
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m     We prefix with the node type to avoid collisions
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m     (e.g., "provider:1234567890" vs "location:loc-001").
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m         providers: List of provider dicts from parse_npi_file()
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m         CSV string ready to upload to S3 for Neptune bulk loading.
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m     output = io.StringIO()
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     writer = csv.writer(output)
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m     # Header row. Neptune uses ~ prefix for system columns.
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m     writer.writerow([
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m         "~id", "~label",
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m         "npi:String", "first_name:String", "last_name:String",
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m         "gender:String", "accepting_new:Bool", "telehealth:Bool",
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m     ])
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m     for p in providers:
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m         writer.writerow([
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m             f"provider:{p['npi']}",       # unique node ID
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m             NODE_LABELS["provider"],       # node label
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m             p["npi"],
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m             p["first_name"],
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m             p["last_name"],
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m             p["gender"],
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m             "true",   # default to accepting; update from credentialing data later
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m             "false",  # default to no telehealth; update from provider portal
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m         ])
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m     return output.getvalue()
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m def build_location_nodes_csv(providers: list[dict]) -> str:
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m     Extract unique locations from provider records and format as Neptune node CSV.
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m     Multiple providers may share a location (same address = same practice).
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m     We deduplicate by address to avoid creating duplicate location nodes.
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m         providers: List of provider dicts from parse_npi_file()
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m         CSV string for location nodes.
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m     output = io.StringIO()
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m     writer = csv.writer(output)
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m     writer.writerow([
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m         "~id", "~label",
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m         "address_line1:String", "city:String", "state:String", "zip:String",
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m     ])
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m     # Deduplicate locations by full address string.
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m     # In production, you'd use geocoding to catch near-duplicates
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m     # ("123 Main St" vs "123 Main Street").
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m     seen_locations = set()
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m     for p in providers:
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m         # Create a location key from the address components.
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m         loc_key = f"{p['address_line1']}|{p['city']}|{p['state']}|{p['zip']}"
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m         if loc_key in seen_locations:
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m         seen_locations.add(loc_key)
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m         # Location ID is a hash of the address for deterministic dedup.
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m         loc_id = f"location:{hash(loc_key) & 0xFFFFFFFF:08x}"
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m         writer.writerow([
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m             loc_id,
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m             NODE_LABELS["location"],
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m             p["address_line1"],
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m             p["city"],
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m             p["state"],
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m             p["zip"],
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m         ])
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m     logger.info("Built %d unique location nodes", len(seen_locations))
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m     return output.getvalue()
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m def build_specialty_nodes_csv() -> str:
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m     Build specialty nodes from our taxonomy hierarchy.
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m     In production, you'd parse the full NUCC taxonomy CSV file.
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m     Here we use the sample hierarchy defined in our constants.
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m         CSV string for specialty nodes.
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m     output = io.StringIO()
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m     writer = csv.writer(output)
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m     writer.writerow([
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m         "~id", "~label", "nucc_code:String", "name:String",
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m     ])
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m     for code, info in SAMPLE_SPECIALTY_HIERARCHY.items():
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m         writer.writerow([
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m             f"specialty:{code}",
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m             NODE_LABELS["specialty"],
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m             code,
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m             info["name"],
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m         ])
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m     return output.getvalue()
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m def build_edges_csv(providers: list[dict]) -> str:
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m     Build edge CSV connecting providers to locations and specialties.
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m     Neptune edge CSV format:
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m     ~id, ~from, ~to, ~label, property1, property2, ...
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m     Edge IDs must be globally unique. We construct them from the
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m     relationship type and the connected node IDs.
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m         providers: List of provider dicts from parse_npi_file()
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m         CSV string for edges.
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m     output = io.StringIO()
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m     writer = csv.writer(output)
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m     writer.writerow([
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m         "~id", "~from", "~to", "~label", "effective_date:String",
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m     ])
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m     today = date.today().isoformat()
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m     for p in providers:
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m         provider_id = f"provider:{p['npi']}"
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m         # Edge: Provider PRACTICES_AT Location
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m         loc_key = f"{p['address_line1']}|{p['city']}|{p['state']}|{p['zip']}"
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m         loc_id = f"location:{hash(loc_key) & 0xFFFFFFFF:08x}"
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m         writer.writerow([
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m             f"edge:practices:{p['npi']}:{hash(loc_key) & 0xFFFFFFFF:08x}",
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m             provider_id,
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m             loc_id,
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m             EDGE_TYPES["practices_at"],
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m             today,
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m         ])
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m         # Edge: Provider HAS_SPECIALTY Specialty
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m         if p["primary_taxonomy"] and p["primary_taxonomy"] in SAMPLE_SPECIALTY_HIERARCHY:
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m             specialty_id = f"specialty:{p['primary_taxonomy']}"
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m             writer.writerow([
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m                 f"edge:specialty:{p['npi']}:{p['primary_taxonomy']}",
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m                 provider_id,
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m                 specialty_id,
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m                 EDGE_TYPES["has_specialty"],
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m                 today,
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m             ])
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m     # Edges: Specialty IS_SUBSPECIALTY_OF parent Specialty
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m     for code, info in SAMPLE_SPECIALTY_HIERARCHY.items():
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m         if info["parent"]:
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m             writer.writerow([
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m                 f"edge:subspec:{code}:{info['parent']}",
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m                 f"specialty:{code}",
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m                 f"specialty:{info['parent']}",
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m                 EDGE_TYPES["is_subspecialty"],
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m                 "",  # no effective_date for taxonomy relationships
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m             ])
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m     return output.getvalue()
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m ## Step 3: Load the Graph via Neptune Bulk Loader
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m *The pseudocode calls this `load_graph(node_files, edge_files, neptune_endpoint)`. We upload our CSVs to S3, then trigger Neptune's bulk loader API. The loader reads from S3 and populates the graph.*
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m neptune_client = boto3.client("neptunedata", region_name=AWS_REGION)
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m def upload_csvs_to_s3(
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m     provider_csv: str,
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m     location_csv: str,
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m     specialty_csv: str,
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m     edges_csv: str,
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m ) -> str:
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m     Upload all bulk load CSVs to S3 under a common prefix.
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m     Neptune's bulk loader can point at an S3 prefix and load all files
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m     beneath it. We organize by load batch (date-stamped) so we can
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m     track which load produced which version of the graph.
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m         The S3 prefix where all files were uploaded.
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m     prefix = f"bulk-load/{date.today().isoformat()}/"
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m     files = {
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m         "providers.csv": provider_csv,
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m         "locations.csv": location_csv,
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m         "specialties.csv": specialty_csv,
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m         "edges.csv": edges_csv,
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m     for filename, content in files.items():
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m         s3_client.put_object(
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m             Bucket=STAGING_BUCKET,
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m             Key=f"{prefix}{filename}",
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m             Body=content.encode("utf-8"),
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m         logger.info("Uploaded %s to s3://%s/%s%s", filename, STAGING_BUCKET, prefix, filename)
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m     return f"s3://{STAGING_BUCKET}/{prefix}"
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m def trigger_bulk_load(s3_source: str) -> dict:
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m     Trigger Neptune's bulk loader to ingest CSVs from S3.
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m     The bulk loader is the efficient path for initial loads and large
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m     batch updates. It's significantly faster than individual Gremlin/openCypher
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m     mutations for anything over a few thousand records.
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m         s3_source: Full S3 URI prefix (e.g., "s3://bucket/bulk-load/2026-05-31/")
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m         Load status response from Neptune.
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m     # Neptune's bulk load API is a REST endpoint on the cluster.
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m     # We use the neptunedata client for this.
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m     response = neptune_client.start_loader_job(
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m         source=s3_source,
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m         format="csv",
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m         iamRoleArn=NEPTUNE_LOAD_ROLE_ARN,
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m         region=AWS_REGION,
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m         failOnError="FALSE",       # log errors, don't abort entire load
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m         parallelism="MEDIUM",      # balance speed vs. cluster load
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m         updateSingleCardinalityProperties="TRUE",  # overwrite existing properties
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m     load_id = response["payload"]["loadId"]
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m     logger.info("Bulk load started. Load ID: %s", load_id)
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m     return {"load_id": load_id, "status": response["status"]}
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m def check_load_status(load_id: str) -> dict:
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m     Check the status of a running bulk load job.
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m     Poll this until status is LOAD_COMPLETED or LOAD_FAILED.
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m     Typical load times: ~15 minutes for 500K providers.
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m         load_id: The load ID returned by trigger_bulk_load()
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m         Status dict with overall status and error counts.
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m     response = neptune_client.get_loader_job_status(loadId=load_id)
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m     status = response["payload"]["overallStatus"]["status"]
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m     logger.info("Load %s status: %s", load_id, status)
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m         "status": status,
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m         "total_records": response["payload"]["overallStatus"].get("totalRecords", 0),
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m         "total_errors": response["payload"]["overallStatus"].get("totalErrors", 0),
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m ## Step 4: Query the Graph (Provider Search)
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m *The pseudocode calls this `search_providers(params)`. This is where the graph pays off. We translate a patient's search criteria into an openCypher traversal that reads like the question being asked.*
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m def execute_opencypher_query(query: str, parameters: dict = None) -> dict:
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m     Execute an openCypher query against Neptune's HTTP endpoint.
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m     Neptune supports openCypher via HTTPS POST. The query and parameters
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m     are sent as form data. Results come back as JSON.
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m         query:      openCypher query string
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m         parameters: Optional dict of query parameters (for parameterized queries)
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m         Query results as a dict with "results" key containing matched records.
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m     payload = {"query": query}
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m     if parameters:
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m         payload["parameters"] = json.dumps(parameters)
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m     # Neptune's openCypher endpoint. Must be reachable from within the VPC.
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m     response = requests.post(
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m         NEPTUNE_OPENCYPHER_URL,
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m         data=payload,
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m         headers={"Content-Type": "application/x-www-form-urlencoded"},
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m     response.raise_for_status()
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m     return response.json()
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m def search_providers(
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m     specialty_code: str,
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m     state: str,
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m     zip_code: str = None,
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m     gender: str = None,
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m     accepting_new: bool = True,
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m     limit: int = 20,
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m ) -> list[dict]:
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m     Search for providers matching the given criteria using graph traversal.
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m     This demonstrates the core value of the graph model: multi-constraint
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m     provider search expressed as a natural traversal pattern rather than
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m     a multi-table join.
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m     In production, you'd combine this with OpenSearch for geospatial
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m     distance filtering (Neptune doesn't do geo natively). Here we
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m     filter by state and ZIP as a simplified geographic constraint.
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m         specialty_code: NUCC taxonomy code (e.g., "207RC0000X" for Cardiology)
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m         state:          Two-letter state code for geographic filtering
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m         zip_code:       Optional ZIP code for narrower geographic filtering
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m         gender:         Optional gender filter ("M" or "F")
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m         accepting_new:  Only return providers accepting new patients
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m         limit:          Max results to return
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m         List of provider dicts with location and specialty details.
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m     # First, get all subspecialty codes beneath the requested specialty.
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m     # "Cardiology" should match "Interventional Cardiology" too.
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m     specialty_codes = get_specialty_subtree(specialty_code)
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m     # Build the openCypher query. We start from providers, then traverse
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m     # to their specialties and locations to apply filters.
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m     #
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m     # The query pattern:
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m     # 1. Match providers with a specialty in our target set
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m     # 2. Match their practice locations
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m     # 3. Filter by geography, gender, accepting status
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m     # 4. Return provider + location + specialty details
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m     query = """
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m     MATCH (p:Provider)-[:HAS_SPECIALTY]->(s:Specialty)
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m     WHERE s.nucc_code IN $specialty_codes
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m     AND p.accepting_new = true
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m     MATCH (p)-[:PRACTICES_AT]->(loc:Location)
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m     WHERE loc.state = $state
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m     params = {
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m         "specialty_codes": specialty_codes,
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m         "state": state,
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m     # Add optional filters. Each one narrows the traversal.
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m     if zip_code:
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m         query += "AND loc.zip = $zip_code\n"
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m         params["zip_code"] = zip_code
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m     if gender:
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m         query += "AND p.gender = $gender\n"
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m         params["gender"] = gender
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m     # Return the matched providers with their details.
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m     query += """
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m     RETURN p.npi AS npi,
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m            p.first_name AS first_name,
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m            p.last_name AS last_name,
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m            p.gender AS gender,
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m            p.accepting_new AS accepting_new,
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m            p.telehealth AS telehealth,
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m            s.name AS specialty_name,
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m            s.nucc_code AS specialty_code,
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m            loc.address_line1 AS address,
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m            loc.city AS city,
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m            loc.state AS state,
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m            loc.zip AS zip
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m     LIMIT $limit
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m     params["limit"] = limit
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m         "Searching providers: specialty=%s, state=%s, zip=%s",
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m         specialty_code, state, zip_code,
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m     result = execute_opencypher_query(query, params)
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m     # Transform Neptune's response format into clean provider dicts.
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m     providers = []
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m     for record in result.get("results", []):
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m         providers.append({
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m             "npi": record["npi"],
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m             "name": f"Dr. {record['first_name']} {record['last_name']}",
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m             "specialty": record["specialty_name"],
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m             "specialty_code": record["specialty_code"],
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m             "gender": record["gender"],
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m             "accepting_new": record["accepting_new"],
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m             "telehealth": record["telehealth"],
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m             "location": {
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m                 "address": record["address"],
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m                 "city": record["city"],
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m                 "state": record["state"],
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m                 "zip": record["zip"],
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m             },
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m     logger.info("Found %d matching providers", len(providers))
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m     return providers
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m def get_specialty_subtree(root_code: str) -> list[str]:
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m     Traverse the specialty hierarchy to find all subspecialties
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m     beneath a given specialty code.
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m     This is the key graph advantage for provider search. When a patient
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m     searches for "Cardiology," they should also see Interventional
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m     Cardiologists and Electrophysiologists. The IS_SUBSPECIALTY edges
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m     make this a simple traversal rather than a hardcoded lookup table.
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m         root_code: NUCC taxonomy code to start from
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m         List of all codes in the subtree (including the root).
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m     # openCypher variable-length path pattern.
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m     # *0.. means "zero or more hops," which includes the starting node itself.
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m     query = """
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m     MATCH (root:Specialty {nucc_code: $root_code})
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m     MATCH (child:Specialty)-[:IS_SUBSPECIALTY*0..]->(root)
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m     RETURN collect(DISTINCT child.nucc_code) AS codes
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m     result = execute_opencypher_query(query, {"root_code": root_code})
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m     codes = []
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m     for record in result.get("results", []):
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m         codes = record.get("codes", [])
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m     # Always include the root code itself.
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m     if root_code not in codes:
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m         codes.append(root_code)
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m         "Specialty subtree for %s: %d codes (%s)",
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m         root_code, len(codes), ", ".join(codes),
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m     return codes
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m ## Step 5: Incremental Updates
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m *The pseudocode calls this `apply_incremental_update(change_event)`. Between bulk loads, provider data changes constantly. A provider stops accepting patients, moves locations, or leaves a network. These changes need to propagate to the graph quickly via direct mutations.*
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m def update_provider_property(npi: str, field: str, value) -> dict:
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m     Update a single property on a provider node.
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m     This is the incremental update path for simple property changes:
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m     accepting_new status flips, telehealth flag changes, etc.
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m         npi:   Provider's NPI (unique identifier)
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m         field: Property name to update
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m         value: New value for the property
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m         Query result confirming the update.
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m     query = """
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m     MATCH (p:Provider {npi: $npi})
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m     SET p[$field] = $value
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m     RETURN p.npi AS npi, p[$field] AS updated_value
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m     # openCypher doesn't support dynamic property names via parameters
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m     # in all implementations. Use string formatting for the field name
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m     # (safe here because field comes from our code, not user input).
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m     query = f"""
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m     MATCH (p:Provider {{npi: $npi}})
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m     SET p.{field} = $value
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m     RETURN p.npi AS npi
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m     result = execute_opencypher_query(query, {"npi": npi, "value": value})
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m     logger.info("Updated provider %s: %s = %s", npi, field, value)
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m     return result
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m def add_network_membership(npi: str, network_id: str, effective_date: str) -> dict:
[0m[49m[38;5;10m+    717[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    718[0m:[38;5;10m[49m     Add a provider to a network by creating an IN_NETWORK edge.
[0m[49m[38;5;10m+    719[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    720[0m:[38;5;10m[49m     This handles the case where a provider joins a new network
[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m     (e.g., signs a new payer contract).
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m         npi:            Provider's NPI
[0m[49m[38;5;10m+    725[0m:[38;5;10m[49m         network_id:     Network identifier
[0m[49m[38;5;10m+    726[0m:[38;5;10m[49m         effective_date: When the network participation begins (ISO date)
[0m[49m[38;5;10m+    727[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    728[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    729[0m:[38;5;10m[49m         Query result confirming the edge creation.
[0m[49m[38;5;10m+    730[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    731[0m:[38;5;10m[49m     query = """
[0m[49m[38;5;10m+    732[0m:[38;5;10m[49m     MATCH (p:Provider {npi: $npi})
[0m[49m[38;5;10m+    733[0m:[38;5;10m[49m     MATCH (n:Network {network_id: $network_id})
[0m[49m[38;5;10m+    734[0m:[38;5;10m[49m     CREATE (p)-[:IN_NETWORK {effective_date: $effective_date}]->(n)
[0m[49m[38;5;10m+    735[0m:[38;5;10m[49m     RETURN p.npi AS npi, n.network_id AS network_id
[0m[49m[38;5;10m+    736[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    737[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    738[0m:[38;5;10m[49m     result = execute_opencypher_query(query, {
[0m[49m[38;5;10m+    739[0m:[38;5;10m[49m         "npi": npi,
[0m[49m[38;5;10m+    740[0m:[38;5;10m[49m         "network_id": network_id,
[0m[49m[38;5;10m+    741[0m:[38;5;10m[49m         "effective_date": effective_date,
