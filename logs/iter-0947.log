[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m     "provider": "Provider",
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m     "location": "Location",
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m     "specialty": "Specialty",
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m     "organization": "Organization",
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m     "network": "Network",
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m     "facility": "Facility",
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m # Edge types connecting our nodes.
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m EDGE_TYPES = {
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m     "practices_at": "PRACTICES_AT",
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m     "has_specialty": "HAS_SPECIALTY",
