[0m[49m[38;5;10m+    744[0m:[38;5;10m[49m     return result
[0m[49m[38;5;10m+    745[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    746[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    747[0m:[38;5;10m[49m def terminate_network_membership(
[0m[49m[38;5;10m+    748[0m:[38;5;10m[49m     npi: str, network_id: str, term_date: str
[0m[49m[38;5;10m+    749[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+    750[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    751[0m:[38;5;10m[49m     Terminate a provider's network membership by setting the term_date
[0m[49m[38;5;10m+    752[0m:[38;5;10m[49m     on the IN_NETWORK edge.
[0m[49m[38;5;10m+    753[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    754[0m:[38;5;10m[49m     We do NOT delete the edge. Historical network participation is needed
[0m[49m[38;5;10m+    755[0m:[38;5;10m[49m     for claims adjudication (was this provider in-network on the date of
[0m[49m[38;5;10m+    756[0m:[38;5;10m[49m     service?). We set a termination date and filter on it in queries.
[0m[49m[38;5;10m+    757[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    758[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    759[0m:[38;5;10m[49m         npi:        Provider's NPI
[0m[49m[38;5;10m+    760[0m:[38;5;10m[49m         network_id: Network identifier
[0m[49m[38;5;10m+    761[0m:[38;5;10m[49m         term_date:  When the network participation ends (ISO date)
[0m[49m[38;5;10m+    762[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    763[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    764[0m:[38;5;10m[49m         Query result confirming the update.
[0m[49m[38;5;10m+    765[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    766[0m:[38;5;10m[49m     query = """
[0m[49m[38;5;10m+    767[0m:[38;5;10m[49m     MATCH (p:Provider {npi: $npi})-[r:IN_NETWORK]->(n:Network {network_id: $network_id})
[0m[49m[38;5;10m+    768[0m:[38;5;10m[49m     WHERE r.term_date IS NULL
[0m[49m[38;5;10m+    769[0m:[38;5;10m[49m     SET r.term_date = $term_date
[0m[49m[38;5;10m+    770[0m:[38;5;10m[49m     RETURN p.npi AS npi, n.network_id AS network_id
[0m[49m[38;5;10m+    771[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    772[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    773[0m:[38;5;10m[49m     result = execute_opencypher_query(query, {
[0m[49m[38;5;10m+    774[0m:[38;5;10m[49m         "npi": npi,
[0m[49m[38;5;10m+    775[0m:[38;5;10m[49m         "network_id": network_id,
[0m[49m[38;5;10m+    776[0m:[38;5;10m[49m         "term_date": term_date,
[0m[49m[38;5;10m+    777[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    778[0m:[38;5;10m[49m     logger.info("Terminated provider %s from network %s effective %s", npi, network_id, term_date)
[0m[49m[38;5;10m+    779[0m:[38;5;10m[49m     return result
[0m[49m[38;5;10m+    780[0m:[38;5;10m[49m ```
