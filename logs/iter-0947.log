[0m[49m[38;5;10m+    801[0m:[38;5;10m[49m         Summary of the load operation.
[0m[49m[38;5;10m+    802[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    803[0m:[38;5;10m[49m     # Step 1: Parse the NPI source file.
[0m[49m[38;5;10m+    804[0m:[38;5;10m[49m     logger.info("Step 1: Parsing NPI source data")
[0m[49m[38;5;10m+    805[0m:[38;5;10m[49m     providers = parse_npi_file(STAGING_BUCKET, npi_file_key)
[0m[49m[38;5;10m+    806[0m:[38;5;10m[49m     logger.info("  Parsed %d providers", len(providers))
[0m[49m[38;5;10m+    807[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    808[0m:[38;5;10m[49m     # Step 2: Build Neptune bulk load CSVs.
[0m[49m[38;5;10m+    809[0m:[38;5;10m[49m     logger.info("Step 2: Building bulk load CSVs")
[0m[49m[38;5;10m+    810[0m:[38;5;10m[49m     provider_csv = build_provider_nodes_csv(providers)
[0m[49m[38;5;10m+    811[0m:[38;5;10m[49m     location_csv = build_location_nodes_csv(providers)
[0m[49m[38;5;10m+    812[0m:[38;5;10m[49m     specialty_csv = build_specialty_nodes_csv()
[0m[49m[38;5;10m+    813[0m:[38;5;10m[49m     edges_csv = build_edges_csv(providers)
[0m[49m[38;5;10m+    814[0m:[38;5;10m[49m     logger.info("  CSVs built for providers, locations, specialties, and edges")
[0m[49m[38;5;10m+    815[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    816[0m:[38;5;10m[49m     # Step 3: Upload CSVs to S3 and trigger Neptune bulk loader.
[0m[49m[38;5;10m+    817[0m:[38;5;10m[49m     logger.info("Step 3: Uploading to S3 and triggering bulk load")
[0m[49m[38;5;10m+    818[0m:[38;5;10m[49m     s3_prefix = upload_csvs_to_s3(provider_csv, location_csv, specialty_csv, edges_csv)
[0m[49m[38;5;10m+    819[0m:[38;5;10m[49m     load_result = trigger_bulk_load(s3_prefix)
[0m[49m[38;5;10m+    820[0m:[38;5;10m[49m     logger.info("  Bulk load triggered: %s", load_result["load_id"])
[0m[49m[38;5;10m+    821[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    822[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    823[0m:[38;5;10m[49m         "providers_parsed": len(providers),
[0m[49m[38;5;10m+    824[0m:[38;5;10m[49m         "s3_prefix": s3_prefix,
[0m[49m[38;5;10m+    825[0m:[38;5;10m[49m         "load_id": load_result["load_id"],
[0m[49m[38;5;10m+    826[0m:[38;5;10m[49m         "load_status": load_result["status"],
[0m[49m[38;5;10m+    827[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    828[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    829[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    830[0m:[38;5;10m[49m # Example: run the full pipeline.
[0m[49m[38;5;10m+    831[0m:[38;5;10m[49m if __name__ == "__main__":
[0m[49m[38;5;10m+    832[0m:[38;5;10m[49m     # Load the graph from an NPI extract file.
[0m[49m[38;5;10m+    833[0m:[38;5;10m[49m     result = run_full_directory_load(
[0m[49m[38;5;10m+    834[0m:[38;5;10m[49m         npi_file_key="source-data/npi-extract-2026-05.csv"
[0m[49m[38;5;10m+    835[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    836[0m:[38;5;10m[49m     print(json.dumps(result, indent=2))
[0m[49m[38;5;10m+    837[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    838[0m:[38;5;10m[49m     # Query the graph: find cardiologists in Kentucky.
[0m[49m[38;5;10m+    839[0m:[38;5;10m[49m     providers = search_providers(
[0m[49m[38;5;10m+    840[0m:[38;5;10m[49m         specialty_code="207RC0000X",  # Cardiovascular Disease
[0m[49m[38;5;10m+    841[0m:[38;5;10m[49m         state="KY",
[0m[49m[38;5;10m+    842[0m:[38;5;10m[49m         zip_code="40202",
[0m[49m[38;5;10m+    843[0m:[38;5;10m[49m         gender="F",
[0m[49m[38;5;10m+    844[0m:[38;5;10m[49m         accepting_new=True,
[0m[49m[38;5;10m+    845[0m:[38;5;10m[49m         limit=10,
[0m[49m[38;5;10m+    846[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    847[0m:[38;5;10m[49m     print(f"\nFound {len(providers)} matching providers:")
[0m[49m[38;5;10m+    848[0m:[38;5;10m[49m     for p in providers:
[0m[49m[38;5;10m+    849[0m:[38;5;10m[49m         print(f"  {p['name']} - {p['specialty']} - {p['location']['city']}, {p['location']['state']}")
[0m[49m[38;5;10m+    850[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    851[0m:[38;5;10m[49m 
