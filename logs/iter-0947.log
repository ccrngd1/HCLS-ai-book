[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m     "member_of": "MEMBER_OF",
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m     "in_network": "IN_NETWORK",
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m     "located_in": "LOCATED_IN",
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m     "is_subspecialty": "IS_SUBSPECIALTY",
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m     "covers_for": "COVERS_FOR",
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m # A small subset of NUCC taxonomy codes for cardiology specialties.
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m # In production, you'd load the full NUCC taxonomy file (~800 codes)
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m # and build the hierarchy from it. This subset demonstrates the pattern.
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m SAMPLE_SPECIALTY_HIERARCHY = {
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m     "207R00000X": {"name": "Internal Medicine", "parent": None},
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m     "207RC0000X": {"name": "Cardiovascular Disease", "parent": "207R00000X"},
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m     "207RI0011X": {"name": "Interventional Cardiology", "parent": "207RC0000X"},
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m     "207RE0101X": {"name": "Cardiac Electrophysiology", "parent": "207RC0000X"},
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m     "207RH0003X": {"name": "Hematology & Oncology", "parent": "207R00000X"},
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m     "2086S0120X": {"name": "Pediatric Cardiology", "parent": None},
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m     "208600000X": {"name": "Surgery", "parent": None},
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m     "2086S0105X": {"name": "Cardiothoracic Surgery", "parent": "208600000X"},
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m 
