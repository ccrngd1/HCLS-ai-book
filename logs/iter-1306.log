[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m # Synthetic clinical notes for demonstration.
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m # In a real system, these come from S3 (de-identified EHR exports).
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m # These are entirely fictional patients with fictional clinical narratives.
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m SYNTHETIC_NOTES = [
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m     {
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m         "note_id": "note-2024-03-15-psych",
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m         "note_date": "2024-03-15",
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m         "note_type": "Psychiatry Consult",
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m         "text": (
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m             "Patient is a 42-year-old female with a history of major depressive "
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m             "disorder, recurrent, severe. She has been struggling with persistent "
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m             "depressive symptoms for the past 3 years despite multiple medication "
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m             "trials. She initially tried sertraline titrated to 200mg daily for "
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m             "12 weeks without adequate response. Subsequently switched to "
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m             "venlafaxine extended-release, titrated to 225mg daily for 10 weeks, "
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m             "also without significant improvement in PHQ-9 scores. Current PHQ-9 "
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m             "remains 18, indicating moderately severe depression. No suicidal "
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m             "ideation. Patient denies any family history of bipolar disorder. "
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m             "Assessment: Treatment-resistant major depressive disorder. Plan: "
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m             "Consider augmentation strategy with aripiprazole or lithium."
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m         ),
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m     {
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m         "note_id": "note-2024-06-22-pcp",
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m         "note_date": "2024-06-22",
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m         "note_type": "Primary Care Visit",
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m         "text": (
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m             "Follow-up visit. Patient continues to endorse low mood, anhedonia, "
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m             "and poor sleep despite trials of two antidepressants (sertraline and "
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m             "Effexor) at therapeutic doses. She was recently started on bupropion "
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m             "300mg daily as augmentation by her psychiatrist. Labs from last month "
