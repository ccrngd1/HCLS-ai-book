[0m[49m[38;5;10m+      5[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+      6[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      7[0m:[38;5;10m[49m ## Setup
[0m[49m[38;5;10m+      8[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      9[0m:[38;5;10m[49m You'll need the AWS SDK for Python and a few standard libraries:
[0m[49m[38;5;10m+     10[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     11[0m:[38;5;10m[49m ```bash
[0m[49m[38;5;10m+     12[0m:[38;5;10m[49m pip install boto3
[0m[49m[38;5;10m+     13[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     14[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     15[0m:[38;5;10m[49m Your environment needs credentials configured (via environment variables, instance profile, or `~/.aws/credentials`). The IAM role or user needs:
[0m[49m[38;5;10m+     16[0m:[38;5;10m[49m - `comprehend:DetectEntitiesV2`
[0m[49m[38;5;10m+     17[0m:[38;5;10m[49m - `comprehend:InferRxNorm`
[0m[49m[38;5;10m+     18[0m:[38;5;10m[49m - `comprehend:InferICD10CM`
[0m[49m[38;5;10m+     19[0m:[38;5;10m[49m - `s3:GetObject`, `s3:PutObject`
[0m[49m[38;5;10m+     20[0m:[38;5;10m[49m - `dynamodb:PutItem`, `dynamodb:Query`
[0m[49m[38;5;10m+     21[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     22[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     23[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     24[0m:[38;5;10m[49m ## Config and Constants
[0m[49m[38;5;10m+     25[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     26[0m:[38;5;10m[49m Before the processing logic, here are the configuration structures that define the phenotype and drive the extraction. These are really the heart of the system: change these, and the pipeline looks for completely different things.
[0m[49m[38;5;10m+     27[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     28[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     29[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+     30[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+     31[0m:[38;5;10m[49m import datetime
[0m[49m[38;5;10m+     32[0m:[38;5;10m[49m from datetime import timezone
[0m[49m[38;5;10m+     33[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+     34[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     35[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+     36[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+     37[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     38[0m:[38;5;10m[49m # Structured logging. In production, use JSON output for CloudWatch Logs Insights.
[0m[49m[38;5;10m+     39[0m:[38;5;10m[49m # PHI Safety: Never log raw clinical text, patient identifiers, or extracted values.
[0m[49m[38;5;10m+     40[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+     41[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+     42[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     43[0m:[38;5;10m[49m # Adaptive retry handles Comprehend Medical throttling under burst load.
[0m[49m[38;5;10m+     44[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 5, "mode": "adaptive"})
[0m[49m[38;5;10m+     45[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     46[0m:[38;5;10m[49m # AWS clients
[0m[49m[38;5;10m+     47[0m:[38;5;10m[49m comprehend_medical = boto3.client("comprehend-medical", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     48[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     49[0m:[38;5;10m[49m s3 = boto3.client("s3", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m # Table and bucket names. Replace with your actual resources.
[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m EVIDENCE_TABLE_NAME = "phenotype-evidence"
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m RESULTS_BUCKET = "phenotype-results"
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m # Minimum confidence for an extracted entity to count as evidence.
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m # Below this, the extraction is too uncertain to use in research classification.
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m # 0.80 is conservative. Some teams use 0.70 for recall-focused phenotypes.
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m CONFIDENCE_THRESHOLD = 0.80
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m ```
