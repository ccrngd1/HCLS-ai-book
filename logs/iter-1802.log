[0m[49m[38;5;10m+      338[0m:[38;5;10m[49m **Step 6: Monitor graph freshness.** A provider directory that silently goes stale is worse than one that doesn't exist, because users trust it. You need custom CloudWatch metrics that answer three questions: "When was the last successful load?", "How current is the data?", and "How much of the graph is expired?" These metrics drive alerts and power a health endpoint that consuming applications can check before trusting results.
[0m[49m[38;5;10m+      339[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      340[0m:[38;5;10m[49m ```pseudocode
[0m[49m[38;5;10m+      341[0m:[38;5;10m[49m FUNCTION publish_freshness_metrics(neptune_endpoint, cloudwatch_client):
[0m[49m[38;5;10m+      342[0m:[38;5;10m[49m     // Metric 1: Last successful bulk load timestamp.
[0m[49m[38;5;10m+      343[0m:[38;5;10m[49m     // Alert if this exceeds 48 hours, meaning the nightly refresh failed
[0m[49m[38;5;10m+      344[0m:[38;5;10m[49m     // or didn't run. This catches silent pipeline failures that leave
[0m[49m[38;5;10m+      345[0m:[38;5;10m[49m     // the graph serving increasingly stale data.
[0m[49m[38;5;10m+      346[0m:[38;5;10m[49m     last_load_time = query Neptune:
[0m[49m[38;5;10m+      347[0m:[38;5;10m[49m         MATCH (m:MetadataNode {type: "bulk_load"})
[0m[49m[38;5;10m+      348[0m:[38;5;10m[49m         RETURN m.last_success_timestamp
[0m[49m[38;5;10m+      349[0m:[38;5;10m[49m         ORDER BY m.last_success_timestamp DESC
[0m[49m[38;5;10m+      350[0m:[38;5;10m[49m         LIMIT 1
[0m[49m[38;5;10m+      351[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      352[0m:[38;5;10m[49m     cloudwatch_client.put_metric_data(
[0m[49m[38;5;10m+      353[0m:[38;5;10m[49m         namespace = "ProviderDirectory/GraphFreshness",
[0m[49m[38;5;10m+      354[0m:[38;5;10m[49m         metric_name = "LastBulkLoadAgeHours",
[0m[49m[38;5;10m+      355[0m:[38;5;10m[49m         value = hours_since(last_load_time),
[0m[49m[38;5;10m+      356[0m:[38;5;10m[49m         unit = "Count"
[0m[49m[38;5;10m+      357[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+      358[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      359[0m:[38;5;10m[49m     // Metric 2: Percentage of provider records updated in the last 30 days.
[0m[49m[38;5;10m+      360[0m:[38;5;10m[49m     // A healthy directory sees regular churn (providers update addresses,
[0m[49m[38;5;10m+      361[0m:[38;5;10m[49m     // accepting status, etc.). If this drops below ~60%, something is wrong
[0m[49m[38;5;10m+      362[0m:[38;5;10m[49m     // with the incremental update pipeline.
[0m[49m[38;5;10m+      363[0m:[38;5;10m[49m     freshness_query = query Neptune:
[0m[49m[38;5;10m+      364[0m:[38;5;10m[49m         MATCH (p:Provider)
[0m[49m[38;5;10m+      365[0m:[38;5;10m[49m         WITH count(p) AS total,
[0m[49m[38;5;10m+      366[0m:[38;5;10m[49m              count(CASE WHEN p.last_updated > date_minus(today(), 30)
[0m[49m[38;5;10m+      367[0m:[38;5;10m[49m                         THEN 1 END) AS recent
[0m[49m[38;5;10m+      368[0m:[38;5;10m[49m         RETURN toFloat(recent) / total * 100 AS pct_updated_30d
[0m[49m[38;5;10m+      369[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      370[0m:[38;5;10m[49m     cloudwatch_client.put_metric_data(
[0m[49m[38;5;10m+      371[0m:[38;5;10m[49m         namespace = "ProviderDirectory/GraphFreshness",
[0m[49m[38;5;10m+      372[0m:[38;5;10m[49m         metric_name = "PercentRecordsUpdated30Days",
[0m[49m[38;5;10m+      373[0m:[38;5;10m[49m         value = freshness_query.pct_updated_30d,
[0m[49m[38;5;10m+      374[0m:[38;5;10m[49m         unit = "Percent"
[0m[49m[38;5;10m+      375[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+      376[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      377[0m:[38;5;10m[49m     // Metric 3: Count of IN_NETWORK edges with term_date in the past.
[0m[49m[38;5;10m+      378[0m:[38;5;10m[49m     // These are expired network participations still in the graph.
[0m[49m[38;5;10m+      379[0m:[38;5;10m[49m     // A small count is normal (historical records). A spike means
[0m[49m[38;5;10m+      380[0m:[38;5;10m[49m     // a network termination file was loaded without proper processing,
[0m[49m[38;5;10m+      381[0m:[38;5;10m[49m     // or the term_date filter in search queries isn't working.
[0m[49m[38;5;10m+      382[0m:[38;5;10m[49m     expired_edges = query Neptune:
[0m[49m[38;5;10m+      383[0m:[38;5;10m[49m         MATCH ()-[r:IN_NETWORK]->()
[0m[49m[38;5;10m+      384[0m:[38;5;10m[49m         WHERE r.term_date < today()
[0m[49m[38;5;10m+      385[0m:[38;5;10m[49m         RETURN count(r) AS expired_count
[0m[49m[38;5;10m+      386[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      387[0m:[38;5;10m[49m     cloudwatch_client.put_metric_data(
[0m[49m[38;5;10m+      388[0m:[38;5;10m[49m         namespace = "ProviderDirectory/GraphFreshness",
[0m[49m[38;5;10m+      389[0m:[38;5;10m[49m         metric_name = "ExpiredNetworkEdges",
[0m[49m[38;5;10m+      390[0m:[38;5;10m[49m         value = expired_edges.expired_count,
[0m[49m[38;5;10m+      391[0m:[38;5;10m[49m         unit = "Count"
[0m[49m[38;5;10m+      392[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+      393[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      394[0m:[38;5;10m[49m // Run this on a schedule (every 15 minutes via EventBridge rule triggering Lambda).
[0m[49m[38;5;10m+      395[0m:[38;5;10m[49m // CloudWatch alarms:
[0m[49m[38;5;10m+      396[0m:[38;5;10m[49m //   - LastBulkLoadAgeHours > 48  -> P2 alert to data engineering on-call
[0m[49m[38;5;10m+      397[0m:[38;5;10m[49m //   - PercentRecordsUpdated30Days < 60 -> P3 alert for investigation
[0m[49m[38;5;10m+      398[0m:[38;5;10m[49m //   - ExpiredNetworkEdges > previous_day * 1.5 -> P3 anomaly alert
[0m[49m[38;5;10m+      399[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      400[0m:[38;5;10m[49m FUNCTION health_endpoint(neptune_endpoint):
[0m[49m[38;5;10m+      401[0m:[38;5;10m[49m     // Expose a /health route on the query API that consuming applications
[0m[49m[38;5;10m+      402[0m:[38;5;10m[49m     // can check before trusting search results. Returns graph freshness
[0m[49m[38;5;10m+      403[0m:[38;5;10m[49m     // metadata so callers can display warnings or degrade gracefully
[0m[49m[38;5;10m+      404[0m:[38;5;10m[49m     // when data is stale.
[0m[49m[38;5;10m+      405[0m:[38;5;10m[49m     last_load = get_last_bulk_load_timestamp(neptune_endpoint)
[0m[49m[38;5;10m+      406[0m:[38;5;10m[49m     record_freshness = get_percent_updated_30d(neptune_endpoint)
[0m[49m[38;5;10m+      407[0m:[38;5;10m[49m     node_count = query Neptune: MATCH (p:Provider) RETURN count(p)
[0m[49m[38;5;10m+      408[0m:[38;5;10m[49m     edge_count = query Neptune: MATCH ()-[r]->() RETURN count(r)
[0m[49m[38;5;10m+      409[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      410[0m:[38;5;10m[49m     RETURN {
[0m[49m[38;5;10m+      411[0m:[38;5;10m[49m         "status": "healthy" IF hours_since(last_load) < 48 ELSE "degraded",
[0m[49m[38;5;10m+      412[0m:[38;5;10m[49m         "last_bulk_load": last_load,
[0m[49m[38;5;10m+      413[0m:[38;5;10m[49m         "hours_since_last_load": hours_since(last_load),
[0m[49m[38;5;10m+      414[0m:[38;5;10m[49m         "percent_records_fresh_30d": record_freshness,
[0m[49m[38;5;10m+      415[0m:[38;5;10m[49m         "provider_count": node_count,
[0m[49m[38;5;10m+      416[0m:[38;5;10m[49m         "edge_count": edge_count,
[0m[49m[38;5;10m+      417[0m:[38;5;10m[49m         "checked_at": now()
[0m[49m[38;5;10m+      418[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+      419[0m:[38;5;10m[49m ```
