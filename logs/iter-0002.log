[0m[48;2;40;67;43m[39m+    423[0m:[39m[48;2;24;38;30m [38;2;208;135;112m>[38;2;208;135;112m [38;2;191;97;106m-[38;2;191;97;106m [38;2;191;97;106mTake aspirin 81mg every day[K
[0m[48;2;40;67;43m[39m+    424[0m:[39m[48;2;24;38;30m [38;2;208;135;112m>[38;2;208;135;112m [38;2;191;97;106m-[38;2;191;97;106m [38;2;191;97;106mTake clopidogrel (Plavix) 75mg every day[K
[0m[48;2;40;67;43m[39m+    425[0m:[39m[48;2;24;38;30m [38;2;208;135;112m>[38;2;208;135;112m [38;2;191;97;106m-[38;2;191;97;106m [38;2;191;97;106mTake both of these for 12 months. Do not stop without talking to your heart doctor.[K
