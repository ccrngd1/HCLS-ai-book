[0m[48;2;40;67;43m[39m+    263[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        temperature = 0.2                // low creativity, high consistency[K
[0m[48;2;40;67;43m[39m+    264[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        max_tokens  = 2048               // enough for a full simplified document[K
