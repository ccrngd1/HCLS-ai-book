[0m[48;2;40;67;43m[39m+    433[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m--------[38;2;192;197;206m|[38;2;192;197;206m---------------[38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    434[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m End-to-end latency [38;2;192;197;206m|[38;2;192;197;206m 2-5 seconds per document [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    435[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Readability improvement [38;2;192;197;206m|[38;2;192;197;206m 6-8 grade levels reduction [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    436[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Entity preservation rate [38;2;192;197;206m|[38;2;192;197;206m 95-98% (medications, conditions) [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    437[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Readability target hit rate [38;2;192;197;206m|[38;2;192;197;206m 85-90% on first attempt [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    438[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Cost per simplification [38;2;192;197;206m|[38;2;192;197;206m ~$0.02-0.04 (Bedrock + Comprehend Medical) [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    439[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Retry rate [38;2;192;197;206m|[38;2;192;197;206m 10-15% (readability failures) [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    440[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Human review rate [38;2;192;197;206m|[38;2;192;197;206m 2-5% (accuracy failures) [38;2;192;197;206m|[K
