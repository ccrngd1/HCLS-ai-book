[0m[48;2;40;67;43m[39m+    245[0m:[39m[48;2;24;38;30m [38;2;192;197;206m    """[K
[0m[48;2;40;67;43m[39m+    246[0m:[39m[48;2;24;38;30m [K
[0m[48;2;40;67;43m[39m+    247[0m:[39m[48;2;24;38;30m [38;2;192;197;206m    RETURN system_prompt, user_prompt[K
