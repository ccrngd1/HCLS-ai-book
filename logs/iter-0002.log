[0m[48;2;40;67;43m[39m+    399[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        doc_type             = doc_type[K
[0m[48;2;40;67;43m[39m+    400[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        original_text        = original_text[K
[0m[48;2;40;67;43m[39m+    401[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        simplified_text      = simplified_text[K
[0m[48;2;40;67;43m[39m+    402[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        readability_scores   = readability[K
[0m[48;2;40;67;43m[39m+    403[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        validation_result    = quality_result[K
