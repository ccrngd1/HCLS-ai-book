[0m[49m[38;5;10m+      7[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+      8[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      9[0m:[38;5;10m[49m ## Setup
[0m[49m[38;5;10m+     10[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     11[0m:[38;5;10m[49m You'll need the AWS SDK for Python and a few scientific computing libraries:
[0m[49m[38;5;10m+     12[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     13[0m:[38;5;10m[49m ```bash
[0m[49m[38;5;10m+     14[0m:[38;5;10m[49m pip install boto3 numpy pandas scikit-learn
[0m[49m[38;5;10m+     15[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     16[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     17[0m:[38;5;10m[49m Your environment needs credentials configured (via environment variables, an instance profile, or `~/.aws/credentials`). The IAM role or user needs:
[0m[49m[38;5;10m+     18[0m:[38;5;10m[49m - `s3:GetObject` and `s3:PutObject` (reading utilization data, writing segment assignments)
[0m[49m[38;5;10m+     19[0m:[38;5;10m[49m - `dynamodb:PutItem` and `dynamodb:BatchWriteItem` (storing segment profiles and member assignments)
[0m[49m[38;5;10m+     20[0m:[38;5;10m[49m - `sagemaker:CreateProcessingJob` (if running at scale via SageMaker Processing)
[0m[49m[38;5;10m+     21[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     22[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     23[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     24[0m:[38;5;10m[49m ## Config and Constants
[0m[49m[38;5;10m+     25[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     26[0m:[38;5;10m[49m These go at the top of your module. They define the utilization features we'll cluster on, the segment labels we expect to discover, and the infrastructure targets.
[0m[49m[38;5;10m+     27[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     28[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     29[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+     30[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+     31[0m:[38;5;10m[49m import datetime
[0m[49m[38;5;10m+     32[0m:[38;5;10m[49m from datetime import timezone
[0m[49m[38;5;10m+     33[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+     34[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     35[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+     36[0m:[38;5;10m[49m import numpy as np
[0m[49m[38;5;10m+     37[0m:[38;5;10m[49m import pandas as pd
[0m[49m[38;5;10m+     38[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+     39[0m:[38;5;10m[49m from sklearn.preprocessing import StandardScaler
[0m[49m[38;5;10m+     40[0m:[38;5;10m[49m from sklearn.cluster import KMeans
[0m[49m[38;5;10m+     41[0m:[38;5;10m[49m from sklearn.metrics import silhouette_score
[0m[49m[38;5;10m+     42[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     43[0m:[38;5;10m[49m # Structured logging. Never log member IDs or PHI in production.
[0m[49m[38;5;10m+     44[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+     45[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+     46[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     47[0m:[38;5;10m[49m # Retry config for AWS API calls.
[0m[49m[38;5;10m+     48[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+     49[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m # boto3 clients (module-level for Lambda container reuse).
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m s3_client = boto3.client("s3", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m # --- Feature Configuration ---
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m # These are the utilization dimensions we cluster on.
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m # Each feature captures a different aspect of how a member uses healthcare.
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m # The choice of features is the single most important design decision in this
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m # pipeline. Get these wrong and your segments will be meaningless.
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m UTILIZATION_FEATURES = [
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m     "ed_visits_12m",           # Emergency department visits in trailing 12 months
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m     "inpatient_admits_12m",    # Inpatient admissions in trailing 12 months
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m     "outpatient_visits_12m",   # Outpatient/office visits in trailing 12 months
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m     "rx_fills_12m",            # Prescription fills in trailing 12 months
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m     "preventive_visits_12m",   # Preventive/wellness visits in trailing 12 months
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m     "specialist_visits_12m",   # Specialist referral visits in trailing 12 months
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m     "telehealth_visits_12m",   # Telehealth encounters in trailing 12 months
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m     "total_allowed_12m",       # Total allowed amount (cost proxy) in trailing 12 months
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m # --- Clustering Configuration ---
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m # Number of segments to discover. 4-6 is typical for utilization segmentation.
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m # Too few and you lose actionable distinctions. Too many and care managers
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m # can't design distinct interventions for each segment.
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m N_CLUSTERS = 5
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m # Random seed for reproducibility. KMeans initialization is stochastic;
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m # setting this ensures you get the same segments on repeated runs with
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m # the same data. Change it when you want to explore alternative solutions.
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m RANDOM_SEED = 42
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m # --- Segment Labels ---
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m # After clustering, we assign human-readable labels based on the centroid
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m # characteristics. These are the labels population health teams actually use.
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m # The mapping from cluster number to label happens in the interpretation step.
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m SEGMENT_LABELS = [
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m     "Healthy/Preventive",      # Low utilization, mostly wellness visits
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m     "Episodic/Acute",          # Occasional ED or urgent care, low chronic
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m     "Chronic/Managed",         # Regular outpatient, high Rx, moderate cost
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m     "Rising Risk",             # Increasing utilization, specialist-heavy
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m     "High Utilizer/Complex",   # High across all dimensions, highest cost
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m # --- Infrastructure ---
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m RESULTS_TABLE_NAME = "utilization-segments"
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m OUTPUT_BUCKET = "population-health-analytics"
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m OUTPUT_PREFIX = "segments/utilization/"
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m ## Step 1: Generate Synthetic Utilization Data
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m *In production, this step is replaced by a query against your claims data warehouse or data lake. We generate synthetic data here so you can run the full pipeline without access to real claims. The distributions are modeled after typical commercial health plan populations.*
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m def generate_synthetic_utilization_data(n_members: int = 5000) -> pd.DataFrame:
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m     Generate synthetic member utilization data for demonstration.
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m     The distributions here are loosely modeled after a typical commercial
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m     health plan population:
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m     - ~60% of members are low utilizers (healthy, preventive-only)
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m     - ~20% are episodic (occasional acute events)
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m     - ~12% are chronic/managed (regular but stable utilization)
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m     - ~5% are rising risk (increasing complexity)
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m     - ~3% are high utilizers (complex, multi-system, expensive)
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m     These proportions aren't exact because we're generating from continuous
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m     distributions, not discrete buckets. The clustering algorithm will
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m     discover the natural groupings from the data itself.
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m         n_members: Number of synthetic members to generate.
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m         DataFrame with one row per member and columns matching UTILIZATION_FEATURES.
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m     rng = np.random.default_rng(RANDOM_SEED)
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m     # We'll generate each "archetype" separately, then combine.
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m     # This gives us realistic multivariate correlations within each group.
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m     # Healthy/Preventive (~60%): low everything, 1-2 preventive visits
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m     n_healthy = int(n_members * 0.60)
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m     healthy = pd.DataFrame({
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m         "ed_visits_12m": rng.poisson(0.05, n_healthy),
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m         "inpatient_admits_12m": rng.poisson(0.01, n_healthy),
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m         "outpatient_visits_12m": rng.poisson(2.0, n_healthy),
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m         "rx_fills_12m": rng.poisson(1.5, n_healthy),
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m         "preventive_visits_12m": rng.poisson(1.5, n_healthy),
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m         "specialist_visits_12m": rng.poisson(0.3, n_healthy),
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m         "telehealth_visits_12m": rng.poisson(0.5, n_healthy),
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m         "total_allowed_12m": rng.lognormal(6.5, 0.8, n_healthy),  # ~$650 median
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m     # Episodic/Acute (~20%): occasional ED, some urgent care
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m     n_episodic = int(n_members * 0.20)
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m     episodic = pd.DataFrame({
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m         "ed_visits_12m": rng.poisson(1.5, n_episodic),
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m         "inpatient_admits_12m": rng.poisson(0.2, n_episodic),
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m         "outpatient_visits_12m": rng.poisson(4.0, n_episodic),
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m         "rx_fills_12m": rng.poisson(4.0, n_episodic),
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m         "preventive_visits_12m": rng.poisson(0.8, n_episodic),
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m         "specialist_visits_12m": rng.poisson(1.0, n_episodic),
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m         "telehealth_visits_12m": rng.poisson(1.0, n_episodic),
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m         "total_allowed_12m": rng.lognormal(8.0, 0.7, n_episodic),  # ~$3,000 median
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m     # Chronic/Managed (~12%): regular outpatient, high Rx
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m     n_chronic = int(n_members * 0.12)
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m     chronic = pd.DataFrame({
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m         "ed_visits_12m": rng.poisson(0.8, n_chronic),
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m         "inpatient_admits_12m": rng.poisson(0.3, n_chronic),
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m         "outpatient_visits_12m": rng.poisson(8.0, n_chronic),
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m         "rx_fills_12m": rng.poisson(12.0, n_chronic),
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m         "preventive_visits_12m": rng.poisson(1.2, n_chronic),
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m         "specialist_visits_12m": rng.poisson(3.0, n_chronic),
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m         "telehealth_visits_12m": rng.poisson(2.0, n_chronic),
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m         "total_allowed_12m": rng.lognormal(8.8, 0.6, n_chronic),  # ~$6,600 median
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m     # Rising Risk (~5%): increasing specialist use, moderate ED
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m     n_rising = int(n_members * 0.05)
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m     rising = pd.DataFrame({
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m         "ed_visits_12m": rng.poisson(2.0, n_rising),
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m         "inpatient_admits_12m": rng.poisson(0.8, n_rising),
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m         "outpatient_visits_12m": rng.poisson(10.0, n_rising),
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m         "rx_fills_12m": rng.poisson(15.0, n_rising),
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m         "preventive_visits_12m": rng.poisson(0.5, n_rising),
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m         "specialist_visits_12m": rng.poisson(6.0, n_rising),
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m         "telehealth_visits_12m": rng.poisson(3.0, n_rising),
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m         "total_allowed_12m": rng.lognormal(9.5, 0.5, n_rising),  # ~$13,000 median
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m     # High Utilizer/Complex (~3%): high across the board
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m     n_high = n_members - n_healthy - n_episodic - n_chronic - n_rising
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m     high = pd.DataFrame({
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m         "ed_visits_12m": rng.poisson(5.0, n_high),
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m         "inpatient_admits_12m": rng.poisson(2.5, n_high),
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m         "outpatient_visits_12m": rng.poisson(15.0, n_high),
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m         "rx_fills_12m": rng.poisson(20.0, n_high),
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m         "preventive_visits_12m": rng.poisson(0.3, n_high),
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m         "specialist_visits_12m": rng.poisson(8.0, n_high),
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m         "telehealth_visits_12m": rng.poisson(4.0, n_high),
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m         "total_allowed_12m": rng.lognormal(10.5, 0.6, n_high),  # ~$36,000 median
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m     # Combine all archetypes and shuffle.
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m     df = pd.concat([healthy, episodic, chronic, rising, high], ignore_index=True)
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m     df = df.sample(frac=1, random_state=RANDOM_SEED).reset_index(drop=True)
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m     # Add synthetic member IDs.
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m     df.insert(0, "member_id", [f"MBR-{i:06d}" for i in range(len(df))])
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m     # Round cost to 2 decimal places (dollars and cents).
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m     df["total_allowed_12m"] = df["total_allowed_12m"].round(2)
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m     logger.info("Generated %d synthetic member records", len(df))
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m     return df
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m ## Step 2: Feature Engineering and Scaling
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m *The pseudocode calls this `prepare_features(utilization_df)`. Before clustering, we need to standardize the features so that high-magnitude columns (like total_allowed_12m in dollars) don't dominate the distance calculations over low-magnitude columns (like inpatient_admits which might be 0-3). StandardScaler centers each feature at mean=0 and scales to unit variance.*
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m def prepare_features(df: pd.DataFrame) -> tuple[np.ndarray, StandardScaler]:
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m     Extract utilization features and standardize them for clustering.
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m     Why standardize? KMeans uses Euclidean distance. If total_allowed_12m
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m     ranges from $200 to $100,000 while ed_visits ranges from 0 to 10,
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m     the cost column will completely dominate the distance calculation.
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m     Standardization puts all features on equal footing.
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m     We also clip extreme outliers before scaling. A single member with
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m     $500,000 in allowed charges would distort the scaling for everyone else.
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m     Clipping at the 99th percentile preserves the "high" signal without
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m     letting extreme values warp the feature space.
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m         df: DataFrame with utilization columns matching UTILIZATION_FEATURES.
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m         Tuple of (scaled feature matrix, fitted scaler object).
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m         The scaler is returned so we can inverse-transform centroids later
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m         for interpretation in original units.
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m     # Extract just the feature columns.
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m     feature_matrix = df[UTILIZATION_FEATURES].copy()
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m     # Clip outliers at the 99th percentile per feature.
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m     # This prevents extreme values from distorting the scaling.
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     # We clip rather than remove because these members still need segment assignments.
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m     for col in UTILIZATION_FEATURES:
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m         cap = feature_matrix[col].quantile(0.99)
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m         feature_matrix[col] = feature_matrix[col].clip(upper=cap)
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m     # Standardize: mean=0, std=1 for each feature.
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m     scaler = StandardScaler()
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m     scaled = scaler.fit_transform(feature_matrix.values)
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m         "Prepared feature matrix: %d members x %d features",
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m         scaled.shape[0], scaled.shape[1]
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m     return scaled, scaler
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m ## Step 3: Run KMeans Clustering
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m *The pseudocode calls this `cluster_members(scaled_features)`. KMeans is the workhorse here. It's not the fanciest algorithm, but it's fast, interpretable, and produces segments that population health teams can actually act on. The key decision is the number of clusters (k). We use the silhouette score to validate that our chosen k produces well-separated segments.*
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m def cluster_members(scaled_features: np.ndarray) -> tuple[np.ndarray, np.ndarray, float]:
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m     Run KMeans clustering on the scaled utilization features.
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m     Why KMeans and not DBSCAN, Gaussian Mixture, or hierarchical clustering?
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m     For utilization segmentation specifically:
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m     - KMeans produces convex, roughly equal-sized clusters. That maps well
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m       to "segments" that care management teams can design programs around.
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m     - The centroids are directly interpretable: each centroid IS the average
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m       utilization profile for that segment.
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m     - It scales linearly with data size. You can run this on 2 million members
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m       without special infrastructure.
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m     - Population health teams expect a fixed number of segments they can name
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m       and build interventions for. KMeans gives you exactly k segments.
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m     The tradeoff: KMeans assumes spherical clusters of similar size. Real
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m     utilization data is skewed (lots of healthy members, few high utilizers).
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m     The standardization in Step 2 helps, but the "Healthy" segment will still
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m     be much larger than "High Utilizer." That's fine for this use case because
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m     the segments are actionable regardless of size.
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m         scaled_features: Standardized feature matrix from prepare_features.
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m         Tuple of (cluster_labels, centroids, silhouette_avg):
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m         - cluster_labels: array of cluster assignments (0 to k-1) per member
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m         - centroids: k x n_features matrix of cluster centers (in scaled space)
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m         - silhouette_avg: average silhouette score (higher = better separation)
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m     kmeans = KMeans(
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m         n_clusters=N_CLUSTERS,
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m         random_state=RANDOM_SEED,
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m         n_init=10,        # Run 10 initializations, keep the best
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m         max_iter=300,     # Usually converges in 20-50 iterations
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m     cluster_labels = kmeans.fit_predict(scaled_features)
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m     centroids = kmeans.cluster_centers_
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m     # Silhouette score: measures how similar each point is to its own cluster
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m     # vs. the nearest neighboring cluster. Ranges from -1 to 1.
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m     # > 0.5 = strong structure, 0.25-0.5 = reasonable, < 0.25 = weak/overlapping.
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m     # For utilization data, 0.3-0.5 is typical and acceptable.
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m     silhouette_avg = silhouette_score(scaled_features, cluster_labels)
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m         "KMeans converged. %d clusters, silhouette score: %.3f",
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m         N_CLUSTERS, silhouette_avg
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m     return cluster_labels, centroids, silhouette_avg
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m ## Step 4: Interpret and Label Segments
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m *The pseudocode calls this `interpret_segments(centroids, scaler)`. This is where the math becomes actionable. We inverse-transform the centroids back to original units (visits, dollars) so population health teams can understand what each segment actually looks like. Then we assign human-readable labels based on the centroid characteristics.*
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m def interpret_segments(
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m     centroids: np.ndarray,
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m     scaler: StandardScaler,
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m     df: pd.DataFrame,
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m     cluster_labels: np.ndarray,
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m ) -> list[dict]:
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m     Convert cluster centroids back to interpretable units and assign labels.
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m     The centroids from KMeans are in standardized space (mean=0, std=1).
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m     That's useful for the algorithm but meaningless to a care manager.
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m     We inverse-transform them back to original units: visits per year,
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m     dollars per year. Then we rank the clusters by total cost (the most
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m     intuitive ordering for population health) and assign labels.
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m     The labeling logic here is heuristic: we sort clusters by total_allowed
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m     and assign labels from lowest-cost to highest-cost. This works because
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m     utilization cost is strongly correlated with overall complexity. In
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m     production, you'd validate these labels against clinical review.
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m         centroids: Cluster centers in scaled space (from cluster_members).
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m         scaler: The fitted StandardScaler (from prepare_features).
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m         df: Original DataFrame with member data.
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m         cluster_labels: Cluster assignment per member.
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m         List of segment profile dicts, one per cluster, sorted by cost.
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m         Each dict contains the label, centroid values in original units,
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m         member count, and percentage of population.
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m     # Inverse-transform centroids back to original feature units.
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m     centroids_original = scaler.inverse_transform(centroids)
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m     # Build a profile for each cluster.
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m     profiles = []
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m     total_members = len(cluster_labels)
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m     for cluster_idx in range(N_CLUSTERS):
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m         centroid = centroids_original[cluster_idx]
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m         member_count = int(np.sum(cluster_labels == cluster_idx))
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m         profile = {
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m             "cluster_id": int(cluster_idx),
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m             "member_count": member_count,
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m             "pct_of_population": round(member_count / total_members * 100, 1),
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m             "centroid": {
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m                 feature: round(float(centroid[i]), 2)
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m                 for i, feature in enumerate(UTILIZATION_FEATURES)
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m             },
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m         profiles.append(profile)
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m     # Sort by total_allowed (cost) ascending: cheapest segment first.
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m     profiles.sort(key=lambda p: p["centroid"]["total_allowed_12m"])
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m     # Assign human-readable labels based on cost ordering.
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m     # Lowest cost = Healthy/Preventive, highest = High Utilizer/Complex.
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m     for i, profile in enumerate(profiles):
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m         profile["segment_label"] = SEGMENT_LABELS[i]
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m         profile["segment_rank"] = i + 1  # 1 = lowest utilization
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m     logger.info("Segment profiles (sorted by cost):")
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m     for p in profiles:
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m         logger.info(
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m             "  %s: %d members (%.1f%%), avg cost $%.0f",
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m             p["segment_label"],
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m             p["member_count"],
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m             p["pct_of_population"],
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m             p["centroid"]["total_allowed_12m"],
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m     return profiles
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m ## Step 5: Store Segment Assignments and Profiles
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m *The pseudocode calls this `store_results(df, cluster_labels, profiles)`. We write two things: (1) the segment profiles (centroids, labels, counts) as a reference document, and (2) the per-member segment assignments so downstream systems can look up any member's segment.*
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m def store_results(
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m     df: pd.DataFrame,
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m     cluster_labels: np.ndarray,
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m     profiles: list[dict],
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m     silhouette_avg: float,
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m     Store segment profiles to S3 and member assignments to DynamoDB.
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m     Two outputs:
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m     1. S3: A JSON file with the full segment profiles, model metadata,
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m        and run timestamp. This is the reference document for population
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m        health teams to understand what each segment means.
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m     2. DynamoDB: One item per member with their segment assignment.
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m        This is the operational lookup table for downstream systems
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m        (care management platforms, outreach engines, dashboards).
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m         df: Original DataFrame with member_id column.
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m         cluster_labels: Cluster assignment per member (from cluster_members).
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m         profiles: Segment profiles from interpret_segments.
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m         silhouette_avg: Model quality metric.
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m         Summary dict with counts and S3 output path.
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m     run_timestamp = datetime.datetime.now(timezone.utc).isoformat()
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m     # --- Write segment profiles to S3 ---
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m     # This is the "model card" for this segmentation run.
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m     output_key = f"{OUTPUT_PREFIX}{run_timestamp[:10]}/segment_profiles.json"
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m     # Build a label lookup from cluster_id to segment_label.
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m     cluster_to_label = {p["cluster_id"]: p["segment_label"] for p in profiles}
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m     profile_document = {
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m         "run_timestamp": run_timestamp,
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m         "n_members": len(df),
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m         "n_clusters": N_CLUSTERS,
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m         "silhouette_score": round(silhouette_avg, 4),
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m         "features_used": UTILIZATION_FEATURES,
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m         "segments": profiles,
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m     s3_client.put_object(
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m         Bucket=OUTPUT_BUCKET,
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m         Key=output_key,
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m         Body=json.dumps(profile_document, indent=2, default=str),
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m         ContentType="application/json",
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m         ServerSideEncryption="aws:kms",
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m     logger.info("Wrote segment profiles to s3://%s/%s", OUTPUT_BUCKET, output_key)
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m     # --- Write per-member assignments to DynamoDB ---
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m     # Batch writes for efficiency. DynamoDB batch_write_item handles up to
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m     # 25 items per call.
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m     table = dynamodb.Table(RESULTS_TABLE_NAME)
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m     with table.batch_writer() as batch:
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m         for idx, row in df.iterrows():
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m             cluster_id = int(cluster_labels[idx])
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m             batch.put_item(Item={
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m                 "member_id": row["member_id"],
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m                 "segment_label": cluster_to_label[cluster_id],
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m                 "segment_rank": next(
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m                     p["segment_rank"] for p in profiles
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m                     if p["cluster_id"] == cluster_id
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m                 ),
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m                 "cluster_id": cluster_id,
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m                 "assigned_at": run_timestamp,
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m                 # Store key utilization metrics alongside the assignment
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m                 # so downstream systems don't need a second lookup.
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m                 "ed_visits_12m": int(row["ed_visits_12m"]),
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m                 "inpatient_admits_12m": int(row["inpatient_admits_12m"]),
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m                 "total_allowed_12m": Decimal(str(row["total_allowed_12m"])),
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m     logger.info("Wrote %d member assignments to DynamoDB", len(df))
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m         "output_s3_path": f"s3://{OUTPUT_BUCKET}/{output_key}",
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m         "members_processed": len(df),
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m         "segments_discovered": N_CLUSTERS,
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m         "silhouette_score": round(silhouette_avg, 4),
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m ## Putting It All Together
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m Here's the full pipeline assembled into a single function. Run it end-to-end to see the segmentation in action.
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m def run_utilization_segmentation(n_members: int = 5000) -> dict:
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m     Run the full utilization pattern segmentation pipeline.
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m     This function implements the complete flow from synthetic data generation
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m     through clustering, interpretation, and storage. In production, Step 1
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m     would be replaced by a query against your claims data warehouse.
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m         n_members: Number of members to segment (for synthetic data).
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m         Summary dict with segment profiles and quality metrics.
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m     # Step 1: Load utilization data.
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m     # In production: query your claims EDW or read from S3 data lake.
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m     logger.info("Step 1: Generating synthetic utilization data...")
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m     df = generate_synthetic_utilization_data(n_members)
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m     logger.info("  %d members with %d features each", len(df), len(UTILIZATION_FEATURES))
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m     # Step 2: Feature engineering and scaling.
