[49m[38;5;10m+      1[0m:[38;5;10m[49m # Recipe 13.1: Python Implementation Example
[0m[49m[38;5;10m+      2[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      3[0m:[38;5;10m[49m > **Heads up:** This is a deliberately simple, illustrative implementation of the pseudocode walkthrough from Recipe 13.1. It shows one way you could translate those graph concepts into working Python code using boto3 and Neptune's openCypher endpoint. It is not production-ready. There's no error handling, no retry logic, no connection pooling. Think of it as the sketchpad version: useful for understanding how the pieces fit together, not something you'd point at a real formulary on Monday morning. A starting point, not a destination.
[0m[49m[38;5;10m+      4[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      5[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+      6[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      7[0m:[38;5;10m[49m ## Setup
[0m[49m[38;5;10m+      8[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      9[0m:[38;5;10m[49m You'll need the AWS SDK for Python and a few supporting libraries:
[0m[49m[38;5;10m+     10[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     11[0m:[38;5;10m[49m ```bash
[0m[49m[38;5;10m+     12[0m:[38;5;10m[49m pip install boto3 requests
[0m[49m[38;5;10m+     13[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     14[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     15[0m:[38;5;10m[49m Your environment needs credentials configured (via environment variables, an instance profile, or `~/.aws/credentials`). The IAM role or user needs permissions for Neptune (`neptune-db:*` scoped to your cluster), S3 (`s3:GetObject` on the formulary bucket), and ElastiCache network access from your VPC.
[0m[49m[38;5;10m+     16[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     17[0m:[38;5;10m[49m Neptune doesn't use IAM for query authentication by default (it uses VPC-level network isolation), but if you've enabled IAM auth on your cluster, you'll need to sign requests with SigV4. This example assumes VPC network access without IAM auth for simplicity.
[0m[49m[38;5;10m+     18[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     19[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     20[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     21[0m:[38;5;10m[49m ## Config and Constants
[0m[49m[38;5;10m+     22[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     23[0m:[38;5;10m[49m Before we get to the steps, here's the configuration that drives the whole pipeline. These constants define how we map formulary file columns to graph entities, what our Neptune endpoint looks like, and how we structure cache keys.
[0m[49m[38;5;10m+     24[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     25[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     26[0m:[38;5;10m[49m # Neptune cluster endpoint. This is the writer endpoint for loads,
[0m[49m[38;5;10m+     27[0m:[38;5;10m[49m # and the reader endpoint for queries. In production, you'd use
[0m[49m[38;5;10m+     28[0m:[38;5;10m[49m # separate endpoints for read vs. write operations.
[0m[49m[38;5;10m+     29[0m:[38;5;10m[49m #
[0m[49m[38;5;10m+     30[0m:[38;5;10m[49m # Neptune runs inside your VPC. This code must execute from within
[0m[49m[38;5;10m+     31[0m:[38;5;10m[49m # the same VPC (Lambda in VPC, EC2, ECS, etc.) to reach it.
[0m[49m[38;5;10m+     32[0m:[38;5;10m[49m NEPTUNE_ENDPOINT = "your-neptune-cluster.cluster-xxxxxxxxxxxx.us-east-1.neptune.amazonaws.com"
[0m[49m[38;5;10m+     33[0m:[38;5;10m[49m NEPTUNE_PORT = 8182
[0m[49m[38;5;10m+     34[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     35[0m:[38;5;10m[49m # The openCypher HTTP endpoint on Neptune.
[0m[49m[38;5;10m+     36[0m:[38;5;10m[49m # Neptune exposes openCypher queries via HTTPS POST to this path.
[0m[49m[38;5;10m+     37[0m:[38;5;10m[49m NEPTUNE_OPENCYPHER_URL = f"https://{NEPTUNE_ENDPOINT}:{NEPTUNE_PORT}/openCypher"
[0m[49m[38;5;10m+     38[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     39[0m:[38;5;10m[49m # Redis endpoint for caching query results.
[0m[49m[38;5;10m+     40[0m:[38;5;10m[49m # ElastiCache Redis cluster, also inside your VPC.
[0m[49m[38;5;10m+     41[0m:[38;5;10m[49m REDIS_HOST = "your-redis-cluster.xxxxxxxxxxxx.use1.cache.amazonaws.com"
[0m[49m[38;5;10m+     42[0m:[38;5;10m[49m REDIS_PORT = 6379
[0m[49m[38;5;10m+     43[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     44[0m:[38;5;10m[49m # Cache TTL in seconds. 24 hours aligns with formulary update frequency.
[0m[49m[38;5;10m+     45[0m:[38;5;10m[49m # Formularies change quarterly with occasional mid-quarter amendments.
[0m[49m[38;5;10m+     46[0m:[38;5;10m[49m # Flush the cache explicitly when you load new formulary data.
[0m[49m[38;5;10m+     47[0m:[38;5;10m[49m CACHE_TTL_SECONDS = 86400
[0m[49m[38;5;10m+     48[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     49[0m:[38;5;10m[49m # S3 bucket where formulary files land.
[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m FORMULARY_BUCKET = "my-formulary-data"
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m # Column positions in CMS-standard pipe-delimited formulary files.
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m # CMS Part D formulary files have a defined layout. Commercial plans
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m # often use similar structures but column positions may vary.
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m # Adjust these mappings for your specific file format.
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m FORMULARY_COLUMNS = {
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m     "rxnorm_cui": 0,
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m     "ndc": 1,
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m     "drug_name": 2,
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m     "dosage_form": 3,
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m     "strength": 4,
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m     "tier_level": 5,
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m     "prior_auth": 6,
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m     "step_therapy": 7,
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m     "quantity_limit": 8,
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m     "therapeutic_class_code": 9,
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m     "therapeutic_class_name": 10,
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m     "plan_id": 11,
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m     "effective_date": 12,
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m     "termination_date": 13,
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m     "alternative_drugs": 14,
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m ## Step 1: Parse Formulary File
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m *The pseudocode calls this `parse_formulary_file(bucket, key)`. It reads a pipe-delimited formulary file from S3 and transforms each row into graph vertices (drugs, therapeutic classes) and edges (tier assignments, class memberships, restrictions, alternatives).*
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m import csv
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m import io
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m s3_client = boto3.client("s3")
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m def parse_formulary_file(bucket: str, key: str) -> tuple[list, list]:
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m     Read a formulary file from S3 and transform it into graph-ready
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m     vertices and edges.
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m     CMS Part D formulary files are pipe-delimited text with a header row.
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m     Each row represents one drug-plan-tier combination. We parse each row
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m     into: a Drug vertex, a TherapeuticClass vertex, and edges connecting
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m     them (class membership, tier assignment, restrictions, alternatives).
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m         bucket: S3 bucket name where formulary files land
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m         key:    S3 object key (path to the specific formulary file)
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m         A tuple of (vertices, edges) where:
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m         - vertices: list of dicts, each with id, label, and properties
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m         - edges: list of dicts, each with from_id, to_id, type, and properties
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m     # Fetch the file from S3.
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m     response = s3_client.get_object(Bucket=bucket, Key=key)
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m     content = response["Body"].read().decode("utf-8")
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m     # Parse as pipe-delimited CSV. CMS files use | as delimiter.
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m     reader = csv.reader(io.StringIO(content), delimiter="|")
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m     # Skip the header row.
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m     next(reader)
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m     vertices = []
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m     edges = []
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m     # Track which vertices we've already created to avoid duplicates.
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m     # The graph MERGE operation handles deduplication too, but skipping
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m     # duplicates here reduces the number of Neptune calls.
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m     seen_vertices = set()
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m     for row in reader:
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m         # Extract fields by column position.
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m         rxnorm_cui = row[FORMULARY_COLUMNS["rxnorm_cui"]].strip()
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m         drug_name = row[FORMULARY_COLUMNS["drug_name"]].strip()
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m         strength = row[FORMULARY_COLUMNS["strength"]].strip()
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m         dosage_form = row[FORMULARY_COLUMNS["dosage_form"]].strip()
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m         tier_level = row[FORMULARY_COLUMNS["tier_level"]].strip()
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m         prior_auth = row[FORMULARY_COLUMNS["prior_auth"]].strip()
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m         step_therapy = row[FORMULARY_COLUMNS["step_therapy"]].strip()
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m         class_code = row[FORMULARY_COLUMNS["therapeutic_class_code"]].strip()
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m         class_name = row[FORMULARY_COLUMNS["therapeutic_class_name"]].strip()
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m         plan_id = row[FORMULARY_COLUMNS["plan_id"]].strip()
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m         effective_date = row[FORMULARY_COLUMNS["effective_date"]].strip()
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m         termination_date = row[FORMULARY_COLUMNS["termination_date"]].strip()
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m         alternatives_raw = row[FORMULARY_COLUMNS["alternative_drugs"]].strip()
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m         # Use RxNorm CUI as the primary drug identifier.
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m         # RxNorm is the standard for drug concept normalization in US healthcare.
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m         drug_id = rxnorm_cui
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m         # Create Drug vertex (if not already seen in this file).
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m         if drug_id not in seen_vertices:
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m             vertices.append({
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m                 "id": drug_id,
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m                 "label": "Drug",
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m                 "properties": {
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m                     "name": drug_name,
