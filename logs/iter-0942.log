[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m         # Edge: Step therapy restriction (if flagged).
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m         if step_therapy.upper() == "Y":
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m             edges.append({
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m                 "from_id": drug_id,
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m                 "to_id": f"ST_{plan_id}_{drug_id}",
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m                 "type": "HAS_RESTRICTION",
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m                 "properties": {
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m                     "restriction_type": "STEP_THERAPY",
