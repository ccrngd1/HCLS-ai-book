[0m[49m[39m  288, 280[0m:[39m[49m 
[0m[49m[39m  289, 281[0m:[39m[49m     Args:
[0m[49m[39m  290, 282[0m:[39m[49m         bucket: S3 bucket containing the verification image
[0m[49m[39m  291, 283[0m:[39m[49m         key: S3 key for the verification image
[0m[49m[39m  292, 284[0m:[39m[49m 
[0m[49m[39m  293, 285[0m:[39m[49m     Returns:
[0m[49m[39m  294, 286[0m:[39m[49m         Dict with match results. If matched, includes patient_id and similarity.
[0m[49m[39m  295, 287[0m:[39m[49m     """
[0m[49m[39m  296, 288[0m:[39m[49m     response = rekognition_client.search_faces_by_image(
[0m[49m[39m  297, 289[0m:[39m[49m         CollectionId=FACE_COLLECTION_ID,
[0m[49m[39m  298, 290[0m:[39m[49m         Image={"S3Object": {"Bucket": bucket, "Name": key}},
[0m[49m[39m  299, 291[0m:[39m[49m         FaceMatchThreshold=SIMILARITY_THRESHOLD,
[0m[49m[39m  300, 292[0m:[39m[49m         MaxFaces=3,  # return top 3 matches for audit purposes
