[0m[49m[39m  244, 236[0m:[39m[49m     tagged with the patient_id as external metadata. Future searches can
[0m[49m[39m  245, 237[0m:[39m[49m     find this patient by face without knowing their ID in advance.
[0m[49m[39m  246, 238[0m:[39m[49m 
[0m[49m[39m  247, 239[0m:[39m[49m     Args:
[0m[49m[39m  248, 240[0m:[39m[49m         patient_id: Unique patient identifier (MRN or similar)
[0m[49m[39m  249, 241[0m:[39m[49m         bucket: S3 bucket containing the enrollment photo
[0m[49m[39m  250, 242[0m:[39m[49m         key: S3 key for the enrollment photo
[0m[49m[39m  251, 243[0m:[39m[49m 
[0m[49m[39m  252, 244[0m:[39m[49m     Returns:
[0m[49m[39m  253, 245[0m:[39m[49m         Dict with face_id (Rekognition's internal ID) and status.
[0m[49m[39m  254, 246[0m:[39m[49m     """
[0m[49m[39m  255, 247[0m:[39m[49m     response = rekognition_client.index_faces(
[0m[49m[39m  256, 248[0m:[39m[49m         CollectionId=FACE_COLLECTION_ID,
[0m[49m[39m  257, 249[0m:[39m[49m         Image={"S3Object": {"Bucket": bucket, "Name": key}},
[0m[49m[39m  258, 250[0m:[39m[49m         # ExternalImageId links this face back to your patient record.
[0m[49m[39m  259, 251[0m:[39m[49m         # Max 255 chars. Use the patient_id so you can resolve matches later.
[0m[49m[39m  260, 252[0m:[39m[49m         ExternalImageId=patient_id,
[0m[49m[39m  261, 253[0m:[39m[49m         # Only index the largest face in the image.
[0m[49m[39m  262, 254[0m:[39m[49m         MaxFaces=1,
[0m[49m[39m  263, 255[0m:[39m[49m         QualityFilter="AUTO",
[0m[49m[39m  264, 256[0m:[39m[49m         DetectionAttributes=["DEFAULT"],
[0m[49m[39m  265, 257[0m:[39m[49m     )
[0m[49m[39m  266, 258[0m:[39m[49m 
[0m[49m[39m  267, 259[0m:[39m[49m     indexed_faces = response.get("FaceRecords", [])
[0m[49m[39m  268, 260[0m:[39m[49m     if not indexed_faces:
[0m[49m[39m  269, 261[0m:[39m[49m         return {"success": False, "reason": "no_face_indexed"}
[0m[49m[39m  270, 262[0m:[39m[49m 
[0m[49m[39m  271, 263[0m:[39m[49m     face_record = indexed_faces[0]
[0m[49m[39m  272, 264[0m:[39m[49m     return {
[0m[49m[39m  273, 265[0m:[39m[49m         "success": True,
[0m[49m[39m  274, 266[0m:[39m[49m         "face_id": face_record["Face"]["FaceId"],
[0m[49m[39m  275, 267[0m:[39m[49m         "patient_id": patient_id,
[0m[49m[39m  276, 268[0m:[39m[49m         "confidence": face_record["Face"]["Confidence"],
[0m[49m[39m  277, 269[0m:[39m[49m     }
[0m[49m[39m  278, 270[0m:[39m[49m 
[0m[49m[39m  279, 271[0m:[39m[49m 
[0m[49m[39m  280, 272[0m:[39m[49m def search_patient_by_face(bucket: str, key: str) -> dict:
[0m[49m[39m  281, 273[0m:[39m[49m     """
[0m[49m[39m  282, 274[0m:[39m[49m     Search the patient face collection for a match to the verification image.
[0m[49m[39m  283, 275[0m:[39m[49m 
[0m[49m[39m  284, 276[0m:[39m[49m     This is the scalable alternative to compare_faces. Instead of comparing
[0m[49m[39m  285, 277[0m:[39m[49m     against one known patient's photo, we search the entire enrolled population.
[0m[49m[39m  286, 278[0m:[39m[49m     Useful for scenarios where the patient hasn't identified themselves yet
