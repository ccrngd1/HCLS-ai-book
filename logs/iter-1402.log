[0m[49m[39m  309, 301[0m:[39m[49m     best = matches[0]
[0m[49m[39m  310, 302[0m:[39m[49m     return {
[0m[49m[39m  311, 303[0m:[39m[49m         "match": True,
[0m[49m[39m  312, 304[0m:[39m[49m         "patient_id": best["Face"]["ExternalImageId"],
[0m[49m[39m  313, 305[0m:[39m[49m         "similarity": best["Similarity"],
[0m[49m[39m  314, 306[0m:[39m[49m         "face_id": best["Face"]["FaceId"],
[0m[49m[39m  315, 307[0m:[39m[49m         "total_candidates": len(matches),
[0m[49m[39m  316, 308[0m:[39m[49m     }
[0m[49m[39m  317, 309[0m:[39m[49m ```
[0m[49m[39m  318, 310[0m:[39m[49m 
[0m[49m[39m  319, 311[0m:[39m[49m ---
