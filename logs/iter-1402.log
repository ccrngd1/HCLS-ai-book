[0m[49m[39m   35,  27[0m:[39m[49m 
[0m[49m[39m   36,  28[0m:[39m[49m ## Config and Constants
[0m[49m[39m   37,  29[0m:[39m[49m 
[0m[49m[39m   38,  30[0m:[39m[49m Before we get to the steps, here's the configuration that drives the verification logic. Thresholds are the heart of any face verification system. Too strict and you reject legitimate patients. Too lenient and you let the wrong person through.
[0m[49m[39m   39,  31[0m:[39m[49m 
[0m[49m[39m   40,  32[0m:[39m[49m ```python
[0m[49m[39m   41,  33[0m:[39m[49m import logging
[0m[49m[39m   42,  34[0m:[39m[49m import datetime
[0m[49m[39m   43,  35[0m:[39m[49m from datetime import timezone
[0m[49m[39m   44,  36[0m:[39m[49m from decimal import Decimal
[0m[49m[39m   45,  37[0m:[39m[49m 
[0m[49m[39m   46,  38[0m:[39m[49m import boto3
[0m[49m[39m   47,  39[0m:[39m[49m from botocore.config import Config
[0m[49m[39m   48,  40[0m:[39m[49m 
[0m[49m[39m   49,  41[0m:[39m[49m # Structured logging. Never log PHI (patient names, MRNs, photos).
[0m[49m[39m   50,  42[0m:[39m[49m # Log patient_id references only, never the biometric data itself.
[0m[49m[39m   51,  43[0m:[39m[49m logger = logging.getLogger(__name__)
[0m[49m[39m   52,  44[0m:[39m[49m logger.setLevel(logging.INFO)
[0m[49m[39m   53,  45[0m:[39m[49m 
[0m[49m[39m   54,  46[0m:[39m[49m # Retry config for AWS API calls. Face comparison is fast but can throttle
[0m[49m[39m   55,  47[0m:[39m[49m # under burst load (think: 200 patients checking in at 8am Monday).
[0m[49m[39m   56,  48[0m:[39m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[39m   57,  49[0m:[39m[49m 
[0m[49m[39m   58,  50[0m:[39m[49m # --- Verification Thresholds ---
[0m[49m[39m   59,  51[0m:[39m[49m #
[0m[49m[39m   60,  52[0m:[39m[49m # SIMILARITY_THRESHOLD: minimum confidence (0-100) that two faces are the same person.
[0m[49m[39m   61,  53[0m:[39m[49m # Rekognition returns a similarity score for each face comparison.
[0m[49m[39m   62,  54[0m:[39m[49m # 95% is conservative. You'll reject some legitimate patients who look different
[0m[49m[39m   63,  55[0m:[39m[49m # from their enrollment photo (new glasses, weight change, aging). But you'll
[0m[49m[39m   64,  56[0m:[39m[49m # catch almost all mismatches.
[0m[49m[39m   65,  57[0m:[39m[49m #
[0m[49m[39m   66,  58[0m:[39m[49m # In practice, most healthcare orgs start at 90% and tune upward based on
[0m[49m[39m   67,  59[0m:[39m[49m # false-accept rates. The cost of a false accept (wrong patient gets treatment)
[0m[49m[39m   68,  60[0m:[39m[49m # is much higher than a false reject (patient re-verifies with staff).
[0m[49m[39m   69,  61[0m:[39m[49m SIMILARITY_THRESHOLD = 95.0
[0m[49m[39m   70,  62[0m:[39m[49m 
[0m[49m[39m   71,  63[0m:[39m[49m # MINIMUM_FACE_CONFIDENCE: minimum confidence that Rekognition actually detected
[0m[49m[39m   72,  64[0m:[39m[49m # a face in the image. Below this, the image quality is too poor to trust.
[0m[49m[39m   73,  65[0m:[39m[49m MINIMUM_FACE_CONFIDENCE = 99.0
[0m[49m[39m   74,  66[0m:[39m[49m 
[0m[49m[39m   75,  67[0m:[39m[49m # IMAGE_QUALITY_THRESHOLDS: brightness and sharpness minimums.
[0m[49m[39m   76,  68[0m:[39m[49m # Rekognition returns quality metrics for each detected face.
[0m[49m[39m   77,  69[0m:[39m[49m # These catch the "photo taken in a dark hallway" and "blurry selfie" cases.
[0m[49m[39m   78,  70[0m:[39m[49m IMAGE_QUALITY_BRIGHTNESS_MIN = 40.0
[0m[49m[39m   79,  71[0m:[39m[49m IMAGE_QUALITY_SHARPNESS_MIN = 40.0
[0m[49m[39m   80,  72[0m:[39m[49m 
[0m[49m[39m   81,  73[0m:[39m[49m # Maximum age (in days) for an enrollment photo before requiring re-enrollment.
[0m[49m[39m   82,  74[0m:[39m[49m # Faces change. A 5-year-old enrollment photo is unreliable.
[0m[49m[39m   83,  75[0m:[39m[49m ENROLLMENT_PHOTO_MAX_AGE_DAYS = 730  # ~2 years
[0m[49m[39m   84,  76[0m:[39m[49m 
[0m[49m[39m   85,  77[0m:[39m[49m # S3 bucket for patient photos (enrollment and verification attempts).
[0m[49m[39m   86,  78[0m:[39m[49m PHOTO_BUCKET = "patient-photos-hipaa"
[0m[49m[39m   87,  79[0m:[39m[49m 
[0m[49m[39m   88,  80[0m:[39m[49m # DynamoDB table for verification audit records.
[0m[49m[39m   89,  81[0m:[39m[49m AUDIT_TABLE = "patient-photo-verifications"
[0m[49m[39m   90,  82[0m:[39m[49m 
[0m[49m[39m   91,  83[0m:[39m[49m # Rekognition collection for indexed patient faces.
[0m[49m[39m   92,  84[0m:[39m[49m # Collections let you search across enrolled faces without re-uploading reference images.
[0m[49m[39m   93,  85[0m:[39m[49m FACE_COLLECTION_ID = "patient-faces"
[0m[49m[39m   94,  86[0m:[39m[49m ```
[0m[49m[39m   95,  87[0m:[39m[49m 
