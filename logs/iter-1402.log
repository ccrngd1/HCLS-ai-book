[0m[49m[39m  207, 199[0m:[39m[49m         best_match = face_matches[0]
[0m[49m[39m  208, 200[0m:[39m[49m         similarity = best_match["Similarity"]
[0m[49m[39m  209, 201[0m:[39m[49m         return {
