[0m[49m[39m  181, 173[0m:[39m[49m     exactly one comparison result.
[0m[49m[39m  182, 174[0m:[39m[49m 
[0m[49m[39m  183, 175[0m:[39m[49m     Args:
[0m[49m[39m  184, 176[0m:[39m[49m         source_bucket: Bucket for the verification (check-in) image
[0m[49m[39m  185, 177[0m:[39m[49m         source_key: Key for the verification image
[0m[49m[39m  186, 178[0m:[39m[49m         target_bucket: Bucket for the enrollment (reference) image
[0m[49m[39m  187, 179[0m:[39m[49m         target_key: Key for the enrollment image
[0m[49m[39m  188, 180[0m:[39m[49m 
[0m[49m[39m  189, 181[0m:[39m[49m     Returns:
[0m[49m[39m  190, 182[0m:[39m[49m         Dict with 'match' (bool), 'similarity' (float 0-100), and metadata.
[0m[49m[39m  191, 183[0m:[39m[49m     """
[0m[49m[39m  192, 184[0m:[39m[49m     response = rekognition_client.compare_faces(
[0m[49m[39m  193, 185[0m:[39m[49m         SourceImage={"S3Object": {"Bucket": source_bucket, "Name": source_key}},
[0m[49m[39m  194, 186[0m:[39m[49m         TargetImage={"S3Object": {"Bucket": target_bucket, "Name": target_key}},
[0m[49m[39m  195, 187[0m:[39m[49m         SimilarityThreshold=SIMILARITY_THRESHOLD,
[0m[49m[39m  196, 188[0m:[39m[49m         # QualityFilter removes low-quality faces from comparison.
[0m[49m[39m  197, 189[0m:[39m[49m         # AUTO lets Rekognition decide. For healthcare identity verification,
[0m[49m[39m  198, 190[0m:[39m[49m         # you want this on. A blurry reference photo shouldn't produce a match.
[0m[49m[39m  199, 191[0m:[39m[49m         QualityFilter="AUTO",
[0m[49m[39m  200, 192[0m:[39m[49m     )
[0m[49m[39m  201, 193[0m:[39m[49m 
[0m[49m[39m  202, 194[0m:[39m[49m     face_matches = response.get("FaceMatches", [])
