[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m         is_resubmission = claim.frequency_code IN ["7", "8"]
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m         // --- Patient Context ---
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m         patient_age = claim.patient_age
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m         coverage_type = claim.coverage_type           // commercial, medicare, medicaid
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m         has_secondary_insurance = claim.secondary_payer IS NOT NULL
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m         // --- Temporal Features ---
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m         day_of_week_submitted = day_of_week(claim.submission_date)
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m         month_of_service = month(claim.date_of_service)
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m         end_of_year = month_of_service IN [11, 12]   // deductible met, different behavior
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m         // --- Bundling / Edit Risk ---
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m         // Check if this procedure has known NCCI edit conflicts
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m         // with other procedures on the same claim
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m         has_ncci_conflict = check_ncci_edits(claim.line_items)
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m         // Assemble feature vector
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m         feature_row = {
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m             claim_id:                    claim.id,
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m             primary_cpt:                 primary_cpt,
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m             primary_icd:                 primary_icd,
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m             dx_proc_pair:                dx_proc_pair,
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m             num_diagnoses:               num_diagnoses,
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m             payer_id:                    payer_id,
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m             payer_proc_denial_rate:      payer_proc_denial_rate,
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m             payer_dx_proc_denial_rate:   payer_dx_proc_denial_rate,
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m             pa_required:                 pa_required,
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m             pa_on_file:                  pa_on_file,
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m             pa_active:                   pa_active,
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m             provider_type:               provider_type,
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m             provider_specialty:          provider_specialty,
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m             provider_payer_denial_rate:  provider_payer_denial_rate,
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m             provider_proc_denial_rate:   provider_proc_denial_rate,
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m             place_of_service:            place_of_service,
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m             claim_amount:                claim_amount,
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m             claim_amount_log:            claim_amount_log,
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m             num_line_items:              num_line_items,
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m             days_since_service:          days_since_service,
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m             has_modifier_25:             has_modifier_25,
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m             has_modifier_59:             has_modifier_59,
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m             has_modifier_26:             has_modifier_26,
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m             is_resubmission:             is_resubmission,
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m             patient_age:                 patient_age,
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m             coverage_type:               coverage_type,
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m             has_secondary_insurance:     has_secondary_insurance,
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m             day_of_week_submitted:       day_of_week_submitted,
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m             end_of_year:                 end_of_year,
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m             has_ncci_conflict:           has_ncci_conflict
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m         append feature_row to features
