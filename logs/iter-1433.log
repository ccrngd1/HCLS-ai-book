[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m     // Write to S3 partitioned by date for efficient training queries
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m     write features to S3 at "s3://claim-ml/features/denial-prediction/{date}/"
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m     RETURN features
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m **Step 2: Model training with class imbalance handling.** A SageMaker training job picks up historical claims with known outcomes (paid vs. denied) and trains a gradient-boosted tree classifier. The critical challenge here is class imbalance: if 12% of claims are denied, the model could achieve 88% accuracy by predicting "paid" for everything. That's useless. We need the model to identify the 12% correctly. Handle this with `scale_pos_weight` (ratio of negatives to positives) and evaluation on precision-recall curves rather than accuracy. Retrain weekly because payer rules change frequently (new PA requirements, coverage policy updates, contract renegotiations).
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m ```pseudocode
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m FUNCTION train_denial_model(training_data_path):
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m     // Configure SageMaker training for binary classification
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m     // with heavy emphasis on identifying the minority class (denials).
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m     // Calculate class weight from the training data
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m     // If 12% denial rate: scale_pos_weight = 0.88 / 0.12 = 7.3
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m     denial_rate = count_denials / total_claims
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m     pos_weight = (1 - denial_rate) / denial_rate
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m     training_config = {
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m         algorithm:        "xgboost",
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m         objective:        "binary:logistic",
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m         eval_metric:      ["aucpr", "auc"],     // area under precision-recall curve
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m                                                  // is more informative than AUC-ROC
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m                                                  // for imbalanced data
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m         num_round:        500,
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m         max_depth:        6,
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m         eta:              0.03,                  // low learning rate for stability
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m         subsample:        0.8,
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m         colsample_bytree: 0.7,
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m         scale_pos_weight: pos_weight,            // critical for class imbalance
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m         min_child_weight: 10,                    // regularization: require at
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m                                                  // least 10 samples per leaf
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m         gamma:            0.1,                   // minimum loss reduction for split
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m         input_data:       training_data_path,
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m         output_path:      "s3://claim-ml/models/denial-prediction/",
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m         instance_type:    "ml.m5.2xlarge",
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m         validation_split: 0.2,
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m         early_stopping:   20                     // stop if no improvement for 20 rounds
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m     // Launch training job
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m     model_artifact = sagemaker.train(training_config)
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m     // Post-training: compute SHAP values on validation set
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m     // This pre-computes the baseline expected value and validates
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m     // that explanations are sensible before deployment.
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m     shap_baseline = sagemaker_clarify.compute_shap_baseline(
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m         model=model_artifact,
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m         data=validation_set,
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m         num_samples=1000
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m     // Evaluate on holdout set with business-relevant metrics
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m     evaluation = {
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m         auc_roc:            compute_auc(holdout_predictions, holdout_labels),
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m         auc_pr:             compute_aucpr(holdout_predictions, holdout_labels),
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m         precision_at_80_recall: compute_precision_at_recall(0.80),
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m         recall_at_80_precision: compute_recall_at_precision(0.80),
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m         // At what threshold do we catch 80% of denials?
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m         // What's the false alarm rate at that threshold?
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m         threshold_for_80_recall: find_threshold(recall=0.80),
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m         false_positive_rate_at_80_recall: compute_fpr_at_recall(0.80)
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m     RETURN model_artifact, evaluation, shap_baseline
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m **Step 3: Real-time scoring at claim creation.** When a coder finalizes a claim in the billing system, the system calls the SageMaker real-time endpoint to get a denial probability and explanation before submission. If the probability exceeds the threshold, the system surfaces a warning with specific reasons. The coder can then fix the issue, override the warning with a reason, or route to a supervisor. This is the highest-value prediction point because the intervention (fixing the claim) costs nearly nothing compared to reworking a denial later.
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m ```pseudocode
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m FUNCTION score_claim_realtime(claim):
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m     // Called by the billing system when a claim is ready for submission.
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m     // Returns a risk assessment with actionable explanations.
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m     // Compute features for this single claim (same logic as batch)
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m     features = compute_single_claim_features(claim)
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m     // Call SageMaker real-time endpoint
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m     response = sagemaker_endpoint.invoke(
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m         endpoint_name="denial-prediction-prod",
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m         content_type="text/csv",
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m         body=serialize_features(features)
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m     denial_probability = response.prediction
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m     // Generate explanation using SHAP
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m     // Only compute SHAP for claims above the alert threshold
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m     // (SHAP computation adds ~50ms latency)
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m     IF denial_probability > ALERT_THRESHOLD:    // e.g., 0.50
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m         shap_values = sagemaker_clarify.explain(
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m             endpoint="denial-prediction-prod",
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m             instance=features,
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m             num_features=5              // top 5 contributing factors
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m         // Map SHAP features to human-readable explanations
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m         explanations = []
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m         FOR each (feature_name, shap_value) in top_shap_values:
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m             explanation = map_feature_to_explanation(
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m                 feature_name, shap_value, features
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m             append explanation to explanations
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m         // Example explanation output:
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m         // "Payer BlueCross denies 67% of CPT 27447 claims without active PA"
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m         // "Provider Dr. Smith has a 34% denial rate with this payer (org avg: 11%)"
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m         // "No modifier 59 present for bundled procedure pair"
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m     // Store prediction in DynamoDB for audit and worklist
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m     dynamodb.put_item(
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m         table="claim-predictions",
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m         item={
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m             claim_id:           claim.id,
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m             score_date:         today(),
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m             denial_probability: denial_probability,
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m             risk_tier:          classify_risk(denial_probability),
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m             top_risk_factors:   explanations,
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m             model_version:      current_model_version,
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m             claim_amount:       claim.total_charge,
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m             expected_loss:      denial_probability * claim.total_charge,
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m             prediction_point:   "PRE_BILLING",
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m             status:             "PENDING_REVIEW" if denial_probability > ALERT_THRESHOLD
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m                                 else "AUTO_CLEARED"
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m     RETURN {
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m         denial_probability: denial_probability,
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m         risk_tier:          classify_risk(denial_probability),
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m         explanations:       explanations,
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m         recommended_action: determine_action(denial_probability, explanations)
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m FUNCTION classify_risk(probability):
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m     IF probability > 0.70: RETURN "HIGH"
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m     IF probability > 0.40: RETURN "MEDIUM"
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m     RETURN "LOW"
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m FUNCTION determine_action(probability, explanations):
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m     // Map risk factors to specific corrective actions
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m     IF any explanation mentions "prior auth required" AND NOT pa_on_file:
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m         RETURN "Obtain prior authorization before submission"
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m     IF any explanation mentions "modifier missing":
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m         RETURN "Review modifier requirements for this procedure combination"
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m     IF any explanation mentions "medical necessity":
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m         RETURN "Attach supporting clinical documentation"
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m     IF probability > 0.70:
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m         RETURN "Route to coding supervisor for review before submission"
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m     RETURN "Review flagged risk factors; submit if confident"
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m **Step 4: Batch scoring and worklist generation.** Nightly, the batch transform job scores all pending claims (submitted but not yet adjudicated) and all upcoming scheduled procedures (pre-visit prediction). The Lambda worklist engine reads the scored predictions and generates prioritized work queues: claims to review before submission, PAs to initiate, and expected denials to prepare appeals for in advance. The prioritization is by expected loss (denial probability times claim amount), which focuses staff time on the highest-value interventions.
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m ```pseudocode
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m FUNCTION generate_worklists(predictions_table):
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m     // Lambda function triggered after batch scoring completes.
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m     // Reads all high-risk predictions and routes to appropriate queues.
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m     // Query DynamoDB for all predictions above threshold, scored today
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m     high_risk_claims = dynamodb.query(
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m         table="claim-predictions",
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m         index="risk-score-index",
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m         key_condition="score_date = today() AND denial_probability > 0.40",
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m         sort_by="expected_loss DESC"
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m     // Route to appropriate queues based on risk factors
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m     coding_review_queue = []
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m     pa_initiation_queue = []
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m     documentation_queue = []
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m     appeal_prep_queue = []
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m     FOR each prediction in high_risk_claims:
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m         risk_factors = prediction.top_risk_factors
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m         IF prediction.prediction_point == "PRE_VISIT":
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m             IF "prior auth required" in risk_factors:
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m                 append to pa_initiation_queue: {
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m                     claim_id:       prediction.claim_id,
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m                     patient:        prediction.patient_id,
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m                     procedure:      prediction.primary_cpt,
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m                     payer:          prediction.payer_id,
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m                     denial_prob:    prediction.denial_probability,
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m                     reason:         "PA required but not on file",
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m                     expected_loss:  prediction.expected_loss
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m                 }
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m         ELSE IF prediction.prediction_point == "PRE_BILLING":
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m             IF "modifier" in any risk_factor OR "coding" in any risk_factor:
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m                 append to coding_review_queue
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m             ELSE IF "documentation" in any risk_factor OR "medical necessity" in any risk_factor:
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m                 append to documentation_queue
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m             ELSE:
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m                 append to coding_review_queue   // default: human review
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m         ELSE IF prediction.prediction_point == "POST_SUBMISSION":
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m             IF prediction.denial_probability > 0.70:
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m                 append to appeal_prep_queue: {
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m                     claim_id:       prediction.claim_id,
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m                     denial_prob:    prediction.denial_probability,
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m                     likely_reason:  top_risk_factor,
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m                     prep_action:    "Gather documentation for appeal"
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m                 }
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m     // Write worklists to downstream systems
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m     publish_to_queue("coding-review", coding_review_queue)
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m     publish_to_queue("pa-initiation", pa_initiation_queue)
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m     publish_to_queue("documentation-request", documentation_queue)
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m     publish_to_queue("appeal-preparation", appeal_prep_queue)
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m     // Emit metrics
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m     cloudwatch.put_metrics({
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m         "HighRiskClaimsToday":      count(high_risk_claims),
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m         "CodingReviewQueued":       count(coding_review_queue),
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m         "PAInitiationQueued":       count(pa_initiation_queue),
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m         "DocumentationQueued":      count(documentation_queue),
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m         "TotalExpectedLossAtRisk":  sum(high_risk_claims.expected_loss)
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m > **Curious how this looks in Python?** The pseudocode above covers the concepts. If you'd like to see sample Python code that demonstrates these patterns using boto3, check out the [Python Example](chapter07.11-python-example). It walks through each step with inline comments and notes on what you'd need to change for a real deployment.
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m ### Expected Results
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m 
