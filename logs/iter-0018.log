[0m[49m[38;5;10m+    1351[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1352[0m:[38;5;10m[49m     metadata = result.get("metadata") or {}
[0m[49m[38;5;10m+    1353[0m:[38;5;10m[49m     if "title" in metadata:
[0m[49m[38;5;10m+    1354[0m:[38;5;10m[49m         return metadata["title"]
[0m[49m[38;5;10m+    1355[0m:[38;5;10m[49m     uri = _source_uri_from_result(result)
[0m[49m[38;5;10m+    1356[0m:[38;5;10m[49m     if uri:
[0m[49m[38;5;10m+    1357[0m:[38;5;10m[49m         return uri.rsplit("/", 1)[-1]
[0m[49m[38;5;10m+    1358[0m:[38;5;10m[49m     return "Source"
[0m[49m[38;5;10m+    1359[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1360[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1361[0m:[38;5;10m[49m def _last_updated_from_result(result: dict) -> Optional[str]:
[0m[49m[38;5;10m+    1362[0m:[38;5;10m[49m     """Extract a last-updated timestamp from chunk metadata."""
[0m[49m[38;5;10m+    1363[0m:[38;5;10m[49m     metadata = result.get("metadata") or {}
[0m[49m[38;5;10m+    1364[0m:[38;5;10m[49m     return metadata.get("last_updated")
[0m[49m[38;5;10m+    1365[0m:[38;5;10m[49m ```
