[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m # --- Prompt-Injection Patterns ---
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m # A starter list of common attempts. Production extends this with
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m # detected patterns from production traffic and pairs it with a
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m # small classifier for paraphrase variation.
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m INJECTION_PATTERNS = [
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m     r"ignore (all |any |the )?(previous|prior|above) (instructions|messages|prompts)",
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m     r"disregard (all |any |the )?(previous|prior|above) (instructions|messages|prompts)",
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m     r"you are now (a |an )?",
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m     r"forget (all |any |everything )?(you|your)",
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m     r"system (prompt|message|instruction)",
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m     r"reveal (your|the) (prompt|instructions|system)",
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m     r"act as (a |an )?",
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m     r"pretend (to be|you are)",
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m     r"new instructions:",
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m # --- PHI Detection Patterns ---
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m # Heuristic patterns for inadvertent PHI volunteered by the user.
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m # Production uses Comprehend Medical or a more robust detector;
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m # the heuristics below catch the most common cases (account
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m # numbers, SSN-like patterns, MRN-like prefixes).
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m PHI_PATTERNS = {
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m     "ssn_like":     re.compile(r"\b\d{3}-\d{2}-\d{4}\b"),
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m     "account_long": re.compile(r"\b\d{9,16}\b"),
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m     "mrn_prefix":   re.compile(r"\bMRN\s*[:#]?\s*\d{4,}\b",
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m                                 re.IGNORECASE),
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m     "dob_like":     re.compile(
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m         r"\b(0?[1-9]|1[0-2])[/-](0?[1-9]|[12]\d|3[01])"
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m         r"[/-](19|20)\d{2}\b"),
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m ## Shared Helpers
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m A few utilities used across steps. Keeping them together so each step's code stays focused on the pattern it teaches.
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m def _to_decimal(obj):
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m     Recursively convert floats to Decimal for DynamoDB.
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m     DynamoDB rejects Python float values; every numeric field has
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m     to pass through Decimal on the way in. This is a recurring SDK
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m     gotcha. Strings, ints, bools, None, and existing Decimals pass
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m     through unchanged.
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m     if isinstance(obj, float):
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m         return Decimal(str(obj))
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m     if isinstance(obj, dict):
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m         return {k: _to_decimal(v) for k, v in obj.items()}
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m     if isinstance(obj, list):
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m         return [_to_decimal(v) for v in obj]
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m     return obj
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m def _from_decimal(obj):
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m     Recursively convert Decimals back to floats / ints for JSON
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m     serialization. The inverse of `_to_decimal`.
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m     if isinstance(obj, Decimal):
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m         if obj % 1 == 0:
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m             return int(obj)
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m         return float(obj)
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m     if isinstance(obj, dict):
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m         return {k: _from_decimal(v) for k, v in obj.items()}
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m     if isinstance(obj, list):
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m         return [_from_decimal(v) for v in obj]
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m     return obj
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m def _now_iso() -> str:
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m     """Current UTC time in ISO-8601 format. Used everywhere."""
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m     return datetime.now(timezone.utc).isoformat()
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m def _parse_json_response(raw_text: str) -> dict:
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m     Parse JSON from a model response, stripping common markdown
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m     wrappers. Claude sometimes wraps JSON in fenced code blocks
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m     even when told not to; defensive parsing keeps the pipeline
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m     robust to that.
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m     cleaned = raw_text.strip()
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m     if cleaned.startswith("```json"):
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m         cleaned = cleaned[7:]
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m     if cleaned.startswith("```"):
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m         cleaned = cleaned[3:]
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m     if cleaned.endswith("```"):
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m         cleaned = cleaned[:-3]
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m     try:
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m         return json.loads(cleaned.strip())
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m     except json.JSONDecodeError:
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m         logger.warning(
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m             "Failed to parse JSON from model; returning empty")
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m         return {}
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m def _redact_pii_for_logging(text: str) -> str:
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m     Light redaction for log lines. Strips digits-heavy patterns
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m     that look like SSNs, account numbers, or DOBs. The audit
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m     pipeline gets the original; only logs get the redaction.
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m     redacted = text
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m     for pattern in PHI_PATTERNS.values():
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m         redacted = pattern.sub("[REDACTED]", redacted)
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m     return redacted
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m def _emit_event(detail_type: str, detail: dict) -> None:
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m     Emit an EventBridge event. Wrapped in try/except so a transient
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m     EventBridge failure does not block the chat-handler response;
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m     a missed event is logged loudly for the on-call engineer to
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m     backfill from the audit archive.
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m     try:
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m         eventbridge_client.put_events(Entries=[{
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m             "Source":       "faq_chatbot",
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m             "DetailType":   detail_type,
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m             "Detail":       json.dumps(detail),
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m             "EventBusName": CHAT_EVENT_BUS_NAME,
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m         }])
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m     except Exception as exc:
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m         logger.error(
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m             "EventBridge emit failed for %s: %s",
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m             detail_type, exc)
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m def _put_metric(metric_name: str, value: float,
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m                 dimensions: dict) -> None:
