[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m # containers so each invocation does not pay the connection cost.
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m REGION = "us-east-1"
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m bedrock_runtime       = boto3.client("bedrock-runtime",
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m bedrock_agent_runtime = boto3.client("bedrock-agent-runtime",
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m dynamodb              = boto3.resource("dynamodb",
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m eventbridge_client    = boto3.client("events",
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m firehose_client       = boto3.client("firehose",
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m cloudwatch_client     = boto3.client("cloudwatch",
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m secrets_client        = boto3.client("secretsmanager",
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m # --- Resource Names ---
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m # Fill these in with your actual resource names. The demo prints
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m # what it would write rather than failing if the resources do
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m # not exist; see run_demo() at the bottom.
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m CONVERSATION_STATE_TABLE      = "faq-bot-conversation-state"
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m CONVERSATION_METADATA_TABLE   = "faq-bot-conversation-metadata"
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m CHAT_EVENT_BUS_NAME           = "faq-bot-events-bus"
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m AUDIT_ARCHIVE_FIREHOSE_NAME   = "faq-bot-audit-archive"
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m CLOUDWATCH_NAMESPACE          = "FAQChatbot"
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m # Bedrock Knowledge Base ID for the curated institutional FAQ
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m # corpus. The Knowledge Base owns chunking, embedding, and the
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m # vector store (OpenSearch Serverless or Aurora pgvector).
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m KNOWLEDGE_BASE_ID             = "KB_PLACEHOLDER_ID"
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m # Bedrock Guardrail for restricted-topic and harmful-content
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m # filtering. Configure in the Bedrock console with restricted
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m # topics for clinical-advice, financial-advice, and legal-advice
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m # at minimum. Pin to a specific version, not DRAFT, in production.
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m GUARDRAIL_ID                  = "GUARDRAIL_PLACEHOLDER_ID"
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m GUARDRAIL_VERSION             = "1"
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m # Deploy-time guardrail. Any blank resource name is a deploy-time
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m # bug, not a runtime surprise.
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m for _name, _value in [
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m     ("CONVERSATION_STATE_TABLE",     CONVERSATION_STATE_TABLE),
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m     ("CONVERSATION_METADATA_TABLE",  CONVERSATION_METADATA_TABLE),
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m     ("CHAT_EVENT_BUS_NAME",          CHAT_EVENT_BUS_NAME),
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m     ("AUDIT_ARCHIVE_FIREHOSE_NAME",  AUDIT_ARCHIVE_FIREHOSE_NAME),
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m     ("CLOUDWATCH_NAMESPACE",         CLOUDWATCH_NAMESPACE),
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m     ("KNOWLEDGE_BASE_ID",            KNOWLEDGE_BASE_ID),
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m     ("GUARDRAIL_ID",                 GUARDRAIL_ID),
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m     ("GUARDRAIL_VERSION",            GUARDRAIL_VERSION),
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m ]:
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m     assert _value, f"{_name} must be set before deploying."
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m # --- Versioning ---
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m # Every conversation turn carries the model version, the prompt
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m # version, the Knowledge Base version, the Guardrail version, and
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m # the scope-rule-set version active at the time of the turn. This
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m # is how a future audit reconstructs which calibration was active
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m # when a particular response was produced.
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m PROMPT_VERSION                = "faq-bot-prompt-v3.2"
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m SCOPE_RULES_VERSION           = "faq-bot-scope-v1.4"
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m CRISIS_LEXICON_VERSION        = "faq-bot-crisis-lexicon-v1.5"
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m INSTITUTION_ID                = "riverside-clinic"
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m INSTITUTION_DISPLAY_NAME      = "Riverside Clinic"
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m # --- Model IDs ---
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m # Two model roles. Scope classification is a cheap per-turn task
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m # where a smaller model earns its keep. Generation is where the
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m # institutional voice, the citation discipline, and the refusal
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m # pattern matter, so use a capable instruction-following model.
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m #
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m # If your region requires cross-region inference, use the inference
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m # profile ID (e.g., "us.anthropic.claude-3-5-haiku-20241022-v1:0").
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m # TODO: verify the exact model IDs available in your region and
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m # account; Bedrock model availability evolves over time.
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m SCOPE_CLASSIFIER_MODEL_ID     = "anthropic.claude-3-5-haiku-20241022-v1:0"
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m RESPONSE_GENERATION_MODEL_ID  = "anthropic.claude-3-5-sonnet-20241022-v2:0"
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m # --- Pipeline Tuning ---
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m # Below this confidence, we ask a clarifying question rather than
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m # acting on the classification. Keep this on the conservative side;
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m # better to ask than to misroute.
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m SCOPE_CONFIDENCE_THRESHOLD    = Decimal("0.65")
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m # Number of chunks to retrieve from the Knowledge Base. The Knowledge
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m # Base does its own ranking; we ask for a small number because
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m # generation works best with a focused context window.
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m RETRIEVAL_TOP_N               = 5
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m # Re-ranked candidates kept for the generation prompt.
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m RERANK_TOP_K                  = 3
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m # Below this score, we treat the retrieval as no-results and have
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m # the bot say "I don't have information on that" rather than
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m # letting the model attempt to answer from training-data memory.
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m # Tune this against a held-out evaluation set; too low and the bot
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m # fabricates from weak retrieval, too high and the bot refuses
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m # answers it could have given correctly.
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m RETRIEVAL_RELEVANCE_THRESHOLD = Decimal("0.45")
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m # Minimum claim-evidence overlap for the hallucination check. The
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m # demo uses a simple token-overlap proxy; production should use a
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m # stronger grounding validator (an LLM-based claim-vs-evidence check
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m # or Bedrock Guardrails' contextual-grounding feature).
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m MIN_CLAIM_OVERLAP             = Decimal("0.30")
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m # --- Scope Categories ---
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m # In-scope categories are the things the bot is allowed to answer.
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m # Out-of-scope categories each have a refusal-and-handoff template.
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m # This is the most important configuration in the file: the runtime
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m # enforcement of what the bot will and will not do begins here.
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m IN_SCOPE_CATEGORIES = [
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m     "hours_and_location",
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m     "parking_and_transportation",
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m     "accepted_insurance_general",
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m     "visit_preparation_general",
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m     "patient_portal_access",
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m     "provider_directory_general",
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m     "telehealth_policy",
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m     "after_hours_policy",
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m     "language_services",
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     "visitor_information",
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m OUT_OF_SCOPE_CATEGORIES = [
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m     "clinical_question",        # symptoms, conditions, dosing
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m     "billing_specific",         # this patient's specific copay
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m     "scheduling_action",        # actually book or change a visit
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m     "refill_request",           # actually submit a refill
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m     "benefits_eligibility",     # this patient's specific coverage
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m     "off_topic",                # general chitchat, jokes
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m # --- Refusal-and-Handoff Templates ---
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m # Each out-of-scope category has a polite refusal with a concrete
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m # next step. "Talk to a person" alone is not a handoff; the right
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m # handoff names the team and how to reach them.
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m OUT_OF_SCOPE_HANDOFFS = {
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m     "clinical_question": (
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m         "That sounds like a question for our nurse advice line. "
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m         "I'm not a clinician and can't give medical advice. You "
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m         "can reach our nurse line at 555-0100, or in an "
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m         "emergency please call 911."
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m     ),
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m     "billing_specific": (
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m         "Account-specific billing questions need our billing "
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m         "team. They can look up your account and answer "
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m         "specifically. Reach them at 555-0123 Monday through "
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m         "Friday 8am to 5pm, or message through the patient "
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m         "portal."
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m     ),
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m     "scheduling_action": (
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m         "I can answer general questions about scheduling but I "
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m         "can't book or change a visit for you here. You can "
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m         "schedule online through the patient portal, or call "
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m         "555-0150."
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m     ),
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m     "refill_request": (
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m         "Refill requests go through our pharmacy team. The "
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m         "fastest path is the patient portal's prescription "
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m         "section, or you can call our pharmacy line at "
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m         "555-0175."
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m     ),
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m     "benefits_eligibility": (
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m         "I can tell you which insurance plans we generally "
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m         "accept, but checking your specific coverage requires "
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m         "your account information. Our benefits team can help "
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m         "at 555-0145."
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m     ),
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m     "off_topic": (
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m         "I'm focused on helping with questions about the "
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m         "clinic, like hours, parking, insurance, and visit "
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m         "prep. Is there something along those lines I can help "
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m         "with?"
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m     ),
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m # Generic fallbacks used by other code paths.
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m INJECTION_REFUSAL_TEMPLATE = (
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m     "I can only help with questions about the clinic. Is "
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m     "there a clinic question I can answer for you?"
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m )
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m PHI_REDIRECT_TEMPLATE = (
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m     "For your privacy, please don't share specific health "
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m     "details, account numbers, or other personal information "
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m     "in this chat. I can answer general questions about the "
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m     "clinic. For anything specific to your account, our "
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m     "billing team can help at 555-0123."
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m )
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m NO_INFORMATION_TEMPLATE = (
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m     "I don't have specific information about that. Our front "
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m     "desk can help you out at 555-0100."
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m )
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m FOLLOWUP_AFFORDANCE_TEMPLATE = (
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m     "Was this helpful? You can reply 'yes' or 'no', ask "
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m     "another question, or type 'agent' to talk to a person."
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m )
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m GREETING_AND_DISCLOSURE_TEMPLATE = (
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m     f"Hi, I'm {INSTITUTION_DISPLAY_NAME}'s chat assistant. I "
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m     "can help with hours, locations, parking, insurance, and "
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m     "general info about the clinic. I'm not a clinician and "
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m     "I can't access your records, so for clinical questions "
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m     "or anything specific to your account, I'll connect you "
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m     "with the right team. Messages may be reviewed for "
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m     "quality. How can I help you today?"
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m )
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m # --- Crisis Lexicon ---
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m # Illustrative only. A production lexicon is a clinical-safety
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m # document owned by the clinical-quality team, multilingual, and
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m # reviewed quarterly. Do not ship the demo lexicon. The lexicon
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m # below is intentionally short to keep the demo readable.
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m CRISIS_LEXICON = {
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m     "medical_emergency": [
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m         "chest pain",
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m         "chest pressure",
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m         "can't breathe",
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m         "cannot breathe",
