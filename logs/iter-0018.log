[0m[49m[38;5;10m+    1458[0m:[38;5;10m[49m         f"{{\n"
[0m[49m[38;5;10m+    1459[0m:[38;5;10m[49m         f'  "response_text": "<your conversational answer>",\n'
[0m[49m[38;5;10m+    1460[0m:[38;5;10m[49m         f'  "cited_chunk_ids": ["<chunk_id_1>", ...],\n'
[0m[49m[38;5;10m+    1461[0m:[38;5;10m[49m         f'  "answered": true | false\n'
[0m[49m[38;5;10m+    1462[0m:[38;5;10m[49m         f"}}\n\n"
[0m[49m[38;5;10m+    1463[0m:[38;5;10m[49m         f"Set answered=false if the chunks do not actually "
[0m[49m[38;5;10m+    1464[0m:[38;5;10m[49m         f"address the user's question; in that case, "
[0m[49m[38;5;10m+    1465[0m:[38;5;10m[49m         f"response_text should politely say so and offer the "
[0m[49m[38;5;10m+    1466[0m:[38;5;10m[49m         f"front desk."
[0m[49m[38;5;10m+    1467[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    1468[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1469[0m:[38;5;10m[49m     # Step 5C: invoke the LLM with the Guardrail attached. The
[0m[49m[38;5;10m+    1470[0m:[38;5;10m[49m     # Guardrail enforces restricted-topic and harmful-content
[0m[49m[38;5;10m+    1471[0m:[38;5;10m[49m     # filtering as a runtime defense-in-depth on top of the
[0m[49m[38;5;10m+    1472[0m:[38;5;10m[49m     # system-prompt scope rules.
[0m[49m[38;5;10m+    1473[0m:[38;5;10m[49m     body = json.dumps({
[0m[49m[38;5;10m+    1474[0m:[38;5;10m[49m         "anthropic_version": "bedrock-2023-05-31",
[0m[49m[38;5;10m+    1475[0m:[38;5;10m[49m         "max_tokens":  500,
[0m[49m[38;5;10m+    1476[0m:[38;5;10m[49m         "temperature": 0.2,  # deterministic-leaning
[0m[49m[38;5;10m+    1477[0m:[38;5;10m[49m         "system":      system_prompt,
[0m[49m[38;5;10m+    1478[0m:[38;5;10m[49m         "messages": [{
[0m[49m[38;5;10m+    1479[0m:[38;5;10m[49m             "role":    "user",
[0m[49m[38;5;10m+    1480[0m:[38;5;10m[49m             "content": user_prompt,
[0m[49m[38;5;10m+    1481[0m:[38;5;10m[49m         }],
[0m[49m[38;5;10m+    1482[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    1483[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1484[0m:[38;5;10m[49m     try:
[0m[49m[38;5;10m+    1485[0m:[38;5;10m[49m         response = bedrock_runtime.invoke_model(
[0m[49m[38;5;10m+    1486[0m:[38;5;10m[49m             modelId=RESPONSE_GENERATION_MODEL_ID,
[0m[49m[38;5;10m+    1487[0m:[38;5;10m[49m             contentType="application/json",
[0m[49m[38;5;10m+    1488[0m:[38;5;10m[49m             accept="application/json",
[0m[49m[38;5;10m+    1489[0m:[38;5;10m[49m             body=body,
[0m[49m[38;5;10m+    1490[0m:[38;5;10m[49m             guardrailIdentifier=GUARDRAIL_ID,
[0m[49m[38;5;10m+    1491[0m:[38;5;10m[49m             guardrailVersion=GUARDRAIL_VERSION,
[0m[49m[38;5;10m+    1492[0m:[38;5;10m[49m             trace="ENABLED")
[0m[49m[38;5;10m+    1493[0m:[38;5;10m[49m         payload = json.loads(response["body"].read())
[0m[49m[38;5;10m+    1494[0m:[38;5;10m[49m         raw_text = payload["content"][0]["text"]
[0m[49m[38;5;10m+    1495[0m:[38;5;10m[49m     except Exception as exc:
[0m[49m[38;5;10m+    1496[0m:[38;5;10m[49m         logger.error(
[0m[49m[38;5;10m+    1497[0m:[38;5;10m[49m             "Response generation failed for %s: %s",
[0m[49m[38;5;10m+    1498[0m:[38;5;10m[49m             session_id, exc)
[0m[49m[38;5;10m+    1499[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    1500[0m:[38;5;10m[49m             "response_text":       NO_INFORMATION_TEMPLATE,
[0m[49m[38;5;10m+    1501[0m:[38;5;10m[49m             "cited_chunk_ids":     [],
[0m[49m[38;5;10m+    1502[0m:[38;5;10m[49m             "retrieved_chunk_ids": retrieved_chunk_ids,
[0m[49m[38;5;10m+    1503[0m:[38;5;10m[49m             "no_information":      True,
[0m[49m[38;5;10m+    1504[0m:[38;5;10m[49m             "audit_stamp":         audit_stamp,
[0m[49m[38;5;10m+    1505[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1506[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1507[0m:[38;5;10m[49m     parsed = _parse_json_response(raw_text)
[0m[49m[38;5;10m+    1508[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1509[0m:[38;5;10m[49m     # If the model decided the chunks do not address the question,
[0m[49m[38;5;10m+    1510[0m:[38;5;10m[49m     # treat it as the no-information path even though retrieval
[0m[49m[38;5;10m+    1511[0m:[38;5;10m[49m     # returned results above the threshold.
[0m[49m[38;5;10m+    1512[0m:[38;5;10m[49m     if not parsed.get("answered", True):
[0m[49m[38;5;10m+    1513[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    1514[0m:[38;5;10m[49m             "response_text":       NO_INFORMATION_TEMPLATE,
[0m[49m[38;5;10m+    1515[0m:[38;5;10m[49m             "cited_chunk_ids":     [],
[0m[49m[38;5;10m+    1516[0m:[38;5;10m[49m             "retrieved_chunk_ids": retrieved_chunk_ids,
[0m[49m[38;5;10m+    1517[0m:[38;5;10m[49m             "no_information":      True,
[0m[49m[38;5;10m+    1518[0m:[38;5;10m[49m             "audit_stamp":         audit_stamp,
[0m[49m[38;5;10m+    1519[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1520[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1521[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    1522[0m:[38;5;10m[49m         "response_text":
[0m[49m[38;5;10m+    1523[0m:[38;5;10m[49m             parsed.get("response_text",
[0m[49m[38;5;10m+    1524[0m:[38;5;10m[49m                         NO_INFORMATION_TEMPLATE),
[0m[49m[38;5;10m+    1525[0m:[38;5;10m[49m         "cited_chunk_ids":
[0m[49m[38;5;10m+    1526[0m:[38;5;10m[49m             parsed.get("cited_chunk_ids", []),
[0m[49m[38;5;10m+    1527[0m:[38;5;10m[49m         "retrieved_chunk_ids": retrieved_chunk_ids,
[0m[49m[38;5;10m+    1528[0m:[38;5;10m[49m         "no_information":  False,
[0m[49m[38;5;10m+    1529[0m:[38;5;10m[49m         "audit_stamp":     audit_stamp,
[0m[49m[38;5;10m+    1530[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1531[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1532[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1533[0m:[38;5;10m[49m def _build_system_prompt(language: str) -> str:
[0m[49m[38;5;10m+    1534[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1535[0m:[38;5;10m[49m     Build the system prompt for response generation. In production
[0m[49m[38;5;10m+    1536[0m:[38;5;10m[49m     this is version-controlled in a prompt registry (Parameter
[0m[49m[38;5;10m+    1537[0m:[38;5;10m[49m     Store, AppConfig, or a dedicated prompt-management service)
[0m[49m[38;5;10m+    1538[0m:[38;5;10m[49m     and the active version is stamped on every audit record.
[0m[49m[38;5;10m+    1539[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1540[0m:[38;5;10m[49m     return (
[0m[49m[38;5;10m+    1541[0m:[38;5;10m[49m         f"You are the chat assistant for "
[0m[49m[38;5;10m+    1542[0m:[38;5;10m[49m         f"{INSTITUTION_DISPLAY_NAME}, a healthcare clinic. "
[0m[49m[38;5;10m+    1543[0m:[38;5;10m[49m         f"Your role is to answer general administrative "
[0m[49m[38;5;10m+    1544[0m:[38;5;10m[49m         f"questions: hours, locations, parking, accepted "
[0m[49m[38;5;10m+    1545[0m:[38;5;10m[49m         f"insurance, what to bring to a visit, the patient "
[0m[49m[38;5;10m+    1546[0m:[38;5;10m[49m         f"portal, and general visit information.\n\n"
[0m[49m[38;5;10m+    1547[0m:[38;5;10m[49m         f"PERSONA:\n"
[0m[49m[38;5;10m+    1548[0m:[38;5;10m[49m         f"- Warm, conversational, professional. One or two "
[0m[49m[38;5;10m+    1549[0m:[38;5;10m[49m         f"sentences for most answers; do not lecture.\n"
[0m[49m[38;5;10m+    1550[0m:[38;5;10m[49m         f"- First person ('we accept...', not 'the clinic "
[0m[49m[38;5;10m+    1551[0m:[38;5;10m[49m         f"accepts...').\n"
[0m[49m[38;5;10m+    1552[0m:[38;5;10m[49m         f"- Acknowledge what the user asked before answering.\n\n"
[0m[49m[38;5;10m+    1553[0m:[38;5;10m[49m         f"SCOPE RULES (HARD):\n"
[0m[49m[38;5;10m+    1554[0m:[38;5;10m[49m         f"- NEVER give clinical advice. NEVER interpret "
[0m[49m[38;5;10m+    1555[0m:[38;5;10m[49m         f"symptoms. NEVER recommend whether the user should "
[0m[49m[38;5;10m+    1556[0m:[38;5;10m[49m         f"come in for a clinical reason.\n"
[0m[49m[38;5;10m+    1557[0m:[38;5;10m[49m         f"- NEVER answer questions about THIS user's specific "
[0m[49m[38;5;10m+    1558[0m:[38;5;10m[49m         f"copay, deductible, claim status, appointment time, "
[0m[49m[38;5;10m+    1559[0m:[38;5;10m[49m         f"or prescription. Refer them to the appropriate team.\n"
[0m[49m[38;5;10m+    1560[0m:[38;5;10m[49m         f"- NEVER make up phone numbers, addresses, hours, or "
[0m[49m[38;5;10m+    1561[0m:[38;5;10m[49m         f"insurance plans. Only state what is in the retrieved "
[0m[49m[38;5;10m+    1562[0m:[38;5;10m[49m         f"content.\n"
[0m[49m[38;5;10m+    1563[0m:[38;5;10m[49m         f"- If the retrieved content does not actually answer "
[0m[49m[38;5;10m+    1564[0m:[38;5;10m[49m         f"the question, set answered=false and offer the front "
[0m[49m[38;5;10m+    1565[0m:[38;5;10m[49m         f"desk.\n\n"
[0m[49m[38;5;10m+    1566[0m:[38;5;10m[49m         f"CITATION DISCIPLINE:\n"
[0m[49m[38;5;10m+    1567[0m:[38;5;10m[49m         f"- Every factual claim must be supported by one of "
[0m[49m[38;5;10m+    1568[0m:[38;5;10m[49m         f"the retrieved chunks. Reference the chunk_id you "
[0m[49m[38;5;10m+    1569[0m:[38;5;10m[49m         f"used in the cited_chunk_ids field.\n"
[0m[49m[38;5;10m+    1570[0m:[38;5;10m[49m         f"- The user-facing response text should mention the "
[0m[49m[38;5;10m+    1571[0m:[38;5;10m[49m         f"source naturally (e.g., 'Based on our visitor "
[0m[49m[38;5;10m+    1572[0m:[38;5;10m[49m         f"parking guide, ...') without including the raw "
[0m[49m[38;5;10m+    1573[0m:[38;5;10m[49m         f"chunk_id.\n\n"
[0m[49m[38;5;10m+    1574[0m:[38;5;10m[49m         f"LANGUAGE: respond in {language}.\n\n"
[0m[49m[38;5;10m+    1575[0m:[38;5;10m[49m         f"OUTPUT: valid JSON only, matching the schema in the "
[0m[49m[38;5;10m+    1576[0m:[38;5;10m[49m         f"user prompt."
[0m[49m[38;5;10m+    1577[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    1578[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    1579[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1580[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    1581[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1582[0m:[38;5;10m[49m ## Step 6: Screen the Output
[0m[49m[38;5;10m+    1583[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1584[0m:[38;5;10m[49m *The pseudocode calls this `screen_output(session_id, response, grounded_in_chunks, retrieved_chunks)`. Even with a careful system prompt and a Guardrail layer, the LLM occasionally drifts. The output-screening pass is independent of the input scope check; it catches drift in the LLM's output specifically. We run a scope filter, a hallucination check, and a citation-rendering pass.*
[0m[49m[38;5;10m+    1585[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1586[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    1587[0m:[38;5;10m[49m def screen_output(session_id: str,
[0m[49m[38;5;10m+    1588[0m:[38;5;10m[49m                    generation_result: dict,
[0m[49m[38;5;10m+    1589[0m:[38;5;10m[49m                    retrieved_chunks: list) -> dict:
[0m[49m[38;5;10m+    1590[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1591[0m:[38;5;10m[49m     Screen the generated response for scope drift and unsupported
[0m[49m[38;5;10m+    1592[0m:[38;5;10m[49m     claims, then render user-facing citations.
[0m[49m[38;5;10m+    1593[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1594[0m:[38;5;10m[49m     Returns a dict with:
[0m[49m[38;5;10m+    1595[0m:[38;5;10m[49m         - action:           "deliver" or "replace_with_refusal"
[0m[49m[38;5;10m+    1596[0m:[38;5;10m[49m         - response_text:    Cleared text (or refusal replacement).
[0m[49m[38;5;10m+    1597[0m:[38;5;10m[49m         - violation_details: If a violation was caught.
[0m[49m[38;5;10m+    1598[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1599[0m:[38;5;10m[49m     response_text = generation_result["response_text"]
[0m[49m[38;5;10m+    1600[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1601[0m:[38;5;10m[49m     # The no-information path was already a safe refusal; render
[0m[49m[38;5;10m+    1602[0m:[38;5;10m[49m     # without further screening but still attribute the source if
[0m[49m[38;5;10m+    1603[0m:[38;5;10m[49m     # any chunks were retrieved (none, in this branch).
[0m[49m[38;5;10m+    1604[0m:[38;5;10m[49m     if generation_result["no_information"]:
[0m[49m[38;5;10m+    1605[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    1606[0m:[38;5;10m[49m             "action":         "deliver",
[0m[49m[38;5;10m+    1607[0m:[38;5;10m[49m             "response_text":  response_text,
[0m[49m[38;5;10m+    1608[0m:[38;5;10m[49m             "violations":     [],
[0m[49m[38;5;10m+    1609[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1610[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1611[0m:[38;5;10m[49m     # Step 6A: scope filter on the generated response. This is
[0m[49m[38;5;10m+    1612[0m:[38;5;10m[49m     # independent of the input scope check; it catches drift in
[0m[49m[38;5;10m+    1613[0m:[38;5;10m[49m     # the LLM's output. Production uses Bedrock Guardrails
[0m[49m[38;5;10m+    1614[0m:[38;5;10m[49m     # restricted-topic filters (already attached at generation)
[0m[49m[38;5;10m+    1615[0m:[38;5;10m[49m     # plus a follow-up classifier; the demo runs a simple keyword
[0m[49m[38;5;10m+    1616[0m:[38;5;10m[49m     # scope check as a backstop.
[0m[49m[38;5;10m+    1617[0m:[38;5;10m[49m     violations = _check_response_scope(response_text)
[0m[49m[38;5;10m+    1618[0m:[38;5;10m[49m     if violations:
[0m[49m[38;5;10m+    1619[0m:[38;5;10m[49m         _put_metric("OutputScopeViolation", 1, {
[0m[49m[38;5;10m+    1620[0m:[38;5;10m[49m             "first_category": violations[0],
[0m[49m[38;5;10m+    1621[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    1622[0m:[38;5;10m[49m         # Replace the response with the appropriate refusal.
[0m[49m[38;5;10m+    1623[0m:[38;5;10m[49m         replacement = OUT_OF_SCOPE_HANDOFFS.get(
[0m[49m[38;5;10m+    1624[0m:[38;5;10m[49m             violations[0],
[0m[49m[38;5;10m+    1625[0m:[38;5;10m[49m             OUT_OF_SCOPE_HANDOFFS["off_topic"])
[0m[49m[38;5;10m+    1626[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    1627[0m:[38;5;10m[49m             "action":         "replace_with_refusal",
[0m[49m[38;5;10m+    1628[0m:[38;5;10m[49m             "response_text":  replacement,
[0m[49m[38;5;10m+    1629[0m:[38;5;10m[49m             "violations":     violations,
[0m[49m[38;5;10m+    1630[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1631[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1632[0m:[38;5;10m[49m     # Step 6B: hallucination check. Each factual claim should map
[0m[49m[38;5;10m+    1633[0m:[38;5;10m[49m     # to a retrieved chunk. The check below uses token-overlap as
[0m[49m[38;5;10m+    1634[0m:[38;5;10m[49m     # a cheap proxy; production uses Bedrock Guardrails contextual
[0m[49m[38;5;10m+    1635[0m:[38;5;10m[49m     # grounding or an LLM-based claim-vs-evidence validator.
[0m[49m[38;5;10m+    1636[0m:[38;5;10m[49m     grounding = _check_grounding(
[0m[49m[38;5;10m+    1637[0m:[38;5;10m[49m         response_text=response_text,
[0m[49m[38;5;10m+    1638[0m:[38;5;10m[49m         cited_chunk_ids=generation_result["cited_chunk_ids"],
[0m[49m[38;5;10m+    1639[0m:[38;5;10m[49m         retrieved_chunks=retrieved_chunks)
[0m[49m[38;5;10m+    1640[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1641[0m:[38;5;10m[49m     if grounding["has_unsupported_claims"]:
[0m[49m[38;5;10m+    1642[0m:[38;5;10m[49m         _put_metric("HallucinationCaught", 1, {})
[0m[49m[38;5;10m+    1643[0m:[38;5;10m[49m         # Conservative policy: replace with no-information rather
[0m[49m[38;5;10m+    1644[0m:[38;5;10m[49m         # than ship an unsupported claim. Production may instead
[0m[49m[38;5;10m+    1645[0m:[38;5;10m[49m         # regenerate with stricter grounding instructions before
