[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m def _recent_turns(session_id: str, k: int = 4) -> list:
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m     Return the most recent k turns for the given session. Used to
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m     give the LLM a small bit of conversation history for follow-up
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m     coherence ("ok thanks. Also do you take Aetna?" needs the
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m     earlier turn for context).
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m     table = dynamodb.Table(CONVERSATION_METADATA_TABLE)
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m     try:
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m         response = table.query(
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m             KeyConditionExpression=
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m                 boto3.dynamodb.conditions.Key("session_id")
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m                     .eq(session_id),
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m             ScanIndexForward=False,
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m             Limit=k)
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m     except Exception as exc:
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m         logger.warning(
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m             "Recent-turns query failed for %s: %s",
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m             session_id, exc)
[0m[49m[38;5;10m+    717[0m:[38;5;10m[49m         return []
[0m[49m[38;5;10m+    718[0m:[38;5;10m[49m     items = [_from_decimal(i) for i in response.get("Items", [])]
[0m[49m[38;5;10m+    719[0m:[38;5;10m[49m     return list(reversed(items))
[0m[49m[38;5;10m+    720[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m ## Step 2: Screen the Input
[0m[49m[38;5;10m+    725[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    726[0m:[38;5;10m[49m *The pseudocode calls this `screen_input(session_id, user_message, language)`. Every user message runs through three parallel screens before it reaches scope classification: a crisis-detection pass that preempts everything else, a prompt-injection pass that catches common adversarial patterns, and a PHI-minimization pass that detects when the user volunteers something sensitive the bot does not need.*
[0m[49m[38;5;10m+    727[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    728[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    729[0m:[38;5;10m[49m def screen_input(session_id: str,
[0m[49m[38;5;10m+    730[0m:[38;5;10m[49m                  user_message: str,
[0m[49m[38;5;10m+    731[0m:[38;5;10m[49m                  language: str) -> dict:
[0m[49m[38;5;10m+    732[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    733[0m:[38;5;10m[49m     Run the input-screening pass.
[0m[49m[38;5;10m+    734[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    735[0m:[38;5;10m[49m     Crisis detection is the highest-priority screen and preempts
[0m[49m[38;5;10m+    736[0m:[38;5;10m[49m     everything else. If a patient describes chest pain while asking
[0m[49m[38;5;10m+    737[0m:[38;5;10m[49m     about parking, the chest-pain signal cannot be lost in the
[0m[49m[38;5;10m+    738[0m:[38;5;10m[49m     routing flow.
[0m[49m[38;5;10m+    739[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    740[0m:[38;5;10m[49m     Returns a dict with one of these actions:
[0m[49m[38;5;10m+    741[0m:[38;5;10m[49m         - "proceed":              Continue to scope classification.
[0m[49m[38;5;10m+    742[0m:[38;5;10m[49m         - "crisis_response":      Emit crisis response, offer warm
[0m[49m[38;5;10m+    743[0m:[38;5;10m[49m                                   handoff, do not retrieve.
[0m[49m[38;5;10m+    744[0m:[38;5;10m[49m         - "injection_refusal":    Refuse with a polite redirect.
[0m[49m[38;5;10m+    745[0m:[38;5;10m[49m         - "phi_redirect":         Refuse with a privacy reminder
[0m[49m[38;5;10m+    746[0m:[38;5;10m[49m                                   and redact the message in audit.
[0m[49m[38;5;10m+    747[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    748[0m:[38;5;10m[49m     # Step 2A: crisis detection. Layered: keyword match first
[0m[49m[38;5;10m+    749[0m:[38;5;10m[49m     # (cheap, deterministic), then a small classifier in production
[0m[49m[38;5;10m+    750[0m:[38;5;10m[49m     # to catch paraphrase variation. The demo runs only the keyword
[0m[49m[38;5;10m+    751[0m:[38;5;10m[49m     # match for clarity; production augments with the classifier.
[0m[49m[38;5;10m+    752[0m:[38;5;10m[49m     crisis = _detect_crisis(user_message, language)
[0m[49m[38;5;10m+    753[0m:[38;5;10m[49m     if crisis["severity"] != "none":
[0m[49m[38;5;10m+    754[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    755[0m:[38;5;10m[49m             "action":   "crisis_response",
[0m[49m[38;5;10m+    756[0m:[38;5;10m[49m             "severity": crisis["severity"],
[0m[49m[38;5;10m+    757[0m:[38;5;10m[49m             "category": crisis["category"],
[0m[49m[38;5;10m+    758[0m:[38;5;10m[49m             "matched_phrase": crisis["matched_phrase"],
[0m[49m[38;5;10m+    759[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    760[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    761[0m:[38;5;10m[49m     # Step 2B: prompt-injection detection. Look for the canonical
[0m[49m[38;5;10m+    762[0m:[38;5;10m[49m     # patterns ("ignore previous instructions," "you are now," etc.)
[0m[49m[38;5;10m+    763[0m:[38;5;10m[49m     # and for attempts to elicit the system prompt.
[0m[49m[38;5;10m+    764[0m:[38;5;10m[49m     injection = _detect_injection(user_message)
[0m[49m[38;5;10m+    765[0m:[38;5;10m[49m     if injection["detected"]:
[0m[49m[38;5;10m+    766[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    767[0m:[38;5;10m[49m             "action":  "injection_refusal",
[0m[49m[38;5;10m+    768[0m:[38;5;10m[49m             "pattern": injection["pattern"],
[0m[49m[38;5;10m+    769[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    770[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    771[0m:[38;5;10m[49m     # Step 2C: PHI minimization. The FAQ bot does not need PHI to
[0m[49m[38;5;10m+    772[0m:[38;5;10m[49m     # do its job. If the user volunteers something sensitive, flag
[0m[49m[38;5;10m+    773[0m:[38;5;10m[49m     # it for log redaction and gently redirect.
[0m[49m[38;5;10m+    774[0m:[38;5;10m[49m     phi = _detect_phi(user_message)
[0m[49m[38;5;10m+    775[0m:[38;5;10m[49m     if phi["detected"]:
[0m[49m[38;5;10m+    776[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    777[0m:[38;5;10m[49m             "action":  "phi_redirect",
[0m[49m[38;5;10m+    778[0m:[38;5;10m[49m             "phi_categories": phi["categories"],
[0m[49m[38;5;10m+    779[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    780[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    781[0m:[38;5;10m[49m     return {"action": "proceed"}
[0m[49m[38;5;10m+    782[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    783[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    784[0m:[38;5;10m[49m def _detect_crisis(text: str, language: str) -> dict:
[0m[49m[38;5;10m+    785[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    786[0m:[38;5;10m[49m     Keyword-based crisis detection. Production layers a small LLM
[0m[49m[38;5;10m+    787[0m:[38;5;10m[49m     classifier on top to catch paraphrases not in the lexicon, and
[0m[49m[38;5;10m+    788[0m:[38;5;10m[49m     operates per-language with native-speaker-reviewed lexicons.
[0m[49m[38;5;10m+    789[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    790[0m:[38;5;10m[49m     lowered = text.lower()
[0m[49m[38;5;10m+    791[0m:[38;5;10m[49m     for category, phrases in CRISIS_LEXICON.items():
[0m[49m[38;5;10m+    792[0m:[38;5;10m[49m         for phrase in phrases:
[0m[49m[38;5;10m+    793[0m:[38;5;10m[49m             if phrase in lowered:
[0m[49m[38;5;10m+    794[0m:[38;5;10m[49m                 return {
[0m[49m[38;5;10m+    795[0m:[38;5;10m[49m                     "severity":       "high",
[0m[49m[38;5;10m+    796[0m:[38;5;10m[49m                     "category":       category,
[0m[49m[38;5;10m+    797[0m:[38;5;10m[49m                     "matched_phrase": phrase,
[0m[49m[38;5;10m+    798[0m:[38;5;10m[49m                 }
[0m[49m[38;5;10m+    799[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    800[0m:[38;5;10m[49m         "severity":       "none",
[0m[49m[38;5;10m+    801[0m:[38;5;10m[49m         "category":       None,
[0m[49m[38;5;10m+    802[0m:[38;5;10m[49m         "matched_phrase": None,
[0m[49m[38;5;10m+    803[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    804[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    805[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    806[0m:[38;5;10m[49m def _detect_injection(text: str) -> dict:
[0m[49m[38;5;10m+    807[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    808[0m:[38;5;10m[49m     Pattern-based prompt-injection detection. Production pairs this
[0m[49m[38;5;10m+    809[0m:[38;5;10m[49m     with a small classifier and continuously updates the pattern
[0m[49m[38;5;10m+    810[0m:[38;5;10m[49m     list from production traffic.
[0m[49m[38;5;10m+    811[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    812[0m:[38;5;10m[49m     lowered = text.lower()
[0m[49m[38;5;10m+    813[0m:[38;5;10m[49m     for pattern in INJECTION_PATTERNS:
[0m[49m[38;5;10m+    814[0m:[38;5;10m[49m         if re.search(pattern, lowered):
[0m[49m[38;5;10m+    815[0m:[38;5;10m[49m             return {"detected": True, "pattern": pattern}
[0m[49m[38;5;10m+    816[0m:[38;5;10m[49m     return {"detected": False, "pattern": None}
[0m[49m[38;5;10m+    817[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    818[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    819[0m:[38;5;10m[49m def _detect_phi(text: str) -> dict:
[0m[49m[38;5;10m+    820[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    821[0m:[38;5;10m[49m     Heuristic PHI detection in user input. Production uses Comprehend
[0m[49m[38;5;10m+    822[0m:[38;5;10m[49m     Medical's PHI detection or a tuned classifier; the demo's regex
[0m[49m[38;5;10m+    823[0m:[38;5;10m[49m     set covers the most common volunteered cases (SSN-like patterns,
[0m[49m[38;5;10m+    824[0m:[38;5;10m[49m     long account numbers, MRN-prefix patterns, DOB-like patterns).
[0m[49m[38;5;10m+    825[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    826[0m:[38;5;10m[49m     matched = []
[0m[49m[38;5;10m+    827[0m:[38;5;10m[49m     for category, pattern in PHI_PATTERNS.items():
[0m[49m[38;5;10m+    828[0m:[38;5;10m[49m         if pattern.search(text):
[0m[49m[38;5;10m+    829[0m:[38;5;10m[49m             matched.append(category)
[0m[49m[38;5;10m+    830[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    831[0m:[38;5;10m[49m         "detected":   len(matched) > 0,
[0m[49m[38;5;10m+    832[0m:[38;5;10m[49m         "categories": matched,
[0m[49m[38;5;10m+    833[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    834[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    835[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    836[0m:[38;5;10m[49m def _handle_screening_action(session_id: str,
[0m[49m[38;5;10m+    837[0m:[38;5;10m[49m                               channel: str,
[0m[49m[38;5;10m+    838[0m:[38;5;10m[49m                               screening_result: dict,
[0m[49m[38;5;10m+    839[0m:[38;5;10m[49m                               attach_greeting: bool,
[0m[49m[38;5;10m+    840[0m:[38;5;10m[49m                               language: str) -> dict:
[0m[49m[38;5;10m+    841[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    842[0m:[38;5;10m[49m     Build and return the response for a screening action that did
[0m[49m[38;5;10m+    843[0m:[38;5;10m[49m     not pass. Each branch emits the right event and the right
[0m[49m[38;5;10m+    844[0m:[38;5;10m[49m     metric for downstream monitoring.
[0m[49m[38;5;10m+    845[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    846[0m:[38;5;10m[49m     action = screening_result["action"]
[0m[49m[38;5;10m+    847[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    848[0m:[38;5;10m[49m     if action == "crisis_response":
[0m[49m[38;5;10m+    849[0m:[38;5;10m[49m         severity = screening_result["severity"]
[0m[49m[38;5;10m+    850[0m:[38;5;10m[49m         category = screening_result["category"]
[0m[49m[38;5;10m+    851[0m:[38;5;10m[49m         response_text = CRISIS_RESPONSES[category]
[0m[49m[38;5;10m+    852[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    853[0m:[38;5;10m[49m         # Mark the conversation as crisis-flagged so the audit
[0m[49m[38;5;10m+    854[0m:[38;5;10m[49m         # archive captures it and the disposition is correct.
[0m[49m[38;5;10m+    855[0m:[38;5;10m[49m         _update_session_flag(session_id, "crisis_detected", True)
[0m[49m[38;5;10m+    856[0m:[38;5;10m[49m         _update_session_flag(session_id, "crisis_severity", severity)
[0m[49m[38;5;10m+    857[0m:[38;5;10m[49m         _update_session_flag(session_id, "crisis_category", category)
[0m[49m[38;5;10m+    858[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    859[0m:[38;5;10m[49m         _emit_event("crisis_detected", {
[0m[49m[38;5;10m+    860[0m:[38;5;10m[49m             "session_id":  session_id,
[0m[49m[38;5;10m+    861[0m:[38;5;10m[49m             "severity":    severity,
[0m[49m[38;5;10m+    862[0m:[38;5;10m[49m             "category":    category,
[0m[49m[38;5;10m+    863[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    864[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    865[0m:[38;5;10m[49m         _put_metric("CrisisDetected", 1, {
[0m[49m[38;5;10m+    866[0m:[38;5;10m[49m             "channel":  channel,
[0m[49m[38;5;10m+    867[0m:[38;5;10m[49m             "category": category,
[0m[49m[38;5;10m+    868[0m:[38;5;10m[49m             "language": language,
[0m[49m[38;5;10m+    869[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    870[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    871[0m:[38;5;10m[49m         # Append the assistant turn with the crisis response and
[0m[49m[38;5;10m+    872[0m:[38;5;10m[49m         # the screening flags.
[0m[49m[38;5;10m+    873[0m:[38;5;10m[49m         _append_turn(session_id, {
[0m[49m[38;5;10m+    874[0m:[38;5;10m[49m             "speaker":   "assistant",
[0m[49m[38;5;10m+    875[0m:[38;5;10m[49m             "text":      response_text,
[0m[49m[38;5;10m+    876[0m:[38;5;10m[49m             "timestamp": _now_iso(),
[0m[49m[38;5;10m+    877[0m:[38;5;10m[49m             "language":  language,
[0m[49m[38;5;10m+    878[0m:[38;5;10m[49m             "screening_action": "crisis_response",
[0m[49m[38;5;10m+    879[0m:[38;5;10m[49m             "screening_category": category,
[0m[49m[38;5;10m+    880[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    881[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    882[0m:[38;5;10m[49m         return _build_chat_reply(
[0m[49m[38;5;10m+    883[0m:[38;5;10m[49m             session_id=session_id,
[0m[49m[38;5;10m+    884[0m:[38;5;10m[49m             response_text=response_text,
[0m[49m[38;5;10m+    885[0m:[38;5;10m[49m             attach_greeting=attach_greeting,
[0m[49m[38;5;10m+    886[0m:[38;5;10m[49m             disposition="crisis_routed")
[0m[49m[38;5;10m+    887[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    888[0m:[38;5;10m[49m     if action == "injection_refusal":
[0m[49m[38;5;10m+    889[0m:[38;5;10m[49m         _put_metric("InjectionAttemptDetected", 1, {
[0m[49m[38;5;10m+    890[0m:[38;5;10m[49m             "channel":  channel,
[0m[49m[38;5;10m+    891[0m:[38;5;10m[49m             "language": language,
[0m[49m[38;5;10m+    892[0m:[38;5;10m[49m         })
