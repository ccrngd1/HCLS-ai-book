[0m[49m[38;5;10m+    1086[0m:[38;5;10m[49m         category=classification["category"],
[0m[49m[38;5;10m+    1087[0m:[38;5;10m[49m         attach_greeting=attach_greeting,
[0m[49m[38;5;10m+    1088[0m:[38;5;10m[49m         language=language)
[0m[49m[38;5;10m+    1089[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1090[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1091[0m:[38;5;10m[49m def classify_scope(session_id: str,
[0m[49m[38;5;10m+    1092[0m:[38;5;10m[49m                     user_message: str,
[0m[49m[38;5;10m+    1093[0m:[38;5;10m[49m                     language: str) -> dict:
[0m[49m[38;5;10m+    1094[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1095[0m:[38;5;10m[49m     Classify the user's message into one of the in-scope or
[0m[49m[38;5;10m+    1096[0m:[38;5;10m[49m     out-of-scope categories. Uses a small LLM with structured
[0m[49m[38;5;10m+    1097[0m:[38;5;10m[49m     JSON output.
[0m[49m[38;5;10m+    1098[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1099[0m:[38;5;10m[49m     Returns a dict with one of these actions:
[0m[49m[38;5;10m+    1100[0m:[38;5;10m[49m         - "retrieve_and_answer": In-scope; route to retrieval.
[0m[49m[38;5;10m+    1101[0m:[38;5;10m[49m         - "handoff":             Out-of-scope; use refusal template.
[0m[49m[38;5;10m+    1102[0m:[38;5;10m[49m         - "clarify":             Below-threshold confidence; ask
[0m[49m[38;5;10m+    1103[0m:[38;5;10m[49m                                  a clarifying question.
[0m[49m[38;5;10m+    1104[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1105[0m:[38;5;10m[49m     in_scope_csv = ", ".join(IN_SCOPE_CATEGORIES)
[0m[49m[38;5;10m+    1106[0m:[38;5;10m[49m     out_of_scope_csv = ", ".join(OUT_OF_SCOPE_CATEGORIES)
[0m[49m[38;5;10m+    1107[0m:[38;5;10m[49m     recent = _recent_turns(session_id, k=4)
[0m[49m[38;5;10m+    1108[0m:[38;5;10m[49m     history_text = "\n".join(
[0m[49m[38;5;10m+    1109[0m:[38;5;10m[49m         f"{t['speaker']}: {t['text']}" for t in recent
[0m[49m[38;5;10m+    1110[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    1111[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1112[0m:[38;5;10m[49m     classification_system = (
[0m[49m[38;5;10m+    1113[0m:[38;5;10m[49m         "You classify patient questions for a healthcare FAQ "
[0m[49m[38;5;10m+    1114[0m:[38;5;10m[49m         "chatbot.\n\n"
[0m[49m[38;5;10m+    1115[0m:[38;5;10m[49m         "Return ONLY valid JSON in this exact shape:\n"
[0m[49m[38;5;10m+    1116[0m:[38;5;10m[49m         "{\n"
[0m[49m[38;5;10m+    1117[0m:[38;5;10m[49m         '  "category": "<one of the categories below>",\n'
[0m[49m[38;5;10m+    1118[0m:[38;5;10m[49m         '  "confidence": <number between 0 and 1>,\n'
[0m[49m[38;5;10m+    1119[0m:[38;5;10m[49m         '  "reasoning": "<one short sentence>"\n'
[0m[49m[38;5;10m+    1120[0m:[38;5;10m[49m         "}\n\n"
[0m[49m[38;5;10m+    1121[0m:[38;5;10m[49m         f"IN-SCOPE CATEGORIES: {in_scope_csv}\n"
[0m[49m[38;5;10m+    1122[0m:[38;5;10m[49m         f"OUT-OF-SCOPE CATEGORIES: {out_of_scope_csv}\n\n"
[0m[49m[38;5;10m+    1123[0m:[38;5;10m[49m         "RULES:\n"
[0m[49m[38;5;10m+    1124[0m:[38;5;10m[49m         "- A clinical question (symptoms, conditions, dosing, "
[0m[49m[38;5;10m+    1125[0m:[38;5;10m[49m         "should-I-come-in) is ALWAYS clinical_question, never "
[0m[49m[38;5;10m+    1126[0m:[38;5;10m[49m         "in-scope.\n"
[0m[49m[38;5;10m+    1127[0m:[38;5;10m[49m         "- A question about THIS PATIENT's specific copay, "
[0m[49m[38;5;10m+    1128[0m:[38;5;10m[49m         "claim, or coverage is billing_specific or "
[0m[49m[38;5;10m+    1129[0m:[38;5;10m[49m         "benefits_eligibility.\n"
[0m[49m[38;5;10m+    1130[0m:[38;5;10m[49m         "- General accepted-insurance questions ('do you take "
[0m[49m[38;5;10m+    1131[0m:[38;5;10m[49m         "Aetna') are accepted_insurance_general (in-scope).\n"
[0m[49m[38;5;10m+    1132[0m:[38;5;10m[49m         "- A request to actually book or change an appointment "
[0m[49m[38;5;10m+    1133[0m:[38;5;10m[49m         "is scheduling_action; a question about how scheduling "
[0m[49m[38;5;10m+    1134[0m:[38;5;10m[49m         "works is hours_and_location or visit_preparation_general.\n"
[0m[49m[38;5;10m+    1135[0m:[38;5;10m[49m         "- A request to refill a prescription is refill_request.\n"
[0m[49m[38;5;10m+    1136[0m:[38;5;10m[49m         "- Confidence 0.9+ for clear cases; 0.6-0.8 for "
[0m[49m[38;5;10m+    1137[0m:[38;5;10m[49m         "ambiguous cases; below 0.6 if you genuinely cannot tell."
[0m[49m[38;5;10m+    1138[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    1139[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1140[0m:[38;5;10m[49m     classification_user = (
[0m[49m[38;5;10m+    1141[0m:[38;5;10m[49m         f"RECENT CONVERSATION:\n{history_text}\n\n"
[0m[49m[38;5;10m+    1142[0m:[38;5;10m[49m         f"NEW USER MESSAGE: {user_message}"
[0m[49m[38;5;10m+    1143[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    1144[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1145[0m:[38;5;10m[49m     body = json.dumps({
[0m[49m[38;5;10m+    1146[0m:[38;5;10m[49m         "anthropic_version": "bedrock-2023-05-31",
[0m[49m[38;5;10m+    1147[0m:[38;5;10m[49m         "max_tokens":  300,
[0m[49m[38;5;10m+    1148[0m:[38;5;10m[49m         "temperature": 0.0,
[0m[49m[38;5;10m+    1149[0m:[38;5;10m[49m         "system":      classification_system,
[0m[49m[38;5;10m+    1150[0m:[38;5;10m[49m         "messages": [{
[0m[49m[38;5;10m+    1151[0m:[38;5;10m[49m             "role":    "user",
[0m[49m[38;5;10m+    1152[0m:[38;5;10m[49m             "content": classification_user,
[0m[49m[38;5;10m+    1153[0m:[38;5;10m[49m         }],
[0m[49m[38;5;10m+    1154[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    1155[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1156[0m:[38;5;10m[49m     try:
[0m[49m[38;5;10m+    1157[0m:[38;5;10m[49m         response = bedrock_runtime.invoke_model(
[0m[49m[38;5;10m+    1158[0m:[38;5;10m[49m             modelId=SCOPE_CLASSIFIER_MODEL_ID,
[0m[49m[38;5;10m+    1159[0m:[38;5;10m[49m             contentType="application/json",
[0m[49m[38;5;10m+    1160[0m:[38;5;10m[49m             accept="application/json",
[0m[49m[38;5;10m+    1161[0m:[38;5;10m[49m             body=body)
[0m[49m[38;5;10m+    1162[0m:[38;5;10m[49m         payload = json.loads(response["body"].read())
[0m[49m[38;5;10m+    1163[0m:[38;5;10m[49m         parsed = _parse_json_response(
[0m[49m[38;5;10m+    1164[0m:[38;5;10m[49m             payload["content"][0]["text"])
[0m[49m[38;5;10m+    1165[0m:[38;5;10m[49m     except Exception as exc:
[0m[49m[38;5;10m+    1166[0m:[38;5;10m[49m         # Classifier failure: fall back to "clarify" rather than
[0m[49m[38;5;10m+    1167[0m:[38;5;10m[49m         # guessing. A clarifying question is the safe move when
[0m[49m[38;5;10m+    1168[0m:[38;5;10m[49m         # the classifier is unavailable.
[0m[49m[38;5;10m+    1169[0m:[38;5;10m[49m         logger.warning(
[0m[49m[38;5;10m+    1170[0m:[38;5;10m[49m             "Scope classifier failed: %s", exc)
[0m[49m[38;5;10m+    1171[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    1172[0m:[38;5;10m[49m             "action":     "clarify",
[0m[49m[38;5;10m+    1173[0m:[38;5;10m[49m             "confidence": Decimal("0.0"),
[0m[49m[38;5;10m+    1174[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1175[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1176[0m:[38;5;10m[49m     category = parsed.get("category", "")
[0m[49m[38;5;10m+    1177[0m:[38;5;10m[49m     confidence = Decimal(str(parsed.get("confidence", 0)))
[0m[49m[38;5;10m+    1178[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1179[0m:[38;5;10m[49m     # Below-threshold confidence: clarify, do not act.
[0m[49m[38;5;10m+    1180[0m:[38;5;10m[49m     if confidence < SCOPE_CONFIDENCE_THRESHOLD:
[0m[49m[38;5;10m+    1181[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    1182[0m:[38;5;10m[49m             "action":     "clarify",
[0m[49m[38;5;10m+    1183[0m:[38;5;10m[49m             "category":   category,
[0m[49m[38;5;10m+    1184[0m:[38;5;10m[49m             "confidence": confidence,
[0m[49m[38;5;10m+    1185[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1186[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1187[0m:[38;5;10m[49m     # Out-of-scope: route to handoff with the appropriate target.
[0m[49m[38;5;10m+    1188[0m:[38;5;10m[49m     if category in OUT_OF_SCOPE_CATEGORIES:
[0m[49m[38;5;10m+    1189[0m:[38;5;10m[49m         target_map = {
[0m[49m[38;5;10m+    1190[0m:[38;5;10m[49m             "clinical_question":   "nurse_triage",
[0m[49m[38;5;10m+    1191[0m:[38;5;10m[49m             "billing_specific":    "billing",
[0m[49m[38;5;10m+    1192[0m:[38;5;10m[49m             "scheduling_action":   "scheduling",
[0m[49m[38;5;10m+    1193[0m:[38;5;10m[49m             "refill_request":      "pharmacy",
[0m[49m[38;5;10m+    1194[0m:[38;5;10m[49m             "benefits_eligibility": "benefits",
[0m[49m[38;5;10m+    1195[0m:[38;5;10m[49m             "off_topic":           "none",
[0m[49m[38;5;10m+    1196[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1197[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    1198[0m:[38;5;10m[49m             "action":     "handoff",
[0m[49m[38;5;10m+    1199[0m:[38;5;10m[49m             "category":   category,
[0m[49m[38;5;10m+    1200[0m:[38;5;10m[49m             "target":     target_map.get(category, "front_desk"),
[0m[49m[38;5;10m+    1201[0m:[38;5;10m[49m             "confidence": confidence,
[0m[49m[38;5;10m+    1202[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1203[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1204[0m:[38;5;10m[49m     # In-scope: continue to retrieval. Pass the category to the
[0m[49m[38;5;10m+    1205[0m:[38;5;10m[49m     # retrieval step so it can apply the appropriate metadata
[0m[49m[38;5;10m+    1206[0m:[38;5;10m[49m     # filter on the Knowledge Base.
[0m[49m[38;5;10m+    1207[0m:[38;5;10m[49m     if category in IN_SCOPE_CATEGORIES:
[0m[49m[38;5;10m+    1208[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    1209[0m:[38;5;10m[49m             "action":     "retrieve_and_answer",
[0m[49m[38;5;10m+    1210[0m:[38;5;10m[49m             "category":   category,
[0m[49m[38;5;10m+    1211[0m:[38;5;10m[49m             "confidence": confidence,
[0m[49m[38;5;10m+    1212[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1213[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1214[0m:[38;5;10m[49m     # Unknown category from the model: clarify rather than act.
[0m[49m[38;5;10m+    1215[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    1216[0m:[38;5;10m[49m         "action":     "clarify",
[0m[49m[38;5;10m+    1217[0m:[38;5;10m[49m         "category":   category,
[0m[49m[38;5;10m+    1218[0m:[38;5;10m[49m         "confidence": confidence,
[0m[49m[38;5;10m+    1219[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1220[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    1221[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1222[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    1223[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1224[0m:[38;5;10m[49m ## Step 4: Retrieve Relevant Chunks From the Knowledge Base
[0m[49m[38;5;10m+    1225[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1226[0m:[38;5;10m[49m *The pseudocode calls this `retrieve_chunks(session_id, user_message, category, language)`. The institution's curated FAQ corpus lives in a Bedrock Knowledge Base, ingested from a versioned S3 prefix. We call `Retrieve` with the user's question, ask for a small number of chunks, apply a relevance threshold so we do not generate from weak retrieval, and return the chunks with their source metadata for the generation prompt.*
[0m[49m[38;5;10m+    1227[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1228[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    1229[0m:[38;5;10m[49m def retrieve_chunks(session_id: str,
[0m[49m[38;5;10m+    1230[0m:[38;5;10m[49m                      user_message: str,
[0m[49m[38;5;10m+    1231[0m:[38;5;10m[49m                      category: str,
[0m[49m[38;5;10m+    1232[0m:[38;5;10m[49m                      language: str) -> dict:
[0m[49m[38;5;10m+    1233[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1234[0m:[38;5;10m[49m     Retrieve the most relevant chunks from the Bedrock Knowledge
[0m[49m[38;5;10m+    1235[0m:[38;5;10m[49m     Base for the user's question.
[0m[49m[38;5;10m+    1236[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1237[0m:[38;5;10m[49m     Bedrock Knowledge Bases handle the embedding, the vector store,
[0m[49m[38;5;10m+    1238[0m:[38;5;10m[49m     the hybrid retrieval (semantic + keyword), and the chunk
[0m[49m[38;5;10m+    1239[0m:[38;5;10m[49m     metadata. We just call Retrieve and apply a relevance threshold.
[0m[49m[38;5;10m+    1240[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1241[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    1242[0m:[38;5;10m[49m         session_id:   Conversation session identifier.
[0m[49m[38;5;10m+    1243[0m:[38;5;10m[49m         user_message: The user's question.
[0m[49m[38;5;10m+    1244[0m:[38;5;10m[49m         category:     The in-scope category from Step 3, used as a
[0m[49m[38;5;10m+    1245[0m:[38;5;10m[49m                       metadata filter when the corpus is tagged.
[0m[49m[38;5;10m+    1246[0m:[38;5;10m[49m         language:     Detected or declared language.
[0m[49m[38;5;10m+    1247[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1248[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    1249[0m:[38;5;10m[49m         Dict with:
[0m[49m[38;5;10m+    1250[0m:[38;5;10m[49m             - chunks:               List of chunk dicts (text + metadata).
[0m[49m[38;5;10m+    1251[0m:[38;5;10m[49m             - no_relevant_results:  True if all chunks scored below
[0m[49m[38;5;10m+    1252[0m:[38;5;10m[49m                                     the relevance threshold.
[0m[49m[38;5;10m+    1253[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1254[0m:[38;5;10m[49m     # Step 4A: build the metadata filter. The Knowledge Base
[0m[49m[38;5;10m+    1255[0m:[38;5;10m[49m     # supports filtering by source-document metadata; we filter
[0m[49m[38;5;10m+    1256[0m:[38;5;10m[49m     # by category and (where applicable) by language so the
[0m[49m[38;5;10m+    1257[0m:[38;5;10m[49m     # retrieval respects the audience.
[0m[49m[38;5;10m+    1258[0m:[38;5;10m[49m     #
[0m[49m[38;5;10m+    1259[0m:[38;5;10m[49m     # Note: the exact filter shape depends on the Knowledge Base
[0m[49m[38;5;10m+    1260[0m:[38;5;10m[49m     # configuration. The shape below assumes the chunks are
[0m[49m[38;5;10m+    1261[0m:[38;5;10m[49m     # tagged with a "category" metadata key during ingestion.
[0m[49m[38;5;10m+    1262[0m:[38;5;10m[49m     metadata_filter = {
[0m[49m[38;5;10m+    1263[0m:[38;5;10m[49m         "andAll": [
[0m[49m[38;5;10m+    1264[0m:[38;5;10m[49m             {"equals": {"key": "category", "value": category}},
[0m[49m[38;5;10m+    1265[0m:[38;5;10m[49m             {"equals": {"key": "language", "value": language}},
[0m[49m[38;5;10m+    1266[0m:[38;5;10m[49m         ]
[0m[49m[38;5;10m+    1267[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1268[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1269[0m:[38;5;10m[49m     # Step 4B: call Retrieve. Bedrock Knowledge Bases exposes
[0m[49m[38;5;10m+    1270[0m:[38;5;10m[49m     # `retrieve` (just retrieval) and `retrieve_and_generate`
[0m[49m[38;5;10m+    1271[0m:[38;5;10m[49m     # (retrieval plus an LLM call in one shot). We use `retrieve`
[0m[49m[38;5;10m+    1272[0m:[38;5;10m[49m     # so the orchestration Lambda controls the generation prompt
[0m[49m[38;5;10m+    1273[0m:[38;5;10m[49m     # and can stamp version metadata on the audit record.
[0m[49m[38;5;10m+    1274[0m:[38;5;10m[49m     try:
[0m[49m[38;5;10m+    1275[0m:[38;5;10m[49m         response = bedrock_agent_runtime.retrieve(
