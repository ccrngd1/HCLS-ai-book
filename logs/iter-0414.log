[0m[49m[38;5;10m+    1438[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1439[0m:[38;5;10m[49m ### Step 1: Enroll the Patient and Capture Cross-Organizational Consent
[0m[49m[38;5;10m+    1440[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1441[0m:[38;5;10m[49m Enrollment is more involved than for the previous chapter 11 bots because the consent posture covers multiple data sources, multiple sharing relationships, and (often) one or more caregivers with proxy-access scope. The consent flow has been reviewed by legal counsel familiar with HIPAA, the Information Blocking rule, state-specific medical-record statutes, state-specific caregiver-consent rules, and (where applicable) 42 CFR Part 2, state-specific mental-health-record protections, and other sensitive-record rules. Skip this step or treat it as boilerplate, and the deployment's regulatory posture is compromised before the first conversation.
[0m[49m[38;5;10m+    1442[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1443[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    1444[0m:[38;5;10m[49m     def enroll_patient(
[0m[49m[38;5;10m+    1445[0m:[38;5;10m[49m         self,
[0m[49m[38;5;10m+    1446[0m:[38;5;10m[49m         *,
[0m[49m[38;5;10m+    1447[0m:[38;5;10m[49m         patient_id,
[0m[49m[38;5;10m+    1448[0m:[38;5;10m[49m         enrollment_program_id,
[0m[49m[38;5;10m+    1449[0m:[38;5;10m[49m         legal_consent_form_signed,
[0m[49m[38;5;10m+    1450[0m:[38;5;10m[49m         caregiver_designations,
[0m[49m[38;5;10m+    1451[0m:[38;5;10m[49m         state_of_residence,
[0m[49m[38;5;10m+    1452[0m:[38;5;10m[49m         known_clinicians,
[0m[49m[38;5;10m+    1453[0m:[38;5;10m[49m         known_pharmacies,
[0m[49m[38;5;10m+    1454[0m:[38;5;10m[49m         known_payers,
[0m[49m[38;5;10m+    1455[0m:[38;5;10m[49m         known_ancillary_services,
[0m[49m[38;5;10m+    1456[0m:[38;5;10m[49m         preferences,
[0m[49m[38;5;10m+    1457[0m:[38;5;10m[49m         signing_user,
[0m[49m[38;5;10m+    1458[0m:[38;5;10m[49m     ):
[0m[49m[38;5;10m+    1459[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+    1460[0m:[38;5;10m[49m         Step 1: enroll the patient with cross-organizational
[0m[49m[38;5;10m+    1461[0m:[38;5;10m[49m         consent and caregiver setup. Returns a structured
[0m[49m[38;5;10m+    1462[0m:[38;5;10m[49m         result that downstream callers persist for audit.
[0m[49m[38;5;10m+    1463[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+    1464[0m:[38;5;10m[49m         # Step 1A: validate the patient is eligible for the
[0m[49m[38;5;10m+    1465[0m:[38;5;10m[49m         # institution's deployment scope. Production has the
[0m[49m[38;5;10m+    1466[0m:[38;5;10m[49m         # exclusion list owned by clinical leadership.
[0m[49m[38;5;10m+    1467[0m:[38;5;10m[49m         if not legal_consent_form_signed:
[0m[49m[38;5;10m+    1468[0m:[38;5;10m[49m             return {
[0m[49m[38;5;10m+    1469[0m:[38;5;10m[49m                 "action": "enrollment_declined",
[0m[49m[38;5;10m+    1470[0m:[38;5;10m[49m                 "reason": "consent_not_signed",
[0m[49m[38;5;10m+    1471[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    1472[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1473[0m:[38;5;10m[49m         # Step 1B: capture cross-organizational consent
[0m[49m[38;5;10m+    1474[0m:[38;5;10m[49m         # posture. Per data source AND per sharing
[0m[49m[38;5;10m+    1475[0m:[38;5;10m[49m         # relationship. Per sensitive-record category.
[0m[49m[38;5;10m+    1476[0m:[38;5;10m[49m         consent_record = {
[0m[49m[38;5;10m+    1477[0m:[38;5;10m[49m             "patient_id": patient_id,
[0m[49m[38;5;10m+    1478[0m:[38;5;10m[49m             "data_sources": [
[0m[49m[38;5;10m+    1479[0m:[38;5;10m[49m                 {"source_id": c["org_id"],
[0m[49m[38;5;10m+    1480[0m:[38;5;10m[49m                  "consented": True,
[0m[49m[38;5;10m+    1481[0m:[38;5;10m[49m                  "category_carve_outs": []}
[0m[49m[38;5;10m+    1482[0m:[38;5;10m[49m                 for c in known_clinicians
[0m[49m[38;5;10m+    1483[0m:[38;5;10m[49m             ] + [
[0m[49m[38;5;10m+    1484[0m:[38;5;10m[49m                 {"source_id": p["pharmacy_id"],
[0m[49m[38;5;10m+    1485[0m:[38;5;10m[49m                  "consented": True,
[0m[49m[38;5;10m+    1486[0m:[38;5;10m[49m                  "category_carve_outs": []}
[0m[49m[38;5;10m+    1487[0m:[38;5;10m[49m                 for p in known_pharmacies
[0m[49m[38;5;10m+    1488[0m:[38;5;10m[49m             ],
[0m[49m[38;5;10m+    1489[0m:[38;5;10m[49m             "sharing_relationships": {
[0m[49m[38;5;10m+    1490[0m:[38;5;10m[49m                 "with_primary_care": True,
[0m[49m[38;5;10m+    1491[0m:[38;5;10m[49m                 "with_specialists": True,
[0m[49m[38;5;10m+    1492[0m:[38;5;10m[49m                 "with_care_management": True,
[0m[49m[38;5;10m+    1493[0m:[38;5;10m[49m                 "with_designated_caregivers": True,
[0m[49m[38;5;10m+    1494[0m:[38;5;10m[49m             },
[0m[49m[38;5;10m+    1495[0m:[38;5;10m[49m             "sensitive_record_consents": {
[0m[49m[38;5;10m+    1496[0m:[38;5;10m[49m                 cat: False for cat in
[0m[49m[38;5;10m+    1497[0m:[38;5;10m[49m                 SENSITIVE_RECORD_CATEGORIES
[0m[49m[38;5;10m+    1498[0m:[38;5;10m[49m                 if cat != "general"
[0m[49m[38;5;10m+    1499[0m:[38;5;10m[49m             },
[0m[49m[38;5;10m+    1500[0m:[38;5;10m[49m             "revocability":
[0m[49m[38;5;10m+    1501[0m:[38;5;10m[49m                 "revocable_at_any_time_per_category",
[0m[49m[38;5;10m+    1502[0m:[38;5;10m[49m             "state_of_residence": state_of_residence,
[0m[49m[38;5;10m+    1503[0m:[38;5;10m[49m             "consent_version": "consent-v1.0",
[0m[49m[38;5;10m+    1504[0m:[38;5;10m[49m             "captured_at": _now_iso(),
[0m[49m[38;5;10m+    1505[0m:[38;5;10m[49m             "captured_by": signing_user,
[0m[49m[38;5;10m+    1506[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1507[0m:[38;5;10m[49m         self.t_consent.put_item(Item=consent_record)
[0m[49m[38;5;10m+    1508[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1509[0m:[38;5;10m[49m         # Step 1C: capture caregiver designations.
[0m[49m[38;5;10m+    1510[0m:[38;5;10m[49m         # Each caregiver is a first-class participant with
[0m[49m[38;5;10m+    1511[0m:[38;5;10m[49m         # separate identity, separate authentication,
[0m[49m[38;5;10m+    1512[0m:[38;5;10m[49m         # separate proxy-access scope, and separate state-
[0m[49m[38;5;10m+    1513[0m:[38;5;10m[49m         # law access posture.
[0m[49m[38;5;10m+    1514[0m:[38;5;10m[49m         caregiver_records = []
[0m[49m[38;5;10m+    1515[0m:[38;5;10m[49m         for cg in caregiver_designations:
[0m[49m[38;5;10m+    1516[0m:[38;5;10m[49m             cg_record = {
[0m[49m[38;5;10m+    1517[0m:[38;5;10m[49m                 "patient_id": patient_id,
[0m[49m[38;5;10m+    1518[0m:[38;5;10m[49m                 "caregiver_id": _new_id("cg"),
[0m[49m[38;5;10m+    1519[0m:[38;5;10m[49m                 "name": cg.get("name"),
[0m[49m[38;5;10m+    1520[0m:[38;5;10m[49m                 "relationship": cg.get("relationship"),
[0m[49m[38;5;10m+    1521[0m:[38;5;10m[49m                 "access_level":
[0m[49m[38;5;10m+    1522[0m:[38;5;10m[49m                     cg.get("access_level", "scheduling_only"),
[0m[49m[38;5;10m+    1523[0m:[38;5;10m[49m                 "sensitive_carve_outs":
[0m[49m[38;5;10m+    1524[0m:[38;5;10m[49m                     cg.get("sensitive_carve_outs", []),
[0m[49m[38;5;10m+    1525[0m:[38;5;10m[49m                 "state_law_check_passed": True,
[0m[49m[38;5;10m+    1526[0m:[38;5;10m[49m                 # Production runs the actual state-specific
[0m[49m[38;5;10m+    1527[0m:[38;5;10m[49m                 # caregiver-consent check here, including
[0m[49m[38;5;10m+    1528[0m:[38;5;10m[49m                 # notarized HCP/POA documentation where the
[0m[49m[38;5;10m+    1529[0m:[38;5;10m[49m                 # state requires it.
[0m[49m[38;5;10m+    1530[0m:[38;5;10m[49m                 "authentication_status":
[0m[49m[38;5;10m+    1531[0m:[38;5;10m[49m                     "verified_app_account",
[0m[49m[38;5;10m+    1532[0m:[38;5;10m[49m                 "designated_at": _now_iso(),
[0m[49m[38;5;10m+    1533[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    1534[0m:[38;5;10m[49m             self.t_caregiver.put_item(Item=cg_record)
[0m[49m[38;5;10m+    1535[0m:[38;5;10m[49m             caregiver_records.append(cg_record)
[0m[49m[38;5;10m+    1536[0m:[38;5;10m[49m             self.event_bus.put_events(Entries=[{
[0m[49m[38;5;10m+    1537[0m:[38;5;10m[49m                 "Source": "cc.coordination",
[0m[49m[38;5;10m+    1538[0m:[38;5;10m[49m                 "DetailType": "caregiver_designated",
[0m[49m[38;5;10m+    1539[0m:[38;5;10m[49m                 "Detail": json.dumps({
[0m[49m[38;5;10m+    1540[0m:[38;5;10m[49m                     "patient_id": patient_id,
[0m[49m[38;5;10m+    1541[0m:[38;5;10m[49m                     "caregiver_id": cg_record["caregiver_id"],
[0m[49m[38;5;10m+    1542[0m:[38;5;10m[49m                 }),
[0m[49m[38;5;10m+    1543[0m:[38;5;10m[49m                 "EventBusName":
[0m[49m[38;5;10m+    1544[0m:[38;5;10m[49m                     COORDINATION_EVENT_BUS_NAME,
[0m[49m[38;5;10m+    1545[0m:[38;5;10m[49m             }])
[0m[49m[38;5;10m+    1546[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1547[0m:[38;5;10m[49m         # Step 1D: capture the patient's known relationships,
[0m[49m[38;5;10m+    1548[0m:[38;5;10m[49m         # preferences, and integration coverage profile. The
[0m[49m[38;5;10m+    1549[0m:[38;5;10m[49m         # coverage profile drives the assistant's confidence
[0m[49m[38;5;10m+    1550[0m:[38;5;10m[49m         # calibration ("how much of David's care do I
[0m[49m[38;5;10m+    1551[0m:[38;5;10m[49m         # actually have visibility into?").
[0m[49m[38;5;10m+    1552[0m:[38;5;10m[49m         patient_record = {
[0m[49m[38;5;10m+    1553[0m:[38;5;10m[49m             "patient_id": patient_id,
[0m[49m[38;5;10m+    1554[0m:[38;5;10m[49m             "enrollment_program_id": enrollment_program_id,
[0m[49m[38;5;10m+    1555[0m:[38;5;10m[49m             "state_of_residence": state_of_residence,
[0m[49m[38;5;10m+    1556[0m:[38;5;10m[49m             "preferences": preferences,
[0m[49m[38;5;10m+    1557[0m:[38;5;10m[49m             "known_clinicians": known_clinicians,
[0m[49m[38;5;10m+    1558[0m:[38;5;10m[49m             "known_pharmacies": known_pharmacies,
[0m[49m[38;5;10m+    1559[0m:[38;5;10m[49m             "known_payers": known_payers,
[0m[49m[38;5;10m+    1560[0m:[38;5;10m[49m             "known_ancillary_services": known_ancillary_services,
[0m[49m[38;5;10m+    1561[0m:[38;5;10m[49m             "engagement_intensity":
[0m[49m[38;5;10m+    1562[0m:[38;5;10m[49m                 preferences.get("engagement_intensity",
[0m[49m[38;5;10m+    1563[0m:[38;5;10m[49m                                 DEFAULT_ENGAGEMENT_INTENSITY),
