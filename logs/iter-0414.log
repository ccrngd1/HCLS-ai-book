[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m # --- Versioning ---
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m # Every conversation turn carries the model version, the
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m # prompt version, the Knowledge Base versions, the Guardrail
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m # version, the active coordination-protocol-corpus version,
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m # the active seam-detection-rule-set version, the active
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m # referral-state-machine version, the active transition-of-
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m # care-protocol version, and the active consent version.
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m # This is how a future audit reconstructs which versions
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m # produced any given coordination decision.
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m PROMPT_VERSION                   = "cc-prompt-v1.0"
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m AGENT_VERSION                    = "cc-agent-v1.0"
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m PROTOCOL_CORPUS_VERSION          = "protocol-corpus-v1.0"
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m SEAM_RULES_VERSION               = "seam-rules-v1.0"
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m REFERRAL_STATE_MACHINE_VERSION   = "referral-fsm-v1.0"
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m TRANSITION_PROTOCOL_VERSION      = "transition-v1.0"
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m INSTITUTION_ID                   = "acme-health-system"
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m INSTITUTION_DISPLAY_NAME         = "Acme Health Coordination"
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m # --- Model IDs ---
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m # Two model roles. The orchestration model handles the multi-
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m # step reasoning, the tool calls, the speaker-role-aware
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m # language, and the final response generation. The smaller
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m # model handles intent classification, seam-detection-rule
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m # pre-filtering, and routine summarization.
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m #
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m # If your region requires cross-region inference, use the
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m # inference profile ID. TODO: verify the exact model IDs
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m # available in your region and account; Bedrock model
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m # availability evolves over time.
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m SMALL_MODEL_ID                   = "anthropic.claude-3-5-haiku-20241022-v1:0"
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m ORCHESTRATION_MODEL_ID           = "anthropic.claude-3-5-sonnet-20241022-v2:0"
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m # --- Pipeline Tuning ---
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m # Below this confidence on intent classification, ask a
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m # clarifying question rather than routing to a specific tool
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m # that will produce a low-quality answer.
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m INTENT_CONFIDENCE_THRESHOLD      = Decimal("0.70")
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m # How much recent conversation history we load into the
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m # coordination context window for each turn. Older context
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m # is reachable on demand via tools but not pre-loaded.
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m RECENT_CONVERSATION_WINDOW_DAYS  = 90
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m RECENT_CONVERSATION_MAX_TURNS    = 20
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m # Engagement intensity defaults. Coordination assistants
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m # default to a respectful cadence; bot-initiated check-ins
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m # beyond protocol-driven triggers require explicit opt-in.
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m DEFAULT_ENGAGEMENT_INTENSITY     = "protocol_driven_only"
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m # Institution regulatory positioning: "informational"
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m # indicates the deployment is positioned as informational
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m # coordination support with care-team oversight in regulated
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m # edge cases; "registered_samd" indicates the deployment is
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m # registered as Software-as-a-Medical-Device with FDA SaMD
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m # post-market obligations. The disclaimer language and the
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m # audit retention scale with this.
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m INSTITUTION_REGULATORY_POSITION  = "informational"
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m # --- Continuous Emergency-Screening Vocabulary ---
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m # The coordination assistant runs continuous emergency
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m # screening on every patient and caregiver utterance.
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m # Acute presentations route to recipe 11.6 triage, recipe
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m # 11.8 mental-health pathway, 911, 988, or the institutional
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m # crisis line as appropriate, with the conversation context
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m # preserved for the receiving system. Coordination-acuity
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m # events (post-discharge symptoms suggestive of
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m # decompensation, missed critical medications, reported
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m # caregiver crisis) route to the high-acuity coordination
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m # pathway with care-team alert.
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m #
