[0m[49m[38;5;10m+    1684[0m:[38;5;10m[49m         consent_check = self._verify_consent(
[0m[49m[38;5;10m+    1685[0m:[38;5;10m[49m             patient_id=patient_id,
[0m[49m[38;5;10m+    1686[0m:[38;5;10m[49m             source_type=source_type,
[0m[49m[38;5;10m+    1687[0m:[38;5;10m[49m             sensitivity_category=sensitivity_category,
[0m[49m[38;5;10m+    1688[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    1689[0m:[38;5;10m[49m         if not consent_check["allowed"]:
[0m[49m[38;5;10m+    1690[0m:[38;5;10m[49m             logger.info(
[0m[49m[38;5;10m+    1691[0m:[38;5;10m[49m                 "ingestion consent-denied patient_hash=%s "
[0m[49m[38;5;10m+    1692[0m:[38;5;10m[49m                 "source=%s category=%s reason=%s",
[0m[49m[38;5;10m+    1693[0m:[38;5;10m[49m                 _hash_patient_id(patient_id),
[0m[49m[38;5;10m+    1694[0m:[38;5;10m[49m                 source_type, sensitivity_category,
[0m[49m[38;5;10m+    1695[0m:[38;5;10m[49m                 consent_check["reason"])
[0m[49m[38;5;10m+    1696[0m:[38;5;10m[49m             return {"action": "consent_denied",
[0m[49m[38;5;10m+    1697[0m:[38;5;10m[49m                     "reason": consent_check["reason"]}
[0m[49m[38;5;10m+    1698[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1699[0m:[38;5;10m[49m         # Step 2E: write the provenance journal. Append-only
[0m[49m[38;5;10m+    1700[0m:[38;5;10m[49m         # and separately KMS-keyed. Production writes the
[0m[49m[38;5;10m+    1701[0m:[38;5;10m[49m         # provenance entry through Firehose into an Object-
[0m[49m[38;5;10m+    1702[0m:[38;5;10m[49m         # Lock S3 archive plus the separately-keyed DDB
[0m[49m[38;5;10m+    1703[0m:[38;5;10m[49m         # index. The demo writes to both mocks for
[0m[49m[38;5;10m+    1704[0m:[38;5;10m[49m         # illustration.
[0m[49m[38;5;10m+    1705[0m:[38;5;10m[49m         provenance_id = _new_id("prov")
[0m[49m[38;5;10m+    1706[0m:[38;5;10m[49m         provenance_entry = {
[0m[49m[38;5;10m+    1707[0m:[38;5;10m[49m             "patient_id": patient_id,
[0m[49m[38;5;10m+    1708[0m:[38;5;10m[49m             "provenance_id": provenance_id,
[0m[49m[38;5;10m+    1709[0m:[38;5;10m[49m             "source_type": source_type,
