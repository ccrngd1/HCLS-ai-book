[0m[49m[38;5;10m+     800[0m:[38;5;10m[49m     if isinstance(value, dict):
[0m[49m[38;5;10m+     801[0m:[38;5;10m[49m         return {k: _to_decimal(v) for k, v in value.items()}
[0m[49m[38;5;10m+     802[0m:[38;5;10m[49m     if isinstance(value, list):
[0m[49m[38;5;10m+     803[0m:[38;5;10m[49m         return [_to_decimal(v) for v in value]
[0m[49m[38;5;10m+     804[0m:[38;5;10m[49m     return value
[0m[49m[38;5;10m+     805[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     806[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     807[0m:[38;5;10m[49m def _from_decimal(value):
[0m[49m[38;5;10m+     808[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     809[0m:[38;5;10m[49m     Inverse of _to_decimal for serializing back to JSON.
[0m[49m[38;5;10m+     810[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     811[0m:[38;5;10m[49m     if isinstance(value, Decimal):
[0m[49m[38;5;10m+     812[0m:[38;5;10m[49m         # Decimal -> int when integral, else float
[0m[49m[38;5;10m+     813[0m:[38;5;10m[49m         return int(value) if value % 1 == 0 else float(value)
[0m[49m[38;5;10m+     814[0m:[38;5;10m[49m     if isinstance(value, dict):
[0m[49m[38;5;10m+     815[0m:[38;5;10m[49m         return {k: _from_decimal(v) for k, v in value.items()}
[0m[49m[38;5;10m+     816[0m:[38;5;10m[49m     if isinstance(value, list):
[0m[49m[38;5;10m+     817[0m:[38;5;10m[49m         return [_from_decimal(v) for v in value]
[0m[49m[38;5;10m+     818[0m:[38;5;10m[49m     return value
[0m[49m[38;5;10m+     819[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     820[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     821[0m:[38;5;10m[49m def _hash_patient_id(patient_id):
[0m[49m[38;5;10m+     822[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     823[0m:[38;5;10m[49m     Stable, non-reversible hash used in log lines so we can
