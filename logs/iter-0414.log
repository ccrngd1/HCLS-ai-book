[0m[49m[38;5;10m+    3542[0m:[38;5;10m[49m         existing = self.t_referral.get_item(
[0m[49m[38;5;10m+    3543[0m:[38;5;10m[49m             Key={"referral_id": referral_id}).get("Item")
