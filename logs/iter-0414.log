[0m[49m[38;5;10m+    2525[0m:[38;5;10m[49m         for crisis_type, spec in EMERGENCY_VOCABULARY.items():
[0m[49m[38;5;10m+    2526[0m:[38;5;10m[49m             for kw in spec["keywords"]:
[0m[49m[38;5;10m+    2527[0m:[38;5;10m[49m                 if kw in utt_lower:
[0m[49m[38;5;10m+    2528[0m:[38;5;10m[49m                     if spec["urgency"] == \
