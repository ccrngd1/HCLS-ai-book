[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m # time bug, not a runtime surprise.
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m for _name, _value in [
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     ("PATIENT_COORDINATION_TABLE",   PATIENT_COORDINATION_TABLE),
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m     ("COORDINATION_STATE_TABLE",     COORDINATION_STATE_TABLE),
