[0m[49m[38;5;10m+    1712[0m:[38;5;10m[49m             "source_timestamp":
[0m[49m[38;5;10m+    1713[0m:[38;5;10m[49m                 parsed.get("source_timestamp"),
[0m[49m[38;5;10m+    1714[0m:[38;5;10m[49m             "ingestion_timestamp": _now_iso(),
[0m[49m[38;5;10m+    1715[0m:[38;5;10m[49m             "ingestion_path":
[0m[49m[38;5;10m+    1716[0m:[38;5;10m[49m                 ingestion_metadata.get("path"),
