[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m # Bedrock Knowledge Base IDs. The protocol corpus is the
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m # institutionally-curated, version-controlled, clinical-
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m # leadership-signed-off coordination-protocol library
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m # (transitions of care by destination setting, referral-
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m # tracking by specialty, post-discharge by admission type,
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m # medication reconciliation, condition-specific playbooks).
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m # The education library is the institutional patient-
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m # education corpus with multilingual and multi-reading-level
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m # variants. The conversation-history index is the patient-
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m # specific retrievable history so the assistant can find a
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m # thing the patient said three months ago.
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m PROTOCOL_KB_ID                   = "PROTOCOL_KB_PLACEHOLDER"
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m EDUCATION_KB_ID                  = "EDUCATION_KB_PLACEHOLDER"
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m HISTORY_KB_ID                    = "HISTORY_KB_PLACEHOLDER"
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m # Bedrock Guardrail for restricted-topic filtering. Configure
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m # in the Bedrock console with restricted topics for diagnosis-
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m # attempted, prescription-attempted, dose-titration-attempted,
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m # treatment-recommendation-beyond-existing-orders, therapy-
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m # attempted (route to recipe 11.8), triage-attempted (route to
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m # recipe 11.6), and benefits-quote-attempted (route to recipe
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m # 11.5). Pin to a specific version, not DRAFT, in production.
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m GUARDRAIL_ID                     = "GUARDRAIL_PLACEHOLDER_ID"
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m GUARDRAIL_VERSION                = "1"
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m # KMS key IDs. The provenance journal and the coordination-
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m # decision-record journal use separately-managed customer
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m # keys for blast-radius containment. A leaked credential to
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m # the general coordination workload should not give an
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m # attacker the provenance journal or the decision-record
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m # archive.
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m GENERAL_KMS_KEY_ID               = "GENERAL_KMS_PLACEHOLDER"
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m PROVENANCE_KMS_KEY_ID            = "PROVENANCE_KMS_PLACEHOLDER"
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m DECISION_RECORD_KMS_KEY_ID       = "DECISION_KMS_PLACEHOLDER"
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m 
