[0m[49m[38;5;10m+    3760[0m:[38;5;10m[49m                 "rule_owner": "pharmacy_director",
[0m[49m[38;5;10m+    3761[0m:[38;5;10m[49m                 "category": "medication_reconciliation",
[0m[49m[38;5;10m+    3762[0m:[38;5;10m[49m                 "priority": seam.get("priority", "medium"),
[0m[49m[38;5;10m+    3763[0m:[38;5;10m[49m                 "confidence":
[0m[49m[38;5;10m+    3764[0m:[38;5;10m[49m                     _to_decimal(seam.get(
[0m[49m[38;5;10m+    3765[0m:[38;5;10m[49m                         "confidence", Decimal("0.85"))),
[0m[49m[38;5;10m+    3766[0m:[38;5;10m[49m                 "suggested_resolver":
