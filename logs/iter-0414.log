[0m[49m[38;5;10m+     835[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     836[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     837[0m:[38;5;10m[49m def _new_id(prefix):
[0m[49m[38;5;10m+     838[0m:[38;5;10m[49m     return f"{prefix}-{uuid.uuid4().hex[:12]}"
[0m[49m[38;5;10m+     839[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     840[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     841[0m:[38;5;10m[49m def _integrity_hash(payload):
[0m[49m[38;5;10m+     842[0m:[38;5;10m[49m     """
