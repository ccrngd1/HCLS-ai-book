[0m[49m[38;5;10m+    1623[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1624[0m:[38;5;10m[49m ### Step 2: Ingest Cross-Organizational Data With Provenance Discipline
[0m[49m[38;5;10m+    1625[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1626[0m:[38;5;10m[49m The ingestion layer is the architectural floor for the coordination assistant. Every data point ingested is recorded with its source, its timestamp, its ingestion path, and its integrity hash. The ingestion pipeline is composed of per-source adapters; each adapter handles authentication, rate limiting, format translation, sensitive-record classification, and provenance recording. In production each adapter is a separate Lambda; the demo collapses them into one method that dispatches by source type.
[0m[49m[38;5;10m+    1627[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1628[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    1629[0m:[38;5;10m[49m     def ingest_event(
[0m[49m[38;5;10m+    1630[0m:[38;5;10m[49m         self,
[0m[49m[38;5;10m+    1631[0m:[38;5;10m[49m         *,
[0m[49m[38;5;10m+    1632[0m:[38;5;10m[49m         source_type,
[0m[49m[38;5;10m+    1633[0m:[38;5;10m[49m         raw_message,
[0m[49m[38;5;10m+    1634[0m:[38;5;10m[49m         ingestion_metadata,
[0m[49m[38;5;10m+    1635[0m:[38;5;10m[49m     ):
[0m[49m[38;5;10m+    1636[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+    1637[0m:[38;5;10m[49m         Step 2: ingest a cross-organizational data event
[0m[49m[38;5;10m+    1638[0m:[38;5;10m[49m         with provenance discipline. Returns a structured
[0m[49m[38;5;10m+    1639[0m:[38;5;10m[49m         result describing the ingestion outcome.
[0m[49m[38;5;10m+    1640[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+    1641[0m:[38;5;10m[49m         # Step 2A: route to the appropriate per-source
[0m[49m[38;5;10m+    1642[0m:[38;5;10m[49m         # adapter. Production wires distinct adapters
[0m[49m[38;5;10m+    1643[0m:[38;5;10m[49m         # behind a common interface; the demo dispatches
[0m[49m[38;5;10m+    1644[0m:[38;5;10m[49m         # by source type.
[0m[49m[38;5;10m+    1645[0m:[38;5;10m[49m         adapter_dispatch = {
[0m[49m[38;5;10m+    1646[0m:[38;5;10m[49m             "hl7_v2_adt":         self._adapter_hl7,
[0m[49m[38;5;10m+    1647[0m:[38;5;10m[49m             "hl7_v2_oru":         self._adapter_hl7,
[0m[49m[38;5;10m+    1648[0m:[38;5;10m[49m             "fhir_subscription":  self._adapter_fhir,
[0m[49m[38;5;10m+    1649[0m:[38;5;10m[49m             "fhir_polling":       self._adapter_fhir,
[0m[49m[38;5;10m+    1650[0m:[38;5;10m[49m             "claims_batch":       self._adapter_claims,
[0m[49m[38;5;10m+    1651[0m:[38;5;10m[49m             "pharmacy_ncpdp":     self._adapter_pharmacy,
[0m[49m[38;5;10m+    1652[0m:[38;5;10m[49m             "pharmacy_vendor":    self._adapter_pharmacy,
[0m[49m[38;5;10m+    1653[0m:[38;5;10m[49m             "home_health_vendor": self._adapter_home_health,
[0m[49m[38;5;10m+    1654[0m:[38;5;10m[49m             "patient_reported":   self._adapter_patient_reported,
[0m[49m[38;5;10m+    1655[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1656[0m:[38;5;10m[49m         adapter = adapter_dispatch.get(source_type)
[0m[49m[38;5;10m+    1657[0m:[38;5;10m[49m         if adapter is None:
[0m[49m[38;5;10m+    1658[0m:[38;5;10m[49m             return {"action": "rejected",
[0m[49m[38;5;10m+    1659[0m:[38;5;10m[49m                     "reason":
[0m[49m[38;5;10m+    1660[0m:[38;5;10m[49m                         f"unknown_source_type:{source_type}"}
[0m[49m[38;5;10m+    1661[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1662[0m:[38;5;10m[49m         # Step 2B: parse and validate via the adapter.
