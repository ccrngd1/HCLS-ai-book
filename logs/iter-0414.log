[0m[49m[38;5;10m+    1667[0m:[38;5;10m[49m                 source_type, parsed.get("reason"))
[0m[49m[38;5;10m+    1668[0m:[38;5;10m[49m             return {"action": "rejected",
[0m[49m[38;5;10m+    1669[0m:[38;5;10m[49m                     "reason": parsed.get("reason")}
