[0m[49m[38;5;10m+    3576[0m:[38;5;10m[49m             "ordering_clinician_id":
[0m[49m[38;5;10m+    3577[0m:[38;5;10m[49m                 referral_event.get(
[0m[49m[38;5;10m+    3578[0m:[38;5;10m[49m                     "ordering_clinician_id"),
[0m[49m[38;5;10m+    3579[0m:[38;5;10m[49m             "ordered_at": _now_iso(),
[0m[49m[38;5;10m+    3580[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    3581[0m:[38;5;10m[49m         record.update({
