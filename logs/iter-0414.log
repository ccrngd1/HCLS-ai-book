[0m[49m[38;5;10m+    1722[0m:[38;5;10m[49m         self.provenance_archive.put(
[0m[49m[38;5;10m+    1723[0m:[38;5;10m[49m             key=f"{patient_id}/{provenance_id}.json",
[0m[49m[38;5;10m+    1724[0m:[38;5;10m[49m             body=provenance_entry)
