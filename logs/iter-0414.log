[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m # hypotheticals, past-tense framing, and culturally and
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m # linguistically variant expressions. Keyword detection
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m # alone is not sufficient.
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m EMERGENCY_VOCABULARY = {
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m     "acute_cardiac": {
