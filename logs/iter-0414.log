[0m[49m[38;5;10m+    3585[0m:[38;5;10m[49m             "provenance_id":
[0m[49m[38;5;10m+    3586[0m:[38;5;10m[49m                 referral_event.get("provenance_id"),
[0m[49m[38;5;10m+    3587[0m:[38;5;10m[49m             "state_machine_version":
[0m[49m[38;5;10m+    3588[0m:[38;5;10m[49m                 REFERRAL_STATE_MACHINE_VERSION,
[0m[49m[38;5;10m+    3589[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    3590[0m:[38;5;10m[49m         self.t_referral.put_item(Item=record)
