[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m         C --> D[SageMaker Training\nBCQ Offline RL]
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m         D --> E[SageMaker Model Registry\nPolicy Versions]
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m         E --> F[SageMaker Endpoint\nPolicy Inference]
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m     end
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m     subgraph Quarterly Visit Inference
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m         G[Clinician Opens Chart] --> H[Lambda\nState Constructor]
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m         H -->|Fetch Longitudinal State| I[DynamoDB\nPatient State]
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m         H -->|Get Recommendation| F
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m         F --> J[Lambda\nSafety Constraints]
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m         J --> K[Treatment Recommendation\nto Clinician]
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m     end
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m     subgraph Monitoring
