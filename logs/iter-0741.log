[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m         "prior_admits_12mo": 1,
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m         "prior_ed_visits_12mo": 3,
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m         "insurance_category_encoded": 1,  # Medicare
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m         "day_of_week_admit": 2,           # Tuesday
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m         "hour_of_admit": 14,
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m         "current_day_of_stay": 3,
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m         "wbc_latest": 9.2,
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m         "creatinine_latest": 1.4,
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m         "albumin_latest": 3.0,
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m         "temp_max_24h": 37.2,
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m         "hr_variability_24h": 12.0,
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m         "o2_requirement": 1.0,
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m         "iv_antibiotics_active": 1,
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m         "vasopressors_active": 0,
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m         "procedures_pending": 1,
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m         "abnormal_lab_count": 2,
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m     prediction = predict_remaining_los(model, sample_patient)
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m     print(f"  Patient: 68yo male, day 3, admitted from ED, Charlson=4")
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m     print(f"  Predicted remaining LOS: {prediction['predicted_remaining_days']} days")
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m     print(f"  Confidence interval: [{prediction['confidence_lower']}, "
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m           f"{prediction['confidence_upper']}] days")
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m     print(f"  Total predicted LOS: {prediction['total_predicted_los']} days")
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m     print(f"  DRG expected LOS: {prediction['drg_expected_los']} days")
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m     print(f"  Exceeds expected: {prediction['exceeds_expected']}")
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m     # --- Step 5: Simulate monitoring ---
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m     print("\n[Step 5] Simulating prediction accuracy monitoring...")
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m     # Pretend we had predictions for 20 patients who were discharged yesterday
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m     simulated_outcomes = [
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m         {"predicted_remaining": 1.5, "actual_remaining": 1},
