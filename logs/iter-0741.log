[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m DAILY_FEATURES = [
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m     "current_day_of_stay", "wbc_latest", "creatinine_latest", "albumin_latest",
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m     "temp_max_24h", "hr_variability_24h", "o2_requirement",
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m     "iv_antibiotics_active", "vasopressors_active", "procedures_pending",
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m     "abnormal_lab_count"
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m ALL_FEATURES = ADMISSION_FEATURES + DAILY_FEATURES
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m # --- Model Hyperparameters ---
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m # These are reasonable defaults for hospital LOS prediction with XGBoost.
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m # Tune them on your actual data. The key tradeoffs:
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m # - max_depth: deeper trees capture more interactions but overfit faster
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m # - learning_rate: lower = more trees needed but better generalization
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m # - min_child_weight: higher = more conservative splits, less overfitting to rare cases
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m MODEL_PARAMS = {
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m     "max_depth": 6,
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m     "learning_rate": 0.05,
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m     "n_estimators": 500,
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m     "subsample": 0.8,
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m     "colsample_bytree": 0.8,
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m     "min_child_weight": 10,
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m     "objective": "reg:squarederror",
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m     "eval_metric": "mae",
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m     "early_stopping_rounds": 20,
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m     "random_state": 42,
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m # --- Operational Thresholds ---
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m # When a patient's predicted total LOS exceeds their DRG geometric mean by
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m # this many days, fire an early warning alert to discharge planning.
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m EXTENDED_STAY_ALERT_THRESHOLD_DAYS = 1.5
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m # Model performance threshold. If daily MAE exceeds this, trigger a
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m # retraining alert. 2.5 days is generous; tighten as your model matures.
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m PERFORMANCE_ALERT_THRESHOLD_MAE = 2.5
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m # DynamoDB table for storing predictions
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m PREDICTIONS_TABLE = "los-predictions"
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m # S3 bucket for training data and model artifacts
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m TRAINING_BUCKET = "my-hospital-ml-data"
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m ## Step 1: Generate Synthetic Training Data
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m *The pseudocode calls this `prepare_training_data`. In a real system, you'd extract this from your EHR data warehouse. Here we generate realistic synthetic encounters so you can run the full pipeline without access to patient data. Never use real PHI in development.*
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m def generate_synthetic_encounters(n_encounters: int = 2000, seed: int = 42) -> pd.DataFrame:
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m     Generate synthetic hospital encounters with realistic LOS distributions.
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m     Real hospital LOS data is right-skewed: most stays are 2-5 days, with a
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m     long tail extending to 30+ days. We simulate this using a log-normal
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m     distribution, which matches the empirical shape well.
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m     The features are correlated with LOS in ways that mirror clinical reality:
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m     - Older patients stay longer (more comorbidities, slower recovery)
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m     - Higher Charlson scores correlate with longer stays
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m     - ED admissions tend to be sicker than direct admits
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m     - Emergent admissions have wider LOS variance than elective
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m         n_encounters: Number of synthetic encounters to generate.
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m         seed: Random seed for reproducibility.
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m         DataFrame with one row per encounter, including features and actual_los.
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m     rng = np.random.default_rng(seed)
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m     # Demographics
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m     ages = rng.integers(18, 95, size=n_encounters)
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m     sex = rng.choice([0, 1], size=n_encounters)  # 0=female, 1=male
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m     # Admission characteristics
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m     # ED admits are ~60% of hospital admissions nationally
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m     admission_source = rng.choice([0, 1, 2], size=n_encounters, p=[0.6, 0.3, 0.1])
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m     # 0=ED, 1=direct, 2=transfer
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m     admission_type = rng.choice([0, 1, 2], size=n_encounters, p=[0.5, 0.35, 0.15])
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m     # 0=emergent, 1=elective, 2=urgent
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m     # Comorbidity burden (Charlson index: 0-15 range, most patients 0-5)
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m     charlson = rng.poisson(lam=2, size=n_encounters).clip(0, 15)
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m     elixhauser = rng.poisson(lam=3, size=n_encounters).clip(0, 12)
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m     # Prior utilization
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m     prior_admits = rng.poisson(lam=0.5, size=n_encounters)
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m     prior_ed = rng.poisson(lam=1.2, size=n_encounters)
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m     # Insurance (0=commercial, 1=Medicare, 2=Medicaid, 3=self-pay)
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m     insurance = rng.choice([0, 1, 2, 3], size=n_encounters, p=[0.35, 0.40, 0.20, 0.05])
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m     # DRG geometric mean LOS (national average for the assigned DRG)
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m     # This is the single strongest predictor of actual LOS.
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m     drg_mean_los = rng.uniform(2.0, 8.0, size=n_encounters)
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m     # Timing
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m     day_of_week = rng.integers(0, 7, size=n_encounters)
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m     hour_of_admit = rng.integers(0, 24, size=n_encounters)
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m     # --- Generate actual LOS ---
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m     # Base LOS is driven by DRG mean, modified by patient factors.
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m     # This is a simplified version of reality, but captures the key relationships.
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m     base_log_los = (
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m         np.log(drg_mean_los)
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m         + 0.01 * (ages - 50)           # older = longer
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m         + 0.05 * charlson               # sicker = longer
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m         + 0.1 * (admission_source == 0).astype(float)  # ED admits slightly longer
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m         + 0.15 * (admission_type == 0).astype(float)   # emergent = longer
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m         + rng.normal(0, 0.3, size=n_encounters)        # noise
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m     # Exponentiate to get actual LOS (log-normal distribution)
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m     actual_los = np.exp(base_log_los).clip(1, 60).round(0).astype(int)
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m     # Build the DataFrame
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m     encounters = pd.DataFrame({
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m         "encounter_id": [f"ENC-{i:06d}" for i in range(n_encounters)],
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m         "age": ages,
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m         "sex_encoded": sex,
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m         "admission_source_encoded": admission_source,
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m         "admission_type_encoded": admission_type,
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m         "drg_geometric_mean_los": drg_mean_los.round(1),
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m         "charlson_score": charlson,
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m         "elixhauser_count": elixhauser,
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m         "prior_admits_12mo": prior_admits,
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m         "prior_ed_visits_12mo": prior_ed,
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m         "insurance_category_encoded": insurance,
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m         "day_of_week_admit": day_of_week,
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m         "hour_of_admit": hour_of_admit,
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m         "actual_los": actual_los,
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m     return encounters
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m ## Step 2: Generate Daily Features for Training
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m *The pseudocode calls this `extract_daily_features`. For training, we need to create examples at multiple time points during each stay. A patient who stayed 7 days generates examples at day 0 (target: 7), day 1 (target: 6), day 2 (target: 5), etc. This teaches the model to predict remaining LOS from any point during the stay.*
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m def generate_daily_features_for_training(encounters: pd.DataFrame, seed: int = 42) -> pd.DataFrame:
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m     Expand each encounter into multiple training examples (one per day of stay).
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m     This is the key insight for LOS prediction: you don't just train on
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     admission-time features. You train on features at every point during the
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m     stay, with the target being REMAINING days (not total days). This lets
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m     the model update predictions as clinical data accumulates.
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m     The daily features simulate lab values, vital signs, and treatment
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m     intensity that evolve during the stay. In a real system, these come
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m     from your EHR data warehouse.
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m         encounters: DataFrame from generate_synthetic_encounters.
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m         seed: Random seed.
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m         DataFrame with one row per (encounter, day) pair, including all
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m         features and the target variable (remaining_los).
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m     rng = np.random.default_rng(seed)
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m     rows = []
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m     for _, enc in encounters.iterrows():
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m         actual_los = enc["actual_los"]
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m         # Generate an example for each day of the stay (day 0 through day actual_los-1)
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m         for day in range(actual_los):
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m             # Remaining LOS is the target: how many more days from this point?
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m             remaining = actual_los - day
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m             # Simulate daily clinical features that evolve during the stay.
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m             # In reality, these come from lab results, vital signs, and orders.
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m             # WBC (white blood cell count): elevated early in infection, normalizes
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m             wbc = max(4.0, 12.0 - day * 0.5 + rng.normal(0, 2))
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m             # Creatinine: kidney function marker, may be elevated in sick patients
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m             creatinine = max(0.5, 1.2 + 0.1 * enc["charlson_score"] - day * 0.05 + rng.normal(0, 0.3))
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m             # Albumin: nutritional status, drops during acute illness
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m             albumin = max(1.5, 3.5 - 0.1 * day + rng.normal(0, 0.3))
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m             # Temperature: fever early, resolves over stay
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m             temp_max = max(36.5, 38.5 - day * 0.3 + rng.normal(0, 0.5))
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m             # Heart rate variability: higher when unstable
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m             hr_var = max(5, 20 - day * 1.5 + rng.normal(0, 5))
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m             # O2 requirement: liters per minute, decreases as patient improves
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m             o2 = max(0, 3 - day * 0.5 + rng.normal(0, 1))
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m             # Treatment intensity flags (binary)
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m             iv_abx = 1 if (day < actual_los * 0.6 and rng.random() > 0.3) else 0
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m             vasopressors = 1 if (day < 2 and enc["charlson_score"] > 4 and rng.random() > 0.5) else 0
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m             # Pending procedures: more early in stay
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m             procedures_pending = max(0, int(3 - day + rng.integers(-1, 2)))
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m             # Abnormal lab count: decreases as patient improves
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m             abnormal_labs = max(0, int(4 - day * 0.5 + rng.integers(-1, 2)))
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m             row = {
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m                 # Admission features (static, same for all days of this encounter)
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m                 "encounter_id": enc["encounter_id"],
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m                 "age": enc["age"],
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m                 "sex_encoded": enc["sex_encoded"],
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m                 "admission_source_encoded": enc["admission_source_encoded"],
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m                 "admission_type_encoded": enc["admission_type_encoded"],
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m                 "drg_geometric_mean_los": enc["drg_geometric_mean_los"],
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m                 "charlson_score": enc["charlson_score"],
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m                 "elixhauser_count": enc["elixhauser_count"],
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m                 "prior_admits_12mo": enc["prior_admits_12mo"],
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m                 "prior_ed_visits_12mo": enc["prior_ed_visits_12mo"],
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m                 "insurance_category_encoded": enc["insurance_category_encoded"],
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m                 "day_of_week_admit": enc["day_of_week_admit"],
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m                 "hour_of_admit": enc["hour_of_admit"],
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m                 # Daily features (change each day)
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m                 "current_day_of_stay": day,
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m                 "wbc_latest": round(wbc, 1),
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m                 "creatinine_latest": round(creatinine, 2),
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m                 "albumin_latest": round(albumin, 1),
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m                 "temp_max_24h": round(temp_max, 1),
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m                 "hr_variability_24h": round(hr_var, 1),
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m                 "o2_requirement": round(o2, 1),
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m                 "iv_antibiotics_active": iv_abx,
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m                 "vasopressors_active": vasopressors,
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m                 "procedures_pending": procedures_pending,
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m                 "abnormal_lab_count": abnormal_labs,
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m                 # Target
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m                 "remaining_los": remaining,
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m             rows.append(row)
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m     return pd.DataFrame(rows)
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m ## Step 3: Train the XGBoost Model
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m *The pseudocode calls this `train_los_model`. We train a gradient boosted tree to predict remaining LOS from the combined admission + daily features. In production, you'd train separate models per service line. Here we train one model on the full synthetic population to keep things simple.*
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m from xgboost import XGBRegressor
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m from sklearn.model_selection import train_test_split
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m from sklearn.metrics import mean_absolute_error, r2_score
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m def train_los_model(training_df: pd.DataFrame) -> tuple:
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m     Train an XGBoost regressor to predict remaining length of stay.
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m     Uses a temporal-style split (last 20% of data for test) to simulate
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m     how the model would perform on future patients. In production, you'd
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m     do a proper time-based split: train on months 1-10, validate on month 11,
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m     test on month 12.
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m         training_df: Output of generate_daily_features_for_training.
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m         Tuple of (trained model, test metrics dict, test DataFrame with predictions).
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m     # Separate features from target and metadata
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m     feature_cols = ALL_FEATURES
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m     target_col = "remaining_los"
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m     X = training_df[feature_cols].copy()
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m     y = training_df[target_col].copy()
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m     # Split: 80% train, 20% test.
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m     # In production, use a time-based split to prevent data leakage.
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m     # Random split is acceptable for this synthetic demonstration.
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m     X_train, X_test, y_train, y_test = train_test_split(
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m         X, y, test_size=0.2, random_state=42
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m     logger.info("Training set: %d examples, Test set: %d examples", len(X_train), len(X_test))
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m     # Train XGBoost regressor
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m     model = XGBRegressor(
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m         max_depth=MODEL_PARAMS["max_depth"],
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m         learning_rate=MODEL_PARAMS["learning_rate"],
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m         n_estimators=MODEL_PARAMS["n_estimators"],
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m         subsample=MODEL_PARAMS["subsample"],
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m         colsample_bytree=MODEL_PARAMS["colsample_bytree"],
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m         min_child_weight=MODEL_PARAMS["min_child_weight"],
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m         objective=MODEL_PARAMS["objective"],
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m         random_state=MODEL_PARAMS["random_state"],
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m         eval_metric="mae",
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m     # Fit with early stopping on a validation subset
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m     model.fit(
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m         X_train, y_train,
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m         eval_set=[(X_test, y_test)],
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m         verbose=False,
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m     # Evaluate on test set
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m     predictions = model.predict(X_test)
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m     # Predictions should never be negative (can't have negative remaining days)
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m     predictions = np.maximum(predictions, 0)
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m     mae = mean_absolute_error(y_test, predictions)
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m     r2 = r2_score(y_test, predictions)
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m     # "Within N days" accuracy: what percentage of predictions are within
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m     # 1 or 2 days of the actual remaining LOS? This is often more meaningful
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m     # to operations teams than MAE.
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m     within_1 = np.mean(np.abs(y_test.values - predictions) <= 1) * 100
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m     within_2 = np.mean(np.abs(y_test.values - predictions) <= 2) * 100
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m     metrics = {
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m         "mae": round(mae, 2),
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m         "r_squared": round(r2, 3),
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m         "within_1_day_pct": round(within_1, 1),
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m         "within_2_days_pct": round(within_2, 1),
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m         "n_train": len(X_train),
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m         "n_test": len(X_test),
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m     logger.info("Model metrics: MAE=%.2f days, R²=%.3f, Within 1 day=%.1f%%",
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m                 mae, r2, within_1)
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m     # Feature importance: which features drive predictions?
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m     # This is critical for clinician trust. If the model says "DRG mean LOS"
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m     # is the top feature, that makes clinical sense. If it says "hour of admit"
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m     # is the top feature, something is wrong.
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m     importances = dict(zip(feature_cols, model.feature_importances_))
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m     top_features = sorted(importances.items(), key=lambda x: x[1], reverse=True)[:5]
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m     logger.info("Top 5 features: %s", [(f, round(v, 3)) for f, v in top_features])
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m     return model, metrics, top_features
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m ## Step 4: Run Inference for a Current Inpatient
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m *The pseudocode calls this `predict_remaining_los`. Given a patient's current features, produce a prediction with a confidence interval. In production, features come from the SageMaker Feature Store. Here we simulate the feature retrieval and show the inference pattern.*
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m def predict_remaining_los(model, patient_features: dict) -> dict:
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m     Generate a LOS prediction for a single current inpatient.
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m     In production, this function would:
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m     1. Pull features from SageMaker Feature Store (online store)
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m     2. Invoke a SageMaker endpoint
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m     3. Write the result to DynamoDB
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m     Here we call the local model directly to demonstrate the logic.
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m         model: Trained XGBRegressor.
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m         patient_features: Dict with keys matching ALL_FEATURES.
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m         Prediction dict with point estimate, confidence bounds, and metadata.
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m     # Build feature vector in the correct order
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m     feature_vector = pd.DataFrame([patient_features])[ALL_FEATURES]
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m     # Point prediction
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m     predicted_remaining = float(model.predict(feature_vector)[0])
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m     predicted_remaining = max(0, predicted_remaining)  # can't be negative
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m     # Confidence interval estimation.
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m     # XGBoost doesn't natively produce prediction intervals. In production,
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m     # you'd use one of these approaches:
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m     # 1. Train quantile regression models (objective="reg:quantileerror")
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m     # 2. Use conformal prediction for distribution-free intervals
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m     # 3. Bootstrap: train multiple models on resampled data, use spread
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m     #
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m     # Here we use a simple heuristic: +/- 1.5 days for short predicted stays,
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m     # wider for longer predicted stays. This is a placeholder. Do not ship this.
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m     uncertainty = max(1.0, predicted_remaining * 0.4)
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m     lower_bound = max(0, predicted_remaining - uncertainty)
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m     upper_bound = predicted_remaining + uncertainty
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m     # Calculate predicted discharge date
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m     current_day = patient_features["current_day_of_stay"]
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m     drg_expected = patient_features["drg_geometric_mean_los"]
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m     total_predicted_los = current_day + predicted_remaining
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m     result = {
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m         "predicted_remaining_days": round(predicted_remaining, 1),
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m         "confidence_lower": round(lower_bound, 1),
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m         "confidence_upper": round(upper_bound, 1),
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m         "current_day_of_stay": current_day,
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m         "total_predicted_los": round(total_predicted_los, 1),
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m         "drg_expected_los": drg_expected,
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m         "exceeds_expected": total_predicted_los > drg_expected,
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m         "prediction_timestamp": datetime.datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m     return result
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m ## Step 5: Store Prediction in DynamoDB
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m *The pseudocode calls this `write_to_prediction_store`. The prediction store is what operational dashboards query. It needs to support queries by unit, by predicted discharge date, and by individual encounter.*
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m def store_prediction(encounter_id: str, unit: str, bed: str, prediction: dict) -> dict:
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m     Write a LOS prediction to DynamoDB for operational consumption.
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m     The table design supports two access patterns:
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m     1. Get prediction for a specific encounter (partition key = encounter_id)
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m     2. Query all predictions for a unit (GSI on unit + predicted_discharge_date)
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m     DynamoDB requires Decimal for numeric values, not float. Every numeric
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m     field must be wrapped in Decimal() or put_item raises a TypeError.
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m     We convert via str() first to avoid floating-point representation artifacts
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m     (e.g., Decimal(0.1) becomes 0.1000000000000000055511151231257827021181583404541015625).
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m         encounter_id: Unique encounter identifier.
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m         unit: Hospital unit (e.g., "4-North Medical").
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m         bed: Bed assignment (e.g., "4N-12").
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m         prediction: Output of predict_remaining_los.
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m         The full record written to DynamoDB.
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m     table = dynamodb.Table(PREDICTIONS_TABLE)
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m     record = {
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m         "encounter_id": encounter_id,
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m         "unit": unit,
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m         "bed": bed,
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m         "predicted_remaining_days": Decimal(str(prediction["predicted_remaining_days"])),
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m         "confidence_lower": Decimal(str(prediction["confidence_lower"])),
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m         "confidence_upper": Decimal(str(prediction["confidence_upper"])),
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m         "current_day_of_stay": prediction["current_day_of_stay"],
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m         "total_predicted_los": Decimal(str(prediction["total_predicted_los"])),
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m         "drg_expected_los": Decimal(str(prediction["drg_expected_los"])),
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m         "exceeds_expected": prediction["exceeds_expected"],
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m         "prediction_timestamp": prediction["prediction_timestamp"],
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m     table.put_item(Item=record)
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m     logger.info("Stored prediction for %s: %.1f days remaining",
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m                 encounter_id, prediction["predicted_remaining_days"])
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m     return record
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m ## Step 6: Daily Monitoring (Compare Predictions to Outcomes)
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m *The pseudocode calls this `daily_batch_refresh` (the monitoring portion). When patients are discharged, you can compare yesterday's prediction against reality. This is how you detect model drift before it becomes a problem.*
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m def evaluate_prediction_accuracy(
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m     predictions_with_outcomes: list[dict],
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m     Compare predictions against actual outcomes for discharged patients.
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m     This runs daily on patients who were discharged in the last 24 hours.
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m     Each entry has the prediction that was active at the start of their
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m     final day and the actual remaining LOS (which we now know was 0 or 1).
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m         predictions_with_outcomes: List of dicts, each with:
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m             - "predicted_remaining": what the model said
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m             - "actual_remaining": what actually happened (0 if discharged that day)
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m         Monitoring metrics dict.
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m     if not predictions_with_outcomes:
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m         return {"n_evaluated": 0, "status": "no_discharges"}
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m     errors = []
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m     for entry in predictions_with_outcomes:
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m         error = entry["predicted_remaining"] - entry["actual_remaining"]
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m         errors.append(error)
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m     errors_arr = np.array(errors)
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m     abs_errors = np.abs(errors_arr)
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m     metrics = {
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m         "n_evaluated": len(errors),
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m         "mae": round(float(np.mean(abs_errors)), 2),
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m         "bias": round(float(np.mean(errors_arr)), 2),  # positive = overpredicting
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m         "within_1_day_pct": round(float(np.mean(abs_errors <= 1) * 100), 1),
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m         "within_2_days_pct": round(float(np.mean(abs_errors <= 2) * 100), 1),
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m         "max_error": round(float(np.max(abs_errors)), 1),
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m         "evaluation_date": datetime.date.today().isoformat(),
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m     # Alert if performance is degrading
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m     if metrics["mae"] > PERFORMANCE_ALERT_THRESHOLD_MAE:
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m         logger.warning(
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m             "Model performance degradation detected. MAE=%.2f exceeds threshold=%.2f. "
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m             "Consider triggering retraining pipeline.",
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m             metrics["mae"], PERFORMANCE_ALERT_THRESHOLD_MAE
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m     return metrics
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m ## Putting It All Together
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m Here's the full pipeline assembled into a single runnable script. This demonstrates the end-to-end flow: generate data, train a model, make predictions, and evaluate.
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m def run_full_pipeline():
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m     Execute the complete LOS prediction pipeline end-to-end.
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m     This demonstrates:
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m     1. Synthetic data generation (stand-in for EHR data extraction)
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m     2. Feature engineering (expanding encounters into daily training examples)
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m     3. Model training (XGBoost regression)
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m     4. Inference (predicting remaining LOS for a simulated current inpatient)
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m     5. Monitoring (evaluating prediction accuracy)
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m     In production, steps 1-3 run as a SageMaker Training Job (weekly/monthly).
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m     Steps 4-5 run continuously via Lambda triggers and daily batch jobs.
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m     print("LOS Prediction Pipeline - Full Demonstration")
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m     # --- Step 1: Generate synthetic encounters ---
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m     print("\n[Step 1] Generating synthetic hospital encounters...")
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m     encounters = generate_synthetic_encounters(n_encounters=2000)
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m     print(f"  Generated {len(encounters)} encounters")
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m     print(f"  LOS distribution: mean={encounters['actual_los'].mean():.1f}, "
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m           f"median={encounters['actual_los'].median():.0f}, "
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m           f"max={encounters['actual_los'].max()}")
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m     # --- Step 2: Expand into daily training examples ---
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m     print("\n[Step 2] Generating daily features for training...")
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m     training_df = generate_daily_features_for_training(encounters)
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m     print(f"  Created {len(training_df)} training examples "
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m           f"from {len(encounters)} encounters")
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m     print(f"  (average {len(training_df)/len(encounters):.1f} examples per encounter)")
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m     # --- Step 3: Train the model ---
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m     print("\n[Step 3] Training XGBoost model...")
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m     model, metrics, top_features = train_los_model(training_df)
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m     print(f"  MAE: {metrics['mae']} days")
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m     print(f"  R²: {metrics['r_squared']}")
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m     print(f"  Within 1 day: {metrics['within_1_day_pct']}%")
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m     print(f"  Within 2 days: {metrics['within_2_days_pct']}%")
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m     print(f"  Top features:")
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m     for feat, importance in top_features:
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m         print(f"    {feat}: {importance:.3f}")
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m     # --- Step 4: Predict for a simulated current inpatient ---
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m     print("\n[Step 4] Running inference for a simulated inpatient...")
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m     # Simulate a 68-year-old Medicare patient, admitted from ED on day 3,
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m     # with moderate comorbidity burden and some abnormal labs.
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m     sample_patient = {
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m         "age": 68,
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m         "sex_encoded": 1,
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m         "admission_source_encoded": 0,  # ED
