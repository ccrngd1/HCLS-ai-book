[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m     print("Pipeline complete.")
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m         "model_metrics": metrics,
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m         "sample_prediction": prediction,
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m         "monitoring_metrics": monitoring,
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m if __name__ == "__main__":
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m     results = run_full_pipeline()
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m     print("\n\nFull results as JSON:")
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m     # Convert any non-serializable types for display
