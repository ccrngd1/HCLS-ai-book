[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m ┌────────── INPUT SAFETY + CONTINUOUS EMERGENCY SCREEN ────┐
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m │                                                           │
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m │   [Standard input safety primitives from recipe 11.1]     │
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m │    - Prompt-injection detection                           │
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m │    - PHI minimization                                     │
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m │    - Self-harm and crisis classifier                      │
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m │                                                           │
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m │   [Recruitment-specific continuous emergency screening]   │
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m │    - Runs on every patient utterance                      │
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m │    - Detects acute-emergency presentations (chest pain,   │
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m │      severe shortness of breath, suspected stroke,        │
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m │      severe bleeding, suspected sepsis, suicidal intent,  │
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m │      acute psychiatric distress, suspected adverse        │
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m │      reaction to current treatment)                       │
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m │    - Detects clinically-significant events that should    │
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m │      route to the patient's treating clinician (new       │
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m │      severe symptoms, suspected disease progression,      │
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m │      suspected treatment-related toxicity)                │
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m │    - Triggers immediate routing to triage (recipe 11.6),  │
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m │      mental-health pathway (recipe 11.8), 911, 988, or    │
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m │      institutional emergency line as appropriate          │
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m │                                                           │
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m │   [Recruitment-specific sensitive-disclosure detection]   │
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m │    - Sensitive-record categories (substance use, mental   │
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m │      health, HIV status, genetic test results)            │
