[0m[49m[38;5;10m+     947[0m:[38;5;10m[49m     identifier as the partition key. Each Flink operator holds
[0m[49m[38;5;10m+     948[0m:[38;5;10m[49m     the state in keyed-state managed by RocksDB and persists
[0m[49m[38;5;10m+     949[0m:[38;5;10m[49m     snapshots to DynamoDB every few records or when the operator
[0m[49m[38;5;10m+     950[0m:[38;5;10m[49m     checkpoints. The demo holds it in a Python dict keyed by
[0m[49m[38;5;10m+     951[0m:[38;5;10m[49m     patient_id and reads / writes from DynamoDB on every change
[0m[49m[38;5;10m+     952[0m:[38;5;10m[49m     to keep the wiring simple.
[0m[49m[38;5;10m+     953[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     954[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     955[0m:[38;5;10m[49m     def __init__(self, patient_id):
[0m[49m[38;5;10m+     956[0m:[38;5;10m[49m         self.patient_id      = patient_id
[0m[49m[38;5;10m+     957[0m:[38;5;10m[49m         # parameter -> deque of (measured_dt, value) tuples
[0m[49m[38;5;10m+     958[0m:[38;5;10m[49m         self.recent          = defaultdict(deque)
[0m[49m[38;5;10m+     959[0m:[38;5;10m[49m         # parameter -> baseline dict
[0m[49m[38;5;10m+     960[0m:[38;5;10m[49m         self.baselines       = {}
