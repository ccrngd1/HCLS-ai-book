[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m def validate_record(record):
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m     """Return (True, record) if the record is well-formed, else
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m     (False, reason). Production sends invalid records to a
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m     dead-letter prefix on S3 for the data-engineering team's
[0m[49m[38;5;10m+    717[0m:[38;5;10m[49m     daily review.
[0m[49m[38;5;10m+    718[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    719[0m:[38;5;10m[49m     for field in REQUIRED_RECORD_FIELDS:
[0m[49m[38;5;10m+    720[0m:[38;5;10m[49m         if field not in record or record[field] is None:
[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m             return False, f"missing_field:{field}"
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m     if record["parameter"] not in VITAL_CATALOG:
