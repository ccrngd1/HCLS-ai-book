[0m[49m[38;5;10m+    1733[0m:[38;5;10m[49m     return counts
[0m[49m[38;5;10m+    1734[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1735[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1736[0m:[38;5;10m[49m if __name__ == "__main__":
[0m[49m[38;5;10m+    1737[0m:[38;5;10m[49m     run_demo()
[0m[49m[38;5;10m+    1738[0m:[38;5;10m[49m ```
