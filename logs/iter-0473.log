[0m[49m[38;5;10m+    1625[0m:[38;5;10m[49m     """End-to-end pipeline orchestration.
[0m[49m[38;5;10m+    1626[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1627[0m:[38;5;10m[49m     The demo wires up a synthetic Kinesis stream; production
[0m[49m[38;5;10m+    1628[0m:[38;5;10m[49m     starts with a Flink application reading from a real Kinesis
[0m[49m[38;5;10m+    1629[0m:[38;5;10m[49m     stream populated by the device gateway.
[0m[49m[38;5;10m+    1630[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1631[0m:[38;5;10m[49m     run_id = str(uuid.uuid4())
[0m[49m[38;5;10m+    1632[0m:[38;5;10m[49m     print(f"\n=== Vital Sign Trajectory Monitoring run_id={run_id} ===\n")
[0m[49m[38;5;10m+    1633[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1634[0m:[38;5;10m[49m     counts = defaultdict(int)
[0m[49m[38;5;10m+    1635[0m:[38;5;10m[49m     for envelope in stream.iterate():
[0m[49m[38;5;10m+    1636[0m:[38;5;10m[49m         record = envelope["Payload"]
[0m[49m[38;5;10m+    1637[0m:[38;5;10m[49m         outcome = process_record(
[0m[49m[38;5;10m+    1638[0m:[38;5;10m[49m             record, patient_states, alert_table, sns_topics,
