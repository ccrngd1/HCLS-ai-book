[0m[49m[38;5;10m+    1657[0m:[38;5;10m[49m     real services.
[0m[49m[38;5;10m+    1658[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1659[0m:[38;5;10m[49m     stream      = MockKinesisStream(VITAL_STREAM_NAME)
[0m[49m[38;5;10m+    1660[0m:[38;5;10m[49m     state_table = MockTable(PATIENT_STATE_TABLE, pk="patient_id")
[0m[49m[38;5;10m+    1661[0m:[38;5;10m[49m     alert_table = MockTable(PATIENT_ALERT_TABLE,
[0m[49m[38;5;10m+    1662[0m:[38;5;10m[49m                             pk="patient_id",
