[0m[49m[38;5;10m+    1577[0m:[38;5;10m[49m     if verdict in ("artifact_hard", "artifact_device"):
[0m[49m[38;5;10m+    1578[0m:[38;5;10m[49m         cloudwatch.put_metric_data(
[0m[49m[38;5;10m+    1579[0m:[38;5;10m[49m             Namespace=CLOUDWATCH_NAMESPACE,
[0m[49m[38;5;10m+    1580[0m:[38;5;10m[49m             MetricData=[{
[0m[49m[38;5;10m+    1581[0m:[38;5;10m[49m                 "MetricName": "ArtifactFiltered",
[0m[49m[38;5;10m+    1582[0m:[38;5;10m[49m                 "Value":      1.0,
[0m[49m[38;5;10m+    1583[0m:[38;5;10m[49m                 "Unit":       "Count",
[0m[49m[38;5;10m+    1584[0m:[38;5;10m[49m                 "Dimensions": [
[0m[49m[38;5;10m+    1585[0m:[38;5;10m[49m                     {"Name": "Verdict",   "Value": verdict},
[0m[49m[38;5;10m+    1586[0m:[38;5;10m[49m                     {"Name": "Parameter", "Value": cleaned["parameter"]},
[0m[49m[38;5;10m+    1587[0m:[38;5;10m[49m                 ],
[0m[49m[38;5;10m+    1588[0m:[38;5;10m[49m             }])
[0m[49m[38;5;10m+    1589[0m:[38;5;10m[49m         return "artifact"
[0m[49m[38;5;10m+    1590[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1591[0m:[38;5;10m[49m     # Step 3: update per-patient state and baseline.
[0m[49m[38;5;10m+    1592[0m:[38;5;10m[49m     state = update_patient_state(state, cleaned, verdict)
[0m[49m[38;5;10m+    1593[0m:[38;5;10m[49m 
