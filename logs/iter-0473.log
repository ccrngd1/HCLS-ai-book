[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m REQUIRED_RECORD_FIELDS = (
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m     "patient_id", "parameter", "value", "unit",
