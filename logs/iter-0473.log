[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m # --- Acuity Tier Thresholds ---
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m # Composite score thresholds drive the alert tier and the routing
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m # decision. The tiers are illustrative; production calibrates per
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m # unit and per population. Higher tiers route to higher-acuity
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m # pagers (rapid response team) and have shorter persistence
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m # windows than lower tiers (bedside RN).
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m ACUITY_TIERS = [
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m     # (lower_inclusive, label, route_target, persistence_minutes)
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m     (0,  "stable",         None,             None),
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m     (3,  "watch",          "bedside_rn",     15),
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m     (5,  "concern",        "bedside_rn",     10),
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m     (7,  "rapid_response", "rapid_response", 5),
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m # --- Acuity-Tier Suppression Windows ---
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m # After a rapid-response page is fired and acknowledged, the
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m # pipeline suppresses repeat pages for this many minutes unless
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m # the score crosses a higher tier. Without this, a single
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m # deterioration produces dozens of pages.
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m TIER_REFRACTORY_MINUTES = {
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m     "watch":           60,
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m     "concern":         45,
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m     "rapid_response":  30,
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m # --- Baseline Window ---
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m # Rolling baseline window length. 6 hours is a reasonable
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m # default for a stable inpatient; production may shorten this
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m # to 2 hours for ICU patients (where the state changes faster)
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m # and lengthen it to 24 hours for med-surg patients (where
