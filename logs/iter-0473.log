[0m[49m[38;5;10m+    1679[0m:[38;5;10m[49m         event_bus, cloudwatch, s3,
[0m[49m[38;5;10m+    1680[0m:[38;5;10m[49m         SUPPRESSED_ALERT_BUCKET,
[0m[49m[38;5;10m+    1681[0m:[38;5;10m[49m         DEVICE_QUALITY_BUCKET,
[0m[49m[38;5;10m+    1682[0m:[38;5;10m[49m         HISTORICAL_VITALS_BUCKET)
[0m[49m[38;5;10m+    1683[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1684[0m:[38;5;10m[49m     # Persist final per-patient state to the state table. In
[0m[49m[38;5;10m+    1685[0m:[38;5;10m[49m     # production each Flink record updates the table
