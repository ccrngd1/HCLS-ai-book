[0m[49m[38;5;10m+    824[0m:[38;5;10m[49m ## Step 2: Filter Artifact Before It Pollutes the Trajectory
[0m[49m[38;5;10m+    825[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    826[0m:[38;5;10m[49m Sensor dropouts, motion artifact, and physiologically impossible values are the single biggest source of false alerts in the literature and in any production deployment. Step 2 catches them before the baseline updater and the score composer ever see them. The demo implements a layered filter (hard physiological bounds, device-quality tag, then a residual-from-baseline outlier check) that mirrors what a production pipeline would have.
[0m[49m[38;5;10m+    827[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    828[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    829[0m:[38;5;10m[49m class ArtifactDetector:
[0m[49m[38;5;10m+    830[0m:[38;5;10m[49m     """Pedagogical artifact detector.
[0m[49m[38;5;10m+    831[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    832[0m:[38;5;10m[49m     Production replaces the residual-from-baseline check with a
[0m[49m[38;5;10m+    833[0m:[38;5;10m[49m     learned classifier (SageMaker endpoint that takes a small
[0m[49m[38;5;10m+    834[0m:[38;5;10m[49m     window of recent samples plus device-quality metadata and
[0m[49m[38;5;10m+    835[0m:[38;5;10m[49m     returns artifact / clean / suspicious). The hard-bound and
[0m[49m[38;5;10m+    836[0m:[38;5;10m[49m     device-quality checks are mechanical and stay in the Lambda;
[0m[49m[38;5;10m+    837[0m:[38;5;10m[49m     only the residual check benefits from a model.
[0m[49m[38;5;10m+    838[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    839[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    840[0m:[38;5;10m[49m     name = "layered_artifact_filter"
[0m[49m[38;5;10m+    841[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    842[0m:[38;5;10m[49m     OUTLIER_RESIDUAL_MAD_MULTIPLIER = 6.0
[0m[49m[38;5;10m+    843[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    844[0m:[38;5;10m[49m     def is_artifact(self, cleaned_record, patient_state):
[0m[49m[38;5;10m+    845[0m:[38;5;10m[49m         """Return (verdict, reason) where verdict is one of
[0m[49m[38;5;10m+    846[0m:[38;5;10m[49m         'clean', 'artifact_hard', 'artifact_device',
[0m[49m[38;5;10m+    847[0m:[38;5;10m[49m         'artifact_residual', or 'suspicious'."""
[0m[49m[38;5;10m+    848[0m:[38;5;10m[49m         param = cleaned_record["parameter"]
[0m[49m[38;5;10m+    849[0m:[38;5;10m[49m         catalog = VITAL_CATALOG[param]
[0m[49m[38;5;10m+    850[0m:[38;5;10m[49m         v = float(cleaned_record["value"])
[0m[49m[38;5;10m+    851[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    852[0m:[38;5;10m[49m         # 2a. Hard physiological bounds. A heart rate of 0 or 350
[0m[49m[38;5;10m+    853[0m:[38;5;10m[49m         # is not a real reading; reject without further analysis.
[0m[49m[38;5;10m+    854[0m:[38;5;10m[49m         if v < catalog["physio_min"] or v > catalog["physio_max"]:
[0m[49m[38;5;10m+    855[0m:[38;5;10m[49m             return "artifact_hard", (
[0m[49m[38;5;10m+    856[0m:[38;5;10m[49m                 f"value {v} outside physio bounds "
[0m[49m[38;5;10m+    857[0m:[38;5;10m[49m                 f"[{catalog['physio_min']}, {catalog['physio_max']}]")
[0m[49m[38;5;10m+    858[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    859[0m:[38;5;10m[49m         # 2b. Device-quality flag. Some monitors emit explicit
[0m[49m[38;5;10m+    860[0m:[38;5;10m[49m         # quality codes ("low_perfusion", "motion", "no_signal"
[0m[49m[38;5;10m+    861[0m:[38;5;10m[49m         # for SpO2; "lead_off" for ECG-derived HR; "cuff_error"
[0m[49m[38;5;10m+    862[0m:[38;5;10m[49m         # for NIBP). When the gateway forwards a non-OK quality
[0m[49m[38;5;10m+    863[0m:[38;5;10m[49m         # tag, treat the value as artifact.
[0m[49m[38;5;10m+    864[0m:[38;5;10m[49m         device_quality = cleaned_record.get("device_quality", "ok")
[0m[49m[38;5;10m+    865[0m:[38;5;10m[49m         if device_quality and device_quality != "ok":
[0m[49m[38;5;10m+    866[0m:[38;5;10m[49m             return "artifact_device", (
[0m[49m[38;5;10m+    867[0m:[38;5;10m[49m                 f"device_quality={device_quality}")
[0m[49m[38;5;10m+    868[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    869[0m:[38;5;10m[49m         # 2c. Residual-from-baseline outlier check. If the
[0m[49m[38;5;10m+    870[0m:[38;5;10m[49m         # patient has a stable rolling baseline, a single value
[0m[49m[38;5;10m+    871[0m:[38;5;10m[49m         # that is far from the baseline relative to the patient's
[0m[49m[38;5;10m+    872[0m:[38;5;10m[49m         # own dispersion is a suspect. Production layers a
[0m[49m[38;5;10m+    873[0m:[38;5;10m[49m         # learned artifact classifier here; the demo uses a
[0m[49m[38;5;10m+    874[0m:[38;5;10m[49m         # robust z-score with a generous multiplier so true
[0m[49m[38;5;10m+    875[0m:[38;5;10m[49m         # deteriorations survive while sensor glitches do not.
[0m[49m[38;5;10m+    876[0m:[38;5;10m[49m         baseline = patient_state.get("baselines", {}).get(param, {})
[0m[49m[38;5;10m+    877[0m:[38;5;10m[49m         if baseline.get("status") == "ready":
[0m[49m[38;5;10m+    878[0m:[38;5;10m[49m             base_v = baseline["baseline_value"]
[0m[49m[38;5;10m+    879[0m:[38;5;10m[49m             base_d = max(baseline["baseline_dispersion"], 1e-3)
[0m[49m[38;5;10m+    880[0m:[38;5;10m[49m             residual = abs(v - base_v) / base_d
[0m[49m[38;5;10m+    881[0m:[38;5;10m[49m             if residual > self.OUTLIER_RESIDUAL_MAD_MULTIPLIER:
[0m[49m[38;5;10m+    882[0m:[38;5;10m[49m                 # Mark as suspicious, not hard artifact. A real
[0m[49m[38;5;10m+    883[0m:[38;5;10m[49m                 # deterioration could legitimately produce a
[0m[49m[38;5;10m+    884[0m:[38;5;10m[49m                 # large residual; the persistence gate downstream
[0m[49m[38;5;10m+    885[0m:[38;5;10m[49m                 # decides whether it sticks. Suspicious values
[0m[49m[38;5;10m+    886[0m:[38;5;10m[49m                 # are excluded from the immediate baseline update
[0m[49m[38;5;10m+    887[0m:[38;5;10m[49m                 # but kept on the recent-window so the slope
[0m[49m[38;5;10m+    888[0m:[38;5;10m[49m                 # detector can see them. This is one of the
[0m[49m[38;5;10m+    889[0m:[38;5;10m[49m                 # subtle calibrations that takes weeks to tune.
[0m[49m[38;5;10m+    890[0m:[38;5;10m[49m                 return "suspicious", (
[0m[49m[38;5;10m+    891[0m:[38;5;10m[49m                     f"residual={residual:.2f} MAD over baseline")
[0m[49m[38;5;10m+    892[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    893[0m:[38;5;10m[49m         return "clean", None
[0m[49m[38;5;10m+    894[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    895[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    896[0m:[38;5;10m[49m # Module-level singleton. Production swaps this for a Lambda
[0m[49m[38;5;10m+    897[0m:[38;5;10m[49m # that calls a SageMaker endpoint or for an inline Flink
[0m[49m[38;5;10m+    898[0m:[38;5;10m[49m # operator that imports a learned model.
[0m[49m[38;5;10m+    899[0m:[38;5;10m[49m ARTIFACT_DETECTOR = ArtifactDetector()
[0m[49m[38;5;10m+    900[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    901[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    902[0m:[38;5;10m[49m def filter_artifact(cleaned_record, patient_state, s3,
[0m[49m[38;5;10m+    903[0m:[38;5;10m[49m                     device_quality_bucket):
[0m[49m[38;5;10m+    904[0m:[38;5;10m[49m     """Step 2: Apply the artifact filter.
[0m[49m[38;5;10m+    905[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    906[0m:[38;5;10m[49m     See pseudocode Step 2 in the main recipe. Returns
[0m[49m[38;5;10m+    907[0m:[38;5;10m[49m     (verdict, reason). Suspect / hard-artifact / device-artifact
[0m[49m[38;5;10m+    908[0m:[38;5;10m[49m     records are logged to the device-quality prefix for offline
[0m[49m[38;5;10m+    909[0m:[38;5;10m[49m     review; clean and suspicious records continue downstream.
[0m[49m[38;5;10m+    910[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    911[0m:[38;5;10m[49m     verdict, reason = ARTIFACT_DETECTOR.is_artifact(
[0m[49m[38;5;10m+    912[0m:[38;5;10m[49m         cleaned_record, patient_state)
[0m[49m[38;5;10m+    913[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    914[0m:[38;5;10m[49m     if verdict in ("artifact_hard", "artifact_device", "suspicious"):
[0m[49m[38;5;10m+    915[0m:[38;5;10m[49m         # Persist the artifact decision so the device-quality
[0m[49m[38;5;10m+    916[0m:[38;5;10m[49m         # team can spot a misbehaving monitor early. The key is
[0m[49m[38;5;10m+    917[0m:[38;5;10m[49m         # partitioned by date and patient so a single device
