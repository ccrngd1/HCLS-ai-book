[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m     if not isinstance(record["value"], (int, float)):
[0m[49m[38;5;10m+    725[0m:[38;5;10m[49m         return False, "non_numeric_value"
[0m[49m[38;5;10m+    726[0m:[38;5;10m[49m     try:
[0m[49m[38;5;10m+    727[0m:[38;5;10m[49m         _parse_iso(record["measured_ts"])
[0m[49m[38;5;10m+    728[0m:[38;5;10m[49m     except (TypeError, ValueError):
[0m[49m[38;5;10m+    729[0m:[38;5;10m[49m         return False, "bad_measured_ts"
[0m[49m[38;5;10m+    730[0m:[38;5;10m[49m     return True, None
[0m[49m[38;5;10m+    731[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    732[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    733[0m:[38;5;10m[49m def _normalize_unit(parameter, value, unit):
[0m[49m[38;5;10m+    734[0m:[38;5;10m[49m     """Convert the device's raw unit to the canonical unit for
[0m[49m[38;5;10m+    735[0m:[38;5;10m[49m     this parameter. Most ward monitors emit canonical units, but
