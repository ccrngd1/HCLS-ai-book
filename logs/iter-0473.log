[0m[49m[38;5;10m+    919[0m:[38;5;10m[49m         eff_dt = _parse_iso(cleaned_record["measured_ts"])
[0m[49m[38;5;10m+    920[0m:[38;5;10m[49m         key = (f"device-quality/date={eff_dt.strftime('%Y-%m-%d')}/"
[0m[49m[38;5;10m+    921[0m:[38;5;10m[49m                f"unit={cleaned_record['unit_id']}/"
[0m[49m[38;5;10m+    922[0m:[38;5;10m[49m                f"{cleaned_record['patient_id']}-{uuid.uuid4()}.json")
[0m[49m[38;5;10m+    923[0m:[38;5;10m[49m         s3.put_object(
