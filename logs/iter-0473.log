[0m[49m[38;5;10m+    1671[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1672[0m:[38;5;10m[49m     print("[setup] generating synthetic stream...")
[0m[49m[38;5;10m+    1673[0m:[38;5;10m[49m     generate_synthetic_vital_stream(stream)
