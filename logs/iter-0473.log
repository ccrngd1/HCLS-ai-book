[0m[49m[38;5;10m+    1299[0m:[38;5;10m[49m def _persistence_satisfied(state, parameter, tier_label, now_dt):
[0m[49m[38;5;10m+    1300[0m:[38;5;10m[49m     """True if the recent window has held the concerning signal
[0m[49m[38;5;10m+    1301[0m:[38;5;10m[49m     long enough to clear the persistence gate."""
[0m[49m[38;5;10m+    1302[0m:[38;5;10m[49m     catalog = VITAL_CATALOG[parameter]
[0m[49m[38;5;10m+    1303[0m:[38;5;10m[49m     required = catalog["persistence_min_minutes"]
[0m[49m[38;5;10m+    1304[0m:[38;5;10m[49m     window = state.recent.get(parameter, [])
[0m[49m[38;5;10m+    1305[0m:[38;5;10m[49m     if not window:
[0m[49m[38;5;10m+    1306[0m:[38;5;10m[49m         return False
[0m[49m[38;5;10m+    1307[0m:[38;5;10m[49m     earliest = window[0][0]
[0m[49m[38;5;10m+    1308[0m:[38;5;10m[49m     elapsed = (now_dt - earliest).total_seconds() / 60.0
[0m[49m[38;5;10m+    1309[0m:[38;5;10m[49m     return elapsed >= required
[0m[49m[38;5;10m+    1310[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1311[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1312[0m:[38;5;10m[49m def _refractory_blocks(state, tier_label, now_dt):
[0m[49m[38;5;10m+    1313[0m:[38;5;10m[49m     """True if a recent page on this or higher tier blocks a new
[0m[49m[38;5;10m+    1314[0m:[38;5;10m[49m     page (refractory window). The tier-rank lets a higher tier
[0m[49m[38;5;10m+    1315[0m:[38;5;10m[49m     bypass a lower tier's refractory window, since a worsening
[0m[49m[38;5;10m+    1316[0m:[38;5;10m[49m     patient must be allowed to escalate."""
[0m[49m[38;5;10m+    1317[0m:[38;5;10m[49m     rank = {"watch": 1, "concern": 2, "rapid_response": 3}
[0m[49m[38;5;10m+    1318[0m:[38;5;10m[49m     target_rank = rank.get(tier_label, 0)
[0m[49m[38;5;10m+    1319[0m:[38;5;10m[49m     for prior_tier, prior_dt in state.last_paged_at.items():
[0m[49m[38;5;10m+    1320[0m:[38;5;10m[49m         if rank.get(prior_tier, 0) >= target_rank:
[0m[49m[38;5;10m+    1321[0m:[38;5;10m[49m             mins = (now_dt - prior_dt).total_seconds() / 60.0
[0m[49m[38;5;10m+    1322[0m:[38;5;10m[49m             window = TIER_REFRACTORY_MINUTES.get(prior_tier, 0)
