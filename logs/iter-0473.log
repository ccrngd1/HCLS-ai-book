[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m             for assn in assignments:
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m                 attr, placeholder = [s.strip() for s in assn.split("=")]
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m                 if (ExpressionAttributeNames
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m                         and attr in ExpressionAttributeNames):
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m                     attr = ExpressionAttributeNames[attr]
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m                 value = ExpressionAttributeValues[placeholder]
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m                 item[attr] = value
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m         self.write_count += 1
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m         return {"Attributes": dict(item)}
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m     def query(self, KeyConditionExpression=None, **kwargs):
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m         # Demo's query usage is limited to "patient_id = :pk".
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m         # A real DynamoDB query parser is out of scope.
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m         items = [v for k, v in self.items.items()
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m                  if KeyConditionExpression is None
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m                  or k[0] == KeyConditionExpression]
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m         return {"Items": [dict(it) for it in items]}
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m class MockEventBus:
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m     """In-memory stand-in for EventBridge.
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m     Production uses boto3.client('events').put_events(...). The
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m     mock accumulates events so the demo can show what would have
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m     been emitted to the vital-sign-events bus at each pipeline
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m     stage.
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m     def __init__(self, name):
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m         self.name   = name
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m         self.events = []
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m     def put_events(self, Entries):
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m         self.events.extend(Entries)
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m         return {"FailedEntryCount": 0}
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m class MockSnsTopic:
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m     """In-memory stand-in for an SNS topic.
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m     Production uses boto3.client('sns').publish(...). The mock
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m     accumulates messages so the demo can show what would have
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m     been paged to the rapid response team and to the bedside RN.
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m     def __init__(self, arn):
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m         self.arn      = arn
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m         self.messages = []
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m     def publish(self, Message, Subject=None,
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m                 MessageAttributes=None, **kwargs):
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m         self.messages.append({
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m             "Subject":           Subject,
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m             "Message":           Message,
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m             "MessageAttributes": MessageAttributes or {},
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m             "TimestampUtc":      datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m         return {"MessageId": str(uuid.uuid4())}
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m class MockCloudWatch:
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m     """In-memory stand-in for CloudWatch.
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m     Production uses boto3.client('cloudwatch').put_metric_data(...).
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m     The mock accumulates metrics so the demo can show what would
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m     have been emitted (per-unit alert volume, artifact-filter
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m     rate, end-to-end record latency).
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m     def __init__(self):
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m         self.metrics = defaultdict(list)
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m     def put_metric_data(self, Namespace, MetricData):
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m         for m in MetricData:
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m             self.metrics[f"{Namespace}/{m['MetricName']}"].append({
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m                 "Value": m["Value"],
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m                 "Unit":  m.get("Unit", "None"),
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m                 "Time":  datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m def _emit_record(stream, patient_id, parameter, value, unit,
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m                  ts, acuity_tier, unit_id):
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m     """Convenience helper that emits a single vital-sign record
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m     to the mock Kinesis stream. Production's device-gateway
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m     Lambda emits records in the same shape via put_record on the
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m     real stream."""
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m     payload = {
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m         "patient_id":        patient_id,
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m         "parameter":         parameter,
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m         "value":             round(float(value), 2),
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m         "unit":              unit,
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m         "measured_ts":       ts.isoformat(),
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m         "acuity_tier":       acuity_tier,
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m         "unit_id":           unit_id,
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m         "device_id":         f"monitor-{patient_id}",
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m         "ingest_ts":         ts.isoformat(),
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m         "device_quality":    "ok",
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m     stream.put_record(
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m         Data=json.dumps(payload),
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m         PartitionKey=patient_id)
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m def generate_synthetic_vital_stream(stream,
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m                                     minutes=SYNTHETIC_STREAM_MINUTES,
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m                                     seed=SYNTHETIC_RANDOM_SEED,
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m                                     now_dt=None):
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m     """Generate a synthetic two-hour vital-sign stream.
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m     Production reads from a Kinesis stream populated by the
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m     device gateway. The demo synthesizes four illustrative
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m     deterioration patterns so you can see the pipeline detect
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m     what it should and ignore what it should:
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m       patient-SEPSIS-A   - Slowly rising HR and RR with falling
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m                            SBP and rising temp; classic sepsis-
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m                            like deterioration. Should surface.
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m       patient-COPD-B     - Falling SpO2 over 90 minutes with
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m                            rising RR. Should surface.
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m       patient-RECOV-C    - Stable post-op recovery; mild
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m                            variation but no concerning trend.
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m                            Should not surface.
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m       patient-ARTIFACT-D - Pulse-oximeter sensor dropout
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m                            (intermittent SpO2 = 0 or NaN-like
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m                            values). Should be filtered as
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m                            artifact and never page.
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m     rng = random.Random(seed)
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m     if now_dt is None:
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m         now_dt = datetime.now(timezone.utc).replace(
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m             tzinfo=None,
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m             second=0,
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m             microsecond=0)
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m     start = now_dt - timedelta(minutes=minutes)
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m     samples = list(range(minutes))   # one sample per minute
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m     # --- patient-SEPSIS-A: progressive deterioration ---
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m     # HR climbs from 88 to 132, RR from 18 to 28, SBP drops from
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m     # 122 to 92, temp climbs from 37.1 to 39.0. Most parameters
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m     # are individually within the alarm bands at the start and
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m     # progressively cross over.
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m     for i in samples:
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m         ts = start + timedelta(minutes=i)
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m         hr = 88 + 0.30 * i + rng.gauss(0, 2.0)
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m         rr = 18 + 0.07 * i + rng.gauss(0, 0.6)
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m         sbp = 122 - 0.18 * i + rng.gauss(0, 3.0)
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m         spo2 = 96 + rng.gauss(0, 0.6)
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m         temp = 37.1 + 0.012 * i + rng.gauss(0, 0.05)
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m         _emit_record(stream, "patient-SEPSIS-A", "heart_rate",
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m                      hr, "bpm", ts, "med_surg", "5W")
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m         _emit_record(stream, "patient-SEPSIS-A", "respiratory_rate",
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m                      rr, "breaths/min", ts, "med_surg", "5W")
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m         _emit_record(stream, "patient-SEPSIS-A", "systolic_bp",
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m                      sbp, "mmHg", ts, "med_surg", "5W")
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m         _emit_record(stream, "patient-SEPSIS-A", "spo2",
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m                      spo2, "%", ts, "med_surg", "5W")
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m         _emit_record(stream, "patient-SEPSIS-A", "temperature_c",
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m                      temp, "C", ts, "med_surg", "5W")
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m     # --- patient-COPD-B: falling SpO2 ---
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m     # Stable HR around 84, RR climbs from 20 to 28, SpO2 drops
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m     # from 95 to 87 over 90 minutes, SBP and temp stable.
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m     for i in samples:
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m         ts = start + timedelta(minutes=i)
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m         hr = 84 + rng.gauss(0, 1.6)
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m         if i < 60:
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m             rr = 20 + rng.gauss(0, 0.5)
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m             rr = 20 + 0.10 * (i - 60) + rng.gauss(0, 0.7)
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m         if i < 60:
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m             spo2 = 95 + rng.gauss(0, 0.4)
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m             spo2 = 95 - 0.07 * (i - 60) + rng.gauss(0, 0.4)
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m         sbp = 130 + rng.gauss(0, 3.0)
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m         temp = 37.0 + rng.gauss(0, 0.05)
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m         _emit_record(stream, "patient-COPD-B", "heart_rate",
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m                      hr, "bpm", ts, "telemetry", "6E")
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m         _emit_record(stream, "patient-COPD-B", "respiratory_rate",
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m                      rr, "breaths/min", ts, "telemetry", "6E")
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m         _emit_record(stream, "patient-COPD-B", "spo2",
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m                      spo2, "%", ts, "telemetry", "6E")
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m         _emit_record(stream, "patient-COPD-B", "systolic_bp",
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m                      sbp, "mmHg", ts, "telemetry", "6E")
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m         _emit_record(stream, "patient-COPD-B", "temperature_c",
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m                      temp, "C", ts, "telemetry", "6E")
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m     # --- patient-RECOV-C: stable post-op recovery ---
