[0m[49m[38;5;10m+     979[0m:[38;5;10m[49m             "patient_id":    self.patient_id,
[0m[49m[38;5;10m+     980[0m:[38;5;10m[49m             "alert_state":   self.alert_state,
[0m[49m[38;5;10m+     981[0m:[38;5;10m[49m             "last_score":    _to_decimal(self.last_score),
[0m[49m[38;5;10m+     982[0m:[38;5;10m[49m             "last_update":   (self.last_update_dt.isoformat()
[0m[49m[38;5;10m+     983[0m:[38;5;10m[49m                               if self.last_update_dt else None),
