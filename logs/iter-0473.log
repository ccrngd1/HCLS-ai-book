[0m[49m[38;5;10m+    741[0m:[38;5;10m[49m     Returns (converted_value, canonical_unit) on success, or
[0m[49m[38;5;10m+    742[0m:[38;5;10m[49m     (None, None) if the conversion is unsupported.
[0m[49m[38;5;10m+    743[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    744[0m:[38;5;10m[49m     catalog = VITAL_CATALOG[parameter]
[0m[49m[38;5;10m+    745[0m:[38;5;10m[49m     canonical = catalog["canonical_unit"]
[0m[49m[38;5;10m+    746[0m:[38;5;10m[49m     if unit == canonical:
[0m[49m[38;5;10m+    747[0m:[38;5;10m[49m         return float(value), canonical
[0m[49m[38;5;10m+    748[0m:[38;5;10m[49m     if parameter == "temperature_c":
[0m[49m[38;5;10m+    749[0m:[38;5;10m[49m         if unit == "F":
[0m[49m[38;5;10m+    750[0m:[38;5;10m[49m             return (float(value) - 32.0) * 5.0 / 9.0, canonical
[0m[49m[38;5;10m+    751[0m:[38;5;10m[49m     if parameter == "systolic_bp":
