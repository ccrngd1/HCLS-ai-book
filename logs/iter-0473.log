[0m[49m[38;5;10m+    1664[0m:[38;5;10m[49m     event_bus   = MockEventBus(VITAL_EVENT_BUS_NAME)
[0m[49m[38;5;10m+    1665[0m:[38;5;10m[49m     cloudwatch  = MockCloudWatch()
