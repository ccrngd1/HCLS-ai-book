[0m[49m[38;5;10m+    1001[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1002[0m:[38;5;10m[49m def _interquartile_mean(values):
[0m[49m[38;5;10m+    1003[0m:[38;5;10m[49m     """Mean of the values between the 25th and 75th percentile.
[0m[49m[38;5;10m+    1004[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1005[0m:[38;5;10m[49m     A robust central-tendency statistic that resists outliers.
[0m[49m[38;5;10m+    1006[0m:[38;5;10m[49m     Production uses scipy.stats.trim_mean(values, 0.25); the
[0m[49m[38;5;10m+    1007[0m:[38;5;10m[49m     demo computes it from primitives so the math is visible.
[0m[49m[38;5;10m+    1008[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1009[0m:[38;5;10m[49m     if not values:
[0m[49m[38;5;10m+    1010[0m:[38;5;10m[49m         return 0.0
[0m[49m[38;5;10m+    1011[0m:[38;5;10m[49m     sorted_vals = sorted(values)
[0m[49m[38;5;10m+    1012[0m:[38;5;10m[49m     n = len(sorted_vals)
[0m[49m[38;5;10m+    1013[0m:[38;5;10m[49m     if n < 4:
[0m[49m[38;5;10m+    1014[0m:[38;5;10m[49m         return sum(sorted_vals) / n
[0m[49m[38;5;10m+    1015[0m:[38;5;10m[49m     lo = int(n * 0.25)
[0m[49m[38;5;10m+    1016[0m:[38;5;10m[49m     hi = int(n * 0.75)
[0m[49m[38;5;10m+    1017[0m:[38;5;10m[49m     if hi <= lo:
[0m[49m[38;5;10m+    1018[0m:[38;5;10m[49m         return sorted_vals[lo]
[0m[49m[38;5;10m+    1019[0m:[38;5;10m[49m     trimmed = sorted_vals[lo:hi]
[0m[49m[38;5;10m+    1020[0m:[38;5;10m[49m     return (sum(trimmed) / len(trimmed)
[0m[49m[38;5;10m+    1021[0m:[38;5;10m[49m             if trimmed else sum(sorted_vals) / n)
[0m[49m[38;5;10m+    1022[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1023[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1024[0m:[38;5;10m[49m def _median_absolute_deviation(values):
[0m[49m[38;5;10m+    1025[0m:[38;5;10m[49m     """Robust dispersion measure: median of |x - median(x)|.
[0m[49m[38;5;10m+    1026[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1027[0m:[38;5;10m[49m     More resistant to outliers than standard deviation.
[0m[49m[38;5;10m+    1028[0m:[38;5;10m[49m     Production uses scipy.stats.median_abs_deviation.
[0m[49m[38;5;10m+    1029[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1030[0m:[38;5;10m[49m     if not values:
[0m[49m[38;5;10m+    1031[0m:[38;5;10m[49m         return 0.0
[0m[49m[38;5;10m+    1032[0m:[38;5;10m[49m     m = median(values)
[0m[49m[38;5;10m+    1033[0m:[38;5;10m[49m     return max(median([abs(v - m) for v in values]), 0.5)
[0m[49m[38;5;10m+    1034[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1035[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1036[0m:[38;5;10m[49m def update_patient_state(state, cleaned_record, verdict,
[0m[49m[38;5;10m+    1037[0m:[38;5;10m[49m                          window_minutes=DEFAULT_BASELINE_WINDOW_MINUTES,
[0m[49m[38;5;10m+    1038[0m:[38;5;10m[49m                          min_samples=DEFAULT_BASELINE_MIN_SAMPLES):
[0m[49m[38;5;10m+    1039[0m:[38;5;10m[49m     """Step 3: Append the new sample and recompute the baseline.
[0m[49m[38;5;10m+    1040[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1041[0m:[38;5;10m[49m     See pseudocode Step 3 in the main recipe. Returns the updated
[0m[49m[38;5;10m+    1042[0m:[38;5;10m[49m     state. Suspicious values are kept in the recent window (the
[0m[49m[38;5;10m+    1043[0m:[38;5;10m[49m     slope detector wants to see them) but excluded from the
[0m[49m[38;5;10m+    1044[0m:[38;5;10m[49m     baseline update. Hard-artifact and device-artifact values
[0m[49m[38;5;10m+    1045[0m:[38;5;10m[49m     are excluded from both.
[0m[49m[38;5;10m+    1046[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1047[0m:[38;5;10m[49m     param   = cleaned_record["parameter"]
[0m[49m[38;5;10m+    1048[0m:[38;5;10m[49m     value   = float(cleaned_record["value"])
[0m[49m[38;5;10m+    1049[0m:[38;5;10m[49m     eff_dt  = _parse_iso(cleaned_record["measured_ts"])
[0m[49m[38;5;10m+    1050[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1051[0m:[38;5;10m[49m     state.last_verdict[param]   = verdict
[0m[49m[38;5;10m+    1052[0m:[38;5;10m[49m     state.last_update_dt        = eff_dt
[0m[49m[38;5;10m+    1053[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1054[0m:[38;5;10m[49m     # 3a. Append to recent window. Trim entries older than the
[0m[49m[38;5;10m+    1055[0m:[38;5;10m[49m     # baseline window so the deque stays bounded. The recent
[0m[49m[38;5;10m+    1056[0m:[38;5;10m[49m     # window is shared between the baseline computation and the
[0m[49m[38;5;10m+    1057[0m:[38;5;10m[49m     # slope detector; both are downstream consumers.
[0m[49m[38;5;10m+    1058[0m:[38;5;10m[49m     if verdict in ("clean", "suspicious"):
[0m[49m[38;5;10m+    1059[0m:[38;5;10m[49m         state.recent[param].append((eff_dt, value))
[0m[49m[38;5;10m+    1060[0m:[38;5;10m[49m     cutoff = eff_dt - timedelta(minutes=window_minutes)
[0m[49m[38;5;10m+    1061[0m:[38;5;10m[49m     while (state.recent[param]
[0m[49m[38;5;10m+    1062[0m:[38;5;10m[49m            and state.recent[param][0][0] < cutoff):
[0m[49m[38;5;10m+    1063[0m:[38;5;10m[49m         state.recent[param].popleft()
[0m[49m[38;5;10m+    1064[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1065[0m:[38;5;10m[49m     # 3b. Recompute the baseline for this parameter using only
[0m[49m[38;5;10m+    1066[0m:[38;5;10m[49m     # clean values from the last <window_minutes> minutes. The
[0m[49m[38;5;10m+    1067[0m:[38;5;10m[49m     # baseline is persistent per parameter so the artifact
[0m[49m[38;5;10m+    1068[0m:[38;5;10m[49m     # filter and the score composer can read it on the next
[0m[49m[38;5;10m+    1069[0m:[38;5;10m[49m     # record without having to recompute.
[0m[49m[38;5;10m+    1070[0m:[38;5;10m[49m     clean_values = [
[0m[49m[38;5;10m+    1071[0m:[38;5;10m[49m         v for (dt, v) in state.recent[param]
[0m[49m[38;5;10m+    1072[0m:[38;5;10m[49m         if state.last_verdict.get(param) != "artifact_hard"
[0m[49m[38;5;10m+    1073[0m:[38;5;10m[49m         and state.last_verdict.get(param) != "artifact_device"
[0m[49m[38;5;10m+    1074[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    1075[0m:[38;5;10m[49m     # Exclude the most recent suspicious entry from the baseline
[0m[49m[38;5;10m+    1076[0m:[38;5;10m[49m     # body but keep it on the recent window. Production tracks a
[0m[49m[38;5;10m+    1077[0m:[38;5;10m[49m     # per-sample verdict; the demo's simplification approximates
[0m[49m[38;5;10m+    1078[0m:[38;5;10m[49m     # by checking the parameter-level last verdict.
[0m[49m[38;5;10m+    1079[0m:[38;5;10m[49m     if verdict == "suspicious" and clean_values:
[0m[49m[38;5;10m+    1080[0m:[38;5;10m[49m         clean_values = clean_values[:-1]
[0m[49m[38;5;10m+    1081[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1082[0m:[38;5;10m[49m     if len(clean_values) < min_samples:
[0m[49m[38;5;10m+    1083[0m:[38;5;10m[49m         state.baselines[param] = {
[0m[49m[38;5;10m+    1084[0m:[38;5;10m[49m             "status":              "insufficient_history",
[0m[49m[38;5;10m+    1085[0m:[38;5;10m[49m             "sample_count":        len(clean_values),
[0m[49m[38;5;10m+    1086[0m:[38;5;10m[49m             "updated_ts":          eff_dt.isoformat(),
[0m[49m[38;5;10m+    1087[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1088[0m:[38;5;10m[49m         return state
[0m[49m[38;5;10m+    1089[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1090[0m:[38;5;10m[49m     state.baselines[param] = {
[0m[49m[38;5;10m+    1091[0m:[38;5;10m[49m         "status":               "ready",
[0m[49m[38;5;10m+    1092[0m:[38;5;10m[49m         "baseline_value":       round(_interquartile_mean(clean_values), 3),
[0m[49m[38;5;10m+    1093[0m:[38;5;10m[49m         "baseline_dispersion":  round(
[0m[49m[38;5;10m+    1094[0m:[38;5;10m[49m             _median_absolute_deviation(clean_values), 3),
[0m[49m[38;5;10m+    1095[0m:[38;5;10m[49m         "sample_count":         len(clean_values),
[0m[49m[38;5;10m+    1096[0m:[38;5;10m[49m         "updated_ts":           eff_dt.isoformat(),
[0m[49m[38;5;10m+    1097[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1098[0m:[38;5;10m[49m     return state
[0m[49m[38;5;10m+    1099[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    1100[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1101[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    1102[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1103[0m:[38;5;10m[49m ## Step 4: Compose the Composite Score and Detect Trajectories
[0m[49m[38;5;10m+    1104[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1105[0m:[38;5;10m[49m This is where the per-record decision happens. The composite scorer is a NEWS2-shaped point sum (illustrative; production uses the validated NEWS2, MEWS, or institution-specific composite). The trajectory slope detector compares the most recent sub-window to the longer baseline; a sub-window slope steeper than the per-parameter threshold is the early-warning signal that catches deterioration before any single value crosses an alarm band.
[0m[49m[38;5;10m+    1106[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1107[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    1108[0m:[38;5;10m[49m def _band_points(parameter, value):
[0m[49m[38;5;10m+    1109[0m:[38;5;10m[49m     """Look up the NEWS2-shaped points for a single value."""
[0m[49m[38;5;10m+    1110[0m:[38;5;10m[49m     catalog = VITAL_CATALOG[parameter]
[0m[49m[38;5;10m+    1111[0m:[38;5;10m[49m     for lower, upper, points in catalog["score_bands"]:
[0m[49m[38;5;10m+    1112[0m:[38;5;10m[49m         if lower <= value < upper:
[0m[49m[38;5;10m+    1113[0m:[38;5;10m[49m             return points
[0m[49m[38;5;10m+    1114[0m:[38;5;10m[49m     return 0
[0m[49m[38;5;10m+    1115[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1116[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1117[0m:[38;5;10m[49m class EarlyWarningScorer:
[0m[49m[38;5;10m+    1118[0m:[38;5;10m[49m     """Pedagogical NEWS2-shaped composite scorer.
[0m[49m[38;5;10m+    1119[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1120[0m:[38;5;10m[49m     Production replaces this with the validated NEWS2 calculator
[0m[49m[38;5;10m+    1121[0m:[38;5;10m[49m     (see Royal College of Physicians' specification) or with the
[0m[49m[38;5;10m+    1122[0m:[38;5;10m[49m     institution's calibrated MEWS / acuity-tier-aware composite.
[0m[49m[38;5;10m+    1123[0m:[38;5;10m[49m     The interface (state -> integer score) is what matters for
[0m[49m[38;5;10m+    1124[0m:[38;5;10m[49m     the routing logic.
[0m[49m[38;5;10m+    1125[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1126[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1127[0m:[38;5;10m[49m     name = "news2_shaped"
[0m[49m[38;5;10m+    1128[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1129[0m:[38;5;10m[49m     def score(self, state):
[0m[49m[38;5;10m+    1130[0m:[38;5;10m[49m         """Return the composite score for the patient's most
[0m[49m[38;5;10m+    1131[0m:[38;5;10m[49m         recent clean values across all monitored parameters."""
[0m[49m[38;5;10m+    1132[0m:[38;5;10m[49m         total = 0
[0m[49m[38;5;10m+    1133[0m:[38;5;10m[49m         contributing = {}
[0m[49m[38;5;10m+    1134[0m:[38;5;10m[49m         for param in VITAL_CATALOG:
[0m[49m[38;5;10m+    1135[0m:[38;5;10m[49m             window = state.recent.get(param)
[0m[49m[38;5;10m+    1136[0m:[38;5;10m[49m             if not window:
[0m[49m[38;5;10m+    1137[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    1138[0m:[38;5;10m[49m             # Use the most recent value as the "current" reading
[0m[49m[38;5;10m+    1139[0m:[38;5;10m[49m             # for the score. Production may use a short median
[0m[49m[38;5;10m+    1140[0m:[38;5;10m[49m             # over the last few samples to dampen single-sample
[0m[49m[38;5;10m+    1141[0m:[38;5;10m[49m             # noise without dampening real deteriorations.
[0m[49m[38;5;10m+    1142[0m:[38;5;10m[49m             _, value = window[-1]
[0m[49m[38;5;10m+    1143[0m:[38;5;10m[49m             points = _band_points(param, value)
[0m[49m[38;5;10m+    1144[0m:[38;5;10m[49m             total += points
[0m[49m[38;5;10m+    1145[0m:[38;5;10m[49m             contributing[param] = {"value": value, "points": points}
[0m[49m[38;5;10m+    1146[0m:[38;5;10m[49m         return total, contributing
[0m[49m[38;5;10m+    1147[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1148[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1149[0m:[38;5;10m[49m EARLY_WARNING_SCORER = EarlyWarningScorer()
[0m[49m[38;5;10m+    1150[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1151[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1152[0m:[38;5;10m[49m class TrajectorySlopeDetector:
[0m[49m[38;5;10m+    1153[0m:[38;5;10m[49m     """Pedagogical slope detector across the recent window.
[0m[49m[38;5;10m+    1154[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1155[0m:[38;5;10m[49m     Computes the linear-regression slope over the trajectory
[0m[49m[38;5;10m+    1156[0m:[38;5;10m[49m     window for each parameter, scaled to per-hour for clinician
[0m[49m[38;5;10m+    1157[0m:[38;5;10m[49m     readability. Slopes that exceed the per-parameter threshold
[0m[49m[38;5;10m+    1158[0m:[38;5;10m[49m     in the concerning direction are returned as alarms.
[0m[49m[38;5;10m+    1159[0m:[38;5;10m[49m     Production replaces this with scipy.stats.linregress or with
[0m[49m[38;5;10m+    1160[0m:[38;5;10m[49m     a learned attention-based deterioration model.
[0m[49m[38;5;10m+    1161[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1162[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1163[0m:[38;5;10m[49m     name = "linear_slope"
[0m[49m[38;5;10m+    1164[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1165[0m:[38;5;10m[49m     def detect(self, state, now_dt,
[0m[49m[38;5;10m+    1166[0m:[38;5;10m[49m                window_minutes=DEFAULT_TRAJECTORY_WINDOW_MINUTES,
[0m[49m[38;5;10m+    1167[0m:[38;5;10m[49m                min_samples=DEFAULT_TRAJECTORY_MIN_SAMPLES):
[0m[49m[38;5;10m+    1168[0m:[38;5;10m[49m         """Return a list of slope alarms.
[0m[49m[38;5;10m+    1169[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1170[0m:[38;5;10m[49m         Each alarm is a dict with parameter, slope_per_hour,
[0m[49m[38;5;10m+    1171[0m:[38;5;10m[49m         deviation_from_baseline, persistence_minutes, and the
[0m[49m[38;5;10m+    1172[0m:[38;5;10m[49m         detector diagnostics. Empty list when nothing concerning
[0m[49m[38;5;10m+    1173[0m:[38;5;10m[49m         is happening, which is the common case.
[0m[49m[38;5;10m+    1174[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+    1175[0m:[38;5;10m[49m         alarms = []
[0m[49m[38;5;10m+    1176[0m:[38;5;10m[49m         cutoff = now_dt - timedelta(minutes=window_minutes)
[0m[49m[38;5;10m+    1177[0m:[38;5;10m[49m         for param, catalog in VITAL_CATALOG.items():
[0m[49m[38;5;10m+    1178[0m:[38;5;10m[49m             window = [
[0m[49m[38;5;10m+    1179[0m:[38;5;10m[49m                 (dt, v) for (dt, v) in state.recent.get(param, [])
[0m[49m[38;5;10m+    1180[0m:[38;5;10m[49m                 if dt >= cutoff]
[0m[49m[38;5;10m+    1181[0m:[38;5;10m[49m             if len(window) < min_samples:
[0m[49m[38;5;10m+    1182[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    1183[0m:[38;5;10m[49m             # Linear regression in primitives. Production swaps
[0m[49m[38;5;10m+    1184[0m:[38;5;10m[49m             # this for scipy.stats.linregress for the per-window
[0m[49m[38;5;10m+    1185[0m:[38;5;10m[49m             # standard error and the proper t-test on the slope.
[0m[49m[38;5;10m+    1186[0m:[38;5;10m[49m             xs = [(dt - window[0][0]).total_seconds() / 60.0
[0m[49m[38;5;10m+    1187[0m:[38;5;10m[49m                   for (dt, _) in window]
[0m[49m[38;5;10m+    1188[0m:[38;5;10m[49m             ys = [v for (_, v) in window]
[0m[49m[38;5;10m+    1189[0m:[38;5;10m[49m             n = len(xs)
[0m[49m[38;5;10m+    1190[0m:[38;5;10m[49m             mean_x = sum(xs) / n
[0m[49m[38;5;10m+    1191[0m:[38;5;10m[49m             mean_y = sum(ys) / n
[0m[49m[38;5;10m+    1192[0m:[38;5;10m[49m             num = sum((xs[i] - mean_x) * (ys[i] - mean_y)
[0m[49m[38;5;10m+    1193[0m:[38;5;10m[49m                       for i in range(n))
[0m[49m[38;5;10m+    1194[0m:[38;5;10m[49m             den = sum((xs[i] - mean_x) ** 2 for i in range(n))
[0m[49m[38;5;10m+    1195[0m:[38;5;10m[49m             if den == 0:
