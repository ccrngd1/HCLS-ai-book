[0m[49m[38;5;10m+    1688[0m:[38;5;10m[49m     for patient_id, state in patient_states.items():
[0m[49m[38;5;10m+    1689[0m:[38;5;10m[49m         state_table.put_item(Item=state.to_dynamodb_item())
