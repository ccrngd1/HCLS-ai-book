[0m[49m[38;5;10m+    1695[0m:[38;5;10m[49m             f" (n={b.get('sample_count', '?')})"
[0m[49m[38;5;10m+    1696[0m:[38;5;10m[49m             for p, b in state.baselines.items())
[0m[49m[38;5;10m+    1697[0m:[38;5;10m[49m         last_paged = sorted(state.last_paged_at.items())
[0m[49m[38;5;10m+    1698[0m:[38;5;10m[49m         print(f"  {patient_id:>22} alert_state={state.alert_state} "
[0m[49m[38;5;10m+    1699[0m:[38;5;10m[49m               f"score={state.last_score} "
[0m[49m[38;5;10m+    1700[0m:[38;5;10m[49m               f"paged_tiers={[t for t, _ in last_paged]}")
[0m[49m[38;5;10m+    1701[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1702[0m:[38;5;10m[49m     print("\n=== Surfaced alerts ===")
[0m[49m[38;5;10m+    1703[0m:[38;5;10m[49m     for (_, _), item in alert_table.items.items():
[0m[49m[38;5;10m+    1704[0m:[38;5;10m[49m         print(f"  {item['patient_id']:>22} "
[0m[49m[38;5;10m+    1705[0m:[38;5;10m[49m               f"tier={item['tier_label']:>14} "
[0m[49m[38;5;10m+    1706[0m:[38;5;10m[49m               f"score={item['composite_score']} "
[0m[49m[38;5;10m+    1707[0m:[38;5;10m[49m               f"target={item['route_target']:>14} "
[0m[49m[38;5;10m+    1708[0m:[38;5;10m[49m               f"at={item['generated_at']}")
[0m[49m[38;5;10m+    1709[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1710[0m:[38;5;10m[49m     print("\n=== SNS pages emitted ===")
[0m[49m[38;5;10m+    1711[0m:[38;5;10m[49m     for tier, topic in sns_topics.items():
[0m[49m[38;5;10m+    1712[0m:[38;5;10m[49m         print(f"  topic={tier}: {len(topic.messages)} message(s)")
[0m[49m[38;5;10m+    1713[0m:[38;5;10m[49m         for msg in topic.messages[:3]:
[0m[49m[38;5;10m+    1714[0m:[38;5;10m[49m             print(f"    [{msg['Subject']}] {msg['Message'][:120]}...")
[0m[49m[38;5;10m+    1715[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1716[0m:[38;5;10m[49m     print("\n=== EventBridge lifecycle events ===")
[0m[49m[38;5;10m+    1717[0m:[38;5;10m[49m     print(f"  total events: {len(event_bus.events)}")
[0m[49m[38;5;10m+    1718[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1719[0m:[38;5;10m[49m     print("\n=== CloudWatch metrics ===")
[0m[49m[38;5;10m+    1720[0m:[38;5;10m[49m     for name, samples in sorted(cloudwatch.metrics.items()):
[0m[49m[38;5;10m+    1721[0m:[38;5;10m[49m         print(f"  {name}: {len(samples)} samples")
[0m[49m[38;5;10m+    1722[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1723[0m:[38;5;10m[49m     print("\n=== Suppressed-alert log preview ===")
[0m[49m[38;5;10m+    1724[0m:[38;5;10m[49m     suppressed_keys = [k for (b, k) in s3.objects
[0m[49m[38;5;10m+    1725[0m:[38;5;10m[49m                        if b == SUPPRESSED_ALERT_BUCKET][:5]
[0m[49m[38;5;10m+    1726[0m:[38;5;10m[49m     for key in suppressed_keys:
