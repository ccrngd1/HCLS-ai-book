[0m[49m[39m  475, 485[0m:[39m[49m     "trend": -8.5,
[0m[49m[39m  476, 486[0m:[39m[49m     "insulin_on_board": 4.0,
[0m[49m[39m  477, 487[0m:[39m[49m     "constraints_active": []
