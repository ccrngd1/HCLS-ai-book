[0m[49m[39m  157, 165[0m:[39m[49m ### Ingredients
[0m[49m[39m  158, 166[0m:[39m[49m 
[0m[49m[39m  159, 167[0m:[39m[49m | AWS Service | Role |
[0m[49m[39m  160, 168[0m:[39m[49m |------------|------|
[0m[49m[39m  161, 169[0m:[39m[49m | **Amazon SageMaker** | Trains offline RL policy, hosts inference endpoint, manages model versions |
[0m[49m[39m  162, 170[0m:[39m[49m | **Amazon S3** | Stores training episodes, model artifacts, evaluation results |
[0m[49m[39m  163, 171[0m:[39m[49m | **AWS Lambda** | Constructs patient state, orchestrates inference, applies safety constraints |
[0m[49m[39m  164, 172[0m:[39m[49m | **Amazon DynamoDB** | Tracks per-patient state history for real-time state construction |
[0m[49m[39m  165, 173[0m:[39m[49m | **AWS Step Functions** | Orchestrates periodic retraining pipeline |
[0m[49m[39m  166, 174[0m:[39m[49m | **Amazon CloudWatch** | Monitors recommendation patterns, outcome tracking, drift detection |
[0m[49m[39m  167, 175[0m:[39m[49m | **AWS KMS** | Manages encryption keys for all PHI-containing services |
[0m[49m[39m  168, 176[0m:[39m[49m 
[0m[49m[39m  169, 177[0m:[39m[49m ### Code
[0m[49m[39m  170, 178[0m:[39m[49m 
[0m[49m[39m  171, 179[0m:[39m[49m #### Walkthrough
[0m[49m[39m  172, 180[0m:[39m[49m 
[0m[49m[38;5;9m- 173     [0m:[38;5;9m[49m **Step 1: Episode construction from EHR data.** The first challenge is transforming raw EHR data into RL episodes. An episode is one ICU stay, discretized into decision intervals (typically 1-4 hours). At each timestep, you need the state (what the clinician observed), the action (what they did), and the reward (how things turned out). This step is where most of the engineering effort lives. EHR data is messy: glucose measurements arrive at irregular intervals, insulin orders don't always align with administration times, and nutrition changes happen asynchronously. You need to bin everything into consistent time windows and handle missing data gracefully. Skip this step or do it poorly, and your RL agent learns from garbage.
[0m[49m[38;5;10m+      181[0m:[38;5;10m[49m **Step 1: Episode construction from EHR data.** The first challenge is transforming raw EHR data into RL episodes. An episode is one ICU stay, discretized into decision intervals (typically 1-4 hours). At each timestep, you need the state (what the clinician observed), the action (what they did), and the reward (how things turned out). This step is where most of the engineering effort lives. EHR data is messy: glucose measurements come from different sources (point-of-care meters, arterial blood gas analyzers, continuous glucose monitors) with different accuracies and different timestamps. Insulin orders don't always align with administration times, and nutrition changes happen asynchronously. You need to bin everything into consistent time windows and handle missing data gracefully. Skip this step or do it poorly, and your RL agent learns from garbage.
[0m[49m[39m  174, 182[0m:[39m[49m 
[0m[49m[39m  175, 183[0m:[39m[49m ```
[0m[49m[39m  176, 184[0m:[39m[49m FUNCTION build_episode(patient_icu_stay):
[0m[49m[39m  177, 185[0m:[39m[49m     // Discretize the ICU stay into fixed-length decision intervals.
[0m[49m[39m  178, 186[0m:[39m[49m     // 4 hours is common: it matches typical glucose check frequency.
[0m[49m[39m  179, 187[0m:[39m[49m     timestep_hours = 4
[0m[49m[39m  180, 188[0m:[39m[49m     episode = empty list
[0m[49m[39m  181, 189[0m:[39m[49m 
[0m[49m[39m  182, 190[0m:[39m[49m     FOR each interval in partition_stay(patient_icu_stay, timestep_hours):
[0m[49m[39m  183, 191[0m:[39m[49m 
[0m[49m[39m  184, 192[0m:[39m[49m         // Construct the state vector: everything the clinician could observe
[0m[49m[39m  185, 193[0m:[39m[49m         // at the start of this interval.
[0m[49m[39m  186, 194[0m:[39m[49m         state = {
[0m[49m[39m  187, 195[0m:[39m[49m             glucose_current:     most recent glucose in this interval (mg/dL),
[0m[49m[39m  188, 196[0m:[39m[49m             glucose_prev_1:      glucose from previous interval,
[0m[49m[39m  189, 197[0m:[39m[49m             glucose_prev_2:      glucose from 2 intervals ago,
[0m[49m[39m  190, 198[0m:[39m[49m             glucose_velocity:    (glucose_current - glucose_prev_1) / timestep_hours,
[0m[49m[39m  191, 199[0m:[39m[49m             insulin_on_board:    total insulin given in last 4 hours (units),
[0m[49m[39m  192, 200[0m:[39m[49m             insulin_infusion:    current insulin drip rate (units/hour) or 0 if subcutaneous,
[0m[49m[39m  193, 201[0m:[39m[49m             nutrition_rate:      current enteral/parenteral nutrition (kcal/hour),
[0m[49m[39m  194, 202[0m:[39m[49m             vasopressor_dose:    norepinephrine equivalent dose (mcg/kg/min),
[0m[49m[39m  195, 203[0m:[39m[49m             steroid_flag:        1 if on corticosteroids (these spike glucose), 0 otherwise,
[0m[49m[39m  196, 204[0m:[39m[49m             creatinine:          most recent value (renal function affects insulin clearance),
[0m[49m[39m  197, 205[0m:[39m[49m             bmi:                 patient BMI (affects insulin sensitivity),
[0m[49m[39m  198, 206[0m:[39m[49m             apache_score:        illness severity score at admission
[0m[49m[39m  199, 207[0m:[39m[49m         }
[0m[49m[39m  200, 208[0m:[39m[49m 
[0m[49m[39m  201, 209[0m:[39m[49m         // The action: what insulin dose was actually given during this interval.
[0m[49m[39m  202, 210[0m:[39m[49m         // Discretize into bins for tabular RL, or keep continuous for actor-critic methods.
[0m[49m[39m  203, 211[0m:[39m[49m         action = total_insulin_given_in_interval(interval)  // units
[0m[49m[39m  204, 212[0m:[39m[49m 
[0m[49m[39m  205, 213[0m:[39m[49m         // The reward: how good was the glucose outcome?
[0m[49m[39m  206, 214[0m:[39m[49m         // Heavily penalize hypoglycemia. Mildly penalize hyperglycemia.
[0m[49m[39m  207, 215[0m:[39m[49m         // Reward time in target range.
[0m[49m[39m  208, 216[0m:[39m[49m         next_glucose = first glucose measurement in next interval
[0m[49m[39m  209, 217[0m:[39m[49m         reward = compute_reward(next_glucose)
[0m[49m[39m  210, 218[0m:[39m[49m 
[0m[49m[39m  211, 219[0m:[39m[49m         append to episode: (state, action, reward)
[0m[49m[39m  212, 220[0m:[39m[49m 
[0m[49m[39m  213, 221[0m:[39m[49m     RETURN episode
[0m[49m[39m  214, 222[0m:[39m[49m ```
[0m[49m[39m  215, 223[0m:[39m[49m 
[0m[49m[39m  216, 224[0m:[39m[49m **Step 2: Reward function design.** This is the most consequential design decision in the entire system. The reward function encodes what "good glucose control" means numerically. Get it wrong and your agent optimizes for the wrong thing. The key insight: hypoglycemia and hyperglycemia are not symmetric risks. A glucose of 60 mg/dL is immediately life-threatening. A glucose of 200 mg/dL is harmful over hours but not acutely dangerous. Your reward function must reflect this asymmetry. Most published work uses a piecewise function with a steep penalty below 70 mg/dL, a mild penalty above 180 mg/dL, and a positive reward in the 80-180 mg/dL range. The exact shape matters enormously and should be calibrated with clinical input.
[0m[49m[39m  217, 225[0m:[39m[49m 
[0m[49m[39m  218, 226[0m:[39m[49m ```
[0m[49m[39m  219, 227[0m:[39m[49m FUNCTION compute_reward(glucose_mg_dl):
[0m[49m[39m  220, 228[0m:[39m[49m     // Asymmetric reward function reflecting clinical risk.
[0m[49m[39m  221, 229[0m:[39m[49m     // Hypoglycemia is immediately dangerous; hyperglycemia is gradually harmful.
[0m[49m[39m  222, 230[0m:[39m[49m 
[0m[49m[39m  223, 231[0m:[39m[49m     IF glucose_mg_dl < 40:
[0m[49m[39m  224, 232[0m:[39m[49m         // Severe hypoglycemia. Seizures, brain damage, death.
[0m[49m[39m  225, 233[0m:[39m[49m         // Maximum penalty. This should almost never happen.
[0m[49m[39m  226, 234[0m:[39m[49m         RETURN -100
[0m[49m[39m  227, 235[0m:[39m[49m 
[0m[49m[39m  228, 236[0m:[39m[49m     ELSE IF glucose_mg_dl < 70:
[0m[49m[39m  229, 237[0m:[39m[49m         // Hypoglycemia. Dangerous. Requires immediate intervention.
[0m[49m[39m  230, 238[0m:[39m[49m         // Steep penalty proportional to severity.
[0m[49m[39m  231, 239[0m:[39m[49m         RETURN -50 * (70 - glucose_mg_dl) / 30
[0m[49m[39m  232, 240[0m:[39m[49m 
[0m[49m[39m  233, 241[0m:[39m[49m     ELSE IF glucose_mg_dl < 80:
[0m[49m[39m  234, 242[0m:[39m[49m         // Below target but not hypoglycemic. Mild concern.
[0m[49m[39m  235, 243[0m:[39m[49m         RETURN -5
[0m[49m[39m  236, 244[0m:[39m[49m 
[0m[49m[39m  237, 245[0m:[39m[49m     ELSE IF glucose_mg_dl >= 80 AND glucose_mg_dl <= 180:
[0m[49m[39m  238, 246[0m:[39m[49m         // Target range. Reward proportional to how centered the value is.
[0m[49m[39m  239, 247[0m:[39m[49m         // Peak reward at 120-140 mg/dL (the "sweet spot").
[0m[49m[39m  240, 248[0m:[39m[49m         center = 130
[0m[49m[39m  241, 249[0m:[39m[49m         distance_from_center = abs(glucose_mg_dl - center)
[0m[49m[39m  242, 250[0m:[39m[49m         RETURN 10 - (distance_from_center / 50) * 5
[0m[49m[39m  243, 251[0m:[39m[49m 
[0m[49m[39m  244, 252[0m:[39m[49m     ELSE IF glucose_mg_dl <= 250:
[0m[49m[39m  245, 253[0m:[39m[49m         // Mild hyperglycemia. Harmful over time but not acutely dangerous.
[0m[49m[39m  246, 254[0m:[39m[49m         RETURN -2 * (glucose_mg_dl - 180) / 70
[0m[49m[39m  247, 255[0m:[39m[49m 
[0m[49m[39m  248, 256[0m:[39m[49m     ELSE:
[0m[49m[39m  249, 257[0m:[39m[49m         // Severe hyperglycemia. Osmotic complications, DKA risk.
[0m[49m[39m  250, 258[0m:[39m[49m         RETURN -10 - (glucose_mg_dl - 250) / 50
[0m[49m[39m  251, 259[0m:[39m[49m ```
[0m[49m[39m  252, 260[0m:[39m[49m 
[0m[49m[39m  253, 261[0m:[39m[49m **Step 3: Offline RL training with safety constraints.** Standard RL algorithms (DQN, PPO) assume online interaction with the environment. We can't do that. We need offline RL: learning a policy purely from historical data without additional environment interaction. The key challenge is distributional shift. If the historical clinicians never gave 20 units of insulin to a patient with glucose of 150, your agent has no data to evaluate that action. Naive offline RL might still recommend it if the Q-function extrapolates incorrectly. Conservative Q-Learning (CQL) addresses this by adding a penalty for actions that are far from the historical data distribution. Batch Constrained Q-Learning (BCQ) restricts the policy to only recommend actions that were actually observed in similar states. Either approach prevents the dangerous extrapolation problem.
[0m[49m[39m  254, 262[0m:[39m[49m 
[0m[49m[39m  255, 263[0m:[39m[49m ```
[0m[49m[39m  256, 264[0m:[39m[49m FUNCTION train_offline_rl_policy(episodes, safety_constraints):
[0m[49m[39m  257, 265[0m:[39m[49m     // Use Conservative Q-Learning (CQL) to learn a policy
[0m[49m[39m  258, 266[0m:[39m[49m     // that stays close to the historical data distribution.
[0m[49m[39m  259, 267[0m:[39m[49m 
[0m[49m[39m  260, 268[0m:[39m[49m     // Initialize Q-network (maps state-action pairs to expected cumulative reward)
[0m[49m[39m  261, 269[0m:[39m[49m     Q_network = initialize_neural_network(
[0m[49m[39m  262, 270[0m:[39m[49m         input_size  = state_dimension + action_dimension,
[0m[49m[39m  263, 271[0m:[39m[49m         hidden_layers = [256, 256, 128],
[0m[49m[39m  264, 272[0m:[39m[49m         output_size = 1
[0m[49m[39m  265, 273[0m:[39m[49m     )
[0m[49m[39m  266, 274[0m:[39m[49m 
[0m[49m[39m  267, 275[0m:[39m[49m     // Initialize policy network (maps states to action distributions)
[0m[49m[39m  268, 276[0m:[39m[49m     policy_network = initialize_neural_network(
[0m[49m[39m  269, 277[0m:[39m[49m         input_size  = state_dimension,
[0m[49m[39m  270, 278[0m:[39m[49m         hidden_layers = [256, 256],
[0m[49m[39m  271, 279[0m:[39m[49m         output_size = action_dimension  // continuous: mean and std of dose
[0m[49m[39m  272, 280[0m:[39m[49m     )
[0m[49m[39m  273, 281[0m:[39m[49m 
[0m[49m[39m  274, 282[0m:[39m[49m     FOR each training_iteration in range(num_iterations):
[0m[49m[39m  275, 283[0m:[39m[49m 
[0m[49m[39m  276, 284[0m:[39m[49m         // Sample a batch of transitions from the historical episodes
[0m[49m[39m  277, 285[0m:[39m[49m         batch = sample_random_transitions(episodes, batch_size=256)
[0m[49m[39m  278, 286[0m:[39m[49m 
[0m[49m[39m  279, 287[0m:[39m[49m         // Standard Bellman backup: estimate Q-values for observed transitions
[0m[49m[39m  280, 288[0m:[39m[49m         bellman_loss = compute_bellman_error(Q_network, batch, discount=0.99)
[0m[49m[39m  281, 289[0m:[39m[49m 
[0m[49m[39m  282, 290[0m:[39m[49m         // CQL penalty: push down Q-values for actions NOT in the dataset.
[0m[49m[39m  283, 291[0m:[39m[49m         // This prevents the policy from recommending untested actions.
[0m[49m[39m  284, 292[0m:[39m[49m         // Sample random actions and penalize their Q-values.
[0m[49m[39m  285, 293[0m:[39m[49m         random_actions = sample_uniform_actions(batch_size=256)
[0m[49m[39m  286, 294[0m:[39m[49m         cql_penalty = mean(Q_network(batch.states, random_actions))
[0m[49m[39m  287, 295[0m:[39m[49m                     - mean(Q_network(batch.states, batch.actions))
[0m[49m[39m  288, 296[0m:[39m[49m 
[0m[49m[39m  289, 297[0m:[39m[49m         // Combined loss: standard RL + conservative penalty
[0m[49m[39m  290, 298[0m:[39m[49m         total_loss = bellman_loss + alpha * cql_penalty
[0m[49m[39m  291, 299[0m:[39m[49m         // alpha controls how conservative the policy is.
[0m[49m[39m  292, 300[0m:[39m[49m         // Higher alpha = stays closer to historical behavior.
[0m[49m[39m  293, 301[0m:[39m[49m         // Lower alpha = more willing to deviate (riskier but potentially better).
[0m[49m[39m  294, 302[0m:[39m[49m 
[0m[49m[39m  295, 303[0m:[39m[49m         update Q_network to minimize total_loss
[0m[49m[39m  296, 304[0m:[39m[49m 
[0m[49m[39m  297, 305[0m:[39m[49m         // Update policy to maximize Q-values subject to safety constraints
[0m[49m[39m  298, 306[0m:[39m[49m         policy_loss = -mean(Q_network(batch.states, policy_network(batch.states)))
[0m[49m[39m  299, 307[0m:[39m[49m 
[0m[49m[39m  300, 308[0m:[39m[49m         // Safety constraint: penalize policies that produce hypoglycemia
[0m[49m[39m  301, 309[0m:[39m[49m         // in the training data (using a learned dynamics model or historical outcomes)
[0m[49m[39m  302, 310[0m:[39m[49m         safety_penalty = estimate_hypoglycemia_probability(
[0m[49m[39m  303, 311[0m:[39m[49m             policy_network, batch.states, safety_constraints
[0m[49m[39m  304, 312[0m:[39m[49m         )
[0m[49m[39m  305, 313[0m:[39m[49m 
[0m[49m[39m  306, 314[0m:[39m[49m         update policy_network to minimize (policy_loss + lambda * safety_penalty)
[0m[49m[39m  307, 315[0m:[39m[49m 
[0m[49m[39m  308, 316[0m:[39m[49m     RETURN policy_network
[0m[49m[39m  309, 317[0m:[39m[49m ```
[0m[49m[39m  310, 318[0m:[39m[49m 
[0m[49m[39m  311, 319[0m:[39m[49m **Step 4: Off-policy evaluation.** Before deploying any learned policy, you need to estimate how it would have performed on historical patients. This is off-policy evaluation (OPE). The core idea: if the learned policy would have recommended the same action the clinician took, we can directly use the observed outcome. If it would have recommended a different action, we need to reweight the observation using importance sampling. OPE is imperfect (high variance, relies on overlap between policies), but it's the best tool available for safety validation without live experimentation. Run OPE on a held-out test set of episodes that were not used for training.
[0m[49m[39m  312, 320[0m:[39m[49m 
[0m[49m[39m  313, 321[0m:[39m[49m ```
[0m[49m[39m  314, 322[0m:[39m[49m FUNCTION evaluate_policy_offline(learned_policy, test_episodes, behavior_policy):
[0m[49m[39m  315, 323[0m:[39m[49m     // Weighted Importance Sampling (WIS) estimator for policy value.
[0m[49m[39m  316, 324[0m:[39m[49m     // Estimates what the cumulative reward would have been if the learned
[0m[49m[39m  317, 325[0m:[39m[49m     // policy had been followed instead of the historical clinician policy.
[0m[49m[39m  318, 326[0m:[39m[49m 
[0m[49m[39m  319, 327[0m:[39m[49m     episode_returns = empty list
[0m[49m[39m  320, 328[0m:[39m[49m 
[0m[49m[39m  321, 329[0m:[39m[49m     FOR each episode in test_episodes:
[0m[49m[39m  322, 330[0m:[39m[49m         cumulative_importance_weight = 1.0
[0m[49m[39m  323, 331[0m:[39m[49m         cumulative_reward = 0.0
[0m[49m[39m  324, 332[0m:[39m[49m 
[0m[49m[39m  325, 333[0m:[39m[49m         FOR each (state, action, reward) in episode:
[0m[49m[39m  326, 334[0m:[39m[49m             // How likely is this action under the learned policy?
[0m[49m[39m  327, 335[0m:[39m[49m             pi_prob = learned_policy.probability(action | state)
[0m[49m[39m  328, 336[0m:[39m[49m 
[0m[49m[39m  329, 337[0m:[39m[49m             // How likely was this action under the historical clinician behavior?
[0m[49m[39m  330, 338[0m:[39m[49m             mu_prob = behavior_policy.probability(action | state)
[0m[49m[39m  331, 339[0m:[39m[49m 
[0m[49m[39m  332, 340[0m:[39m[49m             // Importance ratio: reweights this transition
[0m[49m[39m  333, 341[0m:[39m[49m             // If learned policy strongly agrees with clinician: ratio near 1
[0m[49m[39m  334, 342[0m:[39m[49m             // If learned policy disagrees: ratio far from 1 (high variance)
[0m[49m[39m  335, 343[0m:[39m[49m             ratio = pi_prob / mu_prob
[0m[49m[39m  336, 344[0m:[39m[49m 
[0m[49m[39m  337, 345[0m:[39m[49m             // Clip ratio to prevent extreme weights (variance reduction)
[0m[49m[39m  338, 346[0m:[39m[49m             ratio = clip(ratio, 0.01, 100.0)
[0m[49m[39m  339, 347[0m:[39m[49m 
[0m[49m[39m  340, 348[0m:[39m[49m             cumulative_importance_weight = cumulative_importance_weight * ratio
[0m[49m[39m  341, 349[0m:[39m[49m             cumulative_reward = cumulative_reward + (discount ^ timestep) * reward
[0m[49m[39m  342, 350[0m:[39m[49m 
[0m[49m[39m  343, 351[0m:[39m[49m         // Weighted return for this episode
[0m[49m[39m  344, 352[0m:[39m[49m         append cumulative_importance_weight * cumulative_reward to episode_returns
[0m[49m[39m  345, 353[0m:[39m[49m 
[0m[49m[39m  346, 354[0m:[39m[49m     // Normalize by sum of weights (self-normalized importance sampling)
[0m[49m[39m  347, 355[0m:[39m[49m     estimated_policy_value = sum(episode_returns) / sum(weights)
[0m[49m[39m  348, 356[0m:[39m[49m 
[0m[49m[39m  349, 357[0m:[39m[49m     // Also compute per-metric estimates
[0m[49m[39m  350, 358[0m:[39m[49m     estimated_time_in_range = compute_weighted_metric("time_in_range", ...)
[0m[49m[39m  351, 359[0m:[39m[49m     estimated_hypo_rate     = compute_weighted_metric("hypoglycemia_rate", ...)
[0m[49m[39m  352, 360[0m:[39m[49m 
[0m[49m[39m  353, 361[0m:[39m[49m     RETURN {
[0m[49m[39m  354, 362[0m:[39m[49m         policy_value:   estimated_policy_value,
[0m[49m[39m  355, 363[0m:[39m[49m         time_in_range:  estimated_time_in_range,
[0m[49m[39m  356, 364[0m:[39m[49m         hypo_rate:      estimated_hypo_rate,
[0m[49m[39m  357, 365[0m:[39m[49m         confidence_interval: bootstrap_ci(episode_returns, alpha=0.05)
[0m[49m[39m  358, 366[0m:[39m[49m     }
[0m[49m[39m  359, 367[0m:[39m[49m ```
[0m[49m[39m  360, 368[0m:[39m[49m 
[0m[49m[39m  361, 369[0m:[39m[49m **Step 5: Safety constraint layer.** Even after training with safety-aware objectives and validating with OPE, the deployed system needs a hard safety layer. This is the last line of defense: regardless of what the RL policy recommends, certain actions are never allowed. Think of it as a safety envelope around the policy. The policy operates freely within the envelope; anything outside gets clipped or rejected. This layer encodes clinical knowledge that should never be violated, even if the data-driven policy disagrees.
[0m[49m[39m  362, 370[0m:[39m[49m 
[0m[49m[39m  363, 371[0m:[39m[49m ```
[0m[49m[39m  364, 372[0m:[39m[49m FUNCTION apply_safety_constraints(recommended_dose, patient_state, constraints):
[0m[49m[39m  365, 373[0m:[39m[49m     // Hard safety constraints that override the RL policy.
[0m[49m[39m  366, 374[0m:[39m[49m     // These are non-negotiable clinical rules.
[0m[49m[39m  367, 375[0m:[39m[49m 
[0m[49m[39m  368, 376[0m:[39m[49m     safe_dose = recommended_dose
[0m[49m[39m  369, 377[0m:[39m[49m 
[0m[49m[39m  370, 378[0m:[39m[49m     // Constraint 1: Maximum single dose cap.
[0m[49m[39m  371, 379[0m:[39m[49m     // No matter what the policy says, never exceed this.
[0m[49m[39m  372, 380[0m:[39m[49m     // Clinical rationale: prevents catastrophic hypoglycemia from a single error.
[0m[49m[39m  373, 381[0m:[39m[49m     IF safe_dose > constraints.max_single_dose:  // e.g., 20 units
[0m[49m[39m  374, 382[0m:[39m[49m         safe_dose = constraints.max_single_dose
[0m[49m[39m  375, 383[0m:[39m[49m         log_constraint_activation("max_dose_cap", recommended_dose, safe_dose)
[0m[49m[39m  376, 384[0m:[39m[49m 
[0m[49m[39m  377, 385[0m:[39m[49m     // Constraint 2: If glucose is already trending down rapidly, reduce dose.
[0m[49m[39m  378, 386[0m:[39m[49m     // Clinical rationale: insulin already on board will continue lowering glucose.
[0m[49m[39m  379, 387[0m:[39m[49m     IF patient_state.glucose_velocity < constraints.rapid_decline_threshold:  // e.g., -30 mg/dL/hr
[0m[49m[39m  380, 388[0m:[39m[49m         safe_dose = safe_dose * 0.5
[0m[49m[39m  381, 389[0m:[39m[49m         log_constraint_activation("rapid_decline_reduction", recommended_dose, safe_dose)
[0m[49m[39m  382, 390[0m:[39m[49m 
[0m[49m[39m  383, 391[0m:[39m[49m     // Constraint 3: If glucose is near hypoglycemic range, no insulin.
[0m[49m[39m  384, 392[0m:[39m[49m     // Clinical rationale: giving insulin to someone at 85 mg/dL is reckless.
[0m[49m[39m  385, 393[0m:[39m[49m     IF patient_state.glucose_current < constraints.no_insulin_threshold:  // e.g., 100 mg/dL
[0m[49m[39m  386, 394[0m:[39m[49m         safe_dose = 0
[0m[49m[39m  387, 395[0m:[39m[49m         log_constraint_activation("hypo_prevention_hold", recommended_dose, safe_dose)
[0m[49m[39m  388, 396[0m:[39m[49m 
[0m[49m[39m  389, 397[0m:[39m[49m     // Constraint 4: Maximum dose change from previous interval.
[0m[49m[39m  390, 398[0m:[39m[49m     // Clinical rationale: prevents wild swings in dosing.
[0m[49m[39m  391, 399[0m:[39m[49m     max_change = constraints.max_dose_change_per_interval  // e.g., 5 units
[0m[49m[39m  392, 400[0m:[39m[49m     IF abs(safe_dose - patient_state.previous_dose) > max_change:
[0m[49m[39m  393, 401[0m:[39m[49m         safe_dose = patient_state.previous_dose + sign(safe_dose - patient_state.previous_dose) * max_change
[0m[49m[39m  394, 402[0m:[39m[49m         log_constraint_activation("max_change_cap", recommended_dose, safe_dose)
[0m[49m[39m  395, 403[0m:[39m[49m 
[0m[49m[39m  396, 404[0m:[39m[49m     // Constraint 5: If renal function is severely impaired, reduce dose.
[0m[49m[39m  397, 405[0m:[39m[49m     // Clinical rationale: kidneys clear insulin; impaired clearance means longer effect.
[0m[49m[39m  398, 406[0m:[39m[49m     IF patient_state.creatinine > constraints.renal_impairment_threshold:  // e.g., 3.0 mg/dL
[0m[49m[39m  399, 407[0m:[39m[49m         safe_dose = safe_dose * 0.7
[0m[49m[39m  400, 408[0m:[39m[49m         log_constraint_activation("renal_adjustment", recommended_dose, safe_dose)
[0m[49m[39m  401, 409[0m:[39m[49m 
[0m[49m[39m  402, 410[0m:[39m[49m     RETURN {
[0m[49m[39m  403, 411[0m:[39m[49m         final_dose:         safe_dose,
[0m[49m[39m  404, 412[0m:[39m[49m         original_recommendation: recommended_dose,
[0m[49m[39m  405, 413[0m:[39m[49m         constraints_activated: get_activated_constraints(),
[0m[49m[39m  406, 414[0m:[39m[49m         confidence:         compute_recommendation_confidence(patient_state)
[0m[49m[39m  407, 415[0m:[39m[49m     }
[0m[49m[39m  408, 416[0m:[39m[49m ```
[0m[49m[39m  409, 417[0m:[39m[49m 
[0m[49m[39m  410, 418[0m:[39m[49m **Step 6: Clinical decision support interface.** The RL policy is deployed as a recommendation system, not an autonomous controller. The clinician sees the recommendation, the reasoning behind it, and can accept, modify, or override. Every interaction is logged for ongoing evaluation. This is critical: the system learns from clinician overrides (they indicate where the policy disagrees with expert judgment) and the outcomes of both followed and overridden recommendations provide ongoing validation data.
[0m[49m[39m  411, 419[0m:[39m[49m 
[0m[49m[38;5;10m+      420[0m:[38;5;10m[49m <!-- TODO (TechWriter): Expert review S2 (MEDIUM). Add tamper-evident audit trail guidance after the store_recommendation call. Recommendation logs should also be written to S3 with Object Lock (compliance mode) or CloudWatch Logs with a resource policy preventing deletion. The operational store (DynamoDB) serves real-time reads; the immutable archive serves compliance. -->
[0m[49m[38;5;10m+      421[0m:[38;5;10m[49m 
[0m[49m[39m  412, 422[0m:[39m[49m ```
[0m[49m[39m  413, 423[0m:[39m[49m FUNCTION generate_recommendation(patient_id, new_glucose_reading):
[0m[49m[39m  414, 424[0m:[39m[49m     // Called when a new glucose measurement is entered for an ICU patient.
[0m[49m[39m  415, 425[0m:[39m[49m 
[0m[49m[39m  416, 426[0m:[39m[49m     // Fetch the patient's recent history from the state store
[0m[49m[39m  417, 427[0m:[39m[49m     patient_history = fetch_from_dynamodb(table="patient-glucose-state", key=patient_id)
[0m[49m[39m  418, 428[0m:[39m[49m 
[0m[49m[39m  419, 429[0m:[39m[49m     // Update history with new reading
[0m[49m[39m  420, 430[0m:[39m[49m     update_patient_state(patient_history, new_glucose_reading)
[0m[49m[39m  421, 431[0m:[39m[49m 
[0m[49m[39m  422, 432[0m:[39m[49m     // Construct the state vector for the RL policy
[0m[49m[39m  423, 433[0m:[39m[49m     state_vector = build_state_vector(patient_history)
[0m[49m[39m  424, 434[0m:[39m[49m 
[0m[49m[39m  425, 435[0m:[39m[49m     // Get the RL policy's recommendation
[0m[49m[39m  426, 436[0m:[39m[49m     raw_recommendation = invoke_sagemaker_endpoint(
[0m[49m[39m  427, 437[0m:[39m[49m         endpoint = "glucose-rl-policy-v2",
[0m[49m[39m  428, 438[0m:[39m[49m         payload  = state_vector
[0m[49m[39m  429, 439[0m:[39m[49m     )
[0m[49m[39m  430, 440[0m:[39m[49m 
[0m[49m[39m  431, 441[0m:[39m[49m     // Apply hard safety constraints
[0m[49m[39m  432, 442[0m:[39m[49m     safe_recommendation = apply_safety_constraints(
[0m[49m[39m  433, 443[0m:[39m[49m         raw_recommendation.dose,
[0m[49m[39m  434, 444[0m:[39m[49m         patient_history,
[0m[49m[39m  435, 445[0m:[39m[49m         SAFETY_CONSTRAINTS
[0m[49m[39m  436, 446[0m:[39m[49m     )
[0m[49m[39m  437, 447[0m:[39m[49m 
[0m[49m[39m  438, 448[0m:[39m[49m     // Package for clinical display
[0m[49m[39m  439, 449[0m:[39m[49m     recommendation = {
[0m[49m[39m  440, 450[0m:[39m[49m         patient_id:          patient_id,
[0m[49m[39m  441, 451[0m:[39m[49m         timestamp:           current_utc_timestamp(),
[0m[49m[39m  442, 452[0m:[39m[49m         recommended_dose:    safe_recommendation.final_dose,
[0m[49m[39m  443, 453[0m:[39m[49m         dose_units:          "units insulin (regular)",
[0m[49m[39m  444, 454[0m:[39m[49m         confidence:          safe_recommendation.confidence,
[0m[49m[39m  445, 455[0m:[39m[49m         reasoning: {
[0m[49m[39m  446, 456[0m:[39m[49m             current_glucose:     new_glucose_reading,
[0m[49m[39m  447, 457[0m:[39m[49m             trend:               patient_history.glucose_velocity,
[0m[49m[39m  448, 458[0m:[39m[49m             insulin_on_board:    patient_history.insulin_on_board,
[0m[49m[39m  449, 459[0m:[39m[49m             constraints_active:  safe_recommendation.constraints_activated
[0m[49m[39m  450, 460[0m:[39m[49m         },
[0m[49m[39m  451, 461[0m:[39m[49m         clinician_action:    "PENDING"  // updated when clinician responds
[0m[49m[39m  452, 462[0m:[39m[49m     }
[0m[49m[39m  453, 463[0m:[39m[49m 
[0m[49m[39m  454, 464[0m:[39m[49m     // Store recommendation for audit and outcome tracking
[0m[49m[39m  455, 465[0m:[39m[49m     store_recommendation(recommendation)
[0m[49m[39m  456, 466[0m:[39m[49m 
[0m[49m[39m  457, 467[0m:[39m[49m     RETURN recommendation
[0m[49m[39m  458, 468[0m:[39m[49m ```
