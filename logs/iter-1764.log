[0m[49m[38;5;10m+      347[0m:[38;5;10m[49m **Failure handling and recovery.** Long-running pipelines fail. MediaConvert jobs time out, SageMaker instances get preempted, Lambda functions hit memory limits on unusually long procedures. Your Step Functions state machine needs a catch-all error state that handles any unrecoverable failure:
[0m[49m[38;5;10m+      348[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      349[0m:[38;5;10m[49m ```pseudocode
[0m[49m[38;5;10m+      350[0m:[38;5;10m[49m // Step Functions Catch-All Error Handler (applied to the state machine)
[0m[49m[38;5;10m+      351[0m:[38;5;10m[49m ON ANY unhandled error in any state:
[0m[49m[38;5;10m+      352[0m:[38;5;10m[49m     // Write the failure details to a Dead Letter Queue.
[0m[49m[38;5;10m+      353[0m:[38;5;10m[49m     // This captures the procedure_id, the failed step, and the error message
[0m[49m[38;5;10m+      354[0m:[38;5;10m[49m     // so an operator (or automated retry) can investigate.
[0m[49m[38;5;10m+      355[0m:[38;5;10m[49m     send to SQS DLQ "surgical-pipeline-dlq":
[0m[49m[38;5;10m+      356[0m:[38;5;10m[49m         procedure_id  = execution_input.procedure_id
[0m[49m[38;5;10m+      357[0m:[38;5;10m[49m         failed_step   = current_state_name
[0m[49m[38;5;10m+      358[0m:[38;5;10m[49m         error_type    = error.type
[0m[49m[38;5;10m+      359[0m:[38;5;10m[49m         error_message = error.message
[0m[49m[38;5;10m+      360[0m:[38;5;10m[49m         failed_at     = current UTC timestamp
[0m[49m[38;5;10m+      361[0m:[38;5;10m[49m         execution_arn = current execution ARN
[0m[49m[38;5;10m+      362[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      363[0m:[38;5;10m[49m     // Update the procedure registry so the status reflects the failure.
[0m[49m[38;5;10m+      364[0m:[38;5;10m[49m     update DynamoDB "procedure-registry" where procedure_id:
[0m[49m[38;5;10m+      365[0m:[38;5;10m[49m         status = "failed"
[0m[49m[38;5;10m+      366[0m:[38;5;10m[49m         failure_step = current_state_name
[0m[49m[38;5;10m+      367[0m:[38;5;10m[49m         failure_message = error.message
[0m[49m[38;5;10m+      368[0m:[38;5;10m[49m         failed_at = current UTC timestamp
[0m[49m[38;5;10m+      369[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      370[0m:[38;5;10m[49m // CloudWatch Alarm on DLQ depth.
[0m[49m[38;5;10m+      371[0m:[38;5;10m[49m // If messages accumulate in the DLQ, the pipeline has a systemic issue.
[0m[49m[38;5;10m+      372[0m:[38;5;10m[49m ALARM: "surgical-pipeline-failures"
[0m[49m[38;5;10m+      373[0m:[38;5;10m[49m     metric: ApproximateNumberOfMessagesVisible on DLQ
[0m[49m[38;5;10m+      374[0m:[38;5;10m[49m     threshold: >= 3 over 15 minutes
[0m[49m[38;5;10m+      375[0m:[38;5;10m[49m     action: notify on-call via SNS
[0m[49m[38;5;10m+      376[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      377[0m:[38;5;10m[49m // Scheduled Lambda: scan for stuck procedures.
[0m[49m[38;5;10m+      378[0m:[38;5;10m[49m // Runs every 30 minutes. Catches cases where Step Functions itself hangs
[0m[49m[38;5;10m+      379[0m:[38;5;10m[49m // (rare but possible with service disruptions).
[0m[49m[38;5;10m+      380[0m:[38;5;10m[49m FUNCTION scan_stuck_procedures():
[0m[49m[38;5;10m+      381[0m:[38;5;10m[49m     stuck = query DynamoDB "procedure-registry" WHERE:
[0m[49m[38;5;10m+      382[0m:[38;5;10m[49m         status IN ("ingested", "extracting_frames", "analyzing")
[0m[49m[38;5;10m+      383[0m:[38;5;10m[49m         AND last_updated < (now - 2 hours)
[0m[49m[38;5;10m+      384[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      385[0m:[38;5;10m[49m     FOR each stuck procedure:
[0m[49m[38;5;10m+      386[0m:[38;5;10m[49m         IF retry_count < 3:
[0m[49m[38;5;10m+      387[0m:[38;5;10m[49m             // Re-trigger the pipeline from the stuck step.
[0m[49m[38;5;10m+      388[0m:[38;5;10m[49m             restart Step Functions execution for procedure_id
[0m[49m[38;5;10m+      389[0m:[38;5;10m[49m             increment retry_count in registry
[0m[49m[38;5;10m+      390[0m:[38;5;10m[49m         ELSE:
[0m[49m[38;5;10m+      391[0m:[38;5;10m[49m             // Exhausted retries. Send to DLQ for manual investigation.
[0m[49m[38;5;10m+      392[0m:[38;5;10m[49m             send to SQS DLQ with reason = "exceeded_max_retries"
[0m[49m[38;5;10m+      393[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+      394[0m:[38;5;10m[49m 
