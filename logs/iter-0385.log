[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m ┌────────── CHANNEL ENTRY WITH DISCLOSURE ────────────────────┐
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m │                                                              │
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m │   [Patient-initiated entry]                                  │
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m │    - In-app chat                                             │
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m │    - SMS                                                     │
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m │    - Web chat                                                │
