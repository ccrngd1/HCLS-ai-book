[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m if item_id:
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     item = next((i for i in items if i.get("id") == item_id), None)
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m else:
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m     # When no item_id is provided, default to the first
