[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m print(f"  -> completion_status: {audit['intake_completion_status']}")
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m print(f"  -> acuity_flags_raised: {audit['acuity_flags_raised']}")
