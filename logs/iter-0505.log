[0m[49m[38;5;10m+    1350[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1351[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    1352[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1353[0m:[38;5;10m[49m ## Step 5: Validate, Compose Scenarios, and Surface
[0m[49m[38;5;10m+    1354[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1355[0m:[38;5;10m[49m The pipeline validates calibration on a temporal holdout, composes scenario forecasts under hypothetical interventions, and surfaces the operational forecasts to DynamoDB and the analytic forecasts to the registry. CloudWatch metrics flag calibration drift and ingestion-completeness issues.
[0m[49m[38;5;10m+    1356[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1357[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    1358[0m:[38;5;10m[49m def compute_holdout_calibration(per_model_forecasts, panel,
[0m[49m[38;5;10m+    1359[0m:[38;5;10m[49m                                   primary_feed_id="lab_pcr_positivity",
[0m[49m[38;5;10m+    1360[0m:[38;5;10m[49m                                   holdout_weeks=4):
[0m[49m[38;5;10m+    1361[0m:[38;5;10m[49m     """Coverage of credible intervals on a temporal holdout.
[0m[49m[38;5;10m+    1362[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1363[0m:[38;5;10m[49m     For each model, hold out the most recent `holdout_weeks` of
[0m[49m[38;5;10m+    1364[0m:[38;5;10m[49m     the panel, simulate what the model would have forecast at
[0m[49m[38;5;10m+    1365[0m:[38;5;10m[49m     that point, and check coverage of the held-out observations.
[0m[49m[38;5;10m+    1366[0m:[38;5;10m[49m     The demo's "what would the model have forecast" is approximated
[0m[49m[38;5;10m+    1367[0m:[38;5;10m[49m     by checking whether the held-out actuals fall within the
[0m[49m[38;5;10m+    1368[0m:[38;5;10m[49m     model's current forecast intervals at horizons 1..holdout_weeks.
[0m[49m[38;5;10m+    1369[0m:[38;5;10m[49m     Production runs proper temporal-cross-validation backtests.
[0m[49m[38;5;10m+    1370[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1371[0m:[38;5;10m[49m     actuals = [row.get(primary_feed_id) for row in panel
[0m[49m[38;5;10m+    1372[0m:[38;5;10m[49m                if row.get(primary_feed_id) is not None]
[0m[49m[38;5;10m+    1373[0m:[38;5;10m[49m     if len(actuals) < holdout_weeks + 4:
[0m[49m[38;5;10m+    1374[0m:[38;5;10m[49m         return {}
[0m[49m[38;5;10m+    1375[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1376[0m:[38;5;10m[49m     holdout_actuals = actuals[-holdout_weeks:]
[0m[49m[38;5;10m+    1377[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1378[0m:[38;5;10m[49m     coverage_summary = {}
[0m[49m[38;5;10m+    1379[0m:[38;5;10m[49m     for forecast in per_model_forecasts:
[0m[49m[38;5;10m+    1380[0m:[38;5;10m[49m         coverage_50 = 0
[0m[49m[38;5;10m+    1381[0m:[38;5;10m[49m         coverage_80 = 0
[0m[49m[38;5;10m+    1382[0m:[38;5;10m[49m         coverage_95 = 0
[0m[49m[38;5;10m+    1383[0m:[38;5;10m[49m         wis_total = 0.0
[0m[49m[38;5;10m+    1384[0m:[38;5;10m[49m         n_evaluated = 0
[0m[49m[38;5;10m+    1385[0m:[38;5;10m[49m         for h, actual in enumerate(holdout_actuals):
[0m[49m[38;5;10m+    1386[0m:[38;5;10m[49m             horizon = h + 1
[0m[49m[38;5;10m+    1387[0m:[38;5;10m[49m             week_forecast = next(
[0m[49m[38;5;10m+    1388[0m:[38;5;10m[49m                 (f for f in forecast["forecast_quantiles"]
[0m[49m[38;5;10m+    1389[0m:[38;5;10m[49m                  if f["horizon_weeks"] == horizon),
[0m[49m[38;5;10m+    1390[0m:[38;5;10m[49m                 None)
[0m[49m[38;5;10m+    1391[0m:[38;5;10m[49m             if week_forecast is None:
[0m[49m[38;5;10m+    1392[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    1393[0m:[38;5;10m[49m             qs = week_forecast["quantiles"]
[0m[49m[38;5;10m+    1394[0m:[38;5;10m[49m             # 50% interval.
[0m[49m[38;5;10m+    1395[0m:[38;5;10m[49m             q25 = qs.get("0.25")
[0m[49m[38;5;10m+    1396[0m:[38;5;10m[49m             q75 = qs.get("0.75")
[0m[49m[38;5;10m+    1397[0m:[38;5;10m[49m             if q25 is not None and q75 is not None:
[0m[49m[38;5;10m+    1398[0m:[38;5;10m[49m                 if q25 <= actual <= q75:
[0m[49m[38;5;10m+    1399[0m:[38;5;10m[49m                     coverage_50 += 1
[0m[49m[38;5;10m+    1400[0m:[38;5;10m[49m             # 80% interval.
[0m[49m[38;5;10m+    1401[0m:[38;5;10m[49m             q10 = qs.get("0.1")
[0m[49m[38;5;10m+    1402[0m:[38;5;10m[49m             q90 = qs.get("0.9")
[0m[49m[38;5;10m+    1403[0m:[38;5;10m[49m             if q10 is not None and q90 is not None:
[0m[49m[38;5;10m+    1404[0m:[38;5;10m[49m                 if q10 <= actual <= q90:
[0m[49m[38;5;10m+    1405[0m:[38;5;10m[49m                     coverage_80 += 1
[0m[49m[38;5;10m+    1406[0m:[38;5;10m[49m             # 95% interval.
[0m[49m[38;5;10m+    1407[0m:[38;5;10m[49m             q025 = qs.get("0.025")
[0m[49m[38;5;10m+    1408[0m:[38;5;10m[49m             q975 = qs.get("0.975")
[0m[49m[38;5;10m+    1409[0m:[38;5;10m[49m             if q025 is not None and q975 is not None:
[0m[49m[38;5;10m+    1410[0m:[38;5;10m[49m                 if q025 <= actual <= q975:
[0m[49m[38;5;10m+    1411[0m:[38;5;10m[49m                     coverage_95 += 1
[0m[49m[38;5;10m+    1412[0m:[38;5;10m[49m                 # Approximate WIS contribution: penalty for distance
[0m[49m[38;5;10m+    1413[0m:[38;5;10m[49m                 # outside the 95 interval plus interval width.
[0m[49m[38;5;10m+    1414[0m:[38;5;10m[49m                 width = q975 - q025
[0m[49m[38;5;10m+    1415[0m:[38;5;10m[49m                 if actual < q025:
[0m[49m[38;5;10m+    1416[0m:[38;5;10m[49m                     wis_total += width + 2 * (q025 - actual) / 0.05
[0m[49m[38;5;10m+    1417[0m:[38;5;10m[49m                 elif actual > q975:
[0m[49m[38;5;10m+    1418[0m:[38;5;10m[49m                     wis_total += width + 2 * (actual - q975) / 0.05
[0m[49m[38;5;10m+    1419[0m:[38;5;10m[49m                 else:
[0m[49m[38;5;10m+    1420[0m:[38;5;10m[49m                     wis_total += width
[0m[49m[38;5;10m+    1421[0m:[38;5;10m[49m             n_evaluated += 1
[0m[49m[38;5;10m+    1422[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1423[0m:[38;5;10m[49m         if n_evaluated == 0:
[0m[49m[38;5;10m+    1424[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    1425[0m:[38;5;10m[49m         coverage_summary[forecast["model_id"]] = {
[0m[49m[38;5;10m+    1426[0m:[38;5;10m[49m             "coverage_50":  round(coverage_50 / n_evaluated, 3),
[0m[49m[38;5;10m+    1427[0m:[38;5;10m[49m             "coverage_80":  round(coverage_80 / n_evaluated, 3),
[0m[49m[38;5;10m+    1428[0m:[38;5;10m[49m             "coverage_95":  round(coverage_95 / n_evaluated, 3),
[0m[49m[38;5;10m+    1429[0m:[38;5;10m[49m             "wis":          round(wis_total / n_evaluated, 2),
[0m[49m[38;5;10m+    1430[0m:[38;5;10m[49m             "n_evaluated":  n_evaluated,
[0m[49m[38;5;10m+    1431[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1432[0m:[38;5;10m[49m     return coverage_summary
[0m[49m[38;5;10m+    1433[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1434[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1435[0m:[38;5;10m[49m def detect_calibration_drift(coverage_summary):
[0m[49m[38;5;10m+    1436[0m:[38;5;10m[49m     """Flag models that have drifted out of calibration."""
[0m[49m[38;5;10m+    1437[0m:[38;5;10m[49m     alarms = []
[0m[49m[38;5;10m+    1438[0m:[38;5;10m[49m     for model_id, metrics in coverage_summary.items():
[0m[49m[38;5;10m+    1439[0m:[38;5;10m[49m         if metrics["coverage_95"] < CALIBRATION_THRESHOLDS["coverage_95_minimum"]:
[0m[49m[38;5;10m+    1440[0m:[38;5;10m[49m             alarms.append({
[0m[49m[38;5;10m+    1441[0m:[38;5;10m[49m                 "model_id":     model_id,
[0m[49m[38;5;10m+    1442[0m:[38;5;10m[49m                 "metric":       "coverage_95",
[0m[49m[38;5;10m+    1443[0m:[38;5;10m[49m                 "observed":     metrics["coverage_95"],
[0m[49m[38;5;10m+    1444[0m:[38;5;10m[49m                 "threshold":    CALIBRATION_THRESHOLDS["coverage_95_minimum"],
[0m[49m[38;5;10m+    1445[0m:[38;5;10m[49m                 "severity":     "high",
[0m[49m[38;5;10m+    1446[0m:[38;5;10m[49m                 "description":  "95% credible interval coverage below floor",
[0m[49m[38;5;10m+    1447[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    1448[0m:[38;5;10m[49m         if metrics["coverage_90"] < CALIBRATION_THRESHOLDS["coverage_90_minimum"]:
[0m[49m[38;5;10m+    1449[0m:[38;5;10m[49m             alarms.append({
[0m[49m[38;5;10m+    1450[0m:[38;5;10m[49m                 "model_id":     model_id,
[0m[49m[38;5;10m+    1451[0m:[38;5;10m[49m                 "metric":       "coverage_90",
[0m[49m[38;5;10m+    1452[0m:[38;5;10m[49m                 "observed":     metrics["coverage_90"],
[0m[49m[38;5;10m+    1453[0m:[38;5;10m[49m                 "threshold":    CALIBRATION_THRESHOLDS["coverage_90_minimum"],
[0m[49m[38;5;10m+    1454[0m:[38;5;10m[49m                 "severity":     "medium",
[0m[49m[38;5;10m+    1455[0m:[38;5;10m[49m                 "description":  "90% credible interval coverage below floor",
[0m[49m[38;5;10m+    1456[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    1457[0m:[38;5;10m[49m     return alarms
[0m[49m[38;5;10m+    1458[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1459[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1460[0m:[38;5;10m[49m def compose_scenario_forecasts(seir_model, nowcast_state, scenarios):
[0m[49m[38;5;10m+    1461[0m:[38;5;10m[49m     """Run the SEIR model under each scenario's contact modifier."""
[0m[49m[38;5;10m+    1462[0m:[38;5;10m[49m     scenario_outputs = []
[0m[49m[38;5;10m+    1463[0m:[38;5;10m[49m     for scenario in scenarios:
[0m[49m[38;5;10m+    1464[0m:[38;5;10m[49m         forecast = seir_model.forecast(
[0m[49m[38;5;10m+    1465[0m:[38;5;10m[49m             nowcast_state=nowcast_state,
[0m[49m[38;5;10m+    1466[0m:[38;5;10m[49m             horizon_weeks=FORECAST_HORIZON_WEEKS,
[0m[49m[38;5;10m+    1467[0m:[38;5;10m[49m             contact_modifier=scenario["contact_modifier"])
[0m[49m[38;5;10m+    1468[0m:[38;5;10m[49m         # Compute the peak incidence summary.
[0m[49m[38;5;10m+    1469[0m:[38;5;10m[49m         peak_p50 = max(
[0m[49m[38;5;10m+    1470[0m:[38;5;10m[49m             f["quantiles"].get("0.5", 0)
[0m[49m[38;5;10m+    1471[0m:[38;5;10m[49m             for f in forecast["forecast_quantiles"])
[0m[49m[38;5;10m+    1472[0m:[38;5;10m[49m         peak_week = next(
[0m[49m[38;5;10m+    1473[0m:[38;5;10m[49m             (f["epi_week"] for f in forecast["forecast_quantiles"]
[0m[49m[38;5;10m+    1474[0m:[38;5;10m[49m              if f["quantiles"].get("0.5", 0) == peak_p50),
[0m[49m[38;5;10m+    1475[0m:[38;5;10m[49m             None)
[0m[49m[38;5;10m+    1476[0m:[38;5;10m[49m         peak_p10 = min(
[0m[49m[38;5;10m+    1477[0m:[38;5;10m[49m             f["quantiles"].get("0.1", 1e9)
[0m[49m[38;5;10m+    1478[0m:[38;5;10m[49m             for f in forecast["forecast_quantiles"])
[0m[49m[38;5;10m+    1479[0m:[38;5;10m[49m         peak_p90 = max(
[0m[49m[38;5;10m+    1480[0m:[38;5;10m[49m             f["quantiles"].get("0.9", 0)
[0m[49m[38;5;10m+    1481[0m:[38;5;10m[49m             for f in forecast["forecast_quantiles"])
[0m[49m[38;5;10m+    1482[0m:[38;5;10m[49m         scenario_outputs.append({
[0m[49m[38;5;10m+    1483[0m:[38;5;10m[49m             "scenario_id":          scenario["scenario_id"],
[0m[49m[38;5;10m+    1484[0m:[38;5;10m[49m             "name":                 scenario["name"],
[0m[49m[38;5;10m+    1485[0m:[38;5;10m[49m             "description":          scenario["description"],
[0m[49m[38;5;10m+    1486[0m:[38;5;10m[49m             "contact_modifier":     scenario["contact_modifier"],
