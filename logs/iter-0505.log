[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m                 "Unit":  m.get("Unit", "None"),
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m                 "Time":  datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m     def raise_alarm(self, alarm):
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m         self.alarms.append(dict(alarm))
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m def generate_synthetic_surveillance(jurisdiction=JURISDICTION,
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m                                      history_weeks=SYNTHETIC_HISTORY_WEEKS,
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m                                      outbreak_start_weeks_ago=SYNTHETIC_OUTBREAK_START_WEEKS_AGO,
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m                                      seed=SYNTHETIC_RANDOM_SEED):
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m     """Generate synthetic surveillance feed data for one jurisdiction.
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m     Produces multi-feed, multi-week records that approximate what
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m     would land in the raw S3 prefix from the streaming ingestion
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m     layer. Each feed has its own reporting-delay-induced bias on
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m     the most recent weeks (the most recent counts are systematically
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m     under-reported because some reports have not arrived yet) and
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m     its own lead/lag relationship to the underlying epidemiology.
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m     The synthetic outbreak shows up as a bell curve over the last
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m     six weeks with the wastewater signal leading by ~10 days, the
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m     syndromic signal leading by ~5 days, the lab signal lagging
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m     by ~5 days, and the hospitalization signal lagging by ~10 days.
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m     Returns a dict keyed by feed_id mapping to a list of raw records.
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m     rng = random.Random(seed)
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m     today = date.today()
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m     raw_records = defaultdict(list)
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m     population = jurisdiction["population"]
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m     pop_per_100k = population / 100000.0
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m     # Build the underlying weekly true incidence curve.
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m     true_incidence = []
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m     for w in range(history_weeks):
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m         weeks_back = history_weeks - 1 - w
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m         if weeks_back > outbreak_start_weeks_ago:
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m             # Pre-outbreak baseline with seasonal variation.
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m             seasonal = 2.0 * math.sin(2 * math.pi * w / 52.0)
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m             value = SYNTHETIC_BASELINE_INCIDENCE + seasonal + rng.gauss(0, 1.0)
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m             # Outbreak phase: bell curve centered three weeks ago.
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m             phase_weeks = outbreak_start_weeks_ago - weeks_back
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m             peak_offset = outbreak_start_weeks_ago // 2
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m             sigma = 2.5
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m             outbreak_height = (SYNTHETIC_OUTBREAK_PEAK_INCIDENCE
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m                                - SYNTHETIC_BASELINE_INCIDENCE)
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m             value = (SYNTHETIC_BASELINE_INCIDENCE
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m                      + outbreak_height * math.exp(
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m                          -((phase_weeks - peak_offset) ** 2) / (2 * sigma ** 2))
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m                      + rng.gauss(0, 2.0))
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m         true_incidence.append(max(value, 0.5))
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m     # Generate per-feed raw records with their characteristic
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m     # lead/lag patterns and reporting delays.
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m     for w in range(history_weeks):
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m         week_date = today - timedelta(weeks=(history_weeks - 1 - w))
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m         epi_week = _epi_week_to_str(week_date)
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m         # Lab PCR: lags true incidence by ~1 week, has ~30% under-
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m         # reporting on the last two weeks due to reporting delay.
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m         delay_factor = 1.0
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m         if w >= history_weeks - 2:
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m             delay_factor = 0.7 if w == history_weeks - 1 else 0.85
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m         lab_lagged_idx = max(0, w - 1)
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m         lab_value = true_incidence[lab_lagged_idx] * delay_factor
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m         lab_count = int(lab_value * pop_per_100k)
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m         lab_total_tests = int(lab_count * 8 + rng.gauss(0, 200))
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m         raw_records["lab_pcr_positivity"].append({
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m             "feed_id":             "lab_pcr_positivity",
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m             "specimen_collected_dt": (week_date - timedelta(days=3)).isoformat(),
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m             "report_received_dt":   week_date.isoformat(),
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m             "epi_week":             epi_week,
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m             "geography_fips":       jurisdiction["fips"],
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m             "positive_count":       max(lab_count, 0),
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m             "tests_total":          max(lab_total_tests, 1),
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m             "ingested_at_ts":       datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m         # ED syndromic: leads true incidence by ~5 days (essentially
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m         # current week), nearly real-time reporting.
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m         ed_value = true_incidence[w] * (1.0 + rng.gauss(0, 0.05))
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m         ed_visits_total = int(pop_per_100k * 800 + rng.gauss(0, 1000))
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m         ed_resp_visits = int(ed_value * pop_per_100k * 0.3 + rng.gauss(0, 5))
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m         raw_records["ed_syndromic"].append({
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m             "feed_id":           "ed_syndromic",
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m             "encounter_dt":       week_date.isoformat(),
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m             "epi_week":           epi_week,
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m             "geography_fips":     jurisdiction["fips"],
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m             "respiratory_visits": max(ed_resp_visits, 0),
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m             "total_visits":       max(ed_visits_total, 1),
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m             "ingested_at_ts":     datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m         # Wastewater: leads true incidence by ~10 days. Concentration
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m         # is normalized log10 copies per mL.
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m         ww_lead_idx = min(history_weeks - 1, w + 1)
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m         ww_signal = true_incidence[ww_lead_idx]
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m         ww_log10 = math.log10(max(ww_signal, 0.5)) + rng.gauss(0, 0.15)
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m         raw_records["wastewater_rna"].append({
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m             "feed_id":           "wastewater_rna",
