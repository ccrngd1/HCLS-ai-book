[0m[49m[38;5;10m+     975[0m:[38;5;10m[49m         N = self.jurisdiction["population"]
[0m[49m[38;5;10m+     976[0m:[38;5;10m[49m         # Convert weekly incidence (per 100k) to current infectious count.
[0m[49m[38;5;10m+     977[0m:[38;5;10m[49m         # I0 ~ initial_incidence_per_100k * N / 100000 * (infectious_days / 7)
[0m[49m[38;5;10m+     978[0m:[38;5;10m[49m         infectious_days = self.priors["infectious_days"]
[0m[49m[38;5;10m+     979[0m:[38;5;10m[49m         incubation_days = self.priors["incubation_days"]
[0m[49m[38;5;10m+     980[0m:[38;5;10m[49m         gamma_daily = 1.0 / infectious_days
[0m[49m[38;5;10m+     981[0m:[38;5;10m[49m         sigma_daily = 1.0 / incubation_days
[0m[49m[38;5;10m+     982[0m:[38;5;10m[49m         beta_daily = (R0 * gamma_daily * contact_modifier
