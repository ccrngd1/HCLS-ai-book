[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m # literature. Production uses age-stratified compartments with
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m # stratified contact matrices; the demo uses a single-compartment
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m # SEIR with population-mean parameters so the math is visible.
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m SEIR_PRIORS = {
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m     "R0_mean":             1.40,    # effective reproduction number prior
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m     "R0_sd":               0.25,
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m     "incubation_days":     3.0,     # 1 / sigma in SEIR
