[0m[49m[38;5;10m+    1314[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1315[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    1316[0m:[38;5;10m[49m             "ensemble_method":     self.config["method"],
[0m[49m[38;5;10m+    1317[0m:[38;5;10m[49m             "per_model_weights":   weights,
[0m[49m[38;5;10m+    1318[0m:[38;5;10m[49m             "eligible_models":     [f["model_id"] for f in per_model_forecasts],
[0m[49m[38;5;10m+    1319[0m:[38;5;10m[49m             "ensemble_forecast":   ensemble_forecast,
[0m[49m[38;5;10m+    1320[0m:[38;5;10m[49m             "ensemble_config_version": self.config["version"],
[0m[49m[38;5;10m+    1321[0m:[38;5;10m[49m             "generated_at_ts":     datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    1322[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1323[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1324[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1325[0m:[38;5;10m[49m def run_ensemble(per_model_forecasts, registry, jurisdiction, s3,
[0m[49m[38;5;10m+    1326[0m:[38;5;10m[49m                   ensemble_bucket, run_id):
[0m[49m[38;5;10m+    1327[0m:[38;5;10m[49m     """Step 4: Run the ensemble combiner."""
[0m[49m[38;5;10m+    1328[0m:[38;5;10m[49m     combiner = EnsembleCombiner(ENSEMBLE_CONFIG)
[0m[49m[38;5;10m+    1329[0m:[38;5;10m[49m 
