[0m[49m[38;5;10m+    1091[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1092[0m:[38;5;10m[49m     def __init__(self, hyperparameters, seed=4242):
[0m[49m[38;5;10m+    1093[0m:[38;5;10m[49m         self.hyper = dict(hyperparameters)
[0m[49m[38;5;10m+    1094[0m:[38;5;10m[49m         self.rng = random.Random(seed + 1)
[0m[49m[38;5;10m+    1095[0m:[38;5;10m[49m         self.fitted = False
[0m[49m[38;5;10m+    1096[0m:[38;5;10m[49m         self.ar_coefs = None
[0m[49m[38;5;10m+    1097[0m:[38;5;10m[49m         self.ma_coef = None
[0m[49m[38;5;10m+    1098[0m:[38;5;10m[49m         self.history = None
[0m[49m[38;5;10m+    1099[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1100[0m:[38;5;10m[49m     def fit(self, panel, primary_feed_id="lab_pcr_positivity"):
[0m[49m[38;5;10m+    1101[0m:[38;5;10m[49m         """Fit AR coefficients via OLS on the primary feed's history."""
[0m[49m[38;5;10m+    1102[0m:[38;5;10m[49m         series = [row.get(primary_feed_id) for row in panel
[0m[49m[38;5;10m+    1103[0m:[38;5;10m[49m                   if row.get(primary_feed_id) is not None]
[0m[49m[38;5;10m+    1104[0m:[38;5;10m[49m         if len(series) < 10:
[0m[49m[38;5;10m+    1105[0m:[38;5;10m[49m             raise ValueError("Insufficient data for ARIMA fit")
[0m[49m[38;5;10m+    1106[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1107[0m:[38;5;10m[49m         # OLS for y_t = phi1 * y_{t-1} + phi2 * y_{t-2} + e_t
