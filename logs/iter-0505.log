[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m                f"{jurisdiction['fips']}/{feed_id}.json")
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m         s3.put_object(Bucket=harmonized_bucket, Key=key,
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m                       Body=json.dumps(harmonized[feed_id], default=str))
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m     logger.info("Harmonized %d feeds for jurisdiction %s",
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m                 len(harmonized), jurisdiction["fips"])
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m     return harmonized
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m 
