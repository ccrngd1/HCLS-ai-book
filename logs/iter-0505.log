[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m def harmonize_lab_pcr_record(record, jurisdiction):
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m     """Convert a lab PCR record to canonical units (cases per 100k per week).
