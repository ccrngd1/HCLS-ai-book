[0m[49m[38;5;10m+    1110[0m:[38;5;10m[49m         ys = series[2:]
[0m[49m[38;5;10m+    1111[0m:[38;5;10m[49m         x1 = series[1:-1]
[0m[49m[38;5;10m+    1112[0m:[38;5;10m[49m         x2 = series[:-2]
[0m[49m[38;5;10m+    1113[0m:[38;5;10m[49m         n = len(ys)
[0m[49m[38;5;10m+    1114[0m:[38;5;10m[49m         mean_y, mean_x1, mean_x2 = (sum(ys) / n, sum(x1) / n, sum(x2) / n)
[0m[49m[38;5;10m+    1115[0m:[38;5;10m[49m         # Simple covariance-based estimator.
[0m[49m[38;5;10m+    1116[0m:[38;5;10m[49m         s11 = sum((x1[i] - mean_x1) ** 2 for i in range(n))
[0m[49m[38;5;10m+    1117[0m:[38;5;10m[49m         s22 = sum((x2[i] - mean_x2) ** 2 for i in range(n))
[0m[49m[38;5;10m+    1118[0m:[38;5;10m[49m         s12 = sum((x1[i] - mean_x1) * (x2[i] - mean_x2) for i in range(n))
[0m[49m[38;5;10m+    1119[0m:[38;5;10m[49m         s1y = sum((x1[i] - mean_x1) * (ys[i] - mean_y) for i in range(n))
[0m[49m[38;5;10m+    1120[0m:[38;5;10m[49m         s2y = sum((x2[i] - mean_x2) * (ys[i] - mean_y) for i in range(n))
[0m[49m[38;5;10m+    1121[0m:[38;5;10m[49m         det = s11 * s22 - s12 ** 2
