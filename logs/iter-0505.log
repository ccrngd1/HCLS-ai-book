[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m         "reporting_delay": {"median_days": 3, "p90_days": 7},
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m         "fusion_weight":   0.10,
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m         "version":         FEED_SPEC_VERSION,
