[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m The demo never touches a real Kinesis stream, S3 bucket, DynamoDB table, EventBridge bus, or SageMaker endpoint. The mocks below stand in for those services so the focus stays on the forecasting logic. They print what they would write rather than failing, which makes the demo runnable without any AWS resources provisioned.
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m class MockS3:
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m     """In-memory stand-in for an S3 bucket.
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m     Production uses boto3.client('s3').get_object / put_object.
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m     The mock stores objects keyed by (bucket, key).
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m     def __init__(self):
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m         self.objects = {}
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m     def put_object(self, Bucket, Key, Body, **kwargs):
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m         if isinstance(Body, str):
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m             Body = Body.encode("utf-8")
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m         self.objects[(Bucket, Key)] = Body
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m         return {"ETag": '"' + str(uuid.uuid4()) + '"'}
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m     def get_object(self, Bucket, Key, **kwargs):
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m         if (Bucket, Key) not in self.objects:
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m             raise KeyError(f"NoSuchKey: s3://{Bucket}/{Key}")
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m         body = self.objects[(Bucket, Key)]
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m         class _StreamingBody:
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m             def __init__(self, b):
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m                 self._b = b
