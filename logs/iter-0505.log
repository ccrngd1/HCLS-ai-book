[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m def _to_decimal(value):
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m     """Convert numeric values to Decimal for DynamoDB-safe writes.
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m     DynamoDB rejects Python float at the SDK boundary. Pass
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m     everything numeric through this helper before any PutItem,
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m     BatchWriteItem, or UpdateItem call.
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m     if value is None:
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m     if isinstance(value, Decimal):
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m         return value
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m     if isinstance(value, bool):
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m         return value
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m     if isinstance(value, (int, float)):
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m         return Decimal(str(round(float(value), 6)))
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m     if isinstance(value, str):
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m         return Decimal(value)
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m     raise TypeError(f"Cannot convert {type(value).__name__} to Decimal")
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m def _epi_week_to_str(d):
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m     """Render a date as an epi-week string YYYY-Www.
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m     Epi-weeks start Sunday in the CDC convention. The demo uses a
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m     simple ISO-week approximation; production uses the official
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m     MMWR week computation that handles year-end edge cases.
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m     iso_year, iso_week, _ = d.isocalendar()
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m     return f"{iso_year}-w{iso_week:02d}"
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m def _normal_cdf(z):
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m     """Standard normal CDF via the error function."""
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m     return 0.5 * (1.0 + math.erf(z / math.sqrt(2.0)))
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m ```
