[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m                 h = harmonize_hospitalization_record(record, jurisdiction)
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m             else:
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m                 logger.warning("unknown feed_id %s, skipping", feed_id)
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m             h["harmonized_at_ts"] = datetime.now(timezone.utc).isoformat()
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m             h["harmonization_version"] = HARMONIZATION_VERSION
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m             harmonized[feed_id].append(h)
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m 
