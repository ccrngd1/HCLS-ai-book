[0m[49m[38;5;10m+     944[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     945[0m:[38;5;10m[49m class SEIRCompartmentalModel:
[0m[49m[38;5;10m+     946[0m:[38;5;10m[49m     """Simplified SEIR compartmental model.
[0m[49m[38;5;10m+     947[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     948[0m:[38;5;10m[49m     The differential equations:
[0m[49m[38;5;10m+     949[0m:[38;5;10m[49m         dS/dt = -beta * S * I / N
[0m[49m[38;5;10m+     950[0m:[38;5;10m[49m         dE/dt =  beta * S * I / N - sigma * E
[0m[49m[38;5;10m+     951[0m:[38;5;10m[49m         dI/dt =  sigma * E - gamma * I
