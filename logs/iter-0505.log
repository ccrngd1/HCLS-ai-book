[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m     "initial_susceptible_share": 0.78,   # post-immunity share
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m     "observation_noise_sd": 8.0,    # weekly cases per 100k
