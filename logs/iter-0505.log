[0m[49m[38;5;10m+    1267[0m:[38;5;10m[49m             inverse_wis = {m: 1.0 / w for m, w in wis_per_model.items()}
[0m[49m[38;5;10m+    1268[0m:[38;5;10m[49m             total = sum(inverse_wis.values())
[0m[49m[38;5;10m+    1269[0m:[38;5;10m[49m             return {m: w / total for m, w in inverse_wis.items()}
