[0m[49m[38;5;10m+     968[0m:[38;5;10m[49m     def _simulate_trajectory(self, R0, initial_incidence_per_100k,
[0m[49m[38;5;10m+     969[0m:[38;5;10m[49m                               susceptible_share, horizon_weeks,
[0m[49m[38;5;10m+     970[0m:[38;5;10m[49m                               contact_modifier=1.0):
[0m[49m[38;5;10m+     971[0m:[38;5;10m[49m         """Run the SEIR ODE forward for horizon_weeks.
[0m[49m[38;5;10m+     972[0m:[38;5;10m[49m 
