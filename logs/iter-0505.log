[0m[49m[38;5;10m+    1013[0m:[38;5;10m[49m             week_per_100k = week_new_infections * (100000.0 / N)
[0m[49m[38;5;10m+    1014[0m:[38;5;10m[49m             weekly_new_infections.append(week_per_100k)
[0m[49m[38;5;10m+    1015[0m:[38;5;10m[49m         return weekly_new_infections
