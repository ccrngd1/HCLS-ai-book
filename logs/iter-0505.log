[0m[49m[38;5;10m+     987[0m:[38;5;10m[49m         # Spread the initial cases between E and I compartments.
[0m[49m[38;5;10m+     988[0m:[38;5;10m[49m         I0 = (initial_incidence_per_100k * (N / 100000.0)
[0m[49m[38;5;10m+     989[0m:[38;5;10m[49m               * (infectious_days / 7.0))
[0m[49m[38;5;10m+     990[0m:[38;5;10m[49m         E0 = I0 * (incubation_days / infectious_days)
[0m[49m[38;5;10m+     991[0m:[38;5;10m[49m         S = max(S - I0 - E0, 0.0)
[0m[49m[38;5;10m+     992[0m:[38;5;10m[49m         E = max(E0, 0.0)
[0m[49m[38;5;10m+     993[0m:[38;5;10m[49m         I = max(I0, 0.0)
[0m[49m[38;5;10m+     994[0m:[38;5;10m[49m         R = N - S - E - I
