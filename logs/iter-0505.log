[0m[49m[38;5;10m+    1333[0m:[38;5;10m[49m         history = registry.query_calibration_history(
[0m[49m[38;5;10m+    1334[0m:[38;5;10m[49m             model_id=forecast["model_id"],
[0m[49m[38;5;10m+    1335[0m:[38;5;10m[49m             lookback_weeks=ENSEMBLE_CONFIG["weight_lookback_weeks"])
[0m[49m[38;5;10m+    1336[0m:[38;5;10m[49m         calibration_history[forecast["model_id"]] = history
[0m[49m[38;5;10m+    1337[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1338[0m:[38;5;10m[49m     ensemble_artifact = combiner.combine(per_model_forecasts, calibration_history)
