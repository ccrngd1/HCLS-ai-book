[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m     population = jurisdiction["population"]
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m     pop_per_100k = population / 100000.0
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m     incidence_per_100k = record["positive_count"] / max(pop_per_100k, 1.0)
