[49m[38;5;10m+    743[0m:[38;5;10m[49m ## Step 2: Nowcast the Current Epidemiological State
[0m[49m[38;5;10m+    744[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    745[0m:[38;5;10m[49m Every surveillance feed lags reality. Lab confirmations lag by approximately a week, hospitalizations by a few weeks, and wastewater leads by several days. Nowcasting estimates the unobserved current epidemiological state by reverse-convolving the observed lagged signals against per-feed reporting-delay distributions and fusing across signals. The output is the input to the per-family forecasting layer; its uncertainty propagates forward.
[0m[49m[38;5;10m+    746[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    747[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    748[0m:[38;5;10m[49m class BayesianStateSpaceNowcaster:
[0m[49m[38;5;10m+    749[0m:[38;5;10m[49m     """Pedagogical state-space nowcaster.
[0m[49m[38;5;10m+    750[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    751[0m:[38;5;10m[49m     The model assumes a hidden weekly incidence series and that
[0m[49m[38;5;10m+    752[0m:[38;5;10m[49m     each observed feed is a noisy, lagged, scaled measurement of
[0m[49m[38;5;10m+    753[0m:[38;5;10m[49m     that hidden series. The nowcast estimates the hidden series
[0m[49m[38;5;10m+    754[0m:[38;5;10m[49m     over the most recent N weeks given the observations.
[0m[49m[38;5;10m+    755[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    756[0m:[38;5;10m[49m     Production replaces this with a real Bayesian state-space
[0m[49m[38;5;10m+    757[0m:[38;5;10m[49m     library (PyMC, Stan, NumPyro) that fits the joint posterior
[0m[49m[38;5;10m+    758[0m:[38;5;10m[49m     with NUTS, returns full posterior samples, and emits proper
[0m[49m[38;5;10m+    759[0m:[38;5;10m[49m     convergence diagnostics. The demo uses an inverse-variance-
[0m[49m[38;5;10m+    760[0m:[38;5;10m[49m     weighted fusion approach that captures the structure without
[0m[49m[38;5;10m+    761[0m:[38;5;10m[49m     the sampling machinery.
[0m[49m[38;5;10m+    762[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    763[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    764[0m:[38;5;10m[49m     def __init__(self, feed_catalog, nowcast_weeks_back, seed=4242):
[0m[49m[38;5;10m+    765[0m:[38;5;10m[49m         self.feed_catalog = dict(feed_catalog)
[0m[49m[38;5;10m+    766[0m:[38;5;10m[49m         self.nowcast_weeks_back = nowcast_weeks_back
[0m[49m[38;5;10m+    767[0m:[38;5;10m[49m         self.rng = random.Random(seed)
[0m[49m[38;5;10m+    768[0m:[38;5;10m[49m         self.fitted = False
[0m[49m[38;5;10m+    769[0m:[38;5;10m[49m         self.nowcast_state = None    # dict: epi_week -> {p10, p50, p90, sd}
[0m[49m[38;5;10m+    770[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    771[0m:[38;5;10m[49m     def _signal_to_underlying(self, feed_id, value):
[0m[49m[38;5;10m+    772[0m:[38;5;10m[49m         """Map a feed's observed value to an estimated underlying incidence.
[0m[49m[38;5;10m+    773[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    774[0m:[38;5;10m[49m         Each feed has a different scale and units; this helper
[0m[49m[38;5;10m+    775[0m:[38;5;10m[49m         translates each feed's value to the common underlying
[0m[49m[38;5;10m+    776[0m:[38;5;10m[49m         unit (cases per 100k per week). Production maintains
[0m[49m[38;5;10m+    777[0m:[38;5;10m[49m         feed-specific calibration constants from historical
[0m[49m[38;5;10m+    778[0m:[38;5;10m[49m         regression of each feed against the eventual lab-confirmed
[0m[49m[38;5;10m+    779[0m:[38;5;10m[49m         truth; the demo uses simplified mappings that approximate
[0m[49m[38;5;10m+    780[0m:[38;5;10m[49m         what those calibration constants would produce.
[0m[49m[38;5;10m+    781[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+    782[0m:[38;5;10m[49m         if value is None:
[0m[49m[38;5;10m+    783[0m:[38;5;10m[49m             return None
[0m[49m[38;5;10m+    784[0m:[38;5;10m[49m         if feed_id == "lab_pcr_positivity":
[0m[49m[38;5;10m+    785[0m:[38;5;10m[49m             # Lab is already in target units; divide by 0.7 to
[0m[49m[38;5;10m+    786[0m:[38;5;10m[49m             # un-bias for typical ~30% reporting under-count.
[0m[49m[38;5;10m+    787[0m:[38;5;10m[49m             return value / 0.7
[0m[49m[38;5;10m+    788[0m:[38;5;10m[49m         if feed_id == "ed_syndromic":
[0m[49m[38;5;10m+    789[0m:[38;5;10m[49m             # ED fraction of visits scales with incidence; the
[0m[49m[38;5;10m+    790[0m:[38;5;10m[49m             # demo's calibration constant is incidence ~= ED * 1500.
[0m[49m[38;5;10m+    791[0m:[38;5;10m[49m             return value * 1500.0
[0m[49m[38;5;10m+    792[0m:[38;5;10m[49m         if feed_id == "wastewater_rna":
[0m[49m[38;5;10m+    793[0m:[38;5;10m[49m             # Wastewater log10 copies; the calibration is roughly
[0m[49m[38;5;10m+    794[0m:[38;5;10m[49m             # incidence = 10 ** (ww - 1.0) for the synthetic data.
[0m[49m[38;5;10m+    795[0m:[38;5;10m[49m             return 10 ** (value - 1.0)
[0m[49m[38;5;10m+    796[0m:[38;5;10m[49m         if feed_id == "hospitalizations":
[0m[49m[38;5;10m+    797[0m:[38;5;10m[49m             # Hospitalization rate is ~6% of incidence.
[0m[49m[38;5;10m+    798[0m:[38;5;10m[49m             return value / 0.06
[0m[49m[38;5;10m+    799[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+    800[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    801[0m:[38;5;10m[49m     def _delay_correction_factor(self, feed_id, weeks_back):
[0m[49m[38;5;10m+    802[0m:[38;5;10m[49m         """Multiplier to correct for under-reporting at recent weeks.
[0m[49m[38;5;10m+    803[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    804[0m:[38;5;10m[49m         For a feed with median reporting delay D days and p90 D90,
[0m[49m[38;5;10m+    805[0m:[38;5;10m[49m         the most recent week has a known fraction of reports in
[0m[49m[38;5;10m+    806[0m:[38;5;10m[49m         and the next-most-recent has more. This is a simplified
[0m[49m[38;5;10m+    807[0m:[38;5;10m[49m         model of the reporting-delay distribution; production
[0m[49m[38;5;10m+    808[0m:[38;5;10m[49m         maintains a per-feed PMF.
[0m[49m[38;5;10m+    809[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+    810[0m:[38;5;10m[49m         delay = self.feed_catalog[feed_id]["reporting_delay"]
[0m[49m[38;5;10m+    811[0m:[38;5;10m[49m         median_days = delay["median_days"]
[0m[49m[38;5;10m+    812[0m:[38;5;10m[49m         if weeks_back == 0:
[0m[49m[38;5;10m+    813[0m:[38;5;10m[49m             # Most recent week: only median-day fraction of reports in.
[0m[49m[38;5;10m+    814[0m:[38;5;10m[49m             return min(1.0, 7.0 / max(median_days * 1.5, 1.0))
[0m[49m[38;5;10m+    815[0m:[38;5;10m[49m         if weeks_back == 1:
[0m[49m[38;5;10m+    816[0m:[38;5;10m[49m             return min(1.0, 7.0 / max(median_days, 1.0))
[0m[49m[38;5;10m+    817[0m:[38;5;10m[49m         return 1.0
[0m[49m[38;5;10m+    818[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    819[0m:[38;5;10m[49m     def fit(self, panel):
[0m[49m[38;5;10m+    820[0m:[38;5;10m[49m         """Fit the nowcast for the most recent N weeks.
[0m[49m[38;5;10m+    821[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    822[0m:[38;5;10m[49m         Walks the panel from oldest to newest, applies the per-feed
[0m[49m[38;5;10m+    823[0m:[38;5;10m[49m         signal-to-underlying mapping and the reporting-delay
[0m[49m[38;5;10m+    824[0m:[38;5;10m[49m         correction, fuses across feeds with inverse-variance
[0m[49m[38;5;10m+    825[0m:[38;5;10m[49m         weighting, and returns posterior median + credible intervals
[0m[49m[38;5;10m+    826[0m:[38;5;10m[49m         per epi-week.
[0m[49m[38;5;10m+    827[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+    828[0m:[38;5;10m[49m         if not panel:
[0m[49m[38;5;10m+    829[0m:[38;5;10m[49m             raise ValueError("Cannot fit on empty panel")
[0m[49m[38;5;10m+    830[0m:[38;5;10m[49m         n_weeks = len(panel)
[0m[49m[38;5;10m+    831[0m:[38;5;10m[49m         nowcast_weeks = panel[-self.nowcast_weeks_back:]
[0m[49m[38;5;10m+    832[0m:[38;5;10m[49m         nowcast_state = {}
[0m[49m[38;5;10m+    833[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    834[0m:[38;5;10m[49m         for week_idx, week_row in enumerate(nowcast_weeks):
[0m[49m[38;5;10m+    835[0m:[38;5;10m[49m             weeks_back = self.nowcast_weeks_back - 1 - week_idx
[0m[49m[38;5;10m+    836[0m:[38;5;10m[49m             # Per-feed underlying-incidence estimates.
[0m[49m[38;5;10m+    837[0m:[38;5;10m[49m             estimates = []
[0m[49m[38;5;10m+    838[0m:[38;5;10m[49m             weights = []
[0m[49m[38;5;10m+    839[0m:[38;5;10m[49m             for feed_id, feed_value in week_row.items():
[0m[49m[38;5;10m+    840[0m:[38;5;10m[49m                 if feed_id == "epi_week" or feed_value is None:
[0m[49m[38;5;10m+    841[0m:[38;5;10m[49m                     continue
[0m[49m[38;5;10m+    842[0m:[38;5;10m[49m                 feed_spec = self.feed_catalog.get(feed_id)
[0m[49m[38;5;10m+    843[0m:[38;5;10m[49m                 if feed_spec is None:
[0m[49m[38;5;10m+    844[0m:[38;5;10m[49m                     continue
[0m[49m[38;5;10m+    845[0m:[38;5;10m[49m                 # Map the signal to an underlying-incidence estimate.
[0m[49m[38;5;10m+    846[0m:[38;5;10m[49m                 underlying = self._signal_to_underlying(feed_id, feed_value)
[0m[49m[38;5;10m+    847[0m:[38;5;10m[49m                 if underlying is None:
[0m[49m[38;5;10m+    848[0m:[38;5;10m[49m                     continue
[0m[49m[38;5;10m+    849[0m:[38;5;10m[49m                 # Correct for reporting under-counting on recent weeks.
[0m[49m[38;5;10m+    850[0m:[38;5;10m[49m                 correction = self._delay_correction_factor(feed_id, weeks_back)
[0m[49m[38;5;10m+    851[0m:[38;5;10m[49m                 if correction > 0:
[0m[49m[38;5;10m+    852[0m:[38;5;10m[49m                     underlying = underlying / correction
[0m[49m[38;5;10m+    853[0m:[38;5;10m[49m                 estimates.append(underlying)
[0m[49m[38;5;10m+    854[0m:[38;5;10m[49m                 # Weight by the feed's fusion weight, attenuated by
[0m[49m[38;5;10m+    855[0m:[38;5;10m[49m                 # the reporting-delay correction (more correction
