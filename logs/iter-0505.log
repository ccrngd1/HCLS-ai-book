[0m[49m[38;5;10m+    888[0m:[38;5;10m[49m             # reporting-delay correction is strong.
[0m[49m[38;5;10m+    889[0m:[38;5;10m[49m             if weeks_back == 0:
[0m[49m[38;5;10m+    890[0m:[38;5;10m[49m                 fusion_sd *= 1.5
[0m[49m[38;5;10m+    891[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    892[0m:[38;5;10m[49m             nowcast_state[week_row["epi_week"]] = {
[0m[49m[38;5;10m+    893[0m:[38;5;10m[49m                 "p10": round(max(weighted_mean - 1.282 * fusion_sd, 0.1), 3),
[0m[49m[38;5;10m+    894[0m:[38;5;10m[49m                 "p50": round(max(weighted_mean, 0.1), 3),
[0m[49m[38;5;10m+    895[0m:[38;5;10m[49m                 "p90": round(max(weighted_mean + 1.282 * fusion_sd, 0.1), 3),
[0m[49m[38;5;10m+    896[0m:[38;5;10m[49m                 "sd":  round(fusion_sd, 3),
[0m[49m[38;5;10m+    897[0m:[38;5;10m[49m                 "n_signals": len(estimates),
[0m[49m[38;5;10m+    898[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    899[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    900[0m:[38;5;10m[49m         self.nowcast_state = nowcast_state
[0m[49m[38;5;10m+    901[0m:[38;5;10m[49m         self.fitted = True
[0m[49m[38;5;10m+    902[0m:[38;5;10m[49m         return nowcast_state
