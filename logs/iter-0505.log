[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m def build_signal_panel(harmonized, weeks_to_include=None):
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m     """Stack harmonized feeds into a panel keyed by epi-week.
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m     Returns a list of dicts, one per epi-week, with each feed's
[0m[49m[38;5;10m+    717[0m:[38;5;10m[49m     value as a separate column. Missing values are explicit None.
[0m[49m[38;5;10m+    718[0m:[38;5;10m[49m     The panel is the input to the nowcasting and forecasting layers.
[0m[49m[38;5;10m+    719[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    720[0m:[38;5;10m[49m     # Collect every epi-week that appears in any feed.
[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m     all_weeks = set()
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m     for feed_records in harmonized.values():
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m         for r in feed_records:
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m             all_weeks.add(r["epi_week"])
[0m[49m[38;5;10m+    725[0m:[38;5;10m[49m     sorted_weeks = sorted(all_weeks)
[0m[49m[38;5;10m+    726[0m:[38;5;10m[49m     if weeks_to_include is not None:
[0m[49m[38;5;10m+    727[0m:[38;5;10m[49m         sorted_weeks = sorted_weeks[-weeks_to_include:]
[0m[49m[38;5;10m+    728[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    729[0m:[38;5;10m[49m     # Build the panel.
[0m[49m[38;5;10m+    730[0m:[38;5;10m[49m     panel = []
[0m[49m[38;5;10m+    731[0m:[38;5;10m[49m     for week in sorted_weeks:
[0m[49m[38;5;10m+    732[0m:[38;5;10m[49m         row = {"epi_week": week}
[0m[49m[38;5;10m+    733[0m:[38;5;10m[49m         for feed_id, feed_records in harmonized.items():
[0m[49m[38;5;10m+    734[0m:[38;5;10m[49m             match = next((r for r in feed_records
[0m[49m[38;5;10m+    735[0m:[38;5;10m[49m                           if r["epi_week"] == week), None)
[0m[49m[38;5;10m+    736[0m:[38;5;10m[49m             row[feed_id] = match["value"] if match else None
[0m[49m[38;5;10m+    737[0m:[38;5;10m[49m         panel.append(row)
[0m[49m[38;5;10m+    738[0m:[38;5;10m[49m     return panel
