[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m     def insert_calibration_record(self, record):
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m         self.calibration_history.append(dict(record))
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m     def query_calibration_history(self, model_id, lookback_weeks):
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m         # Used by the ensemble combiner to weight per-model
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m         # contributions. Returns the most recent N calibration
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m         # records for a given model.
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m         recs = [r for r in self.calibration_history
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m                 if r["model_id"] == model_id]
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m         recs.sort(key=lambda r: r["evaluated_at_ts"], reverse=True)
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m         return recs[:lookback_weeks]
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m 
