[0m[49m[38;5;10m+    866[0m:[38;5;10m[49m                         nowcast_state[last_week])
[0m[49m[38;5;10m+    867[0m:[38;5;10m[49m                 else:
[0m[49m[38;5;10m+    868[0m:[38;5;10m[49m                     nowcast_state[week_row["epi_week"]] = {
[0m[49m[38;5;10m+    869[0m:[38;5;10m[49m                         "p10": 5.0, "p50": 10.0, "p90": 20.0, "sd": 5.0,
[0m[49m[38;5;10m+    870[0m:[38;5;10m[49m                     }
[0m[49m[38;5;10m+    871[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    872[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    873[0m:[38;5;10m[49m             # Inverse-variance-weighted fusion.
[0m[49m[38;5;10m+    874[0m:[38;5;10m[49m             total_weight = sum(weights)
[0m[49m[38;5;10m+    875[0m:[38;5;10m[49m             if total_weight <= 0:
[0m[49m[38;5;10m+    876[0m:[38;5;10m[49m                 total_weight = 1.0
[0m[49m[38;5;10m+    877[0m:[38;5;10m[49m             weighted_mean = sum(e * w for e, w in zip(estimates, weights)) / total_weight
[0m[49m[38;5;10m+    878[0m:[38;5;10m[49m             # SD across feeds as a proxy for nowcast uncertainty.
[0m[49m[38;5;10m+    879[0m:[38;5;10m[49m             if len(estimates) > 1:
[0m[49m[38;5;10m+    880[0m:[38;5;10m[49m                 weighted_var = sum(
[0m[49m[38;5;10m+    881[0m:[38;5;10m[49m                     w * (e - weighted_mean) ** 2 for e, w in zip(estimates, weights)
[0m[49m[38;5;10m+    882[0m:[38;5;10m[49m                 ) / total_weight
[0m[49m[38;5;10m+    883[0m:[38;5;10m[49m                 fusion_sd = math.sqrt(max(weighted_var, 1.0))
[0m[49m[38;5;10m+    884[0m:[38;5;10m[49m             else:
[0m[49m[38;5;10m+    885[0m:[38;5;10m[49m                 fusion_sd = max(weighted_mean * 0.30, 2.0)
[0m[49m[38;5;10m+    886[0m:[38;5;10m[49m 
