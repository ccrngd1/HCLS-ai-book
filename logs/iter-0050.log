[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m         language: session.language)
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m IF NOT instructions_check.complete:
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m         action: "augment_with_instructions",
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m         missing_instructions:
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m             instructions_check.missing
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m // Step 7F: regulatory disclaimer presence.
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m disclaimer_check = verify_disclaimers(
