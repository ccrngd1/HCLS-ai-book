[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m CLINICAL_RULE_REGISTRY = {
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m     "heart_score": {
