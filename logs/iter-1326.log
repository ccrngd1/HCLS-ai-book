[0m[49m[38;5;10m+      368[0m:[38;5;10m[49m **Step 5: Result packaging and delivery.** The fusion and analysis results need to get back into the clinical workflow, which means packaging them in DICOM-compatible formats and pushing them to PACS or the treatment planning system. Segmentation maps become DICOM-RT Structure Sets (for radiation oncology) or DICOM SEG objects (for general imaging). Quantitative measurements become DICOM-SR (Structured Reports). The registered and fused volumes become new DICOM series linked to the original study. This packaging step is what makes the computational results clinically usable rather than trapped in a research pipeline.
[0m[49m[38;5;10m+      369[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      370[0m:[38;5;10m[49m ```pseudocode
[0m[49m[38;5;10m+      371[0m:[38;5;10m[49m FUNCTION package_and_deliver(analysis_results, original_study_metadata):
[0m[49m[38;5;10m+      372[0m:[38;5;10m[49m     // Package segmentation as DICOM-RT Structure Set
[0m[49m[38;5;10m+      373[0m:[38;5;10m[49m     IF "segmentation" in analysis_results:
[0m[49m[38;5;10m+      374[0m:[38;5;10m[49m         rt_struct = create DICOM-RT Structure Set:
[0m[49m[38;5;10m+      375[0m:[38;5;10m[49m             referenced_study     = original_study_metadata.StudyInstanceUID
[0m[49m[38;5;10m+      376[0m:[38;5;10m[49m             referenced_series    = reference CT series UID
[0m[49m[38;5;10m+      377[0m:[38;5;10m[49m             structures           = convert each label to a set of contour points per slice
[0m[49m[38;5;10m+      378[0m:[38;5;10m[49m             structure_names      = ["GTV_MRI", "CTV_metabolic", "Edema", ...]
[0m[49m[38;5;10m+      379[0m:[38;5;10m[49m             structure_colors     = [red, green, blue, ...]  // display colors
[0m[49m[38;5;10m+      380[0m:[38;5;10m[49m             manufacturer         = "AI Fusion Pipeline v1.0"
[0m[49m[38;5;10m+      381[0m:[38;5;10m[49m             approval_status      = "UNAPPROVED"  // clinician must verify
[0m[49m[38;5;10m+      382[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      383[0m:[38;5;10m[49m     // Package measurements as DICOM Structured Report
[0m[49m[38;5;10m+      384[0m:[38;5;10m[49m     IF "volumes" in analysis_results:
[0m[49m[38;5;10m+      385[0m:[38;5;10m[49m         dicom_sr = create DICOM-SR:
[0m[49m[38;5;10m+      386[0m:[38;5;10m[49m             measurement_groups = [
[0m[49m[38;5;10m+      387[0m:[38;5;10m[49m                 { concept: "Tumor Volume", value: volumes["tumor_core"], unit: "mL" },
[0m[49m[38;5;10m+      388[0m:[38;5;10m[49m                 { concept: "Metabolic Volume", value: volumes["metabolic"], unit: "mL" },
[0m[49m[38;5;10m+      389[0m:[38;5;10m[49m                 ...
[0m[49m[38;5;10m+      390[0m:[38;5;10m[49m             ]
[0m[49m[38;5;10m+      391[0m:[38;5;10m[49m             referenced_study = original_study_metadata.StudyInstanceUID
[0m[49m[38;5;10m+      392[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      393[0m:[38;5;10m[49m     // Store results in S3
[0m[49m[38;5;10m+      394[0m:[38;5;10m[49m     result_prefix = "fusion-results/" + study_uid + "/"
[0m[49m[38;5;10m+      395[0m:[38;5;10m[49m     upload rt_struct, dicom_sr, and registered volumes to S3 at result_prefix
[0m[49m[38;5;10m+      396[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      397[0m:[38;5;10m[49m     // Push to PACS via DICOM C-STORE or DICOMweb STOW-RS
[0m[49m[38;5;10m+      398[0m:[38;5;10m[49m     send results to PACS endpoint
[0m[49m[38;5;10m+      399[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      400[0m:[38;5;10m[49m     // Update pipeline tracking
[0m[49m[38;5;10m+      401[0m:[38;5;10m[49m     update DynamoDB "pipeline-state":
[0m[49m[38;5;10m+      402[0m:[38;5;10m[49m         study_uid = study_uid
[0m[49m[38;5;10m+      403[0m:[38;5;10m[49m         status    = "completed"
[0m[49m[38;5;10m+      404[0m:[38;5;10m[49m         result_s3 = result_prefix
[0m[49m[38;5;10m+      405[0m:[38;5;10m[49m         completed_at = current UTC timestamp
[0m[49m[38;5;10m+      406[0m:[38;5;10m[49m         quality_metrics = registration and analysis quality scores
[0m[49m[38;5;10m+      407[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      408[0m:[38;5;10m[49m     RETURN { status: "delivered", result_location: result_prefix }
[0m[49m[38;5;10m+      409[0m:[38;5;10m[49m ```
