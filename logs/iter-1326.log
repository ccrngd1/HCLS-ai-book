[0m[49m[39m  405, 324[0m:[39m[49m         
[0m[49m[38;5;9m- 406     [0m:[38;5;9m[49m         // Convert probability maps to binary contours
[0m[49m[38;5;9m- 407     [0m:[38;5;9m[49m         contours = {}
[0m[49m[38;5;9m- 408     [0m:[38;5;9m[49m         FOR each structure, probability_map in predictions:
[0m[49m[38;5;9m- 409     [0m:[38;5;9m[49m             binary_mask = probability_map > config.threshold
[0m[49m[38;5;9m- 410     [0m:[38;5;9m[49m             // Post-process: remove small islands, fill holes
[0m[49m[38;5;9m- 411     [0m:[38;5;9m[49m             binary_mask = morphological_cleanup(binary_mask, min_size_voxels=50)
[0m[49m[38;5;9m- 412     [0m:[38;5;9m[49m             contours[structure] = binary_mask
[0m[49m[38;5;9m- 413     [0m:[38;5;9m[49m 
[0m[49m[38;5;9m- 414     [0m:[38;5;9m[49m         RETURN contours
[0m[49m[38;5;9m- 415     [0m:[38;5;9m[49m 
[0m[49m[38;5;9m- 416     [0m:[38;5;9m[49m     ELSE IF analysis_type == "response_assessment":
[0m[49m[38;5;9m- 417     [0m:[38;5;9m[49m         // Compare pre-treatment and post-treatment fused volumes.
[0m[49m[38;5;9m- 418     [0m:[38;5;9m[49m         // Quantify changes in tumor volume (from contours) and
[0m[49m[38;5;9m- 419     [0m:[38;5;9m[49m         // metabolic activity (from PET channel values within the tumor region).
[0m[49m[38;5;10m+      325[0m:[38;5;10m[49m         // Compute volumetric measurements from segmentation
[0m[49m[38;5;10m+      326[0m:[38;5;10m[49m         volumes = compute volume in mL for each label class
[0m[49m[39m  420, 327[0m:[39m[49m         
[0m[49m[38;5;9m- 421     [0m:[38;5;9m[49m         pre_contour  = load pre-treatment tumor contour
[0m[49m[38;5;9m- 422     [0m:[38;5;9m[49m         post_contour = analyze_fused_volume(fused_volume_path, "auto_contour", clinical_context)
[0m[49m[38;5;10m+      328[0m:[38;5;10m[49m         RETURN {
[0m[49m[38;5;10m+      329[0m:[38;5;10m[49m             segmentation: cleaned_segmentation,
[0m[49m[38;5;10m+      330[0m:[38;5;10m[49m             volumes: volumes,
[0m[49m[38;5;10m+      331[0m:[38;5;10m[49m             confidence_map: model softmax outputs per voxel
[0m[49m[38;5;10m+      332[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+      333[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      334[0m:[38;5;10m[49m     ELSE IF clinical_task == "treatment_planning_support":
[0m[49m[38;5;10m+      335[0m:[38;5;10m[49m         // Propagate structures from MRI to CT planning scan using registration transform
[0m[49m[38;5;10m+      336[0m:[38;5;10m[49m         // Clinician contours on MRI (better soft tissue contrast)
[0m[49m[38;5;10m+      337[0m:[38;5;10m[49m         // Treatment planning happens on CT (needed for dose calculation)
[0m[49m[38;5;10m+      338[0m:[38;5;10m[49m         mri_contours = load existing contours from MRI study
[0m[49m[38;5;10m+      339[0m:[38;5;10m[49m         ct_contours  = transform mri_contours using inverse registration transform
[0m[49m[38;5;10m+      340[0m:[38;5;10m[49m         
[0m[49m[38;5;10m+      341[0m:[38;5;10m[49m         // Also compute metabolic tumor volume from PET
[0m[49m[38;5;10m+      342[0m:[38;5;10m[49m         pet_volume = registered_volumes["PET"].registered_volume
[0m[49m[38;5;10m+      343[0m:[38;5;10m[49m         metabolic_active = threshold pet_volume at SUV > 2.5  // common clinical threshold
[0m[49m[39m  423, 344[0m:[39m[49m         
[0m[49m[38;5;9m- 424     [0m:[38;5;9m[49m         metrics = {
[0m[49m[38;5;9m- 425     [0m:[38;5;9m[49m             volume_change_percent: compute_volume_change(pre_contour, post_contour["GTV"]),
[0m[49m[38;5;9m- 426     [0m:[38;5;9m[49m             suv_max_change: compute_suv_change(fused, pre_contour, post_contour["GTV"]),
[0m[49m[38;5;9m- 427     [0m:[38;5;9m[49m             metabolic_tumor_volume_change: compute_mtv_change(fused, pre_contour, post_contour)
[0m[49m[38;5;10m+      345[0m:[38;5;10m[49m         RETURN {
[0m[49m[38;5;10m+      346[0m:[38;5;10m[49m             propagated_contours: ct_contours,
[0m[49m[38;5;10m+      347[0m:[38;5;10m[49m             metabolic_volume: metabolic_active,
[0m[49m[38;5;10m+      348[0m:[38;5;10m[49m             biological_target_volume: intersection of anatomical and metabolic volumes
[0m[49m[39m  428, 349[0m:[39m[49m         }
[0m[49m[38;5;9m- 429     [0m:[38;5;9m[49m         RETURN metrics
[0m[49m[38;5;10m+      350[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      351[0m:[38;5;10m[49m     ELSE IF clinical_task == "radiomics":
[0m[49m[38;5;10m+      352[0m:[38;5;10m[49m         // Extract quantitative features from each modality within defined ROIs
