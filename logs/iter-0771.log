[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m *The main recipe's Step 1 assembles patient timelines from EHR, claims, pharmacy, and lab systems. Here we generate realistic synthetic data that mimics the structure of those timelines. In production, this step would be a Glue ETL job pulling from your actual data sources.*
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m import numpy as np
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m import pandas as pd
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m from datetime import datetime, timedelta
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m def generate_synthetic_timeline(patient_id: str, risk_profile: str = "rising") -> dict:
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m     Generate a synthetic patient timeline for demonstration purposes.
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m     Creates a realistic sequence of clinical events over 2 years, with
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m     different risk profiles to show how the timing model responds to
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m     different trajectory shapes.
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m         patient_id: Unique patient identifier
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m         risk_profile: One of "rising", "stable_high", "sudden_spike", "improving"
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m                       Controls the shape of the risk trajectory in the synthetic data.
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m         A patient timeline dict matching the schema from the main recipe.
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m     np.random.seed(hash(patient_id) % 2**32)
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m     end_date = datetime(2026, 5, 31)
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m     start_date = end_date - timedelta(days=LOOKBACK_DAYS)
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m     events = []
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m     # Generate encounters (office visits, ED visits, inpatient stays)
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m     # Frequency depends on risk profile: sicker patients have more encounters.
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m     if risk_profile == "rising":
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m         # Encounters accelerate over time: quarterly early, monthly later
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m         encounter_dates = []
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m         current = start_date
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m         gap_days = 90  # start with quarterly visits
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m         while current < end_date:
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m             encounter_dates.append(current)
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m             # Gradually decrease gap (more frequent visits as risk rises)
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m             gap_days = max(14, gap_days - np.random.randint(5, 15))
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m             current += timedelta(days=gap_days + np.random.randint(-5, 5))
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m     elif risk_profile == "stable_high":
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m         # Consistent monthly encounters
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m         encounter_dates = [
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m             start_date + timedelta(days=30 * i + np.random.randint(-3, 3))
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m             for i in range(24)
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m         ]
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m     elif risk_profile == "sudden_spike":
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m         # Quarterly visits, then a burst of activity in the last 2 weeks
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m         encounter_dates = [
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m             start_date + timedelta(days=90 * i + np.random.randint(-5, 5))
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m             for i in range(8)
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m         ]
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m         # Add sudden burst
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m         for i in range(4):
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m             encounter_dates.append(end_date - timedelta(days=np.random.randint(1, 14)))
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m     else:  # improving
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m         # Frequent early, tapering off
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m         encounter_dates = []
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m         current = start_date
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m         gap_days = 14
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m         while current < end_date:
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m             encounter_dates.append(current)
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m             gap_days = min(120, gap_days + np.random.randint(3, 10))
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m             current += timedelta(days=gap_days)
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m     for enc_date in encounter_dates:
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m         # Most encounters are outpatient; sprinkle in ED visits for high-risk profiles
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m         enc_type = "outpatient"
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m         if risk_profile in ("rising", "stable_high") and np.random.random() < 0.1:
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m             enc_type = "ED"
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m         elif risk_profile == "sudden_spike" and enc_date > end_date - timedelta(days=14):
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m             enc_type = "ED" if np.random.random() < 0.3 else "outpatient"
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m         events.append({
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m             "timestamp": enc_date.isoformat(),
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m             "event_type": "encounter",
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m             "event_subtype": enc_type,
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m             "attributes": {
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m                 "diagnosis_codes": ["E11.9"],  # Type 2 diabetes, simplified
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m                 "provider_type": "endocrinology" if np.random.random() < 0.3 else "primary_care",
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m     # Generate A1C lab results (quarterly, with trajectory based on risk profile)
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m     a1c_dates = [start_date + timedelta(days=90 * i) for i in range(9)]
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m     for i, lab_date in enumerate(a1c_dates):
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m         if lab_date > end_date:
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m             break
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m         if risk_profile == "rising":
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m             # A1C drifts upward: 7.2 -> 9.1 over 2 years
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m             a1c_value = 7.2 + (i * 0.25) + np.random.normal(0, 0.1)
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m         elif risk_profile == "stable_high":
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m             # A1C stays elevated around 8.5
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m             a1c_value = 8.5 + np.random.normal(0, 0.3)
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m         elif risk_profile == "sudden_spike":
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m             # A1C stable then jumps
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m             a1c_value = 7.0 + (0.3 if i >= 7 else 0) + np.random.normal(0, 0.1)
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m             if i == 8:
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m                 a1c_value = 9.5  # sudden spike
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m         else:  # improving
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m             a1c_value = 9.0 - (i * 0.2) + np.random.normal(0, 0.1)
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m         events.append({
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m             "timestamp": lab_date.isoformat(),
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m             "event_type": "lab",
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m             "event_subtype": "A1C",
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m             "attributes": {
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m                 "value": round(a1c_value, 1),
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m                 "reference_low": 4.0,
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m                 "reference_high": 5.6,
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m                 "abnormal_flag": "H" if a1c_value > 5.6 else "N",
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m     # Generate medication fills (monthly for adherent, gaps for non-adherent)
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m     med_date = start_date + timedelta(days=np.random.randint(0, 30))
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m     while med_date < end_date:
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m         events.append({
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m             "timestamp": med_date.isoformat(),
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m             "event_type": "medication",
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m             "event_subtype": "fill",
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m             "attributes": {
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m                 "drug_name": "metformin",
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m                 "days_supply": 30,
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m                 "refill_number": len([e for e in events if e["event_type"] == "medication"]),
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m         # Introduce gaps for rising-risk patients (missed refills)
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m         if risk_profile == "rising" and med_date > end_date - timedelta(days=120):
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m             # Increasingly likely to miss refills as risk rises
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m             gap = 30 + np.random.randint(5, 20)  # overdue refills
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m         elif risk_profile == "sudden_spike" and med_date > end_date - timedelta(days=30):
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m             gap = 45  # missed a refill entirely
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m             gap = 30 + np.random.randint(-2, 3)  # normal adherence
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m         med_date += timedelta(days=gap)
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m     # Sort all events chronologically
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m     events.sort(key=lambda e: e["timestamp"])
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m         "patient_id": patient_id,
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m         "timeline": events,
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m         "event_count": len(events),
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m         "span_days": (end_date - start_date).days,
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m ## Step 2: Engineer Temporal Features
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m *The main recipe's Step 2 transforms raw timelines into features that capture temporal dynamics: velocity, acceleration, gaps, and recency. This is where static data becomes timing-aware.*
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m def engineer_temporal_features(timeline: dict, observation_date: datetime) -> dict:
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m     Compute temporal features from a patient timeline at a specific observation point.
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m     These features capture not just current state but rate of change, acceleration,
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m     and gaps. The timing model needs these dynamics to predict when risk will peak.
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m         timeline: Patient timeline dict from Step 1 (or from your data pipeline)
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m         observation_date: The date at which to compute features (today for inference,
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m                          historical dates for training)
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m         Dictionary of feature name -> value. Null values indicate missing data
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m         (the model should handle nulls gracefully via imputation or masking).
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m     events = timeline["timeline"]
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m     features = {}
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m     # Parse timestamps and filter to events before observation_date
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     # (we can't use future events when making predictions)
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m     parsed_events = []
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m     for event in events:
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m         event_date = datetime.fromisoformat(event["timestamp"])
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m         if event_date <= observation_date:
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m             parsed_events.append({**event, "_parsed_date": event_date})
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m     # --- Recency features ---
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m     # How long since key event types? Longer gaps often signal disengagement.
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m     encounters = [e for e in parsed_events if e["event_type"] == "encounter"]
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m     ed_visits = [e for e in parsed_events
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m                  if e["event_type"] == "encounter" and e["event_subtype"] == "ED"]
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m     med_fills = [e for e in parsed_events if e["event_type"] == "medication"]
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m     labs = [e for e in parsed_events if e["event_type"] == "lab"]
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m     features["days_since_last_encounter"] = (
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m         (observation_date - encounters[-1]["_parsed_date"]).days
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m         if encounters else None
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m     features["days_since_last_ed_visit"] = (
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m         (observation_date - ed_visits[-1]["_parsed_date"]).days
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m         if ed_visits else None
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m     features["days_since_last_med_fill"] = (
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m         (observation_date - med_fills[-1]["_parsed_date"]).days
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m         if med_fills else None
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m     features["days_since_last_lab"] = (
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m         (observation_date - labs[-1]["_parsed_date"]).days
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m         if labs else None
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m     # --- Velocity features: rate of change in key lab values ---
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m     # Extract A1C values and compute slope over recent measurements.
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m     a1c_results = [
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m         (e["_parsed_date"], e["attributes"]["value"])
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m         for e in parsed_events
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m         if e["event_type"] == "lab" and e["event_subtype"] == "A1C"
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m     if len(a1c_results) >= 2:
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m         features["a1c_current"] = a1c_results[-1][1]
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m         # Compute slope using last 3 measurements (or all if fewer)
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m         recent_a1c = a1c_results[-3:]
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m         if len(recent_a1c) >= 2:
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m             # Simple linear slope: (last - first) / days between them
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m             days_span = (recent_a1c[-1][0] - recent_a1c[0][0]).days
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m             if days_span > 0:
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m                 value_change = recent_a1c[-1][1] - recent_a1c[0][1]
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m                 features["a1c_slope_per_day"] = value_change / days_span
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m             else:
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m                 features["a1c_slope_per_day"] = 0.0
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m             features["a1c_slope_per_day"] = None
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m         features["a1c_current"] = None
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m         features["a1c_slope_per_day"] = None
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m     # --- Acceleration features: is utilization rate changing? ---
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m     thirty_days_ago = observation_date - timedelta(days=30)
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m     sixty_days_ago = observation_date - timedelta(days=60)
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m     encounters_last_30 = len([
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m         e for e in encounters if e["_parsed_date"] > thirty_days_ago
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m     ])
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m     encounters_prior_30 = len([
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m         e for e in encounters
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m         if sixty_days_ago < e["_parsed_date"] <= thirty_days_ago
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m     ])
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m     features["encounter_acceleration"] = encounters_last_30 - encounters_prior_30
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m     # --- Gap features: missed expected events ---
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m     # Check if the patient is overdue for a medication refill.
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m     if med_fills:
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m         last_fill = med_fills[-1]
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m         days_supply = last_fill["attributes"].get("days_supply", 30)
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m         expected_refill = last_fill["_parsed_date"] + timedelta(days=days_supply)
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m         if observation_date > expected_refill:
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m             features["med_gap_days"] = (observation_date - expected_refill).days
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m             features["med_gap_days"] = 0
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m         features["med_gap_days"] = None
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m     # --- Pattern features ---
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m     features["total_encounters_180d"] = len([
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m         e for e in encounters
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m         if e["_parsed_date"] > observation_date - timedelta(days=180)
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m     ])
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m     features["ed_visits_365d"] = len([
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m         e for e in ed_visits
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m         if e["_parsed_date"] > observation_date - timedelta(days=365)
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m     ])
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m     return features
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m ## Step 3: Predict Hazard Trajectory
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m *The main recipe's Step 3 trains an LSTM-based survival model. Here we use a simplified hazard estimation approach that demonstrates the concept without requiring GPU training infrastructure. In production, you'd replace this with a SageMaker-hosted model endpoint.*
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m def predict_hazard_trajectory(features: dict, horizon_days: int = FORECAST_HORIZON_DAYS) -> list:
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m     Predict the daily hazard trajectory for the next N days.
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m     This is a SIMPLIFIED hazard model for demonstration. It uses the temporal
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m     features to estimate a baseline hazard and a trajectory shape. A real
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m     implementation would call a SageMaker endpoint hosting a trained LSTM or
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m     transformer survival model.
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m     The key insight this demonstrates: hazard isn't flat. It has a shape over time
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m     that depends on the patient's current trajectory. A patient with rising A1C
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m     and a missed medication refill has a hazard that accelerates over the next
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m     few weeks, not a constant elevated risk.
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m         features: Temporal feature dict from Step 2
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m         horizon_days: How many days ahead to forecast
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m         List of daily hazard values (probability of event on each day,
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m         conditional on survival to that day). Length = horizon_days.
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m     # --- Compute baseline hazard from current state ---
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m     # In a real model, this comes from the neural network's output layer.
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m     # Here we use a simple logistic combination of features.
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m     baseline = 0.01  # population average daily hazard
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m     # A1C contribution: higher A1C = higher baseline hazard
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m     a1c = features.get("a1c_current")
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m     if a1c is not None:
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m         # Hazard increases exponentially above A1C of 7.0
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m         if a1c > 7.0:
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m             baseline += 0.005 * (a1c - 7.0) ** 1.5
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m     # Medication gap contribution: overdue refills increase hazard
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m     med_gap = features.get("med_gap_days")
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m     if med_gap is not None and med_gap > 0:
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m         # Hazard grows with days overdue (non-linear: worse the longer you wait)
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m         baseline += 0.002 * (med_gap / 7) ** 1.2
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m     # ED visit recency: recent ED visit indicates instability
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m     days_since_ed = features.get("days_since_last_ed_visit")
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m     if days_since_ed is not None and days_since_ed < 30:
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m         baseline += 0.01 * (1 - days_since_ed / 30)
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m     # --- Compute trajectory shape from velocity features ---
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m     # The slope determines whether hazard is rising, flat, or falling.
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m     a1c_slope = features.get("a1c_slope_per_day", 0) or 0
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m     encounter_accel = features.get("encounter_acceleration", 0) or 0
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m     # Daily hazard growth rate: how much the hazard changes per day
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m     # Positive slope + accelerating encounters = rising hazard
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m     daily_growth = (a1c_slope * 50) + (encounter_accel * 0.003)
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m     # --- Generate the trajectory ---
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m     trajectory = []
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m     current_hazard = baseline
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m     for day in range(horizon_days):
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m         # Apply growth (hazard changes over time based on trajectory)
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m         current_hazard += daily_growth
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m         # Clamp to reasonable bounds (hazard can't be negative or > 1)
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m         current_hazard = max(0.001, min(0.5, current_hazard))
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m         trajectory.append(round(current_hazard, 6))
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m     return trajectory
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m # --- SageMaker integration point ---
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m # In production, replace predict_hazard_trajectory with a call to your
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m # trained model endpoint:
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m #
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m # import boto3
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m # from botocore.config import Config
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m #
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m # sagemaker_runtime = boto3.client(
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m #     "sagemaker-runtime",
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m #     config=Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m # )
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m #
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m # def predict_hazard_trajectory_sagemaker(features: dict) -> list:
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m #     """Call the SageMaker endpoint hosting the trained survival model."""
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m #     import json
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m #     response = sagemaker_runtime.invoke_endpoint(
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m #         EndpointName="intervention-timing-model-v1",
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m #         ContentType="application/json",
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m #         Body=json.dumps({"features": features}),
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m #     )
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m #     result = json.loads(response["Body"].read())
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m #     return result["hazard_trajectory"]
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m ## Step 4: Score Intervention Windows
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m *The main recipe's Step 4 applies decision logic to the hazard trajectory. This is where "risk prediction" becomes "timing recommendation." The scoring function identifies whether the patient is in an optimal intervention window based on the shape of their predicted trajectory.*
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m def score_intervention_window(
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m     patient_id: str,
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m     hazard_trajectory: list,
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m     days_since_last_intervention: int = 30,
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m     last_intervention_outcome: str = "engaged",
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m     Determine whether now is the right time to intervene for this patient.
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m     The core logic: interventions work best when risk is rising but hasn't peaked.
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m     You want to catch the patient on the upslope, not at the top (too late) or
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m     on the flat (too early, they won't engage).
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m         patient_id: Patient identifier
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m         hazard_trajectory: List of daily hazard values from Step 3
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m         days_since_last_intervention: Days since care team last reached out
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m         last_intervention_outcome: "engaged", "no_answer", or "declined"
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m         Intervention scoring result with recommended action and timing window.
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m     # Compute trajectory characteristics
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m     current_hazard = hazard_trajectory[0]
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m     peak_hazard = max(hazard_trajectory)
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m     peak_day = hazard_trajectory.index(peak_hazard)
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m     # Slope over first 7 days (is risk rising in the near term?)
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m     if len(hazard_trajectory) >= 7:
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m         hazard_slope = (hazard_trajectory[6] - hazard_trajectory[0]) / 7
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m         hazard_slope = 0.0
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m     # --- Decision logic ---
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m     intervention_score = 0.0
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m     recommended_action = "monitor"
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m     action_window_days = None
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m     # Case 1: Rising risk with peak ahead. This is the prime intervention window.
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m     # The patient is deteriorating, but we still have time to change the trajectory.
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m     if hazard_slope > 0.001 and 2 < peak_day < 14:
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m         # Score scales with how fast risk is rising and how much worse it will get
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m         intervention_score = hazard_slope * 100 * (peak_hazard / max(current_hazard, 0.001))
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m     # Case 2: Already at or past peak. Window may be closing.
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m     # Intervene urgently if current risk is high, but acknowledge we may be late.
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m     elif peak_day <= 2 and current_hazard > HIGH_RISK_THRESHOLD:
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m         intervention_score = current_hazard * 50
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m         recommended_action = "urgent_outreach"
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m         action_window_days = 1
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m     # Case 3: Flat high risk. Chronically elevated but not acutely changing.
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m     # Timing is less critical here; schedule outreach at convenience.
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m     elif current_hazard > MODERATE_RISK_THRESHOLD and abs(hazard_slope) < 0.0005:
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m         intervention_score = current_hazard * 20
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m         recommended_action = "scheduled_outreach"
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m         action_window_days = 7
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m     # --- Apply intervention fatigue dampening ---
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m     # Patients who were recently contacted (or who declined) get lower urgency.
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m     # This prevents the "boy who cried wolf" problem.
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m     if days_since_last_intervention < MIN_INTERVENTION_GAP_DAYS:
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m         intervention_score *= FATIGUE_DAMPENING
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m     if last_intervention_outcome == "declined":
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m         intervention_score *= DECLINED_DAMPENING
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m     # --- Determine final recommendation ---
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m     if intervention_score > URGENT_THRESHOLD:
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m         recommended_action = "immediate_outreach"
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m         action_window_days = 2
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m     elif intervention_score > ACTION_THRESHOLD:
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m         recommended_action = "outreach_this_week"
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m         action_window_days = max(1, peak_day - 1)
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m         "patient_id": patient_id,
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m         "intervention_score": round(intervention_score, 1),
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m         "recommended_action": recommended_action,
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m         "action_window_days": action_window_days,
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m         "current_hazard": round(current_hazard, 4),
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m         "predicted_peak_day": peak_day,
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m         "peak_hazard": round(peak_hazard, 4),
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m         "trajectory_slope": round(hazard_slope, 6),
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m         "scored_at": datetime.utcnow().isoformat() + "Z",
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m ## Step 5: Generate Explanations and Recommendations
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m *The main recipe's Step 5 assembles scored patients into an actionable worklist with "why now" explanations. Care managers won't act on a number without understanding what changed.*
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m def generate_explanation(scored_result: dict, features: dict) -> str:
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m     Build a human-readable explanation of why this patient needs outreach now.
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m     This is critical for adoption. A care manager looking at a worklist of 8
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m     patients needs to understand, in 10 seconds, why each patient is there today
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m     and not yesterday or next week. The explanation should reference specific
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m     clinical changes, not model internals.
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m         scored_result: Output from score_intervention_window
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m         features: Temporal features from Step 2 (used to identify clinical drivers)
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m         A plain-English explanation string suitable for display in a care
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m         management platform.
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m     parts = []
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m     # Trajectory shape explanation
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m     if scored_result["trajectory_slope"] > 0.002:
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m         parts.append("Risk trajectory is rising sharply")
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m     elif scored_result["trajectory_slope"] > 0.0005:
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m         parts.append("Risk trajectory is trending upward")
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m     # Peak timing
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m     peak_day = scored_result["predicted_peak_day"]
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m     if 0 < peak_day < 14:
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m         parts.append(f"Predicted risk peak within {peak_day} days")
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m     # Current risk level
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m     if scored_result["current_hazard"] > HIGH_RISK_THRESHOLD:
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m         parts.append("Current risk level is elevated")
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m     # Clinical drivers from features
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m     a1c = features.get("a1c_current")
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m     a1c_slope = features.get("a1c_slope_per_day")
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m     if a1c is not None and a1c > 8.0:
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m         if a1c_slope and a1c_slope > 0:
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m             parts.append(f"A1C at {a1c} and rising")
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m             parts.append(f"A1C elevated at {a1c}")
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m     med_gap = features.get("med_gap_days")
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m     if med_gap and med_gap > 7:
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m         parts.append(f"Medication refill overdue by {med_gap} days")
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m     days_since_enc = features.get("days_since_last_encounter")
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m     if days_since_enc and days_since_enc > 90:
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m         parts.append(f"No encounter in {days_since_enc} days")
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m     return ". ".join(parts) + "." if parts else "Risk score elevated above action threshold."
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m def generate_worklist(scored_patients: list, features_by_patient: dict,
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m                       capacity: int = 8) -> list:
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m     Assemble the final care team worklist from scored patients.
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m     Applies capacity constraints and generates explanations. The output is
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m     what the care manager sees in their workflow tool each morning.
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m         scored_patients: List of scoring results from Step 4
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m         features_by_patient: Dict mapping patient_id -> features from Step 2
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m         capacity: Maximum number of recommendations to generate (care team slots)
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m         List of recommendation dicts, sorted by urgency, capped at capacity.
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m     # Filter to actionable recommendations only
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m     actionable = [s for s in scored_patients if s["recommended_action"] != "monitor"]
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m     # Sort by intervention score (most urgent first)
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m     actionable.sort(key=lambda x: x["intervention_score"], reverse=True)
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m     # Cap at team capacity
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m     recommendations = actionable[:capacity]
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m     # Add explanations
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m     for rec in recommendations:
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m         patient_features = features_by_patient.get(rec["patient_id"], {})
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m         rec["explanation"] = generate_explanation(rec, patient_features)
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m         rec["expires_at"] = (
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m             datetime.utcnow() + timedelta(days=rec["action_window_days"] or 7)
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m         ).isoformat() + "Z"
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m         rec["status"] = "pending"
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m     return recommendations
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m ## Step 6: Store Results in DynamoDB
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m *In production, recommendations are written to DynamoDB for the care management platform to consume. This step shows the storage pattern with proper Decimal handling and TTL for automatic expiration of stale recommendations.*
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m def store_recommendation(recommendation: dict) -> dict:
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m     Write an intervention recommendation to DynamoDB.
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m     The care management platform reads from this table to populate the
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m     care manager's daily worklist. TTL ensures stale recommendations
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m     (where the action window has passed) are automatically cleaned up.
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m         recommendation: A single recommendation dict from generate_worklist
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m         The stored record (with DynamoDB-compatible types).
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m     table = dynamodb.Table(PATIENT_STATE_TABLE)
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m     # Convert floats to Decimal (DynamoDB requirement).
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m     # boto3 will raise TypeError on raw floats in put_item.
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m     record = {
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m         "patient_id": recommendation["patient_id"],
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m         "scored_at": recommendation["scored_at"],
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m         "intervention_score": Decimal(str(recommendation["intervention_score"])),
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m         "recommended_action": recommendation["recommended_action"],
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m         "action_window_days": recommendation.get("action_window_days"),
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m         "current_hazard": Decimal(str(recommendation["current_hazard"])),
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m         "predicted_peak_day": recommendation["predicted_peak_day"],
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m         "peak_hazard": Decimal(str(recommendation["peak_hazard"])),
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m         "trajectory_slope": Decimal(str(recommendation["trajectory_slope"])),
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m         "explanation": recommendation["explanation"],
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m         "expires_at": recommendation["expires_at"],
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m         "status": recommendation["status"],
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m     # TTL: DynamoDB will automatically delete expired recommendations.
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m     # This prevents stale items from cluttering the worklist.
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m     from datetime import timezone
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m     expiry_dt = datetime.fromisoformat(recommendation["expires_at"].replace("Z", "+00:00"))
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m     record["ttl"] = int(expiry_dt.timestamp())
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m     table.put_item(Item=record)
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m     return record
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m ## Putting It All Together
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m Here's the full pipeline assembled into a single callable function. This is what you'd invoke daily (for batch scoring) or on-demand (when a real-time event triggers rescoring for a specific patient).
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m def run_intervention_timing_pipeline(patient_ids: list, capacity: int = 8) -> list:
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m     """
