[0m[49m[38;5;10m+    783[0m:[38;5;10m[49m     # Simulate a care manager's panel of 10 patients
[0m[49m[38;5;10m+    784[0m:[38;5;10m[49m     patient_ids = [f"PAT-{1000 + i}" for i in range(10)]
[0m[49m[38;5;10m+    785[0m:[38;5;10m[49m 
