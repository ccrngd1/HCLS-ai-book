[0m[49m[38;5;10m+    792[0m:[38;5;10m[49m         for key, val in rec.items():
[0m[49m[38;5;10m+    793[0m:[38;5;10m[49m             if isinstance(val, Decimal):
[0m[49m[38;5;10m+    794[0m:[38;5;10m[49m                 rec[key] = float(val)
