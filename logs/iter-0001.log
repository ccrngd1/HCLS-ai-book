[0m[48;2;40;67;43m[39m+    1168[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m AUROC for ICU transfer in 6h [38;2;192;197;206m|[38;2;192;197;206m 0.74-0.80 [38;2;192;197;206m|[38;2;192;197;206m 0.80-0.85 [38;2;192;197;206m|[38;2;192;197;206m 0.83-0.88 [38;2;192;197;206m|[38;2;192;197;206m 0.84-0.89 [38;2;192;197;206m|[38;2;192;197;206m 0.85-0.90 [38;2;192;197;206m|[K
