[49m[38;5;10m+      1[0m:[38;5;10m[49m # Recipe 15.2: Python Implementation Example
[0m[49m[38;5;10m+      2[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      3[0m:[38;5;10m[49m > **Heads up:** This is a deliberately simple, illustrative implementation of the contextual bandit concepts from Recipe 15.2. It shows one way you could translate notification timing optimization into working Python. It is not production-ready. The bandit algorithm here is a basic LinUCB implementation for educational purposes. In production, you'd use Amazon Personalize (which handles the algorithm, exploration, and scaling for you) rather than rolling your own. Think of this as the sketchpad version: useful for understanding the shape of the solution, not something you'd deploy to a patient engagement platform on Monday morning.
[0m[49m[38;5;10m+      4[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      5[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+      6[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      7[0m:[38;5;10m[49m ## Setup
[0m[49m[38;5;10m+      8[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      9[0m:[38;5;10m[49m You'll need the AWS SDK for Python and numpy for the linear algebra in LinUCB:
[0m[49m[38;5;10m+     10[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     11[0m:[38;5;10m[49m ```bash
[0m[49m[38;5;10m+     12[0m:[38;5;10m[49m pip install boto3 numpy
[0m[49m[38;5;10m+     13[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     14[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     15[0m:[38;5;10m[49m Your environment needs credentials configured (via environment variables, an instance profile, or `~/.aws/credentials`). The IAM role or user needs:
[0m[49m[38;5;10m+     16[0m:[38;5;10m[49m - `dynamodb:GetItem`, `dynamodb:PutItem`, `dynamodb:UpdateItem` (patient context store)
[0m[49m[38;5;10m+     17[0m:[38;5;10m[49m - `sqs:ReceiveMessage`, `sqs:DeleteMessage` (message queue)
[0m[49m[38;5;10m+     18[0m:[38;5;10m[49m - `scheduler:CreateSchedule`, `scheduler:DeleteSchedule` (EventBridge Scheduler)
[0m[49m[38;5;10m+     19[0m:[38;5;10m[49m - `mobiletargeting:SendMessages` (Pinpoint delivery)
[0m[49m[38;5;10m+     20[0m:[38;5;10m[49m - `kinesis:PutRecord` (engagement event stream)
[0m[49m[38;5;10m+     21[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     22[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     23[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     24[0m:[38;5;10m[49m ## Config and Constants
[0m[49m[38;5;10m+     25[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     26[0m:[38;5;10m[49m Before we get to the logic, here's the configuration that drives the system. Time slots, safety constraints, reward values, and feature dimensions all live here so they're easy to find and tune.
[0m[49m[38;5;10m+     27[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     28[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     29[0m:[38;5;10m[49m import datetime
[0m[49m[38;5;10m+     30[0m:[38;5;10m[49m from datetime import timezone
[0m[49m[38;5;10m+     31[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+     32[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     33[0m:[38;5;10m[49m # TIME_SLOTS: The discrete set of 30-minute windows the agent can choose from.
[0m[49m[38;5;10m+     34[0m:[38;5;10m[49m # We only consider 7am-9pm (patient's local time). That's 28 slots.
[0m[49m[38;5;10m+     35[0m:[38;5;10m[49m # Each slot is represented as minutes-from-midnight for easy math.
[0m[49m[38;5;10m+     36[0m:[38;5;10m[49m TIME_SLOTS = list(range(420, 1260, 30))  # 420 = 7:00am, 1230 = 8:30pm
[0m[49m[38;5;10m+     37[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     38[0m:[38;5;10m[49m # Human-readable labels for logging and debugging.
[0m[49m[38;5;10m+     39[0m:[38;5;10m[49m def slot_to_time_str(slot_minutes: int) -> str:
[0m[49m[38;5;10m+     40[0m:[38;5;10m[49m     """Convert minutes-from-midnight to 'HH:MM' string."""
[0m[49m[38;5;10m+     41[0m:[38;5;10m[49m     hours = slot_minutes // 60
[0m[49m[38;5;10m+     42[0m:[38;5;10m[49m     minutes = slot_minutes % 60
[0m[49m[38;5;10m+     43[0m:[38;5;10m[49m     return f"{hours:02d}:{minutes:02d}"
[0m[49m[38;5;10m+     44[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     45[0m:[38;5;10m[49m # REWARD_MAP: Maps engagement event types to numeric reward values.
[0m[49m[38;5;10m+     46[0m:[38;5;10m[49m # These drive the learning signal. The asymmetry is intentional:
[0m[49m[38;5;10m+     47[0m:[38;5;10m[49m # completed actions are the gold standard, opt-outs are catastrophic.
[0m[49m[38;5;10m+     48[0m:[38;5;10m[49m REWARD_MAP = {
[0m[49m[38;5;10m+     49[0m:[38;5;10m[49m     "action_completed": 1.0,   # patient refilled, scheduled, etc.
[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m     "link_clicked": 0.5,       # meaningful engagement, no action
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m     "message_opened": 0.3,     # opened but didn't act
[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m     "ignored": 0.0,            # no engagement within 48 hours (baseline)
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m     "unsubscribed": -0.5,      # lost the channel entirely
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m     "spam_reported": -1.0,     # worst case: regulatory risk
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m # SAFETY CONSTRAINTS
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m QUIET_HOURS_START = 21 * 60   # 9:00pm (in minutes from midnight)
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m QUIET_HOURS_END = 7 * 60      # 7:00am
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m MAX_DAILY_MESSAGES = 2         # hard cap per patient per day
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m MAX_WEEKLY_MESSAGES = 7        # hard cap per patient per week
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m # LINUCB PARAMETERS
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m # alpha controls exploration. Higher = more exploration.
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m # 0.25 is a reasonable starting point for notification timing.
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m LINUCB_ALPHA = 0.25
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m # Feature dimension: how many features describe the context.
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m # Patient features (6) + temporal features (4) + message features (3) = 13
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m FEATURE_DIM = 13
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m # Number of actions (time slots the agent can choose from).
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m NUM_ACTIONS = len(TIME_SLOTS)  # 28
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m ## The LinUCB Agent
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m *The main recipe uses Amazon Personalize for the bandit model. Here we implement LinUCB from scratch so you can see what's happening inside. LinUCB models the expected reward for each action as a linear function of context features, and adds an exploration bonus proportional to uncertainty.*
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m import numpy as np
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m class LinUCBAgent:
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m     Linear Upper Confidence Bound agent for contextual bandits.
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m     For each action (time slot), maintains:
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m     - A matrix (A) that accumulates outer products of context features
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m     - A vector (b) that accumulates reward-weighted context features
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m     The estimated reward for action a given context x is:
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m         theta_a = A_a^{-1} * b_a
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m         predicted_reward = theta_a . x
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m         exploration_bonus = alpha * sqrt(x^T * A_a^{-1} * x)
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m         UCB = predicted_reward + exploration_bonus
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m     The agent picks the action with the highest UCB score.
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m     def __init__(self, n_actions: int, n_features: int, alpha: float):
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m         Initialize the agent with identity matrices and zero vectors.
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m         Args:
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m             n_actions: Number of possible actions (time slots).
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m             n_features: Dimension of the context feature vector.
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m             alpha: Exploration parameter. Higher = more exploration.
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m         self.n_actions = n_actions
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m         self.n_features = n_features
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m         self.alpha = alpha
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m         # Per-action matrices. A starts as identity (regularization).
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m         # b starts as zeros (no reward signal yet).
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m         self.A = [np.identity(n_features) for _ in range(n_actions)]
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m         self.b = [np.zeros(n_features) for _ in range(n_actions)]
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m     def select_action(self, context: np.ndarray) -> tuple[int, float]:
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m         Select the best action (time slot) given the current context.
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m         Returns:
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m             Tuple of (action_index, ucb_score) for the selected action.
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m         ucb_scores = np.zeros(self.n_actions)
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m         for a in range(self.n_actions):
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m             # Solve for theta: the learned weight vector for this action.
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m             A_inv = np.linalg.inv(self.A[a])
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m             theta = A_inv @ self.b[a]
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m             # Predicted reward: how good we think this action is.
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m             predicted = context @ theta
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m             # Exploration bonus: how uncertain we are about this action.
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m             # High uncertainty = we haven't tried this action much = explore it.
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m             uncertainty = np.sqrt(context @ A_inv @ context)
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m             ucb_scores[a] = predicted + self.alpha * uncertainty
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m         # Pick the action with the highest UCB score.
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m         best_action = int(np.argmax(ucb_scores))
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m         return best_action, float(ucb_scores[best_action])
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m     def update(self, action: int, context: np.ndarray, reward: float):
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m         Update the model after observing a reward for a (context, action) pair.
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m         This is where learning happens. Each observation tightens the estimate
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m         of how good this action is in similar contexts.
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m         Args:
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m             action: The action index that was taken.
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m             context: The context feature vector at decision time.
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m             reward: The observed reward (from REWARD_MAP).
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m         # Update A: accumulate the outer product of the context.
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m         # This reduces uncertainty for this action in similar contexts.
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m         self.A[action] += np.outer(context, context)
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m         # Update b: accumulate the reward-weighted context.
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m         # This shifts the predicted reward for this action in similar contexts.
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m         self.b[action] += reward * context
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m ## Step 1: Build Context Features
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m *The pseudocode calls this `get_patient_context(patient_id)`. Here we fetch patient data from DynamoDB and assemble the numeric feature vector that the bandit model expects.*
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m PATIENT_TABLE_NAME = "notification-patient-context"
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m def build_context_features(patient_record: dict, message: dict) -> np.ndarray:
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m     Assemble the feature vector from patient data and message metadata.
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m     The feature vector has 13 dimensions:
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m     - [0] historical_open_rate (0.0 to 1.0)
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m     - [1] historical_action_rate (0.0 to 1.0)
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m     - [2] days_since_last_message (normalized: days / 30)
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m     - [3] messages_last_7d (normalized: count / MAX_WEEKLY_MESSAGES)
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m     - [4] fatigue_score (0.0 to 1.0)
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m     - [5] age_bucket_normalized (age_bucket / 10, so 0.0 to ~1.0)
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m     - [6] day_of_week (0=Mon to 6=Sun, normalized: / 6)
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m     - [7] is_weekend (0 or 1)
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m     - [8] is_holiday (0 or 1)
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m     - [9] hour_of_day_normalized (current hour / 23)
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m     - [10] message_type_refill (1 if refill reminder, else 0)
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m     - [11] message_type_appointment (1 if appointment reminder, else 0)
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m     - [12] message_type_education (1 if educational content, else 0)
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m         patient_record: Dict from DynamoDB with patient engagement history.
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m         message: Dict with message metadata (type, channel, urgency).
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m         numpy array of shape (FEATURE_DIM,) with normalized features.
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     now = datetime.datetime.now(timezone.utc)
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m     # Patient features (from stored engagement history).
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m     open_rate = float(patient_record.get("open_rate_30d", 0.15))
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m     action_rate = float(patient_record.get("action_rate_30d", 0.05))
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m     days_since_last = float(patient_record.get("days_since_last_send", 7))
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m     msgs_last_7d = int(patient_record.get("recent_message_count", 0))
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m     fatigue = float(patient_record.get("fatigue_score", 0.0))
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m     age_bucket = int(patient_record.get("age_bucket", 5))
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m     # Temporal features (from current time).
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m     day_of_week = now.weekday()  # 0=Monday, 6=Sunday
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m     is_weekend = 1.0 if day_of_week >= 5 else 0.0
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m     is_holiday = 0.0  # In production, check a holiday calendar.
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m     hour_normalized = now.hour / 23.0
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m     # Message type features (one-hot encoding of the three main types).
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m     msg_type = message.get("type", "other")
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m     type_refill = 1.0 if msg_type == "refill_reminder" else 0.0
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m     type_appointment = 1.0 if msg_type == "appointment_reminder" else 0.0
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m     type_education = 1.0 if msg_type == "education" else 0.0
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m     features = np.array([
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m         open_rate,
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m         action_rate,
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m         min(days_since_last / 30.0, 1.0),       # cap at 1.0
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m         min(msgs_last_7d / MAX_WEEKLY_MESSAGES, 1.0),
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m         fatigue,
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m         age_bucket / 10.0,
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m         day_of_week / 6.0,
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m         is_weekend,
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m         is_holiday,
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m         hour_normalized,
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m         type_refill,
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m         type_appointment,
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m         type_education,
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m     ], dtype=np.float64)
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m     return features
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m def get_patient_context(patient_id: str) -> dict:
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m     Fetch the patient's engagement context from DynamoDB.
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m     Returns a dict with engagement history fields, or defaults for new patients.
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m     table = dynamodb.Table(PATIENT_TABLE_NAME)
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m     response = table.get_item(Key={"patient_id": patient_id})
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m     if "Item" not in response:
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m         # New patient. Return population-level defaults.
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m         # The model will use these until it learns this patient's patterns.
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m         logger.info("No history for patient %s, using defaults", patient_id)
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m             "patient_id": patient_id,
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m             "open_rate_30d": Decimal("0.15"),
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m             "action_rate_30d": Decimal("0.05"),
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m             "days_since_last_send": Decimal("7"),
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m             "recent_message_count": 0,
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m             "fatigue_score": Decimal("0.0"),
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m             "age_bucket": 5,
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m             "timezone": "America/New_York",
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m             "messages_today": 0,
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m     return response["Item"]
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m ## Step 2: Apply Safety Constraints
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m *The pseudocode applies constraints after the model's recommendation. Here we implement the hard safety rules that the model cannot violate: quiet hours, frequency caps, and deadline enforcement.*
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m def is_in_quiet_hours(slot_minutes: int) -> bool:
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m     Check if a time slot falls within quiet hours (9pm-7am).
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m         slot_minutes: Time slot as minutes from midnight.
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m         True if the slot is in quiet hours and should not be used.
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m     # Quiet hours wrap around midnight: 9pm (1260) to 7am (420).
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m     if slot_minutes >= QUIET_HOURS_START:
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m         return True
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m     if slot_minutes < QUIET_HOURS_END:
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m         return True
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m     return False
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m def apply_safety_constraints(
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m     ranked_actions: list[tuple[int, float]],
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m     patient_context: dict,
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m     message: dict,
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m ) -> int:
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m     Filter the model's ranked action list through safety constraints.
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m     Returns the highest-scoring action that passes all constraints.
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m     If no action passes, returns the first valid slot after quiet hours.
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m         ranked_actions: List of (action_index, score) sorted by score descending.
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m         patient_context: Patient record with frequency counters.
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m         message: Message metadata including deadline.
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m         The action index (into TIME_SLOTS) of the selected safe slot.
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m     messages_today = int(patient_context.get("messages_today", 0))
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m     # If frequency cap is already hit, we can't send today at all.
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m     # Return the first valid slot tomorrow (7am = slot index 0).
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m     if messages_today >= MAX_DAILY_MESSAGES:
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m         logger.info("Frequency cap hit for patient. Deferring to tomorrow.")
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m         return 0  # First slot (7:00am) as a placeholder for "tomorrow"
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m     # Walk through ranked actions and find the first one that passes all constraints.
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m     for action_idx, score in ranked_actions:
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m         slot_minutes = TIME_SLOTS[action_idx]
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m         # Constraint 1: Quiet hours.
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m         if is_in_quiet_hours(slot_minutes):
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m         # Constraint 2: Deadline enforcement.
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m         # If the message has a deadline, the slot must be before it.
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m         deadline = message.get("deadline")
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m         if deadline:
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m             deadline_minutes = deadline.hour * 60 + deadline.minute
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m             if slot_minutes > deadline_minutes:
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m         # This slot passes all constraints. Use it.
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m         return action_idx
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m     # Fallback: no slot passed. Use the first non-quiet-hours slot.
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m     # This shouldn't happen in practice (we have 28 daytime slots).
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m     logger.warning("No slot passed constraints. Using first available.")
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m     return 0
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m ## Step 3: Select Optimal Send Time
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m *This is the core decision function. It combines the LinUCB agent's recommendation with safety constraints to produce a final send time.*
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m def select_send_time(
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m     agent: LinUCBAgent,
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m     patient_context: dict,
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m     message: dict,
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m     Use the bandit agent to select the optimal send time for a message.
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m     Combines the model's recommendation with safety constraint enforcement.
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m         agent: The trained LinUCB agent.
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m         patient_context: Patient engagement data from DynamoDB.
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m         message: Message metadata (type, channel, urgency, deadline).
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m         Dict with selected_slot (minutes), time_str, action_index, and score.
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m     # Build the context feature vector.
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m     context = build_context_features(patient_context, message)
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m     # Get UCB scores for all actions.
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m     # We need the full ranking (not just the top pick) so we can apply
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m     # safety constraints and fall through to the next-best option.
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m     ucb_scores = []
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m     for a in range(agent.n_actions):
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m         A_inv = np.linalg.inv(agent.A[a])
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m         theta = A_inv @ agent.b[a]
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m         predicted = context @ theta
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m         uncertainty = np.sqrt(context @ A_inv @ context)
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m         score = predicted + agent.alpha * uncertainty
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m         ucb_scores.append((a, score))
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m     # Sort by score descending (best first).
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m     ranked = sorted(ucb_scores, key=lambda x: x[1], reverse=True)
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m     # Apply safety constraints to find the best valid slot.
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m     selected_action = apply_safety_constraints(ranked, patient_context, message)
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m     selected_slot = TIME_SLOTS[selected_action]
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m     selected_score = ucb_scores[selected_action][1]
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m         "action_index": selected_action,
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m         "selected_slot_minutes": selected_slot,
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m         "time_str": slot_to_time_str(selected_slot),
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m         "score": round(selected_score, 4),
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m         "context_features": context.tolist(),
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m ## Step 4: Record Engagement and Update Model
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m *The pseudocode calls this `process_engagement_event(event)`. Here we map engagement outcomes to rewards and feed them back to the agent for learning.*
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m def compute_reward(event_type: str) -> float:
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m     Map an engagement event type to a numeric reward value.
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m         event_type: One of the keys in REWARD_MAP.
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m         The reward value. Unknown event types get 0.0 (neutral).
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m     reward = REWARD_MAP.get(event_type, 0.0)
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m     return reward
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m def update_agent_with_outcome(
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m     agent: LinUCBAgent,
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m     decision_record: dict,
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m     event_type: str,
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m ):
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m     Feed an engagement outcome back to the agent for learning.
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m     This closes the learning loop. Without this step, the agent never improves.
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m         agent: The LinUCB agent to update.
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m         decision_record: The stored decision (contains action_index and context_features).
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m         event_type: The engagement outcome (key from REWARD_MAP).
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m     reward = compute_reward(event_type)
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m     action = decision_record["action_index"]
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m     context = np.array(decision_record["context_features"])
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m     # Update the agent's model for this action.
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m     agent.update(action, context, reward)
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m         "Updated agent: action=%d (%s), reward=%.2f, event=%s",
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m         action,
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m         slot_to_time_str(TIME_SLOTS[action]),
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m         reward,
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m         event_type,
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m ## Step 5: Update Patient Context
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m *After each engagement outcome, update the patient's stored features so future decisions reflect their latest behavior.*
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m def update_patient_context(patient_id: str, event_type: str):
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m     Update the patient's engagement history in DynamoDB after an outcome.
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m     Recalculates rolling engagement rates and fatigue score.
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m     In production, you'd use atomic counters and conditional updates
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m     to handle concurrent writes safely.
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m         patient_id: The patient whose context to update.
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m         event_type: The engagement outcome type.
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m     table = dynamodb.Table(PATIENT_TABLE_NAME)
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m     # Increment the appropriate counter based on outcome.
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m     # This is simplified. Production would maintain rolling 30-day windows.
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m     update_expr = "SET last_engagement_time = :now"
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m     expr_values = {":now": datetime.datetime.now(timezone.utc).isoformat()}
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m     if event_type in ("action_completed", "link_clicked", "message_opened"):
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m         update_expr += ", messages_engaged = if_not_exists(messages_engaged, :zero) + :one"
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m         expr_values[":one"] = 1
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m         expr_values[":zero"] = 0
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m     elif event_type == "ignored":
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m         update_expr += ", fatigue_score = if_not_exists(fatigue_score, :zero) + :fatigue_inc"
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m         expr_values[":fatigue_inc"] = Decimal("0.05")
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m         expr_values[":zero"] = Decimal("0")
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m     elif event_type == "unsubscribed":
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m         update_expr += ", channel_active = :false_val"
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m         expr_values[":false_val"] = False
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m     table.update_item(
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m         Key={"patient_id": patient_id},
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m         UpdateExpression=update_expr,
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m         ExpressionAttributeValues=expr_values,
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m     logger.info("Updated context for patient %s after %s", patient_id, event_type)
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m ## Putting It All Together
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m Here's the full pipeline assembled into a simulation that demonstrates the learning loop. Since we can't actually send messages and wait for engagement in a code example, we simulate patient behavior to show how the agent improves over time.
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m import random
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m def simulate_patient_engagement(slot_minutes: int, patient_prefs: dict) -> str:
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m     Simulate whether a patient engages with a message sent at a given time.
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m     This replaces real engagement tracking for demonstration purposes.
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m     Each simulated patient has preferred hours where engagement probability is higher.
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m         slot_minutes: When the message was sent (minutes from midnight).
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m         patient_prefs: Dict with 'preferred_hours' (list of hour ints) and
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m                        'base_engagement_rate' (float).
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m         An event type string (key from REWARD_MAP).
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m     hour = slot_minutes // 60
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m     preferred = patient_prefs.get("preferred_hours", [18, 19, 20])
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m     base_rate = patient_prefs.get("base_engagement_rate", 0.1)
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m     # Engagement probability is 3x higher during preferred hours.
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m     if hour in preferred:
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m         engage_prob = min(base_rate * 3.0, 0.9)
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m         engage_prob = base_rate
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m     roll = random.random()
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m     if roll < engage_prob * 0.4:
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m         return "action_completed"
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m     elif roll < engage_prob * 0.7:
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m         return "message_opened"
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m     elif roll < engage_prob:
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m         return "link_clicked"
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m         return "ignored"
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m def run_notification_timing_simulation():
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m     Run a full simulation demonstrating the learning loop.
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m     Creates a LinUCB agent, simulates 500 message sends to a patient with
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m     known preferences, and shows how the agent converges on the optimal timing.
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m     print("Notification Timing Optimization: LinUCB Simulation")
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m     # Initialize the agent.
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m     agent = LinUCBAgent(
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m         n_actions=NUM_ACTIONS,
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m         n_features=FEATURE_DIM,
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m         alpha=LINUCB_ALPHA,
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m     # Simulated patient: prefers evening messages (6pm-8pm).
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m     patient_prefs = {
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m         "preferred_hours": [18, 19, 20],
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m         "base_engagement_rate": 0.15,
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m     # Simulated patient context (what we'd fetch from DynamoDB).
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m     patient_context = {
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m         "patient_id": "pat-sim-001",
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m         "open_rate_30d": Decimal("0.15"),
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m         "action_rate_30d": Decimal("0.05"),
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m         "days_since_last_send": Decimal("3"),
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m         "recent_message_count": 1,
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m         "fatigue_score": Decimal("0.1"),
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m         "age_bucket": 6,
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m         "timezone": "America/New_York",
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m         "messages_today": 0,
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m     message = {
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m         "type": "refill_reminder",
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m         "channel": "push",
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m         "urgency": "normal",
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m         "deadline": None,
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m 
