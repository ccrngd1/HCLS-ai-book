[0m[49m[38;5;10m+    1915[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1916[0m:[38;5;10m[49m     table = dynamodb.Table(COORDINATION_STATE_TABLE)
[0m[49m[38;5;10m+    1917[0m:[38;5;10m[49m     response = table.get_item(Key={"patient_id": patient_id})
[0m[49m[38;5;10m+    1918[0m:[38;5;10m[49m     state = response.get("Item") or {
[0m[49m[38;5;10m+    1919[0m:[38;5;10m[49m         "patient_id":          patient_id,
