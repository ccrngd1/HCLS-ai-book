[0m[49m[38;5;10m+    3335[0m:[38;5;10m[49m                 "at": _now_iso(),
[0m[49m[38;5;10m+    3336[0m:[38;5;10m[49m                 "provenance_id":
[0m[49m[38;5;10m+    3337[0m:[38;5;10m[49m                     referral_event.get(
[0m[49m[38;5;10m+    3338[0m:[38;5;10m[49m                         "provenance_id")}],
[0m[49m[38;5;10m+    3339[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    3340[0m:[38;5;10m[49m     ref_table.put_item(Item=_to_decimal(new_record))
