[0m[49m[38;5;10m+    1631[0m:[38;5;10m[49m             parsed["patient_id"], source_type,
[0m[49m[38;5;10m+    1632[0m:[38;5;10m[49m             consent_check.get("reason"))
[0m[49m[38;5;10m+    1633[0m:[38;5;10m[49m         return {"action": "consent_denied",
[0m[49m[38;5;10m+    1634[0m:[38;5;10m[49m                 "reason": consent_check.get("reason")}
[0m[49m[38;5;10m+    1635[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1636[0m:[38;5;10m[49m     # Step 2E: write to the provenance journal. Provenance
[0m[49m[38;5;10m+    1637[0m:[38;5;10m[49m     # records are append-only and separately keyed for
[0m[49m[38;5;10m+    1638[0m:[38;5;10m[49m     # blast-radius containment.
[0m[49m[38;5;10m+    1639[0m:[38;5;10m[49m     provenance_id = _write_provenance(
[0m[49m[38;5;10m+    1640[0m:[38;5;10m[49m         patient_id=parsed["patient_id"],
[0m[49m[38;5;10m+    1641[0m:[38;5;10m[49m         source_type=source_type,
[0m[49m[38;5;10m+    1642[0m:[38;5;10m[49m         source_message_id=ingestion_metadata.get(
[0m[49m[38;5;10m+    1643[0m:[38;5;10m[49m             "message_id", str(uuid.uuid4())),
[0m[49m[38;5;10m+    1644[0m:[38;5;10m[49m         source_timestamp=parsed.get("source_timestamp",
[0m[49m[38;5;10m+    1645[0m:[38;5;10m[49m                                     _now_iso()),
[0m[49m[38;5;10m+    1646[0m:[38;5;10m[49m         ingestion_path=ingestion_metadata.get("path",
[0m[49m[38;5;10m+    1647[0m:[38;5;10m[49m                                               "demo"),
[0m[49m[38;5;10m+    1648[0m:[38;5;10m[49m         integrity_hash=_hash_message(str(raw_message)),
[0m[49m[38;5;10m+    1649[0m:[38;5;10m[49m         sensitivity_category=sensitivity["category"],
[0m[49m[38;5;10m+    1650[0m:[38;5;10m[49m         adapter_version=adapter.version)
