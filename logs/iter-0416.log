[0m[49m[38;5;10m+    1481[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1482[0m:[38;5;10m[49m def _check_eligibility(*, patient_id, enrollment_program):
[0m[49m[38;5;10m+    1483[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1484[0m:[38;5;10m[49m     Check the patient against institutional exclusion
[0m[49m[38;5;10m+    1485[0m:[38;5;10m[49m     criteria. Production runs against FHIR chart context
[0m[49m[38;5;10m+    1486[0m:[38;5;10m[49m     and clinical-leadership-defined rules.
[0m[49m[38;5;10m+    1487[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1488[0m:[38;5;10m[49m     # Coordination assistants typically exclude active-
[0m[49m[38;5;10m+    1489[0m:[38;5;10m[49m     # hospice patients (where a hospice-specific tool is
[0m[49m[38;5;10m+    1490[0m:[38;5;10m[49m     # appropriate), patients whose primary coordination is
[0m[49m[38;5;10m+    1491[0m:[38;5;10m[49m     # owned by a contracted external navigator, and minors
[0m[49m[38;5;10m+    1492[0m:[38;5;10m[49m     # in adult-only deployments.
[0m[49m[38;5;10m+    1493[0m:[38;5;10m[49m     chart = mock_ehr_primary.get_patient_data(patient_id)
[0m[49m[38;5;10m+    1494[0m:[38;5;10m[49m     if chart.get("active_hospice"):
[0m[49m[38;5;10m+    1495[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    1496[0m:[38;5;10m[49m             "eligible": False,
[0m[49m[38;5;10m+    1497[0m:[38;5;10m[49m             "reason":   "active_hospice_outside_scope",
[0m[49m[38;5;10m+    1498[0m:[38;5;10m[49m             "recommended_alternative":
[0m[49m[38;5;10m+    1499[0m:[38;5;10m[49m                 "hospice_coordination_program",
[0m[49m[38;5;10m+    1500[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1501[0m:[38;5;10m[49m     if enrollment_program == "adult_chronic_coordination" \
[0m[49m[38;5;10m+    1502[0m:[38;5;10m[49m             and chart.get("age", 30) < 18:
[0m[49m[38;5;10m+    1503[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    1504[0m:[38;5;10m[49m             "eligible": False,
[0m[49m[38;5;10m+    1505[0m:[38;5;10m[49m             "reason":   "minor_in_adult_only_deployment",
[0m[49m[38;5;10m+    1506[0m:[38;5;10m[49m             "recommended_alternative":
[0m[49m[38;5;10m+    1507[0m:[38;5;10m[49m                 "pediatric_coordination_program",
[0m[49m[38;5;10m+    1508[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1509[0m:[38;5;10m[49m     return {"eligible": True}
[0m[49m[38;5;10m+    1510[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1511[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1512[0m:[38;5;10m[49m def _state_specific_consent_provisions(state_of_residence):
[0m[49m[38;5;10m+    1513[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1514[0m:[38;5;10m[49m     Resolve state-specific privacy provisions. Production
[0m[49m[38;5;10m+    1515[0m:[38;5;10m[49m     has the per-state matrix reviewed by counsel familiar
[0m[49m[38;5;10m+    1516[0m:[38;5;10m[49m     with HIPAA, the Information Blocking rule, TEFCA,
[0m[49m[38;5;10m+    1517[0m:[38;5;10m[49m     42 CFR Part 2, and state-specific mental-health, HIV,
[0m[49m[38;5;10m+    1518[0m:[38;5;10m[49m     genetic, and adolescent confidentiality protections.
[0m[49m[38;5;10m+    1519[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1520[0m:[38;5;10m[49m     enhanced_states = {
[0m[49m[38;5;10m+    1521[0m:[38;5;10m[49m         "CA": {"enhanced_protections": True,
[0m[49m[38;5;10m+    1522[0m:[38;5;10m[49m                "statute_refs": [
[0m[49m[38;5;10m+    1523[0m:[38;5;10m[49m                    "CA_LPS_Act",
[0m[49m[38;5;10m+    1524[0m:[38;5;10m[49m                    "CA_CMIA"]},
[0m[49m[38;5;10m+    1525[0m:[38;5;10m[49m         "NY": {"enhanced_protections": True,
[0m[49m[38;5;10m+    1526[0m:[38;5;10m[49m                "statute_refs": [
[0m[49m[38;5;10m+    1527[0m:[38;5;10m[49m                    "NY_MHL"]},
[0m[49m[38;5;10m+    1528[0m:[38;5;10m[49m         "IL": {"enhanced_protections": True,
[0m[49m[38;5;10m+    1529[0m:[38;5;10m[49m                "statute_refs": [
[0m[49m[38;5;10m+    1530[0m:[38;5;10m[49m                    "IL_MHDDC"]},
[0m[49m[38;5;10m+    1531[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1532[0m:[38;5;10m[49m     return enhanced_states.get(
[0m[49m[38;5;10m+    1533[0m:[38;5;10m[49m         state_of_residence,
[0m[49m[38;5;10m+    1534[0m:[38;5;10m[49m         {"enhanced_protections": False,
[0m[49m[38;5;10m+    1535[0m:[38;5;10m[49m          "statute_refs": ["HIPAA_baseline"]})
[0m[49m[38;5;10m+    1536[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1537[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1538[0m:[38;5;10m[49m def _check_state_caregiver_law(state, relationship):
[0m[49m[38;5;10m+    1539[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1540[0m:[38;5;10m[49m     Resolve state-specific caregiver-consent requirements.
[0m[49m[38;5;10m+    1541[0m:[38;5;10m[49m     Some states require notarized HCP/POA documentation;
[0m[49m[38;5;10m+    1542[0m:[38;5;10m[49m     others have specific rules for adolescents and aging
[0m[49m[38;5;10m+    1543[0m:[38;5;10m[49m     adults. Production has the state-by-state matrix
[0m[49m[38;5;10m+    1544[0m:[38;5;10m[49m     reviewed by legal counsel.
[0m[49m[38;5;10m+    1545[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1546[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    1547[0m:[38;5;10m[49m         "state": state,
[0m[49m[38;5;10m+    1548[0m:[38;5;10m[49m         "relationship": relationship,
[0m[49m[38;5;10m+    1549[0m:[38;5;10m[49m         "documentation_required":
[0m[49m[38;5;10m+    1550[0m:[38;5;10m[49m             relationship in {"power_of_attorney",
[0m[49m[38;5;10m+    1551[0m:[38;5;10m[49m                              "healthcare_proxy"},
[0m[49m[38;5;10m+    1552[0m:[38;5;10m[49m         "signoff_completed_at": _now_iso(),
[0m[49m[38;5;10m+    1553[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1554[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1555[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1556[0m:[38;5;10m[49m def _derive_coverage_profile(known_relationships):
[0m[49m[38;5;10m+    1557[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1558[0m:[38;5;10m[49m     Derive the patient's integration coverage profile from
[0m[49m[38;5;10m+    1559[0m:[38;5;10m[49m     the known clinicians, pharmacies, payers, and ancillary
[0m[49m[38;5;10m+    1560[0m:[38;5;10m[49m     services. Production tracks coverage per source with
[0m[49m[38;5;10m+    1561[0m:[38;5;10m[49m     status (connected, pending, unavailable) and adjusts
[0m[49m[38;5;10m+    1562[0m:[38;5;10m[49m     the assistant's confidence accordingly.
[0m[49m[38;5;10m+    1563[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1564[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    1565[0m:[38;5;10m[49m         "clinician_coverage_count":
[0m[49m[38;5;10m+    1566[0m:[38;5;10m[49m             len(known_relationships.get("clinicians", [])),
[0m[49m[38;5;10m+    1567[0m:[38;5;10m[49m         "pharmacy_coverage_count":
[0m[49m[38;5;10m+    1568[0m:[38;5;10m[49m             len(known_relationships.get("pharmacies", [])),
[0m[49m[38;5;10m+    1569[0m:[38;5;10m[49m         "payer_coverage_count":
[0m[49m[38;5;10m+    1570[0m:[38;5;10m[49m             len(known_relationships.get("payers", [])),
[0m[49m[38;5;10m+    1571[0m:[38;5;10m[49m         "ancillary_coverage_count":
[0m[49m[38;5;10m+    1572[0m:[38;5;10m[49m             len(known_relationships.get(
[0m[49m[38;5;10m+    1573[0m:[38;5;10m[49m                 "ancillary_services", [])),
[0m[49m[38;5;10m+    1574[0m:[38;5;10m[49m         "profile":
[0m[49m[38;5;10m+    1575[0m:[38;5;10m[49m             "well_instrumented"
[0m[49m[38;5;10m+    1576[0m:[38;5;10m[49m             if len(known_relationships.get("clinicians", [])) >= 3
[0m[49m[38;5;10m+    1577[0m:[38;5;10m[49m             and len(known_relationships.get("pharmacies", [])) >= 1
[0m[49m[38;5;10m+    1578[0m:[38;5;10m[49m             else "partially_instrumented",
[0m[49m[38;5;10m+    1579[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1580[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    1581[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1582[0m:[38;5;10m[49m The enrollment function is doing seven things in order. First, it validates eligibility against institutional exclusion criteria; patients outside the bot's scope get a referral, not an enrollment. Second, it captures the cross-organizational consent record per data source, per sharing relationship, per sensitive category, with state-specific provisions stamped on. Third, it captures each designated caregiver as a first-class participant with their own identity, access level, sensitive carve-outs, and state-law signoff. Fourth, it captures the known clinicians, pharmacies, payers, and ancillary services. Fifth, it persists the patient-coordination record with preferences and known relationships. Sixth, it initializes the longitudinal coordination-state record with empty registries that ingestion will fill. Seventh, it emits enrollment events for downstream consumers. Skipping any of these undercuts the discipline the rest of the architecture depends on.
[0m[49m[38;5;10m+    1583[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1584[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    1585[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1586[0m:[38;5;10m[49m ## Step 2: Ingest Cross-Organizational Data with Provenance Discipline
[0m[49m[38;5;10m+    1587[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1588[0m:[38;5;10m[49m The ingestion layer is the architectural floor. Every data point ingested is recorded with its source, timestamp, ingestion path, and integrity hash. The ingestion pipeline is composed of per-source adapters; each adapter handles authentication, rate limiting, format translation, sensitive-record classification, and provenance recording. Skip provenance and the assistant's assertions cannot be traced back to specific sources, which is the failure mode that breaks defensibility when something goes wrong.
[0m[49m[38;5;10m+    1589[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1590[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    1591[0m:[38;5;10m[49m def ingest_event(*,
[0m[49m[38;5;10m+    1592[0m:[38;5;10m[49m                   source_type,
[0m[49m[38;5;10m+    1593[0m:[38;5;10m[49m                   raw_message,
[0m[49m[38;5;10m+    1594[0m:[38;5;10m[49m                   ingestion_metadata):
[0m[49m[38;5;10m+    1595[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1596[0m:[38;5;10m[49m     Ingest a cross-organizational data event with provenance.
[0m[49m[38;5;10m+    1597[0m:[38;5;10m[49m     Per-source adapters handle parsing, validation, and
[0m[49m[38;5;10m+    1598[0m:[38;5;10m[49m     normalization; the provenance journal records the source
[0m[49m[38;5;10m+    1599[0m:[38;5;10m[49m     chain for every ingested data point.
[0m[49m[38;5;10m+    1600[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1601[0m:[38;5;10m[49m     # Step 2A: route to the per-source adapter.
[0m[49m[38;5;10m+    1602[0m:[38;5;10m[49m     adapter = _select_adapter(source_type)
[0m[49m[38;5;10m+    1603[0m:[38;5;10m[49m     if adapter is None:
[0m[49m[38;5;10m+    1604[0m:[38;5;10m[49m         return {"action": "rejected",
[0m[49m[38;5;10m+    1605[0m:[38;5;10m[49m                 "reason": "unknown_source_type"}
[0m[49m[38;5;10m+    1606[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1607[0m:[38;5;10m[49m     # Step 2B: parse and validate.
[0m[49m[38;5;10m+    1608[0m:[38;5;10m[49m     parsed = adapter.parse(raw_message)
[0m[49m[38;5;10m+    1609[0m:[38;5;10m[49m     validation = adapter.validate(parsed)
[0m[49m[38;5;10m+    1610[0m:[38;5;10m[49m     if not validation["valid"]:
[0m[49m[38;5;10m+    1611[0m:[38;5;10m[49m         logger.error(
[0m[49m[38;5;10m+    1612[0m:[38;5;10m[49m             "Ingestion validation failed for %s: %s",
[0m[49m[38;5;10m+    1613[0m:[38;5;10m[49m             source_type, validation.get("errors"))
[0m[49m[38;5;10m+    1614[0m:[38;5;10m[49m         return {"action": "rejected",
[0m[49m[38;5;10m+    1615[0m:[38;5;10m[49m                 "reason": "validation_failed"}
[0m[49m[38;5;10m+    1616[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1617[0m:[38;5;10m[49m     # Step 2C: classify sensitive-record category. Some
[0m[49m[38;5;10m+    1618[0m:[38;5;10m[49m     # categories (42 CFR Part 2, mental-health, HIV, genetic,
[0m[49m[38;5;10m+    1619[0m:[38;5;10m[49m     # adolescent confidential) trigger separate handling per
[0m[49m[38;5;10m+    1620[0m:[38;5;10m[49m     # state and federal rules.
[0m[49m[38;5;10m+    1621[0m:[38;5;10m[49m     sensitivity = _classify_sensitivity(parsed)
[0m[49m[38;5;10m+    1622[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1623[0m:[38;5;10m[49m     # Step 2D: enforce per-source consent posture.
[0m[49m[38;5;10m+    1624[0m:[38;5;10m[49m     consent_check = _verify_consent(
[0m[49m[38;5;10m+    1625[0m:[38;5;10m[49m         patient_id=parsed["patient_id"],
[0m[49m[38;5;10m+    1626[0m:[38;5;10m[49m         source_type=source_type,
[0m[49m[38;5;10m+    1627[0m:[38;5;10m[49m         sensitivity_category=sensitivity["category"])
[0m[49m[38;5;10m+    1628[0m:[38;5;10m[49m     if not consent_check["allowed"]:
[0m[49m[38;5;10m+    1629[0m:[38;5;10m[49m         logger.info(
