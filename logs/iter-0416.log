[0m[49m[38;5;10m+    3305[0m:[38;5;10m[49m                 current_state, event_type, referral_id)
[0m[49m[38;5;10m+    3306[0m:[38;5;10m[49m             return {"action": "rejected",
[0m[49m[38;5;10m+    3307[0m:[38;5;10m[49m                     "reason": "invalid_state_transition"}
[0m[49m[38;5;10m+    3308[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    3309[0m:[38;5;10m[49m         # Brand-new referral: must start in "ordered".
[0m[49m[38;5;10m+    3310[0m:[38;5;10m[49m         if event_type != "ordered":
[0m[49m[38;5;10m+    3311[0m:[38;5;10m[49m             logger.error(
[0m[49m[38;5;10m+    3312[0m:[38;5;10m[49m                 "Brand-new referral %s started in %s "
[0m[49m[38;5;10m+    3313[0m:[38;5;10m[49m                 "(expected ordered)",
[0m[49m[38;5;10m+    3314[0m:[38;5;10m[49m                 referral_id, event_type)
[0m[49m[38;5;10m+    3315[0m:[38;5;10m[49m             return {"action": "rejected",
[0m[49m[38;5;10m+    3316[0m:[38;5;10m[49m                     "reason": "invalid_initial_state"}
[0m[49m[38;5;10m+    3317[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3318[0m:[38;5;10m[49m     # Step 8C: persist the new state.
[0m[49m[38;5;10m+    3319[0m:[38;5;10m[49m     new_record = {
[0m[49m[38;5;10m+    3320[0m:[38;5;10m[49m         "referral_id":      referral_id,
[0m[49m[38;5;10m+    3321[0m:[38;5;10m[49m         "patient_id":       patient_id,
[0m[49m[38;5;10m+    3322[0m:[38;5;10m[49m         "specialty":        referral_event.get(
[0m[49m[38;5;10m+    3323[0m:[38;5;10m[49m             "specialty",
[0m[49m[38;5;10m+    3324[0m:[38;5;10m[49m             current.get("specialty") if current else None),
[0m[49m[38;5;10m+    3325[0m:[38;5;10m[49m         "urgency":          referral_event.get(
[0m[49m[38;5;10m+    3326[0m:[38;5;10m[49m             "urgency",
[0m[49m[38;5;10m+    3327[0m:[38;5;10m[49m             current.get("urgency") if current else "routine"),
[0m[49m[38;5;10m+    3328[0m:[38;5;10m[49m         "state":            event_type,
[0m[49m[38;5;10m+    3329[0m:[38;5;10m[49m         "previous_state":
[0m[49m[38;5;10m+    3330[0m:[38;5;10m[49m             current.get("state") if current else None,
[0m[49m[38;5;10m+    3331[0m:[38;5;10m[49m         "transition_at":    _now_iso(),
