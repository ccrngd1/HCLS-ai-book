[0m[49m[38;5;10m+    3342[0m:[38;5;10m[49m     _emit_event("referral_state_changed", {
[0m[49m[38;5;10m+    3343[0m:[38;5;10m[49m         "patient_id":      patient_id,
[0m[49m[38;5;10m+    3344[0m:[38;5;10m[49m         "referral_id":     referral_id,
[0m[49m[38;5;10m+    3345[0m:[38;5;10m[49m         "previous_state":
[0m[49m[38;5;10m+    3346[0m:[38;5;10m[49m             current.get("state") if current else None,
