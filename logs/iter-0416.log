[0m[49m[38;5;10m+    3166[0m:[38;5;10m[49m         "discharge_event":    discharge_event,
[0m[49m[38;5;10m+    3167[0m:[38;5;10m[49m         "protocol_id":        transition_protocol["protocol_id"],
[0m[49m[38;5;10m+    3168[0m:[38;5;10m[49m         "protocol_version":
