[0m[49m[38;5;10m+    2608[0m:[38;5;10m[49m                 latency_ms=0,
[0m[49m[38;5;10m+    2609[0m:[38;5;10m[49m                 outcome="proxy_denied")
[0m[49m[38;5;10m+    2610[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    2611[0m:[38;5;10m[49m 
