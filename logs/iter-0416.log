[0m[49m[38;5;10m+    1843[0m:[38;5;10m[49m     42 CFR Part 2, state-specific mental-health, HIV,
[0m[49m[38;5;10m+    1844[0m:[38;5;10m[49m     genetic-test, and adolescent confidential categories.
[0m[49m[38;5;10m+    1845[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1846[0m:[38;5;10m[49m     diagnosis = (parsed.get("discharge_diagnosis") or "").lower()
