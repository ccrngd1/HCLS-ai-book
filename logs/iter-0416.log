[0m[49m[38;5;10m+    3221[0m:[38;5;10m[49m                 },
[0m[49m[38;5;10m+    3222[0m:[38;5;10m[49m             },
[0m[49m[38;5;10m+    3223[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    3224[0m:[38;5;10m[49m 
