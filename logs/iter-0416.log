[0m[49m[38;5;10m+    1922[0m:[38;5;10m[49m         "open_referrals":      [],
[0m[49m[38;5;10m+    1923[0m:[38;5;10m[49m         "upcoming_encounters": [],
[0m[49m[38;5;10m+    1924[0m:[38;5;10m[49m         "recent_encounters":   [],
[0m[49m[38;5;10m+    1925[0m:[38;5;10m[49m         "recent_test_results": [],
[0m[49m[38;5;10m+    1926[0m:[38;5;10m[49m         "active_care_events":  [],
[0m[49m[38;5;10m+    1927[0m:[38;5;10m[49m         "seam_flags":          [],
[0m[49m[38;5;10m+    1928[0m:[38;5;10m[49m         "state_version":       0,
[0m[49m[38;5;10m+    1929[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1930[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1931[0m:[38;5;10m[49m     kind = normalized_event["kind"]
