[0m[49m[38;5;10m+    3412[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    3413[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3414[0m:[38;5;10m[49m The referral-lifecycle handling step does four things in order. First, it loads the referral's current state. Second, it validates the requested transition against the state machine; invalid transitions are rejected. Third, it persists the new state and emits the lifecycle-changed event. Fourth, it schedules the next protocol-driven action (patient engagement, care-team alert, or referral closure). Open referrals that age out of their protocol window are surfaced for care-management resolution; the referral-closure rate is a leading indicator of coordination quality.
[0m[49m[38;5;10m+    3415[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3416[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    3417[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3418[0m:[38;5;10m[49m ## Step 9: Handle Medication-Reconciliation Seams Across Pharmacies and Clinicians
[0m[49m[38;5;10m+    3419[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3420[0m:[38;5;10m[49m Medication reconciliation is one of the most data-quality-sensitive coordination tasks. The assistant maintains the patient's medication list as a single source of truth synthesized across pharmacies and clinicians. When discrepancies are detected, the assistant flags them for human reconciliation rather than attempting clinical judgment.
[0m[49m[38;5;10m+    3421[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3422[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    3423[0m:[38;5;10m[49m def handle_medication_event(*, patient_id, medication_event):
[0m[49m[38;5;10m+    3424[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    3425[0m:[38;5;10m[49m     Process a medication event from a pharmacy fill, a
[0m[49m[38;5;10m+    3426[0m:[38;5;10m[49m     clinician order, or a patient/caregiver report. Normalize,
[0m[49m[38;5;10m+    3427[0m:[38;5;10m[49m     reconcile against the synthesized list, and surface any
[0m[49m[38;5;10m+    3428[0m:[38;5;10m[49m     seams.
[0m[49m[38;5;10m+    3429[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    3430[0m:[38;5;10m[49m     # Step 9A: classify the source.
[0m[49m[38;5;10m+    3431[0m:[38;5;10m[49m     source_type = medication_event.get("source_type",
[0m[49m[38;5;10m+    3432[0m:[38;5;10m[49m                                          "unknown")
[0m[49m[38;5;10m+    3433[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3434[0m:[38;5;10m[49m     # Step 9B: normalize the medication entry. Production
[0m[49m[38;5;10m+    3435[0m:[38;5;10m[49m     # canonicalizes drug name (RxNorm), dose (UCUM), and
[0m[49m[38;5;10m+    3436[0m:[38;5;10m[49m     # parses dosing instructions; the demo passes through.
[0m[49m[38;5;10m+    3437[0m:[38;5;10m[49m     normalized = {
[0m[49m[38;5;10m+    3438[0m:[38;5;10m[49m         "medication_name":
[0m[49m[38;5;10m+    3439[0m:[38;5;10m[49m             (medication_event.get("medication_name")
[0m[49m[38;5;10m+    3440[0m:[38;5;10m[49m              or "").lower(),
[0m[49m[38;5;10m+    3441[0m:[38;5;10m[49m         "rxnorm_code":
[0m[49m[38;5;10m+    3442[0m:[38;5;10m[49m             medication_event.get("rxnorm_code"),
[0m[49m[38;5;10m+    3443[0m:[38;5;10m[49m         "dose":         medication_event.get("dose"),
[0m[49m[38;5;10m+    3444[0m:[38;5;10m[49m         "frequency":
[0m[49m[38;5;10m+    3445[0m:[38;5;10m[49m             medication_event.get("frequency"),
[0m[49m[38;5;10m+    3446[0m:[38;5;10m[49m         "prescriber_id":
[0m[49m[38;5;10m+    3447[0m:[38;5;10m[49m             medication_event.get("prescriber_id"),
[0m[49m[38;5;10m+    3448[0m:[38;5;10m[49m         "pharmacy_id":
[0m[49m[38;5;10m+    3449[0m:[38;5;10m[49m             medication_event.get("pharmacy_id"),
