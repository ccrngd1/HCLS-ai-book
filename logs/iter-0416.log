[0m[49m[38;5;10m+    3298[0m:[38;5;10m[49m         current_state = current.get("state")
[0m[49m[38;5;10m+    3299[0m:[38;5;10m[49m         permitted = REFERRAL_LIFECYCLE_TRANSITIONS.get(
[0m[49m[38;5;10m+    3300[0m:[38;5;10m[49m             current_state, set())
