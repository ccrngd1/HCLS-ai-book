[0m[49m[38;5;10m+    3546[0m:[38;5;10m[49m             "priority": "medium_to_high",
[0m[49m[38;5;10m+    3547[0m:[38;5;10m[49m             "suggested_resolver": "care_team",
[0m[49m[38;5;10m+    3548[0m:[38;5;10m[49m             "evidence": {
[0m[49m[38;5;10m+    3549[0m:[38;5;10m[49m                 "medication_name": name,
[0m[49m[38;5;10m+    3550[0m:[38;5;10m[49m                 "doses_observed": sorted(distinct_doses),
[0m[49m[38;5;10m+    3551[0m:[38;5;10m[49m                 "pharmacies": list(pharmacy_doses.keys()),
[0m[49m[38;5;10m+    3552[0m:[38;5;10m[49m             },
[0m[49m[38;5;10m+    3553[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    3554[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3555[0m:[38;5;10m[49m     # Discrepancy between clinicians for high-risk classes.
[0m[49m[38;5;10m+    3556[0m:[38;5;10m[49m     high_risk_classes = {
[0m[49m[38;5;10m+    3557[0m:[38;5;10m[49m         "warfarin", "apixaban", "rivaroxaban",
[0m[49m[38;5;10m+    3558[0m:[38;5;10m[49m         "furosemide", "insulin", "prednisone",
[0m[49m[38;5;10m+    3559[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    3560[0m:[38;5;10m[49m     if any(cls in name for cls in high_risk_classes):
[0m[49m[38;5;10m+    3561[0m:[38;5;10m[49m         prescribers = {normalized.get("prescriber_id")}
[0m[49m[38;5;10m+    3562[0m:[38;5;10m[49m         for m in matching:
[0m[49m[38;5;10m+    3563[0m:[38;5;10m[49m             prescribers.add(m.get("prescriber_id"))
[0m[49m[38;5;10m+    3564[0m:[38;5;10m[49m         prescribers.discard(None)
[0m[49m[38;5;10m+    3565[0m:[38;5;10m[49m         if len(prescribers) > 1:
[0m[49m[38;5;10m+    3566[0m:[38;5;10m[49m             seams.append({
[0m[49m[38;5;10m+    3567[0m:[38;5;10m[49m                 "rule_id":
[0m[49m[38;5;10m+    3568[0m:[38;5;10m[49m                     "conflicting_clinician_orders_for_high_risk_class",
[0m[49m[38;5;10m+    3569[0m:[38;5;10m[49m                 "description":
[0m[49m[38;5;10m+    3570[0m:[38;5;10m[49m                     f"High-risk medication '{name}' has "
[0m[49m[38;5;10m+    3571[0m:[38;5;10m[49m                     "orders from multiple clinicians "
[0m[49m[38;5;10m+    3572[0m:[38;5;10m[49m                     "without recorded coordination.",
[0m[49m[38;5;10m+    3573[0m:[38;5;10m[49m                 "priority": "high",
[0m[49m[38;5;10m+    3574[0m:[38;5;10m[49m                 "suggested_resolver": "care_team",
[0m[49m[38;5;10m+    3575[0m:[38;5;10m[49m                 "evidence": {
[0m[49m[38;5;10m+    3576[0m:[38;5;10m[49m                     "medication_name": name,
[0m[49m[38;5;10m+    3577[0m:[38;5;10m[49m                     "prescribers": list(prescribers),
[0m[49m[38;5;10m+    3578[0m:[38;5;10m[49m                 },
[0m[49m[38;5;10m+    3579[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    3580[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3581[0m:[38;5;10m[49m     return {"seams": seams}
[0m[49m[38;5;10m+    3582[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    3583[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3584[0m:[38;5;10m[49m The medication-reconciliation step does five things in order. First, it classifies the source (pharmacy fill, clinician order, patient report, etc.). Second, it normalizes the medication entry (RxNorm, UCUM in production). Third, it loads the patient's current synthesized list. Fourth, it reconciles the new entry against the list, detecting discrepancies between pharmacies and conflicts between clinicians for high-risk drug classes. Fifth, it surfaces detected seams to the care team for human reconciliation. The bot does not make clinical reconciliation decisions; the bot surfaces the seams for the clinicians who can.
[0m[49m[38;5;10m+    3585[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3586[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    3587[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3588[0m:[38;5;10m[49m ## Step 10: Generate Care-Team Reporting
[0m[49m[38;5;10m+    3589[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3590[0m:[38;5;10m[49m The care team has visibility into the assistant's activity through real-time alerts (already streamed during operations) plus periodic summaries. The reporting is designed for the care team's workflow and reviewed by clinical leadership before launch.
[0m[49m[38;5;10m+    3591[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3592[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    3593[0m:[38;5;10m[49m def compose_weekly_digest(patient_id, window_days=7):
[0m[49m[38;5;10m+    3594[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    3595[0m:[38;5;10m[49m     Compose a weekly digest for the care team summarizing
[0m[49m[38;5;10m+    3596[0m:[38;5;10m[49m     the assistant's activity for a single patient. Returns
[0m[49m[38;5;10m+    3597[0m:[38;5;10m[49m     None if consent does not permit care-team sharing.
[0m[49m[38;5;10m+    3598[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    3599[0m:[38;5;10m[49m     # Step 10A: confirm consent. Consent is checked at
[0m[49m[38;5;10m+    3600[0m:[38;5;10m[49m     # delivery time, not just enrollment, because consent
[0m[49m[38;5;10m+    3601[0m:[38;5;10m[49m     # is revocable.
[0m[49m[38;5;10m+    3602[0m:[38;5;10m[49m     consent_table = dynamodb.Table(CONSENT_RECORD_TABLE)
[0m[49m[38;5;10m+    3603[0m:[38;5;10m[49m     consent_response = consent_table.get_item(
[0m[49m[38;5;10m+    3604[0m:[38;5;10m[49m         Key={"patient_id": patient_id})
[0m[49m[38;5;10m+    3605[0m:[38;5;10m[49m     consent = consent_response.get("Item") or {}
[0m[49m[38;5;10m+    3606[0m:[38;5;10m[49m     if "with_care_management" not in \
[0m[49m[38;5;10m+    3607[0m:[38;5;10m[49m             consent.get(
[0m[49m[38;5;10m+    3608[0m:[38;5;10m[49m                 "sharing_relationships_consented", []):
[0m[49m[38;5;10m+    3609[0m:[38;5;10m[49m         logger.info(
[0m[49m[38;5;10m+    3610[0m:[38;5;10m[49m             "Care-team digest skipped for %s: consent "
[0m[49m[38;5;10m+    3611[0m:[38;5;10m[49m             "does not permit sharing.", patient_id)
[0m[49m[38;5;10m+    3612[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+    3613[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3614[0m:[38;5;10m[49m     cutoff = _now() - timedelta(days=window_days)
[0m[49m[38;5;10m+    3615[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3616[0m:[38;5;10m[49m     # Step 10B: gather seam-flag activity in the window.
[0m[49m[38;5;10m+    3617[0m:[38;5;10m[49m     seam_table = dynamodb.Table(SEAM_FLAG_TABLE)
[0m[49m[38;5;10m+    3618[0m:[38;5;10m[49m     seam_items = [
[0m[49m[38;5;10m+    3619[0m:[38;5;10m[49m         f for f in seam_table.scan().get("Items", [])
[0m[49m[38;5;10m+    3620[0m:[38;5;10m[49m         if f.get("patient_id") == patient_id
[0m[49m[38;5;10m+    3621[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    3622[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3623[0m:[38;5;10m[49m     # Step 10C: gather referral lifecycle activity.
[0m[49m[38;5;10m+    3624[0m:[38;5;10m[49m     ref_table = dynamodb.Table(REFERRAL_LIFECYCLE_TABLE)
[0m[49m[38;5;10m+    3625[0m:[38;5;10m[49m     ref_items = [
[0m[49m[38;5;10m+    3626[0m:[38;5;10m[49m         r for r in ref_table.scan().get("Items", [])
[0m[49m[38;5;10m+    3627[0m:[38;5;10m[49m         if r.get("patient_id") == patient_id
[0m[49m[38;5;10m+    3628[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    3629[0m:[38;5;10m[49m     open_referrals = [
[0m[49m[38;5;10m+    3630[0m:[38;5;10m[49m         r for r in ref_items
[0m[49m[38;5;10m+    3631[0m:[38;5;10m[49m         if r.get("state") in {
[0m[49m[38;5;10m+    3632[0m:[38;5;10m[49m             "ordered", "communicated_to_patient",
[0m[49m[38;5;10m+    3633[0m:[38;5;10m[49m             "scheduled", "rescheduled"}
[0m[49m[38;5;10m+    3634[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    3635[0m:[38;5;10m[49m 
