[0m[49m[38;5;10m+    3361[0m:[38;5;10m[49m                 "MessageConfiguration": {
[0m[49m[38;5;10m+    3362[0m:[38;5;10m[49m                     "PushNotificationTemplate": {
[0m[49m[38;5;10m+    3363[0m:[38;5;10m[49m                         "Body":
[0m[49m[38;5;10m+    3364[0m:[38;5;10m[49m                             "Quick check-in on your "
[0m[49m[38;5;10m+    3365[0m:[38;5;10m[49m                             f"{new_record['specialty']} "
[0m[49m[38;5;10m+    3366[0m:[38;5;10m[49m                             "referral. Has it been "
