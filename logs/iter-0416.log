[0m[49m[38;5;10m+    1905[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1906[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1907[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1908[0m:[38;5;10m[49m def _update_coordination_state(*, patient_id, update_type,
