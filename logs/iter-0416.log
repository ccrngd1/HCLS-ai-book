[0m[49m[38;5;10m+    2600[0m:[38;5;10m[49m         # proxy posture.
[0m[49m[38;5;10m+    2601[0m:[38;5;10m[49m         if not _proxy_scope_permits(tc, role_record):
[0m[49m[38;5;10m+    2602[0m:[38;5;10m[49m             _audit_tool_call(
