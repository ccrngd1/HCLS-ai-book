[0m[49m[38;5;10m+    3368[0m:[38;5;10m[49m                     },
[0m[49m[38;5;10m+    3369[0m:[38;5;10m[49m                 },
[0m[49m[38;5;10m+    3370[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    3371[0m:[38;5;10m[49m     elif next_action["type"] == "alert_care_team":
