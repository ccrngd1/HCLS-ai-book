[0m[49m[38;5;10m+    3507[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3508[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3509[0m:[38;5;10m[49m def _reconcile_medication_entry(*, normalized, current_meds):
[0m[49m[38;5;10m+    3510[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    3511[0m:[38;5;10m[49m     Reconcile a normalized medication entry against the
[0m[49m[38;5;10m+    3512[0m:[38;5;10m[49m     current synthesized list. Detect discrepancies between
[0m[49m[38;5;10m+    3513[0m:[38;5;10m[49m     pharmacies, between clinicians, between patient-reported
[0m[49m[38;5;10m+    3514[0m:[38;5;10m[49m     and source-recorded data.
[0m[49m[38;5;10m+    3515[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    3516[0m:[38;5;10m[49m     seams = []
[0m[49m[38;5;10m+    3517[0m:[38;5;10m[49m     name = normalized["medication_name"]
[0m[49m[38;5;10m+    3518[0m:[38;5;10m[49m     new_dose = str(normalized.get("dose") or "")
[0m[49m[38;5;10m+    3519[0m:[38;5;10m[49m     if not name:
[0m[49m[38;5;10m+    3520[0m:[38;5;10m[49m         return {"seams": []}
[0m[49m[38;5;10m+    3521[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3522[0m:[38;5;10m[49m     matching = [
[0m[49m[38;5;10m+    3523[0m:[38;5;10m[49m         m for m in current_meds
[0m[49m[38;5;10m+    3524[0m:[38;5;10m[49m         if (m.get("medication_name") or "").lower() == name
[0m[49m[38;5;10m+    3525[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    3526[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3527[0m:[38;5;10m[49m     # Discrepancy across pharmacies.
[0m[49m[38;5;10m+    3528[0m:[38;5;10m[49m     pharmacy_doses = defaultdict(set)
[0m[49m[38;5;10m+    3529[0m:[38;5;10m[49m     pharmacy_doses[
[0m[49m[38;5;10m+    3530[0m:[38;5;10m[49m         normalized.get("pharmacy_id") or "report"].add(
[0m[49m[38;5;10m+    3531[0m:[38;5;10m[49m             new_dose)
[0m[49m[38;5;10m+    3532[0m:[38;5;10m[49m     for m in matching:
[0m[49m[38;5;10m+    3533[0m:[38;5;10m[49m         pid = m.get("pharmacy_id") or "report"
[0m[49m[38;5;10m+    3534[0m:[38;5;10m[49m         pharmacy_doses[pid].add(str(m.get("dose") or ""))
[0m[49m[38;5;10m+    3535[0m:[38;5;10m[49m     distinct_doses = set()
[0m[49m[38;5;10m+    3536[0m:[38;5;10m[49m     for doses in pharmacy_doses.values():
[0m[49m[38;5;10m+    3537[0m:[38;5;10m[49m         distinct_doses.update(doses)
[0m[49m[38;5;10m+    3538[0m:[38;5;10m[49m     if len(distinct_doses) > 1:
[0m[49m[38;5;10m+    3539[0m:[38;5;10m[49m         seams.append({
[0m[49m[38;5;10m+    3540[0m:[38;5;10m[49m             "rule_id":
[0m[49m[38;5;10m+    3541[0m:[38;5;10m[49m                 "medication_discrepancy_between_pharmacies",
[0m[49m[38;5;10m+    3542[0m:[38;5;10m[49m             "description":
[0m[49m[38;5;10m+    3543[0m:[38;5;10m[49m                 f"Medication '{name}' has different "
[0m[49m[38;5;10m+    3544[0m:[38;5;10m[49m                 f"recorded doses across sources: "
