[0m[49m[39m  172, 181[0m:[39m[49m 
[0m[49m[39m  173, 182[0m:[39m[49m ### Code (Pseudocode Walkthrough)
[0m[49m[39m  174, 183[0m:[39m[49m 
[0m[49m[39m  175, 184[0m:[39m[49m #### Step 1: Receive and Validate the Wound Image
[0m[49m[39m  176, 185[0m:[39m[49m 
[0m[49m[39m  177, 186[0m:[39m[49m The clinician's app uploads a wound photograph. Before we do anything expensive (like calling a ML model), we validate that the image is usable.
[0m[49m[39m  178, 187[0m:[39m[49m 
[0m[49m[38;5;9m- 179     [0m:[38;5;9m[49m If you skip this step, you'll waste inference costs on blurry photos, images without reference markers, and accidental screenshots of the clinician's home screen.
[0m[49m[38;5;10m+      188[0m:[38;5;10m[49m If you skip this step, you'll waste inference costs on blurry photos, images without reference markers, and accidental screenshots of the clinician's home screen. For production deployments, consider adding an image quality assessment step here (see Recipe 9.1) to reject blurry or poorly-lit images before incurring inference costs.
[0m[49m[39m  180, 189[0m:[39m[49m 
[0m[49m[39m  181, 190[0m:[39m[49m ```
[0m[49m[39m  182, 191[0m:[39m[49m FUNCTION validate_wound_image(image_bytes, metadata):
[0m[49m[39m  183, 192[0m:[39m[49m     // Check basic image properties
[0m[49m[39m  184, 193[0m:[39m[49m     image = decode_image(image_bytes)
[0m[49m[39m  185, 194[0m:[39m[49m 
[0m[49m[39m  186, 195[0m:[39m[49m     IF image.width < 640 OR image.height < 640:
[0m[49m[39m  187, 196[0m:[39m[49m         RETURN error("Image resolution too low for reliable measurement")
[0m[49m[39m  188, 197[0m:[39m[49m 
[0m[49m[39m  189, 198[0m:[39m[49m     IF image.file_size > 20_MB:
[0m[49m[39m  190, 199[0m:[39m[49m         RETURN error("Image too large, compress before upload")
[0m[49m[39m  191, 200[0m:[39m[49m 
[0m[49m[39m  192, 201[0m:[39m[49m     // Check that required metadata is present
[0m[49m[39m  193, 202[0m:[39m[49m     IF metadata.patient_id IS MISSING:
[0m[49m[39m  194, 203[0m:[39m[49m         RETURN error("Patient ID required")
[0m[49m[39m  195, 204[0m:[39m[49m     IF metadata.wound_location IS MISSING:
[0m[49m[39m  196, 205[0m:[39m[49m         RETURN error("Wound anatomical location required")
[0m[49m[39m  197, 206[0m:[39m[49m 
[0m[49m[38;5;9m- 198     [0m:[38;5;9m[49m     // Store the original image in S3 with metadata
[0m[49m[38;5;10m+      207[0m:[38;5;10m[49m     // Strip EXIF metadata before storage
[0m[49m[38;5;10m+      208[0m:[38;5;10m[49m     // Smartphone photos contain GPS (patient home address in home health),
[0m[49m[38;5;10m+      209[0m:[38;5;10m[49m     // device serial numbers, and photographer info. Strip all of it.
[0m[49m[38;5;10m+      210[0m:[38;5;10m[49m     stripped_image = strip_exif_metadata(image_bytes)
[0m[49m[38;5;10m+      211[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      212[0m:[38;5;10m[49m     // Store the cleaned image in S3 with application-level metadata
[0m[49m[39m  199, 213[0m:[39m[49m     s3_key = "wound-images/{patient_id}/{wound_id}/{timestamp}.jpg"
[0m[49m[38;5;9m- 200     [0m:[38;5;9m[49m     upload_to_s3(bucket="wound-images", key=s3_key, body=image_bytes,
[0m[49m[38;5;10m+      214[0m:[38;5;10m[49m     upload_to_s3(bucket="wound-images", key=s3_key, body=stripped_image,
[0m[49m[39m  201, 215[0m:[39m[49m                  metadata=metadata, encryption="aws:kms")
[0m[49m[39m  202, 216[0m:[39m[49m 
[0m[49m[39m  203, 217[0m:[39m[49m     RETURN success(s3_key)
[0m[49m[39m  204, 218[0m:[39m[49m ```
[0m[49m[39m  205, 219[0m:[39m[49m 
[0m[49m[39m  206, 220[0m:[39m[49m #### Step 2: Detect the Reference Marker and Compute Scale
[0m[49m[39m  207, 221[0m:[39m[49m 
[0m[49m[39m  208, 222[0m:[39m[49m The reference marker is how we convert pixels to centimeters. Without it, we have a pretty picture but no measurement.
[0m[49m[39m  209, 223[0m:[39m[49m 
[0m[49m[39m  210, 224[0m:[39m[49m If you skip this step, your "measurements" are just pixel counts with no physical meaning. They can't be compared across sessions taken at different distances.
[0m[49m[39m  211, 225[0m:[39m[49m 
[0m[49m[39m  212, 226[0m:[39m[49m ```
[0m[49m[39m  213, 227[0m:[39m[49m FUNCTION detect_reference_marker(image):
[0m[49m[39m  214, 228[0m:[39m[49m     // Look for the calibration marker (e.g., a circular sticker of known diameter)
[0m[49m[39m  215, 229[0m:[39m[49m     // This could be a simple color/shape detection or a trained detector
[0m[49m[39m  216, 230[0m:[39m[49m 
[0m[49m[39m  217, 231[0m:[39m[49m     // Approach: detect circular object of expected color (e.g., blue circle, 2.5cm diameter)
[0m[49m[39m  218, 232[0m:[39m[49m     circles = detect_circles(image, color_range="blue",
[0m[49m[39m  219, 233[0m:[39m[49m                             min_radius_px=20, max_radius_px=200)
[0m[49m[39m  220, 234[0m:[39m[49m 
[0m[49m[39m  221, 235[0m:[39m[49m     IF no circles found:
[0m[49m[39m  222, 236[0m:[39m[49m         RETURN warning("No reference marker detected. Image flagged for manual review.")
[0m[49m[39m  223, 237[0m:[39m[49m 
[0m[49m[39m  224, 238[0m:[39m[49m     // Take the best candidate (highest confidence, most circular)
[0m[49m[39m  225, 239[0m:[39m[49m     marker = circles[0]
[0m[49m[39m  226, 240[0m:[39m[49m 
[0m[49m[39m  227, 241[0m:[39m[49m     // Known marker diameter = 2.5 cm
[0m[49m[39m  228, 242[0m:[39m[49m     // Measured marker diameter in pixels = marker.diameter_px
[0m[49m[39m  229, 243[0m:[39m[49m     pixels_per_cm = marker.diameter_px / 2.5
[0m[49m[39m  230, 244[0m:[39m[49m 
[0m[49m[39m  231, 245[0m:[39m[49m     // Sanity check: reasonable range is 10-100 pixels per cm for typical photos
[0m[49m[39m  232, 246[0m:[39m[49m     IF pixels_per_cm < 10 OR pixels_per_cm > 100:
[0m[49m[39m  233, 247[0m:[39m[49m         RETURN warning("Scale factor outside expected range. Check marker positioning.")
[0m[49m[39m  234, 248[0m:[39m[49m 
[0m[49m[39m  235, 249[0m:[39m[49m     RETURN success(pixels_per_cm, marker.location)
[0m[49m[39m  236, 250[0m:[39m[49m ```
[0m[49m[39m  237, 251[0m:[39m[49m 
[0m[49m[39m  238, 252[0m:[39m[49m #### Step 3: Segment the Wound
[0m[49m[39m  239, 253[0m:[39m[49m 
[0m[49m[39m  240, 254[0m:[39m[49m This is where the ML model does its work. We send the image to our trained segmentation model and get back a pixel-level mask identifying wound tissue.
[0m[49m[39m  241, 255[0m:[39m[49m 
[0m[49m[39m  242, 256[0m:[39m[49m If you skip this step, you're back to manual tracing, which is what we're trying to replace.
[0m[49m[39m  243, 257[0m:[39m[49m 
[0m[49m[39m  244, 258[0m:[39m[49m ```
[0m[49m[39m  245, 259[0m:[39m[49m FUNCTION segment_wound(image, sagemaker_endpoint):
[0m[49m[39m  246, 260[0m:[39m[49m     // Preprocess: resize to model's expected input size, normalize pixel values
[0m[49m[39m  247, 261[0m:[39m[49m     preprocessed = resize(image, target_size=(512, 512))
[0m[49m[39m  248, 262[0m:[39m[49m     preprocessed = normalize_pixels(preprocessed, mean=[0.485, 0.456, 0.406],
[0m[49m[39m  249, 263[0m:[39m[49m                                                    std=[0.229, 0.224, 0.225])
[0m[49m[39m  250, 264[0m:[39m[49m 
[0m[49m[39m  251, 265[0m:[39m[49m     // Call SageMaker endpoint
[0m[49m[39m  252, 266[0m:[39m[49m     response = invoke_sagemaker_endpoint(
[0m[49m[39m  253, 267[0m:[39m[49m         endpoint_name=sagemaker_endpoint,
[0m[49m[39m  254, 268[0m:[39m[49m         content_type="application/x-image",
[0m[49m[39m  255, 269[0m:[39m[49m         body=preprocessed
[0m[49m[39m  256, 270[0m:[39m[49m     )
[0m[49m[39m  257, 271[0m:[39m[49m 
[0m[49m[39m  258, 272[0m:[39m[49m     // Response is a probability mask (0.0 to 1.0 per pixel)
[0m[49m[39m  259, 273[0m:[39m[49m     probability_mask = parse_response(response)
[0m[49m[39m  260, 274[0m:[39m[49m 
[0m[49m[39m  261, 275[0m:[39m[49m     // Threshold to binary mask
[0m[49m[39m  262, 276[0m:[39m[49m     binary_mask = probability_mask > 0.5
[0m[49m[39m  263, 277[0m:[39m[49m 
[0m[49m[39m  264, 278[0m:[39m[49m     // Compute confidence: average probability of wound pixels
[0m[49m[39m  265, 279[0m:[39m[49m     confidence = mean(probability_mask[binary_mask == True])
[0m[49m[39m  266, 280[0m:[39m[49m 
[0m[49m[39m  267, 281[0m:[39m[49m     IF confidence < 0.7:
[0m[49m[39m  268, 282[0m:[39m[49m         flag_for_review("Low segmentation confidence")
[0m[49m[39m  269, 283[0m:[39m[49m 
[0m[49m[39m  270, 284[0m:[39m[49m     // Resize mask back to original image dimensions
[0m[49m[39m  271, 285[0m:[39m[49m     final_mask = resize(binary_mask, target_size=image.dimensions)
[0m[49m[39m  272, 286[0m:[39m[49m 
[0m[49m[39m  273, 287[0m:[39m[49m     RETURN final_mask, confidence
[0m[49m[39m  274, 288[0m:[39m[49m ```
[0m[49m[39m  275, 289[0m:[39m[49m 
[0m[49m[39m  276, 290[0m:[39m[49m #### Step 4: Compute Wound Measurements
[0m[49m[39m  277, 291[0m:[39m[49m 
[0m[49m[39m  278, 292[0m:[39m[49m With the segmentation mask and the scale factor, we can compute clinically meaningful measurements.
[0m[49m[39m  279, 293[0m:[39m[49m 
[0m[49m[39m  280, 294[0m:[39m[49m If you skip this step, you have a segmentation mask but no numbers for the clinical record.
[0m[49m[39m  281, 295[0m:[39m[49m 
[0m[49m[39m  282, 296[0m:[39m[49m ```
[0m[49m[39m  283, 297[0m:[39m[49m FUNCTION compute_measurements(segmentation_mask, pixels_per_cm):
[0m[49m[39m  284, 298[0m:[39m[49m     // Count wound pixels to get area
[0m[49m[39m  285, 299[0m:[39m[49m     wound_pixel_count = count(segmentation_mask == True)
[0m[49m[39m  286, 300[0m:[39m[49m     area_px = wound_pixel_count
[0m[49m[39m  287, 301[0m:[39m[49m     area_cm2 = area_px / (pixels_per_cm * pixels_per_cm)
[0m[49m[39m  288, 302[0m:[39m[49m 
[0m[49m[39m  289, 303[0m:[39m[49m     // Find wound boundary contour
[0m[49m[39m  290, 304[0m:[39m[49m     contour = find_contour(segmentation_mask)
[0m[49m[39m  291, 305[0m:[39m[49m 
[0m[49m[39m  292, 306[0m:[39m[49m     // Compute perimeter
[0m[49m[39m  293, 307[0m:[39m[49m     perimeter_px = contour.length
[0m[49m[39m  294, 308[0m:[39m[49m     perimeter_cm = perimeter_px / pixels_per_cm
[0m[49m[39m  295, 309[0m:[39m[49m 
[0m[49m[39m  296, 310[0m:[39m[49m     // Fit minimum bounding rectangle for length and width
[0m[49m[39m  297, 311[0m:[39m[49m     bounding_rect = minimum_area_rectangle(contour)
[0m[49m[39m  298, 312[0m:[39m[49m     length_cm = bounding_rect.long_side / pixels_per_cm
[0m[49m[39m  299, 313[0m:[39m[49m     width_cm = bounding_rect.short_side / pixels_per_cm
[0m[49m[39m  300, 314[0m:[39m[49m 
[0m[49m[39m  301, 315[0m:[39m[49m     // Compute circularity (how round is the wound? 1.0 = perfect circle)
[0m[49m[39m  302, 316[0m:[39m[49m     circularity = (4 * PI * area_px) / (perimeter_px * perimeter_px)
[0m[49m[39m  303, 317[0m:[39m[49m 
[0m[49m[39m  304, 318[0m:[39m[49m     RETURN {
[0m[49m[39m  305, 319[0m:[39m[49m         "area_cm2": round(area_cm2, 2),
[0m[49m[39m  306, 320[0m:[39m[49m         "length_cm": round(length_cm, 2),
[0m[49m[39m  307, 321[0m:[39m[49m         "width_cm": round(width_cm, 2),
[0m[49m[39m  308, 322[0m:[39m[49m         "perimeter_cm": round(perimeter_cm, 2),
[0m[49m[39m  309, 323[0m:[39m[49m         "circularity": round(circularity, 3),
[0m[49m[39m  310, 324[0m:[39m[49m         "pixels_per_cm": pixels_per_cm
[0m[49m[39m  311, 325[0m:[39m[49m     }
[0m[49m[39m  312, 326[0m:[39m[49m ```
[0m[49m[39m  313, 327[0m:[39m[49m 
[0m[49m[39m  314, 328[0m:[39m[49m #### Step 5: Store Measurement and Update Wound Timeline
[0m[49m[39m  315, 329[0m:[39m[49m 
[0m[49m[39m  316, 330[0m:[39m[49m Each measurement becomes a data point in the wound's healing timeline. We store it with enough context to support trend analysis and audit.
[0m[49m[39m  317, 331[0m:[39m[49m 
[0m[49m[39m  318, 332[0m:[39m[49m If you skip this step, you lose the longitudinal tracking that makes automated measurement valuable over manual documentation.
[0m[49m[39m  319, 333[0m:[39m[49m 
[0m[49m[38;5;10m+      334[0m:[38;5;10m[49m The key design here: use `patient_id#wound_id` as the partition key and `timestamp` as the sort key. This makes per-wound timeline queries efficient (get all measurements for a specific wound, sorted by date) without needing to scan across unrelated wounds for the same patient. Application-layer authorization must verify that the requesting clinician has a care relationship with the patient before returning wound data.
[0m[49m[38;5;10m+      335[0m:[38;5;10m[49m 
[0m[49m[39m  320, 336[0m:[39m[49m ```
[0m[49m[39m  321, 337[0m:[39m[49m FUNCTION store_measurement(patient_id, wound_id, measurements, metadata, image_key, mask_key):
[0m[49m[39m  322, 338[0m:[39m[49m     record = {
[0m[49m[38;5;9m- 323     [0m:[38;5;9m[49m         "patient_id": patient_id,                    // Partition key
[0m[49m[38;5;9m- 324     [0m:[38;5;9m[49m         "wound_id#timestamp": wound_id + "#" + now(), // Sort key
[0m[49m[38;5;10m+      339[0m:[38;5;10m[49m         "patient_wound_id": patient_id + "#" + wound_id,  // Partition key
[0m[49m[38;5;10m+      340[0m:[38;5;10m[49m         "measurement_date": now(),                         // Sort key
[0m[49m[38;5;10m+      341[0m:[38;5;10m[49m         "patient_id": patient_id,
[0m[49m[39m  325, 342[0m:[39m[49m         "wound_id": wound_id,
[0m[49m[38;5;9m- 326     [0m:[38;5;9m[49m         "measurement_date": now(),
[0m[49m[39m  327, 343[0m:[39m[49m         "area_cm2": measurements.area_cm2,
[0m[49m[39m  328, 344[0m:[39m[49m         "length_cm": measurements.length_cm,
[0m[49m[39m  329, 345[0m:[39m[49m         "width_cm": measurements.width_cm,
[0m[49m[39m  330, 346[0m:[39m[49m         "perimeter_cm": measurements.perimeter_cm,
[0m[49m[39m  331, 347[0m:[39m[49m         "circularity": measurements.circularity,
[0m[49m[39m  332, 348[0m:[39m[49m         "confidence": measurements.confidence,
[0m[49m[39m  333, 349[0m:[39m[49m         "image_s3_key": image_key,
[0m[49m[39m  334, 350[0m:[39m[49m         "mask_s3_key": mask_key,
[0m[49m[39m  335, 351[0m:[39m[49m         "clinician_id": metadata.clinician_id,
[0m[49m[39m  336, 352[0m:[39m[49m         "wound_location": metadata.wound_location,
[0m[49m[39m  337, 353[0m:[39m[49m         "device_info": metadata.device_info,
[0m[49m[39m  338, 354[0m:[39m[49m         "pixels_per_cm": measurements.pixels_per_cm
[0m[49m[39m  339, 355[0m:[39m[49m     }
[0m[49m[39m  340, 356[0m:[39m[49m 
[0m[49m[39m  341, 357[0m:[39m[49m     dynamodb.put_item(table="wound-measurements", item=record)
[0m[49m[39m  342, 358[0m:[39m[49m 
[0m[49m[38;5;9m- 343     [0m:[38;5;9m[49m     // Compute healing rate if previous measurements exist
[0m[49m[38;5;10m+      359[0m:[38;5;10m[49m     // Get previous measurement for this specific wound
[0m[49m[39m  344, 360[0m:[39m[49m     previous = dynamodb.query(
[0m[49m[39m  345, 361[0m:[39m[49m         table="wound-measurements",
[0m[49m[38;5;9m- 346     [0m:[38;5;9m[49m         partition_key=patient_id,
[0m[49m[38;5;9m- 347     [0m:[38;5;9m[49m         sort_key_begins_with=wound_id,
[0m[49m[38;5;9m- 348     [0m:[38;5;9m[49m         limit=1,
[0m[49m[38;5;9m- 349     [0m:[38;5;9m[49m         scan_index_forward=False  // Most recent first
[0m[49m[38;5;10m+      362[0m:[38;5;10m[49m         partition_key=patient_id + "#" + wound_id,
[0m[49m[38;5;10m+      363[0m:[38;5;10m[49m         scan_index_forward=False,  // Most recent first
[0m[49m[38;5;10m+      364[0m:[38;5;10m[49m         limit=2                    // Current + previous
[0m[49m[39m  350, 365[0m:[39m[49m     )
[0m[49m[39m  351, 366[0m:[39m[49m 
[0m[49m[38;5;9m- 352     [0m:[38;5;9m[49m     IF previous exists:
[0m[49m[38;5;9m- 353     [0m:[38;5;9m[49m         days_elapsed = (now() - previous.measurement_date).days
[0m[49m[38;5;10m+      367[0m:[38;5;10m[49m     // Skip the one we just inserted, take the prior measurement
[0m[49m[38;5;10m+      368[0m:[38;5;10m[49m     IF previous has at least 2 records:
[0m[49m[38;5;10m+      369[0m:[38;5;10m[49m         prior = previous[1]
[0m[49m[38;5;10m+      370[0m:[38;5;10m[49m         days_elapsed = (now() - prior.measurement_date).days
[0m[49m[39m  354, 371[0m:[39m[49m         IF days_elapsed > 0:
[0m[49m[38;5;9m- 355     [0m:[38;5;9m[49m             area_change_pct = ((measurements.area_cm2 - previous.area_cm2)
[0m[49m[38;5;9m- 356     [0m:[38;5;9m[49m                               / previous.area_cm2) * 100
[0m[49m[38;5;9m- 357     [0m:[38;5;9m[49m             healing_rate_cm2_per_day = (previous.area_cm2 - measurements.area_cm2)
[0m[49m[38;5;10m+      372[0m:[38;5;10m[49m             area_change_pct = ((measurements.area_cm2 - prior.area_cm2)
[0m[49m[38;5;10m+      373[0m:[38;5;10m[49m                               / prior.area_cm2) * 100
[0m[49m[38;5;10m+      374[0m:[38;5;10m[49m             healing_rate_cm2_per_day = (prior.area_cm2 - measurements.area_cm2)
[0m[49m[39m  358, 375[0m:[39m[49m                                       / days_elapsed
[0m[49m[39m  359, 376[0m:[39m[49m 
[0m[49m[39m  360, 377[0m:[39m[49m             // Alert if wound is growing
[0m[49m[39m  361, 378[0m:[39m[49m             IF area_change_pct > 10:
[0m[49m[39m  362, 379[0m:[39m[49m                 send_alert("Wound {wound_id} for patient {patient_id} "
[0m[49m[39m  363, 380[0m:[39m[49m                           "has increased {area_change_pct}% since last measurement")
[0m[49m[39m  364, 381[0m:[39m[49m 
[0m[49m[39m  365, 382[0m:[39m[49m     RETURN record
[0m[49m[39m  366, 383[0m:[39m[49m ```
[0m[49m[39m  367, 384[0m:[39m[49m 
[0m[49m[39m  368, 385[0m:[39m[49m > **Curious how this looks in Python?** The pseudocode above covers the concepts. If you'd like to see sample Python code that demonstrates these patterns using boto3, check out the [Python Example](chapter09.03-python-example). It walks through each step with inline comments and notes on what you'd need to change for a real deployment.
[0m[49m[39m  369, 386[0m:[39m[49m 
