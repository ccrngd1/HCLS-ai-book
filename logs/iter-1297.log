[0m[49m[38;5;10m+    1140[0m:[38;5;10m[49m """
[0m[49m[38;5;10m+    1141[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1142[0m:[38;5;10m[49m     sample_metadata = {
[0m[49m[38;5;10m+    1143[0m:[38;5;10m[49m         "authored_datetime": "2024-03-07T14:30:00Z",
[0m[49m[38;5;10m+    1144[0m:[38;5;10m[49m         "patient_id": "PAT-SYNTH-88431",
[0m[49m[38;5;10m+    1145[0m:[38;5;10m[49m         "document_id": "NOTE-SYNTH-2024-03-07-001",
[0m[49m[38;5;10m+    1146[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1147[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1148[0m:[38;5;10m[49m     result = extract_temporal_relationships(sample_note, sample_metadata)
[0m[49m[38;5;10m+    1149[0m:[38;5;10m[49m     print(json.dumps(result, indent=2, default=str))
