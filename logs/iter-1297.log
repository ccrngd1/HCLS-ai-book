[0m[49m[38;5;10m+    1096[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    1097[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1098[0m:[38;5;10m[49m     # Step 7: Store in DynamoDB.
[0m[49m[38;5;10m+    1099[0m:[38;5;10m[49m     logger.info("Step 7: Storing timeline")
[0m[49m[38;5;10m+    1100[0m:[38;5;10m[49m     store_timeline(timeline)
[0m[49m[38;5;10m+    1101[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1102[0m:[38;5;10m[49m     logger.info(
