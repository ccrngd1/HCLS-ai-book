[0m[49m[38;5;10m+     398[0m:[38;5;10m[49m                 normalized = resolved.strftime("%Y-%m-%d")
[0m[49m[38;5;10m+     399[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     400[0m:[38;5;10m[49m             elif pattern_type == "POSTOP_DAY":
[0m[49m[38;5;10m+     401[0m:[38;5;10m[49m                 # POD#N: N days after surgery. We note the offset but can't
[0m[49m[38;5;10m+     402[0m:[38;5;10m[49m                 # resolve to an absolute date without knowing the surgery date.
[0m[49m[38;5;10m+     403[0m:[38;5;10m[49m                 day_num = int(match.group(1))
[0m[49m[38;5;10m+     404[0m:[38;5;10m[49m                 normalized = f"SURGERY_DATE+{day_num}d"
[0m[49m[38;5;10m+     405[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     406[0m:[38;5;10m[49m             elif pattern_type == "HOSPITAL_DAY":
[0m[49m[38;5;10m+     407[0m:[38;5;10m[49m                 day_num = int(match.group(1))
[0m[49m[38;5;10m+     408[0m:[38;5;10m[49m                 normalized = f"ADMISSION_DATE+{day_num}d"
[0m[49m[38;5;10m+     409[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     410[0m:[38;5;10m[49m             elif pattern_type == "PERIOP_RELATIVE":
[0m[49m[38;5;10m+     411[0m:[38;5;10m[49m                 prefix = match.group(1).lower()
[0m[49m[38;5;10m+     412[0m:[38;5;10m[49m                 normalized = "AFTER_SURGERY" if prefix == "post" else "BEFORE_SURGERY"
[0m[49m[38;5;10m+     413[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     414[0m:[38;5;10m[49m             temporal_expressions.append({
[0m[49m[38;5;10m+     415[0m:[38;5;10m[49m                 "id": f"TIMEX-{match.start():04d}",
[0m[49m[38;5;10m+     416[0m:[38;5;10m[49m                 "raw_text": raw_text,
[0m[49m[38;5;10m+     417[0m:[38;5;10m[49m                 "pattern_type": pattern_type,
[0m[49m[38;5;10m+     418[0m:[38;5;10m[49m                 "normalized": normalized,
[0m[49m[38;5;10m+     419[0m:[38;5;10m[49m                 "begin_offset": match.start(),
[0m[49m[38;5;10m+     420[0m:[38;5;10m[49m                 "end_offset": match.end(),
[0m[49m[38;5;10m+     421[0m:[38;5;10m[49m                 "confidence": 0.90,  # Rule-based: high confidence when matched
[0m[49m[38;5;10m+     422[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+     423[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     424[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+     425[0m:[38;5;10m[49m         "Recognized %d temporal expressions", len(temporal_expressions)
