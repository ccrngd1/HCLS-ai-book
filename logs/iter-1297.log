[0m[49m[38;5;10m+     100[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     101[0m:[38;5;10m[49m # ---------- Temporal Signal Words ----------
[0m[49m[38;5;10m+     102[0m:[38;5;10m[49m # Words that explicitly signal temporal relationships between events.
[0m[49m[38;5;10m+     103[0m:[38;5;10m[49m # Used both in candidate pair generation and as features for classification.
[0m[49m[38;5;10m+     104[0m:[38;5;10m[49m 
