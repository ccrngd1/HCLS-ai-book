[0m[49m[38;5;10m+      94[0m:[38;5;10m[49m     "assessment and plan": "CURRENT",
[0m[49m[38;5;10m+      95[0m:[38;5;10m[49m     "a/p": "CURRENT",
[0m[49m[38;5;10m+      96[0m:[38;5;10m[49m     "hospital course": "NARRATIVE",
[0m[49m[38;5;10m+      97[0m:[38;5;10m[49m     "discharge instructions": "FUTURE",
