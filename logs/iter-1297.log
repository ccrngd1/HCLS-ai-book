[0m[49m[38;5;10m+      30[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      31[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+      32[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+      33[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+      34[0m:[38;5;10m[49m import re
[0m[49m[38;5;10m+      35[0m:[38;5;10m[49m import datetime
[0m[49m[38;5;10m+      36[0m:[38;5;10m[49m from datetime import timezone, timedelta
[0m[49m[38;5;10m+      37[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+      38[0m:[38;5;10m[49m from collections import defaultdict
[0m[49m[38;5;10m+      39[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      40[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+      41[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+      42[0m:[38;5;10m[49m 
