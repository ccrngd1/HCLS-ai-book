[0m[49m[38;5;10m+      44[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+      45[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+      46[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      47[0m:[38;5;10m[49m # Retry configuration for AWS API calls under load.
[0m[49m[38;5;10m+      48[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+      49[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      50[0m:[38;5;10m[49m # Module-level clients reused across Lambda invocations.
[0m[49m[38;5;10m+      51[0m:[38;5;10m[49m comprehend_medical_client = boto3.client("comprehendmedical", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+      52[0m:[38;5;10m[49m comprehend_client = boto3.client("comprehend", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+      53[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb")
[0m[49m[38;5;10m+      54[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      55[0m:[38;5;10m[49m # ---------- Temporal Relation Configuration ----------
[0m[49m[38;5;10m+      56[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      57[0m:[38;5;10m[49m # The temporal relation labels our classifier predicts.
[0m[49m[38;5;10m+      58[0m:[38;5;10m[49m # Collapsed from the full TimeML set (most clinical systems use this reduced set).
[0m[49m[38;5;10m+      59[0m:[38;5;10m[49m TEMPORAL_RELATION_LABELS = ["BEFORE", "AFTER", "OVERLAP", "CONTAINS", "NONE"]
[0m[49m[38;5;10m+      60[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      61[0m:[38;5;10m[49m # Confidence threshold: relations below this are excluded from the final graph.
[0m[49m[38;5;10m+      62[0m:[38;5;10m[49m # 0.70 is a common starting point. Raise it if you're getting too many false edges.
[0m[49m[38;5;10m+      63[0m:[38;5;10m[49m RELATION_CONFIDENCE_THRESHOLD = 0.70
[0m[49m[38;5;10m+      64[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      65[0m:[38;5;10m[49m # Entity confidence threshold: skip low-confidence entities from Comprehend Medical.
[0m[49m[38;5;10m+      66[0m:[38;5;10m[49m ENTITY_CONFIDENCE_THRESHOLD = 0.75
[0m[49m[38;5;10m+      67[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      68[0m:[38;5;10m[49m # Maximum sentence distance for candidate pair generation.
[0m[49m[38;5;10m+      69[0m:[38;5;10m[49m # Pairs more than 3 sentences apart rarely have direct temporal relationships.
[0m[49m[38;5;10m+      70[0m:[38;5;10m[49m MAX_SENTENCE_DISTANCE = 3
[0m[49m[38;5;10m+      71[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      72[0m:[38;5;10m[49m # Amazon Comprehend custom classification endpoint ARN for temporal relations.
[0m[49m[38;5;10m+      73[0m:[38;5;10m[49m # Replace with your trained classifier's ARN.
[0m[49m[38;5;10m+      74[0m:[38;5;10m[49m TEMPORAL_CLASSIFIER_ARN = "arn:aws:comprehend:us-east-1:123456789012:document-classifier-endpoint/temporal-relation-classifier"
[0m[49m[38;5;10m+      75[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      76[0m:[38;5;10m[49m # DynamoDB table for patient timelines.
[0m[49m[38;5;10m+      77[0m:[38;5;10m[49m TIMELINE_TABLE = "patient-timelines"
[0m[49m[38;5;10m+      78[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      79[0m:[38;5;10m[49m # ---------- Section Temporal Context ----------
[0m[49m[38;5;10m+      80[0m:[38;5;10m[49m # Section headers carry implicit temporal information.
[0m[49m[38;5;10m+      81[0m:[38;5;10m[49m # Events in "Past Medical History" are historical by default.
