[0m[49m[38;5;10m+     428[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     429[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     430[0m:[38;5;10m[49m def detect_temporal_entities(preprocessed_note):
[0m[49m[38;5;10m+     431[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     432[0m:[38;5;10m[49m     Detect both clinical events and temporal expressions from the note.
[0m[49m[38;5;10m+     433[0m:[38;5;10m[49m     This is the combined Step 2 that feeds into candidate pair generation.
[0m[49m[38;5;10m+     434[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     435[0m:[38;5;10m[49m     events = detect_events_comprehend_medical(preprocessed_note["full_text"])
[0m[49m[38;5;10m+     436[0m:[38;5;10m[49m     temporal_expressions = recognize_temporal_expressions(
[0m[49m[38;5;10m+     437[0m:[38;5;10m[49m         preprocessed_note["full_text"],
[0m[49m[38;5;10m+     438[0m:[38;5;10m[49m         preprocessed_note["doc_time"],
[0m[49m[38;5;10m+     439[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     440[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     441[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     442[0m:[38;5;10m[49m         "events": events,
[0m[49m[38;5;10m+     443[0m:[38;5;10m[49m         "temporal_expressions": temporal_expressions,
[0m[49m[38;5;10m+     444[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     445[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     446[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     447[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     448[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     449[0m:[38;5;10m[49m ## Step 3: Generate Candidate Pairs
[0m[49m[38;5;10m+     450[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     451[0m:[38;5;10m[49m *The pseudocode calls this `generate_candidate_pairs(events, temporal_expressions, sentences)`. With N entities, checking all N*(N-1)/2 pairs is expensive and mostly wasteful. This step applies heuristics to select only pairs likely to have meaningful temporal relationships.*
[0m[49m[38;5;10m+     452[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     453[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     454[0m:[38;5;10m[49m def find_sentence_index(offset, sentences):
[0m[49m[38;5;10m+     455[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     456[0m:[38;5;10m[49m     Given a character offset, find which sentence it falls in.
[0m[49m[38;5;10m+     457[0m:[38;5;10m[49m     Returns the sentence index, or -1 if not found.
[0m[49m[38;5;10m+     458[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     459[0m:[38;5;10m[49m     for i, sent in enumerate(sentences):
[0m[49m[38;5;10m+     460[0m:[38;5;10m[49m         sent_start = sent["start_char"]
[0m[49m[38;5;10m+     461[0m:[38;5;10m[49m         sent_end = sent_start + len(sent["text"])
[0m[49m[38;5;10m+     462[0m:[38;5;10m[49m         if sent_start <= offset <= sent_end:
[0m[49m[38;5;10m+     463[0m:[38;5;10m[49m             return i
[0m[49m[38;5;10m+     464[0m:[38;5;10m[49m     return -1
[0m[49m[38;5;10m+     465[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     466[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     467[0m:[38;5;10m[49m def find_temporal_signals_between(text, entity_a, entity_b):
[0m[49m[38;5;10m+     468[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     469[0m:[38;5;10m[49m     Check if there's a temporal signal word in the text between two entities.
[0m[49m[38;5;10m+     470[0m:[38;5;10m[49m     Returns the signal word and its implied relation, or None.
[0m[49m[38;5;10m+     471[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     472[0m:[38;5;10m[49m     # Get the text span between the two entities.
[0m[49m[38;5;10m+     473[0m:[38;5;10m[49m     start = min(entity_a["end_offset"], entity_b["end_offset"])
[0m[49m[38;5;10m+     474[0m:[38;5;10m[49m     end = max(entity_a["begin_offset"], entity_b["begin_offset"])
[0m[49m[38;5;10m+     475[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     476[0m:[38;5;10m[49m     if start >= end:
[0m[49m[38;5;10m+     477[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+     478[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     479[0m:[38;5;10m[49m     between_text = text[start:end].lower()
[0m[49m[38;5;10m+     480[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     481[0m:[38;5;10m[49m     for signal, implied_relation in TEMPORAL_SIGNALS.items():
[0m[49m[38;5;10m+     482[0m:[38;5;10m[49m         if signal in between_text:
[0m[49m[38;5;10m+     483[0m:[38;5;10m[49m             return {"signal": signal, "implied_relation": implied_relation}
[0m[49m[38;5;10m+     484[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     485[0m:[38;5;10m[49m     return None
[0m[49m[38;5;10m+     486[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     487[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     488[0m:[38;5;10m[49m def generate_candidate_pairs(entities, sentences, full_text):
[0m[49m[38;5;10m+     489[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     490[0m:[38;5;10m[49m     Generate candidate entity pairs for temporal relation classification.
[0m[49m[38;5;10m+     491[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     492[0m:[38;5;10m[49m     Heuristics applied (in priority order):
[0m[49m[38;5;10m+     493[0m:[38;5;10m[49m     1. Same-sentence pairs (highest probability of explicit relationship)
[0m[49m[38;5;10m+     494[0m:[38;5;10m[49m     2. Adjacent-sentence pairs (narrative flow implies ordering)
[0m[49m[38;5;10m+     495[0m:[38;5;10m[49m     3. Pairs connected by a temporal signal word
[0m[49m[38;5;10m+     496[0m:[38;5;10m[49m     4. Event paired with its nearest temporal expression
[0m[49m[38;5;10m+     497[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     498[0m:[38;5;10m[49m     Returns a list of candidate pairs with metadata about why they were selected.
[0m[49m[38;5;10m+     499[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     500[0m:[38;5;10m[49m     events = entities["events"]
[0m[49m[38;5;10m+     501[0m:[38;5;10m[49m     temporal_expressions = entities["temporal_expressions"]
[0m[49m[38;5;10m+     502[0m:[38;5;10m[49m     all_entities = events + temporal_expressions
[0m[49m[38;5;10m+     503[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     504[0m:[38;5;10m[49m     # Assign sentence indices to all entities.
[0m[49m[38;5;10m+     505[0m:[38;5;10m[49m     for entity in all_entities:
[0m[49m[38;5;10m+     506[0m:[38;5;10m[49m         entity["sentence_index"] = find_sentence_index(
[0m[49m[38;5;10m+     507[0m:[38;5;10m[49m             entity["begin_offset"], sentences
[0m[49m[38;5;10m+     508[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     509[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     510[0m:[38;5;10m[49m     candidates = []
[0m[49m[38;5;10m+     511[0m:[38;5;10m[49m     seen_pairs = set()
[0m[49m[38;5;10m+     512[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     513[0m:[38;5;10m[49m     for i, entity_a in enumerate(all_entities):
[0m[49m[38;5;10m+     514[0m:[38;5;10m[49m         for j, entity_b in enumerate(all_entities):
[0m[49m[38;5;10m+     515[0m:[38;5;10m[49m             if i >= j:
[0m[49m[38;5;10m+     516[0m:[38;5;10m[49m                 continue  # Avoid duplicates and self-pairs
[0m[49m[38;5;10m+     517[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     518[0m:[38;5;10m[49m             pair_key = (entity_a["id"], entity_b["id"])
[0m[49m[38;5;10m+     519[0m:[38;5;10m[49m             if pair_key in seen_pairs:
[0m[49m[38;5;10m+     520[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+     521[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     522[0m:[38;5;10m[49m             sent_a = entity_a["sentence_index"]
[0m[49m[38;5;10m+     523[0m:[38;5;10m[49m             sent_b = entity_b["sentence_index"]
[0m[49m[38;5;10m+     524[0m:[38;5;10m[49m             sentence_distance = abs(sent_a - sent_b) if (sent_a >= 0 and sent_b >= 0) else 999
[0m[49m[38;5;10m+     525[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     526[0m:[38;5;10m[49m             pair_type = None
[0m[49m[38;5;10m+     527[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     528[0m:[38;5;10m[49m             # Heuristic 1: Same sentence.
[0m[49m[38;5;10m+     529[0m:[38;5;10m[49m             if sentence_distance == 0:
[0m[49m[38;5;10m+     530[0m:[38;5;10m[49m                 pair_type = "same_sentence"
[0m[49m[38;5;10m+     531[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     532[0m:[38;5;10m[49m             # Heuristic 2: Adjacent sentences (within max distance).
[0m[49m[38;5;10m+     533[0m:[38;5;10m[49m             elif sentence_distance <= MAX_SENTENCE_DISTANCE:
[0m[49m[38;5;10m+     534[0m:[38;5;10m[49m                 pair_type = "adjacent"
[0m[49m[38;5;10m+     535[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     536[0m:[38;5;10m[49m             # Heuristic 3: Temporal signal between them.
[0m[49m[38;5;10m+     537[0m:[38;5;10m[49m             if pair_type is None:
[0m[49m[38;5;10m+     538[0m:[38;5;10m[49m                 signal = find_temporal_signals_between(full_text, entity_a, entity_b)
[0m[49m[38;5;10m+     539[0m:[38;5;10m[49m                 if signal:
[0m[49m[38;5;10m+     540[0m:[38;5;10m[49m                     pair_type = "signal_connected"
[0m[49m[38;5;10m+     541[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     542[0m:[38;5;10m[49m             if pair_type is None:
[0m[49m[38;5;10m+     543[0m:[38;5;10m[49m                 continue  # Skip pairs that don't match any heuristic.
[0m[49m[38;5;10m+     544[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     545[0m:[38;5;10m[49m             candidates.append({
[0m[49m[38;5;10m+     546[0m:[38;5;10m[49m                 "entity_a": entity_a,
[0m[49m[38;5;10m+     547[0m:[38;5;10m[49m                 "entity_b": entity_b,
[0m[49m[38;5;10m+     548[0m:[38;5;10m[49m                 "pair_type": pair_type,
[0m[49m[38;5;10m+     549[0m:[38;5;10m[49m                 "sentence_distance": sentence_distance,
[0m[49m[38;5;10m+     550[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+     551[0m:[38;5;10m[49m             seen_pairs.add(pair_key)
[0m[49m[38;5;10m+     552[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     553[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+     554[0m:[38;5;10m[49m         "Generated %d candidate pairs from %d entities",
[0m[49m[38;5;10m+     555[0m:[38;5;10m[49m         len(candidates), len(all_entities)
[0m[49m[38;5;10m+     556[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     557[0m:[38;5;10m[49m     return candidates
[0m[49m[38;5;10m+     558[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     559[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     560[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     561[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     562[0m:[38;5;10m[49m ## Step 4: Classify Temporal Relations
[0m[49m[38;5;10m+     563[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     564[0m:[38;5;10m[49m *The pseudocode calls this `classify_relations(candidate_pairs, full_text, sections)`. For each candidate pair, we build a context window, format it for the classifier, and get a temporal relation prediction. This uses Amazon Comprehend Custom Classification with a model trained on temporal relation annotated data.*
[0m[49m[38;5;10m+     565[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     566[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     567[0m:[38;5;10m[49m def build_context_window(entity_a, entity_b, full_text, window_chars=200):
[0m[49m[38;5;10m+     568[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     569[0m:[38;5;10m[49m     Extract a context window around two entities for classification input.
[0m[49m[38;5;10m+     570[0m:[38;5;10m[49m     Includes the text of both entities and surrounding context.
[0m[49m[38;5;10m+     571[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     572[0m:[38;5;10m[49m     # Find the span that covers both entities plus context.
[0m[49m[38;5;10m+     573[0m:[38;5;10m[49m     span_start = min(entity_a["begin_offset"], entity_b["begin_offset"])
[0m[49m[38;5;10m+     574[0m:[38;5;10m[49m     span_end = max(entity_a["end_offset"], entity_b["end_offset"])
[0m[49m[38;5;10m+     575[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     576[0m:[38;5;10m[49m     # Add context window on each side.
[0m[49m[38;5;10m+     577[0m:[38;5;10m[49m     context_start = max(0, span_start - window_chars)
[0m[49m[38;5;10m+     578[0m:[38;5;10m[49m     context_end = min(len(full_text), span_end + window_chars)
[0m[49m[38;5;10m+     579[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     580[0m:[38;5;10m[49m     return full_text[context_start:context_end]
[0m[49m[38;5;10m+     581[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     582[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     583[0m:[38;5;10m[49m def format_for_classification(context, entity_a, entity_b, full_text):
[0m[49m[38;5;10m+     584[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     585[0m:[38;5;10m[49m     Format a candidate pair for the temporal relation classifier.
[0m[49m[38;5;10m+     586[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     587[0m:[38;5;10m[49m     The classifier expects entity markers in the text so it knows which
[0m[49m[38;5;10m+     588[0m:[38;5;10m[49m     two entities to classify the relationship for. We use [E1]...[/E1]
[0m[49m[38;5;10m+     589[0m:[38;5;10m[49m     and [E2]...[/E2] markers (a common convention in relation extraction).
[0m[49m[38;5;10m+     590[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     591[0m:[38;5;10m[49m     # Replace entity spans with marked versions in the context.
[0m[49m[38;5;10m+     592[0m:[38;5;10m[49m     # We need to be careful about offsets since we're working with a substring.
[0m[49m[38;5;10m+     593[0m:[38;5;10m[49m     context_start = max(0, min(entity_a["begin_offset"], entity_b["begin_offset"]) - 200)
[0m[49m[38;5;10m+     594[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     595[0m:[38;5;10m[49m     # Build marked text with entity boundaries.
[0m[49m[38;5;10m+     596[0m:[38;5;10m[49m     # Simpler approach: just format as a structured input string.
[0m[49m[38;5;10m+     597[0m:[38;5;10m[49m     formatted = (
[0m[49m[38;5;10m+     598[0m:[38;5;10m[49m         f"Entity1: {entity_a['text']} | "
[0m[49m[38;5;10m+     599[0m:[38;5;10m[49m         f"Entity2: {entity_b['text']} | "
[0m[49m[38;5;10m+     600[0m:[38;5;10m[49m         f"Context: {context}"
[0m[49m[38;5;10m+     601[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     602[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     603[0m:[38;5;10m[49m     return formatted
[0m[49m[38;5;10m+     604[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     605[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     606[0m:[38;5;10m[49m def classify_single_relation(formatted_input):
[0m[49m[38;5;10m+     607[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     608[0m:[38;5;10m[49m     Call the Amazon Comprehend custom classifier for a single entity pair.
[0m[49m[38;5;10m+     609[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     610[0m:[38;5;10m[49m     Returns the predicted temporal relation label and confidence score.
[0m[49m[38;5;10m+     611[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     612[0m:[38;5;10m[49m     response = comprehend_client.classify_document(
[0m[49m[38;5;10m+     613[0m:[38;5;10m[49m         Text=formatted_input[:5000],  # Comprehend has a 5000 char limit
[0m[49m[38;5;10m+     614[0m:[38;5;10m[49m         EndpointArn=TEMPORAL_CLASSIFIER_ARN,
[0m[49m[38;5;10m+     615[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     616[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     617[0m:[38;5;10m[49m     # Comprehend returns classes sorted by confidence (highest first).
[0m[49m[38;5;10m+     618[0m:[38;5;10m[49m     classes = response.get("Classes", [])
[0m[49m[38;5;10m+     619[0m:[38;5;10m[49m     if not classes:
[0m[49m[38;5;10m+     620[0m:[38;5;10m[49m         return {"label": "NONE", "confidence": 0.0}
[0m[49m[38;5;10m+     621[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     622[0m:[38;5;10m[49m     top_class = classes[0]
[0m[49m[38;5;10m+     623[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     624[0m:[38;5;10m[49m         "label": top_class["Name"],
[0m[49m[38;5;10m+     625[0m:[38;5;10m[49m         "confidence": top_class["Score"],
[0m[49m[38;5;10m+     626[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     627[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     628[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     629[0m:[38;5;10m[49m def classify_relations(candidate_pairs, full_text, sections):
[0m[49m[38;5;10m+     630[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     631[0m:[38;5;10m[49m     Classify temporal relations for all candidate pairs.
[0m[49m[38;5;10m+     632[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     633[0m:[38;5;10m[49m     For each pair, builds a context window, formats it for the classifier,
[0m[49m[38;5;10m+     634[0m:[38;5;10m[49m     and filters results by confidence threshold.
[0m[49m[38;5;10m+     635[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     636[0m:[38;5;10m[49m     Returns only relations above the confidence threshold.
[0m[49m[38;5;10m+     637[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     638[0m:[38;5;10m[49m     classified_relations = []
[0m[49m[38;5;10m+     639[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     640[0m:[38;5;10m[49m     for pair in candidate_pairs:
[0m[49m[38;5;10m+     641[0m:[38;5;10m[49m         entity_a = pair["entity_a"]
[0m[49m[38;5;10m+     642[0m:[38;5;10m[49m         entity_b = pair["entity_b"]
[0m[49m[38;5;10m+     643[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     644[0m:[38;5;10m[49m         # Build context window around the pair.
[0m[49m[38;5;10m+     645[0m:[38;5;10m[49m         context = build_context_window(entity_a, entity_b, full_text)
[0m[49m[38;5;10m+     646[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     647[0m:[38;5;10m[49m         # Format for the classifier.
[0m[49m[38;5;10m+     648[0m:[38;5;10m[49m         formatted_input = format_for_classification(
[0m[49m[38;5;10m+     649[0m:[38;5;10m[49m             context, entity_a, entity_b, full_text
[0m[49m[38;5;10m+     650[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     651[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     652[0m:[38;5;10m[49m         # Call the classifier.
[0m[49m[38;5;10m+     653[0m:[38;5;10m[49m         prediction = classify_single_relation(formatted_input)
[0m[49m[38;5;10m+     654[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     655[0m:[38;5;10m[49m         # Apply confidence threshold.
[0m[49m[38;5;10m+     656[0m:[38;5;10m[49m         if prediction["confidence"] < RELATION_CONFIDENCE_THRESHOLD:
[0m[49m[38;5;10m+     657[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     658[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     659[0m:[38;5;10m[49m         # Skip NONE predictions (no temporal relationship).
[0m[49m[38;5;10m+     660[0m:[38;5;10m[49m         if prediction["label"] == "NONE":
[0m[49m[38;5;10m+     661[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     662[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     663[0m:[38;5;10m[49m         classified_relations.append({
[0m[49m[38;5;10m+     664[0m:[38;5;10m[49m             "entity_a_id": entity_a["id"],
[0m[49m[38;5;10m+     665[0m:[38;5;10m[49m             "entity_b_id": entity_b["id"],
[0m[49m[38;5;10m+     666[0m:[38;5;10m[49m             "entity_a_text": entity_a["text"],
[0m[49m[38;5;10m+     667[0m:[38;5;10m[49m             "entity_b_text": entity_b["text"],
[0m[49m[38;5;10m+     668[0m:[38;5;10m[49m             "relation": prediction["label"],
[0m[49m[38;5;10m+     669[0m:[38;5;10m[49m             "confidence": prediction["confidence"],
[0m[49m[38;5;10m+     670[0m:[38;5;10m[49m             "pair_type": pair["pair_type"],
[0m[49m[38;5;10m+     671[0m:[38;5;10m[49m             "context_snippet": context[:200],
[0m[49m[38;5;10m+     672[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     673[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     674[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+     675[0m:[38;5;10m[49m         "Classified %d temporal relations (from %d candidates)",
[0m[49m[38;5;10m+     676[0m:[38;5;10m[49m         len(classified_relations), len(candidate_pairs)
[0m[49m[38;5;10m+     677[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     678[0m:[38;5;10m[49m     return classified_relations
[0m[49m[38;5;10m+     679[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     680[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     681[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     682[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     683[0m:[38;5;10m[49m ## Step 5: Build Temporal Graph and Propagate Constraints
[0m[49m[38;5;10m+     684[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     685[0m:[38;5;10m[49m *The pseudocode calls this `build_temporal_graph(classified_relations, events, temporal_expressions)`. We assemble relations into a directed graph, apply transitivity (if A BEFORE B and B BEFORE C, then A BEFORE C), and detect/resolve inconsistencies.*
[0m[49m[38;5;10m+     686[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     687[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     688[0m:[38;5;10m[49m def build_temporal_graph(classified_relations, events, temporal_expressions):
[0m[49m[38;5;10m+     689[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     690[0m:[38;5;10m[49m     Assemble classified relations into a temporal graph.
[0m[49m[38;5;10m+     691[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     692[0m:[38;5;10m[49m     The graph is represented as:
[0m[49m[38;5;10m+     693[0m:[38;5;10m[49m     - nodes: dict of entity_id -> entity data
[0m[49m[38;5;10m+     694[0m:[38;5;10m[49m     - edges: list of (from_id, to_id, relation, confidence)
[0m[49m[38;5;10m+     695[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     696[0m:[38;5;10m[49m     After initial construction, applies transitivity to infer additional
[0m[49m[38;5;10m+     697[0m:[38;5;10m[49m     relations and detects cycles (contradictions) in the BEFORE/AFTER subgraph.
[0m[49m[38;5;10m+     698[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     699[0m:[38;5;10m[49m     all_entities = {e["id"]: e for e in events + temporal_expressions}
[0m[49m[38;5;10m+     700[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     701[0m:[38;5;10m[49m     # Build adjacency list representation.
[0m[49m[38;5;10m+     702[0m:[38;5;10m[49m     edges = []
[0m[49m[38;5;10m+     703[0m:[38;5;10m[49m     adjacency = defaultdict(list)  # node_id -> list of (target_id, relation, confidence)
[0m[49m[38;5;10m+     704[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     705[0m:[38;5;10m[49m     for rel in classified_relations:
[0m[49m[38;5;10m+     706[0m:[38;5;10m[49m         edge = {
[0m[49m[38;5;10m+     707[0m:[38;5;10m[49m             "from": rel["entity_a_id"],
[0m[49m[38;5;10m+     708[0m:[38;5;10m[49m             "to": rel["entity_b_id"],
[0m[49m[38;5;10m+     709[0m:[38;5;10m[49m             "relation": rel["relation"],
[0m[49m[38;5;10m+     710[0m:[38;5;10m[49m             "confidence": rel["confidence"],
[0m[49m[38;5;10m+     711[0m:[38;5;10m[49m             "inferred": False,
[0m[49m[38;5;10m+     712[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+     713[0m:[38;5;10m[49m         edges.append(edge)
[0m[49m[38;5;10m+     714[0m:[38;5;10m[49m         adjacency[rel["entity_a_id"]].append(
[0m[49m[38;5;10m+     715[0m:[38;5;10m[49m             (rel["entity_b_id"], rel["relation"], rel["confidence"])
[0m[49m[38;5;10m+     716[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     717[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     718[0m:[38;5;10m[49m     # --- Transitivity propagation ---
[0m[49m[38;5;10m+     719[0m:[38;5;10m[49m     # If A BEFORE B and B BEFORE C, infer A BEFORE C.
[0m[49m[38;5;10m+     720[0m:[38;5;10m[49m     # This increases coverage without additional classifier calls.
[0m[49m[38;5;10m+     721[0m:[38;5;10m[49m     inferred_edges = []
[0m[49m[38;5;10m+     722[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     723[0m:[38;5;10m[49m     for edge_ab in edges:
[0m[49m[38;5;10m+     724[0m:[38;5;10m[49m         if edge_ab["relation"] != "BEFORE":
[0m[49m[38;5;10m+     725[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     726[0m:[38;5;10m[49m         node_b = edge_ab["to"]
[0m[49m[38;5;10m+     727[0m:[38;5;10m[49m         # Find all edges where B is BEFORE something else.
[0m[49m[38;5;10m+     728[0m:[38;5;10m[49m         for target_c, relation_bc, conf_bc in adjacency.get(node_b, []):
[0m[49m[38;5;10m+     729[0m:[38;5;10m[49m             if relation_bc != "BEFORE":
[0m[49m[38;5;10m+     730[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+     731[0m:[38;5;10m[49m             # A BEFORE B and B BEFORE C -> A BEFORE C
[0m[49m[38;5;10m+     732[0m:[38;5;10m[49m             pair_key = (edge_ab["from"], target_c)
[0m[49m[38;5;10m+     733[0m:[38;5;10m[49m             # Check we haven't already classified this pair.
[0m[49m[38;5;10m+     734[0m:[38;5;10m[49m             existing = any(
[0m[49m[38;5;10m+     735[0m:[38;5;10m[49m                 e["from"] == pair_key[0] and e["to"] == pair_key[1]
[0m[49m[38;5;10m+     736[0m:[38;5;10m[49m                 for e in edges + inferred_edges
[0m[49m[38;5;10m+     737[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+     738[0m:[38;5;10m[49m             if not existing and edge_ab["from"] != target_c:
[0m[49m[38;5;10m+     739[0m:[38;5;10m[49m                 inferred_confidence = min(edge_ab["confidence"], conf_bc) * 0.95
[0m[49m[38;5;10m+     740[0m:[38;5;10m[49m                 inferred_edges.append({
[0m[49m[38;5;10m+     741[0m:[38;5;10m[49m                     "from": edge_ab["from"],
[0m[49m[38;5;10m+     742[0m:[38;5;10m[49m                     "to": target_c,
[0m[49m[38;5;10m+     743[0m:[38;5;10m[49m                     "relation": "BEFORE",
[0m[49m[38;5;10m+     744[0m:[38;5;10m[49m                     "confidence": inferred_confidence,
[0m[49m[38;5;10m+     745[0m:[38;5;10m[49m                     "inferred": True,
[0m[49m[38;5;10m+     746[0m:[38;5;10m[49m                 })
[0m[49m[38;5;10m+     747[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     748[0m:[38;5;10m[49m     edges.extend(inferred_edges)
[0m[49m[38;5;10m+     749[0m:[38;5;10m[49m     logger.info("Inferred %d additional relations via transitivity", len(inferred_edges))
[0m[49m[38;5;10m+     750[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     751[0m:[38;5;10m[49m     # --- Cycle detection and resolution ---
[0m[49m[38;5;10m+     752[0m:[38;5;10m[49m     # A cycle in the BEFORE/AFTER graph means contradictory temporal claims.
[0m[49m[38;5;10m+     753[0m:[38;5;10m[49m     # Simple approach: detect and remove the weakest edge in any cycle.
[0m[49m[38;5;10m+     754[0m:[38;5;10m[49m     cycles_resolved = resolve_cycles(edges)
[0m[49m[38;5;10m+     755[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     756[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     757[0m:[38;5;10m[49m         "nodes": all_entities,
[0m[49m[38;5;10m+     758[0m:[38;5;10m[49m         "edges": edges,
[0m[49m[38;5;10m+     759[0m:[38;5;10m[49m         "inferred_count": len(inferred_edges),
[0m[49m[38;5;10m+     760[0m:[38;5;10m[49m         "cycles_resolved": cycles_resolved,
[0m[49m[38;5;10m+     761[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     762[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     763[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     764[0m:[38;5;10m[49m def resolve_cycles(edges):
[0m[49m[38;5;10m+     765[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     766[0m:[38;5;10m[49m     Detect cycles in the BEFORE subgraph and remove the lowest-confidence
[0m[49m[38;5;10m+     767[0m:[38;5;10m[49m     edge in each cycle to restore consistency.
[0m[49m[38;5;10m+     768[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     769[0m:[38;5;10m[49m     Uses a simplified DFS-based cycle detection on the BEFORE edges.
[0m[49m[38;5;10m+     770[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     771[0m:[38;5;10m[49m     # Build a directed graph of BEFORE relations only.
[0m[49m[38;5;10m+     772[0m:[38;5;10m[49m     before_graph = defaultdict(list)
[0m[49m[38;5;10m+     773[0m:[38;5;10m[49m     edge_lookup = {}
[0m[49m[38;5;10m+     774[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     775[0m:[38;5;10m[49m     for edge in edges:
[0m[49m[38;5;10m+     776[0m:[38;5;10m[49m         if edge["relation"] == "BEFORE":
[0m[49m[38;5;10m+     777[0m:[38;5;10m[49m             before_graph[edge["from"]].append(edge["to"])
[0m[49m[38;5;10m+     778[0m:[38;5;10m[49m             edge_lookup[(edge["from"], edge["to"])] = edge
[0m[49m[38;5;10m+     779[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     780[0m:[38;5;10m[49m     # DFS-based cycle detection.
[0m[49m[38;5;10m+     781[0m:[38;5;10m[49m     visited = set()
[0m[49m[38;5;10m+     782[0m:[38;5;10m[49m     in_stack = set()
[0m[49m[38;5;10m+     783[0m:[38;5;10m[49m     cycles_found = 0
[0m[49m[38;5;10m+     784[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     785[0m:[38;5;10m[49m     def dfs(node, path):
[0m[49m[38;5;10m+     786[0m:[38;5;10m[49m         nonlocal cycles_found
[0m[49m[38;5;10m+     787[0m:[38;5;10m[49m         if node in in_stack:
[0m[49m[38;5;10m+     788[0m:[38;5;10m[49m             # Found a cycle. Remove the weakest edge in the cycle portion.
[0m[49m[38;5;10m+     789[0m:[38;5;10m[49m             cycle_start = path.index(node)
[0m[49m[38;5;10m+     790[0m:[38;5;10m[49m             cycle_path = path[cycle_start:]
[0m[49m[38;5;10m+     791[0m:[38;5;10m[49m             # Find the weakest edge in this cycle.
[0m[49m[38;5;10m+     792[0m:[38;5;10m[49m             weakest_conf = float("inf")
[0m[49m[38;5;10m+     793[0m:[38;5;10m[49m             weakest_pair = None
[0m[49m[38;5;10m+     794[0m:[38;5;10m[49m             for k in range(len(cycle_path) - 1):
[0m[49m[38;5;10m+     795[0m:[38;5;10m[49m                 pair = (cycle_path[k], cycle_path[k + 1])
[0m[49m[38;5;10m+     796[0m:[38;5;10m[49m                 if pair in edge_lookup:
[0m[49m[38;5;10m+     797[0m:[38;5;10m[49m                     conf = edge_lookup[pair]["confidence"]
[0m[49m[38;5;10m+     798[0m:[38;5;10m[49m                     if conf < weakest_conf:
[0m[49m[38;5;10m+     799[0m:[38;5;10m[49m                         weakest_conf = conf
[0m[49m[38;5;10m+     800[0m:[38;5;10m[49m                         weakest_pair = pair
[0m[49m[38;5;10m+     801[0m:[38;5;10m[49m             if weakest_pair and weakest_pair in edge_lookup:
[0m[49m[38;5;10m+     802[0m:[38;5;10m[49m                 edges.remove(edge_lookup[weakest_pair])
[0m[49m[38;5;10m+     803[0m:[38;5;10m[49m                 del edge_lookup[weakest_pair]
[0m[49m[38;5;10m+     804[0m:[38;5;10m[49m                 cycles_found += 1
[0m[49m[38;5;10m+     805[0m:[38;5;10m[49m             return
[0m[49m[38;5;10m+     806[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     807[0m:[38;5;10m[49m         if node in visited:
[0m[49m[38;5;10m+     808[0m:[38;5;10m[49m             return
[0m[49m[38;5;10m+     809[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     810[0m:[38;5;10m[49m         visited.add(node)
[0m[49m[38;5;10m+     811[0m:[38;5;10m[49m         in_stack.add(node)
[0m[49m[38;5;10m+     812[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     813[0m:[38;5;10m[49m         for neighbor in before_graph.get(node, []):
[0m[49m[38;5;10m+     814[0m:[38;5;10m[49m             dfs(neighbor, path + [neighbor])
[0m[49m[38;5;10m+     815[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     816[0m:[38;5;10m[49m         in_stack.discard(node)
[0m[49m[38;5;10m+     817[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     818[0m:[38;5;10m[49m     for start_node in list(before_graph.keys()):
[0m[49m[38;5;10m+     819[0m:[38;5;10m[49m         if start_node not in visited:
[0m[49m[38;5;10m+     820[0m:[38;5;10m[49m             dfs(start_node, [start_node])
[0m[49m[38;5;10m+     821[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     822[0m:[38;5;10m[49m     if cycles_found > 0:
[0m[49m[38;5;10m+     823[0m:[38;5;10m[49m         logger.info("Resolved %d temporal inconsistencies (cycles)", cycles_found)
[0m[49m[38;5;10m+     824[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     825[0m:[38;5;10m[49m     return cycles_found
[0m[49m[38;5;10m+     826[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     827[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     828[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     829[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     830[0m:[38;5;10m[49m ## Step 6: Generate the Patient Timeline
[0m[49m[38;5;10m+     831[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     832[0m:[38;5;10m[49m *The pseudocode calls this `generate_timeline(temporal_graph, doc_time)`. We flatten the graph into a chronological sequence of events, assigning absolute timestamps where possible and maintaining relative ordering elsewhere.*
[0m[49m[38;5;10m+     833[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     834[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     835[0m:[38;5;10m[49m def generate_timeline(temporal_graph, doc_time, metadata):
[0m[49m[38;5;10m+     836[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     837[0m:[38;5;10m[49m     Flatten the temporal graph into a linear patient timeline.
[0m[49m[38;5;10m+     838[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     839[0m:[38;5;10m[49m     Events directly linked to normalized temporal expressions get absolute
[0m[49m[38;5;10m+     840[0m:[38;5;10m[49m     timestamps. Events with BEFORE/AFTER relations to anchored events get
[0m[49m[38;5;10m+     841[0m:[38;5;10m[49m     inferred timestamps. Events with only relative ordering get placed in
[0m[49m[38;5;10m+     842[0m:[38;5;10m[49m     sequence without absolute times.
[0m[49m[38;5;10m+     843[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     844[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     845[0m:[38;5;10m[49m         temporal_graph: Output from build_temporal_graph.
[0m[49m[38;5;10m+     846[0m:[38;5;10m[49m         doc_time: Document creation timestamp (ISO 8601).
[0m[49m[38;5;10m+     847[0m:[38;5;10m[49m         metadata: Document metadata (patient_id, document_id).
[0m[49m[38;5;10m+     848[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     849[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     850[0m:[38;5;10m[49m         A timeline dict ready for storage in DynamoDB.
[0m[49m[38;5;10m+     851[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     852[0m:[38;5;10m[49m     nodes = temporal_graph["nodes"]
[0m[49m[38;5;10m+     853[0m:[38;5;10m[49m     edges = temporal_graph["edges"]
[0m[49m[38;5;10m+     854[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     855[0m:[38;5;10m[49m     # First pass: assign absolute timestamps from temporal expressions.
[0m[49m[38;5;10m+     856[0m:[38;5;10m[49m     # Any temporal expression with an ISO-format normalized value gets a timestamp.
[0m[49m[38;5;10m+     857[0m:[38;5;10m[49m     anchored_times = {}
[0m[49m[38;5;10m+     858[0m:[38;5;10m[49m     for node_id, node in nodes.items():
[0m[49m[38;5;10m+     859[0m:[38;5;10m[49m         if node_id.startswith("TIMEX-"):
[0m[49m[38;5;10m+     860[0m:[38;5;10m[49m             normalized = node.get("normalized", "")
[0m[49m[38;5;10m+     861[0m:[38;5;10m[49m             # Check if it's a resolvable date (YYYY-MM-DD format).
[0m[49m[38;5;10m+     862[0m:[38;5;10m[49m             if normalized and re.match(r"\d{4}-\d{2}-\d{2}", normalized):
[0m[49m[38;5;10m+     863[0m:[38;5;10m[49m                 anchored_times[node_id] = normalized
[0m[49m[38;5;10m+     864[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     865[0m:[38;5;10m[49m     # Second pass: propagate timestamps to events linked to temporal expressions.
[0m[49m[38;5;10m+     866[0m:[38;5;10m[49m     event_timestamps = {}
[0m[49m[38;5;10m+     867[0m:[38;5;10m[49m     for edge in edges:
[0m[49m[38;5;10m+     868[0m:[38;5;10m[49m         # If an event has a BEFORE/AFTER/OVERLAP relation with an anchored time,
[0m[49m[38;5;10m+     869[0m:[38;5;10m[49m         # assign or infer a timestamp for that event.
[0m[49m[38;5;10m+     870[0m:[38;5;10m[49m         from_node = edge["from"]
[0m[49m[38;5;10m+     871[0m:[38;5;10m[49m         to_node = edge["to"]
[0m[49m[38;5;10m+     872[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     873[0m:[38;5;10m[49m         if to_node in anchored_times and from_node.startswith("EVT-"):
[0m[49m[38;5;10m+     874[0m:[38;5;10m[49m             if edge["relation"] == "BEFORE":
[0m[49m[38;5;10m+     875[0m:[38;5;10m[49m                 event_timestamps[from_node] = {
[0m[49m[38;5;10m+     876[0m:[38;5;10m[49m                     "timestamp": anchored_times[to_node],
[0m[49m[38;5;10m+     877[0m:[38;5;10m[49m                     "type": "INFERRED",
[0m[49m[38;5;10m+     878[0m:[38;5;10m[49m                     "confidence": edge["confidence"],
[0m[49m[38;5;10m+     879[0m:[38;5;10m[49m                 }
[0m[49m[38;5;10m+     880[0m:[38;5;10m[49m             elif edge["relation"] in ("OVERLAP", "CONTAINS"):
[0m[49m[38;5;10m+     881[0m:[38;5;10m[49m                 event_timestamps[from_node] = {
[0m[49m[38;5;10m+     882[0m:[38;5;10m[49m                     "timestamp": anchored_times[to_node],
[0m[49m[38;5;10m+     883[0m:[38;5;10m[49m                     "type": "INFERRED",
[0m[49m[38;5;10m+     884[0m:[38;5;10m[49m                     "confidence": edge["confidence"],
[0m[49m[38;5;10m+     885[0m:[38;5;10m[49m                 }
[0m[49m[38;5;10m+     886[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     887[0m:[38;5;10m[49m         if from_node in anchored_times and to_node.startswith("EVT-"):
[0m[49m[38;5;10m+     888[0m:[38;5;10m[49m             if edge["relation"] == "BEFORE":
[0m[49m[38;5;10m+     889[0m:[38;5;10m[49m                 event_timestamps[to_node] = {
[0m[49m[38;5;10m+     890[0m:[38;5;10m[49m                     "timestamp": anchored_times[from_node],
[0m[49m[38;5;10m+     891[0m:[38;5;10m[49m                     "type": "INFERRED",
[0m[49m[38;5;10m+     892[0m:[38;5;10m[49m                     "confidence": edge["confidence"],
[0m[49m[38;5;10m+     893[0m:[38;5;10m[49m                 }
[0m[49m[38;5;10m+     894[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     895[0m:[38;5;10m[49m     # Third pass: compute relative ordering for unanchored events
[0m[49m[38;5;10m+     896[0m:[38;5;10m[49m     # using topological sort on the BEFORE edges.
[0m[49m[38;5;10m+     897[0m:[38;5;10m[49m     before_edges = [(e["from"], e["to"]) for e in edges if e["relation"] == "BEFORE"]
[0m[49m[38;5;10m+     898[0m:[38;5;10m[49m     relative_order = topological_sort_events(before_edges, nodes)
[0m[49m[38;5;10m+     899[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     900[0m:[38;5;10m[49m     # Build the timeline entries (events only, not raw temporal expressions).
[0m[49m[38;5;10m+     901[0m:[38;5;10m[49m     timeline = []
[0m[49m[38;5;10m+     902[0m:[38;5;10m[49m     for node_id, node in nodes.items():
[0m[49m[38;5;10m+     903[0m:[38;5;10m[49m         if not node_id.startswith("EVT-"):
[0m[49m[38;5;10m+     904[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     905[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     906[0m:[38;5;10m[49m         ts_info = event_timestamps.get(node_id, {})
[0m[49m[38;5;10m+     907[0m:[38;5;10m[49m         timestamp = ts_info.get("timestamp")
[0m[49m[38;5;10m+     908[0m:[38;5;10m[49m         timestamp_type = ts_info.get("type", "RELATIVE_ONLY")
[0m[49m[38;5;10m+     909[0m:[38;5;10m[49m         ts_confidence = ts_info.get("confidence", node.get("confidence", 0.0))
[0m[49m[38;5;10m+     910[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     911[0m:[38;5;10m[49m         timeline.append({
[0m[49m[38;5;10m+     912[0m:[38;5;10m[49m             "event_id": node_id,
[0m[49m[38;5;10m+     913[0m:[38;5;10m[49m             "event_text": node["text"],
[0m[49m[38;5;10m+     914[0m:[38;5;10m[49m             "event_type": node.get("type", "UNKNOWN"),
[0m[49m[38;5;10m+     915[0m:[38;5;10m[49m             "timestamp": timestamp,
[0m[49m[38;5;10m+     916[0m:[38;5;10m[49m             "timestamp_type": timestamp_type,
[0m[49m[38;5;10m+     917[0m:[38;5;10m[49m             "confidence": ts_confidence,
[0m[49m[38;5;10m+     918[0m:[38;5;10m[49m             "relative_position": relative_order.get(node_id, 999),
[0m[49m[38;5;10m+     919[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     920[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     921[0m:[38;5;10m[49m     # Sort: absolute timestamps first (chronological), then by relative position.
[0m[49m[38;5;10m+     922[0m:[38;5;10m[49m     timeline.sort(key=lambda x: (
[0m[49m[38;5;10m+     923[0m:[38;5;10m[49m         x["timestamp"] or "9999-99-99",  # Unanchored events sort last
[0m[49m[38;5;10m+     924[0m:[38;5;10m[49m         x["relative_position"],
[0m[49m[38;5;10m+     925[0m:[38;5;10m[49m     ))
[0m[49m[38;5;10m+     926[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     927[0m:[38;5;10m[49m     # Count stats.
[0m[49m[38;5;10m+     928[0m:[38;5;10m[49m     anchored_count = sum(1 for t in timeline if t["timestamp_type"] != "RELATIVE_ONLY")
[0m[49m[38;5;10m+     929[0m:[38;5;10m[49m     relative_count = sum(1 for t in timeline if t["timestamp_type"] == "RELATIVE_ONLY")
[0m[49m[38;5;10m+     930[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     931[0m:[38;5;10m[49m     result = {
[0m[49m[38;5;10m+     932[0m:[38;5;10m[49m         "patient_id": metadata.get("patient_id", "UNKNOWN"),
[0m[49m[38;5;10m+     933[0m:[38;5;10m[49m         "document_id": metadata.get("document_id", "UNKNOWN"),
[0m[49m[38;5;10m+     934[0m:[38;5;10m[49m         "doc_time": doc_time,
[0m[49m[38;5;10m+     935[0m:[38;5;10m[49m         "timeline": timeline,
[0m[49m[38;5;10m+     936[0m:[38;5;10m[49m         "event_count": len(timeline),
[0m[49m[38;5;10m+     937[0m:[38;5;10m[49m         "anchored_count": anchored_count,
[0m[49m[38;5;10m+     938[0m:[38;5;10m[49m         "relative_only_count": relative_count,
[0m[49m[38;5;10m+     939[0m:[38;5;10m[49m         "temporal_relations": [
[0m[49m[38;5;10m+     940[0m:[38;5;10m[49m             {
[0m[49m[38;5;10m+     941[0m:[38;5;10m[49m                 "from": e["from"],
[0m[49m[38;5;10m+     942[0m:[38;5;10m[49m                 "to": e["to"],
[0m[49m[38;5;10m+     943[0m:[38;5;10m[49m                 "relation": e["relation"],
[0m[49m[38;5;10m+     944[0m:[38;5;10m[49m                 "confidence": e["confidence"],
[0m[49m[38;5;10m+     945[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+     946[0m:[38;5;10m[49m             for e in edges if not e.get("inferred", False)
[0m[49m[38;5;10m+     947[0m:[38;5;10m[49m         ],
[0m[49m[38;5;10m+     948[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     949[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     950[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+     951[0m:[38;5;10m[49m         "Generated timeline: %d events (%d anchored, %d relative-only)",
[0m[49m[38;5;10m+     952[0m:[38;5;10m[49m         len(timeline), anchored_count, relative_count
[0m[49m[38;5;10m+     953[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     954[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     955[0m:[38;5;10m[49m     return result
[0m[49m[38;5;10m+     956[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     957[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     958[0m:[38;5;10m[49m def topological_sort_events(before_edges, nodes):
[0m[49m[38;5;10m+     959[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     960[0m:[38;5;10m[49m     Compute a topological ordering of events based on BEFORE relations.
[0m[49m[38;5;10m+     961[0m:[38;5;10m[49m     Returns a dict mapping node_id to its position in the ordering.
[0m[49m[38;5;10m+     962[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     963[0m:[38;5;10m[49m     Uses Kahn's algorithm (BFS-based) for simplicity.
[0m[49m[38;5;10m+     964[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     965[0m:[38;5;10m[49m     # Build in-degree counts and adjacency.
[0m[49m[38;5;10m+     966[0m:[38;5;10m[49m     in_degree = defaultdict(int)
[0m[49m[38;5;10m+     967[0m:[38;5;10m[49m     adjacency = defaultdict(list)
[0m[49m[38;5;10m+     968[0m:[38;5;10m[49m     all_nodes = set()
[0m[49m[38;5;10m+     969[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     970[0m:[38;5;10m[49m     for from_id, to_id in before_edges:
[0m[49m[38;5;10m+     971[0m:[38;5;10m[49m         if from_id.startswith("EVT-") or to_id.startswith("EVT-"):
[0m[49m[38;5;10m+     972[0m:[38;5;10m[49m             adjacency[from_id].append(to_id)
[0m[49m[38;5;10m+     973[0m:[38;5;10m[49m             in_degree[to_id] += 1
[0m[49m[38;5;10m+     974[0m:[38;5;10m[49m             all_nodes.add(from_id)
[0m[49m[38;5;10m+     975[0m:[38;5;10m[49m             all_nodes.add(to_id)
[0m[49m[38;5;10m+     976[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     977[0m:[38;5;10m[49m     # Initialize queue with nodes that have no incoming BEFORE edges.
[0m[49m[38;5;10m+     978[0m:[38;5;10m[49m     queue = [n for n in all_nodes if in_degree[n] == 0]
[0m[49m[38;5;10m+     979[0m:[38;5;10m[49m     order = {}
[0m[49m[38;5;10m+     980[0m:[38;5;10m[49m     position = 0
[0m[49m[38;5;10m+     981[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     982[0m:[38;5;10m[49m     while queue:
[0m[49m[38;5;10m+     983[0m:[38;5;10m[49m         # Sort for deterministic ordering among ties.
[0m[49m[38;5;10m+     984[0m:[38;5;10m[49m         queue.sort()
[0m[49m[38;5;10m+     985[0m:[38;5;10m[49m         node = queue.pop(0)
[0m[49m[38;5;10m+     986[0m:[38;5;10m[49m         order[node] = position
[0m[49m[38;5;10m+     987[0m:[38;5;10m[49m         position += 1
[0m[49m[38;5;10m+     988[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     989[0m:[38;5;10m[49m         for neighbor in adjacency[node]:
[0m[49m[38;5;10m+     990[0m:[38;5;10m[49m             in_degree[neighbor] -= 1
[0m[49m[38;5;10m+     991[0m:[38;5;10m[49m             if in_degree[neighbor] == 0:
[0m[49m[38;5;10m+     992[0m:[38;5;10m[49m                 queue.append(neighbor)
[0m[49m[38;5;10m+     993[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     994[0m:[38;5;10m[49m     return order
[0m[49m[38;5;10m+     995[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     996[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     997[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     998[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     999[0m:[38;5;10m[49m ## Step 7: Store the Timeline in DynamoDB
[0m[49m[38;5;10m+    1000[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1001[0m:[38;5;10m[49m *The pseudocode calls this `store_result`. We write the generated timeline to DynamoDB, indexed by patient_id and document_id for efficient retrieval.*
[0m[49m[38;5;10m+    1002[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1003[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    1004[0m:[38;5;10m[49m def store_timeline(timeline_result):
[0m[49m[38;5;10m+    1005[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1006[0m:[38;5;10m[49m     Write the patient timeline to DynamoDB.
[0m[49m[38;5;10m+    1007[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1008[0m:[38;5;10m[49m     The table uses patient_id as the partition key and document_id as the
[0m[49m[38;5;10m+    1009[0m:[38;5;10m[49m     sort key, allowing efficient queries for "all timelines for patient X"
[0m[49m[38;5;10m+    1010[0m:[38;5;10m[49m     or "the timeline from a specific document."
[0m[49m[38;5;10m+    1011[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1012[0m:[38;5;10m[49m     table = dynamodb.Table(TIMELINE_TABLE)
[0m[49m[38;5;10m+    1013[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1014[0m:[38;5;10m[49m     # DynamoDB requires Decimal for numeric values, not float.
[0m[49m[38;5;10m+    1015[0m:[38;5;10m[49m     # Convert all confidence scores.
[0m[49m[38;5;10m+    1016[0m:[38;5;10m[49m     item = json.loads(json.dumps(timeline_result), parse_float=Decimal)
[0m[49m[38;5;10m+    1017[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1018[0m:[38;5;10m[49m     # Add processing metadata.
[0m[49m[38;5;10m+    1019[0m:[38;5;10m[49m     item["processing_timestamp"] = datetime.datetime.now(timezone.utc).isoformat()
[0m[49m[38;5;10m+    1020[0m:[38;5;10m[49m     item["version"] = "1.0"
[0m[49m[38;5;10m+    1021[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1022[0m:[38;5;10m[49m     table.put_item(Item=item)
[0m[49m[38;5;10m+    1023[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1024[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    1025[0m:[38;5;10m[49m         "Stored timeline for patient %s, document %s",
[0m[49m[38;5;10m+    1026[0m:[38;5;10m[49m         timeline_result["patient_id"],
[0m[49m[38;5;10m+    1027[0m:[38;5;10m[49m         timeline_result["document_id"],
[0m[49m[38;5;10m+    1028[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    1029[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1030[0m:[38;5;10m[49m     return item
[0m[49m[38;5;10m+    1031[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    1032[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1033[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    1034[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1035[0m:[38;5;10m[49m ## Putting It All Together
[0m[49m[38;5;10m+    1036[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1037[0m:[38;5;10m[49m Here's the full pipeline assembled into a single function. This is what your Lambda handler (or Step Functions task) would call.
[0m[49m[38;5;10m+    1038[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1039[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    1040[0m:[38;5;10m[49m def extract_temporal_relationships(note_text, document_metadata):
[0m[49m[38;5;10m+    1041[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1042[0m:[38;5;10m[49m     Run the full temporal relationship extraction pipeline for one clinical note.
[0m[49m[38;5;10m+    1043[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1044[0m:[38;5;10m[49m     This is the main entry point. In a Lambda deployment, your handler
[0m[49m[38;5;10m+    1045[0m:[38;5;10m[49m     would parse the input event, extract the note text and metadata,
[0m[49m[38;5;10m+    1046[0m:[38;5;10m[49m     and call this function.
[0m[49m[38;5;10m+    1047[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1048[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    1049[0m:[38;5;10m[49m         note_text: Full text of the clinical note.
[0m[49m[38;5;10m+    1050[0m:[38;5;10m[49m         document_metadata: Dict with 'authored_datetime' (ISO 8601),
[0m[49m[38;5;10m+    1051[0m:[38;5;10m[49m                           'patient_id', and 'document_id'.
[0m[49m[38;5;10m+    1052[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1053[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    1054[0m:[38;5;10m[49m         The generated patient timeline (also stored in DynamoDB).
[0m[49m[38;5;10m+    1055[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1056[0m:[38;5;10m[49m     # Step 1: Preprocess the note (section segmentation, sentence splitting).
[0m[49m[38;5;10m+    1057[0m:[38;5;10m[49m     logger.info("Step 1: Preprocessing note")
[0m[49m[38;5;10m+    1058[0m:[38;5;10m[49m     preprocessed = preprocess_note(note_text, document_metadata)
[0m[49m[38;5;10m+    1059[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1060[0m:[38;5;10m[49m     # Step 2: Detect clinical events and temporal expressions.
[0m[49m[38;5;10m+    1061[0m:[38;5;10m[49m     logger.info("Step 2: Detecting temporal entities")
[0m[49m[38;5;10m+    1062[0m:[38;5;10m[49m     entities = detect_temporal_entities(preprocessed)
[0m[49m[38;5;10m+    1063[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    1064[0m:[38;5;10m[49m         "  Found %d events, %d temporal expressions",
[0m[49m[38;5;10m+    1065[0m:[38;5;10m[49m         len(entities["events"]), len(entities["temporal_expressions"])
[0m[49m[38;5;10m+    1066[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    1067[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1068[0m:[38;5;10m[49m     # Step 3: Generate candidate pairs for classification.
[0m[49m[38;5;10m+    1069[0m:[38;5;10m[49m     logger.info("Step 3: Generating candidate pairs")
[0m[49m[38;5;10m+    1070[0m:[38;5;10m[49m     candidates = generate_candidate_pairs(
[0m[49m[38;5;10m+    1071[0m:[38;5;10m[49m         entities, preprocessed["sentences"], preprocessed["full_text"]
[0m[49m[38;5;10m+    1072[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    1073[0m:[38;5;10m[49m     logger.info("  Generated %d candidate pairs", len(candidates))
[0m[49m[38;5;10m+    1074[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1075[0m:[38;5;10m[49m     # Step 4: Classify temporal relations for each candidate pair.
[0m[49m[38;5;10m+    1076[0m:[38;5;10m[49m     logger.info("Step 4: Classifying temporal relations")
[0m[49m[38;5;10m+    1077[0m:[38;5;10m[49m     classified = classify_relations(
[0m[49m[38;5;10m+    1078[0m:[38;5;10m[49m         candidates, preprocessed["full_text"], preprocessed["sections"]
[0m[49m[38;5;10m+    1079[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    1080[0m:[38;5;10m[49m     logger.info("  Classified %d relations above threshold", len(classified))
[0m[49m[38;5;10m+    1081[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1082[0m:[38;5;10m[49m     # Step 5: Build temporal graph with constraint propagation.
[0m[49m[38;5;10m+    1083[0m:[38;5;10m[49m     logger.info("Step 5: Building temporal graph")
[0m[49m[38;5;10m+    1084[0m:[38;5;10m[49m     graph = build_temporal_graph(
[0m[49m[38;5;10m+    1085[0m:[38;5;10m[49m         classified, entities["events"], entities["temporal_expressions"]
[0m[49m[38;5;10m+    1086[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    1087[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    1088[0m:[38;5;10m[49m         "  Graph: %d nodes, %d edges (%d inferred)",
[0m[49m[38;5;10m+    1089[0m:[38;5;10m[49m         len(graph["nodes"]), len(graph["edges"]), graph["inferred_count"]
[0m[49m[38;5;10m+    1090[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    1091[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1092[0m:[38;5;10m[49m     # Step 6: Generate the patient timeline.
[0m[49m[38;5;10m+    1093[0m:[38;5;10m[49m     logger.info("Step 6: Generating timeline")
[0m[49m[38;5;10m+    1094[0m:[38;5;10m[49m     timeline = generate_timeline(
