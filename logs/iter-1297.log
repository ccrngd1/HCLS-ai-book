[0m[49m[38;5;10m+     124[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     125[0m:[38;5;10m[49m # ---------- Clinical Temporal Patterns ----------
[0m[49m[38;5;10m+     126[0m:[38;5;10m[49m # Regex patterns for domain-specific temporal expressions.
[0m[49m[38;5;10m+     127[0m:[38;5;10m[49m # These won't appear in general-domain temporal parsers.
[0m[49m[38;5;10m+     128[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     129[0m:[38;5;10m[49m CLINICAL_TEMPORAL_PATTERNS = [
[0m[49m[38;5;10m+     130[0m:[38;5;10m[49m     # Postoperative day: POD#2, POD 2, pod#1
[0m[49m[38;5;10m+     131[0m:[38;5;10m[49m     (r"(?i)pod\s*#?\s*(\d+)", "POSTOP_DAY"),
[0m[49m[38;5;10m+     132[0m:[38;5;10m[49m     # Hospital day: HD3, HD#5, hospital day 3
[0m[49m[38;5;10m+     133[0m:[38;5;10m[49m     (r"(?i)(?:hd|hospital\s+day)\s*#?\s*(\d+)", "HOSPITAL_DAY"),
[0m[49m[38;5;10m+     134[0m:[38;5;10m[49m     # Day of life (neonates): DOL 3, DOL#2
[0m[49m[38;5;10m+     135[0m:[38;5;10m[49m     (r"(?i)dol\s*#?\s*(\d+)", "DAY_OF_LIFE"),
[0m[49m[38;5;10m+     136[0m:[38;5;10m[49m     # Transplant day: T+14, t+3
[0m[49m[38;5;10m+     137[0m:[38;5;10m[49m     (r"(?i)t\s*\+\s*(\d+)", "TRANSPLANT_DAY"),
[0m[49m[38;5;10m+     138[0m:[38;5;10m[49m     # Chemo cycle: Cycle 3 Day 1, C3D1
[0m[49m[38;5;10m+     139[0m:[38;5;10m[49m     (r"(?i)(?:cycle\s*(\d+)\s*day\s*(\d+)|c(\d+)d(\d+))", "CHEMO_CYCLE"),
[0m[49m[38;5;10m+     140[0m:[38;5;10m[49m     # Relative days: "2 days ago", "3 weeks later", "48 hours after"
[0m[49m[38;5;10m+     141[0m:[38;5;10m[49m     (r"(\d+)\s*(day|week|month|hour|year)s?\s*(ago|later|after|before|prior)", "RELATIVE"),
[0m[49m[38;5;10m+     142[0m:[38;5;10m[49m     # Postoperatively, preoperatively
[0m[49m[38;5;10m+     143[0m:[38;5;10m[49m     (r"(?i)(post|pre)[-\s]?operatively", "PERIOP_RELATIVE"),
[0m[49m[38;5;10m+     144[0m:[38;5;10m[49m     # Explicit dates: March 3, 2024 or 3/3/2024 or 2024-03-03
[0m[49m[38;5;10m+     145[0m:[38;5;10m[49m     (r"(\d{4})-(\d{2})-(\d{2})", "ISO_DATE"),
[0m[49m[38;5;10m+     146[0m:[38;5;10m[49m     (r"(\d{1,2})/(\d{1,2})/(\d{2,4})", "US_DATE"),
[0m[49m[38;5;10m+     147[0m:[38;5;10m[49m     (r"(?i)(january|february|march|april|may|june|july|august|september|october|november|december)\s+(\d{1,2})(?:,?\s*(\d{4}))?", "NAMED_DATE"),
[0m[49m[38;5;10m+     148[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+     149[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     150[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     151[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     152[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     153[0m:[38;5;10m[49m ## Step 1: Preprocess and Segment the Clinical Note
[0m[49m[38;5;10m+     154[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     155[0m:[38;5;10m[49m *The pseudocode calls this `preprocess_note(note_text, document_metadata)`. It identifies section boundaries, splits sentences, and establishes the document creation timestamp as the temporal anchor for all relative expressions.*
[0m[49m[38;5;10m+     156[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     157[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     158[0m:[38;5;10m[49m def segment_sections(text):
[0m[49m[38;5;10m+     159[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     160[0m:[38;5;10m[49m     Identify section boundaries in clinical text by looking for common
[0m[49m[38;5;10m+     161[0m:[38;5;10m[49m     header patterns. Returns a list of sections with their temporal context.
[0m[49m[38;5;10m+     162[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     163[0m:[38;5;10m[49m     Clinical notes follow conventions: headers are often on their own line,
[0m[49m[38;5;10m+     164[0m:[38;5;10m[49m     may be ALL CAPS, may end with a colon, or may be bold/underlined in the
[0m[49m[38;5;10m+     165[0m:[38;5;10m[49m     source (which shows up as formatting artifacts after text extraction).
[0m[49m[38;5;10m+     166[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     167[0m:[38;5;10m[49m     # Common section header patterns in clinical notes.
[0m[49m[38;5;10m+     168[0m:[38;5;10m[49m     # These appear on their own line, possibly followed by a colon.
[0m[49m[38;5;10m+     169[0m:[38;5;10m[49m     header_pattern = re.compile(
[0m[49m[38;5;10m+     170[0m:[38;5;10m[49m         r"^([A-Z][A-Za-z /&]+):?\s*$", re.MULTILINE
[0m[49m[38;5;10m+     171[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     172[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     173[0m:[38;5;10m[49m     sections = []
[0m[49m[38;5;10m+     174[0m:[38;5;10m[49m     matches = list(header_pattern.finditer(text))
[0m[49m[38;5;10m+     175[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     176[0m:[38;5;10m[49m     for i, match in enumerate(matches):
[0m[49m[38;5;10m+     177[0m:[38;5;10m[49m         header = match.group(1).strip()
[0m[49m[38;5;10m+     178[0m:[38;5;10m[49m         start = match.end()
[0m[49m[38;5;10m+     179[0m:[38;5;10m[49m         # Section content runs until the next header or end of text.
[0m[49m[38;5;10m+     180[0m:[38;5;10m[49m         end = matches[i + 1].start() if i + 1 < len(matches) else len(text)
[0m[49m[38;5;10m+     181[0m:[38;5;10m[49m         content = text[start:end].strip()
[0m[49m[38;5;10m+     182[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     183[0m:[38;5;10m[49m         # Look up temporal context for this section type.
[0m[49m[38;5;10m+     184[0m:[38;5;10m[49m         temporal_context = SECTION_TEMPORAL_CONTEXT.get(
[0m[49m[38;5;10m+     185[0m:[38;5;10m[49m             header.lower(), "UNKNOWN"
[0m[49m[38;5;10m+     186[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     187[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     188[0m:[38;5;10m[49m         sections.append({
[0m[49m[38;5;10m+     189[0m:[38;5;10m[49m             "header": header,
[0m[49m[38;5;10m+     190[0m:[38;5;10m[49m             "content": content,
[0m[49m[38;5;10m+     191[0m:[38;5;10m[49m             "start": match.start(),
[0m[49m[38;5;10m+     192[0m:[38;5;10m[49m             "end": end,
[0m[49m[38;5;10m+     193[0m:[38;5;10m[49m             "temporal_context": temporal_context,
[0m[49m[38;5;10m+     194[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     195[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     196[0m:[38;5;10m[49m     # If no headers found, treat entire text as one NARRATIVE section.
[0m[49m[38;5;10m+     197[0m:[38;5;10m[49m     if not sections:
[0m[49m[38;5;10m+     198[0m:[38;5;10m[49m         sections.append({
[0m[49m[38;5;10m+     199[0m:[38;5;10m[49m             "header": "FULL_NOTE",
[0m[49m[38;5;10m+     200[0m:[38;5;10m[49m             "content": text,
[0m[49m[38;5;10m+     201[0m:[38;5;10m[49m             "start": 0,
[0m[49m[38;5;10m+     202[0m:[38;5;10m[49m             "end": len(text),
[0m[49m[38;5;10m+     203[0m:[38;5;10m[49m             "temporal_context": "NARRATIVE",
[0m[49m[38;5;10m+     204[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     205[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     206[0m:[38;5;10m[49m     return sections
[0m[49m[38;5;10m+     207[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     208[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     209[0m:[38;5;10m[49m def split_sentences(text):
[0m[49m[38;5;10m+     210[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     211[0m:[38;5;10m[49m     Split clinical text into sentences. Clinical text has non-standard
[0m[49m[38;5;10m+     212[0m:[38;5;10m[49m     sentence boundaries: abbreviations with periods ("pt."), lab values
[0m[49m[38;5;10m+     213[0m:[38;5;10m[49m     with decimals ("WBC 12.3"), numbered lists, and more.
[0m[49m[38;5;10m+     214[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     215[0m:[38;5;10m[49m     This is a simplified splitter. Production systems use specialized
[0m[49m[38;5;10m+     216[0m:[38;5;10m[49m     clinical sentence tokenizers (e.g., from the NLTK punkt model trained
[0m[49m[38;5;10m+     217[0m:[38;5;10m[49m     on clinical text, or the sentencizer from scispaCy).
[0m[49m[38;5;10m+     218[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     219[0m:[38;5;10m[49m     # Split on period followed by space and capital letter, question marks,
[0m[49m[38;5;10m+     220[0m:[38;5;10m[49m     # and newlines that start a new thought.
[0m[49m[38;5;10m+     221[0m:[38;5;10m[49m     # Avoid splitting on common clinical abbreviations.
[0m[49m[38;5;10m+     222[0m:[38;5;10m[49m     abbreviations = {"dr", "pt", "mr", "mrs", "ms", "vs", "etc", "approx"}
[0m[49m[38;5;10m+     223[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     224[0m:[38;5;10m[49m     # Rough split on sentence-ending punctuation followed by whitespace.
[0m[49m[38;5;10m+     225[0m:[38;5;10m[49m     raw_splits = re.split(r"(?<=[.!?])\s+(?=[A-Z])", text)
[0m[49m[38;5;10m+     226[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     227[0m:[38;5;10m[49m     sentences = []
[0m[49m[38;5;10m+     228[0m:[38;5;10m[49m     for i, s in enumerate(raw_splits):
[0m[49m[38;5;10m+     229[0m:[38;5;10m[49m         s = s.strip()
[0m[49m[38;5;10m+     230[0m:[38;5;10m[49m         if s:
[0m[49m[38;5;10m+     231[0m:[38;5;10m[49m             sentences.append({
[0m[49m[38;5;10m+     232[0m:[38;5;10m[49m                 "text": s,
[0m[49m[38;5;10m+     233[0m:[38;5;10m[49m                 "index": i,
[0m[49m[38;5;10m+     234[0m:[38;5;10m[49m                 "start_char": text.find(s),
[0m[49m[38;5;10m+     235[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+     236[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     237[0m:[38;5;10m[49m     return sentences
[0m[49m[38;5;10m+     238[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     239[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     240[0m:[38;5;10m[49m def preprocess_note(note_text, document_metadata):
[0m[49m[38;5;10m+     241[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     242[0m:[38;5;10m[49m     Preprocess a clinical note for temporal analysis.
[0m[49m[38;5;10m+     243[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     244[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     245[0m:[38;5;10m[49m         note_text: The full text of the clinical note.
[0m[49m[38;5;10m+     246[0m:[38;5;10m[49m         document_metadata: Dict with at least 'authored_datetime' (ISO 8601),
[0m[49m[38;5;10m+     247[0m:[38;5;10m[49m                           'patient_id', and 'document_id'.
[0m[49m[38;5;10m+     248[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     249[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     250[0m:[38;5;10m[49m         A dict with doc_time, sections, sentences, and the original text.
[0m[49m[38;5;10m+     251[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     252[0m:[38;5;10m[49m     # The document creation timestamp anchors all relative temporal expressions.
[0m[49m[38;5;10m+     253[0m:[38;5;10m[49m     # Clinical notes are frequently batch-charted hours after the encounter.
[0m[49m[38;5;10m+     254[0m:[38;5;10m[49m     # Use the note's authored timestamp, not the encounter date.
[0m[49m[38;5;10m+     255[0m:[38;5;10m[49m     doc_time = document_metadata.get("authored_datetime")
[0m[49m[38;5;10m+     256[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     257[0m:[38;5;10m[49m     sections = segment_sections(note_text)
[0m[49m[38;5;10m+     258[0m:[38;5;10m[49m     sentences = split_sentences(note_text)
[0m[49m[38;5;10m+     259[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     260[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+     261[0m:[38;5;10m[49m         "Preprocessed note: %d sections, %d sentences",
[0m[49m[38;5;10m+     262[0m:[38;5;10m[49m         len(sections), len(sentences)
[0m[49m[38;5;10m+     263[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     264[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     265[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     266[0m:[38;5;10m[49m         "doc_time": doc_time,
[0m[49m[38;5;10m+     267[0m:[38;5;10m[49m         "sections": sections,
[0m[49m[38;5;10m+     268[0m:[38;5;10m[49m         "sentences": sentences,
[0m[49m[38;5;10m+     269[0m:[38;5;10m[49m         "full_text": note_text,
[0m[49m[38;5;10m+     270[0m:[38;5;10m[49m         "metadata": document_metadata,
[0m[49m[38;5;10m+     271[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     272[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     273[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     274[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     275[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     276[0m:[38;5;10m[49m ## Step 2: Detect Clinical Events and Temporal Expressions
[0m[49m[38;5;10m+     277[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     278[0m:[38;5;10m[49m *The pseudocode calls this `detect_temporal_entities(preprocessed_note)`. We use Amazon Comprehend Medical for clinical event detection and a regex-based parser for temporal expressions. Production systems would use HeidelTime or SUTime for the temporal parsing; the regex approach here demonstrates the concept.*
[0m[49m[38;5;10m+     279[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     280[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     281[0m:[38;5;10m[49m def detect_events_comprehend_medical(text):
[0m[49m[38;5;10m+     282[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     283[0m:[38;5;10m[49m     Use Amazon Comprehend Medical to detect clinical events in text.
[0m[49m[38;5;10m+     284[0m:[38;5;10m[49m     Events include: diagnoses, procedures, medications, tests, symptoms.
[0m[49m[38;5;10m+     285[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     286[0m:[38;5;10m[49m     Comprehend Medical returns entities with categories like MEDICAL_CONDITION,
[0m[49m[38;5;10m+     287[0m:[38;5;10m[49m     MEDICATION, PROCEDURE, TEST_TREATMENT_PROCEDURE. We filter to entities
[0m[49m[38;5;10m+     288[0m:[38;5;10m[49m     that represent temporal events (things that happened at some point in time).
[0m[49m[38;5;10m+     289[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     290[0m:[38;5;10m[49m     # Comprehend Medical has a 20,000 character limit per call.
[0m[49m[38;5;10m+     291[0m:[38;5;10m[49m     # For longer notes, you'd chunk the text (see gap to production).
[0m[49m[38;5;10m+     292[0m:[38;5;10m[49m     response = comprehend_medical_client.detect_entities_v2(Text=text[:20000])
[0m[49m[38;5;10m+     293[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     294[0m:[38;5;10m[49m     events = []
[0m[49m[38;5;10m+     295[0m:[38;5;10m[49m     for entity in response.get("Entities", []):
[0m[49m[38;5;10m+     296[0m:[38;5;10m[49m         # Skip entities below our confidence threshold.
[0m[49m[38;5;10m+     297[0m:[38;5;10m[49m         if entity.get("Score", 0) < ENTITY_CONFIDENCE_THRESHOLD:
[0m[49m[38;5;10m+     298[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     299[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     300[0m:[38;5;10m[49m         # Map Comprehend Medical categories to event types.
[0m[49m[38;5;10m+     301[0m:[38;5;10m[49m         category = entity.get("Category", "")
[0m[49m[38;5;10m+     302[0m:[38;5;10m[49m         event_type_map = {
[0m[49m[38;5;10m+     303[0m:[38;5;10m[49m             "MEDICAL_CONDITION": "DIAGNOSIS",
[0m[49m[38;5;10m+     304[0m:[38;5;10m[49m             "MEDICATION": "MEDICATION",
[0m[49m[38;5;10m+     305[0m:[38;5;10m[49m             "TEST_TREATMENT_PROCEDURE": "PROCEDURE",
[0m[49m[38;5;10m+     306[0m:[38;5;10m[49m             "ANATOMY": None,  # Not a temporal event
[0m[49m[38;5;10m+     307[0m:[38;5;10m[49m             "PROTECTED_HEALTH_INFORMATION": None,  # Not a temporal event
[0m[49m[38;5;10m+     308[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+     309[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     310[0m:[38;5;10m[49m         event_type = event_type_map.get(category)
[0m[49m[38;5;10m+     311[0m:[38;5;10m[49m         if event_type is None:
[0m[49m[38;5;10m+     312[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     313[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     314[0m:[38;5;10m[49m         # Check traits for assertion status (negation, etc.)
[0m[49m[38;5;10m+     315[0m:[38;5;10m[49m         traits = {t["Name"]: t["Score"] for t in entity.get("Traits", [])}
[0m[49m[38;5;10m+     316[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     317[0m:[38;5;10m[49m         events.append({
[0m[49m[38;5;10m+     318[0m:[38;5;10m[49m             "id": f"EVT-{entity['BeginOffset']:04d}",
[0m[49m[38;5;10m+     319[0m:[38;5;10m[49m             "text": entity["Text"],
[0m[49m[38;5;10m+     320[0m:[38;5;10m[49m             "type": event_type,
[0m[49m[38;5;10m+     321[0m:[38;5;10m[49m             "category": category,
[0m[49m[38;5;10m+     322[0m:[38;5;10m[49m             "begin_offset": entity["BeginOffset"],
[0m[49m[38;5;10m+     323[0m:[38;5;10m[49m             "end_offset": entity["EndOffset"],
[0m[49m[38;5;10m+     324[0m:[38;5;10m[49m             "confidence": entity["Score"],
[0m[49m[38;5;10m+     325[0m:[38;5;10m[49m             "is_negated": traits.get("NEGATION", 0) > 0.5,
[0m[49m[38;5;10m+     326[0m:[38;5;10m[49m             "traits": traits,
[0m[49m[38;5;10m+     327[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     328[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     329[0m:[38;5;10m[49m     logger.info("Detected %d clinical events via Comprehend Medical", len(events))
[0m[49m[38;5;10m+     330[0m:[38;5;10m[49m     return events
[0m[49m[38;5;10m+     331[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     332[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     333[0m:[38;5;10m[49m def recognize_temporal_expressions(text, doc_time):
[0m[49m[38;5;10m+     334[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     335[0m:[38;5;10m[49m     Identify and normalize temporal expressions in clinical text.
[0m[49m[38;5;10m+     336[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     337[0m:[38;5;10m[49m     This is a simplified regex-based parser. Production systems use
[0m[49m[38;5;10m+     338[0m:[38;5;10m[49m     HeidelTime (Java-based, rule-driven, handles 90%+ of temporal expressions)
[0m[49m[38;5;10m+     339[0m:[38;5;10m[49m     or SUTime (Stanford NLP). The regex approach here covers the most common
[0m[49m[38;5;10m+     340[0m:[38;5;10m[49m     clinical patterns to demonstrate the concept.
[0m[49m[38;5;10m+     341[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     342[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     343[0m:[38;5;10m[49m         text: Clinical note text.
[0m[49m[38;5;10m+     344[0m:[38;5;10m[49m         doc_time: Document creation timestamp (ISO 8601 string) for anchoring
[0m[49m[38;5;10m+     345[0m:[38;5;10m[49m                   relative expressions.
[0m[49m[38;5;10m+     346[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     347[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     348[0m:[38;5;10m[49m         List of temporal expression dicts with normalized values.
[0m[49m[38;5;10m+     349[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     350[0m:[38;5;10m[49m     doc_datetime = datetime.datetime.fromisoformat(doc_time.replace("Z", "+00:00"))
[0m[49m[38;5;10m+     351[0m:[38;5;10m[49m     temporal_expressions = []
[0m[49m[38;5;10m+     352[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     353[0m:[38;5;10m[49m     for pattern, pattern_type in CLINICAL_TEMPORAL_PATTERNS:
[0m[49m[38;5;10m+     354[0m:[38;5;10m[49m         for match in re.finditer(pattern, text):
[0m[49m[38;5;10m+     355[0m:[38;5;10m[49m             raw_text = match.group(0)
[0m[49m[38;5;10m+     356[0m:[38;5;10m[49m             normalized = None
[0m[49m[38;5;10m+     357[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     358[0m:[38;5;10m[49m             if pattern_type == "ISO_DATE":
[0m[49m[38;5;10m+     359[0m:[38;5;10m[49m                 year, month, day = match.groups()
[0m[49m[38;5;10m+     360[0m:[38;5;10m[49m                 normalized = f"{year}-{month}-{day}"
[0m[49m[38;5;10m+     361[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     362[0m:[38;5;10m[49m             elif pattern_type == "US_DATE":
[0m[49m[38;5;10m+     363[0m:[38;5;10m[49m                 month, day, year = match.groups()
[0m[49m[38;5;10m+     364[0m:[38;5;10m[49m                 if len(year) == 2:
[0m[49m[38;5;10m+     365[0m:[38;5;10m[49m                     year = "20" + year
[0m[49m[38;5;10m+     366[0m:[38;5;10m[49m                 normalized = f"{year}-{int(month):02d}-{int(day):02d}"
[0m[49m[38;5;10m+     367[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     368[0m:[38;5;10m[49m             elif pattern_type == "NAMED_DATE":
[0m[49m[38;5;10m+     369[0m:[38;5;10m[49m                 month_names = {
[0m[49m[38;5;10m+     370[0m:[38;5;10m[49m                     "january": 1, "february": 2, "march": 3, "april": 4,
[0m[49m[38;5;10m+     371[0m:[38;5;10m[49m                     "may": 5, "june": 6, "july": 7, "august": 8,
[0m[49m[38;5;10m+     372[0m:[38;5;10m[49m                     "september": 9, "october": 10, "november": 11, "december": 12,
[0m[49m[38;5;10m+     373[0m:[38;5;10m[49m                 }
[0m[49m[38;5;10m+     374[0m:[38;5;10m[49m                 month_name = match.group(1).lower()
[0m[49m[38;5;10m+     375[0m:[38;5;10m[49m                 day = int(match.group(2))
[0m[49m[38;5;10m+     376[0m:[38;5;10m[49m                 year = int(match.group(3)) if match.group(3) else doc_datetime.year
[0m[49m[38;5;10m+     377[0m:[38;5;10m[49m                 month_num = month_names.get(month_name, 1)
[0m[49m[38;5;10m+     378[0m:[38;5;10m[49m                 normalized = f"{year}-{month_num:02d}-{day:02d}"
[0m[49m[38;5;10m+     379[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     380[0m:[38;5;10m[49m             elif pattern_type == "RELATIVE":
[0m[49m[38;5;10m+     381[0m:[38;5;10m[49m                 amount = int(match.group(1))
[0m[49m[38;5;10m+     382[0m:[38;5;10m[49m                 unit = match.group(2).lower()
[0m[49m[38;5;10m+     383[0m:[38;5;10m[49m                 direction = match.group(3).lower()
[0m[49m[38;5;10m+     384[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     385[0m:[38;5;10m[49m                 delta_map = {
[0m[49m[38;5;10m+     386[0m:[38;5;10m[49m                     "hour": timedelta(hours=amount),
[0m[49m[38;5;10m+     387[0m:[38;5;10m[49m                     "day": timedelta(days=amount),
[0m[49m[38;5;10m+     388[0m:[38;5;10m[49m                     "week": timedelta(weeks=amount),
[0m[49m[38;5;10m+     389[0m:[38;5;10m[49m                     "month": timedelta(days=amount * 30),  # Approximate
[0m[49m[38;5;10m+     390[0m:[38;5;10m[49m                     "year": timedelta(days=amount * 365),
[0m[49m[38;5;10m+     391[0m:[38;5;10m[49m                 }
[0m[49m[38;5;10m+     392[0m:[38;5;10m[49m                 delta = delta_map.get(unit, timedelta(days=amount))
[0m[49m[38;5;10m+     393[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     394[0m:[38;5;10m[49m                 if direction in ("ago", "before", "prior"):
[0m[49m[38;5;10m+     395[0m:[38;5;10m[49m                     resolved = doc_datetime - delta
[0m[49m[38;5;10m+     396[0m:[38;5;10m[49m                 else:
