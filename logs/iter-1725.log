[0m[49m[38;5;10m+      696[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      697[0m:[38;5;10m[49m *The architecture companion's Step 6 describes collecting actual outcomes after appointments occur, computing rolling AUC, and triggering retraining when performance degrades. Here's the Lambda logic that closes that feedback loop.*
[0m[49m[38;5;10m+      698[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      699[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+      700[0m:[38;5;10m[49m def collect_ground_truth(target_date: str, actuals: list[dict]) -> dict:
[0m[49m[38;5;10m+      701[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+      702[0m:[38;5;10m[49m     Join predictions with actual outcomes and compute model performance metrics.
[0m[49m[38;5;10m+      703[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      704[0m:[38;5;10m[49m     Runs nightly (triggered by EventBridge), one day after the appointment date.
[0m[49m[38;5;10m+      705[0m:[38;5;10m[49m     Compares what the model predicted against what actually happened, computes
[0m[49m[38;5;10m+      706[0m:[38;5;10m[49m     rolling AUC, and publishes metrics to CloudWatch.
[0m[49m[38;5;10m+      707[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      708[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+      709[0m:[38;5;10m[49m         target_date: ISO date string for the appointment date to evaluate
[0m[49m[38;5;10m+      710[0m:[38;5;10m[49m             (typically yesterday).
[0m[49m[38;5;10m+      711[0m:[38;5;10m[49m         actuals: List of dicts with appointment_id and actual_status
[0m[49m[38;5;10m+      712[0m:[38;5;10m[49m             ("completed" or "no_show") from the scheduling system.
[0m[49m[38;5;10m+      713[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      714[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+      715[0m:[38;5;10m[49m         Dict with daily_auc, prediction_count, and retrain_triggered flag.
[0m[49m[38;5;10m+      716[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+      717[0m:[38;5;10m[49m     from sklearn.metrics import roc_auc_score, brier_score_loss
[0m[49m[38;5;10m+      718[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      719[0m:[38;5;10m[49m     cloudwatch = boto3.client("cloudwatch", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+      720[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      721[0m:[38;5;10m[49m     # Query all predictions for appointments on target_date.
[0m[49m[38;5;10m+      722[0m:[38;5;10m[49m     table = dynamodb.Table(PREDICTIONS_TABLE)
[0m[49m[38;5;10m+      723[0m:[38;5;10m[49m     response = table.query(
[0m[49m[38;5;10m+      724[0m:[38;5;10m[49m         IndexName="scheduled-date-index",
[0m[49m[38;5;10m+      725[0m:[38;5;10m[49m         KeyConditionExpression=Key("scheduled_date").eq(target_date),
[0m[49m[38;5;10m+      726[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+      727[0m:[38;5;10m[49m     predictions = {
[0m[49m[38;5;10m+      728[0m:[38;5;10m[49m         item["appointment_id"]: float(item["no_show_probability"])
[0m[49m[38;5;10m+      729[0m:[38;5;10m[49m         for item in response.get("Items", [])
[0m[49m[38;5;10m+      730[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+      731[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      732[0m:[38;5;10m[49m     # Join predictions with actuals.
[0m[49m[38;5;10m+      733[0m:[38;5;10m[49m     y_true = []
[0m[49m[38;5;10m+      734[0m:[38;5;10m[49m     y_scores = []
[0m[49m[38;5;10m+      735[0m:[38;5;10m[49m     for actual in actuals:
[0m[49m[38;5;10m+      736[0m:[38;5;10m[49m         appt_id = actual["appointment_id"]
[0m[49m[38;5;10m+      737[0m:[38;5;10m[49m         if appt_id in predictions:
[0m[49m[38;5;10m+      738[0m:[38;5;10m[49m             y_true.append(1 if actual["actual_status"] == "no_show" else 0)
[0m[49m[38;5;10m+      739[0m:[38;5;10m[49m             y_scores.append(predictions[appt_id])
[0m[49m[38;5;10m+      740[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      741[0m:[38;5;10m[49m     if len(y_true) < 10:
[0m[49m[38;5;10m+      742[0m:[38;5;10m[49m         logger.warning(
[0m[49m[38;5;10m+      743[0m:[38;5;10m[49m             "Only %d joined records for %s; skipping metric computation.",
[0m[49m[38;5;10m+      744[0m:[38;5;10m[49m             len(y_true), target_date,
[0m[49m[38;5;10m+      745[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+      746[0m:[38;5;10m[49m         return {"daily_auc": None, "prediction_count": len(y_true), "retrain_triggered": False}
[0m[49m[38;5;10m+      747[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      748[0m:[38;5;10m[49m     daily_auc = roc_auc_score(y_true, y_scores)
[0m[49m[38;5;10m+      749[0m:[38;5;10m[49m     daily_brier = brier_score_loss(y_true, y_scores)
[0m[49m[38;5;10m+      750[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      751[0m:[38;5;10m[49m     # Publish to CloudWatch.
[0m[49m[38;5;10m+      752[0m:[38;5;10m[49m     cloudwatch.put_metric_data(
[0m[49m[38;5;10m+      753[0m:[38;5;10m[49m         Namespace="NoShowModel",
[0m[49m[38;5;10m+      754[0m:[38;5;10m[49m         MetricData=[
[0m[49m[38;5;10m+      755[0m:[38;5;10m[49m             {"MetricName": "DailyAUC", "Value": daily_auc, "Unit": "None"},
[0m[49m[38;5;10m+      756[0m:[38;5;10m[49m             {"MetricName": "DailyBrierScore", "Value": daily_brier, "Unit": "None"},
[0m[49m[38;5;10m+      757[0m:[38;5;10m[49m             {"MetricName": "PredictionCount", "Value": len(y_true), "Unit": "Count"},
[0m[49m[38;5;10m+      758[0m:[38;5;10m[49m         ],
[0m[49m[38;5;10m+      759[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+      760[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      761[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+      762[0m:[38;5;10m[49m         "Ground truth for %s: AUC=%.3f, Brier=%.4f, n=%d",
[0m[49m[38;5;10m+      763[0m:[38;5;10m[49m         target_date, daily_auc, daily_brier, len(y_true),
[0m[49m[38;5;10m+      764[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+      765[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      766[0m:[38;5;10m[49m     # Check if retraining is needed.
[0m[49m[38;5;10m+      767[0m:[38;5;10m[49m     # In production, compute a 30-day rolling AUC from CloudWatch metrics
[0m[49m[38;5;10m+      768[0m:[38;5;10m[49m     # rather than a single-day value (too noisy). Here we demonstrate the
[0m[49m[38;5;10m+      769[0m:[38;5;10m[49m     # threshold check against the daily value for simplicity.
[0m[49m[38;5;10m+      770[0m:[38;5;10m[49m     AUC_RETRAIN_THRESHOLD = 0.72
[0m[49m[38;5;10m+      771[0m:[38;5;10m[49m     retrain_triggered = daily_auc < AUC_RETRAIN_THRESHOLD
[0m[49m[38;5;10m+      772[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      773[0m:[38;5;10m[49m     if retrain_triggered:
[0m[49m[38;5;10m+      774[0m:[38;5;10m[49m         logger.warning(
[0m[49m[38;5;10m+      775[0m:[38;5;10m[49m             "AUC %.3f below threshold %.2f. Retraining should be triggered.",
[0m[49m[38;5;10m+      776[0m:[38;5;10m[49m             daily_auc, AUC_RETRAIN_THRESHOLD,
[0m[49m[38;5;10m+      777[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+      778[0m:[38;5;10m[49m         # In production: publish to an EventBridge event or SNS topic
[0m[49m[38;5;10m+      779[0m:[38;5;10m[49m         # that triggers the retraining pipeline.
[0m[49m[38;5;10m+      780[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      781[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+      782[0m:[38;5;10m[49m         "daily_auc": daily_auc,
[0m[49m[38;5;10m+      783[0m:[38;5;10m[49m         "prediction_count": len(y_true),
[0m[49m[38;5;10m+      784[0m:[38;5;10m[49m         "retrain_triggered": retrain_triggered,
[0m[49m[38;5;10m+      785[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+      786[0m:[38;5;10m[49m ```
