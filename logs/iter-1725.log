[0m[49m[38;5;10m+      294[0m:[38;5;10m[49m **Step 6: Ground truth collection and model monitoring.** After the appointment date passes, you know the actual outcome: did the patient show up or not? A nightly Lambda (or scheduled Glue job) joins predictions with actual outcomes from the scheduling system, computes rolling model performance metrics, publishes them to CloudWatch, and triggers retraining when performance drops below an acceptable threshold. Without this feedback loop, your model silently degrades as patient behavior shifts, new providers join, or your practice adds telehealth options. You won't notice until someone asks "why aren't our no-show reminders working anymore?"
[0m[49m[38;5;10m+      295[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      296[0m:[38;5;10m[49m ```pseudocode
[0m[49m[38;5;10m+      297[0m:[38;5;10m[49m FUNCTION collect_ground_truth_and_monitor():
[0m[49m[38;5;10m+      298[0m:[38;5;10m[49m     // Runs nightly via EventBridge, one day after the appointment date.
[0m[49m[38;5;10m+      299[0m:[38;5;10m[49m     // Joins predictions (from DynamoDB) with actual outcomes (from scheduling system).
[0m[49m[38;5;10m+      300[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      301[0m:[38;5;10m[49m     yesterday = today - 1 day
[0m[49m[38;5;10m+      302[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      303[0m:[38;5;10m[49m     // Pull all predictions for appointments that occurred yesterday.
[0m[49m[38;5;10m+      304[0m:[38;5;10m[49m     predictions = query DynamoDB "appointment-predictions"
[0m[49m[38;5;10m+      305[0m:[38;5;10m[49m                   WHERE scheduled_date = yesterday
[0m[49m[38;5;10m+      306[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      307[0m:[38;5;10m[49m     // Pull actual outcomes from the scheduling system.
[0m[49m[38;5;10m+      308[0m:[38;5;10m[49m     // Each appointment now has a final status: "completed", "no_show", "cancelled", "rescheduled".
[0m[49m[38;5;10m+      309[0m:[38;5;10m[49m     actuals = query scheduling_system
[0m[49m[38;5;10m+      310[0m:[38;5;10m[49m               WHERE appointment_date = yesterday
[0m[49m[38;5;10m+      311[0m:[38;5;10m[49m               AND status IN ("completed", "no_show")
[0m[49m[38;5;10m+      312[0m:[38;5;10m[49m               // Exclude cancelled/rescheduled since those aren't true no-show events.
[0m[49m[38;5;10m+      313[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      314[0m:[38;5;10m[49m     // Join predictions to actuals by appointment_id.
[0m[49m[38;5;10m+      315[0m:[38;5;10m[49m     joined = inner_join(predictions, actuals, on="appointment_id")
[0m[49m[38;5;10m+      316[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      317[0m:[38;5;10m[49m     // Compute performance metrics on this batch.
[0m[49m[38;5;10m+      318[0m:[38;5;10m[49m     y_true = [1 if row.actual_status == "no_show" else 0 for row in joined]
[0m[49m[38;5;10m+      319[0m:[38;5;10m[49m     y_pred = [row.no_show_probability for row in joined]
[0m[49m[38;5;10m+      320[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      321[0m:[38;5;10m[49m     daily_auc = compute_auc_roc(y_true, y_pred)
[0m[49m[38;5;10m+      322[0m:[38;5;10m[49m     daily_brier = compute_brier_score(y_true, y_pred)
[0m[49m[38;5;10m+      323[0m:[38;5;10m[49m     daily_count = count(joined)
[0m[49m[38;5;10m+      324[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      325[0m:[38;5;10m[49m     // Compute a 30-day rolling AUC for stability (single-day AUC is noisy).
[0m[49m[38;5;10m+      326[0m:[38;5;10m[49m     rolling_auc = compute_rolling_auc(window_days=30)
[0m[49m[38;5;10m+      327[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      328[0m:[38;5;10m[49m     // Publish metrics to CloudWatch for dashboarding and alarming.
[0m[49m[38;5;10m+      329[0m:[38;5;10m[49m     publish_metric("ModelPerformance/DailyAUC", daily_auc)
[0m[49m[38;5;10m+      330[0m:[38;5;10m[49m     publish_metric("ModelPerformance/RollingAUC30d", rolling_auc)
[0m[49m[38;5;10m+      331[0m:[38;5;10m[49m     publish_metric("ModelPerformance/DailyBrierScore", daily_brier)
[0m[49m[38;5;10m+      332[0m:[38;5;10m[49m     publish_metric("ModelPerformance/PredictionCount", daily_count)
[0m[49m[38;5;10m+      333[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      334[0m:[38;5;10m[49m     // Check if rolling AUC has dropped below the retraining threshold.
[0m[49m[38;5;10m+      335[0m:[38;5;10m[49m     // 0.72 is a reasonable floor; below this, the model is barely better than
[0m[49m[38;5;10m+      336[0m:[38;5;10m[49m     // basic heuristics (e.g., "flag everyone with prior no-shows").
[0m[49m[38;5;10m+      337[0m:[38;5;10m[49m     AUC_RETRAIN_THRESHOLD = 0.72
[0m[49m[38;5;10m+      338[0m:[38;5;10m[49m 
