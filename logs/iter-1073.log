[0m[49m[38;5;10m+     898[0m:[38;5;10m[49m     print(f"Target date: {target_date}")
[0m[49m[38;5;10m+     899[0m:[38;5;10m[49m     print("=" * 70)
[0m[49m[38;5;10m+     900[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     901[0m:[38;5;10m[49m     # Step 1: Build requests
[0m[49m[38;5;10m+     902[0m:[38;5;10m[49m     requests = build_scheduling_requests(target_date)
[0m[49m[38;5;10m+     903[0m:[38;5;10m[49m 
