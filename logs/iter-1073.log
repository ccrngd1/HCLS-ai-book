[0m[49m[38;5;10m+     938[0m:[38;5;10m[49m     print(f"  Patients scheduled: {summary['total_patients']}")
[0m[49m[38;5;10m+     939[0m:[38;5;10m[49m     print(f"  Chair utilization: {summary['utilization_rate']:.1%}")
[0m[49m[38;5;10m+     940[0m:[38;5;10m[49m     print(f"  Preferences met: {summary['preferences_met']}/{summary['preferences_total']} "
[0m[49m[38;5;10m+     941[0m:[38;5;10m[49m           f"({summary['preference_rate']:.0%})")
[0m[49m[38;5;10m+     942[0m:[38;5;10m[49m     print(f"  Solve time: {schedule['solve_time_seconds']}s")
[0m[49m[38;5;10m+     943[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     944[0m:[38;5;10m[49m     # Demonstrate disruption handling
[0m[49m[38;5;10m+     945[0m:[38;5;10m[49m     print(f"\n{'=' * 70}")
[0m[49m[38;5;10m+     946[0m:[38;5;10m[49m     print(f"DISRUPTION HANDLING DEMO")
[0m[49m[38;5;10m+     947[0m:[38;5;10m[49m     print(f"{'=' * 70}")
[0m[49m[38;5;10m+     948[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     949[0m:[38;5;10m[49m     # Simulate: PT-003 is 20 minutes late
[0m[49m[38;5;10m+     950[0m:[38;5;10m[49m     schedule = handle_disruption("patient_late", "PT-003", schedule, resource_model,
[0m[49m[38;5;10m+     951[0m:[38;5;10m[49m                                  extra_minutes=20)
[0m[49m[38;5;10m+     952[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     953[0m:[38;5;10m[49m     # Simulate: PT-005 cancelled
[0m[49m[38;5;10m+     954[0m:[38;5;10m[49m     schedule = handle_disruption("patient_cancelled", "PT-005", schedule, resource_model)
[0m[49m[38;5;10m+     955[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     956[0m:[38;5;10m[49m     # Simulate: PT-001 needs 30 extra minutes
[0m[49m[38;5;10m+     957[0m:[38;5;10m[49m     schedule = handle_disruption("extended_duration", "PT-001", schedule, resource_model,
[0m[49m[38;5;10m+     958[0m:[38;5;10m[49m                                  extra_minutes=30)
[0m[49m[38;5;10m+     959[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     960[0m:[38;5;10m[49m     return schedule
