[0m[49m[38;5;10m+     140[0m:[38;5;10m[49m         "phases": [
[0m[49m[38;5;10m+     141[0m:[38;5;10m[49m             {"type": "pre_medication", "duration_minutes": 15, "nursing_attention": 0.33},
[0m[49m[38;5;10m+     142[0m:[38;5;10m[49m             {"type": "infusion", "duration_minutes": 30, "nursing_attention": 0.25},
[0m[49m[38;5;10m+     143[0m:[38;5;10m[49m             {"type": "observation", "duration_minutes": 30, "nursing_attention": 0.20},
[0m[49m[38;5;10m+     144[0m:[38;5;10m[49m         ],
[0m[49m[38;5;10m+     145[0m:[38;5;10m[49m         "pharmacy_prep_minutes": 20,
[0m[49m[38;5;10m+     146[0m:[38;5;10m[49m         "drug_stability_hours": 6,
[0m[49m[38;5;10m+     147[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+     148[0m:[38;5;10m[49m     "RCHOP": {
[0m[49m[38;5;10m+     149[0m:[38;5;10m[49m         "name": "R-CHOP (Lymphoma)",
[0m[49m[38;5;10m+     150[0m:[38;5;10m[49m         "phases": [
[0m[49m[38;5;10m+     151[0m:[38;5;10m[49m             {"type": "pre_medication", "duration_minutes": 30, "nursing_attention": 0.33},
[0m[49m[38;5;10m+     152[0m:[38;5;10m[49m             {"type": "rituximab", "duration_minutes": 180, "nursing_attention": 0.25},
[0m[49m[38;5;10m+     153[0m:[38;5;10m[49m             {"type": "chop_drugs", "duration_minutes": 60, "nursing_attention": 0.25},
[0m[49m[38;5;10m+     154[0m:[38;5;10m[49m             {"type": "observation", "duration_minutes": 30, "nursing_attention": 0.20},
[0m[49m[38;5;10m+     155[0m:[38;5;10m[49m         ],
[0m[49m[38;5;10m+     156[0m:[38;5;10m[49m         "pharmacy_prep_minutes": 60,
[0m[49m[38;5;10m+     157[0m:[38;5;10m[49m         "drug_stability_hours": 4,
[0m[49m[38;5;10m+     158[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+     159[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     160[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     161[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     162[0m:[38;5;10m[49m def get_total_duration(protocol_key: str) -> int:
[0m[49m[38;5;10m+     163[0m:[38;5;10m[49m     """Sum all phase durations for a protocol. Returns total minutes in chair."""
[0m[49m[38;5;10m+     164[0m:[38;5;10m[49m     protocol = PROTOCOLS[protocol_key]
[0m[49m[38;5;10m+     165[0m:[38;5;10m[49m     return sum(phase["duration_minutes"] for phase in protocol["phases"])
[0m[49m[38;5;10m+     166[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     167[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     168[0m:[38;5;10m[49m def get_nursing_demand_at_offset(protocol_key: str, offset_minutes: int) -> float:
[0m[49m[38;5;10m+     169[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     170[0m:[38;5;10m[49m     Given a protocol and a time offset from the start of the visit,
[0m[49m[38;5;10m+     171[0m:[38;5;10m[49m     return the nursing attention demand at that moment.
[0m[49m[38;5;10m+     172[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     173[0m:[38;5;10m[49m     This is the key function for workload leveling. At any point in time,
[0m[49m[38;5;10m+     174[0m:[38;5;10m[49m     we can ask "how much nursing attention does this patient need right now?"
[0m[49m[38;5;10m+     175[0m:[38;5;10m[49m     and sum across all patients to get total demand for that time period.
[0m[49m[38;5;10m+     176[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     177[0m:[38;5;10m[49m     protocol = PROTOCOLS[protocol_key]
[0m[49m[38;5;10m+     178[0m:[38;5;10m[49m     elapsed = 0
[0m[49m[38;5;10m+     179[0m:[38;5;10m[49m     for phase in protocol["phases"]:
[0m[49m[38;5;10m+     180[0m:[38;5;10m[49m         if elapsed <= offset_minutes < elapsed + phase["duration_minutes"]:
[0m[49m[38;5;10m+     181[0m:[38;5;10m[49m             return phase["nursing_attention"]
[0m[49m[38;5;10m+     182[0m:[38;5;10m[49m         elapsed += phase["duration_minutes"]
[0m[49m[38;5;10m+     183[0m:[38;5;10m[49m     return 0.0  # past end of visit
[0m[49m[38;5;10m+     184[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     185[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     186[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     187[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     188[0m:[38;5;10m[49m ## Step 1: Build Scheduling Requests
[0m[49m[38;5;10m+     189[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     190[0m:[38;5;10m[49m *Maps to pseudocode Step 1 (Ingest Treatment Orders) and Step 2 (Predict Durations). In production, these come from the EHR and a SageMaker duration prediction model. Here we use synthetic data with realistic distributions.*
[0m[49m[38;5;10m+     191[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     192[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     193[0m:[38;5;10m[49m def build_scheduling_requests(target_date: str) -> list[dict]:
[0m[49m[38;5;10m+     194[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     195[0m:[38;5;10m[49m     Build the list of patients who need scheduling for a given date.
[0m[49m[38;5;10m+     196[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     197[0m:[38;5;10m[49m     In production, this pulls from the EHR's pending treatment orders,
[0m[49m[38;5;10m+     198[0m:[38;5;10m[49m     enriches with protocol details, and calls the duration prediction model.
[0m[49m[38;5;10m+     199[0m:[38;5;10m[49m     Here we generate a realistic synthetic workload for a 20-chair center.
[0m[49m[38;5;10m+     200[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     201[0m:[38;5;10m[49m     Each request contains everything the optimizer needs:
[0m[49m[38;5;10m+     202[0m:[38;5;10m[49m     - Who (patient ID, cycle info)
[0m[49m[38;5;10m+     203[0m:[38;5;10m[49m     - What (protocol, phases, durations)
[0m[49m[38;5;10m+     204[0m:[38;5;10m[49m     - When (time window constraints)
[0m[49m[38;5;10m+     205[0m:[38;5;10m[49m     - How much (nursing demand, pharmacy prep needs)
[0m[49m[38;5;10m+     206[0m:[38;5;10m[49m     - Preferences (soft constraints the optimizer tries to satisfy)
[0m[49m[38;5;10m+     207[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     208[0m:[38;5;10m[49m     # Synthetic patient list. In production, this comes from:
[0m[49m[38;5;10m+     209[0m:[38;5;10m[49m     # query_ehr_orders(status="pending_scheduling", date=target_date)
[0m[49m[38;5;10m+     210[0m:[38;5;10m[49m     patients = [
[0m[49m[38;5;10m+     211[0m:[38;5;10m[49m         {"id": "PT-001", "protocol": "FOLFOX", "cycle": 4, "is_first_dose": False,
[0m[49m[38;5;10m+     212[0m:[38;5;10m[49m          "preferred_start": "08:00", "preferred_window_hours": 1},
[0m[49m[38;5;10m+     213[0m:[38;5;10m[49m         {"id": "PT-002", "protocol": "RCHOP", "cycle": 1, "is_first_dose": True,
[0m[49m[38;5;10m+     214[0m:[38;5;10m[49m          "preferred_start": "08:00", "preferred_window_hours": 2},
[0m[49m[38;5;10m+     215[0m:[38;5;10m[49m         {"id": "PT-003", "protocol": "HERCEPTIN", "cycle": 12, "is_first_dose": False,
[0m[49m[38;5;10m+     216[0m:[38;5;10m[49m          "preferred_start": "09:00", "preferred_window_hours": 2},
[0m[49m[38;5;10m+     217[0m:[38;5;10m[49m         {"id": "PT-004", "protocol": "AC_TAXOL", "cycle": 2, "is_first_dose": False,
[0m[49m[38;5;10m+     218[0m:[38;5;10m[49m          "preferred_start": "08:30", "preferred_window_hours": 1},
[0m[49m[38;5;10m+     219[0m:[38;5;10m[49m         {"id": "PT-005", "protocol": "PEMBROLIZUMAB", "cycle": 6, "is_first_dose": False,
[0m[49m[38;5;10m+     220[0m:[38;5;10m[49m          "preferred_start": "10:00", "preferred_window_hours": 2},
[0m[49m[38;5;10m+     221[0m:[38;5;10m[49m         {"id": "PT-006", "protocol": "FOLFOX", "cycle": 8, "is_first_dose": False,
[0m[49m[38;5;10m+     222[0m:[38;5;10m[49m          "preferred_start": "07:00", "preferred_window_hours": 1},
[0m[49m[38;5;10m+     223[0m:[38;5;10m[49m         {"id": "PT-007", "protocol": "HERCEPTIN", "cycle": 8, "is_first_dose": False,
[0m[49m[38;5;10m+     224[0m:[38;5;10m[49m          "preferred_start": "11:00", "preferred_window_hours": 3},
[0m[49m[38;5;10m+     225[0m:[38;5;10m[49m         {"id": "PT-008", "protocol": "RCHOP", "cycle": 3, "is_first_dose": False,
[0m[49m[38;5;10m+     226[0m:[38;5;10m[49m          "preferred_start": "08:00", "preferred_window_hours": 1},
[0m[49m[38;5;10m+     227[0m:[38;5;10m[49m         {"id": "PT-009", "protocol": "AC_TAXOL", "cycle": 1, "is_first_dose": True,
[0m[49m[38;5;10m+     228[0m:[38;5;10m[49m          "preferred_start": "09:00", "preferred_window_hours": 2},
[0m[49m[38;5;10m+     229[0m:[38;5;10m[49m         {"id": "PT-010", "protocol": "PEMBROLIZUMAB", "cycle": 2, "is_first_dose": False,
[0m[49m[38;5;10m+     230[0m:[38;5;10m[49m          "preferred_start": "13:00", "preferred_window_hours": 2},
[0m[49m[38;5;10m+     231[0m:[38;5;10m[49m         {"id": "PT-011", "protocol": "FOLFOX", "cycle": 6, "is_first_dose": False,
[0m[49m[38;5;10m+     232[0m:[38;5;10m[49m          "preferred_start": "07:30", "preferred_window_hours": 1},
[0m[49m[38;5;10m+     233[0m:[38;5;10m[49m         {"id": "PT-012", "protocol": "HERCEPTIN", "cycle": 15, "is_first_dose": False,
[0m[49m[38;5;10m+     234[0m:[38;5;10m[49m          "preferred_start": "14:00", "preferred_window_hours": 3},
[0m[49m[38;5;10m+     235[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+     236[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     237[0m:[38;5;10m[49m     requests = []
[0m[49m[38;5;10m+     238[0m:[38;5;10m[49m     for patient in patients:
[0m[49m[38;5;10m+     239[0m:[38;5;10m[49m         protocol = PROTOCOLS[patient["protocol"]]
[0m[49m[38;5;10m+     240[0m:[38;5;10m[49m         total_duration = get_total_duration(patient["protocol"])
[0m[49m[38;5;10m+     241[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     242[0m:[38;5;10m[49m         # Parse preferred start into minutes from midnight
[0m[49m[38;5;10m+     243[0m:[38;5;10m[49m         pref_hour, pref_min = map(int, patient["preferred_start"].split(":"))
[0m[49m[38;5;10m+     244[0m:[38;5;10m[49m         preferred_start_minutes = pref_hour * 60 + pref_min
[0m[49m[38;5;10m+     245[0m:[38;5;10m[49m         window_minutes = patient["preferred_window_hours"] * 60
[0m[49m[38;5;10m+     246[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     247[0m:[38;5;10m[49m         requests.append({
[0m[49m[38;5;10m+     248[0m:[38;5;10m[49m             "patient_id": patient["id"],
[0m[49m[38;5;10m+     249[0m:[38;5;10m[49m             "protocol_key": patient["protocol"],
[0m[49m[38;5;10m+     250[0m:[38;5;10m[49m             "protocol_name": protocol["name"],
[0m[49m[38;5;10m+     251[0m:[38;5;10m[49m             "cycle": patient["cycle"],
[0m[49m[38;5;10m+     252[0m:[38;5;10m[49m             "is_first_dose": patient["is_first_dose"],
[0m[49m[38;5;10m+     253[0m:[38;5;10m[49m             "total_duration_minutes": total_duration,
[0m[49m[38;5;10m+     254[0m:[38;5;10m[49m             "pharmacy_prep_minutes": protocol["pharmacy_prep_minutes"],
[0m[49m[38;5;10m+     255[0m:[38;5;10m[49m             "drug_stability_hours": protocol["drug_stability_hours"],
[0m[49m[38;5;10m+     256[0m:[38;5;10m[49m             "preferred_start_minutes": preferred_start_minutes,
[0m[49m[38;5;10m+     257[0m:[38;5;10m[49m             "preferred_window_minutes": window_minutes,
[0m[49m[38;5;10m+     258[0m:[38;5;10m[49m             # Hard constraints: earliest and latest possible start
[0m[49m[38;5;10m+     259[0m:[38;5;10m[49m             "earliest_start": DAY_START_MINUTES,
[0m[49m[38;5;10m+     260[0m:[38;5;10m[49m             "latest_start": DAY_END_MINUTES - total_duration,
[0m[49m[38;5;10m+     261[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     262[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     263[0m:[38;5;10m[49m     print(f"Built {len(requests)} scheduling requests for {target_date}")
[0m[49m[38;5;10m+     264[0m:[38;5;10m[49m     for req in requests:
[0m[49m[38;5;10m+     265[0m:[38;5;10m[49m         print(f"  {req['patient_id']}: {req['protocol_name']} "
[0m[49m[38;5;10m+     266[0m:[38;5;10m[49m               f"(cycle {req['cycle']}, {req['total_duration_minutes']} min)")
[0m[49m[38;5;10m+     267[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     268[0m:[38;5;10m[49m     return requests
[0m[49m[38;5;10m+     269[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     270[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     271[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     272[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     273[0m:[38;5;10m[49m ## Step 2: Build Resource Model
[0m[49m[38;5;10m+     274[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     275[0m:[38;5;10m[49m *Maps to pseudocode Step 3 (Build Resource Model). Defines what the infusion center has available: chairs, nursing capacity, and pharmacy prep slots.*
[0m[49m[38;5;10m+     276[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     277[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     278[0m:[38;5;10m[49m def build_resource_model(num_chairs: int = 20, num_nurses: int = 6) -> dict:
[0m[49m[38;5;10m+     279[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     280[0m:[38;5;10m[49m     Assemble the resource model for the infusion center.
[0m[49m[38;5;10m+     281[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     282[0m:[38;5;10m[49m     In production, this queries the staffing system (who's working today,
[0m[49m[38;5;10m+     283[0m:[38;5;10m[49m     what shift, what certifications) and the facilities system (which chairs
[0m[49m[38;5;10m+     284[0m:[38;5;10m[49m     are active, any maintenance). Here we define a simple static model.
[0m[49m[38;5;10m+     285[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     286[0m:[38;5;10m[49m     The key insight: resources aren't just counts. They're time-varying
[0m[49m[38;5;10m+     287[0m:[38;5;10m[49m     capacities. A nurse working 7 AM to 3 PM contributes differently than
[0m[49m[38;5;10m+     288[0m:[38;5;10m[49m     one working 10 AM to 6 PM. The model must capture this.
[0m[49m[38;5;10m+     289[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     290[0m:[38;5;10m[49m     # Calculate time periods for the day
[0m[49m[38;5;10m+     291[0m:[38;5;10m[49m     num_periods = (DAY_END_MINUTES - DAY_START_MINUTES) // PERIOD_LENGTH_MINUTES
[0m[49m[38;5;10m+     292[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     293[0m:[38;5;10m[49m     # Nursing capacity per period. In this simplified model, all nurses
[0m[49m[38;5;10m+     294[0m:[38;5;10m[49m     # work the full day. In production, you'd have shift patterns:
[0m[49m[38;5;10m+     295[0m:[38;5;10m[49m     # early shift (7-3), late shift (10-6), mid shift (9-5), etc.
[0m[49m[38;5;10m+     296[0m:[38;5;10m[49m     # Each nurse provides 1.0 "attention units" per period.
[0m[49m[38;5;10m+     297[0m:[38;5;10m[49m     nursing_capacity_per_period = float(num_nurses)
[0m[49m[38;5;10m+     298[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     299[0m:[38;5;10m[49m     # Pharmacy prep capacity per hour. Constant here; in production it
[0m[49m[38;5;10m+     300[0m:[38;5;10m[49m     # might vary (fewer techs in early morning, peak at mid-morning).
[0m[49m[38;5;10m+     301[0m:[38;5;10m[49m     pharmacy_hours = (DAY_END_MINUTES - DAY_START_MINUTES) // 60
[0m[49m[38;5;10m+     302[0m:[38;5;10m[49m     pharmacy_capacity = [MAX_PHARMACY_PREPS_PER_HOUR] * pharmacy_hours
[0m[49m[38;5;10m+     303[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     304[0m:[38;5;10m[49m     model = {
[0m[49m[38;5;10m+     305[0m:[38;5;10m[49m         "num_chairs": num_chairs,
[0m[49m[38;5;10m+     306[0m:[38;5;10m[49m         "num_nurses": num_nurses,
[0m[49m[38;5;10m+     307[0m:[38;5;10m[49m         "num_periods": num_periods,
[0m[49m[38;5;10m+     308[0m:[38;5;10m[49m         "nursing_capacity_per_period": nursing_capacity_per_period,
[0m[49m[38;5;10m+     309[0m:[38;5;10m[49m         "pharmacy_capacity_per_hour": pharmacy_capacity,
[0m[49m[38;5;10m+     310[0m:[38;5;10m[49m         "day_start": DAY_START_MINUTES,
[0m[49m[38;5;10m+     311[0m:[38;5;10m[49m         "day_end": DAY_END_MINUTES,
[0m[49m[38;5;10m+     312[0m:[38;5;10m[49m         "period_length": PERIOD_LENGTH_MINUTES,
[0m[49m[38;5;10m+     313[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     314[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     315[0m:[38;5;10m[49m     print(f"Resource model: {num_chairs} chairs, {num_nurses} nurses, "
[0m[49m[38;5;10m+     316[0m:[38;5;10m[49m           f"{num_periods} periods ({PERIOD_LENGTH_MINUTES}-min each)")
[0m[49m[38;5;10m+     317[0m:[38;5;10m[49m     print(f"  Operating hours: {DAY_START_MINUTES // 60}:00 - {DAY_END_MINUTES // 60}:00")
[0m[49m[38;5;10m+     318[0m:[38;5;10m[49m     print(f"  Pharmacy capacity: {MAX_PHARMACY_PREPS_PER_HOUR} preps/hour")
[0m[49m[38;5;10m+     319[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     320[0m:[38;5;10m[49m     return model
[0m[49m[38;5;10m+     321[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     322[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     323[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     324[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     325[0m:[38;5;10m[49m ## Step 3: Run the Optimizer
[0m[49m[38;5;10m+     326[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     327[0m:[38;5;10m[49m *Maps to pseudocode Step 4 (Run the Optimizer). This is the core of the recipe. We formulate the scheduling problem as a constraint programming model and solve it with CP-SAT.*
[0m[49m[38;5;10m+     328[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     329[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     330[0m:[38;5;10m[49m def optimize_schedule(requests: list[dict], resource_model: dict) -> dict:
[0m[49m[38;5;10m+     331[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     332[0m:[38;5;10m[49m     The main optimization function. Takes patient requests and resource
[0m[49m[38;5;10m+     333[0m:[38;5;10m[49m     constraints, returns an optimized schedule.
[0m[49m[38;5;10m+     334[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     335[0m:[38;5;10m[49m     The formulation:
[0m[49m[38;5;10m+     336[0m:[38;5;10m[49m     - Decision variables: start time and chair assignment for each patient
[0m[49m[38;5;10m+     337[0m:[38;5;10m[49m     - Hard constraints: no chair overlap, nursing capacity, pharmacy capacity,
[0m[49m[38;5;10m+     338[0m:[38;5;10m[49m       drug stability windows, operating hours
[0m[49m[38;5;10m+     339[0m:[38;5;10m[49m     - Soft constraints (in objective): patient preferences, workload leveling
[0m[49m[38;5;10m+     340[0m:[38;5;10m[49m     - Objective: weighted combination of utilization, wait time, leveling, preferences
[0m[49m[38;5;10m+     341[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     342[0m:[38;5;10m[49m     CP-SAT works by exploring the space of feasible assignments, pruning
[0m[49m[38;5;10m+     343[0m:[38;5;10m[49m     branches that violate constraints, and optimizing the objective. For
[0m[49m[38;5;10m+     344[0m:[38;5;10m[49m     our problem size (12 patients, 20 chairs), it finds optimal solutions
[0m[49m[38;5;10m+     345[0m:[38;5;10m[49m     in under a second. For 80 patients and 50 chairs, expect 10-60 seconds.
[0m[49m[38;5;10m+     346[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     347[0m:[38;5;10m[49m     model = cp_model.CpModel()
[0m[49m[38;5;10m+     348[0m:[38;5;10m[49m     num_patients = len(requests)
[0m[49m[38;5;10m+     349[0m:[38;5;10m[49m     num_chairs = resource_model["num_chairs"]
[0m[49m[38;5;10m+     350[0m:[38;5;10m[49m     num_periods = resource_model["num_periods"]
[0m[49m[38;5;10m+     351[0m:[38;5;10m[49m     day_start = resource_model["day_start"]
[0m[49m[38;5;10m+     352[0m:[38;5;10m[49m     day_end = resource_model["day_end"]
[0m[49m[38;5;10m+     353[0m:[38;5;10m[49m     period_length = resource_model["period_length"]
[0m[49m[38;5;10m+     354[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     355[0m:[38;5;10m[49m     # --- Decision Variables ---
[0m[49m[38;5;10m+     356[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     357[0m:[38;5;10m[49m     # start_vars[i]: the start time (in minutes from midnight) for patient i
[0m[49m[38;5;10m+     358[0m:[38;5;10m[49m     start_vars = []
[0m[49m[38;5;10m+     359[0m:[38;5;10m[49m     for i, req in enumerate(requests):
[0m[49m[38;5;10m+     360[0m:[38;5;10m[49m         start_vars.append(model.NewIntVar(
[0m[49m[38;5;10m+     361[0m:[38;5;10m[49m             req["earliest_start"],
[0m[49m[38;5;10m+     362[0m:[38;5;10m[49m             req["latest_start"],
[0m[49m[38;5;10m+     363[0m:[38;5;10m[49m             f"start_{req['patient_id']}"
[0m[49m[38;5;10m+     364[0m:[38;5;10m[49m         ))
[0m[49m[38;5;10m+     365[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     366[0m:[38;5;10m[49m     # chair_vars[i]: which chair (0 to num_chairs-1) patient i is assigned to
[0m[49m[38;5;10m+     367[0m:[38;5;10m[49m     chair_vars = []
[0m[49m[38;5;10m+     368[0m:[38;5;10m[49m     for i, req in enumerate(requests):
[0m[49m[38;5;10m+     369[0m:[38;5;10m[49m         chair_vars.append(model.NewIntVar(
[0m[49m[38;5;10m+     370[0m:[38;5;10m[49m             0, num_chairs - 1,
[0m[49m[38;5;10m+     371[0m:[38;5;10m[49m             f"chair_{req['patient_id']}"
[0m[49m[38;5;10m+     372[0m:[38;5;10m[49m         ))
[0m[49m[38;5;10m+     373[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     374[0m:[38;5;10m[49m     # --- Hard Constraints ---
[0m[49m[38;5;10m+     375[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     376[0m:[38;5;10m[49m     # Constraint 1: No two patients overlap in the same chair.
[0m[49m[38;5;10m+     377[0m:[38;5;10m[49m     # We use interval variables and NoOverlap2D (or pairwise disjunctions).
[0m[49m[38;5;10m+     378[0m:[38;5;10m[49m     # CP-SAT's AddNoOverlap works on intervals within the same resource.
[0m[49m[38;5;10m+     379[0m:[38;5;10m[49m     # Since chair assignment is also a variable, we use a conditional approach:
[0m[49m[38;5;10m+     380[0m:[38;5;10m[49m     # for each pair of patients, if they're in the same chair, their time
[0m[49m[38;5;10m+     381[0m:[38;5;10m[49m     # intervals must not overlap.
[0m[49m[38;5;10m+     382[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     383[0m:[38;5;10m[49m     for i in range(num_patients):
[0m[49m[38;5;10m+     384[0m:[38;5;10m[49m         for j in range(i + 1, num_patients):
[0m[49m[38;5;10m+     385[0m:[38;5;10m[49m             # Duration including turnover buffer
[0m[49m[38;5;10m+     386[0m:[38;5;10m[49m             duration_i = requests[i]["total_duration_minutes"] + TURNOVER_BUFFER_MINUTES
[0m[49m[38;5;10m+     387[0m:[38;5;10m[49m             duration_j = requests[j]["total_duration_minutes"] + TURNOVER_BUFFER_MINUTES
[0m[49m[38;5;10m+     388[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     389[0m:[38;5;10m[49m             # Boolean: are patients i and j in the same chair?
[0m[49m[38;5;10m+     390[0m:[38;5;10m[49m             same_chair = model.NewBoolVar(f"same_chair_{i}_{j}")
[0m[49m[38;5;10m+     391[0m:[38;5;10m[49m             model.Add(chair_vars[i] == chair_vars[j]).OnlyEnforceIf(same_chair)
[0m[49m[38;5;10m+     392[0m:[38;5;10m[49m             model.Add(chair_vars[i] != chair_vars[j]).OnlyEnforceIf(same_chair.Not())
[0m[49m[38;5;10m+     393[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     394[0m:[38;5;10m[49m             # If same chair, they must not overlap in time.
[0m[49m[38;5;10m+     395[0m:[38;5;10m[49m             # Either i finishes before j starts, or j finishes before i starts.
[0m[49m[38;5;10m+     396[0m:[38;5;10m[49m             no_overlap_ij = model.NewBoolVar(f"no_overlap_{i}_{j}")
[0m[49m[38;5;10m+     397[0m:[38;5;10m[49m             model.Add(
[0m[49m[38;5;10m+     398[0m:[38;5;10m[49m                 start_vars[i] + duration_i <= start_vars[j]
[0m[49m[38;5;10m+     399[0m:[38;5;10m[49m             ).OnlyEnforceIf(no_overlap_ij)
[0m[49m[38;5;10m+     400[0m:[38;5;10m[49m             model.Add(
[0m[49m[38;5;10m+     401[0m:[38;5;10m[49m                 start_vars[j] + duration_j <= start_vars[i]
[0m[49m[38;5;10m+     402[0m:[38;5;10m[49m             ).OnlyEnforceIf(no_overlap_ij.Not())
[0m[49m[38;5;10m+     403[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     404[0m:[38;5;10m[49m             # If same chair, one of the ordering constraints must hold
[0m[49m[38;5;10m+     405[0m:[38;5;10m[49m             model.AddBoolOr([no_overlap_ij, no_overlap_ij.Not()]).OnlyEnforceIf(same_chair)
[0m[49m[38;5;10m+     406[0m:[38;5;10m[49m             # Actually, we need: if same_chair, then (i before j) OR (j before i)
[0m[49m[38;5;10m+     407[0m:[38;5;10m[49m             i_before_j = model.NewBoolVar(f"i_before_j_{i}_{j}")
[0m[49m[38;5;10m+     408[0m:[38;5;10m[49m             j_before_i = model.NewBoolVar(f"j_before_i_{i}_{j}")
[0m[49m[38;5;10m+     409[0m:[38;5;10m[49m             model.Add(start_vars[i] + duration_i <= start_vars[j]).OnlyEnforceIf(i_before_j)
[0m[49m[38;5;10m+     410[0m:[38;5;10m[49m             model.Add(start_vars[j] + duration_j <= start_vars[i]).OnlyEnforceIf(j_before_i)
[0m[49m[38;5;10m+     411[0m:[38;5;10m[49m             # If same chair, at least one ordering must hold
[0m[49m[38;5;10m+     412[0m:[38;5;10m[49m             model.AddBoolOr([i_before_j, j_before_i]).OnlyEnforceIf(same_chair)
[0m[49m[38;5;10m+     413[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     414[0m:[38;5;10m[49m     # Constraint 2: Nursing capacity per time period.
[0m[49m[38;5;10m+     415[0m:[38;5;10m[49m     # For each 15-minute period, the total nursing demand from all patients
[0m[49m[38;5;10m+     416[0m:[38;5;10m[49m     # whose visit overlaps that period must not exceed available nurses.
[0m[49m[38;5;10m+     417[0m:[38;5;10m[49m     #
[0m[49m[38;5;10m+     418[0m:[38;5;10m[49m     # This is the trickiest constraint because nursing demand varies by phase.
[0m[49m[38;5;10m+     419[0m:[38;5;10m[49m     # We linearize it: for each patient and period, compute a boolean "is this
[0m[49m[38;5;10m+     420[0m:[38;5;10m[49m     # patient in this period?" and multiply by their nursing demand at that offset.
[0m[49m[38;5;10m+     421[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     422[0m:[38;5;10m[49m     # We approximate nursing demand using the maximum attention per patient
[0m[49m[38;5;10m+     423[0m:[38;5;10m[49m     # as a simplification. A full implementation would track phase-specific
[0m[49m[38;5;10m+     424[0m:[38;5;10m[49m     # demand, but that makes the model significantly more complex.
[0m[49m[38;5;10m+     425[0m:[38;5;10m[49m     # For this example, we use average nursing attention across the visit.
[0m[49m[38;5;10m+     426[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     427[0m:[38;5;10m[49m     for period_idx in range(num_periods):
[0m[49m[38;5;10m+     428[0m:[38;5;10m[49m         period_start = day_start + period_idx * period_length
[0m[49m[38;5;10m+     429[0m:[38;5;10m[49m         period_end = period_start + period_length
[0m[49m[38;5;10m+     430[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     431[0m:[38;5;10m[49m         # For each patient, determine if they overlap this period
[0m[49m[38;5;10m+     432[0m:[38;5;10m[49m         # and what their nursing demand would be.
[0m[49m[38;5;10m+     433[0m:[38;5;10m[49m         period_demand_terms = []
[0m[49m[38;5;10m+     434[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     435[0m:[38;5;10m[49m         for i, req in enumerate(requests):
[0m[49m[38;5;10m+     436[0m:[38;5;10m[49m             duration = req["total_duration_minutes"]
[0m[49m[38;5;10m+     437[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     438[0m:[38;5;10m[49m             # Boolean: does patient i overlap this period?
[0m[49m[38;5;10m+     439[0m:[38;5;10m[49m             # Patient i overlaps if: start_i < period_end AND start_i + duration > period_start
[0m[49m[38;5;10m+     440[0m:[38;5;10m[49m             overlaps = model.NewBoolVar(f"overlaps_{i}_p{period_idx}")
[0m[49m[38;5;10m+     441[0m:[38;5;10m[49m             model.Add(start_vars[i] < period_end).OnlyEnforceIf(overlaps)
[0m[49m[38;5;10m+     442[0m:[38;5;10m[49m             model.Add(start_vars[i] + duration > period_start).OnlyEnforceIf(overlaps)
[0m[49m[38;5;10m+     443[0m:[38;5;10m[49m             model.Add(start_vars[i] >= period_end).OnlyEnforceIf(overlaps.Not())
[0m[49m[38;5;10m+     444[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     445[0m:[38;5;10m[49m             # Compute average nursing attention for this protocol
[0m[49m[38;5;10m+     446[0m:[38;5;10m[49m             protocol = PROTOCOLS[req["protocol_key"]]
[0m[49m[38;5;10m+     447[0m:[38;5;10m[49m             total_attention = sum(
[0m[49m[38;5;10m+     448[0m:[38;5;10m[49m                 p["nursing_attention"] * p["duration_minutes"]
[0m[49m[38;5;10m+     449[0m:[38;5;10m[49m                 for p in protocol["phases"]
[0m[49m[38;5;10m+     450[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+     451[0m:[38;5;10m[49m             avg_attention = total_attention / duration
[0m[49m[38;5;10m+     452[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     453[0m:[38;5;10m[49m             # Scale to integer (CP-SAT works with integers).
[0m[49m[38;5;10m+     454[0m:[38;5;10m[49m             # Multiply by 100 to preserve two decimal places.
[0m[49m[38;5;10m+     455[0m:[38;5;10m[49m             attention_scaled = int(avg_attention * 100)
[0m[49m[38;5;10m+     456[0m:[38;5;10m[49m             period_demand_terms.append((overlaps, attention_scaled))
[0m[49m[38;5;10m+     457[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     458[0m:[38;5;10m[49m         # Sum of nursing demand in this period <= capacity (scaled)
[0m[49m[38;5;10m+     459[0m:[38;5;10m[49m         capacity_scaled = int(resource_model["nursing_capacity_per_period"] * 100)
[0m[49m[38;5;10m+     460[0m:[38;5;10m[49m         model.Add(
[0m[49m[38;5;10m+     461[0m:[38;5;10m[49m             sum(attention_scaled * overlaps
[0m[49m[38;5;10m+     462[0m:[38;5;10m[49m                 for overlaps, attention_scaled in period_demand_terms)
[0m[49m[38;5;10m+     463[0m:[38;5;10m[49m             <= capacity_scaled
[0m[49m[38;5;10m+     464[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     465[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     466[0m:[38;5;10m[49m     # Constraint 3: Pharmacy prep capacity per hour.
[0m[49m[38;5;10m+     467[0m:[38;5;10m[49m     # Each patient's prep must start pharmacy_prep_minutes before their
[0m[49m[38;5;10m+     468[0m:[38;5;10m[49m     # chair start time. No more than MAX_PHARMACY_PREPS_PER_HOUR can
[0m[49m[38;5;10m+     469[0m:[38;5;10m[49m     # start in any given hour.
[0m[49m[38;5;10m+     470[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     471[0m:[38;5;10m[49m     for hour_idx in range(len(resource_model["pharmacy_capacity_per_hour"])):
[0m[49m[38;5;10m+     472[0m:[38;5;10m[49m         hour_start = day_start + hour_idx * 60
[0m[49m[38;5;10m+     473[0m:[38;5;10m[49m         hour_end = hour_start + 60
[0m[49m[38;5;10m+     474[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     475[0m:[38;5;10m[49m         preps_in_hour = []
[0m[49m[38;5;10m+     476[0m:[38;5;10m[49m         for i, req in enumerate(requests):
[0m[49m[38;5;10m+     477[0m:[38;5;10m[49m             # Pharmacy prep starts this many minutes before the patient's chair time
[0m[49m[38;5;10m+     478[0m:[38;5;10m[49m             prep_offset = req["pharmacy_prep_minutes"]
[0m[49m[38;5;10m+     479[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     480[0m:[38;5;10m[49m             # Boolean: does this patient's prep fall in this hour?
[0m[49m[38;5;10m+     481[0m:[38;5;10m[49m             # Prep start = start_vars[i] - prep_offset
[0m[49m[38;5;10m+     482[0m:[38;5;10m[49m             prep_in_hour = model.NewBoolVar(f"prep_{i}_hour{hour_idx}")
[0m[49m[38;5;10m+     483[0m:[38;5;10m[49m             model.Add(
[0m[49m[38;5;10m+     484[0m:[38;5;10m[49m                 start_vars[i] - prep_offset >= hour_start
[0m[49m[38;5;10m+     485[0m:[38;5;10m[49m             ).OnlyEnforceIf(prep_in_hour)
[0m[49m[38;5;10m+     486[0m:[38;5;10m[49m             model.Add(
[0m[49m[38;5;10m+     487[0m:[38;5;10m[49m                 start_vars[i] - prep_offset < hour_end
[0m[49m[38;5;10m+     488[0m:[38;5;10m[49m             ).OnlyEnforceIf(prep_in_hour)
[0m[49m[38;5;10m+     489[0m:[38;5;10m[49m             model.Add(
[0m[49m[38;5;10m+     490[0m:[38;5;10m[49m                 start_vars[i] - prep_offset < hour_start
[0m[49m[38;5;10m+     491[0m:[38;5;10m[49m             ).OnlyEnforceIf(prep_in_hour.Not())
[0m[49m[38;5;10m+     492[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     493[0m:[38;5;10m[49m             preps_in_hour.append(prep_in_hour)
[0m[49m[38;5;10m+     494[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     495[0m:[38;5;10m[49m         # At most MAX_PHARMACY_PREPS_PER_HOUR preps start in this hour
[0m[49m[38;5;10m+     496[0m:[38;5;10m[49m         model.Add(sum(preps_in_hour) <= resource_model["pharmacy_capacity_per_hour"][hour_idx])
[0m[49m[38;5;10m+     497[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     498[0m:[38;5;10m[49m     # Constraint 4: Drug stability window.
[0m[49m[38;5;10m+     499[0m:[38;5;10m[49m     # The time from pharmacy prep completion to infusion start must not
[0m[49m[38;5;10m+     500[0m:[38;5;10m[49m     # exceed the drug's beyond-use date (BUD).
[0m[49m[38;5;10m+     501[0m:[38;5;10m[49m     # Since prep completes at (start_time - prep_minutes + prep_minutes) = start_time,
[0m[49m[38;5;10m+     502[0m:[38;5;10m[49m     # and the drug is administered at start_time, this is automatically satisfied
[0m[49m[38;5;10m+     503[0m:[38;5;10m[49m     # in our simplified model. In production, you'd track actual prep completion
[0m[49m[38;5;10m+     504[0m:[38;5;10m[49m     # time separately (pharmacy might prep early if they have capacity).
[0m[49m[38;5;10m+     505[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     506[0m:[38;5;10m[49m     # --- Objective Function ---
[0m[49m[38;5;10m+     507[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     508[0m:[38;5;10m[49m     # We combine multiple objectives into a single weighted score.
[0m[49m[38;5;10m+     509[0m:[38;5;10m[49m     # CP-SAT maximizes, so we formulate all terms as "higher is better."
[0m[49m[38;5;10m+     510[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     511[0m:[38;5;10m[49m     objective_terms = []
[0m[49m[38;5;10m+     512[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     513[0m:[38;5;10m[49m     # Objective 1: Minimize total schedule span (proxy for utilization).
[0m[49m[38;5;10m+     514[0m:[38;5;10m[49m     # Earlier starts = more compact schedule = higher utilization.
[0m[49m[38;5;10m+     515[0m:[38;5;10m[49m     # We minimize the sum of start times (scaled by weight).
[0m[49m[38;5;10m+     516[0m:[38;5;10m[49m     max_possible_start = day_end
[0m[49m[38;5;10m+     517[0m:[38;5;10m[49m     for i in range(num_patients):
[0m[49m[38;5;10m+     518[0m:[38;5;10m[49m         # "Earliness bonus": how much earlier than latest possible
[0m[49m[38;5;10m+     519[0m:[38;5;10m[49m         earliness = model.NewIntVar(0, max_possible_start, f"earliness_{i}")
[0m[49m[38;5;10m+     520[0m:[38;5;10m[49m         model.Add(earliness == requests[i]["latest_start"] - start_vars[i])
[0m[49m[38;5;10m+     521[0m:[38;5;10m[49m         objective_terms.append(earliness)  # higher earliness = better utilization
[0m[49m[38;5;10m+     522[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     523[0m:[38;5;10m[49m     # Objective 2: Patient preference satisfaction.
[0m[49m[38;5;10m+     524[0m:[38;5;10m[49m     # Bonus for scheduling within the patient's preferred window.
[0m[49m[38;5;10m+     525[0m:[38;5;10m[49m     preference_bonuses = []
[0m[49m[38;5;10m+     526[0m:[38;5;10m[49m     for i, req in enumerate(requests):
[0m[49m[38;5;10m+     527[0m:[38;5;10m[49m         pref_start = req["preferred_start_minutes"]
[0m[49m[38;5;10m+     528[0m:[38;5;10m[49m         pref_end = pref_start + req["preferred_window_minutes"]
[0m[49m[38;5;10m+     529[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     530[0m:[38;5;10m[49m         in_window = model.NewBoolVar(f"in_pref_{i}")
[0m[49m[38;5;10m+     531[0m:[38;5;10m[49m         model.Add(start_vars[i] >= pref_start).OnlyEnforceIf(in_window)
[0m[49m[38;5;10m+     532[0m:[38;5;10m[49m         model.Add(start_vars[i] <= pref_end).OnlyEnforceIf(in_window)
[0m[49m[38;5;10m+     533[0m:[38;5;10m[49m         model.Add(start_vars[i] < pref_start).OnlyEnforceIf(in_window.Not())
[0m[49m[38;5;10m+     534[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     535[0m:[38;5;10m[49m         # Bonus of 100 points for being in the preferred window
[0m[49m[38;5;10m+     536[0m:[38;5;10m[49m         preference_bonuses.append(in_window)
[0m[49m[38;5;10m+     537[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     538[0m:[38;5;10m[49m     # Objective 3: Workload leveling.
[0m[49m[38;5;10m+     539[0m:[38;5;10m[49m     # Minimize the maximum nursing demand across all periods.
[0m[49m[38;5;10m+     540[0m:[38;5;10m[49m     # We use a minimax formulation: introduce a variable "max_demand"
[0m[49m[38;5;10m+     541[0m:[38;5;10m[49m     # and constrain it to be >= demand in every period, then minimize it.
[0m[49m[38;5;10m+     542[0m:[38;5;10m[49m     # (Since we're maximizing overall, we subtract max_demand from objective.)
[0m[49m[38;5;10m+     543[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     544[0m:[38;5;10m[49m     max_demand = model.NewIntVar(0, num_patients * 100, "max_demand")
[0m[49m[38;5;10m+     545[0m:[38;5;10m[49m     # We already have the period demand constraints above. For the objective,
[0m[49m[38;5;10m+     546[0m:[38;5;10m[49m     # we'd need to track actual demand per period. This is complex in CP-SAT
[0m[49m[38;5;10m+     547[0m:[38;5;10m[49m     # with conditional variables, so we use the preference and earliness
[0m[49m[38;5;10m+     548[0m:[38;5;10m[49m     # terms as our primary objectives for this example.
[0m[49m[38;5;10m+     549[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     550[0m:[38;5;10m[49m     # Combine objectives
[0m[49m[38;5;10m+     551[0m:[38;5;10m[49m     # Weight earliness (utilization proxy) and preferences
[0m[49m[38;5;10m+     552[0m:[38;5;10m[49m     model.Maximize(
[0m[49m[38;5;10m+     553[0m:[38;5;10m[49m         sum(objective_terms)  # earliness terms
[0m[49m[38;5;10m+     554[0m:[38;5;10m[49m         + 100 * sum(preference_bonuses)  # preference bonus
[0m[49m[38;5;10m+     555[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     556[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     557[0m:[38;5;10m[49m     # --- Solve ---
[0m[49m[38;5;10m+     558[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     559[0m:[38;5;10m[49m     solver = cp_model.CpSolver()
[0m[49m[38;5;10m+     560[0m:[38;5;10m[49m     solver.parameters.max_time_in_seconds = 30.0  # time limit for large instances
[0m[49m[38;5;10m+     561[0m:[38;5;10m[49m     solver.parameters.num_search_workers = 4       # parallel search threads
[0m[49m[38;5;10m+     562[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     563[0m:[38;5;10m[49m     print("\nSolving schedule optimization...")
[0m[49m[38;5;10m+     564[0m:[38;5;10m[49m     status = solver.Solve(model)
[0m[49m[38;5;10m+     565[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     566[0m:[38;5;10m[49m     if status == cp_model.OPTIMAL or status == cp_model.FEASIBLE:
[0m[49m[38;5;10m+     567[0m:[38;5;10m[49m         status_name = "OPTIMAL" if status == cp_model.OPTIMAL else "FEASIBLE"
[0m[49m[38;5;10m+     568[0m:[38;5;10m[49m         print(f"  Solution found: {status_name}")
[0m[49m[38;5;10m+     569[0m:[38;5;10m[49m         print(f"  Objective value: {solver.ObjectiveValue()}")
[0m[49m[38;5;10m+     570[0m:[38;5;10m[49m         print(f"  Solve time: {solver.WallTime():.2f} seconds")
[0m[49m[38;5;10m+     571[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     572[0m:[38;5;10m[49m         # Extract the solution
[0m[49m[38;5;10m+     573[0m:[38;5;10m[49m         assignments = []
[0m[49m[38;5;10m+     574[0m:[38;5;10m[49m         for i, req in enumerate(requests):
[0m[49m[38;5;10m+     575[0m:[38;5;10m[49m             start_time = solver.Value(start_vars[i])
[0m[49m[38;5;10m+     576[0m:[38;5;10m[49m             chair = solver.Value(chair_vars[i])
[0m[49m[38;5;10m+     577[0m:[38;5;10m[49m             end_time = start_time + req["total_duration_minutes"]
[0m[49m[38;5;10m+     578[0m:[38;5;10m[49m             prep_start = start_time - req["pharmacy_prep_minutes"]
[0m[49m[38;5;10m+     579[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     580[0m:[38;5;10m[49m             # Check if preference was met
[0m[49m[38;5;10m+     581[0m:[38;5;10m[49m             pref_met = (req["preferred_start_minutes"] <= start_time <=
[0m[49m[38;5;10m+     582[0m:[38;5;10m[49m                         req["preferred_start_minutes"] + req["preferred_window_minutes"])
[0m[49m[38;5;10m+     583[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     584[0m:[38;5;10m[49m             assignments.append({
[0m[49m[38;5;10m+     585[0m:[38;5;10m[49m                 "patient_id": req["patient_id"],
[0m[49m[38;5;10m+     586[0m:[38;5;10m[49m                 "protocol": req["protocol_key"],
[0m[49m[38;5;10m+     587[0m:[38;5;10m[49m                 "cycle": req["cycle"],
[0m[49m[38;5;10m+     588[0m:[38;5;10m[49m                 "chair_id": f"C-{chair + 1:02d}",
[0m[49m[38;5;10m+     589[0m:[38;5;10m[49m                 "start_time_minutes": start_time,
[0m[49m[38;5;10m+     590[0m:[38;5;10m[49m                 "start_time_display": f"{start_time // 60:02d}:{start_time % 60:02d}",
[0m[49m[38;5;10m+     591[0m:[38;5;10m[49m                 "end_time_minutes": end_time,
[0m[49m[38;5;10m+     592[0m:[38;5;10m[49m                 "end_time_display": f"{end_time // 60:02d}:{end_time % 60:02d}",
[0m[49m[38;5;10m+     593[0m:[38;5;10m[49m                 "duration_minutes": req["total_duration_minutes"],
[0m[49m[38;5;10m+     594[0m:[38;5;10m[49m                 "pharmacy_prep_start": f"{prep_start // 60:02d}:{prep_start % 60:02d}",
[0m[49m[38;5;10m+     595[0m:[38;5;10m[49m                 "preference_met": pref_met,
[0m[49m[38;5;10m+     596[0m:[38;5;10m[49m                 "is_first_dose": req["is_first_dose"],
[0m[49m[38;5;10m+     597[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+     598[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     599[0m:[38;5;10m[49m         # Sort by start time for readability
[0m[49m[38;5;10m+     600[0m:[38;5;10m[49m         assignments.sort(key=lambda a: a["start_time_minutes"])
[0m[49m[38;5;10m+     601[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     602[0m:[38;5;10m[49m         # Calculate summary metrics
[0m[49m[38;5;10m+     603[0m:[38;5;10m[49m         total_chair_minutes = sum(a["duration_minutes"] for a in assignments)
[0m[49m[38;5;10m+     604[0m:[38;5;10m[49m         available_chair_minutes = resource_model["num_chairs"] * (day_end - day_start)
[0m[49m[38;5;10m+     605[0m:[38;5;10m[49m         utilization = total_chair_minutes / available_chair_minutes
[0m[49m[38;5;10m+     606[0m:[38;5;10m[49m         preferences_met = sum(1 for a in assignments if a["preference_met"])
[0m[49m[38;5;10m+     607[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     608[0m:[38;5;10m[49m         schedule = {
[0m[49m[38;5;10m+     609[0m:[38;5;10m[49m             "status": status_name,
[0m[49m[38;5;10m+     610[0m:[38;5;10m[49m             "solve_time_seconds": round(solver.WallTime(), 2),
[0m[49m[38;5;10m+     611[0m:[38;5;10m[49m             "objective_value": solver.ObjectiveValue(),
[0m[49m[38;5;10m+     612[0m:[38;5;10m[49m             "assignments": assignments,
[0m[49m[38;5;10m+     613[0m:[38;5;10m[49m             "summary": {
[0m[49m[38;5;10m+     614[0m:[38;5;10m[49m                 "total_patients": num_patients,
[0m[49m[38;5;10m+     615[0m:[38;5;10m[49m                 "total_chair_minutes": total_chair_minutes,
[0m[49m[38;5;10m+     616[0m:[38;5;10m[49m                 "utilization_rate": round(utilization, 3),
[0m[49m[38;5;10m+     617[0m:[38;5;10m[49m                 "preferences_met": preferences_met,
[0m[49m[38;5;10m+     618[0m:[38;5;10m[49m                 "preferences_total": num_patients,
[0m[49m[38;5;10m+     619[0m:[38;5;10m[49m                 "preference_rate": round(preferences_met / num_patients, 2),
[0m[49m[38;5;10m+     620[0m:[38;5;10m[49m             },
[0m[49m[38;5;10m+     621[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+     622[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     623[0m:[38;5;10m[49m         return schedule
[0m[49m[38;5;10m+     624[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     625[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+     626[0m:[38;5;10m[49m         print(f"  No solution found. Status: {solver.StatusName(status)}")
[0m[49m[38;5;10m+     627[0m:[38;5;10m[49m         print("  This usually means constraints are too tight.")
[0m[49m[38;5;10m+     628[0m:[38;5;10m[49m         print("  Try: adding chairs, relaxing time windows, or reducing patient count.")
[0m[49m[38;5;10m+     629[0m:[38;5;10m[49m         return {"status": "INFEASIBLE", "assignments": [], "summary": {}}
[0m[49m[38;5;10m+     630[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     631[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     632[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     633[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     634[0m:[38;5;10m[49m ## Step 4: Build Pharmacy Prep Sequence
[0m[49m[38;5;10m+     635[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     636[0m:[38;5;10m[49m *Maps to the pharmacy coordination piece of pseudocode Step 5 (Validate and Publish). Once we have the schedule, we derive the pharmacy prep order so the pharmacy knows exactly when to start mixing each patient's drugs.*
[0m[49m[38;5;10m+     637[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     638[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     639[0m:[38;5;10m[49m def build_pharmacy_sequence(schedule: dict) -> list[dict]:
[0m[49m[38;5;10m+     640[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     641[0m:[38;5;10m[49m     Convert the optimized schedule into a pharmacy prep sequence.
[0m[49m[38;5;10m+     642[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     643[0m:[38;5;10m[49m     Pharmacy needs to know: which patient's drugs to prep, when to start,
[0m[49m[38;5;10m+     644[0m:[38;5;10m[49m     and the deadline (when the patient will be in the chair and ready).
[0m[49m[38;5;10m+     645[0m:[38;5;10m[49m     The sequence is ordered by prep start time so pharmacy can work
[0m[49m[38;5;10m+     646[0m:[38;5;10m[49m     through it chronologically.
[0m[49m[38;5;10m+     647[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     648[0m:[38;5;10m[49m     The drug stability constraint is critical here. If pharmacy preps too
[0m[49m[38;5;10m+     649[0m:[38;5;10m[49m     early, the drug expires before administration. If too late, the patient
[0m[49m[38;5;10m+     650[0m:[38;5;10m[49m     waits in the chair while pharmacy scrambles. The optimizer already
[0m[49m[38;5;10m+     651[0m:[38;5;10m[49m     accounts for this, but we make it explicit in the prep sequence.
[0m[49m[38;5;10m+     652[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     653[0m:[38;5;10m[49m     if not schedule.get("assignments"):
[0m[49m[38;5;10m+     654[0m:[38;5;10m[49m         return []
[0m[49m[38;5;10m+     655[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     656[0m:[38;5;10m[49m     prep_sequence = []
[0m[49m[38;5;10m+     657[0m:[38;5;10m[49m     for assignment in schedule["assignments"]:
[0m[49m[38;5;10m+     658[0m:[38;5;10m[49m         protocol = PROTOCOLS[assignment["protocol"]]
[0m[49m[38;5;10m+     659[0m:[38;5;10m[49m         prep_start_minutes = (assignment["start_time_minutes"]
[0m[49m[38;5;10m+     660[0m:[38;5;10m[49m                               - protocol["pharmacy_prep_minutes"])
[0m[49m[38;5;10m+     661[0m:[38;5;10m[49m         stability_deadline_minutes = (assignment["start_time_minutes"]
[0m[49m[38;5;10m+     662[0m:[38;5;10m[49m                                       + protocol["drug_stability_hours"] * 60)
[0m[49m[38;5;10m+     663[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     664[0m:[38;5;10m[49m         prep_sequence.append({
[0m[49m[38;5;10m+     665[0m:[38;5;10m[49m             "patient_id": assignment["patient_id"],
[0m[49m[38;5;10m+     666[0m:[38;5;10m[49m             "protocol": assignment["protocol"],
[0m[49m[38;5;10m+     667[0m:[38;5;10m[49m             "prep_start_time": f"{prep_start_minutes // 60:02d}:{prep_start_minutes % 60:02d}",
[0m[49m[38;5;10m+     668[0m:[38;5;10m[49m             "prep_start_minutes": prep_start_minutes,
[0m[49m[38;5;10m+     669[0m:[38;5;10m[49m             "prep_duration_minutes": protocol["pharmacy_prep_minutes"],
[0m[49m[38;5;10m+     670[0m:[38;5;10m[49m             "patient_chair_time": assignment["start_time_display"],
[0m[49m[38;5;10m+     671[0m:[38;5;10m[49m             "drug_stability_deadline": f"{stability_deadline_minutes // 60:02d}:{stability_deadline_minutes % 60:02d}",
[0m[49m[38;5;10m+     672[0m:[38;5;10m[49m             "chair_id": assignment["chair_id"],
[0m[49m[38;5;10m+     673[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     674[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     675[0m:[38;5;10m[49m     # Sort by prep start time (pharmacy works chronologically)
[0m[49m[38;5;10m+     676[0m:[38;5;10m[49m     prep_sequence.sort(key=lambda p: p["prep_start_minutes"])
[0m[49m[38;5;10m+     677[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     678[0m:[38;5;10m[49m     print(f"\nPharmacy prep sequence ({len(prep_sequence)} bags):")
[0m[49m[38;5;10m+     679[0m:[38;5;10m[49m     print(f"  {'Time':<8} {'Patient':<8} {'Protocol':<15} {'Chair Time':<12} {'Deadline'}")
[0m[49m[38;5;10m+     680[0m:[38;5;10m[49m     print(f"  {'-'*8} {'-'*8} {'-'*15} {'-'*12} {'-'*10}")
[0m[49m[38;5;10m+     681[0m:[38;5;10m[49m     for prep in prep_sequence:
[0m[49m[38;5;10m+     682[0m:[38;5;10m[49m         print(f"  {prep['prep_start_time']:<8} {prep['patient_id']:<8} "
[0m[49m[38;5;10m+     683[0m:[38;5;10m[49m               f"{prep['protocol']:<15} {prep['patient_chair_time']:<12} "
[0m[49m[38;5;10m+     684[0m:[38;5;10m[49m               f"{prep['drug_stability_deadline']}")
[0m[49m[38;5;10m+     685[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     686[0m:[38;5;10m[49m     return prep_sequence
[0m[49m[38;5;10m+     687[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     688[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     689[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     690[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     691[0m:[38;5;10m[49m ## Step 5: Store Schedule to DynamoDB
[0m[49m[38;5;10m+     692[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     693[0m:[38;5;10m[49m *Maps to the persistence piece of pseudocode Step 5. The published schedule goes to DynamoDB where the staff dashboard, patient portal, and pharmacy system can read it.*
[0m[49m[38;5;10m+     694[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     695[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     696[0m:[38;5;10m[49m def store_schedule(schedule: dict, target_date: str) -> str:
[0m[49m[38;5;10m+     697[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     698[0m:[38;5;10m[49m     Write the optimized schedule to DynamoDB.
[0m[49m[38;5;10m+     699[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     700[0m:[38;5;10m[49m     The schedule record serves multiple consumers:
[0m[49m[38;5;10m+     701[0m:[38;5;10m[49m     - Staff dashboard: shows today's assignments, chair map, timeline view
[0m[49m[38;5;10m+     702[0m:[38;5;10m[49m     - Patient portal: shows confirmed appointment time
[0m[49m[38;5;10m+     703[0m:[38;5;10m[49m     - Pharmacy system: reads prep sequence and timing
[0m[49m[38;5;10m+     704[0m:[38;5;10m[49m     - Audit trail: records what was scheduled and why (objective value, solve time)
[0m[49m[38;5;10m+     705[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     706[0m:[38;5;10m[49m     We store the full schedule as a single item. For larger centers, you might
[0m[49m[38;5;10m+     707[0m:[38;5;10m[49m     partition by time block or chair group, but for most infusion centers
[0m[49m[38;5;10m+     708[0m:[38;5;10m[49m     a single item per day works fine (DynamoDB items can be up to 400 KB).
[0m[49m[38;5;10m+     709[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     710[0m:[38;5;10m[49m     table = dynamodb.Table(SCHEDULE_TABLE_NAME)
[0m[49m[38;5;10m+     711[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     712[0m:[38;5;10m[49m     schedule_id = f"SCH-{target_date}-INF"
[0m[49m[38;5;10m+     713[0m:[38;5;10m[49m     now = datetime.datetime.now(timezone.utc).isoformat()
[0m[49m[38;5;10m+     714[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     715[0m:[38;5;10m[49m     # Convert floats to Decimals for DynamoDB
[0m[49m[38;5;10m+     716[0m:[38;5;10m[49m     def decimal_safe(obj):
[0m[49m[38;5;10m+     717[0m:[38;5;10m[49m         if isinstance(obj, float):
[0m[49m[38;5;10m+     718[0m:[38;5;10m[49m             return Decimal(str(round(obj, 4)))
[0m[49m[38;5;10m+     719[0m:[38;5;10m[49m         if isinstance(obj, dict):
[0m[49m[38;5;10m+     720[0m:[38;5;10m[49m             return {k: decimal_safe(v) for k, v in obj.items()}
[0m[49m[38;5;10m+     721[0m:[38;5;10m[49m         if isinstance(obj, list):
[0m[49m[38;5;10m+     722[0m:[38;5;10m[49m             return [decimal_safe(item) for item in obj]
[0m[49m[38;5;10m+     723[0m:[38;5;10m[49m         return obj
[0m[49m[38;5;10m+     724[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     725[0m:[38;5;10m[49m     record = {
[0m[49m[38;5;10m+     726[0m:[38;5;10m[49m         "schedule_id": schedule_id,
[0m[49m[38;5;10m+     727[0m:[38;5;10m[49m         "target_date": target_date,
[0m[49m[38;5;10m+     728[0m:[38;5;10m[49m         "created_at": now,
[0m[49m[38;5;10m+     729[0m:[38;5;10m[49m         "status": schedule.get("status", "UNKNOWN"),
[0m[49m[38;5;10m+     730[0m:[38;5;10m[49m         "solve_time_seconds": Decimal(str(schedule.get("solve_time_seconds", 0))),
[0m[49m[38;5;10m+     731[0m:[38;5;10m[49m         "summary": decimal_safe(schedule.get("summary", {})),
[0m[49m[38;5;10m+     732[0m:[38;5;10m[49m         "assignments": decimal_safe(schedule.get("assignments", [])),
[0m[49m[38;5;10m+     733[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     734[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     735[0m:[38;5;10m[49m     table.put_item(Item=record)
[0m[49m[38;5;10m+     736[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     737[0m:[38;5;10m[49m     print(f"\nSchedule stored: {schedule_id}")
[0m[49m[38;5;10m+     738[0m:[38;5;10m[49m     print(f"  DynamoDB table: {SCHEDULE_TABLE_NAME}")
[0m[49m[38;5;10m+     739[0m:[38;5;10m[49m     print(f"  Patients scheduled: {schedule['summary'].get('total_patients', 0)}")
[0m[49m[38;5;10m+     740[0m:[38;5;10m[49m     print(f"  Utilization: {schedule['summary'].get('utilization_rate', 0):.1%}")
[0m[49m[38;5;10m+     741[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     742[0m:[38;5;10m[49m     return schedule_id
[0m[49m[38;5;10m+     743[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     744[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     745[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     746[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     747[0m:[38;5;10m[49m ## Step 6: Handle Real-Time Disruptions
[0m[49m[38;5;10m+     748[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     749[0m:[38;5;10m[49m *Maps to pseudocode Step 6 (Handle Real-Time Adjustments). When reality diverges from the plan, this function finds the least-disruptive adjustment.*
[0m[49m[38;5;10m+     750[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     751[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     752[0m:[38;5;10m[49m def handle_disruption(
[0m[49m[38;5;10m+     753[0m:[38;5;10m[49m     disruption_type: str,
[0m[49m[38;5;10m+     754[0m:[38;5;10m[49m     patient_id: str,
[0m[49m[38;5;10m+     755[0m:[38;5;10m[49m     schedule: dict,
[0m[49m[38;5;10m+     756[0m:[38;5;10m[49m     resource_model: dict,
[0m[49m[38;5;10m+     757[0m:[38;5;10m[49m     extra_minutes: int = 0,
[0m[49m[38;5;10m+     758[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+     759[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     760[0m:[38;5;10m[49m     Handle a day-of disruption with minimal schedule impact.
[0m[49m[38;5;10m+     761[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     762[0m:[38;5;10m[49m     In production, disruptions arrive as EventBridge events and trigger
[0m[49m[38;5;10m+     763[0m:[38;5;10m[49m     a Lambda function. Here we demonstrate the decision logic for the
[0m[49m[38;5;10m+     764[0m:[38;5;10m[49m     three most common disruption types:
[0m[49m[38;5;10m+     765[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     766[0m:[38;5;10m[49m     1. Patient late: shift their start time, check for cascading conflicts
[0m[49m[38;5;10m+     767[0m:[38;5;10m[49m     2. Patient cancelled: free the slot, check waitlist
[0m[49m[38;5;10m+     768[0m:[38;5;10m[49m     3. Extended duration: patient needs more time than scheduled
[0m[49m[38;5;10m+     769[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     770[0m:[38;5;10m[49m     The key principle: minimize the number of other patients affected.
[0m[49m[38;5;10m+     771[0m:[38;5;10m[49m     A disruption to one patient should not cascade into rescheduling
[0m[49m[38;5;10m+     772[0m:[38;5;10m[49m     the entire day. Use buffers, swap chairs, or shift adjacent patients
[0m[49m[38;5;10m+     773[0m:[38;5;10m[49m     only when absolutely necessary.
[0m[49m[38;5;10m+     774[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     775[0m:[38;5;10m[49m     assignments = schedule.get("assignments", [])
[0m[49m[38;5;10m+     776[0m:[38;5;10m[49m     affected = next((a for a in assignments if a["patient_id"] == patient_id), None)
[0m[49m[38;5;10m+     777[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     778[0m:[38;5;10m[49m     if not affected:
[0m[49m[38;5;10m+     779[0m:[38;5;10m[49m         print(f"  Patient {patient_id} not found in schedule.")
[0m[49m[38;5;10m+     780[0m:[38;5;10m[49m         return schedule
[0m[49m[38;5;10m+     781[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     782[0m:[38;5;10m[49m     print(f"\nHandling disruption: {disruption_type} for {patient_id}")
[0m[49m[38;5;10m+     783[0m:[38;5;10m[49m     print(f"  Current assignment: Chair {affected['chair_id']}, "
[0m[49m[38;5;10m+     784[0m:[38;5;10m[49m           f"{affected['start_time_display']} - {affected['end_time_display']}")
[0m[49m[38;5;10m+     785[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     786[0m:[38;5;10m[49m     if disruption_type == "patient_late":
[0m[49m[38;5;10m+     787[0m:[38;5;10m[49m         # Can we absorb the delay in the turnover buffer?
[0m[49m[38;5;10m+     788[0m:[38;5;10m[49m         new_start = affected["start_time_minutes"] + extra_minutes
[0m[49m[38;5;10m+     789[0m:[38;5;10m[49m         new_end = new_start + affected["duration_minutes"]
[0m[49m[38;5;10m+     790[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     791[0m:[38;5;10m[49m         # Check if the new end time conflicts with the next patient in this chair
[0m[49m[38;5;10m+     792[0m:[38;5;10m[49m         same_chair = [a for a in assignments
[0m[49m[38;5;10m+     793[0m:[38;5;10m[49m                       if a["chair_id"] == affected["chair_id"]
[0m[49m[38;5;10m+     794[0m:[38;5;10m[49m                       and a["start_time_minutes"] > affected["start_time_minutes"]]
[0m[49m[38;5;10m+     795[0m:[38;5;10m[49m         same_chair.sort(key=lambda a: a["start_time_minutes"])
[0m[49m[38;5;10m+     796[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     797[0m:[38;5;10m[49m         if same_chair:
[0m[49m[38;5;10m+     798[0m:[38;5;10m[49m             next_patient = same_chair[0]
[0m[49m[38;5;10m+     799[0m:[38;5;10m[49m             gap = next_patient["start_time_minutes"] - new_end
[0m[49m[38;5;10m+     800[0m:[38;5;10m[49m             if gap >= TURNOVER_BUFFER_MINUTES:
[0m[49m[38;5;10m+     801[0m:[38;5;10m[49m                 # Delay fits within existing gap. Just shift this patient.
[0m[49m[38;5;10m+     802[0m:[38;5;10m[49m                 affected["start_time_minutes"] = new_start
[0m[49m[38;5;10m+     803[0m:[38;5;10m[49m                 affected["start_time_display"] = f"{new_start // 60:02d}:{new_start % 60:02d}"
[0m[49m[38;5;10m+     804[0m:[38;5;10m[49m                 affected["end_time_minutes"] = new_end
[0m[49m[38;5;10m+     805[0m:[38;5;10m[49m                 affected["end_time_display"] = f"{new_end // 60:02d}:{new_end % 60:02d}"
[0m[49m[38;5;10m+     806[0m:[38;5;10m[49m                 print(f"  Absorbed delay. New time: {affected['start_time_display']} - "
[0m[49m[38;5;10m+     807[0m:[38;5;10m[49m                       f"{affected['end_time_display']}")
[0m[49m[38;5;10m+     808[0m:[38;5;10m[49m             else:
[0m[49m[38;5;10m+     809[0m:[38;5;10m[49m                 # Conflict. Try to move the late patient to an empty chair.
[0m[49m[38;5;10m+     810[0m:[38;5;10m[49m                 used_chairs = {a["chair_id"] for a in assignments
[0m[49m[38;5;10m+     811[0m:[38;5;10m[49m                                if a["start_time_minutes"] < new_end
[0m[49m[38;5;10m+     812[0m:[38;5;10m[49m                                and a["end_time_minutes"] > new_start}
[0m[49m[38;5;10m+     813[0m:[38;5;10m[49m                 all_chairs = {f"C-{i+1:02d}" for i in range(resource_model["num_chairs"])}
[0m[49m[38;5;10m+     814[0m:[38;5;10m[49m                 free_chairs = all_chairs - used_chairs
[0m[49m[38;5;10m+     815[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     816[0m:[38;5;10m[49m                 if free_chairs:
[0m[49m[38;5;10m+     817[0m:[38;5;10m[49m                     new_chair = sorted(free_chairs)[0]
[0m[49m[38;5;10m+     818[0m:[38;5;10m[49m                     affected["chair_id"] = new_chair
[0m[49m[38;5;10m+     819[0m:[38;5;10m[49m                     affected["start_time_minutes"] = new_start
[0m[49m[38;5;10m+     820[0m:[38;5;10m[49m                     affected["start_time_display"] = f"{new_start // 60:02d}:{new_start % 60:02d}"
[0m[49m[38;5;10m+     821[0m:[38;5;10m[49m                     affected["end_time_minutes"] = new_end
[0m[49m[38;5;10m+     822[0m:[38;5;10m[49m                     affected["end_time_display"] = f"{new_end // 60:02d}:{new_end % 60:02d}"
[0m[49m[38;5;10m+     823[0m:[38;5;10m[49m                     print(f"  Moved to {new_chair}. New time: "
[0m[49m[38;5;10m+     824[0m:[38;5;10m[49m                           f"{affected['start_time_display']} - {affected['end_time_display']}")
[0m[49m[38;5;10m+     825[0m:[38;5;10m[49m                 else:
[0m[49m[38;5;10m+     826[0m:[38;5;10m[49m                     print(f"  WARNING: No resolution found. Manual intervention needed.")
[0m[49m[38;5;10m+     827[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+     828[0m:[38;5;10m[49m             # No one after this patient in this chair. Just shift.
[0m[49m[38;5;10m+     829[0m:[38;5;10m[49m             affected["start_time_minutes"] = new_start
[0m[49m[38;5;10m+     830[0m:[38;5;10m[49m             affected["start_time_display"] = f"{new_start // 60:02d}:{new_start % 60:02d}"
[0m[49m[38;5;10m+     831[0m:[38;5;10m[49m             affected["end_time_minutes"] = new_end
[0m[49m[38;5;10m+     832[0m:[38;5;10m[49m             affected["end_time_display"] = f"{new_end // 60:02d}:{new_end % 60:02d}"
[0m[49m[38;5;10m+     833[0m:[38;5;10m[49m             print(f"  No conflict. Shifted to: {affected['start_time_display']} - "
[0m[49m[38;5;10m+     834[0m:[38;5;10m[49m                   f"{affected['end_time_display']}")
[0m[49m[38;5;10m+     835[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     836[0m:[38;5;10m[49m     elif disruption_type == "patient_cancelled":
[0m[49m[38;5;10m+     837[0m:[38;5;10m[49m         # Remove from schedule, note the freed slot
[0m[49m[38;5;10m+     838[0m:[38;5;10m[49m         assignments.remove(affected)
[0m[49m[38;5;10m+     839[0m:[38;5;10m[49m         print(f"  Removed {patient_id}. Chair {affected['chair_id']} free "
[0m[49m[38;5;10m+     840[0m:[38;5;10m[49m               f"{affected['start_time_display']} - {affected['end_time_display']}")
[0m[49m[38;5;10m+     841[0m:[38;5;10m[49m         print(f"  Check waitlist for patients needing ~{affected['duration_minutes']} min slot.")
[0m[49m[38;5;10m+     842[0m:[38;5;10m[49m         # In production: query waitlist, offer slot, notify pharmacy to cancel prep
[0m[49m[38;5;10m+     843[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     844[0m:[38;5;10m[49m     elif disruption_type == "extended_duration":
[0m[49m[38;5;10m+     845[0m:[38;5;10m[49m         # Patient needs more time. Check for conflicts.
[0m[49m[38;5;10m+     846[0m:[38;5;10m[49m         new_end = affected["end_time_minutes"] + extra_minutes
[0m[49m[38;5;10m+     847[0m:[38;5;10m[49m         affected["end_time_minutes"] = new_end
[0m[49m[38;5;10m+     848[0m:[38;5;10m[49m         affected["end_time_display"] = f"{new_end // 60:02d}:{new_end % 60:02d}"
[0m[49m[38;5;10m+     849[0m:[38;5;10m[49m         affected["duration_minutes"] += extra_minutes
[0m[49m[38;5;10m+     850[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     851[0m:[38;5;10m[49m         # Check if this conflicts with next patient in same chair
[0m[49m[38;5;10m+     852[0m:[38;5;10m[49m         same_chair = [a for a in assignments
[0m[49m[38;5;10m+     853[0m:[38;5;10m[49m                       if a["chair_id"] == affected["chair_id"]
[0m[49m[38;5;10m+     854[0m:[38;5;10m[49m                       and a["patient_id"] != patient_id
[0m[49m[38;5;10m+     855[0m:[38;5;10m[49m                       and a["start_time_minutes"] > affected["start_time_minutes"]]
[0m[49m[38;5;10m+     856[0m:[38;5;10m[49m         same_chair.sort(key=lambda a: a["start_time_minutes"])
[0m[49m[38;5;10m+     857[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     858[0m:[38;5;10m[49m         if same_chair:
[0m[49m[38;5;10m+     859[0m:[38;5;10m[49m             next_patient = same_chair[0]
[0m[49m[38;5;10m+     860[0m:[38;5;10m[49m             if new_end + TURNOVER_BUFFER_MINUTES > next_patient["start_time_minutes"]:
[0m[49m[38;5;10m+     861[0m:[38;5;10m[49m                 print(f"  CONFLICT with {next_patient['patient_id']} at "
[0m[49m[38;5;10m+     862[0m:[38;5;10m[49m                       f"{next_patient['start_time_display']}. Needs reassignment.")
[0m[49m[38;5;10m+     863[0m:[38;5;10m[49m                 # In production: trigger reoptimization for affected patients
[0m[49m[38;5;10m+     864[0m:[38;5;10m[49m             else:
[0m[49m[38;5;10m+     865[0m:[38;5;10m[49m                 print(f"  Extended to {affected['end_time_display']}. No conflict.")
[0m[49m[38;5;10m+     866[0m:[38;5;10m[49m         else:
