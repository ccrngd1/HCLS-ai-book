[0m[49m[38;5;10m+     909[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     910[0m:[38;5;10m[49m     if schedule["status"] == "INFEASIBLE":
[0m[49m[38;5;10m+     911[0m:[38;5;10m[49m         print("\nSchedule optimization failed. Cannot proceed.")
[0m[49m[38;5;10m+     912[0m:[38;5;10m[49m         return schedule
