[0m[49m[38;5;10m+     915[0m:[38;5;10m[49m     pharmacy_sequence = build_pharmacy_sequence(schedule)
[0m[49m[38;5;10m+     916[0m:[38;5;10m[49m     schedule["pharmacy_sequence"] = pharmacy_sequence
[0m[49m[38;5;10m+     917[0m:[38;5;10m[49m 
