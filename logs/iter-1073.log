[0m[49m[38;5;10m+     106[0m:[38;5;10m[49m     "FOLFOX": {
[0m[49m[38;5;10m+     107[0m:[38;5;10m[49m         "name": "FOLFOX (Colorectal)",
[0m[49m[38;5;10m+     108[0m:[38;5;10m[49m         "phases": [
