[0m[49m[38;5;10m+     920[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     921[0m:[38;5;10m[49m     # Print the final schedule
[0m[49m[38;5;10m+     922[0m:[38;5;10m[49m     print(f"\n{'=' * 70}")
[0m[49m[38;5;10m+     923[0m:[38;5;10m[49m     print(f"OPTIMIZED SCHEDULE")
[0m[49m[38;5;10m+     924[0m:[38;5;10m[49m     print(f"{'=' * 70}")
[0m[49m[38;5;10m+     925[0m:[38;5;10m[49m     print(f"\n{'Patient':<8} {'Protocol':<15} {'Chair':<7} {'Start':<7} "
[0m[49m[38;5;10m+     926[0m:[38;5;10m[49m           f"{'End':<7} {'Duration':<10} {'Pref Met'}")
[0m[49m[38;5;10m+     927[0m:[38;5;10m[49m     print(f"{'-'*8} {'-'*15} {'-'*7} {'-'*7} {'-'*7} {'-'*10} {'-'*8}")
[0m[49m[38;5;10m+     928[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     929[0m:[38;5;10m[49m     for a in schedule["assignments"]:
[0m[49m[38;5;10m+     930[0m:[38;5;10m[49m         pref = "Yes" if a["preference_met"] else "No"
[0m[49m[38;5;10m+     931[0m:[38;5;10m[49m         first = " [1st]" if a["is_first_dose"] else ""
[0m[49m[38;5;10m+     932[0m:[38;5;10m[49m         print(f"{a['patient_id']:<8} {a['protocol']:<15} {a['chair_id']:<7} "
[0m[49m[38;5;10m+     933[0m:[38;5;10m[49m               f"{a['start_time_display']:<7} {a['end_time_display']:<7} "
[0m[49m[38;5;10m+     934[0m:[38;5;10m[49m               f"{a['duration_minutes']:<10} {pref}{first}")
[0m[49m[38;5;10m+     935[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     936[0m:[38;5;10m[49m     summary = schedule["summary"]
