[49m[39m  510, 510[0m:[39m[49m #### Step 5: Cache and Serve Results
[0m[49m[39m  511, 511[0m:[39m[49m 
[0m[49m[39m  512, 512[0m:[39m[49m Clinical systems need sub-second response times. Caching interaction results for common drug combinations avoids redundant graph traversals while ensuring freshness when the knowledge base updates.
[0m[49m[39m  513, 513[0m:[39m[49m 
[0m[49m[38;5;10m+      514[0m:[38;5;10m[49m Important: after the normalizer Lambda completes a graph update, it should publish an EventBridge event (`graph.updated`) that triggers a cache flush. This flush invalidates all cached entries (or selectively invalidates entries containing affected drugs). Without explicit invalidation, the system could serve stale "no interaction found" results for up to the full TTL after a new interaction is added to the graph. For a safety-critical system, stale cache is a patient safety risk. The TTL below (24 hours) serves as a backstop, not the primary invalidation mechanism.
[0m[49m[38;5;10m+      515[0m:[38;5;10m[49m 
[0m[49m[39m  514, 516[0m:[39m[49m ```
[0m[49m[39m  515, 517[0m:[39m[49m FUNCTION serve_interaction_check(request):
[0m[49m[39m  516, 518[0m:[39m[49m     // request: {medications: [...], patient_context: {...}}
[0m[49m[39m  517, 519[0m:[39m[49m     
[0m[49m[39m  518, 520[0m:[39m[49m     // Generate cache key from sorted medication RxCUIs
[0m[49m[39m  519, 521[0m:[39m[49m     // (patient context is NOT part of cache key because it varies per patient)
[0m[49m[39m  520, 522[0m:[39m[49m     med_key = SORT(request.medications.map(m => m.rxcui)).JOIN("_")
[0m[49m[39m  521, 523[0m:[39m[49m     
[0m[49m[39m  522, 524[0m:[39m[49m     // Check cache for base interaction paths (without patient contextualization)
[0m[49m[39m  523, 525[0m:[39m[49m     cached_paths = CACHE_GET("interactions:" + med_key)
[0m[49m[39m  524, 526[0m:[39m[49m     
[0m[49m[39m  525, 527[0m:[39m[49m     IF cached_paths IS NOT NULL:
[0m[49m[39m  526, 528[0m:[39m[49m         // Re-score cached paths with this patient's context
[0m[49m[39m  527, 529[0m:[39m[49m         scored = CONTEXTUALIZE(cached_paths, request.patient_context)
[0m[49m[39m  528, 530[0m:[39m[49m         RETURN scored
[0m[49m[39m  529, 531[0m:[39m[49m     
[0m[49m[39m  530, 532[0m:[39m[49m     // Cache miss: run full graph traversal
[0m[49m[39m  531, 533[0m:[39m[49m     result = check_interactions(request.medications, request.patient_context)
[0m[49m[39m  532, 534[0m:[39m[49m     
[0m[49m[39m  533, 535[0m:[39m[49m     // Cache the raw interaction paths (before patient-specific scoring)
[0m[49m[38;5;9m- 534     [0m:[38;5;9m[49m     // TTL aligned with knowledge base update frequency
[0m[49m[38;5;9m- 535     [0m:[38;5;9m[49m     CACHE_SET("interactions:" + med_key, result.raw_paths, TTL=7_DAYS)
[0m[49m[38;5;10m+      536[0m:[38;5;10m[49m     // TTL is a safety backstop; primary invalidation is event-driven on graph update
[0m[49m[38;5;10m+      537[0m:[38;5;10m[49m     CACHE_SET("interactions:" + med_key, result.raw_paths, TTL=24_HOURS)
