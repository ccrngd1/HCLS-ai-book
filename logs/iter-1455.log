[0m[49m[39m  214, 214[0m:[39m[49m MAX_SUGGESTIONS_PER_NOTE = 5        // more than this causes alert fatigue
[0m[49m[39m  215, 215[0m:[39m[49m CONFIDENCE_THRESHOLD     = "medium"  // suppress "low" confidence suggestions
[0m[49m[39m  216, 216[0m:[39m[49m 
[0m[49m[39m  217, 217[0m:[39m[49m FUNCTION prioritize_suggestions(suggestions):
[0m[49m[39m  218, 218[0m:[39m[49m     // Filter out low-confidence suggestions
[0m[49m[39m  219, 219[0m:[39m[49m     filtered = [s for s in suggestions where s.confidence >= CONFIDENCE_THRESHOLD]
[0m[49m[39m  220, 220[0m:[39m[49m     
[0m[49m[39m  221, 221[0m:[39m[49m     // Sort by impact: high first, then medium, then low
[0m[49m[39m  222, 222[0m:[39m[49m     // Within same impact level, sort by confidence (high first)
[0m[49m[39m  223, 223[0m:[39m[49m     sorted = sort filtered by (estimated_impact DESC, confidence DESC)
[0m[49m[39m  224, 224[0m:[39m[49m     
[0m[49m[39m  225, 225[0m:[39m[49m     // Cap at maximum suggestions per note
[0m[49m[39m  226, 226[0m:[39m[49m     final = first MAX_SUGGESTIONS_PER_NOTE items from sorted
[0m[49m[39m  227, 227[0m:[39m[49m     
[0m[49m[39m  228, 228[0m:[39m[49m     // Add suppression metadata for audit: record what was filtered and why
[0m[49m[39m  229, 229[0m:[39m[49m     suppressed = suggestions NOT in final
[0m[49m[39m  230, 230[0m:[39m[49m     
[0m[49m[39m  231, 231[0m:[39m[49m     RETURN {
[0m[49m[39m  232, 232[0m:[39m[49m         active_suggestions: final,
[0m[49m[39m  233, 233[0m:[39m[49m         suppressed:         suppressed,
[0m[49m[39m  234, 234[0m:[39m[49m         suppression_reasons: "low confidence" or "exceeded max per note"
[0m[49m[39m  235, 235[0m:[39m[49m     }
[0m[49m[39m  236, 236[0m:[39m[49m ```
