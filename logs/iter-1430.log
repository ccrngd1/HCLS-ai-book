[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m # --- Forecast parameters ---
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m FORECAST_HORIZON_DAYS = 14          # how far forward to predict
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m VALIDATION_WINDOW_DAYS = 90         # held-out days for model evaluation
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m CONFIDENCE_INTERVAL_WIDTH = 0.80    # 80% prediction interval
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m # --- Quality gate ---
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m # If the new model's MAPE is more than 20% worse than the previous
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m # model's MAPE, reject it and keep the old model in production.
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m MAPE_DEGRADATION_THRESHOLD = 1.20
