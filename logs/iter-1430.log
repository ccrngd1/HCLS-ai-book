[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m ## Synthetic Data Generator
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m Before we get to the pipeline steps, we need data to work with. This function generates realistic appointment-volume history with the patterns a real clinic would show: weekly seasonality (Mondays busy, Fridays lighter), annual seasonality (summer dips, January spikes), holiday drops, and a slow upward trend. The noise is calibrated to produce the 5-10% MAPE range you'd see on a stable primary care clinic.
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m Never use real patient appointment data in development. Generate from a known process so you can validate your pipeline against ground truth.
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m def generate_synthetic_history(
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m     clinic_id: str,
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m     start_date: date,
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m     end_date: date,
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m     base_volume: int = 180,
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m ) -> pd.DataFrame:
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m     Generate synthetic daily appointment counts with realistic patterns.
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m     The generated data has:
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m     - Weekly seasonality (Monday highest, Friday/weekend lowest)
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m     - Annual seasonality (winter spike, summer dip)
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m     - Holiday effects (volume drops ~60% on holidays)
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m     - Slow upward trend (~5% annual growth)
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m     - Random noise (std dev ~8% of daily mean)
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m         clinic_id:   Identifier for the clinic (metadata, not used in modeling)
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m         start_date:  First day of synthetic history
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m         end_date:    Last day of synthetic history
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m         base_volume: Average daily appointment count at the start of the series
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m         DataFrame with columns: ds (date), y (appointment count), clinic_id
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m     random.seed(42)  # reproducible for demo purposes
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m     # Day-of-week multipliers. Monday is heaviest; weekend is near-zero
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m     # for a typical outpatient clinic.
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m     dow_multipliers = {
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m         0: 1.15,   # Monday
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m         1: 1.08,   # Tuesday
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m         2: 1.05,   # Wednesday
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m         3: 1.00,   # Thursday
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m         4: 0.85,   # Friday
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m         5: 0.05,   # Saturday (urgent care only)
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m         6: 0.00,   # Sunday (closed)
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m     # Build the holiday set for fast lookup.
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m     holiday_dates = {h["ds"] for h in US_HOLIDAYS}
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m     rows = []
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m     current = start_date
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m     day_index = 0
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m     while current <= end_date:
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m         # Trend: slow linear growth, ~5% per year.
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m         trend = 1.0 + (day_index / 365.0) * 0.05
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m         # Annual seasonality: sine wave with peak in January, trough in July.
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m         # Healthcare clinics see post-holiday surges and summer slowdowns.
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m         day_of_year = current.timetuple().tm_yday
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m         annual_seasonal = 1.0 + 0.08 * math.sin(
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m             2 * math.pi * (day_of_year - 15) / 365.0
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m         # Day-of-week effect.
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m         dow_effect = dow_multipliers[current.weekday()]
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m         # Holiday effect: volume drops significantly on holidays.
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m         is_holiday = current.isoformat() in holiday_dates
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m         holiday_effect = 0.35 if is_holiday else 1.0
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m         # Compose the deterministic signal.
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m         signal = base_volume * trend * annual_seasonal * dow_effect * holiday_effect
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m         # Add Gaussian noise (~8% coefficient of variation).
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m         noise = random.gauss(0, base_volume * 0.08)
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m         volume = max(0, int(round(signal + noise)))
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m         rows.append({
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m             "ds": current.isoformat(),
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m             "y": volume,
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m             "clinic_id": clinic_id,
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m         current += timedelta(days=1)
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m         day_index += 1
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m     df = pd.DataFrame(rows)
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m     df["ds"] = pd.to_datetime(df["ds"])
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m     return df
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m ## Step 1: Prepare Training Data
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m *The pseudocode calls this `prepare_training_data(raw_history, holiday_calendar)`. It shapes the raw appointment history into the format Prophet expects and ensures there are no gaps in the time series.*
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m def prepare_training_data(history_df: pd.DataFrame) -> pd.DataFrame:
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m     Shape raw appointment history into Prophet's expected format.
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m     Prophet requires exactly two columns for the basic case:
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     - ds: the datestamp (datetime or date)
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m     - y: the value to forecast (numeric)
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m     This function also fills any missing dates with zero counts.
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m     A missing day is ambiguous (was the clinic closed, or did the
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m     data pipeline fail?), but an explicit zero is at least consistent.
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m     In production, you'd distinguish planned closures (weekends,
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m     holidays) from data gaps and handle them differently.
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m         history_df: DataFrame with at least 'ds' and 'y' columns.
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m         Clean DataFrame with one row per day, no gaps, sorted by date.
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m     df = history_df[["ds", "y"]].copy()
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m     df["ds"] = pd.to_datetime(df["ds"])
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m     # Create a complete date range from first to last day in history.
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m     full_range = pd.date_range(start=df["ds"].min(), end=df["ds"].max(), freq="D")
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m     # Reindex to fill any gaps with zero. This ensures Prophet sees
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m     # a regular daily series with no missing time steps.
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m     df = df.set_index("ds").reindex(full_range, fill_value=0).reset_index()
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m     df.columns = ["ds", "y"]
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m         "Prepared training data: %d days from %s to %s",
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m         len(df),
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m         df["ds"].min().date(),
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m         df["ds"].max().date(),
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     return df
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m ## Step 2: Train the Forecasting Model
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m *The pseudocode calls this `train_forecast_model(daily_counts)`. It fits a Prophet model on the training window, evaluates on a held-out validation window, and applies a quality gate before promoting the model.*
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m def train_forecast_model(
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m     training_df: pd.DataFrame,
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m     clinic_id: str,
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m ) -> tuple:
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m     Train a Prophet model and evaluate it against a held-out validation window.
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m     The workflow:
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m     1. Split the data into training and validation sets.
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m     2. Fit Prophet on the training set with weekly + yearly seasonality
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m        and the US holiday calendar.
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m     3. Predict over the validation window.
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m     4. Compute MAPE as the accuracy metric.
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m         training_df: Full history DataFrame (ds, y), already cleaned.
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m         clinic_id:   Clinic identifier for logging and model versioning.
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m         Tuple of (fitted_model, mape_score, model_version_string).
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m     # Split: hold out the most recent VALIDATION_WINDOW_DAYS for evaluation.
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m     cutoff_date = training_df["ds"].max() - timedelta(days=VALIDATION_WINDOW_DAYS)
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m     train = training_df[training_df["ds"] <= cutoff_date].copy()
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m     valid = training_df[training_df["ds"] > cutoff_date].copy()
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m         "Training on %d days (through %s), validating on %d days",
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m         len(train),
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m         cutoff_date.date(),
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m         len(valid),
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m     # Build the holiday DataFrame in the format Prophet expects.
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m     holidays_df = pd.DataFrame(US_HOLIDAYS)
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m     holidays_df["ds"] = pd.to_datetime(holidays_df["ds"])
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m     # Prophet lets you specify a window around each holiday to capture
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m     # the before/after effects (e.g., the day after Thanksgiving is slow too).
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m     holidays_df["lower_window"] = 0
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m     holidays_df["upper_window"] = 1  # include the day after each holiday
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m     # Configure and fit the model.
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m     # Prophet's defaults are reasonable for most healthcare volume series.
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m     # Key knobs:
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m     #   - changepoint_prior_scale: controls trend flexibility.
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m     #     Lower = smoother trend, less likely to overfit to recent changes.
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m     #     0.05 is conservative; increase to 0.1-0.3 for clinics in flux.
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m     #   - seasonality_prior_scale: regularization on seasonal components.
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m     #     Default (10) is fine for most cases.
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m     #   - interval_width: sets the prediction interval coverage.
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m     model = Prophet(
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m         yearly_seasonality=True,
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m         weekly_seasonality=True,
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m         daily_seasonality=False,       # not useful at daily granularity
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m         holidays=holidays_df,
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m         changepoint_prior_scale=0.05,
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m         interval_width=CONFIDENCE_INTERVAL_WIDTH,
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m     # Suppress Prophet's verbose Stan output during fitting.
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m     model.fit(train)
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m     # Generate predictions over the validation window.
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m     future_valid = model.make_future_dataframe(
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m         periods=len(valid), include_history=False
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m     # Prophet's make_future_dataframe starts from the last training date,
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m     # so shift forward by one day to align with the validation set.
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m     forecast_valid = model.predict(future_valid)
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m     # Compute MAPE on the validation set.
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m     # Only evaluate on days where actual volume > 0 (skip Sundays/closures).
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m     merged = valid.merge(
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m         forecast_valid[["ds", "yhat"]], on="ds", how="inner"
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m     merged = merged[merged["y"] > 0]  # exclude zero-volume days
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m     if len(merged) == 0:
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m         logger.warning("No valid days for MAPE calculation")
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m         mape = 999.0
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m         mape = (
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m             (merged["y"] - merged["yhat"]).abs() / merged["y"]
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m         ).mean() * 100.0
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m     model_version = f"prophet-v1-{clinic_id}-{date.today().isoformat()}"
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m         "Model %s trained. Validation MAPE: %.1f%% on %d days",
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m         model_version,
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m         mape,
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m         len(merged),
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m     return model, mape, model_version
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m ## Step 3: Generate the Forecast
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m *The pseudocode calls this `generate_forecast(model, forecast_horizon_days)`. It runs the trained model forward to produce daily forecasts with prediction intervals.*
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m def generate_forecast(
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m     model: Prophet,
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m     clinic_id: str,
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m     model_version: str,
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m     horizon_days: int = FORECAST_HORIZON_DAYS,
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m ) -> list[dict]:
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m     Generate a daily forecast with prediction intervals for the next N days.
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m     The output includes both the point forecast (yhat, rounded to whole
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m     appointments) and the 80% prediction interval bounds. Operations
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m     leaders use the upper bound for staffing decisions because being
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m     understaffed on a busy day costs more than being slightly overstaffed
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m     on a quiet one.
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m         model:         Fitted Prophet model.
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m         clinic_id:     Clinic identifier for the output records.
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m         model_version: Version string for traceability.
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m         horizon_days:  Number of days to forecast forward.
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m         List of forecast records, one per day.
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m     # Prophet generates the future date range from the end of training data.
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m     future_df = model.make_future_dataframe(
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m         periods=horizon_days, include_history=False
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m     forecast_df = model.predict(future_df)
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m     generated_at = datetime.now(timezone.utc).isoformat()
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m     records = []
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m     for _, row in forecast_df.iterrows():
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m         # Round point forecast to whole appointments.
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m         # Keep bounds at one decimal for downstream math.
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m         point = max(0, int(round(row["yhat"])))
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m         lower = max(0, round(row["yhat_lower"], 1))
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m         upper = max(0, round(row["yhat_upper"], 1))
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m         records.append({
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m             "clinic_id": clinic_id,
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m             "forecast_date": row["ds"].strftime("%Y-%m-%d"),
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m             "point_forecast": point,
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m             "lower_bound": lower,
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m             "upper_bound": upper,
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m             "generated_at": generated_at,
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m             "model_version": model_version,
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m         "Generated %d-day forecast for %s. Range: %d to %d appts/day",
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m         horizon_days,
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m         clinic_id,
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m         min(r["point_forecast"] for r in records),
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m         max(r["point_forecast"] for r in records),
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m     return records
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m ## Step 4: Load Forecasts to DynamoDB
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m *The pseudocode calls this `load_forecasts_to_dynamodb(forecast_records, table_name)`. It writes each forecast record to DynamoDB keyed by clinic_id (partition key) and forecast_date (sort key), using BatchWriteItem for efficiency.*
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m def _to_decimal(value) -> Decimal:
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m     Convert a numeric value to Decimal for DynamoDB.
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m     DynamoDB does not accept Python float. You must wrap every numeric
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m     value in Decimal() or put_item / batch_write_item will raise a
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m     TypeError. Converting via str() first avoids floating-point artifacts
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m     (e.g., Decimal(0.1) becomes 0.1000000000000000055511151231257827021181...,
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m     but Decimal("0.1") becomes exactly 0.1).
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m     if isinstance(value, float):
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m         return Decimal(str(value))
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m     return Decimal(str(value))
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m def load_forecasts_to_dynamodb(
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m     forecast_records: list[dict],
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m     table_name: str = DYNAMODB_TABLE,
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m ) -> int:
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m     Write forecast records to DynamoDB in batches of 25.
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m     Each record is keyed by (clinic_id, forecast_date). Writing a forecast
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m     for the same clinic and date overwrites the previous forecast, which is
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m     intentional: today's forecast supersedes yesterday's forecast for the
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m     same future date.
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m         forecast_records: List of dicts from generate_forecast().
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m         table_name:       DynamoDB table name.
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m         Number of records successfully written.
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m     dynamodb = boto3.resource("dynamodb", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m     table = dynamodb.Table(table_name)
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m     written = 0
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m     # DynamoDB BatchWriteItem accepts up to 25 items per call.
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m     for i in range(0, len(forecast_records), 25):
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m         batch = forecast_records[i : i + 25]
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m         with table.batch_writer() as writer:
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m             for record in batch:
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m                 item = {
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m                     "clinic_id": record["clinic_id"],
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m                     "forecast_date": record["forecast_date"],
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m                     "point_forecast": _to_decimal(record["point_forecast"]),
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m                     "lower_bound": _to_decimal(record["lower_bound"]),
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m                     "upper_bound": _to_decimal(record["upper_bound"]),
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m                     "generated_at": record["generated_at"],
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m                     "model_version": record["model_version"],
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m                 }
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m                 writer.put_item(Item=item)
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m         written += len(batch)
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m     logger.info("Wrote %d forecast records to DynamoDB table %s", written, table_name)
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m     return written
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m ## Putting It All Together
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m Here's the full pipeline assembled into a single function. In production, each step would be a separate Lambda or SageMaker job orchestrated by Step Functions. Here they run sequentially in-process so you can trace the flow.
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m def run_forecast_pipeline(
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m     clinic_id: str = "primary-care-001",
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m     history_years: int = 3,
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m     write_to_dynamodb: bool = False,
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m     Run the complete appointment-volume-forecasting pipeline for one clinic.
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m     Steps:
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m     1. Generate (or load) historical appointment data.
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m     2. Prepare the training DataFrame.
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m     3. Train a Prophet model with validation.
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m     4. Apply the quality gate.
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m     5. Generate the forward forecast.
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m     6. Optionally write to DynamoDB.
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m         clinic_id:        Identifier for the clinic.
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m         history_years:    Years of synthetic history to generate.
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m         write_to_dynamodb: If True, write forecasts to DynamoDB.
