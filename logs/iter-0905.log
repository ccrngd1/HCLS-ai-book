[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m ## Step 1: Classify the Study and Select Models
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m *Maps to pseudocode Step 2 in the main recipe. Given a study's DICOM metadata, determine which AI models should analyze it. The routing logic handles the inconsistency of real-world DICOM metadata by checking multiple fields and normalizing values.*
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m def classify_study_and_select_models(study_metadata: dict) -> list[dict]:
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m     Examine DICOM metadata and determine which AI models apply to this study.
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m     Real-world DICOM metadata is messy. BodyPartExamined might be "HEAD",
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m     "BRAIN", "Head", or empty. StudyDescription might say "CT HEAD W/O"
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m     or "CT Brain Non-Con" or "TRAUMA CT HEAD NECK". This function normalizes
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m     the metadata and matches against the model configuration.
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m         study_metadata: dict with keys from DICOM headers:
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m             - Modality (str): "CT", "MR", "CR", "DX"
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m             - BodyPartExamined (str): varies wildly
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m             - StudyDescription (str): free text
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m             - ProtocolName (str): sometimes more specific
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m         List of model config dicts from MODEL_ENDPOINTS that should run.
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m         Empty list if no models match (study type not covered by triage).
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m     modality = study_metadata.get("Modality", "").upper().strip()
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m     body_part = study_metadata.get("BodyPartExamined", "").upper().strip()
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m     description = study_metadata.get("StudyDescription", "").upper().strip()
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m     protocol = study_metadata.get("ProtocolName", "").upper().strip()
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m     # CR and DX are both plain radiographs. Normalize to match either.
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m     xray_modalities = {"CR", "DX"}
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m     selected_models = []
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m     for model_name, config in MODEL_ENDPOINTS.items():
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m         model_modality = config["modality"]
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m         # Check modality match. Handle CR/DX equivalence.
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m         modality_match = False
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m         if model_modality in xray_modalities:
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m             modality_match = modality in xray_modalities
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m             modality_match = modality == model_modality
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m         if not modality_match:
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m         # Check body part match. Also search the study description and protocol
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m         # for body part keywords, because BodyPartExamined is often empty or wrong.
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m         body_part_match = False
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m         for bp in config["body_parts"]:
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m             if bp in body_part or bp in description or bp in protocol:
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m                 body_part_match = True
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m                 break
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m         if body_part_match:
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m             selected_models.append({"model_name": model_name, **config})
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m     if not selected_models:
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m         logger.info(
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m             "No models matched for study: modality=%s, body_part=%s, desc=%s",
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m             modality, body_part, description
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m     return selected_models
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m ## Step 2: Preprocess Pixel Data for a Specific Model
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m *Maps to the preprocessing portion of pseudocode Step 3. Each model expects input in a specific format. CT models need windowing, resampling, and volume extraction. X-ray models need 2D resizing and normalization. This function dispatches to the correct preprocessing based on model configuration.*
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m def preprocess_for_model(
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     pixel_array: np.ndarray,
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m     model_config: dict,
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m     original_spacing: tuple[float, float, float],
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m ) -> np.ndarray:
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m     Transform raw pixel data into the format expected by a specific model.
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m     For CT volumes: apply windowing, resample to target voxel spacing,
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m     resize to model input dimensions, normalize to [0, 1].
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m     For X-ray (2D): resize to target dimensions, normalize to [0, 1].
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m         pixel_array: raw pixel data as numpy array.
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m             CT: shape (slices, height, width) in Hounsfield Units.
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m             X-ray: shape (height, width) in raw pixel values.
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m         model_config: model configuration dict from MODEL_ENDPOINTS.
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m         original_spacing: (slice_spacing, row_spacing, col_spacing) in mm.
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m             For X-ray, only (row_spacing, col_spacing) matters.
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m         Preprocessed numpy array matching model_config["input_shape"],
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m         dtype float32, values in [0, 1].
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m     target_shape = model_config["input_shape"]
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m     if len(pixel_array.shape) == 3:
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m         # 3D volume (CT or MRI)
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m         preprocessed = _preprocess_volume(pixel_array, model_config, original_spacing)
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m         # 2D image (X-ray)
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m         preprocessed = _preprocess_2d(pixel_array, model_config)
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     return preprocessed.astype(np.float32)
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m def _preprocess_volume(
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m     volume: np.ndarray,
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m     model_config: dict,
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m     original_spacing: tuple[float, float, float],
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m ) -> np.ndarray:
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m     Preprocess a 3D CT/MRI volume for model inference.
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m     Steps:
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m     1. Apply HU windowing (converts raw HU to visible range)
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m     2. Resample to isotropic voxel spacing
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m     3. Resize/crop to model input dimensions
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m     4. Normalize to [0, 1]
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m     # Step 1: Windowing. Maps the relevant HU range to [0, 1].
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m     # Brain window (W:80, L:40) shows soft tissue.
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m     # Bone window (W:1800, L:400) shows fractures.
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m     # The model was trained on a specific window; use the same one.
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m     window_center = model_config.get("window_center", 40)
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m     window_width = model_config.get("window_width", 80)
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m     lower = window_center - (window_width / 2)
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m     upper = window_center + (window_width / 2)
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m     windowed = np.clip(volume, lower, upper)
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m     windowed = (windowed - lower) / (upper - lower)  # Now in [0, 1]
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m     # Step 2: Resample to target voxel spacing.
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m     # Real CT scans have non-isotropic voxels (e.g., 0.5mm x 0.5mm x 2.5mm).
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m     # Models expect isotropic input. We resample using simple nearest-neighbor
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m     # here; production would use scipy.ndimage.zoom with order=1 or 3.
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m     target_spacing = model_config.get("voxel_spacing_mm", 1.0)
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m     zoom_factors = (
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m         original_spacing[0] / target_spacing,
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m         original_spacing[1] / target_spacing,
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m         original_spacing[2] / target_spacing,
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m     # Simplified resampling: just resize to target shape.
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m     # In production, use scipy.ndimage.zoom(windowed, zoom_factors, order=1)
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m     # then center-crop or pad to target dimensions.
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m     target_h, target_w, target_slices = model_config["input_shape"]
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m     # Resize each slice to target H x W, then select/pad slices.
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m     from numpy.lib.stride_tricks import as_strided  # noqa: avoid heavy imports
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m     # Simple approach: uniformly sample target_slices from the volume.
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m     num_slices = windowed.shape[0]
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m     if num_slices >= target_slices:
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m         # Uniformly sample slices
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m         indices = np.linspace(0, num_slices - 1, target_slices, dtype=int)
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m         sampled = windowed[indices]
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m         # Pad with zeros if fewer slices than expected
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m         pad_amount = target_slices - num_slices
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m         sampled = np.pad(windowed, ((0, pad_amount), (0, 0), (0, 0)), mode="constant")
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m     # Resize spatial dimensions (simple nearest-neighbor via slicing).
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m     # Production: use cv2.resize or scipy for proper interpolation.
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m     h, w = sampled.shape[1], sampled.shape[2]
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m     row_step = max(1, h // target_h)
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m     col_step = max(1, w // target_w)
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m     resized = sampled[:, ::row_step, ::col_step][:, :target_h, :target_w]
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m     # Pad if smaller than target
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m     if resized.shape[1] < target_h or resized.shape[2] < target_w:
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m         pad_h = target_h - resized.shape[1]
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m         pad_w = target_w - resized.shape[2]
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m         resized = np.pad(resized, ((0, 0), (0, pad_h), (0, pad_w)), mode="constant")
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m     # Transpose to (H, W, slices) to match model input convention.
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m     result = np.transpose(resized, (1, 2, 0))
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m     return result
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m def _preprocess_2d(image: np.ndarray, model_config: dict) -> np.ndarray:
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m     Preprocess a 2D X-ray image for model inference.
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m     Steps:
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m     1. Normalize pixel values to [0, 1]
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m     2. Resize to model input dimensions
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m     target_h, target_w, _ = model_config["input_shape"]
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m     # Normalize to [0, 1] based on actual pixel range.
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m     img_min = image.min()
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m     img_max = image.max()
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m     if img_max > img_min:
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m         normalized = (image - img_min) / (img_max - img_min)
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m         normalized = np.zeros_like(image, dtype=np.float32)
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m     # Simple resize via uniform sampling.
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m     h, w = normalized.shape
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m     row_indices = np.linspace(0, h - 1, target_h, dtype=int)
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m     col_indices = np.linspace(0, w - 1, target_w, dtype=int)
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m     resized = normalized[np.ix_(row_indices, col_indices)]
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m     # Add channel dimension: (H, W) -> (H, W, 1)
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m     return resized[:, :, np.newaxis]
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m ## Step 3: Invoke SageMaker Endpoint for Inference
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m *Maps to the inference call in pseudocode Step 3. Sends the preprocessed array to the appropriate SageMaker endpoint and parses the response into structured findings.*
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m def invoke_model(model_config: dict, preprocessed_array: np.ndarray) -> list[dict]:
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m     Call a SageMaker endpoint with preprocessed image data and parse findings.
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m     The endpoint expects a numpy array serialized as bytes. The response is
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m     JSON containing a list of detected findings with confidence scores.
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m         model_config: model configuration dict with endpoint_name and findings list.
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m         preprocessed_array: numpy float32 array matching model input_shape.
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m         List of finding dicts: [{"finding": str, "confidence": float, ...}]
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m         Only findings above MINIMUM_FINDING_CONFIDENCE are returned.
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m     endpoint_name = model_config["endpoint_name"]
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m     # Serialize the numpy array for transmission.
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m     # SageMaker endpoints accept various content types.
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m     # application/x-npy is efficient for numpy arrays.
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m     payload = preprocessed_array.tobytes()
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m     # Include shape metadata in a custom header so the endpoint can reconstruct.
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m     # Alternative: use application/json with the array as a nested list (slower).
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m     custom_attributes = json.dumps({
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m         "shape": list(preprocessed_array.shape),
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m         "dtype": "float32",
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m     response = sagemaker_runtime.invoke_endpoint(
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m         EndpointName=endpoint_name,
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m         ContentType="application/x-npy",
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m         Body=payload,
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m         CustomAttributes=custom_attributes,
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m     # Parse the response body. Expected format:
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m     # {
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m     #   "findings": [
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m     #     {"finding": "intracranial_hemorrhage", "confidence": 0.94,
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m     #      "subtype": "subdural", "location": {"slice_range": [45, 62]}},
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m     #     {"finding": "midline_shift", "confidence": 0.87, "shift_mm": 6.2}
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m     #   ],
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m     #   "model_version": "v2.3.1",
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m     #   "inference_time_ms": 1240
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m     # }
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m     result = json.loads(response["Body"].read().decode("utf-8"))
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m     findings = result.get("findings", [])
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m     # Filter out low-confidence noise.
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m     filtered = [
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m         f for f in findings
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m         if f.get("confidence", 0) >= MINIMUM_FINDING_CONFIDENCE
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m         "Model %s returned %d findings (%d above threshold)",
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m         endpoint_name, len(findings), len(filtered)
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m     return filtered
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m ## Step 4: Assign Priority Based on Findings
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m *Maps to pseudocode Step 4. Takes the combined findings from all models that ran on a study and determines the highest applicable priority level.*
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m def assign_priority(all_findings: list[dict]) -> tuple[str, list[dict]]:
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m     Map combined model findings to a clinical priority level.
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m     Iterates through PRIORITY_RULES (ordered STAT first, then URGENT).
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m     The highest matching priority wins. A study with both a STAT finding
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m     and an URGENT finding gets STAT priority.
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m         all_findings: combined list of findings from all models.
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m         Tuple of (priority_level, triggering_findings):
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m         - priority_level: "STAT", "URGENT", or "ROUTINE"
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m         - triggering_findings: list of findings that triggered the assigned priority
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m     highest_priority = "ROUTINE"
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m     triggering_findings = []
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m     for finding in all_findings:
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m         finding_name = finding.get("finding", "")
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m         confidence = finding.get("confidence", 0.0)
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m         for rule in PRIORITY_RULES:
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m             if finding_name == rule["finding"] and confidence >= rule["min_confidence"]:
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m                 rule_priority = rule["priority"]
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m                 if PRIORITY_LEVELS[rule_priority] > PRIORITY_LEVELS[highest_priority]:
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m                     highest_priority = rule_priority
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m                     triggering_findings = [finding]
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m                 elif PRIORITY_LEVELS[rule_priority] == PRIORITY_LEVELS[highest_priority]:
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m                     triggering_findings.append(finding)
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m     return highest_priority, triggering_findings
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m ## Step 5: Store Results and Send Alerts
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m *Maps to the result storage and notification portions of the pseudocode. Writes the triage result to DynamoDB and fires an SNS alert for STAT findings.*
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m def store_triage_result(
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m     study_uid: str,
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m     study_metadata: dict,
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m     priority: str,
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m     all_findings: list[dict],
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m     triggering_findings: list[dict],
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m     models_invoked: list[str],
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m     Write the triage result to DynamoDB and send alerts for critical findings.
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m     The record includes everything needed for audit: which models ran,
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m     what they found, what priority was assigned, and why. This is critical
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m     for FDA audit trail requirements on medical device software.
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m         study_uid: DICOM StudyInstanceUID (unique study identifier).
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m         study_metadata: original DICOM metadata dict.
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m         priority: assigned priority level ("STAT", "URGENT", "ROUTINE").
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m         all_findings: complete list of findings from all models.
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m         triggering_findings: subset of findings that triggered the priority.
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m         models_invoked: list of model names that were run.
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m         The stored record dict.
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m     results_table = dynamodb.Table(RESULTS_TABLE_NAME)
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m     # Convert floats to Decimal for DynamoDB.
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m     def decimal_findings(findings_list):
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m         converted = []
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m         for f in findings_list:
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m             entry = {}
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m             for k, v in f.items():
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m                 if isinstance(v, float):
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m                     entry[k] = Decimal(str(round(v, 4)))
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m                 else:
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m                     entry[k] = v
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m             converted.append(entry)
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m         return converted
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m     record = {
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m         "study_uid": study_uid,
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m         "triaged_at": datetime.datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m         "priority": priority,
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m         "patient_id": study_metadata.get("PatientID", "UNKNOWN"),
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m         "accession_number": study_metadata.get("AccessionNumber", ""),
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m         "modality": study_metadata.get("Modality", ""),
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m         "study_description": study_metadata.get("StudyDescription", ""),
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m         "models_invoked": models_invoked,
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m         "all_findings": decimal_findings(all_findings),
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m         "triggering_findings": decimal_findings(triggering_findings),
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m         "acknowledged": False,
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m         "acknowledged_by": None,
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m         "acknowledged_at": None,
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m     results_table.put_item(Item=record)
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m     logger.info("Stored triage result for %s: priority=%s", study_uid, priority)
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m     # Send SNS alert for STAT findings.
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m     if priority == "STAT":
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m         _send_critical_alert(study_uid, study_metadata, triggering_findings)
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m     return record
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m def _send_critical_alert(
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m     study_uid: str,
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m     study_metadata: dict,
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m     triggering_findings: list[dict],
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m ) -> None:
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m     Publish a critical finding alert via SNS.
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m     The message goes to the on-call radiologist and the referring physician.
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m     It contains enough context to act on without opening the full study:
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m     what was found, how confident the AI is, and where to find the study.
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m     Never include patient name or MRN in the SNS message body.
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m     Use accession number (which maps to the study in PACS) as the identifier.
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m     finding_summaries = []
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m     for f in triggering_findings:
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m         summary = f"{f['finding']} (confidence: {f.get('confidence', 'N/A')})"
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m         if "subtype" in f:
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m             summary += f" [{f['subtype']}]"
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m         finding_summaries.append(summary)
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m     message = {
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m         "alert_type": "STAT_RADIOLOGY_FINDING",
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m         "accession_number": study_metadata.get("AccessionNumber", "UNKNOWN"),
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m         "modality": study_metadata.get("Modality", ""),
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m         "study_description": study_metadata.get("StudyDescription", ""),
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m         "findings": finding_summaries,
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m         "study_uid": study_uid,
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m         "timestamp": datetime.datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m         "action_required": "Immediate radiologist review required",
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m     sns_client.publish(
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m         TopicArn=CRITICAL_ALERT_TOPIC_ARN,
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m         Subject="STAT: Critical Radiology Finding Detected",
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m         Message=json.dumps(message, indent=2),
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m         MessageAttributes={
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m             "priority": {"DataType": "String", "StringValue": "STAT"},
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m             "modality": {"DataType": "String", "StringValue": study_metadata.get("Modality", "")},
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m     logger.info("Published STAT alert for accession %s", study_metadata.get("AccessionNumber"))
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m ## Putting It All Together
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m def triage_study(study_uid: str, study_metadata: dict, pixel_data: np.ndarray,
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m                  voxel_spacing: tuple[float, float, float]) -> dict:
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m     Run the full multi-modality triage pipeline for one imaging study.
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m     Steps:
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m       1. Classify the study and select applicable models
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m       2. For each model: preprocess and invoke inference
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m       3. Aggregate all findings and assign priority
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m       4. Store results and alert if critical
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m         study_uid: DICOM StudyInstanceUID.
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m         study_metadata: dict of DICOM header fields.
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m         pixel_data: numpy array of pixel/voxel data.
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m         voxel_spacing: (slice_spacing, row_spacing, col_spacing) in mm.
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m         Triage result record from DynamoDB.
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m     logger.info("Starting triage for study %s", study_uid)
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m     # Step 1: Determine which models to run.
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m     selected_models = classify_study_and_select_models(study_metadata)
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m     if not selected_models:
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m         logger.info("No applicable models for study %s. Assigning ROUTINE.", study_uid)
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m         return store_triage_result(
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m             study_uid=study_uid,
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m             study_metadata=study_metadata,
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m             priority="ROUTINE",
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m             all_findings=[],
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m             triggering_findings=[],
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m             models_invoked=[],
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m     logger.info("Selected %d model(s): %s",
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m                 len(selected_models),
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m                 [m["model_name"] for m in selected_models])
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m     # Step 2: Preprocess and invoke each model.
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m     all_findings = []
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m     models_invoked = []
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m     for model_config in selected_models:
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m         model_name = model_config["model_name"]
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m         logger.info("  Running model: %s", model_name)
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m         try:
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m             preprocessed = preprocess_for_model(pixel_data, model_config, voxel_spacing)
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m             findings = invoke_model(model_config, preprocessed)
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m             # Tag each finding with the model that produced it (for audit).
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m             for f in findings:
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m                 f["source_model"] = model_name
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m             all_findings.extend(findings)
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m             models_invoked.append(model_name)
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m         except Exception as e:
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m             # Model failure should not block triage of other models.
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m             # Log the error, continue with remaining models.
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m             logger.error("Model %s failed for study %s: %s", model_name, study_uid, str(e))
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m     # Step 3: Assign priority based on combined findings.
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m     priority, triggering_findings = assign_priority(all_findings)
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m     logger.info("  Priority assigned: %s (%d triggering findings)",
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m                 priority, len(triggering_findings))
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m     # Step 4: Store and alert.
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m     result = store_triage_result(
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m         study_uid=study_uid,
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m         study_metadata=study_metadata,
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m         priority=priority,
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m         all_findings=all_findings,
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m         triggering_findings=triggering_findings,
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m         models_invoked=models_invoked,
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m     return result
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m # ----- Example: Simulate a triage run with synthetic data -----
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m if __name__ == "__main__":
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m     # Synthetic CT Head study metadata (mimics what you'd parse from DICOM headers).
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m     synthetic_metadata = {
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m         "StudyInstanceUID": "1.2.840.113619.2.55.3.12345.2026.05.31.12.00.00",
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m         "Modality": "CT",
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m         "BodyPartExamined": "HEAD",
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m         "StudyDescription": "CT HEAD W/O CONTRAST",
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m         "ProtocolName": "CT Head Routine",
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m         "PatientID": "SYNTH-001",
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m         "AccessionNumber": "ACC-2026-0531-001",
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m         "ReferringPhysicianName": "Dr. Smith",
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m     # Synthetic pixel data: random noise shaped like a CT head volume.
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m     # 200 slices, 512x512 pixels each. Values in Hounsfield Units range.
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m     synthetic_volume = np.random.randint(-1000, 1000, size=(200, 512, 512)).astype(np.float32)
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m     # Typical CT head spacing: 0.5mm slice thickness, 0.5mm x 0.5mm pixel spacing.
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m     synthetic_spacing = (0.5, 0.5, 0.5)
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m     print("Radiology AI Triage: Synthetic CT Head Study")
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m     # Step 1: Classify
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m     models = classify_study_and_select_models(synthetic_metadata)
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m     print(f"\nSelected models: {[m['model_name'] for m in models]}")
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m     # Step 2: Preprocess (demonstrate without calling SageMaker)
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m     if models:
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m         model = models[0]
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m         preprocessed = preprocess_for_model(synthetic_volume, model, synthetic_spacing)
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m         print(f"Preprocessed shape for {model['model_name']}: {preprocessed.shape}")
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m         print(f"Value range: [{preprocessed.min():.3f}, {preprocessed.max():.3f}]")
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m     # Step 3: Simulate findings (since we can't call real endpoints here)
