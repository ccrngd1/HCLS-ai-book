[0m[48;2;40;67;43m[39m+    416[0m:[39m[48;2;24;38;30m [38;2;192;197;206m│    - WER, diarization error rate, faithfulness score,     │[K
[0m[48;2;40;67;43m[39m+    417[0m:[39m[48;2;24;38;30m [38;2;192;197;206m│      structured-field acceptance, edit distance,          │[K
[0m[48;2;40;67;43m[39m+    418[0m:[39m[48;2;24;38;30m [38;2;192;197;206m│      adoption rate                                        │[K
[0m[48;2;40;67;43m[39m+    419[0m:[39m[48;2;24;38;30m [38;2;192;197;206m│   [Operational telemetry]                                 │[K
[0m[48;2;40;67;43m[39m+    420[0m:[39m[48;2;24;38;30m [38;2;192;197;206m│    - Per-encounter audio length, transcript length,       │[K
[0m[48;2;40;67;43m[39m+    421[0m:[39m[48;2;24;38;30m [38;2;192;197;206m│      note generation latency                              │[K
[0m[48;2;40;67;43m[39m+    422[0m:[39m[48;2;24;38;30m [38;2;192;197;206m│    - Edit distance between draft and signed final         │[K
[0m[48;2;40;67;43m[39m+    423[0m:[39m[48;2;24;38;30m [38;2;192;197;206m│    - Per-clinician adoption metrics                       │[K
[0m[48;2;40;67;43m[39m+    424[0m:[39m[48;2;24;38;30m [38;2;192;197;206m│   [Audio retention enforcement]                           │[K
[0m[48;2;40;67;43m[39m+    425[0m:[39m[48;2;24;38;30m [38;2;192;197;206m│    - Brief retention with automatic deletion              │[K
[0m[48;2;40;67;43m[39m+    426[0m:[39m[48;2;24;38;30m [38;2;192;197;206m│   [Sampled review for clinical-quality concerns]          │[K
[0m[48;2;40;67;43m[39m+    427[0m:[39m[48;2;24;38;30m [38;2;192;197;206m│           │                                               │[K
