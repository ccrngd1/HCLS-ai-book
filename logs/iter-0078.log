[0m[48;2;40;67;43m[39m+    1536[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Diarization error rate, two-speaker (clinician + patient) [38;2;192;197;206m|[38;2;192;197;206m n/a [38;2;192;197;206m|[38;2;192;197;206m 3-8% [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    1537[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Diarization error rate, three-speaker (with family) [38;2;192;197;206m|[38;2;192;197;206m n/a [38;2;192;197;206m|[38;2;192;197;206m 8-18% [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    1538[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Diarization error rate, four-or-more-speaker (teaching) [38;2;192;197;206m|[38;2;192;197;206m n/a [38;2;192;197;206m|[38;2;192;197;206m 15-30% [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    1539[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Faithfulness score on rendered note [38;2;192;197;206m|[38;2;192;197;206m n/a [38;2;192;197;206m|[38;2;192;197;206m 0.88-0.96 [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    1540[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Edit distance (draft to signed) median word fraction [38;2;192;197;206m|[38;2;192;197;206m n/a [38;2;192;197;206m|[38;2;192;197;206m 0.10-0.30 [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    1541[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Structured-extraction acceptance rate [38;2;192;197;206m|[38;2;192;197;206m n/a [38;2;192;197;206m|[38;2;192;197;206m 70-90% [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    1542[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Per-encounter AWS infrastructure cost [38;2;192;197;206m|[38;2;192;197;206m n/a [38;2;192;197;206m|[38;2;192;197;206m $0.40-2.50 [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    1543[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Sustained adoption at three months [38;2;192;197;206m|[38;2;192;197;206m n/a [38;2;192;197;206m|[38;2;192;197;206m 60-85% of eligible encounters use the feature [38;2;192;197;206m|[K
