[0m[48;2;40;67;43m[39m+    449[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m------------[38;2;192;197;206m|[38;2;192;197;206m------[38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    450[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAmazon Kinesis Data Streams[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m Canonical audit-event stream [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    451[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAWS Lambda (ehr-audit-ingest)[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m EHR audit-log feed ingestion and source-format normalization [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    452[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAWS Lambda (app-audit-ingest)[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m Application-system audit-log ingestion (PACS, lab, pharmacy, billing) [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    453[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAWS Lambda (identity-log-ingest)[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m IdP, VPN, and authentication-log ingestion [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    454[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAWS Lambda (break-glass-ingest)[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m Break-glass override event ingestion with override-reason text capture [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    455[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAWS Lambda (identity-context-loader)[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m Periodic load of HRIS, IAM, and scheduling enrichment data [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    456[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAWS Lambda (event-normalizer)[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m Canonical event format, identifier resolution, deduplication [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    457[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAWS Lambda (enrichment)[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m Identity, role, schedule, care-team, sensitivity-flag enrichment per event [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    458[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAWS Lambda (rules-engine)[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m Same-name, VIP, self-access, break-glass, off-hours rule evaluation [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    459[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAWS Lambda (baseline-detector)[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m Per-user statistical deviation detection against rolling baseline [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    460[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAWS Lambda (graph-detector)[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m Relationship-based detection using Neptune queries [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    461[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAWS Lambda (composite-scoring)[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m Combines per-detector scores into composite case scores [38;2;192;197;206m|[K
