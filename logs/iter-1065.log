[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m # medical direction protocols. Priority 1 = life-threatening emergency.
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m RESPONSE_TIME_TARGETS = {
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m     1: 480,   # 8 minutes for Priority 1 (cardiac arrest, major trauma)
