[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m # For Priority 1 calls, we override the weights to prioritize pure speed.
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m # Coverage concerns take a back seat when someone is dying.
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m PRIORITY_1_WEIGHTS = {
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m     "response_time": 0.90,
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m     "coverage_impact": 0.10,
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m     "fatigue": 0.0,
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m     "workload": 0.0,
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m # Coverage threshold: a zone is "covered" if at least one available unit
