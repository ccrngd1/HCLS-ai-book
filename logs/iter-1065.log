[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m             "longitude": -77.0500,
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m             "status": "EN_ROUTE",
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m             "zone": "ZONE-C",
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m             "shift_start": "2026-06-01T06:00:00Z",
