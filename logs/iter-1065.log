[0m[49m[38;5;10m+     49[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m # Table where we store dispatch decisions for audit trail.
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m DISPATCH_TABLE_NAME = "ems-dispatch-decisions"
[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m 
