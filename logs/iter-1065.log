[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m     "ALS": 2,  # Advanced Life Support (paramedic)
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m     "BLS": 1,  # Basic Life Support (EMT)
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m # Scoring weights for the dispatch optimizer. These control the trade-off
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m # between "send the fastest unit" and "preserve system coverage."
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m # Tuned per system based on historical performance analysis.
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m DISPATCH_WEIGHTS = {
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m     "response_time": 0.60,   # dominant factor: get there fast
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m     "coverage_impact": 0.25, # don't leave zones uncovered
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m     "fatigue": 0.10,         # crew welfare (hours on shift)
