[0m[49m[38;5;10m+     27[0m:[38;5;10m[49m Before we get into the logic, here are the configuration values and lookup tables that drive the pipeline. The SDOH keyword list determines which notes get full NLP processing (and which ones we skip to save cost). The domain code map connects extracted categories to standard terminology for downstream interoperability.
[0m[49m[38;5;10m+     28[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     29[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     30[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+     31[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+     32[0m:[38;5;10m[49m import re
[0m[49m[38;5;10m+     33[0m:[38;5;10m[49m import datetime
[0m[49m[38;5;10m+     34[0m:[38;5;10m[49m from datetime import timezone
[0m[49m[38;5;10m+     35[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+     36[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     37[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+     38[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+     39[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     40[0m:[38;5;10m[49m # Structured logging. In production, use JSON-formatted output for
[0m[49m[38;5;10m+     41[0m:[38;5;10m[49m # CloudWatch Logs Insights queries. Never log PHI field values.
[0m[49m[38;5;10m+     42[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+     43[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+     44[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     45[0m:[38;5;10m[49m # Adaptive retry handles burst throttling from Comprehend Medical.
[0m[49m[38;5;10m+     46[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 5, "mode": "adaptive"})
[0m[49m[38;5;10m+     47[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     48[0m:[38;5;10m[49m # AWS clients
[0m[49m[38;5;10m+     49[0m:[38;5;10m[49m comprehend_medical = boto3.client("comprehendmedical", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m comprehend = boto3.client("comprehend", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m # Table name. Replace with your actual DynamoDB table name.
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m SDOH_PROFILES_TABLE = "sdoh-profiles"
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m # The ARN of your trained Comprehend custom classifier endpoint.
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m # You must train and deploy this before running the pipeline.
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m # See the main recipe for training data requirements.
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m SDOH_CLASSIFIER_ENDPOINT_ARN = "arn:aws:comprehend:us-east-1:123456789012:document-classifier-endpoint/sdoh-classifier"
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m # Confidence threshold for accepting an SDOH classification.
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m # Below this, we still extract but flag for human review.
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m CONFIDENCE_THRESHOLD = 0.75
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m # SDOH relevance keywords: terms that suggest a note may contain
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m # social determinant information. This is a high-recall filter.
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m # False positives are cheap (we just run NLP on a note that turns out
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m # to have nothing). False negatives are expensive (we miss a real need).
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m SDOH_KEYWORDS = [
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m     "housing", "homeless", "unhoused", "shelter", "evict",
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m     "food", "hungry", "meal", "nutrition", "food bank", "snap",
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m     "transportation", "ride", "bus", "car",
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m     "employ", "job", "unemploy", "income", "afford", "financial",
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m     "isolat", "alone", "support", "caregiver",
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m     "utility", "electric", "heat", "water",
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m     "safe", "violence", "abuse",
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m     "education", "literacy", "language barrier",
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m     "incarcerat", "legal", "immigration",
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m # Section header patterns for clinical notes. These help us identify
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m # which part of the note a sentence came from, which affects interpretation.
