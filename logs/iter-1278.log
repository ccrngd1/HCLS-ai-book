[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m         "snomed": ["422587007"],
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m         "display": "Social isolation and inadequate social support",
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m     "interpersonal_safety": {
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m         "icd10": ["Z63.0", "T74", "T76"],
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m         "loinc": ["76501-6"],
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m         "snomed": ["706893006"],
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m         "display": "Interpersonal violence and safety concerns",
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m     "education_literacy": {
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m         "icd10": ["Z55.0", "Z55.9"],
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m         "loinc": ["82589-3"],
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m         "snomed": ["105421008"],
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m         "display": "Problems related to education and literacy",
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m     "utility_insecurity": {
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m         "icd10": ["Z59.81"],
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m         "loinc": ["93033-9"],
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m         "snomed": [],
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m         "display": "Utility insecurity",
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m ## Step 1: Relevance Filtering
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m *The pseudocode calls this `should_process_note(note_text)`. Before running expensive NLP extraction on every note, apply a quick keyword scan to identify notes worth processing. Most progress notes contain zero SDOH information, and Comprehend Medical charges per character.*
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m def should_process_note(note_text: str) -> bool:
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m     Quick keyword scan to decide if a note is worth full SDOH extraction.
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m     This is intentionally permissive (high recall, lower precision).
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m     We'd rather spend $0.05 processing an irrelevant note than miss
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m     a real SDOH mention in a note we skipped.
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m         note_text: The full clinical note text.
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m         True if the note contains any SDOH-related keywords, False otherwise.
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m     lower_text = note_text.lower()
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m     for keyword in SDOH_KEYWORDS:
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m         if keyword in lower_text:
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m             return True
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m     return False
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m ## Step 2: Section Detection and Sentence Segmentation
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m *The pseudocode calls this `segment_note(note_text)`. We identify note sections (social history, assessment/plan, etc.) and split into sentences. Section context matters because "patient's mother was homeless" in family history means something different than "patient is homeless" in social history.*
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m def detect_sections(note_text: str) -> list[dict]:
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m     Identify sections within a clinical note based on header patterns.
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m     Clinical notes have implicit structure. Headers like "Social History:"
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m     or "Assessment and Plan:" divide the note into meaningful segments.
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m     We detect these headers and tag each chunk of text with its section type.
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m         note_text: The full clinical note text.
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m         A list of dicts, each with:
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m         - text: the section content (string)
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m         - section_type: one of the keys in SECTION_PATTERNS, or "unknown"
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m     # Build a combined regex that matches any known section header.
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m     # We look for these at the start of a line, optionally followed by a colon.
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m     all_patterns = []
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m     pattern_to_section = {}
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m     for section_type, headers in SECTION_PATTERNS.items():
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m         for header in headers:
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m             all_patterns.append(re.escape(header))
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m             pattern_to_section[header.lower()] = section_type
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m     # Match section headers at the start of a line (case-insensitive).
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m     header_regex = re.compile(
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m         r"^(" + "|".join(all_patterns) + r")\s*:?\s*$",
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m         re.IGNORECASE | re.MULTILINE,
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m     # Find all header positions in the note.
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m     matches = list(header_regex.finditer(note_text))
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m     if not matches:
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m         # No recognized headers found. Treat the entire note as one "unknown" section.
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m         return [{"text": note_text, "section_type": "unknown"}]
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m     sections = []
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m     # Add text before the first header as "unknown" section.
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m     if matches[0].start() > 0:
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m         pre_text = note_text[: matches[0].start()].strip()
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m         if pre_text:
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m             sections.append({"text": pre_text, "section_type": "unknown"})
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m     # Walk through each header and capture the text until the next header.
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     for i, match in enumerate(matches):
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m         header_text = match.group(1).lower().strip()
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m         section_type = pattern_to_section.get(header_text, "unknown")
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m         # Section content runs from end of this header to start of next header
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m         # (or end of note).
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m         content_start = match.end()
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m         content_end = matches[i + 1].start() if i + 1 < len(matches) else len(note_text)
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m         content = note_text[content_start:content_end].strip()
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m         if content:
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m             sections.append({"text": content, "section_type": section_type})
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m     return sections
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m def segment_into_sentences(text: str) -> list[str]:
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m     Split text into sentences using simple heuristics.
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m     Clinical text doesn't follow standard English sentence rules.
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m     Abbreviations (Dr., pt., q.d.) create false positive splits.
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m     This is a "good enough" approach. Production systems use more
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m     sophisticated sentence boundary detection (spaCy, scispacy, or
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m     Comprehend Medical's own sentence detection).
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m         text: A block of text (typically one note section).
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m         A list of sentence strings.
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m     # Split on period followed by space and uppercase, or on newlines.
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m     # This is deliberately conservative to avoid splitting on "Dr. Smith"
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m     # or "q.d. dosing".
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m     sentences = re.split(r"(?<=[.!?])\s+(?=[A-Z])", text)
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m     # Also split on newlines (clinical notes often use line breaks as separators).
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m     expanded = []
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m     for sent in sentences:
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m         parts = sent.split("\n")
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m         expanded.extend([p.strip() for p in parts if p.strip()])
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m     return expanded
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m def segment_note(note_text: str) -> list[dict]:
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m     Full segmentation: detect sections, split into sentences, tag each sentence
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m     with its section context and priority level.
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m         note_text: The full clinical note text.
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m         A list of dicts, each representing one sentence with metadata:
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m         - text: the sentence string
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m         - section_type: which section it came from
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m         - is_priority: whether this section is high-priority for SDOH
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m     sections = detect_sections(note_text)
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m     segmented = []
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m     for section in sections:
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m         sentences = segment_into_sentences(section["text"])
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m         for sentence in sentences:
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m             # Skip very short fragments (likely artifacts).
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m             if len(sentence) < 10:
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m             segmented.append({
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m                 "text": sentence,
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m                 "section_type": section["section_type"],
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m                 "is_priority": section["section_type"] in HIGH_PRIORITY_SECTIONS,
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m     return segmented
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m ## Step 3: Medical Context Extraction with Comprehend Medical
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m *The pseudocode calls this `extract_medical_context(note_text)`. We pass the note through Comprehend Medical to get negation detection and entity context. The main value here is the negation map: "patient denies food insecurity" should not be flagged as an active need.*
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m def extract_medical_context(note_text: str) -> dict:
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m     Call Comprehend Medical to get foundational NLP context.
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m     We primarily care about negation detection here. Comprehend Medical
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m     identifies which entities in the text are negated ("denies," "no history of,"
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m     "patient does not have"). We use this to override assertion classification
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m     in the next step.
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m     Comprehend Medical's DetectEntitiesV2 handles up to 20,000 UTF-8 characters.
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m     For longer notes, you'd need to chunk the text (maintaining sentence boundaries)
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m     and merge results.
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m         note_text: The full clinical note text (max 20,000 characters).
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m         A dict with:
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m         - entities: the full list of detected entities
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m         - negation_spans: list of (begin, end) tuples for negated text spans
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m     # Truncate to API limit if needed. In production, chunk properly.
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m     text_to_process = note_text[:20000]
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m     response = comprehend_medical.detect_entities_v2(Text=text_to_process)
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m     entities = response.get("Entities", [])
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m     # Build negation map: character spans where Comprehend Medical detected negation.
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m     # "Patient denies food insecurity" would mark "food insecurity" as negated.
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m     negation_spans = []
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m     for entity in entities:
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m         traits = entity.get("Traits", [])
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m         for trait in traits:
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m             if trait.get("Name") == "NEGATION":
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m                 negation_spans.append(
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m                     (entity["BeginOffset"], entity["EndOffset"])
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m                 )
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m         "entities": entities,
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m         "negation_spans": negation_spans,
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m ## Step 4: SDOH Sentence Classification
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m *The pseudocode calls this `classify_sdoh_sentences(segmented_sentences, negation_spans)`. This is the core extraction step. For each sentence, we call the custom Comprehend classifier to determine whether it contains SDOH information and, if so, which domain it belongs to.*
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m def is_within_negation(sentence_text: str, note_text: str, negation_spans: list) -> bool:
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m     Check whether a sentence overlaps with any negated span from Comprehend Medical.
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m     This is a simplified check: we find the sentence's position in the full note
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m     and check if any negation span overlaps with it. In production, you'd use
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m     character offsets tracked from segmentation.
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m         sentence_text: The sentence to check.
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m         note_text: The full note text (for finding position).
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m         negation_spans: List of (begin, end) tuples from Step 3.
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m         True if the sentence overlaps a negated span, False otherwise.
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m     # Find where this sentence appears in the original note.
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m     pos = note_text.find(sentence_text)
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m     if pos == -1:
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m         return False
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m     sent_begin = pos
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m     sent_end = pos + len(sentence_text)
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m     # Check overlap with any negation span.
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m     for neg_begin, neg_end in negation_spans:
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m         # Overlap exists if spans intersect.
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m         if sent_begin < neg_end and sent_end > neg_begin:
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m             return True
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m     return False
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m def classify_sdoh_sentences(
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m     segmented_sentences: list[dict],
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m     negation_spans: list,
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m     note_text: str,
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m ) -> list[dict]:
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m     Classify each sentence for SDOH domain and assertion status.
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m     For each sentence from Step 2, call the Comprehend custom classifier
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m     to determine: (a) whether it contains SDOH content, and (b) which domain
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m     it belongs to (housing, food, transportation, etc.).
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m     Then cross-reference with negation spans from Step 3 to determine
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m     assertion status. Negated mentions get marked "absent" rather than
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m     "active_need."
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m         segmented_sentences: Output of segment_note() (list of sentence dicts).
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m         negation_spans: Negation spans from extract_medical_context().
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m         note_text: The full original note text.
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m         A list of SDOH findings, each with domain, assertion, confidence,
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m         and source text.
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m     findings = []
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m     for sentence_data in segmented_sentences:
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m         sentence_text = sentence_data["text"]
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m         # Call the custom classifier endpoint.
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m         # The response includes a list of classes sorted by confidence score.
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m         try:
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m             response = comprehend.classify_document(
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m                 Text=sentence_text,
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m                 EndpointArn=SDOH_CLASSIFIER_ENDPOINT_ARN,
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m         except Exception as e:
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m             # Log but don't crash the whole pipeline for one sentence.
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m             logger.warning("Classification failed for sentence: %s", str(e))
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m         classes = response.get("Classes", [])
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m         if not classes:
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m         # The top class is the most likely domain.
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m         top_class = classes[0]
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m         domain = top_class["Name"]
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m         confidence = top_class["Score"]
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m         # Skip sentences classified as "none" (no SDOH content).
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m         if domain.lower() == "none":
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m         # Skip low-confidence classifications.
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m         if confidence < CONFIDENCE_THRESHOLD:
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m         # Determine assertion: is this an active need or a negated one?
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m         if is_within_negation(sentence_text, note_text, negation_spans):
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m             assertion = "absent"
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m             # Simple heuristic for assertion beyond negation:
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m             # - Past tense markers suggest "resolved"
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m             # - "referred to" or "connected with" suggest "resource_connected"
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m             # - Everything else defaults to "active_need"
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m             assertion = determine_assertion(sentence_text)
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m         findings.append({
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m             "text": sentence_text,
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m             "domain": domain,
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m             "confidence": confidence,
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m             "assertion": assertion,
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m             "section": sentence_data["section_type"],
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m             "is_priority": sentence_data["is_priority"],
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m     return findings
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m def determine_assertion(sentence_text: str) -> str:
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m     Simple rule-based assertion classification for SDOH mentions.
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m     In production, this would be a second classifier or a more sophisticated
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m     model. Here we use keyword heuristics to distinguish active needs from
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m     resolved ones or connected resources.
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m         sentence_text: The sentence containing the SDOH mention.
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m         One of: "active_need", "resolved", "at_risk", "resource_connected"
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m     lower = sentence_text.lower()
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m     # Resource-connected indicators.
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m     resource_patterns = [
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m         "referred to", "connected with", "enrolled in",
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m         "receiving services", "food bank providing", "voucher",
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m         "approved for", "started receiving",
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m     for pattern in resource_patterns:
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m         if pattern in lower:
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m             return "resource_connected"
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m     # Resolved indicators.
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m     resolved_patterns = [
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m         "no longer", "resolved", "now has stable",
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m         "secured housing", "found employment", "obtained",
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m     for pattern in resolved_patterns:
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m         if pattern in lower:
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m             return "resolved"
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m     # At-risk indicators (not yet a need, but heading that direction).
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m     risk_patterns = [
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m         "at risk", "may lose", "lease expir", "worried about",
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m         "concerned about", "might not be able",
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m     for pattern in risk_patterns:
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m         if pattern in lower:
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m             return "at_risk"
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m     # Default: active need.
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m     return "active_need"
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m ## Step 5: Code Normalization
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m *The pseudocode calls this `normalize_to_codes(sdoh_findings, code_map)`. We map each classified finding to standard terminology codes (ICD-10 Z-codes, LOINC, SNOMED) for downstream interoperability.*
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m def normalize_to_codes(findings: list[dict]) -> list[dict]:
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m     Attach standard terminology codes to each SDOH finding.
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m     This enables extraction results to flow into EHR structured fields,
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m     quality dashboards, and population health platforms without custom
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m     integration per consumer. The codes come from the Gravity Project
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m     value sets.
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m         findings: Output of classify_sdoh_sentences().
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m         The same findings list, enriched with icd10_codes, loinc_codes,
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m         snomed_codes, and display text for each domain.
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m     normalized = []
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m     for finding in findings:
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m         domain = finding["domain"]
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m         if domain not in SDOH_CODE_MAP:
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m             # Unknown domain from classifier. Log and skip normalization
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m             # but still include the finding.
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m             logger.warning("No code mapping for domain: %s", domain)
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m             finding["icd10_codes"] = []
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m             finding["loinc_codes"] = []
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m             finding["snomed_codes"] = []
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m             finding["display"] = domain
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m             normalized.append(finding)
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m         codes = SDOH_CODE_MAP[domain]
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m         finding["icd10_codes"] = codes["icd10"]
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m         finding["loinc_codes"] = codes["loinc"]
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m         finding["snomed_codes"] = codes["snomed"]
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m         finding["display"] = codes["display"]
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m         normalized.append(finding)
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m     return normalized
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m ## Step 6: Store Patient-Level SDOH Profile
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m *The pseudocode calls this `store_sdoh_profile(patient_id, note_id, note_date, findings)`. We write each finding to DynamoDB with provenance (which note, which date) so care managers can trace back to the source.*
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m def store_sdoh_profile(
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m     patient_id: str,
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m     note_id: str,
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m     note_date: str,
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m     findings: list[dict],
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m ) -> list[dict]:
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m     Write SDOH findings to the patient's profile in DynamoDB.
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m     Each finding becomes a separate item, partitioned by patient_id and
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m     sorted by domain + note_date. This schema supports queries like:
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m     - "All SDOH findings for patient X" (query on partition key)
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m     - "All housing findings for patient X" (query with sort key prefix)
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m     - "All findings from the last 6 months" (query with date range)
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m         patient_id: The patient's unique identifier.
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m         note_id: The source note's identifier (for traceability).
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m         note_date: When the note was written (ISO date string).
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m         findings: Normalized findings from Step 5.
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m         The list of records written to DynamoDB.
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m     table = dynamodb.Table(SDOH_PROFILES_TABLE)
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m     records_written = []
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m     for finding in findings:
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m         # Sort key combines domain and date for efficient range queries.
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m         sort_key = f"{finding['domain']}#{note_date}"
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m         record = {
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m             "patient_id": patient_id,
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m             "sort_key": sort_key,
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m             "domain": finding["domain"],
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m             "assertion": finding["assertion"],
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m             "confidence": Decimal(str(round(finding["confidence"], 4))),
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m             # DynamoDB does not accept Python floats. Wrap in Decimal()
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m             # via str() to avoid floating-point artifacts.
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m             "source_text": finding["text"],
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m             "source_note": note_id,
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m             "note_date": note_date,
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m             "extraction_ts": datetime.datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m             "icd10_codes": finding.get("icd10_codes", []),
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m             "loinc_codes": finding.get("loinc_codes", []),
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m             "snomed_codes": finding.get("snomed_codes", []),
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m             "display": finding.get("display", ""),
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m             "section": finding["section"],
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m             "reviewed": False,
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m         table.put_item(Item=record)
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m         records_written.append(record)
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m     return records_written
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m ## Putting It All Together
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m Here's the full pipeline assembled into a single function. This is what your Lambda handler would call when a note arrives via SQS.
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m def process_note_for_sdoh(
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m     patient_id: str,
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m     note_id: str,
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m     note_date: str,
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m     note_text: str,
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m     Run the full SDOH extraction pipeline for one clinical note.
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m     This is the main entry point. In a Lambda deployment, your handler
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m     would parse the SQS message (which contains the note metadata and text),
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m     and call this function.
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m         patient_id: The patient's unique identifier.
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m         note_id: The note's unique identifier (for audit trail).
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m         note_date: When the note was written (YYYY-MM-DD).
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m         note_text: The full clinical note text.
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m         A summary dict with extraction results and metadata.
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m     # Step 1: Quick relevance check. Skip notes with no SDOH keywords.
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m     logger.info("Step 1: Relevance filtering for note %s", note_id)
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m     if not should_process_note(note_text):
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m         logger.info("  No SDOH keywords found. Skipping full extraction.")
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m             "patient_id": patient_id,
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m             "note_id": note_id,
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m             "skipped": True,
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m             "reason": "no_sdoh_keywords",
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m             "findings": [],
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m     # Step 2: Section detection and sentence segmentation.
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m     logger.info("Step 2: Segmenting note into sections and sentences")
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m     segmented = segment_note(note_text)
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m     logger.info("  Found %d sentences across sections", len(segmented))
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m     # Step 3: Get negation context from Comprehend Medical.
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m     logger.info("Step 3: Extracting medical context (negation detection)")
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m     medical_context = extract_medical_context(note_text)
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m     negation_spans = medical_context["negation_spans"]
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m     logger.info("  Found %d negation spans", len(negation_spans))
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m     # Step 4: Classify each sentence for SDOH content.
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m     logger.info("Step 4: Classifying sentences for SDOH domains")
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m     findings = classify_sdoh_sentences(segmented, negation_spans, note_text)
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m     logger.info("  Found %d SDOH findings above threshold", len(findings))
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    717[0m:[38;5;10m[49m     # Step 5: Normalize findings to standard codes.
[0m[49m[38;5;10m+    718[0m:[38;5;10m[49m     logger.info("Step 5: Normalizing to ICD-10/LOINC/SNOMED codes")
[0m[49m[38;5;10m+    719[0m:[38;5;10m[49m     normalized = normalize_to_codes(findings)
[0m[49m[38;5;10m+    720[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m     # Step 6: Store in patient profile.
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m     logger.info("Step 6: Storing SDOH profile in DynamoDB")
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m     stored = store_sdoh_profile(patient_id, note_id, note_date, normalized)
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m     logger.info("  Wrote %d records to DynamoDB", len(stored))
[0m[49m[38;5;10m+    725[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    726[0m:[38;5;10m[49m     result = {
[0m[49m[38;5;10m+    727[0m:[38;5;10m[49m         "patient_id": patient_id,
[0m[49m[38;5;10m+    728[0m:[38;5;10m[49m         "note_id": note_id,
[0m[49m[38;5;10m+    729[0m:[38;5;10m[49m         "note_date": note_date,
[0m[49m[38;5;10m+    730[0m:[38;5;10m[49m         "extraction_timestamp": datetime.datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    731[0m:[38;5;10m[49m         "skipped": False,
[0m[49m[38;5;10m+    732[0m:[38;5;10m[49m         "sentences_evaluated": len(segmented),
[0m[49m[38;5;10m+    733[0m:[38;5;10m[49m         "sdoh_findings_count": len(normalized),
[0m[49m[38;5;10m+    734[0m:[38;5;10m[49m         "findings": [
