[0m[49m[38;5;9m- 194     [0m:[38;5;9m[49m     // If the selected time is within the next 5 minutes, just send now.
[0m[49m[38;5;9m- 195     [0m:[38;5;9m[49m     // No point creating a schedule for something that fires immediately.
[0m[49m[38;5;9m- 196     [0m:[38;5;9m[49m     IF selected_slot <= (now + 5 minutes):
[0m[49m[38;5;10m+      193[0m:[38;5;10m[49m FUNCTION schedule_delivery(message, selected_slot, sqs_receipt_handle):
[0m[49m[38;5;10m+      194[0m:[38;5;10m[49m     // IMPORTANT: Validate the selected slot is in the future with margin.
[0m[49m[38;5;10m+      195[0m:[38;5;10m[49m     // EventBridge Scheduler silently ignores schedules set in the past.
[0m[49m[38;5;10m+      196[0m:[38;5;10m[49m     // A 2-minute buffer accounts for processing latency and clock skew.
[0m[49m[38;5;10m+      197[0m:[38;5;10m[49m     IF selected_slot <= (now + 2 minutes):
[0m[49m[38;5;10m+      198[0m:[38;5;10m[49m         // The slot is too close or already past. Send immediately
[0m[49m[38;5;10m+      199[0m:[38;5;10m[49m         // rather than risk a silent schedule drop.
