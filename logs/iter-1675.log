[0m[49m[38;5;10m+       1308[0m:[38;5;10m[49m # Direct identifier field names to strip from structured data
[0m[49m[38;5;10m+       1309[0m:[38;5;10m[49m _PHI_DIRECT_IDENTIFIER_KEYS = frozenset([
[0m[49m[38;5;10m+       1310[0m:[38;5;10m[49m     "mrn", "medical_record_number", "date_of_birth", "dob",
[0m[49m[38;5;10m+       1311[0m:[38;5;10m[49m     "patient_name", "name", "address", "street", "city", "state",
[0m[49m[38;5;10m+       1312[0m:[38;5;10m[49m     "zip", "postal_code", "phone", "telephone", "email",
