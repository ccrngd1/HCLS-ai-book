[0m[49m[38;5;10m+       1314[0m:[38;5;10m[49m     "npi", "provider_npi", "ssn", "social_security_number",
[0m[49m[38;5;10m+       1315[0m:[38;5;10m[49m ])
[0m[49m[38;5;10m+       1316[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+       1317[0m:[38;5;10m[49m import copy
[0m[49m[38;5;10m+       1318[0m:[38;5;10m[49m import re
[0m[49m[38;5;10m+       1319[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+       1320[0m:[38;5;10m[49m # Regex pattern that matches common PHI patterns in free text.
[0m[49m[38;5;10m+       1321[0m:[38;5;10m[49m # This is a simplified illustrative pattern; production systems use
[0m[49m[38;5;10m+       1322[0m:[38;5;10m[49m # a dedicated de-identification library (e.g., Philter, scrubadub,
[0m[49m[38;5;10m+       1323[0m:[38;5;10m[49m # or a Comprehend Medical PII detection pass).
[0m[49m[38;5;10m+       1324[0m:[38;5;10m[49m _PHI_PATTERN = re.compile(
[0m[49m[38;5;10m+       1325[0m:[38;5;10m[49m     r"\b(?:\d{3}-\d{2}-\d{4})"       # SSN
[0m[49m[38;5;10m+       1326[0m:[38;5;10m[49m     r"|(?:\d{10})"                     # phone (10 digits)
[0m[49m[38;5;10m+       1327[0m:[38;5;10m[49m     r"|(?:\d{3}[-.]\d{3}[-.]\d{4})"   # phone formatted
[0m[49m[38;5;10m+       1328[0m:[38;5;10m[49m     r"|(?:[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,})"  # email
[0m[49m[38;5;10m+       1329[0m:[38;5;10m[49m     r"|(?:MRN[:\s]*\w+)"              # MRN label
[0m[49m[38;5;10m+       1330[0m:[38;5;10m[49m     , re.IGNORECASE
[0m[49m[38;5;10m+       1331[0m:[38;5;10m[49m )
[0m[49m[38;5;10m+       1332[0m:[38;5;10m[49m 
