[0m[48;2;40;67;43m[39m+    445[0m:[39m[48;2;24;38;30m [38;2;143;161;179m##[38;2;192;197;206m [38;2;143;161;179mRelated Recipes[K
[0m[48;2;40;67;43m[39m+    446[0m:[39m[48;2;24;38;30m [K
[0m[48;2;40;67;43m[39m+    447[0m:[39m[48;2;24;38;30m [38;2;191;97;106m-[38;2;191;97;106m [38;2;235;203;139m**[38;2;235;203;139mRecipe 2.1 (Patient Message Response Drafting):[38;2;235;203;139m**[38;2;191;97;106m Shares the Bedrock inference pattern but for a different text generation use case[K
[0m[48;2;40;67;43m[39m+    448[0m:[39m[48;2;24;38;30m [38;2;191;97;106m-[38;2;191;97;106m [38;2;235;203;139m**[38;2;235;203;139mRecipe 2.4 (Prior Authorization Letter Generation):[38;2;235;203;139m**[38;2;191;97;106m Uses similar clinical element extraction but generates outbound letters rather than internal queries[K
[0m[48;2;40;67;43m[39m+    449[0m:[39m[48;2;24;38;30m [38;2;191;97;106m-[38;2;191;97;106m [38;2;235;203;139m**[38;2;235;203;139mRecipe 2.6 (Clinical Note Summarization):[38;2;235;203;139m**[38;2;191;97;106m Complementary capability; summarization helps CDI specialists review notes faster[K
[0m[48;2;40;67;43m[39m+    450[0m:[39m[48;2;24;38;30m [38;2;191;97;106m-[38;2;191;97;106m [38;2;235;203;139m**[38;2;235;203;139mRecipe 7.3 (DRG Prediction):[38;2;235;203;139m**[38;2;191;97;106m TODO: verify recipe number. Predicts DRG assignment, which CDI suggestions aim to improve through better documentation[K
