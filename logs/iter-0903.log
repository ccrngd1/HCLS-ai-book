[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m     {
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m       "finding": "midline_shift",
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m       "confidence": 0.87,
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m       "shift_mm": 6.2,
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m       "direction": "right_to_left"
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m   ],
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m   "assigned_priority": "STAT",
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m   "triggering_findings": ["intracranial_hemorrhage", "midline_shift"],
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m   "timestamp": "2026-03-15T14:22:08.341Z",
