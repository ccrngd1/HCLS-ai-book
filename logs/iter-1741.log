[0m[49m[38;5;10m+      252[0m:[38;5;10m[49m def _chunk_text(text: str, max_chars: int = 20000) -> list[tuple[int, str]]:
[0m[49m[38;5;10m+      253[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+      254[0m:[38;5;10m[49m     Split text into chunks that respect the Comprehend Medical character limit.
[0m[49m[38;5;10m+      255[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      256[0m:[38;5;10m[49m     Chunks at sentence boundaries (period followed by space or newline) to avoid
[0m[49m[38;5;10m+      257[0m:[38;5;10m[49m     splitting mid-sentence, which would break negation scope. Returns a list of
[0m[49m[38;5;10m+      258[0m:[38;5;10m[49m     (offset, chunk_text) tuples so callers can correct entity offsets.
[0m[49m[38;5;10m+      259[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+      260[0m:[38;5;10m[49m     if len(text) <= max_chars:
[0m[49m[38;5;10m+      261[0m:[38;5;10m[49m         return [(0, text)]
[0m[49m[38;5;10m+      262[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      263[0m:[38;5;10m[49m     chunks = []
[0m[49m[38;5;10m+      264[0m:[38;5;10m[49m     start = 0
[0m[49m[38;5;10m+      265[0m:[38;5;10m[49m     while start < len(text):
[0m[49m[38;5;10m+      266[0m:[38;5;10m[49m         end = start + max_chars
[0m[49m[38;5;10m+      267[0m:[38;5;10m[49m         if end >= len(text):
[0m[49m[38;5;10m+      268[0m:[38;5;10m[49m             chunks.append((start, text[start:]))
[0m[49m[38;5;10m+      269[0m:[38;5;10m[49m             break
[0m[49m[38;5;10m+      270[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      271[0m:[38;5;10m[49m         # Find the last sentence boundary before the limit.
[0m[49m[38;5;10m+      272[0m:[38;5;10m[49m         # Look for ". " or ".\n" working backwards from the cut point.
[0m[49m[38;5;10m+      273[0m:[38;5;10m[49m         boundary = text.rfind(". ", start, end)
[0m[49m[38;5;10m+      274[0m:[38;5;10m[49m         if boundary == -1:
[0m[49m[38;5;10m+      275[0m:[38;5;10m[49m             boundary = text.rfind(".\n", start, end)
[0m[49m[38;5;10m+      276[0m:[38;5;10m[49m         if boundary == -1 or boundary <= start:
[0m[49m[38;5;10m+      277[0m:[38;5;10m[49m             # No sentence boundary found; fall back to cutting at max_chars.
[0m[49m[38;5;10m+      278[0m:[38;5;10m[49m             boundary = end
[0m[49m[38;5;10m+      279[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+      280[0m:[38;5;10m[49m             boundary += 2  # include the period and space
[0m[49m[38;5;10m+      281[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      282[0m:[38;5;10m[49m         chunks.append((start, text[start:boundary]))
[0m[49m[38;5;10m+      283[0m:[38;5;10m[49m         start = boundary
[0m[49m[38;5;10m+      284[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      285[0m:[38;5;10m[49m     return chunks
