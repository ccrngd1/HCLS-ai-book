[0m[48;2;40;67;43m[39m+    928[0m:[39m[48;2;24;38;30m [38;2;191;97;106m-[38;2;191;97;106m [38;2;208;135;112m[[38;2;208;135;112mAmazon HealthLake Developer Guide[38;2;208;135;112m][38;2;208;135;112m([38;2;208;135;112mhttps://docs.aws.amazon.com/healthlake/latest/devguide/what-is-amazon-health-lake.html[38;2;208;135;112m)[K
[0m[48;2;40;67;43m[39m+    929[0m:[39m[48;2;24;38;30m [38;2;191;97;106m-[38;2;191;97;106m [38;2;208;135;112m[[38;2;208;135;112mAmazon Comprehend Medical Developer Guide[38;2;208;135;112m][38;2;208;135;112m([38;2;208;135;112mhttps://docs.aws.amazon.com/comprehend-medical/latest/dev/comprehendmedical-welcome.html[38;2;208;135;112m)[K
