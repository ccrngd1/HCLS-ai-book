[0m[48;2;40;67;43m[39m+    821[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Must-include checklist pass rate (after backfill) [38;2;192;197;206m|[38;2;192;197;206m 95%+ for inpatient handoff; 90%+ for discharge summaries [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    822[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Clinician override/edit rate when review is enabled [38;2;192;197;206m|[38;2;192;197;206m 10-25% minor edits; 3-8% substantive edits [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    823[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Cost per summary [38;2;192;197;206m|[38;2;192;197;206m $0.05-$0.25 inpatient; $0.30-$1.00 longitudinal [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    824[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Grounding-check rejection rate (Guardrails) [38;2;192;197;206m|[38;2;192;197;206m 2-8% initial; drops to under 2% after prompt iteration [38;2;192;197;206m|[K
