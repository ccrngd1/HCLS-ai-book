[0m[48;2;40;67;43m[39m+    1240[0m:[39m[48;2;24;38;30m [38;2;192;197;206m            "unverified_claims_count": len(result.get("unverified_claims", [])),[K
[0m[48;2;40;67;43m[39m+    1241[0m:[39m[48;2;24;38;30m [38;2;192;197;206m            "draft_key": result.get("draft_key"),[K
[0m[48;2;40;67;43m[39m+    1242[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        },[K
