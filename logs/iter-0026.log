[0m[48;2;40;67;43m[39m+    1237[0m:[39m[48;2;24;38;30m [38;2;192;197;206m            "status": result["status"],[K
[0m[48;2;40;67;43m[39m+    1238[0m:[39m[48;2;24;38;30m [38;2;192;197;206m            "validation_rate": result.get("validation_rate"),[K
