[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m     "allocated_blocks": 148,
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m     "open_time_blocks": 12,
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m     "projected_utilization": 0.82,
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m     "current_utilization": 0.68,
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m     "utilization_improvement": "+14 percentage points",
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m     "estimated_annual_revenue_impact": "$4.2M"
