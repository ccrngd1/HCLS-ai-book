[0m[49m[38;5;9m- 278     [0m:[38;5;9m[49m         logger.warning("Unmapped payer types found: %s. Defaulting to 2.", unmapped)
[0m[49m[38;5;9m- 279     [0m:[38;5;9m[49m         df["payer_ordinal"] = df["payer_ordinal"].fillna(2)
