[0m[49m[38;5;10m+      248[0m:[38;5;10m[49m     # why data is missing. Here, median imputation is a safe default
[0m[49m[38;5;10m+      249[0m:[38;5;10m[49m     # that places unknown patients in the middle of the distribution.
[0m[49m[38;5;10m+      250[0m:[38;5;10m[49m     feature_df = feature_df.fillna(feature_df.median())
