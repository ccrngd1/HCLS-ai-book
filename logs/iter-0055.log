[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m     for record in record_list
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m     if record.get("patient_id") ==
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m         longitudinal["patient_id"]
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m     and record.get("status") == "delivered"
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m     and record.get("delivered_at", "").startswith(today))
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m And from "Step 4," `_recent_conversation_for_context`:
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m metadata_table = dynamodb.Table(CONVERSATION_METADATA_TABLE)
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m out = []
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m for record_list in metadata_table.items.values():
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m     for record in record_list:
