[0m[49m[39m  507, 528[0m:[39m[49m         "scenarios_opposing": ["base_case", "high_growth"]
[0m[49m[39m  508, 529[0m:[39m[49m       }
[0m[49m[39m  509, 530[0m:[39m[49m     ]
[0m[49m[39m  510, 531[0m:[39m[49m   },
[0m[49m[39m  511, 532[0m:[39m[49m   "access_impact": {
