[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m     # --- END SIMULATION ---
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m         "pixel_array": pixel_array,
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m         "modality": modality,
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m         "study_uid": study_uid,
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m         "series_uid": series_uid,
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m         "body_part": body_part,
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m         "source_key": key,
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m ## Step 2: Compute Rule-Based Quality Metrics
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m *The pseudocode calls this `compute_basic_metrics(pixel_array)`. These are fast, deterministic checks that catch obvious failures before you spend compute on ML inference. The Laplacian variance for blur, histogram statistics for exposure, and noise estimation are the workhorses here.*
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m def compute_laplacian_variance(pixel_array: np.ndarray) -> float:
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m     Compute the variance of the Laplacian as a sharpness/blur metric.
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m     The Laplacian operator computes the second spatial derivative of the image.
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m     Sharp images have lots of edges, which produce high values in the Laplacian.
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m     Blurry images are smooth, so the Laplacian output is mostly near zero.
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m     The variance of the Laplacian output is a single number that summarizes
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m     how much edge content exists in the image.
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m     High variance = sharp image (good).
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m     Low variance = blurry image (bad, likely motion artifact).
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m     This is the classic Pech-Pacheco et al. blur detection method.
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m     Simple, fast, and surprisingly effective for catching motion blur.
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m     # The Laplacian kernel (3x3 approximation of the second derivative).
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m     # This responds to intensity changes in all directions.
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m     # We apply it via convolution (here, a simple numpy implementation).
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m     #
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m     # In production, use cv2.Laplacian(image, cv2.CV_64F) for speed.
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m     # This manual implementation shows what's actually happening.
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m     kernel = np.array([[0, 1, 0],
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m                        [1, -4, 1],
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m                        [0, 1, 0]], dtype=np.float64)
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m     # Pad the image to handle borders (replicate edge pixels).
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m     padded = np.pad(pixel_array, pad_width=1, mode="edge")
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m     # Apply the Laplacian kernel via convolution.
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m     # For each pixel, multiply the 3x3 neighborhood by the kernel and sum.
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m     laplacian = np.zeros_like(pixel_array)
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m     for i in range(pixel_array.shape[0]):
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m         for j in range(pixel_array.shape[1]):
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m             region = padded[i:i+3, j:j+3]
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m             laplacian[i, j] = np.sum(region * kernel)
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m     # The variance of the Laplacian output is our blur metric.
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m     return float(np.var(laplacian))
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m def compute_basic_metrics(pixel_array: np.ndarray) -> dict:
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m     Compute rule-based quality metrics from the raw pixel data.
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m     These metrics catch the obvious failures fast (milliseconds) without
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m     needing ML inference. They also serve as input features to the ML model,
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m     giving it both raw pixels and computed statistics.
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     Returns a dictionary of metric names to values. Each metric has a clear
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m     physical interpretation tied to image quality.
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m     metrics = {}
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m     # --- Blur Detection (Laplacian Variance) ---
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m     metrics["blur_score"] = compute_laplacian_variance(pixel_array)
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m     # --- Exposure / Brightness Analysis ---
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m     # A well-exposed medical image uses the available dynamic range appropriately.
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m     # Underexposed: pixel values cluster at the low end (dark, no detail in soft tissue).
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m     # Overexposed: pixel values cluster at the high end (washed out, no bone detail).
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m     metrics["mean_intensity"] = float(np.mean(pixel_array))
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m     metrics["std_intensity"] = float(np.std(pixel_array))
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m     metrics["percentile_5"] = float(np.percentile(pixel_array, 5))
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m     metrics["percentile_95"] = float(np.percentile(pixel_array, 95))
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m     metrics["dynamic_range"] = metrics["percentile_95"] - metrics["percentile_5"]
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m     # --- Noise Estimation ---
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m     # Estimate noise using the median absolute deviation (MAD) of pixel differences.
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m     # In a homogeneous region, adjacent pixels should have similar values.
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m     # High variation between neighbors suggests noise.
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m     # This is a simplified estimator; production would use wavelet-based methods.
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m     horizontal_diff = np.diff(pixel_array, axis=1)
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m     noise_estimate = float(np.median(np.abs(horizontal_diff)) * 1.4826)
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m     # The 1.4826 factor converts MAD to an estimate of standard deviation
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m     # (assuming Gaussian noise). It's a robust noise estimator that isn't
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m     # fooled by edges the way simple std() would be.
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m     metrics["noise_level"] = noise_estimate
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m     # --- Sanity Checks ---
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m     # These catch hardware failures: detector malfunction (blank image),
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m     # stuck exposure (saturated image).
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     metrics["is_blank"] = metrics["dynamic_range"] < 10
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m     metrics["is_saturated"] = metrics["percentile_95"] >= 4000  # near 12-bit max
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m     return metrics
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m ## Step 3: Invoke the ML Quality Model
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m *The pseudocode calls this `assess_quality_ml(pixel_array, basic_metrics, modality)`. The ML model handles nuanced quality issues that rule-based metrics miss: subtle motion blur, positioning errors, complex artifact patterns. It takes the preprocessed image and computed metrics as input and returns quality scores.*
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m def assess_quality_ml(pixel_array: np.ndarray, basic_metrics: dict, modality: str) -> dict:
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m     Invoke the SageMaker-hosted quality assessment model.
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m     The model is a CNN trained on historical PACS rejection data from your
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m     institution. It learned what your radiologists consider "acceptable" vs.
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m     "reject" quality. The input is a resized, normalized image plus the
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m     computed metrics as auxiliary features.
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m     In production, the model architecture would be something like:
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m     - ResNet-18 or EfficientNet-B0 for the image branch (small, fast)
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m     - A small MLP for the tabular metrics branch
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m     - Concatenated features fed to a classification head
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m     Returns overall quality score (0-1) and per-category breakdowns.
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m     # Preprocess: resize to model's expected input size and normalize to [0, 1].
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m     # Most quality models use 512x512 or 256x256 input. Larger isn't necessarily
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m     # better here because quality assessment doesn't need fine anatomical detail.
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m     target_size = (512, 512)
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m     # Simple resize via nearest-neighbor interpolation.
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m     # In production, use cv2.resize with INTER_AREA for downsampling.
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m     if pixel_array.shape != target_size:
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m         # Crude resize for demonstration. Production uses proper interpolation.
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m         row_indices = np.linspace(0, pixel_array.shape[0] - 1, target_size[0]).astype(int)
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m         col_indices = np.linspace(0, pixel_array.shape[1] - 1, target_size[1]).astype(int)
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m         resized = pixel_array[np.ix_(row_indices, col_indices)]
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m         resized = pixel_array
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m     # Normalize to [0, 1] range.
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m     img_min = resized.min()
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m     img_max = resized.max()
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m     if img_max > img_min:
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m         normalized = (resized - img_min) / (img_max - img_min)
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m         normalized = np.zeros_like(resized)
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m     # Build the payload for the SageMaker endpoint.
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m     # The model expects a JSON payload with the image as a flattened array
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m     # and the metrics as a separate field.
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m     payload = {
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m         "image": normalized.flatten().tolist(),
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m         "image_shape": list(target_size),
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m         "metrics": basic_metrics,
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m         "modality": modality,
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m     # Invoke the SageMaker real-time endpoint.
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m     # The endpoint runs the trained model and returns quality scores.
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m     response = sagemaker_runtime.invoke_endpoint(
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m         EndpointName=SAGEMAKER_ENDPOINT_NAME,
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m         ContentType="application/json",
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m         Body=json.dumps(payload),
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m     # Parse the model's response.
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m     result = json.loads(response["Body"].read().decode("utf-8"))
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m     # Expected response structure from the model:
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m     # {
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m     #   "overall_quality": 0.72,
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m     #   "sharpness_score": 0.45,
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m     #   "exposure_score": 0.91,
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m     #   "positioning_score": 0.83,
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m     #   "artifact_score": 0.88
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m     # }
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m         "overall_score": result["overall_quality"],
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m         "category_scores": {
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m             "sharpness": result["sharpness_score"],
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m             "exposure": result["exposure_score"],
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m             "positioning": result["positioning_score"],
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m             "artifacts": result["artifact_score"],
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m ## Step 4: Apply Decision Thresholds
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m *The pseudocode calls this `apply_decision(quality_result, modality, body_part)`. This translates continuous quality scores into discrete clinical actions: accept, review, or reject. The thresholds are configurable per modality and body part because "acceptable" means different things for different exam types.*
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m def apply_decision(quality_result: dict, modality: str, body_part: str) -> dict:
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m     Apply configurable thresholds to convert quality scores into actions.
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m     Three-tier decision:
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m     - ACCEPT: image passes, route to PACS normally.
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m     - REVIEW: borderline, flag for technologist review while patient is still there.
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m     - REJECT: clear failure, alert technologist for immediate retake.
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m     The thresholds are stored in QUALITY_THRESHOLDS (top of this file) and
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m     looked up by modality + body_part. This separation of model output from
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m     decision logic means you can tune sensitivity without retraining the model.
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m     # Look up thresholds for this modality/body_part combination.
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m     threshold_key = f"{modality}_{body_part}"
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m     thresholds = QUALITY_THRESHOLDS.get(threshold_key, QUALITY_THRESHOLDS["DEFAULT"])
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m     overall = quality_result["overall_score"]
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m     category_scores = quality_result["category_scores"]
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m     # Apply the three-tier decision logic.
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m     if overall >= thresholds["accept"]:
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m         decision = "ACCEPT"
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m         action = "Route to PACS normally"
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m     elif overall >= thresholds["review"]:
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m         decision = "REVIEW"
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m         action = "Flag for technologist review before patient leaves"
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m         decision = "REJECT"
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m         # Find the worst-scoring category to give actionable feedback.
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m         # "Retake recommended" is useless without telling the tech WHY.
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m         worst_category = min(category_scores, key=category_scores.get)
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m         action = f"Alert technologist: retake recommended (primary issue: {worst_category})"
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m         "decision": decision,
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m         "action": action,
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m         "overall_score": overall,
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m         "category_scores": category_scores,
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m         "thresholds_used": thresholds,
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m ## Step 5: Store Results and Alert
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m *The pseudocode calls this `store_and_alert(image_info, decision_result)`. It writes the assessment record to DynamoDB for audit and analytics, and fires an SNS alert if the image failed or needs review. Every assessment is stored regardless of outcome because you need the full history for model retraining and compliance audits.*
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m def store_and_alert(image_info: dict, decision_result: dict) -> str:
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m     Persist the quality assessment and notify on failures.
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m     The DynamoDB record is the audit trail: what was assessed, when, what
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m     was decided, and why. HIPAA requires you to be able to trace any
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m     clinical decision back to its inputs. This record provides that linkage.
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m     SNS alerts go to the technologist's console or department dashboard.
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m     The alert includes enough context for the tech to act without looking
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m     up the full record.
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m     table = dynamodb.Table(DYNAMODB_TABLE)
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m     # Build the assessment record.
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m     # DynamoDB requires Decimal for numeric values, not float.
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m     # This is a known boto3 gotcha that will raise TypeError if you forget.
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m     record = {
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m         "study_uid": image_info["study_uid"],
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m         "series_uid": image_info["series_uid"],
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m         "source_key": image_info["source_key"],
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m         "modality": image_info["modality"],
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m         "body_part": image_info["body_part"],
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m         "assessment_time": datetime.datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m         "decision": decision_result["decision"],
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m         "overall_score": Decimal(str(round(decision_result["overall_score"], 4))),
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m         "category_scores": {
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m             k: Decimal(str(round(v, 4)))
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m             for k, v in decision_result["category_scores"].items()
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m         "action": decision_result["action"],
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m     table.put_item(Item=record)
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m     # Alert on failures. ACCEPT images flow silently to PACS.
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m     # REVIEW and REJECT images need human attention while the patient is still there.
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m     if decision_result["decision"] in ("REJECT", "REVIEW"):
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m         alert_message = {
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m             "study_uid": image_info["study_uid"],
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m             "modality": image_info["modality"],
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m             "body_part": image_info["body_part"],
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m             "decision": decision_result["decision"],
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m             "action": decision_result["action"],
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m             "score": decision_result["overall_score"],
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m         sns_client.publish(
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m             TopicArn=SNS_TOPIC_ARN,
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m             Subject=f"Image Quality {decision_result['decision']}: {image_info['modality']} {image_info['body_part']}",
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m             Message=json.dumps(alert_message, indent=2),
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m     return decision_result["decision"]
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m ## Putting It All Together
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m Here's the full pipeline assembled into a single function. This is what your Lambda handler would call when an S3 event fires for a new DICOM image.
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m def assess_image_quality(bucket: str, key: str) -> dict:
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m     Run the full image quality assessment pipeline for one DICOM image.
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m     Pipeline flow:
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m     1. Download and parse the DICOM image from S3
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m     2. Compute rule-based metrics (blur, exposure, noise) for fast rejection
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m     3. If basic checks pass, invoke the ML model for nuanced assessment
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m     4. Apply decision thresholds to get ACCEPT/REVIEW/REJECT
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m     5. Store the result and alert on failures
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m         bucket: S3 bucket containing the DICOM file
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m         key:    S3 object key (path to the .dcm file)
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m         The complete assessment result including decision and scores.
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m     # Step 1: Get the image and metadata.
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m     logger.info("Step 1: Receiving image from s3://%s/%s", bucket, key)
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m     image_info = receive_image(bucket, key)
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m     logger.info("  Modality: %s, Body part: %s", image_info["modality"], image_info["body_part"])
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m     # Step 2: Compute rule-based metrics.
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m     logger.info("Step 2: Computing basic quality metrics")
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m     basic_metrics = compute_basic_metrics(image_info["pixel_array"])
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m     logger.info("  Blur score: %.1f, Dynamic range: %.1f, Noise: %.2f",
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m                 basic_metrics["blur_score"], basic_metrics["dynamic_range"],
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m                 basic_metrics["noise_level"])
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m     # Fast reject: if the image is blank, saturated, or severely blurred,
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m     # skip the ML model entirely. No point spending inference compute on
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m     # an image that's obviously unusable.
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m     if basic_metrics["is_blank"] or basic_metrics["is_saturated"]:
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m         logger.info("  FAST REJECT: image is blank or saturated")
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m         quality_result = {
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m             "overall_score": 0.0,
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m             "category_scores": {
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m                 "sharpness": 0.0 if basic_metrics["blur_score"] < BLUR_THRESHOLD else 0.5,
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m                 "exposure": 0.0,
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m                 "positioning": 0.5,  # can't assess positioning on a blank image
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m                 "artifacts": 0.5,
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m             },
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m     elif basic_metrics["blur_score"] < BLUR_THRESHOLD:
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m         logger.info("  FAST REJECT: severe blur detected (score %.1f < threshold %.1f)",
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m                     basic_metrics["blur_score"], BLUR_THRESHOLD)
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m         quality_result = {
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m             "overall_score": 0.2,
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m             "category_scores": {
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m                 "sharpness": 0.1,
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m                 "exposure": 0.8 if basic_metrics["dynamic_range"] > DYNAMIC_RANGE_MINIMUM else 0.3,
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m                 "positioning": 0.5,
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m                 "artifacts": 0.7,
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m             },
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m         # Step 3: Image passes basic checks. Invoke the ML model for nuanced assessment.
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m         logger.info("Step 3: Invoking ML quality model")
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m         quality_result = assess_quality_ml(
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m             image_info["pixel_array"],
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m             basic_metrics,
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m             image_info["modality"],
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m         logger.info("  ML overall score: %.3f", quality_result["overall_score"])
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m     # Step 4: Apply decision thresholds.
