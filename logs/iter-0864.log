[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m     logger.info("  Decision: %s (score: %.3f)", decision_result["decision"], decision_result["overall_score"])
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m     # Step 5: Store and alert.
