[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m import numpy as np
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m # Structured logging. In production, use JSON-formatted output for
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m # CloudWatch Logs Insights queries. Never log pixel data or patient identifiers.
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m # Adaptive retry handles burst throttling from SageMaker and other services.
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m s3_client = boto3.client("s3", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m sagemaker_runtime = boto3.client("sagemaker-runtime", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m sns_client = boto3.client("sns", config=BOTO3_RETRY_CONFIG)
