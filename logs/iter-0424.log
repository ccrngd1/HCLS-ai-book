404:A few utilities used across steps. Keeping them together so each step's code stays focused on the pattern it teaches.
407:def _to_decimal(obj):
409:    Recursively convert floats to Decimal for DynamoDB.
410:    DynamoDB rejects Python float values; every numeric field
411:    has to pass through Decimal on the way in.
413:    if isinstance(obj, float):
414:        return Decimal(str(obj))
415:    if isinstance(obj, dict):
416:        return {k: _to_decimal(v) for k, v in obj.items()}
417:    if isinstance(obj, list):
418:        return [_to_decimal(v) for v in obj]
422:def _from_decimal(obj):
423:    """Inverse of _to_decimal for JSON serialization."""
424:    if isinstance(obj, Decimal):
425:        if obj % 1 == 0:
426:            return int(obj)
428:    if isinstance(obj, dict):
429:        return {k: _from_decimal(v) for k, v in obj.items()}
430:    if isinstance(obj, list):
431:        return [_from_decimal(v) for v in obj]
