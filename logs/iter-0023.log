[0m[49m[38;5;10m+    2790[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2791[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    2792[0m:[38;5;10m[49m         "action":         "deliver",
[0m[49m[38;5;10m+    2793[0m:[38;5;10m[49m         "response_text":  response_text,
[0m[49m[38;5;10m+    2794[0m:[38;5;10m[49m         "violations":     [],
[0m[49m[38;5;10m+    2795[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    2796[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2797[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2798[0m:[38;5;10m[49m def _check_response_scope(response_text: str) -> list:
[0m[49m[38;5;10m+    2799[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2800[0m:[38;5;10m[49m     Backstop keyword scope check on generated output. Catches
[0m[49m[38;5;10m+    2801[0m:[38;5;10m[49m     obvious drift into clinical, financial-advice, or
[0m[49m[38;5;10m+    2802[0m:[38;5;10m[49m     impersonation territory.
[0m[49m[38;5;10m+    2803[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2804[0m:[38;5;10m[49m     lowered = response_text.lower()
[0m[49m[38;5;10m+    2805[0m:[38;5;10m[49m     violations = []
[0m[49m[38;5;10m+    2806[0m:[38;5;10m[49m     clinical_phrases = [
[0m[49m[38;5;10m+    2807[0m:[38;5;10m[49m         "you should take", "you should not take",
[0m[49m[38;5;10m+    2808[0m:[38;5;10m[49m         "i recommend you", "your symptoms suggest",
[0m[49m[38;5;10m+    2809[0m:[38;5;10m[49m         "you probably have",
[0m[49m[38;5;10m+    2810[0m:[38;5;10m[49m         "you don't need to come in",
[0m[49m[38;5;10m+    2811[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    2812[0m:[38;5;10m[49m     for phrase in clinical_phrases:
[0m[49m[38;5;10m+    2813[0m:[38;5;10m[49m         if phrase in lowered:
[0m[49m[38;5;10m+    2814[0m:[38;5;10m[49m             violations.append("clinical_question")
[0m[49m[38;5;10m+    2815[0m:[38;5;10m[49m             break
