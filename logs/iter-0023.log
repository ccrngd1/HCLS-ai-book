[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m # --- Prompt-Injection Patterns ---
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m INJECTION_PATTERNS = [
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m     r"ignore (all |any |the )?(previous|prior|above) (instructions|messages|prompts)",
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m     r"disregard (all |any |the )?(previous|prior|above) (instructions|messages|prompts)",
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m     r"you are now (a |an )?",
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m     r"forget (all |any |everything )?(you|your)",
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m     r"system (prompt|message|instruction)",
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m     r"reveal (your|the) (prompt|instructions|system)",
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m     r"act as (a |an )?",
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m     r"pretend (to be|you are)",
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m     r"new instructions:",
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m # --- PHI Detection Patterns ---
