[0m[49m[38;5;10m+    2817[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2818[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2819[0m:[38;5;10m[49m def _extract_booking_claims(response_text: str) -> list:
[0m[49m[38;5;10m+    2820[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2821[0m:[38;5;10m[49m     Extract any "appointment confirmed" claims from the response
[0m[49m[38;5;10m+    2822[0m:[38;5;10m[49m     text along with their referenced confirmation IDs. Anything
[0m[49m[38;5;10m+    2823[0m:[38;5;10m[49m     matching is a claim we need to back up with a successful
[0m[49m[38;5;10m+    2824[0m:[38;5;10m[49m     booking-tool result.
[0m[49m[38;5;10m+    2825[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2826[0m:[38;5;10m[49m     claims = []
[0m[49m[38;5;10m+    2827[0m:[38;5;10m[49m     # Match "confirmation is RC-2026-1234567" or similar.
[0m[49m[38;5;10m+    2828[0m:[38;5;10m[49m     for match in re.finditer(
[0m[49m[38;5;10m+    2829[0m:[38;5;10m[49m             r"confirmation\s+(?:is|number|id|#)?\s*"
[0m[49m[38;5;10m+    2830[0m:[38;5;10m[49m             r"([A-Z]{2}-\d{4}-\d{3,})",
[0m[49m[38;5;10m+    2831[0m:[38;5;10m[49m             response_text,
[0m[49m[38;5;10m+    2832[0m:[38;5;10m[49m             flags=re.IGNORECASE):
[0m[49m[38;5;10m+    2833[0m:[38;5;10m[49m         claims.append({
[0m[49m[38;5;10m+    2834[0m:[38;5;10m[49m             "type":            "confirmation_id_claim",
[0m[49m[38;5;10m+    2835[0m:[38;5;10m[49m             "confirmation_id": match.group(1),
[0m[49m[38;5;10m+    2836[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    2837[0m:[38;5;10m[49m     if claims:
[0m[49m[38;5;10m+    2838[0m:[38;5;10m[49m         return claims
[0m[49m[38;5;10m+    2839[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2840[0m:[38;5;10m[49m     # Less specific: "booked" or "your appointment is confirmed"
[0m[49m[38;5;10m+    2841[0m:[38;5;10m[49m     # without a confirmation ID. We still need a backing tool
[0m[49m[38;5;10m+    2842[0m:[38;5;10m[49m     # result.
