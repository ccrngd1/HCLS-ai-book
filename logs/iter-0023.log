[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m     "mrn_prefix":   re.compile(r"\bMRN\s*[:#]?\s*\d{4,}\b",
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m                                 re.IGNORECASE),
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m }
