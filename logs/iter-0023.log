[0m[49m[38;5;10m+    2844[0m:[38;5;10m[49m             r"\b(booked|appointment is confirmed|"
[0m[49m[38;5;10m+    2845[0m:[38;5;10m[49m             r"all set for|you're booked)\b",
[0m[49m[38;5;10m+    2846[0m:[38;5;10m[49m             response_text,
[0m[49m[38;5;10m+    2847[0m:[38;5;10m[49m             flags=re.IGNORECASE):
[0m[49m[38;5;10m+    2848[0m:[38;5;10m[49m         claims.append({"type": "general_booking_claim"})
[0m[49m[38;5;10m+    2849[0m:[38;5;10m[49m     return claims
[0m[49m[38;5;10m+    2850[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2851[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2852[0m:[38;5;10m[49m def _tool_call_ledger_for_session(session_id: str) -> list:
[0m[49m[38;5;10m+    2853[0m:[38;5;10m[49m     """Pull the tool-call ledger entries for the session."""
