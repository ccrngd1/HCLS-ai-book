[0m[49m[38;5;10m+    2867[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2868[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2869[0m:[38;5;10m[49m def _find_supporting_book_call(claim: dict,
