[0m[49m[38;5;10m+    3563[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    3564[0m:[38;5;10m[49m     scenarios = [
[0m[49m[38;5;10m+    3565[0m:[38;5;10m[49m         {
[0m[49m[38;5;10m+    3566[0m:[38;5;10m[49m             "name":        "happy_path_booking",
