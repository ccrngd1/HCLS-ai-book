[0m[49m[38;5;10m+    2013[0m:[38;5;10m[49m         "telehealth":      {"modality": "telehealth"},
[0m[49m[38;5;10m+    2014[0m:[38;5;10m[49m         "in person":       {"modality": "in_person"},
[0m[49m[38;5;10m+    2015[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    2016[0m:[38;5;10m[49m     for cue, refinement in refine_cues.items():
