[0m[49m[38;5;10m+    2038[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2039[0m:[38;5;10m[49m     if (lowered in ("yes", "yes please", "sure", "ok", "okay")
[0m[49m[38;5;10m+    2040[0m:[38;5;10m[49m             and len(candidates) == 1):
[0m[49m[38;5;10m+    2041[0m:[38;5;10m[49m         return {"action": "select", "choice_index": 0}
[0m[49m[38;5;10m+    2042[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2043[0m:[38;5;10m[49m     return {"action": "unknown"}
[0m[49m[38;5;10m+    2044[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2045[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2046[0m:[38;5;10m[49m def _apply_refinement(current: dict, refinement: dict) -> dict:
[0m[49m[38;5;10m+    2047[0m:[38;5;10m[49m     """Apply a refinement to the current search parameters."""
[0m[49m[38;5;10m+    2048[0m:[38;5;10m[49m     refined = dict(current)
[0m[49m[38;5;10m+    2049[0m:[38;5;10m[49m     if "time_window_modifier" in refinement:
[0m[49m[38;5;10m+    2050[0m:[38;5;10m[49m         existing = refined.get("time_window") or ""
[0m[49m[38;5;10m+    2051[0m:[38;5;10m[49m         refined["time_window"] = (
[0m[49m[38;5;10m+    2052[0m:[38;5;10m[49m             f"{existing} {refinement['time_window_modifier']}"
