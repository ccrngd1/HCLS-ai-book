[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m # highest-leverage operational investment for the bot's quality.
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m # The dict below is a starter for the demo only.
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m VISIT_TYPE_CATALOG = {
