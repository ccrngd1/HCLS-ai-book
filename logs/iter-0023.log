[0m[49m[38;5;10m+    2019[0m:[38;5;10m[49m                 "action":    "refine",
[0m[49m[38;5;10m+    2020[0m:[38;5;10m[49m                 "refinement": refinement,
[0m[49m[38;5;10m+    2021[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    2022[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2023[0m:[38;5;10m[49m     # Selection cues: "the tuesday one", "tuesday", first/second
[0m[49m[38;5;10m+    2024[0m:[38;5;10m[49m     # /third, "1"/"2"/"3", "yes" with a single candidate.
