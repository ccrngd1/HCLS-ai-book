[0m[49m[38;5;10m+    2876[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2877[0m:[38;5;10m[49m     for entry in ledger:
[0m[49m[38;5;10m+    2878[0m:[38;5;10m[49m         if entry.get("tool") != "slot_book":
[0m[49m[38;5;10m+    2879[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    2880[0m:[38;5;10m[49m         if entry.get("outcome") != "booked":
[0m[49m[38;5;10m+    2881[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    2882[0m:[38;5;10m[49m         if claim["type"] == "general_booking_claim":
[0m[49m[38;5;10m+    2883[0m:[38;5;10m[49m             return entry
[0m[49m[38;5;10m+    2884[0m:[38;5;10m[49m         if claim["type"] == "confirmation_id_claim":
[0m[49m[38;5;10m+    2885[0m:[38;5;10m[49m             ledger_id = (
[0m[49m[38;5;10m+    2886[0m:[38;5;10m[49m                 entry.get("result_summary", {})
[0m[49m[38;5;10m+    2887[0m:[38;5;10m[49m                      .get("confirmation_id"))
[0m[49m[38;5;10m+    2888[0m:[38;5;10m[49m             if ledger_id == claim["confirmation_id"]:
[0m[49m[38;5;10m+    2889[0m:[38;5;10m[49m                 return entry
[0m[49m[38;5;10m+    2890[0m:[38;5;10m[49m     return None
[0m[49m[38;5;10m+    2891[0m:[38;5;10m[49m ```
