[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m ## Shared Helpers
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m A few utilities used across steps. Keeping them together so each step's code stays focused on the pattern it teaches.
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m def _to_decimal(obj):
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m     Recursively convert floats to Decimal for DynamoDB. DynamoDB
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m     rejects Python float values; every numeric field has to pass
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m     through Decimal on the way in. This is a recurring SDK gotcha.
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m     if isinstance(obj, float):
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m         return Decimal(str(obj))
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m     if isinstance(obj, dict):
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m         return {k: _to_decimal(v) for k, v in obj.items()}
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m     if isinstance(obj, list):
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m         return [_to_decimal(v) for v in obj]
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m     return obj
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m def _from_decimal(obj):
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m     """Inverse of `_to_decimal` for JSON serialization."""
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m     if isinstance(obj, Decimal):
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m         if obj % 1 == 0:
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m             return int(obj)
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m         return float(obj)
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m     if isinstance(obj, dict):
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m         return {k: _from_decimal(v) for k, v in obj.items()}
