[0m[49m[38;5;10m+    1431[0m:[38;5;10m[49m def _required_assurance_for(intent: str, ctx: dict) -> str:
[0m[49m[38;5;10m+    1432[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1433[0m:[38;5;10m[49m     Look up the required assurance level for (intent, ctx) using
[0m[49m[38;5;10m+    1434[0m:[38;5;10m[49m     the policy table. Falls back to "basic".
[0m[49m[38;5;10m+    1435[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1436[0m:[38;5;10m[49m     rules = IDENTITY_POLICY.get(intent, [(lambda c: True, "basic")])
[0m[49m[38;5;10m+    1437[0m:[38;5;10m[49m     for predicate, level in rules:
[0m[49m[38;5;10m+    1438[0m:[38;5;10m[49m         if predicate(ctx):
[0m[49m[38;5;10m+    1439[0m:[38;5;10m[49m             return level
[0m[49m[38;5;10m+    1440[0m:[38;5;10m[49m     return "basic"
[0m[49m[38;5;10m+    1441[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1442[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1443[0m:[38;5;10m[49m def _collect_identifiers_from_message(user_message: str,
[0m[49m[38;5;10m+    1444[0m:[38;5;10m[49m                                         recent_turns: list) -> dict:
[0m[49m[38;5;10m+    1445[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1446[0m:[38;5;10m[49m     Pull name, DOB, and a confirmation factor out of the user's
[0m[49m[38;5;10m+    1447[0m:[38;5;10m[49m     recent messages. The demo uses simple regex; production uses
[0m[49m[38;5;10m+    1448[0m:[38;5;10m[49m     the LLM with the recent conversation as context to extract
[0m[49m[38;5;10m+    1449[0m:[38;5;10m[49m     identifiers conversationally.
[0m[49m[38;5;10m+    1450[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1451[0m:[38;5;10m[49m     combined = user_message + " " + " ".join(
[0m[49m[38;5;10m+    1452[0m:[38;5;10m[49m         t.get("text", "")
[0m[49m[38;5;10m+    1453[0m:[38;5;10m[49m         for t in recent_turns
[0m[49m[38;5;10m+    1454[0m:[38;5;10m[49m         if t.get("speaker") == "user")
[0m[49m[38;5;10m+    1455[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1456[0m:[38;5;10m[49m     name_match = re.search(
[0m[49m[38;5;10m+    1457[0m:[38;5;10m[49m         r"(?:my name is|i'?m|this is)\s+"
[0m[49m[38;5;10m+    1458[0m:[38;5;10m[49m         r"([A-Z][a-z]+(?:\s+[A-Z][a-z]+)+)",
[0m[49m[38;5;10m+    1459[0m:[38;5;10m[49m         combined)
[0m[49m[38;5;10m+    1460[0m:[38;5;10m[49m     name = name_match.group(1) if name_match else None
[0m[49m[38;5;10m+    1461[0m:[38;5;10m[49m     # Allow a bare "First Last" if name pattern not found.
[0m[49m[38;5;10m+    1462[0m:[38;5;10m[49m     if not name:
[0m[49m[38;5;10m+    1463[0m:[38;5;10m[49m         bare_name = re.search(
[0m[49m[38;5;10m+    1464[0m:[38;5;10m[49m             r"\b([A-Z][a-z]+\s+[A-Z][a-z]+)\b", combined)
[0m[49m[38;5;10m+    1465[0m:[38;5;10m[49m         name = bare_name.group(1) if bare_name else None
[0m[49m[38;5;10m+    1466[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1467[0m:[38;5;10m[49m     dob_match = re.search(
[0m[49m[38;5;10m+    1468[0m:[38;5;10m[49m         r"\b(\d{4}-\d{2}-\d{2}|\d{1,2}/\d{1,2}/\d{2,4})\b",
[0m[49m[38;5;10m+    1469[0m:[38;5;10m[49m         combined)
[0m[49m[38;5;10m+    1470[0m:[38;5;10m[49m     dob = dob_match.group(1) if dob_match else None
[0m[49m[38;5;10m+    1471[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1472[0m:[38;5;10m[49m     # Confirmation factor: a 4-digit number not part of a longer
[0m[49m[38;5;10m+    1473[0m:[38;5;10m[49m     # number sequence (heuristic for last-four-of-phone).
[0m[49m[38;5;10m+    1474[0m:[38;5;10m[49m     conf_match = re.search(
[0m[49m[38;5;10m+    1475[0m:[38;5;10m[49m         r"(?<!\d)(\d{4})(?!\d)", combined)
[0m[49m[38;5;10m+    1476[0m:[38;5;10m[49m     confirmation = conf_match.group(1) if conf_match else None
[0m[49m[38;5;10m+    1477[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1478[0m:[38;5;10m[49m     complete = bool(name and dob and confirmation)
[0m[49m[38;5;10m+    1479[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    1480[0m:[38;5;10m[49m         "name":                 name,
[0m[49m[38;5;10m+    1481[0m:[38;5;10m[49m         "date_of_birth":        dob,
[0m[49m[38;5;10m+    1482[0m:[38;5;10m[49m         "confirmation_factor": confirmation,
[0m[49m[38;5;10m+    1483[0m:[38;5;10m[49m         "complete":             complete,
[0m[49m[38;5;10m+    1484[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1485[0m:[38;5;10m[49m ```
