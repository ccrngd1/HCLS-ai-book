[0m[49m[38;5;10m+    2740[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    2741[0m:[38;5;10m[49m def screen_output(session_id: str, response_text: str) -> dict:
[0m[49m[38;5;10m+    2742[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2743[0m:[38;5;10m[49m     Screen a generated response before delivery. Returns a dict
[0m[49m[38;5;10m+    2744[0m:[38;5;10m[49m     with 'action' ('deliver' or 'replace_with_safe_response') and
[0m[49m[38;5;10m+    2745[0m:[38;5;10m[49m     the cleared or replacement text.
[0m[49m[38;5;10m+    2746[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2747[0m:[38;5;10m[49m     The chat handler calls this on every assistant turn before
[0m[49m[38;5;10m+    2748[0m:[38;5;10m[49m     appending it to the metadata table. The Python helper
[0m[49m[38;5;10m+    2749[0m:[38;5;10m[49m     functions above each call _append_turn directly with
[0m[49m[38;5;10m+    2750[0m:[38;5;10m[49m     pre-built strings; in production all generated assistant text
[0m[49m[38;5;10m+    2751[0m:[38;5;10m[49m     goes through this screen first.
[0m[49m[38;5;10m+    2752[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2753[0m:[38;5;10m[49m     # Step 9A: standard scope-drift check on the generated text.
[0m[49m[38;5;10m+    2754[0m:[38;5;10m[49m     # Backstop keyword check; production runs Bedrock Guardrails
[0m[49m[38;5;10m+    2755[0m:[38;5;10m[49m     # plus a follow-up classifier.
[0m[49m[38;5;10m+    2756[0m:[38;5;10m[49m     violations = _check_response_scope(response_text)
[0m[49m[38;5;10m+    2757[0m:[38;5;10m[49m     if violations:
[0m[49m[38;5;10m+    2758[0m:[38;5;10m[49m         _put_metric("OutputScopeViolation", 1, {
[0m[49m[38;5;10m+    2759[0m:[38;5;10m[49m             "first_category": violations[0],
[0m[49m[38;5;10m+    2760[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    2761[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    2762[0m:[38;5;10m[49m             "action":         "replace_with_safe_response",
[0m[49m[38;5;10m+    2763[0m:[38;5;10m[49m             "response_text":
[0m[49m[38;5;10m+    2764[0m:[38;5;10m[49m                 OUT_OF_SCOPE_HANDOFFS["out_of_scope"],
[0m[49m[38;5;10m+    2765[0m:[38;5;10m[49m             "violations":     violations,
[0m[49m[38;5;10m+    2766[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    2767[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2768[0m:[38;5;10m[49m     # Step 9B: scheduling-specific booking-claim verification.
[0m[49m[38;5;10m+    2769[0m:[38;5;10m[49m     # If the response claims a booking, that claim must be
[0m[49m[38;5;10m+    2770[0m:[38;5;10m[49m     # supported by a successful slot_book tool call in the
[0m[49m[38;5;10m+    2771[0m:[38;5;10m[49m     # session's tool-call ledger.
[0m[49m[38;5;10m+    2772[0m:[38;5;10m[49m     claims = _extract_booking_claims(response_text)
[0m[49m[38;5;10m+    2773[0m:[38;5;10m[49m     if claims:
[0m[49m[38;5;10m+    2774[0m:[38;5;10m[49m         ledger = _tool_call_ledger_for_session(session_id)
[0m[49m[38;5;10m+    2775[0m:[38;5;10m[49m         for claim in claims:
[0m[49m[38;5;10m+    2776[0m:[38;5;10m[49m             supporting = _find_supporting_book_call(
[0m[49m[38;5;10m+    2777[0m:[38;5;10m[49m                 claim=claim,
[0m[49m[38;5;10m+    2778[0m:[38;5;10m[49m                 ledger=ledger)
[0m[49m[38;5;10m+    2779[0m:[38;5;10m[49m             if not supporting:
[0m[49m[38;5;10m+    2780[0m:[38;5;10m[49m                 _put_metric(
[0m[49m[38;5;10m+    2781[0m:[38;5;10m[49m                     "UnsupportedBookingClaim", 1, {
[0m[49m[38;5;10m+    2782[0m:[38;5;10m[49m                         "session_id": session_id,
[0m[49m[38;5;10m+    2783[0m:[38;5;10m[49m                     })
[0m[49m[38;5;10m+    2784[0m:[38;5;10m[49m                 return {
[0m[49m[38;5;10m+    2785[0m:[38;5;10m[49m                     "action":         "replace_with_safe_response",
[0m[49m[38;5;10m+    2786[0m:[38;5;10m[49m                     "response_text":  BOOKING_CLAIM_FAILED_TEMPLATE,
