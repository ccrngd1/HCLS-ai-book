[0m[49m[38;5;10m+     909[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     910[0m:[38;5;10m[49m         _put_metric("CrisisDetected", 1, {
[0m[49m[38;5;10m+     911[0m:[38;5;10m[49m             "channel":  channel,
[0m[49m[38;5;10m+     912[0m:[38;5;10m[49m             "language": language,
[0m[49m[38;5;10m+     913[0m:[38;5;10m[49m         })
