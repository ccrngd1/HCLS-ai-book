[0m[49m[38;5;10m+     870[0m:[38;5;10m[49m     # Prompt-injection detection.
[0m[49m[38;5;10m+     871[0m:[38;5;10m[49m     for pattern in INJECTION_PATTERNS:
[0m[49m[38;5;10m+     872[0m:[38;5;10m[49m         if re.search(pattern, lowered):
[0m[49m[38;5;10m+     873[0m:[38;5;10m[49m             return {
[0m[49m[38;5;10m+     874[0m:[38;5;10m[49m                 "action":  "injection_refusal",
[0m[49m[38;5;10m+     875[0m:[38;5;10m[49m                 "pattern": pattern,
[0m[49m[38;5;10m+     876[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+     877[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     878[0m:[38;5;10m[49m     # PHI minimization. Before identity verification, the bot does
[0m[49m[38;5;10m+     879[0m:[38;5;10m[49m     # not need PHI; if the user volunteers something sensitive,
[0m[49m[38;5;10m+     880[0m:[38;5;10m[49m     # flag for redaction and gently redirect.
[0m[49m[38;5;10m+     881[0m:[38;5;10m[49m     matched = []
[0m[49m[38;5;10m+     882[0m:[38;5;10m[49m     for category, pattern in PHI_PATTERNS.items():
[0m[49m[38;5;10m+     883[0m:[38;5;10m[49m         if pattern.search(user_message):
[0m[49m[38;5;10m+     884[0m:[38;5;10m[49m             matched.append(category)
[0m[49m[38;5;10m+     885[0m:[38;5;10m[49m     if matched:
