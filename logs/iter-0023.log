[0m[49m[38;5;10m+    2027[0m:[38;5;10m[49m         if cue and cue.split()[0] in lowered:
[0m[49m[38;5;10m+    2028[0m:[38;5;10m[49m             return {"action": "select", "choice_index": idx}
[0m[49m[38;5;10m+    2029[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2030[0m:[38;5;10m[49m     if "first" in lowered or lowered.startswith("1"):
[0m[49m[38;5;10m+    2031[0m:[38;5;10m[49m         return {"action": "select", "choice_index": 0}
[0m[49m[38;5;10m+    2032[0m:[38;5;10m[49m     if "second" in lowered or lowered.startswith("2"):
[0m[49m[38;5;10m+    2033[0m:[38;5;10m[49m         if len(candidates) >= 2:
[0m[49m[38;5;10m+    2034[0m:[38;5;10m[49m             return {"action": "select", "choice_index": 1}
[0m[49m[38;5;10m+    2035[0m:[38;5;10m[49m     if "third" in lowered or lowered.startswith("3"):
