[0m[49m[38;5;10m+    1926[0m:[38;5;10m[49m         // values: "patient_only", "caregiver_only",
[0m[49m[38;5;10m+    1927[0m:[38;5;10m[49m         // "patient_with_caregiver_copy",
[0m[49m[38;5;10m+    1928[0m:[38;5;10m[49m         // "caregiver_with_patient_copy"
