[0m[49m[38;5;10m+    2463[0m:[38;5;10m[49m def _convert_unit(*, value, from_unit, to_unit) -> Optional[float]:
[0m[49m[38;5;10m+    2464[0m:[38;5;10m[49m     """Small unit-conversion table. Production uses a
[0m[49m[38;5;10m+    2465[0m:[38;5;10m[49m     clinical-leadership-owned conversion library reviewed
[0m[49m[38;5;10m+    2466[0m:[38;5;10m[49m     for the specific clinical contexts the trials use."""
