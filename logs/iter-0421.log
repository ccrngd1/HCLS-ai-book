[0m[49m[38;5;10m+    1374[0m:[38;5;10m[49m         identity_context = {"identity": IDENTITY_ADULT_SELF}
[0m[49m[38;5;10m+    1375[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1376[0m:[38;5;10m[49m     # 1. Continuous emergency screening. Runs first; the
