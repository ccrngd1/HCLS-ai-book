[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m # --- Emergency-screening signals ---
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m # Continuous emergency screening across every utterance,
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m # same architectural primitive as recipes 11.6, 11.7, 11.8,
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m # and 11.9. The trigger phrases live in a curated, clinical-
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m # leadership-owned, multilingual rule library. The list
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m # below is illustrative; production deployments use a
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m # materially larger rule library reviewed clinically and
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m # updated continuously.
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m EMERGENCY_PATTERNS_RAW = [
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m     r"\bchest pain\b",
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m     r"\bpressure in (?:my|the) chest\b",
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m     r"\bcan't breathe\b",
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m     r"\bcannot breathe\b",
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m     r"\bshort(?:ness)? of breath\b",
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m     r"\bnumb(?:ness)? on one side\b",
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m     r"\bface(?: is)? drooping\b",
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m     r"\bslurr(?:ed|ing) speech\b",
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m     r"\bworst headache (?:of|in) my life\b",
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m     r"\bsuicid(?:e|al)\b",
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m     r"\bkill myself\b",
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m     r"\bend my life\b",
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m     r"\bovers?dose\b",
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m     r"\babout to (?:hurt|harm) (?:my|some)self\b",
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m     r"\b911\b",
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m     r"\bemergency room\b",
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m EMERGENCY_PATTERNS = [
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m     re.compile(p, re.IGNORECASE) for p in EMERGENCY_PATTERNS_RAW]
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m # --- Out-of-scope routing rules ---
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m # Topics outside recruitment scope route to specific
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m # alternative pathways. The mapping below is illustrative;
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m # institutional production deployments tailor the routing
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m # table to their actual care-team and compliance-team
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m # escalation surface.
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m OUT_OF_SCOPE_PATTERNS = {
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m     "clinical_advice_about_existing_care": [
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m         r"\bshould I (?:take|stop|change) (?:my )?\w+",
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m         r"\bis (?:it|this) safe for me to\b",
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m         r"\bdo I have\b.*\b(?:diabetes|cancer|heart attack|stroke)\b",
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m     ],
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m     "trial_recommendation_request": [
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m         r"\bdo you think (?:I should|this trial)\b",
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m         r"\bwhat would you do\b",
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m         r"\bwhich trial is best\b",
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m     ],
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m     "benefits_quote_request": [
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m         r"\bhow much will (?:my )?insurance pay\b",
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m         r"\bwill (?:medicare|medicaid|my insurance) cover\b",
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m     ],
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m     "prescription_request": [
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m         r"\bcan I get a prescription\b",
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m         r"\brefill my\b",
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m     ],
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m OUT_OF_SCOPE_COMPILED = {
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m     category: [re.compile(p, re.IGNORECASE) for p in patterns]
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m     for category, patterns in OUT_OF_SCOPE_PATTERNS.items()
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m # --- IRB-approved disclosure language identifiers ---
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m # Each IRB-approved disclosure has a unique identifier that
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m # the orchestration prompt and the output-safety layer use
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m # to verify that required disclosures were surfaced. The
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m # actual text comes from the trial-context store with strict
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m # version pinning.
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m DISCLOSURE_ASSISTANT_NOT_PERSON   = "DISC.ASSISTANT_NOT_PERSON"
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m DISCLOSURE_NOT_COORDINATOR        = "DISC.NOT_COORDINATOR"
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m DISCLOSURE_CANNOT_ENROLL          = "DISC.CANNOT_ENROLL"
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m DISCLOSURE_PROVIDING_INFO_ONLY    = "DISC.PROVIDING_INFO_ONLY"
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m DISCLOSURE_CAN_STOP_ANY_TIME      = "DISC.CAN_STOP_ANY_TIME"
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m DISCLOSURE_DATA_RETENTION_NOTICE  = "DISC.DATA_RETENTION_NOTICE"
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m DISCLOSURE_REQUEST_COORDINATOR    = "DISC.REQUEST_COORDINATOR_ANY_TIME"
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m REQUIRED_DISCLOSURES_FIRST_TURN = [
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m     DISCLOSURE_ASSISTANT_NOT_PERSON,
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m     DISCLOSURE_NOT_COORDINATOR,
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m     DISCLOSURE_CANNOT_ENROLL,
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m     DISCLOSURE_PROVIDING_INFO_ONLY,
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m     DISCLOSURE_CAN_STOP_ANY_TIME,
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m     DISCLOSURE_DATA_RETENTION_NOTICE,
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m     DISCLOSURE_REQUEST_COORDINATOR,
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m # --- Eligibility-criterion category taxonomy ---
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m # Each eligibility criterion is classified into one of the
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m # four categories below. The category determines how the
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m # rule engine evaluates the criterion and what the assistant
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m # is permitted to say about the result.
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m CRITERION_CATEGORY_SIMPLE_STRUCTURED   = "SIMPLE_STRUCTURED"
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m CRITERION_CATEGORY_COMPLEX_STRUCTURED  = "COMPLEX_STRUCTURED"
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m CRITERION_CATEGORY_CLINICAL_JUDGMENT   = "CLINICAL_JUDGMENT"
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m CRITERION_CATEGORY_VERIFICATION_ONLY   = "VERIFICATION_ONLY"
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m # --- Eligibility evaluation outcomes (per criterion) ---
