[0m[49m[38;5;10m+    1131[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1132[0m:[38;5;10m[49m     _KB_CORPUS[TRIAL_CORPUS_KB_ID].append({
[0m[49m[38;5;10m+    1133[0m:[38;5;10m[49m         "id":      f"{trial_id}::{excerpt_id}",
[0m[49m[38;5;10m+    1134[0m:[38;5;10m[49m         "content": content,
[0m[49m[38;5;10m+    1135[0m:[38;5;10m[49m         "uri":     f"s3://irb-approved/{trial_id}/{section}/{excerpt_id}.md",
[0m[49m[38;5;10m+    1136[0m:[38;5;10m[49m         "metadata": {
[0m[49m[38;5;10m+    1137[0m:[38;5;10m[49m             "trial_id":          trial_id,
[0m[49m[38;5;10m+    1138[0m:[38;5;10m[49m             "excerpt_id":        excerpt_id,
