[0m[49m[38;5;10m+    2993[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    2994[0m:[38;5;10m[49m def persist_recruitment_decision(*,
[0m[49m[38;5;10m+    2995[0m:[38;5;10m[49m                                    session_id,
[0m[49m[38;5;10m+    2996[0m:[38;5;10m[49m                                    trial_id,
[0m[49m[38;5;10m+    2997[0m:[38;5;10m[49m                                    disposition,
[0m[49m[38;5;10m+    2998[0m:[38;5;10m[49m                                    prescreen_summary,
[0m[49m[38;5;10m+    2999[0m:[38;5;10m[49m                                    coordinator_handoff,
