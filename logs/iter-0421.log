[0m[49m[38;5;10m+    1062[0m:[38;5;10m[49m     return record
[0m[49m[38;5;10m+    1063[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1064[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1065[0m:[38;5;10m[49m def register_recruitment_faq(*,
[0m[49m[38;5;10m+    1066[0m:[38;5;10m[49m                               trial_id,
[0m[49m[38;5;10m+    1067[0m:[38;5;10m[49m                               faq_id,
[0m[49m[38;5;10m+    1068[0m:[38;5;10m[49m                               question_irb_approved,
[0m[49m[38;5;10m+    1069[0m:[38;5;10m[49m                               answer_irb_approved,
[0m[49m[38;5;10m+    1070[0m:[38;5;10m[49m                               category,
[0m[49m[38;5;10m+    1071[0m:[38;5;10m[49m                               irb_review_record,
[0m[49m[38;5;10m+    1072[0m:[38;5;10m[49m                               languages=None):
[0m[49m[38;5;10m+    1073[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1074[0m:[38;5;10m[49m     Register an IRB-approved recruitment-FAQ entry. Each
[0m[49m[38;5;10m+    1075[0m:[38;5;10m[49m     answer lives only as IRB-approved text; the runtime
[0m[49m[38;5;10m+    1076[0m:[38;5;10m[49m     retrieval surface returns the IRB-approved answer
[0m[49m[38;5;10m+    1077[0m:[38;5;10m[49m     verbatim with citation. The LLM is permitted to
[0m[49m[38;5;10m+    1078[0m:[38;5;10m[49m     surface the answer (with the patient's question
[0m[49m[38;5;10m+    1079[0m:[38;5;10m[49m     context for selection) but not to generate novel
[0m[49m[38;5;10m+    1080[0m:[38;5;10m[49m     answer text.
[0m[49m[38;5;10m+    1081[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1082[0m:[38;5;10m[49m     if languages is None:
[0m[49m[38;5;10m+    1083[0m:[38;5;10m[49m         languages = ["en"]
[0m[49m[38;5;10m+    1084[0m:[38;5;10m[49m     record = {
[0m[49m[38;5;10m+    1085[0m:[38;5;10m[49m         "trial_id":               trial_id,
[0m[49m[38;5;10m+    1086[0m:[38;5;10m[49m         "faq_id":                 faq_id,
[0m[49m[38;5;10m+    1087[0m:[38;5;10m[49m         "question_irb_approved":  question_irb_approved,
[0m[49m[38;5;10m+    1088[0m:[38;5;10m[49m         "answer_irb_approved":    answer_irb_approved,
[0m[49m[38;5;10m+    1089[0m:[38;5;10m[49m         "category":               category,
[0m[49m[38;5;10m+    1090[0m:[38;5;10m[49m         "irb_review_record":      irb_review_record,
[0m[49m[38;5;10m+    1091[0m:[38;5;10m[49m         "languages":              languages,
[0m[49m[38;5;10m+    1092[0m:[38;5;10m[49m         "registered_at":          _now_iso(),
[0m[49m[38;5;10m+    1093[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1094[0m:[38;5;10m[49m     table = dynamodb.Table(RECRUITMENT_FAQ_TABLE)
[0m[49m[38;5;10m+    1095[0m:[38;5;10m[49m     table.put_item(Item=_to_decimal(record))
[0m[49m[38;5;10m+    1096[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1097[0m:[38;5;10m[49m     # Add to the Knowledge Base mock corpus too. In
[0m[49m[38;5;10m+    1098[0m:[38;5;10m[49m     # production the IRB-approved-FAQ corpus lands in S3
[0m[49m[38;5;10m+    1099[0m:[38;5;10m[49m     # and the Knowledge Base ingestion pipeline runs the
[0m[49m[38;5;10m+    1100[0m:[38;5;10m[49m     # embedding job; the trial_id metadata is the per-
[0m[49m[38;5;10m+    1101[0m:[38;5;10m[49m     # trial isolation primitive at retrieval time.
[0m[49m[38;5;10m+    1102[0m:[38;5;10m[49m     _KB_CORPUS[FAQ_KB_ID].append({
[0m[49m[38;5;10m+    1103[0m:[38;5;10m[49m         "id":      f"{trial_id}::{faq_id}",
[0m[49m[38;5;10m+    1104[0m:[38;5;10m[49m         "content": (
[0m[49m[38;5;10m+    1105[0m:[38;5;10m[49m             f"Q: {question_irb_approved}\n"
[0m[49m[38;5;10m+    1106[0m:[38;5;10m[49m             f"A: {answer_irb_approved}"),
[0m[49m[38;5;10m+    1107[0m:[38;5;10m[49m         "uri":     f"s3://irb-approved/{trial_id}/{faq_id}.md",
[0m[49m[38;5;10m+    1108[0m:[38;5;10m[49m         "metadata": {
[0m[49m[38;5;10m+    1109[0m:[38;5;10m[49m             "trial_id":              trial_id,
[0m[49m[38;5;10m+    1110[0m:[38;5;10m[49m             "faq_id":                faq_id,
[0m[49m[38;5;10m+    1111[0m:[38;5;10m[49m             "category":              category,
[0m[49m[38;5;10m+    1112[0m:[38;5;10m[49m             "irb_review_record":     irb_review_record,
[0m[49m[38;5;10m+    1113[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    1114[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    1115[0m:[38;5;10m[49m     return record
[0m[49m[38;5;10m+    1116[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1117[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1118[0m:[38;5;10m[49m def register_irb_approved_corpus_excerpt(*,
[0m[49m[38;5;10m+    1119[0m:[38;5;10m[49m                                            trial_id,
[0m[49m[38;5;10m+    1120[0m:[38;5;10m[49m                                            excerpt_id,
[0m[49m[38;5;10m+    1121[0m:[38;5;10m[49m                                            content,
[0m[49m[38;5;10m+    1122[0m:[38;5;10m[49m                                            section,
[0m[49m[38;5;10m+    1123[0m:[38;5;10m[49m                                            irb_review_record):
[0m[49m[38;5;10m+    1124[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1125[0m:[38;5;10m[49m     Register an IRB-approved trial-content excerpt for the
[0m[49m[38;5;10m+    1126[0m:[38;5;10m[49m     trial-corpus Knowledge Base. The runtime retrieval
[0m[49m[38;5;10m+    1127[0m:[38;5;10m[49m     surface returns excerpts with citation; the LLM is
[0m[49m[38;5;10m+    1128[0m:[38;5;10m[49m     permitted to surface excerpts but not to paraphrase
[0m[49m[38;5;10m+    1129[0m:[38;5;10m[49m     them in ways that diverge from the IRB-approved text.
