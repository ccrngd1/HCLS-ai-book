[0m[49m[38;5;10m+    2938[0m:[38;5;10m[49m         "session_id":    session_id,
[0m[49m[38;5;10m+    2939[0m:[38;5;10m[49m         "captured_at":   _now_iso(),
[0m[49m[38;5;10m+    2940[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    2941[0m:[38;5;10m[49m     for dimension in COHORT_DIMENSIONS:
[0m[49m[38;5;10m+    2942[0m:[38;5;10m[49m         if dimension in captured and captured[dimension]:
[0m[49m[38;5;10m+    2943[0m:[38;5;10m[49m             record[dimension] = captured[dimension]
[0m[49m[38;5;10m+    2944[0m:[38;5;10m[49m     table = dynamodb.Table(REPRESENTATIVENESS_TABLE)
[0m[49m[38;5;10m+    2945[0m:[38;5;10m[49m     table.put_item(Item=_to_decimal(record))
[0m[49m[38;5;10m+    2946[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2947[0m:[38;5;10m[49m     _emit_event(
[0m[49m[38;5;10m+    2948[0m:[38;5;10m[49m         "RecruitmentEvent.RepresentativenessCaptured", {
[0m[49m[38;5;10m+    2949[0m:[38;5;10m[49m             "trial_id":     trial_id,
[0m[49m[38;5;10m+    2950[0m:[38;5;10m[49m             "session_id":   session_id,
[0m[49m[38;5;10m+    2951[0m:[38;5;10m[49m             "fields":       sorted(record.keys()),
[0m[49m[38;5;10m+    2952[0m:[38;5;10m[49m             "captured_at":  record["captured_at"],
