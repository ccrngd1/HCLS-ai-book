[0m[49m[38;5;10m+    2266[0m:[38;5;10m[49m     record = _from_decimal(record)
[0m[49m[38;5;10m+    2267[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2268[0m:[38;5;10m[49m     evaluation = evaluate_eligibility_criterion(
[0m[49m[38;5;10m+    2269[0m:[38;5;10m[49m         rule_definition=record["rule_definition"],
[0m[49m[38;5;10m+    2270[0m:[38;5;10m[49m         category=record["category"],
[0m[49m[38;5;10m+    2271[0m:[38;5;10m[49m         inclusion=record.get("inclusion", True),
[0m[49m[38;5;10m+    2272[0m:[38;5;10m[49m         patient_response_value=patient_response_value,
[0m[49m[38;5;10m+    2273[0m:[38;5;10m[49m         patient_reported_unit=patient_reported_unit)
[0m[49m[38;5;10m+    2274[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2275[0m:[38;5;10m[49m     # Persist the captured response onto the prescreen
[0m[49m[38;5;10m+    2276[0m:[38;5;10m[49m     # record. The conversation state's prescreen_responses
[0m[49m[38;5;10m+    2277[0m:[38;5;10m[49m     # dict is the running accumulator.
[0m[49m[38;5;10m+    2278[0m:[38;5;10m[49m     state = _safe_get(CONVERSATION_STATE_TABLE,
[0m[49m[38;5;10m+    2279[0m:[38;5;10m[49m                        {"session_id": session_id})
[0m[49m[38;5;10m+    2280[0m:[38;5;10m[49m     if state:
[0m[49m[38;5;10m+    2281[0m:[38;5;10m[49m         state = _from_decimal(state)
[0m[49m[38;5;10m+    2282[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    2283[0m:[38;5;10m[49m         state = {"session_id": session_id, "trial_id": trial_id}
[0m[49m[38;5;10m+    2284[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2285[0m:[38;5;10m[49m     responses = state.get("prescreen_responses", {})
[0m[49m[38;5;10m+    2286[0m:[38;5;10m[49m     responses[criterion_id] = {
[0m[49m[38;5;10m+    2287[0m:[38;5;10m[49m         "value":            patient_response_value,
[0m[49m[38;5;10m+    2288[0m:[38;5;10m[49m         "unit":             patient_reported_unit,
[0m[49m[38;5;10m+    2289[0m:[38;5;10m[49m         "evaluation":       evaluation["outcome"],
[0m[49m[38;5;10m+    2290[0m:[38;5;10m[49m         "rule_version":     record.get("rule_version", "v1"),
[0m[49m[38;5;10m+    2291[0m:[38;5;10m[49m         "captured_at":      _now_iso(),
[0m[49m[38;5;10m+    2292[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    2293[0m:[38;5;10m[49m     state["prescreen_responses"] = responses
[0m[49m[38;5;10m+    2294[0m:[38;5;10m[49m     state["prescreen_state"] = "IN_PROGRESS"
[0m[49m[38;5;10m+    2295[0m:[38;5;10m[49m     table = dynamodb.Table(CONVERSATION_STATE_TABLE)
[0m[49m[38;5;10m+    2296[0m:[38;5;10m[49m     table.put_item(Item=_to_decimal(state))
[0m[49m[38;5;10m+    2297[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2298[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    2299[0m:[38;5;10m[49m         "outcome":            "OK",
[0m[49m[38;5;10m+    2300[0m:[38;5;10m[49m         "criterion_id":       criterion_id,
[0m[49m[38;5;10m+    2301[0m:[38;5;10m[49m         "evaluation_outcome": evaluation["outcome"],
[0m[49m[38;5;10m+    2302[0m:[38;5;10m[49m         "evaluation_reason":  evaluation.get("reason"),
[0m[49m[38;5;10m+    2303[0m:[38;5;10m[49m         "patient_reported":   True,
[0m[49m[38;5;10m+    2304[0m:[38;5;10m[49m         "coordinator_review_required":
[0m[49m[38;5;10m+    2305[0m:[38;5;10m[49m             evaluation["outcome"] in (
[0m[49m[38;5;10m+    2306[0m:[38;5;10m[49m                 EVAL_OUTCOME_REQUIRES_COORDINATOR,
[0m[49m[38;5;10m+    2307[0m:[38;5;10m[49m                 EVAL_OUTCOME_INDETERMINATE),
[0m[49m[38;5;10m+    2308[0m:[38;5;10m[49m         "citations": [{
[0m[49m[38;5;10m+    2309[0m:[38;5;10m[49m             "trial_id":          trial_id,
[0m[49m[38;5;10m+    2310[0m:[38;5;10m[49m             "criterion_id":      criterion_id,
[0m[49m[38;5;10m+    2311[0m:[38;5;10m[49m             "rule_version":      record.get("rule_version", "v1"),
[0m[49m[38;5;10m+    2312[0m:[38;5;10m[49m             "irb_review_record":
[0m[49m[38;5;10m+    2313[0m:[38;5;10m[49m                 record.get("irb_review_record", {}),
[0m[49m[38;5;10m+    2314[0m:[38;5;10m[49m         }],
[0m[49m[38;5;10m+    2315[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    2316[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2317[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2318[0m:[38;5;10m[49m def evaluate_eligibility_criterion(*,
[0m[49m[38;5;10m+    2319[0m:[38;5;10m[49m                                      rule_definition,
[0m[49m[38;5;10m+    2320[0m:[38;5;10m[49m                                      category,
[0m[49m[38;5;10m+    2321[0m:[38;5;10m[49m                                      inclusion,
[0m[49m[38;5;10m+    2322[0m:[38;5;10m[49m                                      patient_response_value,
[0m[49m[38;5;10m+    2323[0m:[38;5;10m[49m                                      patient_reported_unit
[0m[49m[38;5;10m+    2324[0m:[38;5;10m[49m                                      ) -> dict:
[0m[49m[38;5;10m+    2325[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2326[0m:[38;5;10m[49m     Deterministic per-criterion evaluator. The rule
[0m[49m[38;5;10m+    2327[0m:[38;5;10m[49m     definition is a structured dict; the evaluator applies
[0m[49m[38;5;10m+    2328[0m:[38;5;10m[49m     the rule and returns one of MET, NOT_MET, INDETERMINATE,
[0m[49m[38;5;10m+    2329[0m:[38;5;10m[49m     or REQUIRES_COORDINATOR_REVIEW.
[0m[49m[38;5;10m+    2330[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2331[0m:[38;5;10m[49m     Each rule is owned by named clinical leadership with
[0m[49m[38;5;10m+    2332[0m:[38;5;10m[49m     version history and IRB-review evidence. The evaluator
[0m[49m[38;5;10m+    2333[0m:[38;5;10m[49m     here covers a small subset of patterns to keep the
[0m[49m[38;5;10m+    2334[0m:[38;5;10m[49m     demo readable. Production has dozens of rule types
[0m[49m[38;5;10m+    2335[0m:[38;5;10m[49m     covering numeric ranges, lab-value windows, medication
[0m[49m[38;5;10m+    2336[0m:[38;5;10m[49m     histories, comorbidity patterns, demographic constraints,
[0m[49m[38;5;10m+    2337[0m:[38;5;10m[49m     and time-window arithmetic.
[0m[49m[38;5;10m+    2338[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2339[0m:[38;5;10m[49m     rule_type = rule_definition.get("type")
[0m[49m[38;5;10m+    2340[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2341[0m:[38;5;10m[49m     if rule_type == "boolean_response":
[0m[49m[38;5;10m+    2342[0m:[38;5;10m[49m         # Patient self-reports yes/no for the criterion.
[0m[49m[38;5;10m+    2343[0m:[38;5;10m[49m         normalized = patient_response_value.strip().lower()
[0m[49m[38;5;10m+    2344[0m:[38;5;10m[49m         if normalized in ("yes", "y", "true", "1"):
[0m[49m[38;5;10m+    2345[0m:[38;5;10m[49m             patient_value_bool = True
[0m[49m[38;5;10m+    2346[0m:[38;5;10m[49m         elif normalized in ("no", "n", "false", "0"):
[0m[49m[38;5;10m+    2347[0m:[38;5;10m[49m             patient_value_bool = False
[0m[49m[38;5;10m+    2348[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    2349[0m:[38;5;10m[49m             return {"outcome": EVAL_OUTCOME_INDETERMINATE,
[0m[49m[38;5;10m+    2350[0m:[38;5;10m[49m                     "reason":  "Could not parse boolean"}
[0m[49m[38;5;10m+    2351[0m:[38;5;10m[49m         expected = rule_definition.get(
[0m[49m[38;5;10m+    2352[0m:[38;5;10m[49m             "expected_value", True)
[0m[49m[38;5;10m+    2353[0m:[38;5;10m[49m         is_match = (patient_value_bool == expected)
[0m[49m[38;5;10m+    2354[0m:[38;5;10m[49m         outcome = (
[0m[49m[38;5;10m+    2355[0m:[38;5;10m[49m             EVAL_OUTCOME_MET if (is_match == inclusion)
[0m[49m[38;5;10m+    2356[0m:[38;5;10m[49m             else EVAL_OUTCOME_NOT_MET)
[0m[49m[38;5;10m+    2357[0m:[38;5;10m[49m         return {"outcome": outcome,
[0m[49m[38;5;10m+    2358[0m:[38;5;10m[49m                 "reason":  None}
[0m[49m[38;5;10m+    2359[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2360[0m:[38;5;10m[49m     if rule_type == "age_range":
[0m[49m[38;5;10m+    2361[0m:[38;5;10m[49m         try:
[0m[49m[38;5;10m+    2362[0m:[38;5;10m[49m             age = int(patient_response_value)
[0m[49m[38;5;10m+    2363[0m:[38;5;10m[49m         except (ValueError, TypeError):
[0m[49m[38;5;10m+    2364[0m:[38;5;10m[49m             return {"outcome": EVAL_OUTCOME_INDETERMINATE,
[0m[49m[38;5;10m+    2365[0m:[38;5;10m[49m                     "reason":  "Could not parse age"}
[0m[49m[38;5;10m+    2366[0m:[38;5;10m[49m         min_age = rule_definition.get("min_age", 0)
[0m[49m[38;5;10m+    2367[0m:[38;5;10m[49m         max_age = rule_definition.get("max_age", 200)
[0m[49m[38;5;10m+    2368[0m:[38;5;10m[49m         in_range = (min_age <= age <= max_age)
[0m[49m[38;5;10m+    2369[0m:[38;5;10m[49m         outcome = (
[0m[49m[38;5;10m+    2370[0m:[38;5;10m[49m             EVAL_OUTCOME_MET if (in_range == inclusion)
[0m[49m[38;5;10m+    2371[0m:[38;5;10m[49m             else EVAL_OUTCOME_NOT_MET)
[0m[49m[38;5;10m+    2372[0m:[38;5;10m[49m         return {"outcome": outcome,
[0m[49m[38;5;10m+    2373[0m:[38;5;10m[49m                 "reason":  None}
[0m[49m[38;5;10m+    2374[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2375[0m:[38;5;10m[49m     if rule_type == "numeric_range_with_unit":
[0m[49m[38;5;10m+    2376[0m:[38;5;10m[49m         # Numeric range with required unit. Includes unit-
[0m[49m[38;5;10m+    2377[0m:[38;5;10m[49m         # conversion logic for the common cases (HbA1c %
[0m[49m[38;5;10m+    2378[0m:[38;5;10m[49m         # vs mmol/mol, weight kg vs lb).
[0m[49m[38;5;10m+    2379[0m:[38;5;10m[49m         try:
[0m[49m[38;5;10m+    2380[0m:[38;5;10m[49m             value = float(patient_response_value)
[0m[49m[38;5;10m+    2381[0m:[38;5;10m[49m         except (ValueError, TypeError):
[0m[49m[38;5;10m+    2382[0m:[38;5;10m[49m             return {"outcome": EVAL_OUTCOME_INDETERMINATE,
[0m[49m[38;5;10m+    2383[0m:[38;5;10m[49m                     "reason":  "Could not parse numeric value"}
[0m[49m[38;5;10m+    2384[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2385[0m:[38;5;10m[49m         target_unit = rule_definition.get("unit")
[0m[49m[38;5;10m+    2386[0m:[38;5;10m[49m         if patient_reported_unit and \
[0m[49m[38;5;10m+    2387[0m:[38;5;10m[49m                 patient_reported_unit != target_unit:
[0m[49m[38;5;10m+    2388[0m:[38;5;10m[49m             value = _convert_unit(
[0m[49m[38;5;10m+    2389[0m:[38;5;10m[49m                 value=value,
[0m[49m[38;5;10m+    2390[0m:[38;5;10m[49m                 from_unit=patient_reported_unit,
[0m[49m[38;5;10m+    2391[0m:[38;5;10m[49m                 to_unit=target_unit)
[0m[49m[38;5;10m+    2392[0m:[38;5;10m[49m             if value is None:
[0m[49m[38;5;10m+    2393[0m:[38;5;10m[49m                 return {
[0m[49m[38;5;10m+    2394[0m:[38;5;10m[49m                     "outcome": EVAL_OUTCOME_REQUIRES_COORDINATOR,
[0m[49m[38;5;10m+    2395[0m:[38;5;10m[49m                     "reason":  (
[0m[49m[38;5;10m+    2396[0m:[38;5;10m[49m                         f"Unit conversion from "
[0m[49m[38;5;10m+    2397[0m:[38;5;10m[49m                         f"{patient_reported_unit} to "
[0m[49m[38;5;10m+    2398[0m:[38;5;10m[49m                         f"{target_unit} not supported")}
[0m[49m[38;5;10m+    2399[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2400[0m:[38;5;10m[49m         min_v = rule_definition.get("min", float("-inf"))
[0m[49m[38;5;10m+    2401[0m:[38;5;10m[49m         max_v = rule_definition.get("max", float("inf"))
[0m[49m[38;5;10m+    2402[0m:[38;5;10m[49m         in_range = (min_v <= value <= max_v)
[0m[49m[38;5;10m+    2403[0m:[38;5;10m[49m         outcome = (
[0m[49m[38;5;10m+    2404[0m:[38;5;10m[49m             EVAL_OUTCOME_MET if (in_range == inclusion)
[0m[49m[38;5;10m+    2405[0m:[38;5;10m[49m             else EVAL_OUTCOME_NOT_MET)
[0m[49m[38;5;10m+    2406[0m:[38;5;10m[49m         return {"outcome": outcome,
[0m[49m[38;5;10m+    2407[0m:[38;5;10m[49m                 "reason":  None}
[0m[49m[38;5;10m+    2408[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2409[0m:[38;5;10m[49m     if rule_type == "categorical_set":
[0m[49m[38;5;10m+    2410[0m:[38;5;10m[49m         # Patient response must be in a named set.
[0m[49m[38;5;10m+    2411[0m:[38;5;10m[49m         allowed = set(rule_definition.get("allowed_values", []))
[0m[49m[38;5;10m+    2412[0m:[38;5;10m[49m         is_match = (
[0m[49m[38;5;10m+    2413[0m:[38;5;10m[49m             patient_response_value.strip().lower() in
[0m[49m[38;5;10m+    2414[0m:[38;5;10m[49m             {a.lower() for a in allowed})
[0m[49m[38;5;10m+    2415[0m:[38;5;10m[49m         outcome = (
[0m[49m[38;5;10m+    2416[0m:[38;5;10m[49m             EVAL_OUTCOME_MET if (is_match == inclusion)
[0m[49m[38;5;10m+    2417[0m:[38;5;10m[49m             else EVAL_OUTCOME_NOT_MET)
[0m[49m[38;5;10m+    2418[0m:[38;5;10m[49m         return {"outcome": outcome,
[0m[49m[38;5;10m+    2419[0m:[38;5;10m[49m                 "reason":  None}
[0m[49m[38;5;10m+    2420[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2421[0m:[38;5;10m[49m     if rule_type == "time_since":
[0m[49m[38;5;10m+    2422[0m:[38;5;10m[49m         # "How long since X" in days, months, or years.
[0m[49m[38;5;10m+    2423[0m:[38;5;10m[49m         # Patient response interpreted as the duration.
[0m[49m[38;5;10m+    2424[0m:[38;5;10m[49m         try:
[0m[49m[38;5;10m+    2425[0m:[38;5;10m[49m             value = int(patient_response_value)
[0m[49m[38;5;10m+    2426[0m:[38;5;10m[49m         except (ValueError, TypeError):
[0m[49m[38;5;10m+    2427[0m:[38;5;10m[49m             return {"outcome": EVAL_OUTCOME_INDETERMINATE,
[0m[49m[38;5;10m+    2428[0m:[38;5;10m[49m                     "reason":  "Could not parse duration"}
[0m[49m[38;5;10m+    2429[0m:[38;5;10m[49m         max_duration_days = rule_definition.get(
[0m[49m[38;5;10m+    2430[0m:[38;5;10m[49m             "max_duration_days", float("inf"))
[0m[49m[38;5;10m+    2431[0m:[38;5;10m[49m         unit = (patient_reported_unit or "days").lower()
[0m[49m[38;5;10m+    2432[0m:[38;5;10m[49m         duration_days = value * {
[0m[49m[38;5;10m+    2433[0m:[38;5;10m[49m             "day":   1, "days":   1,
[0m[49m[38;5;10m+    2434[0m:[38;5;10m[49m             "week":  7, "weeks":  7,
[0m[49m[38;5;10m+    2435[0m:[38;5;10m[49m             "month": 30, "months": 30,
[0m[49m[38;5;10m+    2436[0m:[38;5;10m[49m             "year":  365, "years":  365,
[0m[49m[38;5;10m+    2437[0m:[38;5;10m[49m         }.get(unit, 1)
[0m[49m[38;5;10m+    2438[0m:[38;5;10m[49m         in_window = (duration_days <= max_duration_days)
[0m[49m[38;5;10m+    2439[0m:[38;5;10m[49m         outcome = (
[0m[49m[38;5;10m+    2440[0m:[38;5;10m[49m             EVAL_OUTCOME_MET if (in_window == inclusion)
[0m[49m[38;5;10m+    2441[0m:[38;5;10m[49m             else EVAL_OUTCOME_NOT_MET)
[0m[49m[38;5;10m+    2442[0m:[38;5;10m[49m         return {"outcome": outcome,
[0m[49m[38;5;10m+    2443[0m:[38;5;10m[49m                 "reason":  None}
[0m[49m[38;5;10m+    2444[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2445[0m:[38;5;10m[49m     if rule_type == "clinical_judgment":
[0m[49m[38;5;10m+    2446[0m:[38;5;10m[49m         # The criterion requires clinical judgment (severity,
[0m[49m[38;5;10m+    2447[0m:[38;5;10m[49m         # prognosis, comorbidity context). The assistant
[0m[49m[38;5;10m+    2448[0m:[38;5;10m[49m         # captures the patient's report; the coordinator
[0m[49m[38;5;10m+    2449[0m:[38;5;10m[49m         # makes the determination.
[0m[49m[38;5;10m+    2450[0m:[38;5;10m[49m         return {"outcome": EVAL_OUTCOME_REQUIRES_COORDINATOR,
[0m[49m[38;5;10m+    2451[0m:[38;5;10m[49m                 "reason":  "Clinical judgment required"}
[0m[49m[38;5;10m+    2452[0m:[38;5;10m[49m 
