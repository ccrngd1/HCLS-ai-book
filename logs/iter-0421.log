[0m[49m[38;5;10m+    2636[0m:[38;5;10m[49m     #    factual claims but no IRB-approved retrieval
[0m[49m[38;5;10m+    2637[0m:[38;5;10m[49m     #    happened on this turn, that's a finding.
[0m[49m[38;5;10m+    2638[0m:[38;5;10m[49m     retrieval_tools = {
[0m[49m[38;5;10m+    2639[0m:[38;5;10m[49m         "trial_context_retrieve",
