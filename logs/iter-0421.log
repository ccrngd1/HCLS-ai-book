[0m[49m[38;5;10m+    2468[0m:[38;5;10m[49m         return value
[0m[49m[38;5;10m+    2469[0m:[38;5;10m[49m     conversions = {
[0m[49m[38;5;10m+    2470[0m:[38;5;10m[49m         # HbA1c
[0m[49m[38;5;10m+    2471[0m:[38;5;10m[49m         ("%", "mmol/mol"):    lambda v: 10.929 * (v - 2.15),
[0m[49m[38;5;10m+    2472[0m:[38;5;10m[49m         ("mmol/mol", "%"):    lambda v: (v / 10.929) + 2.15,
[0m[49m[38;5;10m+    2473[0m:[38;5;10m[49m         # Weight
[0m[49m[38;5;10m+    2474[0m:[38;5;10m[49m         ("kg", "lb"):         lambda v: v * 2.20462,
[0m[49m[38;5;10m+    2475[0m:[38;5;10m[49m         ("lb", "kg"):         lambda v: v / 2.20462,
[0m[49m[38;5;10m+    2476[0m:[38;5;10m[49m         # Height
[0m[49m[38;5;10m+    2477[0m:[38;5;10m[49m         ("cm", "in"):         lambda v: v / 2.54,
[0m[49m[38;5;10m+    2478[0m:[38;5;10m[49m         ("in", "cm"):         lambda v: v * 2.54,
[0m[49m[38;5;10m+    2479[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    2480[0m:[38;5;10m[49m     fn = conversions.get((from_unit, to_unit))
[0m[49m[38;5;10m+    2481[0m:[38;5;10m[49m     return fn(value) if fn else None
