[0m[49m[38;5;10m+    1021[0m:[38;5;10m[49m def register_eligibility_criterion(*,
[0m[49m[38;5;10m+    1022[0m:[38;5;10m[49m                                     trial_id,
[0m[49m[38;5;10m+    1023[0m:[38;5;10m[49m                                     criterion_id,
[0m[49m[38;5;10m+    1024[0m:[38;5;10m[49m                                     description_irb_approved,
[0m[49m[38;5;10m+    1025[0m:[38;5;10m[49m                                     category,
[0m[49m[38;5;10m+    1026[0m:[38;5;10m[49m                                     rule_definition,
[0m[49m[38;5;10m+    1027[0m:[38;5;10m[49m                                     clinical_owner,
[0m[49m[38;5;10m+    1028[0m:[38;5;10m[49m                                     irb_review_record,
[0m[49m[38;5;10m+    1029[0m:[38;5;10m[49m                                     inclusion=True,
[0m[49m[38;5;10m+    1030[0m:[38;5;10m[49m                                     rule_version="v1"):
[0m[49m[38;5;10m+    1031[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1032[0m:[38;5;10m[49m     Register a single eligibility criterion. The rule
[0m[49m[38;5;10m+    1033[0m:[38;5;10m[49m     definition is a deterministic structure interpretable
[0m[49m[38;5;10m+    1034[0m:[38;5;10m[49m     by the rule engine. The LLM does not interpret rule
[0m[49m[38;5;10m+    1035[0m:[38;5;10m[49m     definitions; it surfaces the question the rule needs
[0m[49m[38;5;10m+    1036[0m:[38;5;10m[49m     answered, captures the patient's response, and routes
[0m[49m[38;5;10m+    1037[0m:[38;5;10m[49m     the response to the deterministic evaluator.
[0m[49m[38;5;10m+    1038[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1039[0m:[38;5;10m[49m     if category not in (
[0m[49m[38;5;10m+    1040[0m:[38;5;10m[49m         CRITERION_CATEGORY_SIMPLE_STRUCTURED,
[0m[49m[38;5;10m+    1041[0m:[38;5;10m[49m         CRITERION_CATEGORY_COMPLEX_STRUCTURED,
[0m[49m[38;5;10m+    1042[0m:[38;5;10m[49m         CRITERION_CATEGORY_CLINICAL_JUDGMENT,
[0m[49m[38;5;10m+    1043[0m:[38;5;10m[49m         CRITERION_CATEGORY_VERIFICATION_ONLY,
[0m[49m[38;5;10m+    1044[0m:[38;5;10m[49m     ):
[0m[49m[38;5;10m+    1045[0m:[38;5;10m[49m         raise ValueError(
[0m[49m[38;5;10m+    1046[0m:[38;5;10m[49m             f"Unknown criterion category: {category}")
[0m[49m[38;5;10m+    1047[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1048[0m:[38;5;10m[49m     record = {
[0m[49m[38;5;10m+    1049[0m:[38;5;10m[49m         "trial_id":                  trial_id,
[0m[49m[38;5;10m+    1050[0m:[38;5;10m[49m         "criterion_id":              criterion_id,
[0m[49m[38;5;10m+    1051[0m:[38;5;10m[49m         "description_irb_approved":  description_irb_approved,
[0m[49m[38;5;10m+    1052[0m:[38;5;10m[49m         "category":                  category,
[0m[49m[38;5;10m+    1053[0m:[38;5;10m[49m         "rule_definition":           rule_definition,
[0m[49m[38;5;10m+    1054[0m:[38;5;10m[49m         "clinical_owner":            clinical_owner,
[0m[49m[38;5;10m+    1055[0m:[38;5;10m[49m         "irb_review_record":         irb_review_record,
[0m[49m[38;5;10m+    1056[0m:[38;5;10m[49m         "inclusion":                 inclusion,
[0m[49m[38;5;10m+    1057[0m:[38;5;10m[49m         "rule_version":              rule_version,
[0m[49m[38;5;10m+    1058[0m:[38;5;10m[49m         "registered_at":             _now_iso(),
[0m[49m[38;5;10m+    1059[0m:[38;5;10m[49m     }
