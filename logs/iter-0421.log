[49m[38;5;10m+    2518[0m:[38;5;10m[49m ## Step 6: Run Output Safety With IRB-Language Faithfulness Verification
[0m[49m[38;5;10m+    2519[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2520[0m:[38;5;10m[49m The output-safety layer is the architectural backstop for the IRB-citation discipline. Before any model-generated text reaches the patient, the layer verifies (1) that the response cites the IRB-approved corpus for every trial-specific assertion, (2) that the response stays within the recruitment scope (no recommendation language, no off-protocol claims, no comparisons across trials, no clinical advice on the patient's existing care), (3) that on the first turn the IRB-required disclosures were surfaced, and (4) that a Bedrock Guardrail with a recruitment-tuned restricted-topic policy did not flag the content. A response that fails any check is replaced with an IRB-approved safe-fallback that routes the patient to the coordinator.
[0m[49m[38;5;10m+    2521[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2522[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    2523[0m:[38;5;10m[49m # Phrases that suggest the assistant is recommending,
[0m[49m[38;5;10m+    2524[0m:[38;5;10m[49m # comparing, or advising. Pattern-based first pass; the
[0m[49m[38;5;10m+    2525[0m:[38;5;10m[49m # real production deployment combines this with a tuned
[0m[49m[38;5;10m+    2526[0m:[38;5;10m[49m # classifier and a Guardrail with a restricted-topic
[0m[49m[38;5;10m+    2527[0m:[38;5;10m[49m # filter calibrated for recruitment.
[0m[49m[38;5;10m+    2528[0m:[38;5;10m[49m RECOMMENDATION_PATTERNS_RAW = [
[0m[49m[38;5;10m+    2529[0m:[38;5;10m[49m     r"\byou should\b",
[0m[49m[38;5;10m+    2530[0m:[38;5;10m[49m     r"\bI recommend\b",
[0m[49m[38;5;10m+    2531[0m:[38;5;10m[49m     r"\bI think you'?d\b",
[0m[49m[38;5;10m+    2532[0m:[38;5;10m[49m     r"\bin my opinion\b",
[0m[49m[38;5;10m+    2533[0m:[38;5;10m[49m     r"\bthe right (?:trial|study|choice) for you\b",
[0m[49m[38;5;10m+    2534[0m:[38;5;10m[49m     r"\bthis (?:trial|study) is (?:better|best)\b",
[0m[49m[38;5;10m+    2535[0m:[38;5;10m[49m     r"\bcompared to (?:other|the other) (?:trial|study)\b",
[0m[49m[38;5;10m+    2536[0m:[38;5;10m[49m     r"\bfor someone like you\b",
[0m[49m[38;5;10m+    2537[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+    2538[0m:[38;5;10m[49m RECOMMENDATION_PATTERNS = [
[0m[49m[38;5;10m+    2539[0m:[38;5;10m[49m     re.compile(p, re.IGNORECASE)
[0m[49m[38;5;10m+    2540[0m:[38;5;10m[49m     for p in RECOMMENDATION_PATTERNS_RAW]
[0m[49m[38;5;10m+    2541[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2542[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2543[0m:[38;5;10m[49m def screen_assistant_response(*,
[0m[49m[38;5;10m+    2544[0m:[38;5;10m[49m                                 response_text,
[0m[49m[38;5;10m+    2545[0m:[38;5;10m[49m                                 citations,
[0m[49m[38;5;10m+    2546[0m:[38;5;10m[49m                                 trial_id,
[0m[49m[38;5;10m+    2547[0m:[38;5;10m[49m                                 conversation_state,
[0m[49m[38;5;10m+    2548[0m:[38;5;10m[49m                                 tool_trace) -> dict:
[0m[49m[38;5;10m+    2549[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2550[0m:[38;5;10m[49m     Run the output-safety layer. Returns a dict with
[0m[49m[38;5;10m+    2551[0m:[38;5;10m[49m     routing instructions; the chat handler uses the result
[0m[49m[38;5;10m+    2552[0m:[38;5;10m[49m     to decide whether to surface the response or to
[0m[49m[38;5;10m+    2553[0m:[38;5;10m[49m     surface the IRB-approved safe-fallback instead.
[0m[49m[38;5;10m+    2554[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2555[0m:[38;5;10m[49m     findings: list = []
[0m[49m[38;5;10m+    2556[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2557[0m:[38;5;10m[49m     # 1. Recommendation language.
[0m[49m[38;5;10m+    2558[0m:[38;5;10m[49m     for pattern in RECOMMENDATION_PATTERNS:
[0m[49m[38;5;10m+    2559[0m:[38;5;10m[49m         if pattern.search(response_text):
[0m[49m[38;5;10m+    2560[0m:[38;5;10m[49m             findings.append({
[0m[49m[38;5;10m+    2561[0m:[38;5;10m[49m                 "category":         "RECOMMENDATION_LANGUAGE",
[0m[49m[38;5;10m+    2562[0m:[38;5;10m[49m                 "severity":         "BLOCK",
[0m[49m[38;5;10m+    2563[0m:[38;5;10m[49m                 "matched_pattern":  pattern.pattern,
[0m[49m[38;5;10m+    2564[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    2565[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2566[0m:[38;5;10m[49m     # 2. Citation coverage. Every trial-specific assertion
[0m[49m[38;5;10m+    2567[0m:[38;5;10m[49m     #    should be tied to a citation. The demo uses a
[0m[49m[38;5;10m+    2568[0m:[38;5;10m[49m     #    simple heuristic: count sentence-like spans that
[0m[49m[38;5;10m+    2569[0m:[38;5;10m[49m     #    contain trial-specific markers (the protocol
[0m[49m[38;5;10m+    2570[0m:[38;5;10m[49m     #    identifier or therapeutic-area keywords) and
[0m[49m[38;5;10m+    2571[0m:[38;5;10m[49m     #    require at least one citation per such span.
[0m[49m[38;5;10m+    2572[0m:[38;5;10m[49m     trial_context = get_trial_context(trial_id) or {}
[0m[49m[38;5;10m+    2573[0m:[38;5;10m[49m     therapeutic_area = trial_context.get(
[0m[49m[38;5;10m+    2574[0m:[38;5;10m[49m         "therapeutic_area", "").lower()
[0m[49m[38;5;10m+    2575[0m:[38;5;10m[49m     protocol_identifier = trial_context.get(
[0m[49m[38;5;10m+    2576[0m:[38;5;10m[49m         "protocol_identifier", "").lower()
[0m[49m[38;5;10m+    2577[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2578[0m:[38;5;10m[49m     spans = re.split(r"(?<=[.!?])\s+", response_text)
[0m[49m[38;5;10m+    2579[0m:[38;5;10m[49m     trial_specific_spans = [
[0m[49m[38;5;10m+    2580[0m:[38;5;10m[49m         s for s in spans
[0m[49m[38;5;10m+    2581[0m:[38;5;10m[49m         if therapeutic_area and therapeutic_area in s.lower()
[0m[49m[38;5;10m+    2582[0m:[38;5;10m[49m         or protocol_identifier and protocol_identifier in s.lower()
[0m[49m[38;5;10m+    2583[0m:[38;5;10m[49m         or " trial" in s.lower()
[0m[49m[38;5;10m+    2584[0m:[38;5;10m[49m         or " study" in s.lower()
[0m[49m[38;5;10m+    2585[0m:[38;5;10m[49m         or " medication" in s.lower()
[0m[49m[38;5;10m+    2586[0m:[38;5;10m[49m         or " visit" in s.lower()
[0m[49m[38;5;10m+    2587[0m:[38;5;10m[49m         or " procedure" in s.lower()
[0m[49m[38;5;10m+    2588[0m:[38;5;10m[49m         or " sponsor" in s.lower()
[0m[49m[38;5;10m+    2589[0m:[38;5;10m[49m         or " investigator" in s.lower()
[0m[49m[38;5;10m+    2590[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    2591[0m:[38;5;10m[49m     if trial_specific_spans:
[0m[49m[38;5;10m+    2592[0m:[38;5;10m[49m         coverage = (
[0m[49m[38;5;10m+    2593[0m:[38;5;10m[49m             min(1.0, len(citations)
[0m[49m[38;5;10m+    2594[0m:[38;5;10m[49m                 / max(1, len(trial_specific_spans))))
[0m[49m[38;5;10m+    2595[0m:[38;5;10m[49m         if Decimal(str(coverage)) < CITATION_COVERAGE_FLOOR:
[0m[49m[38;5;10m+    2596[0m:[38;5;10m[49m             findings.append({
[0m[49m[38;5;10m+    2597[0m:[38;5;10m[49m                 "category":              "CITATION_COVERAGE",
[0m[49m[38;5;10m+    2598[0m:[38;5;10m[49m                 "severity":              "BLOCK",
[0m[49m[38;5;10m+    2599[0m:[38;5;10m[49m                 "trial_specific_spans":  len(trial_specific_spans),
[0m[49m[38;5;10m+    2600[0m:[38;5;10m[49m                 "citation_count":        len(citations),
[0m[49m[38;5;10m+    2601[0m:[38;5;10m[49m                 "coverage":              coverage,
[0m[49m[38;5;10m+    2602[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    2603[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2604[0m:[38;5;10m[49m     # 3. First-turn disclosure check. The orchestration
[0m[49m[38;5;10m+    2605[0m:[38;5;10m[49m     #    prompt requires the IRB-approved disclosures to
[0m[49m[38;5;10m+    2606[0m:[38;5;10m[49m     #    appear on the first turn; the output-safety layer
[0m[49m[38;5;10m+    2607[0m:[38;5;10m[49m     #    verifies that the disclosures were surfaced (here
[0m[49m[38;5;10m+    2608[0m:[38;5;10m[49m     #    as a structural check on tool calls plus the
[0m[49m[38;5;10m+    2609[0m:[38;5;10m[49m     #    presence of disclosure-style language). The check
[0m[49m[38;5;10m+    2610[0m:[38;5;10m[49m     #    is illustrative; production verifies disclosure
[0m[49m[38;5;10m+    2611[0m:[38;5;10m[49m     #    surfacing against an explicit token taxonomy that
[0m[49m[38;5;10m+    2612[0m:[38;5;10m[49m     #    the IRB has approved.
[0m[49m[38;5;10m+    2613[0m:[38;5;10m[49m     is_first_turn = (conversation_state.get(
[0m[49m[38;5;10m+    2614[0m:[38;5;10m[49m         "turn_count", 0) <= 1)
[0m[49m[38;5;10m+    2615[0m:[38;5;10m[49m     disclosures_shown = conversation_state.get(
[0m[49m[38;5;10m+    2616[0m:[38;5;10m[49m         "disclosures_shown", [])
[0m[49m[38;5;10m+    2617[0m:[38;5;10m[49m     if is_first_turn:
[0m[49m[38;5;10m+    2618[0m:[38;5;10m[49m         # The first-turn response should mention the chat-
[0m[49m[38;5;10m+    2619[0m:[38;5;10m[49m         # tool-not-person disclosure and the can-stop-any-
[0m[49m[38;5;10m+    2620[0m:[38;5;10m[49m         # time disclosure at minimum.
[0m[49m[38;5;10m+    2621[0m:[38;5;10m[49m         if ("chat" not in response_text.lower()
[0m[49m[38;5;10m+    2622[0m:[38;5;10m[49m                 and "tool" not in response_text.lower()
[0m[49m[38;5;10m+    2623[0m:[38;5;10m[49m                 and DISCLOSURE_ASSISTANT_NOT_PERSON
[0m[49m[38;5;10m+    2624[0m:[38;5;10m[49m                 not in disclosures_shown):
[0m[49m[38;5;10m+    2625[0m:[38;5;10m[49m             findings.append({
[0m[49m[38;5;10m+    2626[0m:[38;5;10m[49m                 "category":     "MISSING_DISCLOSURE",
[0m[49m[38;5;10m+    2627[0m:[38;5;10m[49m                 "severity":     "WARN",
[0m[49m[38;5;10m+    2628[0m:[38;5;10m[49m                 "disclosure":   DISCLOSURE_ASSISTANT_NOT_PERSON,
[0m[49m[38;5;10m+    2629[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    2630[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2631[0m:[38;5;10m[49m     # 4. Off-corpus assertion check. The response must
[0m[49m[38;5;10m+    2632[0m:[38;5;10m[49m     #    not include trial-specific factual claims that
