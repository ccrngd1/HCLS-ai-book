[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m ## Configuration and Constants
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m Everything that is configuration rather than logic lives here. Resource names, model IDs, the per-visit-type protocol library, the validated-screener library, the acuity-pattern library, the persona templates, and the validation thresholds are what you would change between environments.
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m import re
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m import uuid
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m from collections import defaultdict
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m from datetime import datetime, timedelta, timezone
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m from typing import Optional
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m # Structured logging. In production, ship JSON-formatted records
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m # to CloudWatch Logs Insights for cross-call investigation.
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m # Conversation logs are dense PHI: the user's answers contain
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m # specific symptoms, medications, family history, mental-health
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m # disclosures, and substance-use disclosures. Log structural
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m # metadata only (session_id, intent, tool name, tool latency,
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m # tool outcome, protocol-position, screener-id), never raw user
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m # utterances, never raw generated responses, never tool arguments
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m # that contain identifiers, never specific HPI free-text or
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m # screener responses. The full transcripts and full tool calls
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m # live in the audit pipeline (Firehose plus Object-Lock S3) with
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m # appropriate access controls.
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m # Adaptive retry handles throttling from Bedrock, DynamoDB,
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m # EventBridge, Firehose, CloudWatch, S3, Comprehend Medical, and
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m # Secrets Manager. The intake-bot response window is moderate:
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m # the patient is filling this out asynchronously, so an extra
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m # second is acceptable. But the resume-friendliness depends on
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m # fast persistence, so cap the retries and let the graceful-
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m # failure path keep the patient's progress.
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m     retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m # Module-level clients. Reused across Lambda invocations in warm
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m # containers so each invocation does not pay the connection cost.
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m REGION = "us-east-1"
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m bedrock_runtime       = boto3.client("bedrock-runtime",
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m bedrock_agent_runtime = boto3.client("bedrock-agent-runtime",
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m comprehend_medical    = boto3.client("comprehendmedical",
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m dynamodb              = boto3.resource("dynamodb",
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m eventbridge_client    = boto3.client("events",
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m firehose_client       = boto3.client("firehose",
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m cloudwatch_client     = boto3.client("cloudwatch",
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m s3_client             = boto3.client("s3",
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m secrets_client        = boto3.client("secretsmanager",
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m # --- Resource Names ---
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m # Fill these in with your actual resource names. The demo prints
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m # what it would write rather than failing if the resources do not
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m # exist; see run_demo() at the bottom.
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m CONVERSATION_STATE_TABLE      = "intake-bot-conversation-state"
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m CONVERSATION_METADATA_TABLE   = "intake-bot-conversation-metadata"
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m TOOL_CALL_LEDGER_TABLE        = "intake-bot-tool-call-ledger"
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m PARTIAL_STATE_TABLE           = "intake-bot-partial-state"
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m FLAG_EVENTS_TABLE             = "intake-bot-flag-events"
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m INTAKE_EVENT_BUS_NAME         = "intake-bot-events-bus"
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m AUDIT_ARCHIVE_FIREHOSE_NAME   = "intake-bot-audit-archive"
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m PACKET_JOURNAL_BUCKET         = "intake-bot-packet-journal"
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m CLOUDWATCH_NAMESPACE          = "IntakeBot"
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m # Bedrock Knowledge Base ID for the conversational-template
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m # corpus (per-visit-type protocol-language phrasings, persona
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m # guidance, sensitive-item phrasings, screener-introduction
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m # templates, closing-summary templates).
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m KNOWLEDGE_BASE_ID             = "KB_PLACEHOLDER_ID"
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m # Bedrock Guardrail for restricted-topic filtering. Configure in
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m # the Bedrock console with restricted topics for clinical-advice,
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m # diagnostic-speculation, treatment-recommendation, and
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m # severity-assessment at minimum. Pin to a specific version, not
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m # DRAFT, in production.
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m GUARDRAIL_ID                  = "GUARDRAIL_PLACEHOLDER_ID"
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m GUARDRAIL_VERSION             = "1"
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m # Deploy-time guardrail. Any blank resource name is a deploy-time
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m # bug, not a runtime surprise.
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m for _name, _value in [
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m     ("CONVERSATION_STATE_TABLE",     CONVERSATION_STATE_TABLE),
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m     ("CONVERSATION_METADATA_TABLE",  CONVERSATION_METADATA_TABLE),
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m     ("TOOL_CALL_LEDGER_TABLE",       TOOL_CALL_LEDGER_TABLE),
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m     ("PARTIAL_STATE_TABLE",          PARTIAL_STATE_TABLE),
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m     ("FLAG_EVENTS_TABLE",            FLAG_EVENTS_TABLE),
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m     ("INTAKE_EVENT_BUS_NAME",        INTAKE_EVENT_BUS_NAME),
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m     ("AUDIT_ARCHIVE_FIREHOSE_NAME",  AUDIT_ARCHIVE_FIREHOSE_NAME),
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m     ("PACKET_JOURNAL_BUCKET",        PACKET_JOURNAL_BUCKET),
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m     ("CLOUDWATCH_NAMESPACE",         CLOUDWATCH_NAMESPACE),
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m     ("KNOWLEDGE_BASE_ID",            KNOWLEDGE_BASE_ID),
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m     ("GUARDRAIL_ID",                 GUARDRAIL_ID),
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m     ("GUARDRAIL_VERSION",            GUARDRAIL_VERSION),
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m ]:
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m     assert _value, f"{_name} must be set before deploying."
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m # --- Versioning ---
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m # Every conversation turn carries the model version, the prompt
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m # version, the Knowledge Base version, the Guardrail version,
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m # the active per-visit-type protocol version, the active
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m # screener-bundle version, the active acuity-pattern-library
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m # version, and the packet-schema version. This is how a future
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m # audit reconstructs which versions produced any given packet.
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m PROMPT_VERSION                  = "intake-bot-prompt-v2.0"
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m AGENT_VERSION                   = "intake-agent-v1.5"
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m ACUITY_PATTERN_LIBRARY_VERSION  = "acuity_patterns_v4.0"
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m PACKET_SCHEMA_VERSION           = "packet_schema_v1.2"
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m INSTITUTION_ID                  = "riverside-clinic"
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m INSTITUTION_DISPLAY_NAME        = "Riverside Clinic"
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m # --- Model IDs ---
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m # Two model roles. Question phrasing and structured extraction
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m # are per-turn tasks where the orchestration model handles tool
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m # choices and the extraction model produces the structured
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m # representation of HPI, ROS, history, and reconciliation outputs.
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m #
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m # If your region requires cross-region inference, use the
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m # inference profile ID. TODO: verify the exact model IDs
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m # available in your region and account; Bedrock model
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m # availability evolves over time.
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m EXTRACTION_MODEL_ID         = "anthropic.claude-3-5-haiku-20241022-v1:0"
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m ORCHESTRATION_MODEL_ID      = "anthropic.claude-3-5-sonnet-20241022-v2:0"
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m # --- Pipeline Tuning ---
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m # Below this confidence on a structured extraction, ask a gentle
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m # clarifying follow-up rather than acting on the wrong
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m # representation. Keep this on the conservative side; better to
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m # ask than to misrepresent the patient's answer.
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m EXTRACTION_CONFIDENCE_THRESHOLD = Decimal("0.70")
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m # Partial-state TTL. Tuned per visit type in production
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m # (typically 48-72 hours before the scheduled visit). The demo
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m # uses a single value for simplicity.
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m PARTIAL_STATE_TTL_SECONDS       = 60 * 60 * 72  # 72 hours
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m # Identity assurance. Most institutions require an authenticated
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m # portal session for intake delivery; the demo enforces this and
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m # the rest of the identity primitives flow from there.
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m REQUIRE_AUTHENTICATED_FOR_INTAKE = True
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m # --- Per-Visit-Type Protocol Library (illustrative) ---
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m # In production this is encoded as versioned policy artifacts
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m # reviewed by clinical informatics and the relevant clinical
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m # service lines, not as a Python dict. Each entry holds the
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m # question flow, the screener bundle, the relevant ROS systems,
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m # and the packet schema variant. The dict below is a starter for
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m # the demo only.
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m PROTOCOL_LIBRARY = {
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m     "primary_care_followup": {
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m         "version":          "primary_care_followup_v3.2",
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m         "question_flow": [
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m             # Order matters; the state machine walks it.
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m             {"id": "chief_complaint",        "category": "open"},
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m             {"id": "hpi_onset",              "category": "hpi",
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m              "dimension": "onset"},
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m             {"id": "hpi_provocation",        "category": "hpi",
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m              "dimension": "provocation"},
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m             {"id": "hpi_quality",            "category": "hpi",
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m              "dimension": "quality"},
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m             {"id": "hpi_radiation",          "category": "hpi",
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m              "dimension": "radiation"},
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m             {"id": "hpi_associated",         "category": "hpi",
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m              "dimension": "associated"},
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m             {"id": "hpi_timing",             "category": "hpi",
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m              "dimension": "timing"},
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m             {"id": "ros_cardiopulmonary",    "category": "ros",
