[0m[49m[38;5;10m+    2271[0m:[38;5;10m[49m     if response_value is None:
[0m[49m[38;5;10m+    2272[0m:[38;5;10m[49m         return {"action": "ask_clarification",
[0m[49m[38;5;10m+    2273[0m:[38;5;10m[49m                 "finding": None}
[0m[49m[38;5;10m+    2274[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2275[0m:[38;5;10m[49m     finding = {
[0m[49m[38;5;10m+    2276[0m:[38;5;10m[49m         "type":           "screener_item_response",
[0m[49m[38;5;10m+    2277[0m:[38;5;10m[49m         "screener_id":    screener_id,
[0m[49m[38;5;10m+    2278[0m:[38;5;10m[49m         "screener_version": screener.get("version"),
[0m[49m[38;5;10m+    2279[0m:[38;5;10m[49m         "item_id":        item.get("id"),
[0m[49m[38;5;10m+    2280[0m:[38;5;10m[49m         "item_text":      item.get("text"),
[0m[49m[38;5;10m+    2281[0m:[38;5;10m[49m         "response_value": response_value,
[0m[49m[38;5;10m+    2282[0m:[38;5;10m[49m         "response_text":  answer_text,
[0m[49m[38;5;10m+    2283[0m:[38;5;10m[49m         "captured_at":    _now_iso(),
[0m[49m[38;5;10m+    2284[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    2285[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2286[0m:[38;5;10m[49m     # Crisis-sensitive item handling. PHQ-9 item 9 is the
[0m[49m[38;5;10m+    2287[0m:[38;5;10m[49m     # canonical example.
[0m[49m[38;5;10m+    2288[0m:[38;5;10m[49m     if item.get("is_crisis_sensitive"):
[0m[49m[38;5;10m+    2289[0m:[38;5;10m[49m         crisis_values = item.get("crisis_response_values", [])
[0m[49m[38;5;10m+    2290[0m:[38;5;10m[49m         if response_value in crisis_values:
[0m[49m[38;5;10m+    2291[0m:[38;5;10m[49m             finding["crisis_signal"] = {
[0m[49m[38;5;10m+    2292[0m:[38;5;10m[49m                 "category":
[0m[49m[38;5;10m+    2293[0m:[38;5;10m[49m                     item.get("crisis_category"),
[0m[49m[38;5;10m+    2294[0m:[38;5;10m[49m                 "severity": "high",
[0m[49m[38;5;10m+    2295[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    2296[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2297[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    2298[0m:[38;5;10m[49m         "action":  "captured",
[0m[49m[38;5;10m+    2299[0m:[38;5;10m[49m         "finding": finding,
[0m[49m[38;5;10m+    2300[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    2301[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2302[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2303[0m:[38;5;10m[49m def _match_response_value(item: dict,
[0m[49m[38;5;10m+    2304[0m:[38;5;10m[49m                             answer_text: str
[0m[49m[38;5;10m+    2305[0m:[38;5;10m[49m                             ) -> Optional[int]:
[0m[49m[38;5;10m+    2306[0m:[38;5;10m[49m     """Map free-text to one of the screener item's response options."""
[0m[49m[38;5;10m+    2307[0m:[38;5;10m[49m     lowered = (answer_text or "").lower().strip()
[0m[49m[38;5;10m+    2308[0m:[38;5;10m[49m     for option in item.get("response_options", []):
[0m[49m[38;5;10m+    2309[0m:[38;5;10m[49m         if option["label"] in lowered:
[0m[49m[38;5;10m+    2310[0m:[38;5;10m[49m             return option["value"]
[0m[49m[38;5;10m+    2311[0m:[38;5;10m[49m     # Numeric-direct shortcut: patient typed "0", "1", "2", "3".
[0m[49m[38;5;10m+    2312[0m:[38;5;10m[49m     if lowered.isdigit():
[0m[49m[38;5;10m+    2313[0m:[38;5;10m[49m         value = int(lowered)
[0m[49m[38;5;10m+    2314[0m:[38;5;10m[49m         if any(o["value"] == value
[0m[49m[38;5;10m+    2315[0m:[38;5;10m[49m                for o in item.get("response_options", [])):
[0m[49m[38;5;10m+    2316[0m:[38;5;10m[49m             return value
[0m[49m[38;5;10m+    2317[0m:[38;5;10m[49m     return None
[0m[49m[38;5;10m+    2318[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2319[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2320[0m:[38;5;10m[49m def _compute_screener_score(screener_id: str,
[0m[49m[38;5;10m+    2321[0m:[38;5;10m[49m                               item_responses: list) -> dict:
[0m[49m[38;5;10m+    2322[0m:[38;5;10m[49m     """Compute the score for a completed screener."""
[0m[49m[38;5;10m+    2323[0m:[38;5;10m[49m     screener = SCREENER_LIBRARY.get(screener_id, {})
[0m[49m[38;5;10m+    2324[0m:[38;5;10m[49m     scoring = screener.get("scoring", {})
[0m[49m[38;5;10m+    2325[0m:[38;5;10m[49m     if scoring.get("method") != "sum":
[0m[49m[38;5;10m+    2326[0m:[38;5;10m[49m         return {"score": None, "band": None}
[0m[49m[38;5;10m+    2327[0m:[38;5;10m[49m     score = sum(r.get("response_value", 0)
[0m[49m[38;5;10m+    2328[0m:[38;5;10m[49m                 for r in item_responses)
[0m[49m[38;5;10m+    2329[0m:[38;5;10m[49m     band = None
[0m[49m[38;5;10m+    2330[0m:[38;5;10m[49m     for band_def in scoring.get("bands", []):
[0m[49m[38;5;10m+    2331[0m:[38;5;10m[49m         if (score >= band_def["min"]
[0m[49m[38;5;10m+    2332[0m:[38;5;10m[49m                 and score <= band_def["max"]):
[0m[49m[38;5;10m+    2333[0m:[38;5;10m[49m             band = band_def["band"]
