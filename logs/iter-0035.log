[0m[48;2;40;67;43m[39m+    254[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        A2 --> A5[Lambda<br/>Fetch Institutional Content][K
[0m[48;2;40;67;43m[39m+    255[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        A3 --> A6[S3 Raw Corpus][K
[0m[48;2;40;67;43m[39m+    256[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        A4 --> A6[K
[0m[48;2;40;67;43m[39m+    257[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        A5 --> A6[K
[0m[48;2;40;67;43m[39m+    258[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        A6 --> A7[Lambda or Batch<br/>Parse, Clean, Chunk][K
[0m[48;2;40;67;43m[39m+    259[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        A7 --> A8[Amazon Comprehend Medical<br/>Entity Tagging per Chunk][K
[0m[48;2;40;67;43m[39m+    260[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        A8 --> A9[Amazon Bedrock<br/>Titan/Cohere Embeddings][K
[0m[48;2;40;67;43m[39m+    261[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        A9 --> A10[OpenSearch<br/>Hybrid Index<br/>Vector + BM25 + Metadata][K
[0m[48;2;40;67;43m[39m+    262[0m:[39m[48;2;24;38;30m [38;2;192;197;206m    end[K
[0m[48;2;40;67;43m[39m+    263[0m:[39m[48;2;24;38;30m [K
[0m[48;2;40;67;43m[39m+    264[0m:[39m[48;2;24;38;30m [38;2;192;197;206m    subgraph Query[Query-Time Pipeline - Per Clinician Question][K
[0m[48;2;40;67;43m[39m+    265[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        B1[Clinician Question<br/>via EHR or Standalone UI] --> B2[API Gateway + Cognito][K
[0m[48;2;40;67;43m[39m+    266[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        B2 --> B3[Step Functions<br/>Query Workflow][K
