[0m[48;2;40;67;43m[39m+    315[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAmazon Bedrock Guardrails[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m Contextual grounding check, PII policies, content filters on the generated answer [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    316[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAmazon OpenSearch Service[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m Hybrid retrieval index: vectors + BM25 + metadata filters + re-ranking pipelines [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    317[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAmazon Comprehend Medical[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m Entity and relationship extraction for queries and for corpus chunks; ontology mapping to RxNorm and ICD-10 [38;2;192;197;206m|[K
