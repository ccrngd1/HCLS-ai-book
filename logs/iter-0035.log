[0m[48;2;40;67;43m[39m+    1060[0m:[39m[48;2;24;38;30m [38;2;191;97;106m-[38;2;191;97;106m [38;2;208;135;112m[[38;2;208;135;112mAmazon Comprehend Medical InferICD10CM[38;2;208;135;112m][38;2;208;135;112m([38;2;208;135;112mhttps://docs.aws.amazon.com/comprehend-medical/latest/dev/ontology-linking-icd10.html[38;2;208;135;112m)[K
[0m[48;2;40;67;43m[39m+    1061[0m:[39m[48;2;24;38;30m [38;2;191;97;106m-[38;2;191;97;106m [38;2;208;135;112m[[38;2;208;135;112mAWS Step Functions Parallel and Map States[38;2;208;135;112m][38;2;208;135;112m([38;2;208;135;112mhttps://docs.aws.amazon.com/step-functions/latest/dg/amazon-states-language-parallel-state.html[38;2;208;135;112m)[K
