[0m[48;2;40;67;43m[39m+    1055[0m:[39m[48;2;24;38;30m [38;2;191;97;106m-[38;2;191;97;106m [38;2;208;135;112m[[38;2;208;135;112mAmazon Titan Text Embeddings[38;2;208;135;112m][38;2;208;135;112m([38;2;208;135;112mhttps://docs.aws.amazon.com/bedrock/latest/userguide/titan-embedding-models.html[38;2;208;135;112m)[K
[0m[48;2;40;67;43m[39m+    1056[0m:[39m[48;2;24;38;30m [38;2;191;97;106m-[38;2;191;97;106m [38;2;208;135;112m[[38;2;208;135;112mAmazon OpenSearch Service k-NN[38;2;208;135;112m][38;2;208;135;112m([38;2;208;135;112mhttps://docs.aws.amazon.com/opensearch-service/latest/developerguide/knn.html[38;2;208;135;112m)[K
[0m[48;2;40;67;43m[39m+    1057[0m:[39m[48;2;24;38;30m [38;2;191;97;106m-[38;2;191;97;106m [38;2;208;135;112m[[38;2;208;135;112mAmazon OpenSearch Service Hybrid Search[38;2;208;135;112m][38;2;208;135;112m([38;2;208;135;112mhttps://docs.aws.amazon.com/opensearch-service/latest/developerguide/neural-search.html[38;2;208;135;112m)[K
