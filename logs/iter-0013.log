[0m[48;2;40;67;43m[39m+    469[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m------------[38;2;192;197;206m|[38;2;192;197;206m------[38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    470[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAmazon Kinesis Data Streams[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m Canonical surveillance-event stream [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    471[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAWS Lambda (encounter-ingest)[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m ED and urgent-care encounter ingestion (HL7 v2, FHIR) [38;2;192;197;206m|[K
