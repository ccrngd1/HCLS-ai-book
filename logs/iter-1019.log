[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m     FOR each assignment in assignments:
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m         write to DynamoDB "assignments" table:
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m             patient_id   = assignment.patient_id
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m             provider_id  = assignment.provider_id
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m             run_id       = run_id
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m             score        = assignment.score
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m             reasons      = assignment.reasons
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m             status       = "PENDING_REVIEW"
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m             created_at   = current UTC timestamp
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m     // Notify panel managers
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m     publish to SNS topic "panel-assignments":
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m         message = "{count} new assignments ready for review. Run ID: {run_id}"
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m     RETURN count of assignments stored
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m ```
