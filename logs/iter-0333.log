[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m │    principal, disclosure acknowledged]                    │
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m │                                                           │
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m └───────────────────────────────────────────────────────────┘
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m ┌────────── INPUT SAFETY + EMERGENCY SCREENING ────────────┐
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m │                                                           │
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m │   [Standard input safety primitives from recipe 11.1]     │
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m │    - Prompt-injection detection                           │
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m │    - PHI minimization                                     │
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m │                                                           │
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m │   [Emergency screening (carried over from recipes 11.6,   │
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m │    11.8 because the bot will encounter these even in      │
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m │    coordination conversations)]                           │
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m │    - Medical-emergency keyword and pattern detection      │
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m │      (chest pain, severe shortness of breath, stroke      │
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m │      symptoms, severe bleeding, etc.)                     │
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m │    - Mental-health-crisis screening                       │
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m │    - Sensitive-disclosure detection (intimate-partner     │
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m │      violence, child abuse, elder abuse, substance-use    │
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m │      crisis)                                              │
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m │    - Triggers appropriate emergency pathway immediately   │
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m │      regardless of conversation state                     │
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m │           │                                               │
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m │           ▼                                               │
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m │   [Output: input passes / input blocked / emergency       │
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m │    pathway triggered / sensitive disclosure flagged]      │
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m │                                                           │
