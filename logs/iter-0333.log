[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m │      - order_status_retrieve (lab, imaging, DME, home     │
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m │        health) and order_track                            │
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m │      - appointment_retrieve and appointment_propose       │
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m │      - prior_authorization_status_retrieve                │
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m │      - care_gap_retrieve                                  │
