[0m[49m[38;5;10m+    1888[0m:[38;5;10m[49m     return state.get("conversational_state", "idle")
[0m[49m[38;5;10m+    1889[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1890[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1891[0m:[38;5;10m[49m def halt_translation(translation_id):
[0m[49m[38;5;10m+    1892[0m:[38;5;10m[49m     """Halt an in-flight TTS playback. Production sends an
