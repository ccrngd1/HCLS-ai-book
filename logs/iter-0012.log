[0m[48;2;40;67;43m[39m+    1261[0m:[39m[48;2;24;38;30m [38;2;192;197;206m                    agg["mod25_claims"] += 1[K
[0m[48;2;40;67;43m[39m+    1262[0m:[39m[48;2;24;38;30m [38;2;192;197;206m            if line["code"] in DRUG_TEST_CODES:[K
[0m[48;2;40;67;43m[39m+    1263[0m:[39m[48;2;24;38;30m [38;2;192;197;206m                agg["drug_test_units"] += line["units"][K
[0m[48;2;40;67;43m[39m+    1264[0m:[39m[48;2;24;38;30m [K
[0m[48;2;40;67;43m[39m+    1265[0m:[39m[48;2;24;38;30m [38;2;192;197;206m    for pid, agg in by_provider.items():[K
[0m[48;2;40;67;43m[39m+    1266[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        em_total = max(agg["em_claims"], 1)[K
