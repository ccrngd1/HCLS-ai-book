[0m[49m[38;5;10m+    859[0m:[38;5;10m[49m cloudwatch            = MockCloudWatch()
[0m[49m[38;5;10m+    860[0m:[38;5;10m[49m connect_mock          = MockConnect()
[0m[49m[38;5;10m+    861[0m:[38;5;10m[49m chime_mock            = MockChimeSDK()
[0m[49m[38;5;10m+    862[0m:[38;5;10m[49m interpreter_pool      = MockHumanInterpreterPool()
[0m[49m[38;5;10m+    863[0m:[38;5;10m[49m polly_mock            = MockPolly()
