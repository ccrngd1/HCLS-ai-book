[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m     "permission for longer retention. By continuing, you "
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m     "consent to this interpretation method.")
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m CONSENT_DISCLOSURE_DEFAULT_ES = (
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     "Estamos usando un servicio de interpretacion por "
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m     "computadora para esta conversacion. Su voz esta "
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m     "siendo procesada por software automatizado para "
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m     "traducir entre ingles y su idioma preferido. Puede "
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m     "solicitar un interprete humano en cualquier momento, "
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m     "y su atencion no se demorara si lo hace. Las "
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m     "grabaciones de audio se eliminaran despues del "
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m     "encuentro a menos que usted otorgue permiso "
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m     "especifico para una retencion mas prolongada. Al "
