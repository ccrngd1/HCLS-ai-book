[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m # update cadence.
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m # TODO (TechWriter): verify the current biometric-data-law
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m # state list against the IAPP biometric-privacy tracker
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m # before deploying.
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m BIOMETRIC_DATA_LAW_STATES = {"IL", "TX", "WA"}
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m # --- Topic Category to Deployment Posture Mapping ---
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m # The institutional language-access policy owns this mapping.
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m # Production maintains it as a clinical-operations-reviewed
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m # configuration with explicit version history; the demo
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m # uses an illustrative set.
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m TOPIC_TO_POSTURE = {
