[0m[49m[38;5;10m+    1938[0m:[38;5;10m[49m                 speaker != state.get(
[0m[49m[38;5;10m+    1939[0m:[38;5;10m[49m                     "translating_for_speaker"):
[0m[49m[38;5;10m+    1940[0m:[38;5;10m[49m             handle_barge_in(
[0m[49m[38;5;10m+    1941[0m:[38;5;10m[49m                 encounter_id=encounter_id,
[0m[49m[38;5;10m+    1942[0m:[38;5;10m[49m                 interrupting_speaker=speaker,
[0m[49m[38;5;10m+    1943[0m:[38;5;10m[49m                 in_flight_translation=state.get(
[0m[49m[38;5;10m+    1944[0m:[38;5;10m[49m                     "in_flight_translation", {}))
[0m[49m[38;5;10m+    1945[0m:[38;5;10m[49m             transition_to_state(
