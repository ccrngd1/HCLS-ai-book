[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG_ASYNC = Config(
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m     retries={"max_attempts": 6, "mode": "adaptive"})
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m 
