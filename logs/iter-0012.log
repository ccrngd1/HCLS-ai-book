[0m[49m[38;5;10m+    2003[0m:[38;5;10m[49m         "has_pre_staged":   pre_staged_session is not None,
[0m[49m[38;5;10m+    2004[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    2005[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2006[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2007[0m:[38;5;10m[49m def determine_urgency(topic_category, reason):
