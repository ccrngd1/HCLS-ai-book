[0m[49m[38;5;10m+    2769[0m:[38;5;10m[49m         topic_category="routine_clinical",
[0m[49m[38;5;10m+    2770[0m:[38;5;10m[49m         conversation_segments=conversation,
[0m[49m[38;5;10m+    2771[0m:[38;5;10m[49m         encounter_id_hint=encounter_id_demo)
[0m[49m[38;5;10m+    2772[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2773[0m:[38;5;10m[49m     # Summarize the demo run for visibility.
[0m[49m[38;5;10m+    2774[0m:[38;5;10m[49m     audit = result.get("audit_record", {})
[0m[49m[38;5;10m+    2775[0m:[38;5;10m[49m     summary = {
[0m[49m[38;5;10m+    2776[0m:[38;5;10m[49m         "status":          result.get("status"),
[0m[49m[38;5;10m+    2777[0m:[38;5;10m[49m         "encounter_id":
[0m[49m[38;5;10m+    2778[0m:[38;5;10m[49m             result.get("encounter_id"),
[0m[49m[38;5;10m+    2779[0m:[38;5;10m[49m         "language_pair":
[0m[49m[38;5;10m+    2780[0m:[38;5;10m[49m             audit.get("language_pair"),
[0m[49m[38;5;10m+    2781[0m:[38;5;10m[49m         "posture":
[0m[49m[38;5;10m+    2782[0m:[38;5;10m[49m             audit.get("deployment_posture"),
