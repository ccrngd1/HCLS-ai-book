[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m     "self_service":             "machine_only",
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m     "routine_clinical":         "machine_with_human_standby",
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m     "patient_education":        "machine_with_human_standby",
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m     "safety_critical":          "human_primary_with_machine_assistance",
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m     "informed_consent":         "human_only",
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m     "mental_health_crisis":     "human_only",
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m     "end_of_life":              "human_only",
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m     "complex_new_diagnosis":    "human_only",
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m # --- Per-Pair Configuration Definitions ---
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m # Each language pair stores the validated vendor selection,
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m # the medical-vocabulary and custom-terminology IDs, the per-
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m # pair confidence threshold (often tuned tighter for low-
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m # resource pairs), and the deployment status. Production
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m # reads these from DynamoDB; the demo uses an in-memory dict.
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m LANGUAGE_PAIR_CONFIGS = {
