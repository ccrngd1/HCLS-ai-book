[0m[49m[38;5;10m+    754[0m:[38;5;10m[49m                 "briefing_id":
[0m[49m[38;5;10m+    755[0m:[38;5;10m[49m                     f"brief-{uuid.uuid4().hex[:8]}"}
[0m[49m[38;5;10m+    756[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    757[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    758[0m:[38;5;10m[49m class MockEncounterTable:
[0m[49m[38;5;10m+    759[0m:[38;5;10m[49m     """In-memory stand-in for the DynamoDB encounter table.
[0m[49m[38;5;10m+    760[0m:[38;5;10m[49m     Each entry tracks one encounter session through the
[0m[49m[38;5;10m+    761[0m:[38;5;10m[49m     seven pipeline stages."""
[0m[49m[38;5;10m+    762[0m:[38;5;10m[49m     def __init__(self):
[0m[49m[38;5;10m+    763[0m:[38;5;10m[49m         self._items = {}
[0m[49m[38;5;10m+    764[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    765[0m:[38;5;10m[49m     def get(self, encounter_id):
[0m[49m[38;5;10m+    766[0m:[38;5;10m[49m         return dict(self._items.get(encounter_id, {}))
[0m[49m[38;5;10m+    767[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    768[0m:[38;5;10m[49m     def put(self, encounter_id, item):
[0m[49m[38;5;10m+    769[0m:[38;5;10m[49m         self._items[encounter_id] = dict(item)
[0m[49m[38;5;10m+    770[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    771[0m:[38;5;10m[49m     def update(self, encounter_id, updates):
[0m[49m[38;5;10m+    772[0m:[38;5;10m[49m         existing = self._items.setdefault(
[0m[49m[38;5;10m+    773[0m:[38;5;10m[49m             encounter_id, {"encounter_id": encounter_id})
[0m[49m[38;5;10m+    774[0m:[38;5;10m[49m         existing.update(updates)
[0m[49m[38;5;10m+    775[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    776[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    777[0m:[38;5;10m[49m class MockAuditTable:
[0m[49m[38;5;10m+    778[0m:[38;5;10m[49m     """In-memory stand-in for the DynamoDB per-utterance
[0m[49m[38;5;10m+    779[0m:[38;5;10m[49m     audit table."""
[0m[49m[38;5;10m+    780[0m:[38;5;10m[49m     def __init__(self):
[0m[49m[38;5;10m+    781[0m:[38;5;10m[49m         self._items = []
[0m[49m[38;5;10m+    782[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    783[0m:[38;5;10m[49m     def put(self, item):
[0m[49m[38;5;10m+    784[0m:[38;5;10m[49m         self._items.append(dict(item))
[0m[49m[38;5;10m+    785[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    786[0m:[38;5;10m[49m     def query_by_encounter(self, encounter_id):
[0m[49m[38;5;10m+    787[0m:[38;5;10m[49m         return [dict(item) for item in self._items
[0m[49m[38;5;10m+    788[0m:[38;5;10m[49m                   if item.get("encounter_id") ==
[0m[49m[38;5;10m+    789[0m:[38;5;10m[49m                      encounter_id]
[0m[49m[38;5;10m+    790[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    791[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    792[0m:[38;5;10m[49m class MockS3:
[0m[49m[38;5;10m+    793[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    794[0m:[38;5;10m[49m     Stands in for S3 audio storage and audit archive. Holds
[0m[49m[38;5;10m+    795[0m:[38;5;10m[49m     objects in memory keyed by (bucket, key). Production uses
[0m[49m[38;5;10m+    796[0m:[38;5;10m[49m     customer-managed KMS keys for encryption and lifecycle
[0m[49m[38;5;10m+    797[0m:[38;5;10m[49m     policies for retention.
[0m[49m[38;5;10m+    798[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    799[0m:[38;5;10m[49m     def __init__(self):
[0m[49m[38;5;10m+    800[0m:[38;5;10m[49m         self._objects = {}
[0m[49m[38;5;10m+    801[0m:[38;5;10m[49m         self.deletion_log = []
[0m[49m[38;5;10m+    802[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    803[0m:[38;5;10m[49m     def put_object(self, bucket, key, body, metadata=None):
[0m[49m[38;5;10m+    804[0m:[38;5;10m[49m         self._objects[(bucket, key)] = {
[0m[49m[38;5;10m+    805[0m:[38;5;10m[49m             "body":      body,
[0m[49m[38;5;10m+    806[0m:[38;5;10m[49m             "metadata":  dict(metadata or {}),
[0m[49m[38;5;10m+    807[0m:[38;5;10m[49m             "stored_at": _now_iso(),
[0m[49m[38;5;10m+    808[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    809[0m:[38;5;10m[49m         return {"bucket": bucket, "key": key,
[0m[49m[38;5;10m+    810[0m:[38;5;10m[49m                 "uri":    f"s3://{bucket}/{key}"}
[0m[49m[38;5;10m+    811[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    812[0m:[38;5;10m[49m     def get_object(self, bucket, key):
[0m[49m[38;5;10m+    813[0m:[38;5;10m[49m         return dict(self._objects.get((bucket, key), {}))
[0m[49m[38;5;10m+    814[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    815[0m:[38;5;10m[49m     def delete_object(self, bucket, key, reason="lifecycle"):
[0m[49m[38;5;10m+    816[0m:[38;5;10m[49m         if (bucket, key) in self._objects:
[0m[49m[38;5;10m+    817[0m:[38;5;10m[49m             del self._objects[(bucket, key)]
[0m[49m[38;5;10m+    818[0m:[38;5;10m[49m         self.deletion_log.append({
[0m[49m[38;5;10m+    819[0m:[38;5;10m[49m             "bucket":     bucket,
[0m[49m[38;5;10m+    820[0m:[38;5;10m[49m             "key":        key,
[0m[49m[38;5;10m+    821[0m:[38;5;10m[49m             "reason":     reason,
[0m[49m[38;5;10m+    822[0m:[38;5;10m[49m             "deleted_at": _now_iso(),
[0m[49m[38;5;10m+    823[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    824[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    825[0m:[38;5;10m[49m 
