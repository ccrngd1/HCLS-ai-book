[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m polly_client        = boto3.client("polly", region_name=REGION,
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m                                        config=BOTO3_RETRY_CONFIG_REALTIME)
