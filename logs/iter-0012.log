[0m[49m[38;5;10m+    1894[0m:[38;5;10m[49m     pending audio buffer; the demo just logs."""
[0m[49m[38;5;10m+    1895[0m:[38;5;10m[49m     audit_log({
[0m[49m[38;5;10m+    1896[0m:[38;5;10m[49m         "event_type":      "TRANSLATION_HALTED",
[0m[49m[38;5;10m+    1897[0m:[38;5;10m[49m         "translation_id":  translation_id,
[0m[49m[38;5;10m+    1898[0m:[38;5;10m[49m         "timestamp":       _now_iso(),
[0m[49m[38;5;10m+    1899[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    1900[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1901[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1902[0m:[38;5;10m[49m def handle_barge_in(encounter_id, interrupting_speaker,
[0m[49m[38;5;10m+    1903[0m:[38;5;10m[49m                        in_flight_translation):
[0m[49m[38;5;10m+    1904[0m:[38;5;10m[49m     """A new speaker started before the system finished
[0m[49m[38;5;10m+    1905[0m:[38;5;10m[49m     translating the previous turn. Halt TTS gracefully and
