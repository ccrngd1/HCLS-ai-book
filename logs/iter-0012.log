[0m[48;2;40;67;43m[39m+    1269[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        agg["drug_test_units_per_patient"] = ([K
[0m[48;2;40;67;43m[39m+    1270[0m:[39m[48;2;24;38;30m [38;2;192;197;206m            agg["drug_test_units"] / max(len(agg["unique_patients"]), 1)[K
