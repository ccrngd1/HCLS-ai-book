[0m[49m[38;5;10m+    1947[0m:[38;5;10m[49m                 active_speaker=speaker)
[0m[49m[38;5;10m+    1948[0m:[38;5;10m[49m         elif current_state == "playing_translation" and \
[0m[49m[38;5;10m+    1949[0m:[38;5;10m[49m                 speaker == state.get(
[0m[49m[38;5;10m+    1950[0m:[38;5;10m[49m                     "target_audience_speaker"):
[0m[49m[38;5;10m+    1951[0m:[38;5;10m[49m             handle_barge_in(
[0m[49m[38;5;10m+    1952[0m:[38;5;10m[49m                 encounter_id=encounter_id,
[0m[49m[38;5;10m+    1953[0m:[38;5;10m[49m                 interrupting_speaker=speaker,
[0m[49m[38;5;10m+    1954[0m:[38;5;10m[49m                 in_flight_translation=state.get(
