[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m # the real clients are never invoked here.
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m REGION = "us-east-1"
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m dynamodb            = boto3.resource("dynamodb", region_name=REGION,
