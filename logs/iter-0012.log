[0m[49m[38;5;10m+    848[0m:[38;5;10m[49m             "dimensions":  dimensions or {},
[0m[49m[38;5;10m+    849[0m:[38;5;10m[49m             "timestamp":   _now_iso(),
[0m[49m[38;5;10m+    850[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    851[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    852[0m:[38;5;10m[49m 
