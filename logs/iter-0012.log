[0m[49m[38;5;10m+    2628[0m:[38;5;10m[49m         f"s3://{AUDIO_BUCKET}/{encounter_id_demo}/patient.ogg":
[0m[49m[38;5;10m+    2629[0m:[38;5;10m[49m             [],
