[0m[49m[38;5;10m+    1878[0m:[38;5;10m[49m     updates = {
[0m[49m[38;5;10m+    1879[0m:[38;5;10m[49m         "conversational_state": new_state,
[0m[49m[38;5;10m+    1880[0m:[38;5;10m[49m         "last_state_change_at": _now_iso(),
[0m[49m[38;5;10m+    1881[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1882[0m:[38;5;10m[49m     updates.update(extra)
[0m[49m[38;5;10m+    1883[0m:[38;5;10m[49m     encounter_table.update(encounter_id, _to_decimal(updates))
[0m[49m[38;5;10m+    1884[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1885[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1886[0m:[38;5;10m[49m def get_current_state(encounter_id):
