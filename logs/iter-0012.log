[0m[49m[38;5;10m+    1916[0m:[38;5;10m[49m         "timestamp":       _now_iso(),
[0m[49m[38;5;10m+    1917[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    1918[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1919[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1920[0m:[38;5;10m[49m def vad_event(encounter_id, speaker, event_type):
[0m[49m[38;5;10m+    1921[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1922[0m:[38;5;10m[49m     VAD events (speech_start, speech_end, silence) drive the
