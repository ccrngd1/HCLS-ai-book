[0m[49m[38;5;10m+    740[0m:[38;5;10m[49m             "dialect":         dialect,
[0m[49m[38;5;10m+    741[0m:[38;5;10m[49m             "encounter_type":  encounter_type,
[0m[49m[38;5;10m+    742[0m:[38;5;10m[49m             "urgency":         urgency,
[0m[49m[38;5;10m+    743[0m:[38;5;10m[49m             "dispatch_time":   _now_iso(),
