[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m # --- Helpers ---
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m # DynamoDB rejects native Python float. Every numeric value on
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m # its way into DynamoDB has to be a Decimal. This helper
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m # handles nested dicts and lists.
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m def _to_decimal(value):
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m     if isinstance(value, float):
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m         return Decimal(str(value))
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m     if isinstance(value, dict):
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m         return {k: _to_decimal(v) for k, v in value.items()}
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m     if isinstance(value, list):
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m         return [_to_decimal(v) for v in value]
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m     return value
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m def _hash_value(value):
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m     """Stable hash for non-PHI audit linkage."""
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m     if not value:
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m     return hashlib.sha256(str(value).encode("utf-8")).hexdigest()
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m def _now_iso():
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m     return datetime.now(timezone.utc).isoformat()
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m def _select_consent_disclosure(language, jurisdiction):
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m     """Pick the appropriate disclosure language and any
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m     jurisdiction-specific overlay (BIPA for Illinois, etc.)."""
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m     base = (CONSENT_DISCLOSURE_DEFAULT_ES
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m             if language.startswith("es")
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m             else CONSENT_DISCLOSURE_DEFAULT_EN)
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m     overlay = (CONSENT_DISCLOSURE_BIPA_OVERLAY_EN
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m                 if jurisdiction in BIOMETRIC_DATA_LAW_STATES
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m                 else None)
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m     if overlay:
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m         return f"{base}\n\n{overlay}"
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m     return base
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m def audit_log(event):
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m     Sanitized audit print so you can see the sequence of
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m     decisions without leaking the underlying values. Production
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m     routes events to CloudWatch Logs Insights with structured
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m     JSON; ship to a SIEM if available. Voice samples are
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m     biometric; never include the audio reference itself in
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m     routine audit logs, never include source or target
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m     transcript content that could capture spontaneous PHI,
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m     never include patient demographics that could enable
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m     re-identification.
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m     safe_event = {k: v for k, v in event.items()
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m                   if k not in {"audio_ref", "source_text",
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m                                 "target_text",
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m                                 "patient_demographics"}}
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m     if "audio_ref" in event:
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m         safe_event["audio_ref_hash"] = _hash_value(
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m             event["audio_ref"])
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m     logger.info("AUDIT %s",
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m                   json.dumps(safe_event, default=str))
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m ```
