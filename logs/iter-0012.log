[0m[49m[38;5;10m+    1956[0m:[38;5;10m[49m             transition_to_state(
[0m[49m[38;5;10m+    1957[0m:[38;5;10m[49m                 encounter_id, "speaker_active",
[0m[49m[38;5;10m+    1958[0m:[38;5;10m[49m                 active_speaker=speaker)
