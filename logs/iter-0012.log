[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m     def pre_stage_interpreter(self, language, dialect,
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m                                   encounter_type):
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m         session_id = f"interp-standby-{uuid.uuid4().hex[:10]}"
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m         self.standby_sessions[session_id] = {
