[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m CONSENT_DISCLOSURE_BIPA_OVERLAY_EN = (
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m     "Under Illinois law, we are specifically informing you "
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m     "that voice recordings are biometric data. We are "
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m     "collecting them for the medical-interpretation purpose "
