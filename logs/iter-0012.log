[0m[49m[38;5;10m+    2785[0m:[38;5;10m[49m         "escalation_count":
[0m[49m[38;5;10m+    2786[0m:[38;5;10m[49m             len(audit.get("escalation_events", []) or []),
[0m[49m[38;5;10m+    2787[0m:[38;5;10m[49m         "modes_used":
[0m[49m[38;5;10m+    2788[0m:[38;5;10m[49m             audit.get("modes_used"),
[0m[49m[38;5;10m+    2789[0m:[38;5;10m[49m         "audit_archive_ref":
[0m[49m[38;5;10m+    2790[0m:[38;5;10m[49m             (encounter_table.get(
[0m[49m[38;5;10m+    2791[0m:[38;5;10m[49m                 result.get("encounter_id")) or {}).get(
[0m[49m[38;5;10m+    2792[0m:[38;5;10m[49m                 "audit_archive_ref"),
