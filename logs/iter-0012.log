[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m                                        config=BOTO3_RETRY_CONFIG_ASYNC)
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m cloudwatch_client   = boto3.client("cloudwatch", region_name=REGION,
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m                                        config=BOTO3_RETRY_CONFIG_ASYNC)
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m secrets_client      = boto3.client("secretsmanager",
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m                                        region_name=REGION,
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m                                        config=BOTO3_RETRY_CONFIG_ASYNC)
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m # --- Resource Names ---
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m # Fill these in with your actual resource names. The demo
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m # prints what it would write rather than failing if the
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m # resources do not exist.
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m ENCOUNTER_TABLE              = "medical-interpretation-encounters"
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m AUDIT_TABLE                  = "medical-interpretation-audit"
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m LANGUAGE_PAIR_CONFIG_TABLE   = "medical-interpretation-pair-configs"
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m AUDIO_BUCKET                 = "medical-interpretation-audio"
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m AUDIT_ARCHIVE_BUCKET         = "medical-interpretation-audit-archive"
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m EVENT_BUS_NAME               = "medical-interpretation-events-bus"
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m CLOUDWATCH_NAMESPACE         = "MedicalInterpretation"
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m INSTITUTION_ID               = "academic-medical-center-richmond"
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m # Bedrock configuration. In production, pin to a specific
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m # model version and inference profile so a model upgrade does
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m # not silently change translation behavior. The model and
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m # region combination must be in your AWS BAA scope.
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m BEDROCK_TRANSLATION_MODEL_ID = (
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m     "anthropic.claude-3-5-sonnet-20240620-v1:0")
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m BEDROCK_TRANSLATION_PROFILE_ARN = (
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m     "arn:aws:bedrock:us-east-1:000000000000:inference-profile/"
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m     "medical-interpretation-translation-v1")
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m BEDROCK_FAITHFULNESS_MODEL_ID = (
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m     "anthropic.claude-3-haiku-20240307-v1:0")
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m TRANSLATION_GUARDRAIL_ID = "guardrail-medical-translation-v1"
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m TRANSLATION_GUARDRAIL_VERSION = "2"
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m # Deploy-time guardrail. Any blank resource name is a deploy-
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m # time bug, not a runtime surprise.
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m for _name, _value in [
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m     ("ENCOUNTER_TABLE",             ENCOUNTER_TABLE),
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m     ("AUDIT_TABLE",                 AUDIT_TABLE),
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m     ("LANGUAGE_PAIR_CONFIG_TABLE",  LANGUAGE_PAIR_CONFIG_TABLE),
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m     ("AUDIO_BUCKET",                AUDIO_BUCKET),
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m     ("AUDIT_ARCHIVE_BUCKET",        AUDIT_ARCHIVE_BUCKET),
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m     ("EVENT_BUS_NAME",              EVENT_BUS_NAME),
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m     ("CLOUDWATCH_NAMESPACE",        CLOUDWATCH_NAMESPACE),
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m     ("BEDROCK_TRANSLATION_MODEL_ID",
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m         BEDROCK_TRANSLATION_MODEL_ID),
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m ]:
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m     assert _value, f"{_name} must be set before deploying."
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m # --- Versioning ---
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m # Every encounter carries the versions of the artifacts that
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m # influenced its translations: per-pair ASR and MT engine
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m # versions, the medical-vocabulary and custom-terminology
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m # version, the LLM-translation prompt version, the
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m # faithfulness-verifier prompt version, and the Polly voice
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m # version. A future audit reconstructs which configuration
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m # was active when a particular utterance was translated.
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m ASR_PIPELINE_VERSION             = "asr-pipeline-2026-q1"
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m MT_PIPELINE_VERSION              = "mt-pipeline-2026-q1"
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m TTS_PIPELINE_VERSION             = "tts-pipeline-2026-q1"
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m TRANSLATION_PROMPT_VERSION       = "translation-prompt-v2.1"
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m FAITHFULNESS_PROMPT_VERSION      = "faithfulness-prompt-v1.4"
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m # --- Confidence and Quality Thresholds ---
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m # Per-segment translation confidence below this threshold
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m # triggers escalation review or render-with-warning depending
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m # on the deployment posture. Per-word ASR confidence below
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m # this threshold contributes to escalation decisions on the
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m # upstream side.
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m DEFAULT_TRANSLATION_CONFIDENCE_THRESHOLD = Decimal("0.78")
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m DEFAULT_ASR_CONFIDENCE_THRESHOLD         = Decimal("0.72")
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m DEFAULT_FAITHFULNESS_THRESHOLD           = Decimal("0.85")
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m # --- Latency Budgets ---
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m # End-to-end latency budget per utterance: from end-of-source-
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m # audio to start-of-target-audio playback. Budget overruns are
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m # tracked and alarmed; sustained overruns trigger automatic
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m # escalation to human interpretation.
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m LATENCY_BUDGET_P50_MS = 1800
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m LATENCY_BUDGET_P95_MS = 2800
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m # --- Audio Quality Thresholds ---
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m DEFAULT_MIN_SAMPLE_RATE_HZ      = 16000
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m DEFAULT_MIN_SNR_DB              = Decimal("10.0")
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m # --- Endpointing Thresholds ---
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m # Silence threshold for end-of-utterance detection. Aggressive
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m # (short) values reduce latency but produce more mid-sentence
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m # cutoffs; conservative (long) values produce cleaner segments
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m # at the cost of latency. Per-topic-category configuration:
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m # routine clinical uses moderate values, sensitive content
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m # (mental health, end-of-life) uses longer thresholds to give
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m # the speaker space.
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m ENDPOINTING_THRESHOLDS_MS = {
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m     "administrative":           500,
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m     "routine_clinical":         700,
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m     "safety_critical":          1100,
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m     "mental_health":            1400,
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m     "end_of_life":              1500,
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m # --- Consent Disclosures ---
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m # Voice samples are biometric. The disclosure language differs
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m # by jurisdiction (Illinois BIPA, Texas, Washington each have
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m # specific requirements), by EU patients (GDPR Article 9 adds
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m # explicit-consent and right-to-erasure framing), and by
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m # language. The disclosure must be presented in the patient's
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m # preferred language, validated per language by native
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m # speakers, and at an appropriate literacy level. Production
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m # looks up the patient's jurisdiction and language; the demo
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m # uses illustrative defaults.
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m # TODO (TechWriter): consent disclosure text below is
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m # illustrative-only. Production deployment requires native-
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m # speaker-validated translations per language with attention
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m # to literacy level and cultural framing.
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m CONSENT_DISCLOSURE_DEFAULT_EN = (
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m     "We are using a computer-based interpretation service "
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m     "for this conversation. Your voice is being processed "
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m     "by automated software to translate between English "
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m     "and your preferred language. You can ask for a human "
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m     "interpreter at any time, and your care will not be "
