[0m[48;2;40;67;43m[39m+    700[0m:[39m[48;2;24;38;30m [38;2;192;197;206m    return record[K
[0m[48;2;40;67;43m[39m+    701[0m:[39m[48;2;24;38;30m [K
[0m[48;2;40;67;43m[39m+    702[0m:[39m[48;2;24;38;30m [K
[0m[48;2;40;67;43m[39m+    703[0m:[39m[48;2;24;38;30m [38;2;192;197;206m# Example: run the pipeline against a sample discharge summary.[K
[0m[48;2;40;67;43m[39m+    704[0m:[39m[48;2;24;38;30m [38;2;192;197;206mif __name__ == "__main__":[K
[0m[48;2;40;67;43m[39m+    705[0m:[39m[48;2;24;38;30m [38;2;192;197;206m    sample_clinical_text = ([K
[0m[48;2;40;67;43m[39m+    706[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        "Patient experienced acute ST-elevation myocardial infarction with "[K
[0m[48;2;40;67;43m[39m+    707[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        "subsequent percutaneous coronary intervention via drug-eluting stent "[K
[0m[48;2;40;67;43m[39m+    708[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        "placement in the left anterior descending artery. Continue dual "[K
[0m[48;2;40;67;43m[39m+    709[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        "antiplatelet therapy with aspirin 81mg and clopidogrel 75mg daily "[K
[0m[48;2;40;67;43m[39m+    710[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        "for 12 months. Avoid NSAIDs. Follow up with cardiology in 2 weeks "[K
[0m[48;2;40;67;43m[39m+    711[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        "for post-PCI assessment."[K
[0m[48;2;40;67;43m[39m+    712[0m:[39m[48;2;24;38;30m [38;2;192;197;206m    )[K
[0m[48;2;40;67;43m[39m+    713[0m:[39m[48;2;24;38;30m [K
