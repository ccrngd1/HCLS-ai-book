[0m[48;2;40;67;43m[39m+    285[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        I7 --> I8[Bedrock Embeddings][K
[0m[48;2;40;67;43m[39m+    286[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        I8 --> I9[OpenSearch<br/>Guidelines + Protocols][K
[0m[48;2;40;67;43m[39m+    287[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        I7 --> I10[Aurora pgvector<br/>Drug Tables + Embeddings][K
[0m[48;2;40;67;43m[39m+    288[0m:[39m[48;2;24;38;30m [38;2;192;197;206m    end[K
[0m[48;2;40;67;43m[39m+    289[0m:[39m[48;2;24;38;30m [K
