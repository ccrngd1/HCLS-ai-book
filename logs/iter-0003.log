[0m[48;2;40;67;43m[39m+    683[0m:[39m[48;2;24;38;30m [38;2;192;197;206m    logger.info("Step 7: Storing result in DynamoDB")[K
[0m[48;2;40;67;43m[39m+    684[0m:[39m[48;2;24;38;30m [38;2;192;197;206m    readability = quality_result.get("readability", score_readability(simplified_text))[K
[0m[48;2;40;67;43m[39m+    685[0m:[39m[48;2;24;38;30m [38;2;192;197;206m    record = store_result([K
[0m[48;2;40;67;43m[39m+    686[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        document_id=document_id,[K
[0m[48;2;40;67;43m[39m+    687[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        original_text=clinical_text,[K
[0m[48;2;40;67;43m[39m+    688[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        simplified_text=simplified_text,[K
[0m[48;2;40;67;43m[39m+    689[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        doc_type=doc_type,[K
[0m[48;2;40;67;43m[39m+    690[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        quality_result=quality_result,[K
[0m[48;2;40;67;43m[39m+    691[0m:[39m[48;2;24;38;30m [38;2;192;197;206m        readability=readability,[K
