[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m │      determinant-resource utilization, patient-reported   │
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m │      coordination experience                              │
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m │           │                                               │
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m │           ▼                                               │
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m │   [Output: care-team visibility into assistant activity   │
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m │    (consent-gated); outcome metrics for clinical and      │
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m │    operational review]                                    │
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m │                                                           │
