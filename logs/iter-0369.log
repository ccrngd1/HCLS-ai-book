[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m ┌────────── CARE-TEAM REPORTING (CONSENT-GATED) ───────────┐
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m │                                                           │
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m │   [Real-time alerts]                                      │
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m │    - Service-level breaches affecting the patient         │
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m │    - Concerning trajectory patterns                       │
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m │    - Sensitive-disclosure events (with appropriate        │
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m │      consent)                                             │
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m │    - Care-transition risk indicators                      │
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m │                                                           │
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m │   [Periodic reports (consent-gated)]                      │
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m │    - Weekly digest per patient (engagement, coordination  │
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m │      activity, open referrals, social-determinant flags,  │
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m │      patient-stated concerns)                             │
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m │    - Monthly summary per patient                          │
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m │    - Care-transition completion summaries                 │
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m │                                                           │
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m │   [Care-team feedback loop]                               │
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m │    - Care manager marks alerts as actioned                │
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m │    - Care team flags inappropriate assistant responses    │
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m │      for review                                           │
