[0m[48;2;40;67;43m[39m+    488[0m:[39m[48;2;24;38;30m [38;2;191;97;106m-[38;2;191;97;106m [38;2;235;203;139m**[38;2;235;203;139mExpert:[38;2;235;203;139m**[38;2;191;97;106m Networking[K
[0m[48;2;40;67;43m[39m+    489[0m:[39m[48;2;24;38;30m [38;2;191;97;106m-[38;2;191;97;106m [38;2;235;203;139m**[38;2;235;203;139mLocation:[38;2;235;203;139m**[38;2;191;97;106m See Architecture Finding A5.[K
