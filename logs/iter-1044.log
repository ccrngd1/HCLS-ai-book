[0m[49m[39m  375, 387[0m:[39m[49m FUNCTION handle_calloff(calloff_event):
[0m[49m[39m  376, 388[0m:[39m[49m     // A nurse has called off. We need coverage.
[0m[49m[39m  377, 389[0m:[39m[49m     // calloff_event contains: nurse_id, shift, day, unit, reason
[0m[49m[39m  378, 390[0m:[39m[49m     
[0m[49m[39m  379, 391[0m:[39m[49m     // Load current schedule state
[0m[49m[39m  380, 392[0m:[39m[49m     current_schedule = fetch from schedule database
[0m[49m[39m  381, 393[0m:[39m[49m     
