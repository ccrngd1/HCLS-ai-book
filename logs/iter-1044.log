[0m[49m[39m  383, 395[0m:[39m[49m     gap = {
[0m[49m[39m  384, 396[0m:[39m[49m         shift:  calloff_event.shift,
[0m[49m[39m  385, 397[0m:[39m[49m         day:    calloff_event.day,
[0m[49m[39m  386, 398[0m:[39m[49m         unit:   calloff_event.unit,
[0m[49m[39m  387, 399[0m:[39m[49m         required_certs: get_required_certifications(calloff_event.unit)
[0m[49m[39m  388, 400[0m:[39m[49m     }
[0m[49m[39m  389, 401[0m:[39m[49m     
[0m[49m[39m  390, 402[0m:[39m[49m     // Find eligible nurses (not already scheduled, qualified, available)
[0m[49m[39m  391, 403[0m:[39m[49m     candidates = []
[0m[49m[39m  392, 404[0m:[39m[49m     FOR each nurse n in staff_roster:
[0m[49m[39m  393, 405[0m:[39m[49m         IF n.id == calloff_event.nurse_id: CONTINUE  // skip the one who called off
[0m[49m[39m  394, 406[0m:[39m[49m         IF not has_required_certs(n, gap.required_certs): CONTINUE
[0m[49m[39m  395, 407[0m:[39m[49m         IF is_scheduled(n, gap.day): CONTINUE  // already working
[0m[49m[39m  396, 408[0m:[39m[49m         IF violates_rest_rule(n, gap.shift, gap.day, current_schedule): CONTINUE
[0m[49m[39m  397, 409[0m:[39m[49m         IF exceeds_max_hours(n, gap.shift, current_schedule): CONTINUE
[0m[49m[39m  398, 410[0m:[39m[49m         IF is_on_pto(n, gap.day): CONTINUE
[0m[49m[39m  399, 411[0m:[39m[49m         
[0m[49m[39m  400, 412[0m:[39m[49m         // Score this candidate
[0m[49m[39m  401, 413[0m:[39m[49m         score = compute_coverage_score(n, gap, current_schedule)
[0m[49m[39m  402, 414[0m:[39m[49m         // Score considers: overtime cost, fairness impact, historical acceptance rate,
[0m[49m[39m  403, 415[0m:[39m[49m         // distance from home (if known), consecutive days worked
[0m[49m[39m  404, 416[0m:[39m[49m         
[0m[49m[39m  405, 417[0m:[39m[49m         append to candidates: { nurse: n, score: score }
[0m[49m[39m  406, 418[0m:[39m[49m     
[0m[49m[39m  407, 419[0m:[39m[49m     // Sort by score (best candidates first)
[0m[49m[39m  408, 420[0m:[39m[49m     sort candidates by score descending
[0m[49m[39m  409, 421[0m:[39m[49m     
[0m[49m[38;5;10m+      422[0m:[38;5;10m[49m     // Before auto-assigning, use a conditional write to verify the candidate
[0m[49m[38;5;10m+      423[0m:[38;5;10m[49m     // is still unscheduled (prevents race conditions from concurrent call-offs)
[0m[49m[38;5;10m+      424[0m:[38;5;10m[49m     IF candidates[0].score > AUTO_THRESHOLD:
[0m[49m[38;5;10m+      425[0m:[38;5;10m[49m         success = conditional_write_assignment(candidates[0], gap)
