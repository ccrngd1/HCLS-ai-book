[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m def _increment_session_counter(session_id: str, counter_name: str) -> None:
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m     session_key = _resolve_session_key(session_id)  # from W1's fix
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m     if not session_key:
