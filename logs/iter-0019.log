[0m[48;2;40;67;43m[39m+    10[0m:[39m[48;2;24;38;30m [K
[0m[48;2;40;67;43m[39m+    11[0m:[39m[48;2;24;38;30m [38;2;235;203;139m**[38;2;235;203;139mVerdict: PASS[38;2;235;203;139m**[K
