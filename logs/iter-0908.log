[0m[49m[39m  343, 343[0m:[39m[49m   "clinical_decision": "ROUTINE_REFERRAL",
[0m[49m[39m  344, 344[0m:[39m[49m   "urgency": "routine",
[0m[49m[39m  345, 345[0m:[39m[49m   "model_version": "v2.3.1",
