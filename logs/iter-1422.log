[0m[49m[38;5;10m+    1064[0m:[38;5;10m[49m         return (
[0m[49m[38;5;10m+    1065[0m:[38;5;10m[49m             f"ED currently holding {int(ed_boarders_feat)} boarders. "
[0m[49m[38;5;10m+    1066[0m:[38;5;10m[49m             f"Target unit has available capacity. Moving now prevents cascade "
