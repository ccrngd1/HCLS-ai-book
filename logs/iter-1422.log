[0m[49m[38;5;10m+    1141[0m:[38;5;10m[49m     print("\n[2/4] Evaluating policy against historical operations...")
[0m[49m[38;5;10m+    1142[0m:[38;5;10m[49m     # In production: load real historical episodes from S3
[0m[49m[38;5;10m+    1143[0m:[38;5;10m[49m     # For demo: generate synthetic evaluation data
[0m[49m[38;5;10m+    1144[0m:[38;5;10m[49m     eval_result = {
[0m[49m[38;5;10m+    1145[0m:[38;5;10m[49m         "episodes_evaluated": 30,
[0m[49m[38;5;10m+    1146[0m:[38;5;10m[49m         "avg_improvement": 0.15,
[0m[49m[38;5;10m+    1147[0m:[38;5;10m[49m         "ci_95_lower": 0.03,
[0m[49m[38;5;10m+    1148[0m:[38;5;10m[49m         "ci_95_upper": 0.27,
[0m[49m[38;5;10m+    1149[0m:[38;5;10m[49m         "passes_threshold": True,
[0m[49m[38;5;10m+    1150[0m:[38;5;10m[49m         "recommendation": "DEPLOY",
[0m[49m[38;5;10m+    1151[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1152[0m:[38;5;10m[49m     print(f"      Episodes evaluated: {eval_result['episodes_evaluated']}")
[0m[49m[38;5;10m+    1153[0m:[38;5;10m[49m     print(f"      Average improvement: {eval_result['avg_improvement']:.1%}")
[0m[49m[38;5;10m+    1154[0m:[38;5;10m[49m     print(f"      95% CI: [{eval_result['ci_95_lower']:.1%}, {eval_result['ci_95_upper']:.1%}]")
[0m[49m[38;5;10m+    1155[0m:[38;5;10m[49m     print(f"      Recommendation: {eval_result['recommendation']}")
[0m[49m[38;5;10m+    1156[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1157[0m:[38;5;10m[49m     # --- Step 3: Register model (only if evaluation passes) ---
[0m[49m[38;5;10m+    1158[0m:[38;5;10m[49m     if not eval_result["passes_threshold"]:
[0m[49m[38;5;10m+    1159[0m:[38;5;10m[49m         print("\n[STOP] Policy did not pass offline evaluation. Not deploying.")
[0m[49m[38;5;10m+    1160[0m:[38;5;10m[49m         print("       Review constraint satisfaction and reward shaping.")
[0m[49m[38;5;10m+    1161[0m:[38;5;10m[49m         return
[0m[49m[38;5;10m+    1162[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1163[0m:[38;5;10m[49m     print("\n[3/4] Registering model in SageMaker Model Registry...")
[0m[49m[38;5;10m+    1164[0m:[38;5;10m[49m     # In production: sagemaker model registry with approval workflow
[0m[49m[38;5;10m+    1165[0m:[38;5;10m[49m     model_version = f"v1.0.{int(time.time())}"
[0m[49m[38;5;10m+    1166[0m:[38;5;10m[49m     print(f"      Registered as: {model_version}")
[0m[49m[38;5;10m+    1167[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1168[0m:[38;5;10m[49m     # --- Step 4: Generate sample recommendation ---
[0m[49m[38;5;10m+    1169[0m:[38;5;10m[49m     print("\n[4/4] Generating sample recommendation for current state...")
[0m[49m[38;5;10m+    1170[0m:[38;5;10m[49m     recommendation = generate_recommendation(hospital_id, policy)
[0m[49m[38;5;10m+    1171[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1172[0m:[38;5;10m[49m     print(f"\n      Recommendation ID: {recommendation['recommendation_id']}")
[0m[49m[38;5;10m+    1173[0m:[38;5;10m[49m     print(f"      State summary: {json.dumps(recommendation['state_summary'], indent=2)}")
[0m[49m[38;5;10m+    1174[0m:[38;5;10m[49m     print(f"      Top recommendations:")
[0m[49m[38;5;10m+    1175[0m:[38;5;10m[49m     for i, rec in enumerate(recommendation.get("recommendations", []), 1):
[0m[49m[38;5;10m+    1176[0m:[38;5;10m[49m         print(f"        {i}. {rec['action_description']} (confidence: {rec['confidence']:.1%})")
[0m[49m[38;5;10m+    1177[0m:[38;5;10m[49m         print(f"           {rec['explanation']}")
[0m[49m[38;5;10m+    1178[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1179[0m:[38;5;10m[49m     print("\n" + "=" * 60)
[0m[49m[38;5;10m+    1180[0m:[38;5;10m[49m     print("Pipeline complete. Model ready for decision support deployment.")
[0m[49m[38;5;10m+    1181[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    1182[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1183[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1184[0m:[38;5;10m[49m if __name__ == "__main__":
[0m[49m[38;5;10m+    1185[0m:[38;5;10m[49m     run_full_pipeline(hospital_id="hospital-demo-001")
[0m[49m[38;5;10m+    1186[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    1187[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1188[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    1189[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1190[0m:[38;5;10m[49m ## Gap to Production
[0m[49m[38;5;10m+    1191[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1192[0m:[38;5;10m[49m This example shows the skeleton. Here's what you'd need for a real deployment:
[0m[49m[38;5;10m+    1193[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1194[0m:[38;5;10m[49m **Simulation fidelity.** The simulator above uses basic Poisson arrivals and uniform distributions. A real simulator needs:
[0m[49m[38;5;10m+    1195[0m:[38;5;10m[49m - Fitted arrival models from 2+ years of ADT data (time-of-day, day-of-week, seasonal patterns)
[0m[49m[38;5;10m+    1196[0m:[38;5;10m[49m - Log-normal length-of-stay distributions stratified by diagnosis group
[0m[49m[38;5;10m+    1197[0m:[38;5;10m[49m - Individual patient acuity trajectories (patients improve and deteriorate)
[0m[49m[38;5;10m+    1198[0m:[38;5;10m[49m - OR schedule integration with realistic case durations
[0m[49m[38;5;10m+    1199[0m:[38;5;10m[49m - Staff behavior modeling (response times, float preferences)
[0m[49m[38;5;10m+    1200[0m:[38;5;10m[49m - Equipment maintenance and failure modes
[0m[49m[38;5;10m+    1201[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1202[0m:[38;5;10m[49m **Proper RL framework.** The numpy policy network here doesn't actually learn (no backpropagation). Use SageMaker RL with RLlib, which provides:
[0m[49m[38;5;10m+    1203[0m:[38;5;10m[49m - PPO with proper advantage estimation (GAE)
[0m[49m[38;5;10m+    1204[0m:[38;5;10m[49m - Distributed rollout workers for parallel simulation
[0m[49m[38;5;10m+    1205[0m:[38;5;10m[49m - GPU-accelerated policy updates
[0m[49m[38;5;10m+    1206[0m:[38;5;10m[49m - Proper value function baseline
[0m[49m[38;5;10m+    1207[0m:[38;5;10m[49m - Entropy bonus for exploration
[0m[49m[38;5;10m+    1208[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1209[0m:[38;5;10m[49m **Off-policy evaluation.** The evaluation function above is extremely simplified. Real OPE requires:
[0m[49m[38;5;10m+    1210[0m:[38;5;10m[49m - Fitted Q-Evaluation (FQE) for lower-variance estimates
[0m[49m[38;5;10m+    1211[0m:[38;5;10m[49m - Doubly-robust estimators to balance bias and variance
[0m[49m[38;5;10m+    1212[0m:[38;5;10m[49m - Multiple OPE methods cross-validated against each other
[0m[49m[38;5;10m+    1213[0m:[38;5;10m[49m - Confidence intervals that account for distributional shift
[0m[49m[38;5;10m+    1214[0m:[38;5;10m[49m - Sensitivity analysis to modeling assumptions
[0m[49m[38;5;10m+    1215[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1216[0m:[38;5;10m[49m **Domain randomization.** During training, randomize simulator parameters (arrival rates, LOS, staffing levels) to make the policy robust to miscalibration. The sim-to-real gap is the biggest risk. If your simulator is wrong, your policy is optimized for the wrong world.
[0m[49m[38;5;10m+    1217[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1218[0m:[38;5;10m[49m **Error handling and retries.** Every AWS API call needs proper exception handling with exponential backoff. Kinesis streams can have hot shards. DynamoDB can throttle during training data writes. SageMaker training jobs can fail from spot instance interruptions.
[0m[49m[38;5;10m+    1219[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1220[0m:[38;5;10m[49m **Input validation.** State vectors from real hospital systems will have missing data, stale values, and impossible combinations. Validate ranges, check timestamps for staleness, and have fallback behavior when data quality is poor.
[0m[49m[38;5;10m+    1221[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1222[0m:[38;5;10m[49m **Structured logging.** All recommendations, state observations, and human decisions need structured JSON logging for CloudWatch Logs Insights. Include correlation IDs that connect a recommendation to the state that generated it and the human decision that followed.
[0m[49m[38;5;10m+    1223[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1224[0m:[38;5;10m[49m **IAM least privilege.** The inference Lambda should only have permissions for the specific DynamoDB table and model artifact. The training pipeline needs broader permissions but only during execution. Separate roles for training vs. inference.
[0m[49m[38;5;10m+    1225[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1226[0m:[38;5;10m[49m **VPC configuration.** All components handling operational data (which contains PHI through room assignments and acuity levels) must run in private subnets. VPC endpoints for S3, DynamoDB, SageMaker, and Kinesis. No public internet access for data-plane traffic.
[0m[49m[38;5;10m+    1227[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1228[0m:[38;5;10m[49m **KMS encryption.** Use customer-managed KMS keys for S3 training data, DynamoDB state tables, and model artifacts. Key policies should restrict access to the specific roles that need decryption.
[0m[49m[38;5;10m+    1229[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1230[0m:[38;5;10m[49m **Monitoring and alerting.** CloudWatch alarms for:
[0m[49m[38;5;10m+    1231[0m:[38;5;10m[49m - Recommendation latency exceeding SLA
[0m[49m[38;5;10m+    1232[0m:[38;5;10m[49m - State data staleness (no updates in > 5 minutes)
[0m[49m[38;5;10m+    1233[0m:[38;5;10m[49m - Model drift (recommendation distribution shifting unexpectedly)
[0m[49m[38;5;10m+    1234[0m:[38;5;10m[49m - Constraint checker firing rate (if constraints are hit constantly, something is wrong)
[0m[49m[38;5;10m+    1235[0m:[38;5;10m[49m - Human rejection rate (high rejection = policy misalignment)
[0m[49m[38;5;10m+    1236[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1237[0m:[38;5;10m[49m **Human feedback loop.** Every recommendation must have an easy accept/reject/modify workflow in the dashboard. This data is gold for retraining. Track what humans change and why. Feed accepted-action distributions back as a behavioral cloning signal to keep the policy aligned with operational preferences.
[0m[49m[38;5;10m+    1238[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1239[0m:[38;5;10m[49m **A/B evaluation protocol.** Before system-wide deployment, run a controlled pilot:
[0m[49m[38;5;10m+    1240[0m:[38;5;10m[49m - Randomize by time block (recommendations shown vs. hidden on alternating shifts)
[0m[49m[38;5;10m+    1241[0m:[38;5;10m[49m - Or randomize by unit (some units get recommendations, others don't)
[0m[49m[38;5;10m+    1242[0m:[38;5;10m[49m - Measure the same operational KPIs used in offline evaluation
[0m[49m[38;5;10m+    1243[0m:[38;5;10m[49m - Run for 4-8 weeks minimum to capture weekly patterns
[0m[49m[38;5;10m+    1244[0m:[38;5;10m[49m - Pre-register the evaluation metrics and success criteria
[0m[49m[38;5;10m+    1245[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1246[0m:[38;5;10m[49m **Reward function governance.** The weights in `REWARD_WEIGHTS` are organizational policy decisions, not engineering parameters. Changes require approval from hospital operations leadership. Version-control the weights and log which weight configuration was used for each training run.
[0m[49m[38;5;10m+    1247[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1248[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    1249[0m:[38;5;10m[49m 
