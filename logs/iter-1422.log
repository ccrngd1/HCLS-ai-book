[0m[49m[38;5;10m+     126[0m:[38;5;10m[49m     "discharge_before_noon": 2.0,        # each discharge completed before noon
[0m[49m[38;5;10m+     127[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     128[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     129[0m:[38;5;10m[49m # --- Hard Constraints (Non-Negotiable) ---
[0m[49m[38;5;10m+     130[0m:[38;5;10m[49m # These are enforced at action selection time. The policy NEVER gets to violate these,
[0m[49m[38;5;10m+     131[0m:[38;5;10m[49m # regardless of what the neural network outputs. Think of these as the guardrails
[0m[49m[38;5;10m+     132[0m:[38;5;10m[49m # that prevent the system from recommending anything dangerous or illegal.
[0m[49m[38;5;10m+     133[0m:[38;5;10m[49m HARD_CONSTRAINTS = {
[0m[49m[38;5;10m+     134[0m:[38;5;10m[49m     "min_staffing_ratio": True,          # never recommend action that drops below minimum
[0m[49m[38;5;10m+     135[0m:[38;5;10m[49m     "max_unit_capacity": True,           # never exceed licensed bed count
[0m[49m[38;5;10m+     136[0m:[38;5;10m[49m     "isolation_requirements": True,      # never place infectious patient in shared room
[0m[49m[38;5;10m+     137[0m:[38;5;10m[49m     "equipment_availability": True,      # never assign bed requiring equipment that's out
[0m[49m[38;5;10m+     138[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     139[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     140[0m:[38;5;10m[49m # --- Training Hyperparameters ---
[0m[49m[38;5;10m+     141[0m:[38;5;10m[49m TRAINING_CONFIG = {
[0m[49m[38;5;10m+     142[0m:[38;5;10m[49m     "algorithm": "PPO",
[0m[49m[38;5;10m+     143[0m:[38;5;10m[49m     "learning_rate": 3e-4,
[0m[49m[38;5;10m+     144[0m:[38;5;10m[49m     "gamma": 0.99,                       # discount factor (long horizon)
[0m[49m[38;5;10m+     145[0m:[38;5;10m[49m     "gae_lambda": 0.95,                  # GAE parameter
[0m[49m[38;5;10m+     146[0m:[38;5;10m[49m     "clip_epsilon": 0.2,                 # PPO clipping
[0m[49m[38;5;10m+     147[0m:[38;5;10m[49m     "entropy_coeff": 0.01,               # exploration encouragement
[0m[49m[38;5;10m+     148[0m:[38;5;10m[49m     "num_episodes": 10000,
[0m[49m[38;5;10m+     149[0m:[38;5;10m[49m     "episode_length_hours": 24,          # simulate 24-hour periods
[0m[49m[38;5;10m+     150[0m:[38;5;10m[49m     "decision_interval_minutes": 30,     # recommend every 30 minutes
[0m[49m[38;5;10m+     151[0m:[38;5;10m[49m     "lagrange_lr": 0.01,                 # learning rate for constraint multipliers
[0m[49m[38;5;10m+     152[0m:[38;5;10m[49m     "constraint_thresholds": {
[0m[49m[38;5;10m+     153[0m:[38;5;10m[49m         "staffing_violations_per_day": 2.0,
[0m[49m[38;5;10m+     154[0m:[38;5;10m[49m         "capacity_overflows_per_day": 0.5,
[0m[49m[38;5;10m+     155[0m:[38;5;10m[49m         "ed_boarding_hours_per_day": 20.0,
[0m[49m[38;5;10m+     156[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+     157[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     158[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     159[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     160[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     161[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     162[0m:[38;5;10m[49m ## Step 1: Build the Hospital State Vector
[0m[49m[38;5;10m+     163[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     164[0m:[38;5;10m[49m *The pseudocode calls this `build_state_vector(hospital_id, timestamp)`. It collects real-time data from multiple source systems and assembles a normalized feature vector representing the current hospital state.*
[0m[49m[38;5;10m+     165[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     166[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     167[0m:[38;5;10m[49m # AWS clients for pulling operational data.
[0m[49m[38;5;10m+     168[0m:[38;5;10m[49m kinesis_client = boto3.client("kinesis", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     169[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     170[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     171[0m:[38;5;10m[49m # Table where we store the latest state observations from each source system.
[0m[49m[38;5;10m+     172[0m:[38;5;10m[49m state_table = dynamodb.Table("hospital-resource-state")
[0m[49m[38;5;10m+     173[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     174[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     175[0m:[38;5;10m[49m def build_state_vector(hospital_id: str, timestamp_epoch: float) -> np.ndarray:
[0m[49m[38;5;10m+     176[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     177[0m:[38;5;10m[49m     Assemble the current hospital state into a normalized feature vector.
[0m[49m[38;5;10m+     178[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     179[0m:[38;5;10m[49m     In production, this pulls from multiple real-time sources:
[0m[49m[38;5;10m+     180[0m:[38;5;10m[49m     - ADT system (census, pending admissions/discharges)
[0m[49m[38;5;10m+     181[0m:[38;5;10m[49m     - Staffing platform (current levels vs. scheduled)
[0m[49m[38;5;10m+     182[0m:[38;5;10m[49m     - OR scheduling system (cases remaining)
[0m[49m[38;5;10m+     183[0m:[38;5;10m[49m     - Equipment tracking (ventilators, monitors)
[0m[49m[38;5;10m+     184[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     185[0m:[38;5;10m[49m     For this example, we read from a DynamoDB table that a Lambda-based
[0m[49m[38;5;10m+     186[0m:[38;5;10m[49m     state aggregator populates from Kinesis streams.
[0m[49m[38;5;10m+     187[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     188[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     189[0m:[38;5;10m[49m         hospital_id: Identifier for the facility
[0m[49m[38;5;10m+     190[0m:[38;5;10m[49m         timestamp_epoch: Current time as Unix epoch seconds
[0m[49m[38;5;10m+     191[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     192[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     193[0m:[38;5;10m[49m         Normalized numpy array of shape (NUM_STATE_FEATURES,)
[0m[49m[38;5;10m+     194[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     195[0m:[38;5;10m[49m     # Query latest state snapshot from DynamoDB.
[0m[49m[38;5;10m+     196[0m:[38;5;10m[49m     # The state aggregator Lambda writes here every time it processes
[0m[49m[38;5;10m+     197[0m:[38;5;10m[49m     # a batch of events from the Kinesis stream.
[0m[49m[38;5;10m+     198[0m:[38;5;10m[49m     response = state_table.get_item(
[0m[49m[38;5;10m+     199[0m:[38;5;10m[49m         Key={"hospital_id": hospital_id, "record_type": "current_state"}
[0m[49m[38;5;10m+     200[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     201[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     202[0m:[38;5;10m[49m     if "Item" not in response:
[0m[49m[38;5;10m+     203[0m:[38;5;10m[49m         logger.warning("No current state found for hospital %s, using defaults", hospital_id)
[0m[49m[38;5;10m+     204[0m:[38;5;10m[49m         return np.zeros(NUM_STATE_FEATURES, dtype=np.float32)
[0m[49m[38;5;10m+     205[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     206[0m:[38;5;10m[49m     raw_state = response["Item"]
[0m[49m[38;5;10m+     207[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     208[0m:[38;5;10m[49m     # Extract and normalize each feature.
[0m[49m[38;5;10m+     209[0m:[38;5;10m[49m     # Normalization maps each value to roughly [0, 1] based on expected ranges.
[0m[49m[38;5;10m+     210[0m:[38;5;10m[49m     # This helps the neural network learn efficiently.
[0m[49m[38;5;10m+     211[0m:[38;5;10m[49m     features = []
[0m[49m[38;5;10m+     212[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     213[0m:[38;5;10m[49m     for feature_def in STATE_FEATURES:
[0m[49m[38;5;10m+     214[0m:[38;5;10m[49m         name = feature_def["name"]
[0m[49m[38;5;10m+     215[0m:[38;5;10m[49m         raw_value = float(raw_state.get(name, 0))
[0m[49m[38;5;10m+     216[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     217[0m:[38;5;10m[49m         # Min-max normalization to [0, 1]
[0m[49m[38;5;10m+     218[0m:[38;5;10m[49m         feat_min = feature_def["min"]
[0m[49m[38;5;10m+     219[0m:[38;5;10m[49m         feat_max = feature_def["max"]
[0m[49m[38;5;10m+     220[0m:[38;5;10m[49m         if feat_max > feat_min:
[0m[49m[38;5;10m+     221[0m:[38;5;10m[49m             normalized = (raw_value - feat_min) / (feat_max - feat_min)
[0m[49m[38;5;10m+     222[0m:[38;5;10m[49m             normalized = np.clip(normalized, 0.0, 1.0)
[0m[49m[38;5;10m+     223[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+     224[0m:[38;5;10m[49m             normalized = 0.0
[0m[49m[38;5;10m+     225[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     226[0m:[38;5;10m[49m         features.append(normalized)
[0m[49m[38;5;10m+     227[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     228[0m:[38;5;10m[49m     return np.array(features, dtype=np.float32)
[0m[49m[38;5;10m+     229[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     230[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     231[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     232[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     233[0m:[38;5;10m[49m ## Step 2: Define the Hospital Simulation Environment
[0m[49m[38;5;10m+     234[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     235[0m:[38;5;10m[49m *The pseudocode defines `CLASS HospitalSimulator`. This is where the RL agent trains. The simulator models patient arrivals, discharges, staff shifts, and resource consumption. Fidelity here determines whether the learned policy transfers to reality.*
[0m[49m[38;5;10m+     236[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     237[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     238[0m:[38;5;10m[49m class HospitalSimulator:
[0m[49m[38;5;10m+     239[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     240[0m:[38;5;10m[49m     Discrete-event simulation of hospital resource dynamics.
[0m[49m[38;5;10m+     241[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     242[0m:[38;5;10m[49m     This is a simplified version for illustration. A production simulator would:
[0m[49m[38;5;10m+     243[0m:[38;5;10m[49m     - Use fitted arrival distributions from 2+ years of ADT data
[0m[49m[38;5;10m+     244[0m:[38;5;10m[49m     - Model individual patient acuity trajectories
[0m[49m[38;5;10m+     245[0m:[38;5;10m[49m     - Include OR schedule with case-type-specific durations
[0m[49m[38;5;10m+     246[0m:[38;5;10m[49m     - Handle staff callouts and float pool availability
[0m[49m[38;5;10m+     247[0m:[38;5;10m[49m     - Model equipment maintenance cycles
[0m[49m[38;5;10m+     248[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     249[0m:[38;5;10m[49m     For training, we need this to be fast (thousands of episodes).
[0m[49m[38;5;10m+     250[0m:[38;5;10m[49m     Fidelity matters, but speed matters too. The tradeoff is: model the
[0m[49m[38;5;10m+     251[0m:[38;5;10m[49m     dynamics that affect resource allocation decisions, skip the details
[0m[49m[38;5;10m+     252[0m:[38;5;10m[49m     that don't (e.g., specific medication timing doesn't matter here).
[0m[49m[38;5;10m+     253[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     254[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     255[0m:[38;5;10m[49m     def __init__(self, config: dict = None):
[0m[49m[38;5;10m+     256[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     257[0m:[38;5;10m[49m         Initialize the simulator with hospital parameters.
[0m[49m[38;5;10m+     258[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     259[0m:[38;5;10m[49m         Args:
[0m[49m[38;5;10m+     260[0m:[38;5;10m[49m             config: Optional overrides for domain randomization during training.
[0m[49m[38;5;10m+     261[0m:[38;5;10m[49m                     Keys can override arrival rates, LOS distributions, etc.
[0m[49m[38;5;10m+     262[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     263[0m:[38;5;10m[49m         self.config = config or {}
[0m[49m[38;5;10m+     264[0m:[38;5;10m[49m         self.rng = np.random.default_rng()
[0m[49m[38;5;10m+     265[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     266[0m:[38;5;10m[49m         # Base arrival rates (patients per hour) by unit type.
[0m[49m[38;5;10m+     267[0m:[38;5;10m[49m         # These get randomized during training for robustness.
[0m[49m[38;5;10m+     268[0m:[38;5;10m[49m         self.base_arrival_rates = self.config.get("arrival_rates", {
[0m[49m[38;5;10m+     269[0m:[38;5;10m[49m             "ed": 4.0,           # ~4 ED arrivals per hour requiring admission
[0m[49m[38;5;10m+     270[0m:[38;5;10m[49m             "direct_admit": 1.0, # direct admits (scheduled, transfers in)
[0m[49m[38;5;10m+     271[0m:[38;5;10m[49m             "or_post_op": 1.5,   # patients coming out of OR needing beds
[0m[49m[38;5;10m+     272[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     273[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     274[0m:[38;5;10m[49m         # Mean length of stay by unit (hours). Log-normal in reality.
[0m[49m[38;5;10m+     275[0m:[38;5;10m[49m         self.mean_los_hours = self.config.get("mean_los", {
[0m[49m[38;5;10m+     276[0m:[38;5;10m[49m             "icu": 72,
[0m[49m[38;5;10m+     277[0m:[38;5;10m[49m             "stepdown": 48,
[0m[49m[38;5;10m+     278[0m:[38;5;10m[49m             "medsurg": 96,
[0m[49m[38;5;10m+     279[0m:[38;5;10m[49m             "telemetry": 72,
[0m[49m[38;5;10m+     280[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     281[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     282[0m:[38;5;10m[49m         self.reset()
[0m[49m[38;5;10m+     283[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     284[0m:[38;5;10m[49m     def reset(self) -> np.ndarray:
[0m[49m[38;5;10m+     285[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     286[0m:[38;5;10m[49m         Start a new 24-hour episode with randomized initial conditions.
[0m[49m[38;5;10m+     287[0m:[38;5;10m[49m         Returns the initial state vector.
[0m[49m[38;5;10m+     288[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     289[0m:[38;5;10m[49m         # Randomize start time (hour of day affects dynamics significantly)
[0m[49m[38;5;10m+     290[0m:[38;5;10m[49m         self.hour = self.rng.integers(0, 24)
[0m[49m[38;5;10m+     291[0m:[38;5;10m[49m         self.minute = 0
[0m[49m[38;5;10m+     292[0m:[38;5;10m[49m         self.steps_taken = 0
[0m[49m[38;5;10m+     293[0m:[38;5;10m[49m         self.episode_done = False
[0m[49m[38;5;10m+     294[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     295[0m:[38;5;10m[49m         # Initialize census at realistic levels (60-85% occupancy)
[0m[49m[38;5;10m+     296[0m:[38;5;10m[49m         self.census = {}
[0m[49m[38;5;10m+     297[0m:[38;5;10m[49m         for unit in UNITS:
[0m[49m[38;5;10m+     298[0m:[38;5;10m[49m             occupancy_frac = self.rng.uniform(0.6, 0.85)
[0m[49m[38;5;10m+     299[0m:[38;5;10m[49m             self.census[unit["name"]] = int(unit["capacity"] * occupancy_frac)
[0m[49m[38;5;10m+     300[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     301[0m:[38;5;10m[49m         # Initialize staffing (some randomness around scheduled levels)
[0m[49m[38;5;10m+     302[0m:[38;5;10m[49m         self.staffing = {}
[0m[49m[38;5;10m+     303[0m:[38;5;10m[49m         for unit in UNITS:
[0m[49m[38;5;10m+     304[0m:[38;5;10m[49m             # Scheduled staff that would exactly meet ratio at current census
[0m[49m[38;5;10m+     305[0m:[38;5;10m[49m             needed = int(np.ceil(self.census[unit["name"]] * unit["min_ratio"]))
[0m[49m[38;5;10m+     306[0m:[38;5;10m[49m             # Actual staff: usually at or slightly above needed
[0m[49m[38;5;10m+     307[0m:[38;5;10m[49m             actual = needed + self.rng.integers(0, 3)
[0m[49m[38;5;10m+     308[0m:[38;5;10m[49m             self.staffing[unit["name"]] = actual
[0m[49m[38;5;10m+     309[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     310[0m:[38;5;10m[49m         # Pending queues
[0m[49m[38;5;10m+     311[0m:[38;5;10m[49m         self.ed_boarders = self.rng.integers(0, 5)
[0m[49m[38;5;10m+     312[0m:[38;5;10m[49m         self.pending_discharges = self.rng.integers(2, 8)
[0m[49m[38;5;10m+     313[0m:[38;5;10m[49m         self.or_cases_remaining = self.rng.integers(3, 10)
[0m[49m[38;5;10m+     314[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     315[0m:[38;5;10m[49m         # Equipment
[0m[49m[38;5;10m+     316[0m:[38;5;10m[49m         self.ventilators_total = 30
[0m[49m[38;5;10m+     317[0m:[38;5;10m[49m         self.ventilators_in_use = self.rng.integers(15, 25)
[0m[49m[38;5;10m+     318[0m:[38;5;10m[49m         self.monitors_total = 50
[0m[49m[38;5;10m+     319[0m:[38;5;10m[49m         self.monitors_in_use = self.rng.integers(30, 45)
[0m[49m[38;5;10m+     320[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     321[0m:[38;5;10m[49m         # Tracking for reward calculation
