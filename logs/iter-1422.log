[0m[49m[38;5;10m+     513[0m:[38;5;10m[49m                     self.census["icu"] = self.census.get("icu", 0) + 1
[0m[49m[38;5;10m+     514[0m:[38;5;10m[49m                 else:
[0m[49m[38;5;10m+     515[0m:[38;5;10m[49m                     self.census["stepdown"] = self.census.get("stepdown", 0) + 1
[0m[49m[38;5;10m+     516[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     517[0m:[38;5;10m[49m         # --- Patient discharges (stochastic based on pending count) ---
[0m[49m[38;5;10m+     518[0m:[38;5;10m[49m         if self.pending_discharges > 0:
[0m[49m[38;5;10m+     519[0m:[38;5;10m[49m             # Higher discharge probability during daytime hours
[0m[49m[38;5;10m+     520[0m:[38;5;10m[49m             discharge_prob = 0.1 if 8 <= self.hour <= 16 else 0.03
[0m[49m[38;5;10m+     521[0m:[38;5;10m[49m             discharges = self.rng.binomial(self.pending_discharges, discharge_prob)
[0m[49m[38;5;10m+     522[0m:[38;5;10m[49m             self.pending_discharges -= discharges
[0m[49m[38;5;10m+     523[0m:[38;5;10m[49m             # Remove patients from random occupied units
[0m[49m[38;5;10m+     524[0m:[38;5;10m[49m             for _ in range(discharges):
[0m[49m[38;5;10m+     525[0m:[38;5;10m[49m                 occupied = [u["name"] for u in UNITS if self.census.get(u["name"], 0) > 0]
[0m[49m[38;5;10m+     526[0m:[38;5;10m[49m                 if occupied:
[0m[49m[38;5;10m+     527[0m:[38;5;10m[49m                     unit = self.rng.choice(occupied)
[0m[49m[38;5;10m+     528[0m:[38;5;10m[49m                     self.census[unit] -= 1
[0m[49m[38;5;10m+     529[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     530[0m:[38;5;10m[49m         # --- Accumulate ED boarding penalty ---
[0m[49m[38;5;10m+     531[0m:[38;5;10m[49m         self.ed_boarding_hours += self.ed_boarders * interval_hours
[0m[49m[38;5;10m+     532[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     533[0m:[38;5;10m[49m         # --- Check staffing violations ---
[0m[49m[38;5;10m+     534[0m:[38;5;10m[49m         for unit in UNITS:
[0m[49m[38;5;10m+     535[0m:[38;5;10m[49m             name = unit["name"]
[0m[49m[38;5;10m+     536[0m:[38;5;10m[49m             current_staff = self.staffing.get(name, 0)
[0m[49m[38;5;10m+     537[0m:[38;5;10m[49m             needed = int(np.ceil(self.census.get(name, 0) * unit["min_ratio"]))
[0m[49m[38;5;10m+     538[0m:[38;5;10m[49m             if current_staff < needed:
[0m[49m[38;5;10m+     539[0m:[38;5;10m[49m                 self.staffing_violations += 1
[0m[49m[38;5;10m+     540[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     541[0m:[38;5;10m[49m         # --- Check for surgical cancellations ---
[0m[49m[38;5;10m+     542[0m:[38;5;10m[49m         # If ICU and step-down are both full, OR cases can't proceed
[0m[49m[38;5;10m+     543[0m:[38;5;10m[49m         icu_full = self.census.get("icu", 0) >= 20
[0m[49m[38;5;10m+     544[0m:[38;5;10m[49m         stepdown_full = self.census.get("stepdown", 0) >= 24
[0m[49m[38;5;10m+     545[0m:[38;5;10m[49m         if icu_full and stepdown_full and self.or_cases_remaining > 0:
[0m[49m[38;5;10m+     546[0m:[38;5;10m[49m             if self.rng.random() < 0.1:  # 10% chance per interval when both full
[0m[49m[38;5;10m+     547[0m:[38;5;10m[49m                 self.surgical_cancellations += 1
[0m[49m[38;5;10m+     548[0m:[38;5;10m[49m                 self.or_cases_remaining -= 1
[0m[49m[38;5;10m+     549[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     550[0m:[38;5;10m[49m         # --- Advance clock ---
[0m[49m[38;5;10m+     551[0m:[38;5;10m[49m         self.minute += TRAINING_CONFIG["decision_interval_minutes"]
[0m[49m[38;5;10m+     552[0m:[38;5;10m[49m         if self.minute >= 60:
[0m[49m[38;5;10m+     553[0m:[38;5;10m[49m             self.hour = (self.hour + self.minute // 60) % 24
[0m[49m[38;5;10m+     554[0m:[38;5;10m[49m             self.minute = self.minute % 60
[0m[49m[38;5;10m+     555[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     556[0m:[38;5;10m[49m         self.steps_taken += 1
[0m[49m[38;5;10m+     557[0m:[38;5;10m[49m         max_steps = (TRAINING_CONFIG["episode_length_hours"] * 60
[0m[49m[38;5;10m+     558[0m:[38;5;10m[49m                      // TRAINING_CONFIG["decision_interval_minutes"])
[0m[49m[38;5;10m+     559[0m:[38;5;10m[49m         if self.steps_taken >= max_steps:
[0m[49m[38;5;10m+     560[0m:[38;5;10m[49m             self.episode_done = True
[0m[49m[38;5;10m+     561[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     562[0m:[38;5;10m[49m     def _compute_reward(self) -> float:
[0m[49m[38;5;10m+     563[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     564[0m:[38;5;10m[49m         Compute the immediate reward for the current state.
[0m[49m[38;5;10m+     565[0m:[38;5;10m[49m         This is called after each step to provide the training signal.
[0m[49m[38;5;10m+     566[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     567[0m:[38;5;10m[49m         reward = 0.0
[0m[49m[38;5;10m+     568[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     569[0m:[38;5;10m[49m         # Penalize ED boarding (per boarder, per interval)
[0m[49m[38;5;10m+     570[0m:[38;5;10m[49m         interval_hours = TRAINING_CONFIG["decision_interval_minutes"] / 60.0
[0m[49m[38;5;10m+     571[0m:[38;5;10m[49m         reward += REWARD_WEIGHTS["ed_boarding_per_hour"] * self.ed_boarders * interval_hours
[0m[49m[38;5;10m+     572[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     573[0m:[38;5;10m[49m         # Penalize staffing violations
[0m[49m[38;5;10m+     574[0m:[38;5;10m[49m         for unit in UNITS:
[0m[49m[38;5;10m+     575[0m:[38;5;10m[49m             name = unit["name"]
[0m[49m[38;5;10m+     576[0m:[38;5;10m[49m             current_staff = self.staffing.get(name, 0)
[0m[49m[38;5;10m+     577[0m:[38;5;10m[49m             needed = int(np.ceil(self.census.get(name, 0) * unit["min_ratio"]))
[0m[49m[38;5;10m+     578[0m:[38;5;10m[49m             if current_staff < needed:
[0m[49m[38;5;10m+     579[0m:[38;5;10m[49m                 reward += REWARD_WEIGHTS["staffing_ratio_violation"] * interval_hours
[0m[49m[38;5;10m+     580[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     581[0m:[38;5;10m[49m         # Reward balanced census distribution
[0m[49m[38;5;10m+     582[0m:[38;5;10m[49m         occupancies = []
[0m[49m[38;5;10m+     583[0m:[38;5;10m[49m         for unit in UNITS:
[0m[49m[38;5;10m+     584[0m:[38;5;10m[49m             occ = self.census.get(unit["name"], 0) / unit["capacity"]
[0m[49m[38;5;10m+     585[0m:[38;5;10m[49m             occupancies.append(occ)
[0m[49m[38;5;10m+     586[0m:[38;5;10m[49m         # Lower variance in occupancy = better balance
[0m[49m[38;5;10m+     587[0m:[38;5;10m[49m         balance_score = 1.0 - np.std(occupancies)
[0m[49m[38;5;10m+     588[0m:[38;5;10m[49m         reward += REWARD_WEIGHTS["census_balance_bonus"] * max(0, balance_score)
[0m[49m[38;5;10m+     589[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     590[0m:[38;5;10m[49m         return reward
[0m[49m[38;5;10m+     591[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     592[0m:[38;5;10m[49m     def _get_state(self) -> np.ndarray:
[0m[49m[38;5;10m+     593[0m:[38;5;10m[49m         """Assemble current simulation state into a normalized feature vector."""
[0m[49m[38;5;10m+     594[0m:[38;5;10m[49m         features = []
[0m[49m[38;5;10m+     595[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     596[0m:[38;5;10m[49m         # Census occupancy fractions
[0m[49m[38;5;10m+     597[0m:[38;5;10m[49m         for unit in UNITS:
[0m[49m[38;5;10m+     598[0m:[38;5;10m[49m             occ = self.census.get(unit["name"], 0) / unit["capacity"]
[0m[49m[38;5;10m+     599[0m:[38;5;10m[49m             features.append(np.clip(occ, 0.0, 1.2))
[0m[49m[38;5;10m+     600[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     601[0m:[38;5;10m[49m         # Staffing ratios (actual / minimum required)
[0m[49m[38;5;10m+     602[0m:[38;5;10m[49m         for unit in UNITS:
[0m[49m[38;5;10m+     603[0m:[38;5;10m[49m             name = unit["name"]
[0m[49m[38;5;10m+     604[0m:[38;5;10m[49m             current = self.staffing.get(name, 0)
[0m[49m[38;5;10m+     605[0m:[38;5;10m[49m             needed = max(1, int(np.ceil(self.census.get(name, 0) * unit["min_ratio"])))
[0m[49m[38;5;10m+     606[0m:[38;5;10m[49m             ratio = current / needed
[0m[49m[38;5;10m+     607[0m:[38;5;10m[49m             features.append(np.clip(ratio, 0.5, 2.0))
[0m[49m[38;5;10m+     608[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     609[0m:[38;5;10m[49m         # Pending queues
[0m[49m[38;5;10m+     610[0m:[38;5;10m[49m         features.append(float(self.ed_boarders))
[0m[49m[38;5;10m+     611[0m:[38;5;10m[49m         features.append(float(self.rng.integers(0, 5)))  # simplified pending admits
[0m[49m[38;5;10m+     612[0m:[38;5;10m[49m         features.append(float(self.pending_discharges))
[0m[49m[38;5;10m+     613[0m:[38;5;10m[49m         features.append(float(self.pending_discharges * 0.5))  # probable discharges
[0m[49m[38;5;10m+     614[0m:[38;5;10m[49m         features.append(float(self.or_cases_remaining))
[0m[49m[38;5;10m+     615[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     616[0m:[38;5;10m[49m         # Equipment availability
[0m[49m[38;5;10m+     617[0m:[38;5;10m[49m         features.append((self.ventilators_total - self.ventilators_in_use) / self.ventilators_total)
[0m[49m[38;5;10m+     618[0m:[38;5;10m[49m         features.append((self.monitors_total - self.monitors_in_use) / self.monitors_total)
[0m[49m[38;5;10m+     619[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     620[0m:[38;5;10m[49m         # Time encoding (cyclical)
[0m[49m[38;5;10m+     621[0m:[38;5;10m[49m         hour_frac = self.hour / 24.0
[0m[49m[38;5;10m+     622[0m:[38;5;10m[49m         features.append(np.sin(2 * np.pi * hour_frac))
[0m[49m[38;5;10m+     623[0m:[38;5;10m[49m         features.append(np.cos(2 * np.pi * hour_frac))
[0m[49m[38;5;10m+     624[0m:[38;5;10m[49m         # Day of week (fixed for single-episode simulation)
[0m[49m[38;5;10m+     625[0m:[38;5;10m[49m         dow_frac = 2 / 7.0  # pretend it's Tuesday
[0m[49m[38;5;10m+     626[0m:[38;5;10m[49m         features.append(np.sin(2 * np.pi * dow_frac))
[0m[49m[38;5;10m+     627[0m:[38;5;10m[49m         features.append(np.cos(2 * np.pi * dow_frac))
[0m[49m[38;5;10m+     628[0m:[38;5;10m[49m         features.append(0.0)  # is_weekend
[0m[49m[38;5;10m+     629[0m:[38;5;10m[49m         # Minutes to next shift change (simplified: shifts at 7, 15, 23)
[0m[49m[38;5;10m+     630[0m:[38;5;10m[49m         shift_hours = [7, 15, 23]
[0m[49m[38;5;10m+     631[0m:[38;5;10m[49m         mins_to_shift = min((sh - self.hour) % 24 * 60 - self.minute for sh in shift_hours)
[0m[49m[38;5;10m+     632[0m:[38;5;10m[49m         features.append(max(0, mins_to_shift) / 720.0)
[0m[49m[38;5;10m+     633[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     634[0m:[38;5;10m[49m         return np.array(features, dtype=np.float32)
[0m[49m[38;5;10m+     635[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     636[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     637[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     638[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     639[0m:[38;5;10m[49m ## Step 3: Implement the RL Policy Network and Training Loop
[0m[49m[38;5;10m+     640[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     641[0m:[38;5;10m[49m *The pseudocode calls this `train_policy(simulator, config)`. This implements Proximal Policy Optimization (PPO) with Lagrangian constraint handling. PPO is the workhorse of modern RL: stable, well-understood, and effective with discrete action spaces.*
[0m[49m[38;5;10m+     642[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     643[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     644[0m:[38;5;10m[49m class PolicyNetwork:
[0m[49m[38;5;10m+     645[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     646[0m:[38;5;10m[49m     Simple feedforward policy network for the resource allocation agent.
[0m[49m[38;5;10m+     647[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     648[0m:[38;5;10m[49m     In production, you'd use PyTorch or TensorFlow with SageMaker's RL
[0m[49m[38;5;10m+     649[0m:[38;5;10m[49m     container (which bundles RLlib). This numpy-only version shows the
[0m[49m[38;5;10m+     650[0m:[38;5;10m[49m     structure without pulling in a heavy framework dependency.
[0m[49m[38;5;10m+     651[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     652[0m:[38;5;10m[49m     Architecture: state -> hidden(128) -> hidden(64) -> action logits
[0m[49m[38;5;10m+     653[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     654[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     655[0m:[38;5;10m[49m     def __init__(self, state_dim: int, action_dim: int, hidden_size: int = 128):
[0m[49m[38;5;10m+     656[0m:[38;5;10m[49m         """Initialize with random weights (Xavier initialization)."""
[0m[49m[38;5;10m+     657[0m:[38;5;10m[49m         self.state_dim = state_dim
[0m[49m[38;5;10m+     658[0m:[38;5;10m[49m         self.action_dim = action_dim
[0m[49m[38;5;10m+     659[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     660[0m:[38;5;10m[49m         # Layer 1: state_dim -> hidden_size
[0m[49m[38;5;10m+     661[0m:[38;5;10m[49m         self.w1 = np.random.randn(state_dim, hidden_size) * np.sqrt(2.0 / state_dim)
[0m[49m[38;5;10m+     662[0m:[38;5;10m[49m         self.b1 = np.zeros(hidden_size)
[0m[49m[38;5;10m+     663[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     664[0m:[38;5;10m[49m         # Layer 2: hidden_size -> hidden_size // 2
[0m[49m[38;5;10m+     665[0m:[38;5;10m[49m         h2 = hidden_size // 2
[0m[49m[38;5;10m+     666[0m:[38;5;10m[49m         self.w2 = np.random.randn(hidden_size, h2) * np.sqrt(2.0 / hidden_size)
[0m[49m[38;5;10m+     667[0m:[38;5;10m[49m         self.b2 = np.zeros(h2)
[0m[49m[38;5;10m+     668[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     669[0m:[38;5;10m[49m         # Output layer: hidden -> action_dim (logits)
[0m[49m[38;5;10m+     670[0m:[38;5;10m[49m         self.w_out = np.random.randn(h2, action_dim) * np.sqrt(2.0 / h2)
[0m[49m[38;5;10m+     671[0m:[38;5;10m[49m         self.b_out = np.zeros(action_dim)
[0m[49m[38;5;10m+     672[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     673[0m:[38;5;10m[49m     def forward(self, state: np.ndarray) -> np.ndarray:
[0m[49m[38;5;10m+     674[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     675[0m:[38;5;10m[49m         Forward pass: state vector -> action probabilities.
[0m[49m[38;5;10m+     676[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     677[0m:[38;5;10m[49m         Args:
[0m[49m[38;5;10m+     678[0m:[38;5;10m[49m             state: normalized state vector of shape (state_dim,)
[0m[49m[38;5;10m+     679[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     680[0m:[38;5;10m[49m         Returns:
[0m[49m[38;5;10m+     681[0m:[38;5;10m[49m             Action probability distribution of shape (action_dim,)
[0m[49m[38;5;10m+     682[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     683[0m:[38;5;10m[49m         # Hidden layer 1 with ReLU activation
[0m[49m[38;5;10m+     684[0m:[38;5;10m[49m         h1 = np.maximum(0, state @ self.w1 + self.b1)
[0m[49m[38;5;10m+     685[0m:[38;5;10m[49m         # Hidden layer 2 with ReLU
[0m[49m[38;5;10m+     686[0m:[38;5;10m[49m         h2 = np.maximum(0, h1 @ self.w2 + self.b2)
[0m[49m[38;5;10m+     687[0m:[38;5;10m[49m         # Output logits
[0m[49m[38;5;10m+     688[0m:[38;5;10m[49m         logits = h2 @ self.w_out + self.b_out
[0m[49m[38;5;10m+     689[0m:[38;5;10m[49m         # Softmax to get probabilities
[0m[49m[38;5;10m+     690[0m:[38;5;10m[49m         exp_logits = np.exp(logits - np.max(logits))  # subtract max for stability
[0m[49m[38;5;10m+     691[0m:[38;5;10m[49m         probs = exp_logits / exp_logits.sum()
[0m[49m[38;5;10m+     692[0m:[38;5;10m[49m         return probs
[0m[49m[38;5;10m+     693[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     694[0m:[38;5;10m[49m     def select_action(self, state: np.ndarray, feasible_mask: np.ndarray) -> tuple:
[0m[49m[38;5;10m+     695[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     696[0m:[38;5;10m[49m         Select an action, masking out infeasible actions.
[0m[49m[38;5;10m+     697[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     698[0m:[38;5;10m[49m         Args:
[0m[49m[38;5;10m+     699[0m:[38;5;10m[49m             state: current state vector
[0m[49m[38;5;10m+     700[0m:[38;5;10m[49m             feasible_mask: binary array where 1 = feasible, 0 = infeasible
[0m[49m[38;5;10m+     701[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     702[0m:[38;5;10m[49m         Returns:
[0m[49m[38;5;10m+     703[0m:[38;5;10m[49m             (action_index, action_probability) tuple
[0m[49m[38;5;10m+     704[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     705[0m:[38;5;10m[49m         probs = self.forward(state)
[0m[49m[38;5;10m+     706[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     707[0m:[38;5;10m[49m         # Zero out infeasible actions and renormalize
[0m[49m[38;5;10m+     708[0m:[38;5;10m[49m         masked_probs = probs * feasible_mask
[0m[49m[38;5;10m+     709[0m:[38;5;10m[49m         prob_sum = masked_probs.sum()
[0m[49m[38;5;10m+     710[0m:[38;5;10m[49m         if prob_sum > 0:
[0m[49m[38;5;10m+     711[0m:[38;5;10m[49m             masked_probs = masked_probs / prob_sum
[0m[49m[38;5;10m+     712[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+     713[0m:[38;5;10m[49m             # All actions infeasible (shouldn't happen if no_action is always feasible)
[0m[49m[38;5;10m+     714[0m:[38;5;10m[49m             masked_probs = feasible_mask / feasible_mask.sum()
[0m[49m[38;5;10m+     715[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     716[0m:[38;5;10m[49m         # Sample from the masked distribution
[0m[49m[38;5;10m+     717[0m:[38;5;10m[49m         action = np.random.choice(self.action_dim, p=masked_probs)
[0m[49m[38;5;10m+     718[0m:[38;5;10m[49m         return action, masked_probs[action]
[0m[49m[38;5;10m+     719[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     720[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     721[0m:[38;5;10m[49m def train_policy_loop(num_episodes: int = 1000) -> PolicyNetwork:
[0m[49m[38;5;10m+     722[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     723[0m:[38;5;10m[49m     Train the resource allocation policy using PPO with Lagrangian constraints.
[0m[49m[38;5;10m+     724[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     725[0m:[38;5;10m[49m     This is a simplified training loop that demonstrates the structure.
[0m[49m[38;5;10m+     726[0m:[38;5;10m[49m     In production, you'd use SageMaker RL with RLlib, which handles:
[0m[49m[38;5;10m+     727[0m:[38;5;10m[49m     - Distributed rollout workers (multiple simulator copies in parallel)
[0m[49m[38;5;10m+     728[0m:[38;5;10m[49m     - GPU-accelerated policy updates
[0m[49m[38;5;10m+     729[0m:[38;5;10m[49m     - Proper advantage estimation (GAE)
[0m[49m[38;5;10m+     730[0m:[38;5;10m[49m     - Gradient-based policy optimization
[0m[49m[38;5;10m+     731[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     732[0m:[38;5;10m[49m     Here we show the conceptual flow: collect experience, compute rewards
[0m[49m[38;5;10m+     733[0m:[38;5;10m[49m     with constraint penalties, update the policy.
[0m[49m[38;5;10m+     734[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     735[0m:[38;5;10m[49m     sim = HospitalSimulator()
[0m[49m[38;5;10m+     736[0m:[38;5;10m[49m     policy = PolicyNetwork(state_dim=NUM_STATE_FEATURES, action_dim=NUM_ACTIONS)
[0m[49m[38;5;10m+     737[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     738[0m:[38;5;10m[49m     # Lagrange multipliers for constraint costs (adaptive penalty weights)
[0m[49m[38;5;10m+     739[0m:[38;5;10m[49m     lambda_staffing = 1.0
[0m[49m[38;5;10m+     740[0m:[38;5;10m[49m     lambda_capacity = 1.0
[0m[49m[38;5;10m+     741[0m:[38;5;10m[49m     lambda_boarding = 1.0
[0m[49m[38;5;10m+     742[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     743[0m:[38;5;10m[49m     thresholds = TRAINING_CONFIG["constraint_thresholds"]
[0m[49m[38;5;10m+     744[0m:[38;5;10m[49m     lr_dual = TRAINING_CONFIG["lagrange_lr"]
[0m[49m[38;5;10m+     745[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     746[0m:[38;5;10m[49m     # Track training progress
[0m[49m[38;5;10m+     747[0m:[38;5;10m[49m     episode_rewards = []
[0m[49m[38;5;10m+     748[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     749[0m:[38;5;10m[49m     for episode in range(num_episodes):
[0m[49m[38;5;10m+     750[0m:[38;5;10m[49m         state = sim.reset()
[0m[49m[38;5;10m+     751[0m:[38;5;10m[49m         total_reward = 0.0
[0m[49m[38;5;10m+     752[0m:[38;5;10m[49m         episode_staffing_cost = 0.0
[0m[49m[38;5;10m+     753[0m:[38;5;10m[49m         episode_capacity_cost = 0.0
[0m[49m[38;5;10m+     754[0m:[38;5;10m[49m         episode_boarding_cost = 0.0
[0m[49m[38;5;10m+     755[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     756[0m:[38;5;10m[49m         while not sim.episode_done:
[0m[49m[38;5;10m+     757[0m:[38;5;10m[49m             # Get feasible action mask from constraint checker
[0m[49m[38;5;10m+     758[0m:[38;5;10m[49m             feasible_mask = np.array([
[0m[49m[38;5;10m+     759[0m:[38;5;10m[49m                 1.0 if sim._is_action_feasible(a) else 0.0
[0m[49m[38;5;10m+     760[0m:[38;5;10m[49m                 for a in range(NUM_ACTIONS)
[0m[49m[38;5;10m+     761[0m:[38;5;10m[49m             ])
[0m[49m[38;5;10m+     762[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     763[0m:[38;5;10m[49m             # Select action from policy (with feasibility masking)
[0m[49m[38;5;10m+     764[0m:[38;5;10m[49m             action, action_prob = policy.select_action(state, feasible_mask)
[0m[49m[38;5;10m+     765[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     766[0m:[38;5;10m[49m             # Take step in environment
[0m[49m[38;5;10m+     767[0m:[38;5;10m[49m             next_state, reward, done, info = sim.step(action)
[0m[49m[38;5;10m+     768[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     769[0m:[38;5;10m[49m             # Compute constraint costs for Lagrangian update
[0m[49m[38;5;10m+     770[0m:[38;5;10m[49m             step_staffing_cost = 1.0 if info.get("constraint_violation") else 0.0
[0m[49m[38;5;10m+     771[0m:[38;5;10m[49m             for unit in UNITS:
[0m[49m[38;5;10m+     772[0m:[38;5;10m[49m                 name = unit["name"]
[0m[49m[38;5;10m+     773[0m:[38;5;10m[49m                 if sim.staffing.get(name, 0) < int(np.ceil(sim.census.get(name, 0) * unit["min_ratio"])):
[0m[49m[38;5;10m+     774[0m:[38;5;10m[49m                     step_staffing_cost += 1.0
[0m[49m[38;5;10m+     775[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     776[0m:[38;5;10m[49m             step_boarding_cost = sim.ed_boarders * (TRAINING_CONFIG["decision_interval_minutes"] / 60.0)
[0m[49m[38;5;10m+     777[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     778[0m:[38;5;10m[49m             step_capacity_cost = 0.0
[0m[49m[38;5;10m+     779[0m:[38;5;10m[49m             for unit in UNITS:
[0m[49m[38;5;10m+     780[0m:[38;5;10m[49m                 if sim.census.get(unit["name"], 0) > unit["capacity"]:
[0m[49m[38;5;10m+     781[0m:[38;5;10m[49m                     step_capacity_cost += 1.0
[0m[49m[38;5;10m+     782[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     783[0m:[38;5;10m[49m             episode_staffing_cost += step_staffing_cost
[0m[49m[38;5;10m+     784[0m:[38;5;10m[49m             episode_capacity_cost += step_capacity_cost
[0m[49m[38;5;10m+     785[0m:[38;5;10m[49m             episode_boarding_cost += step_boarding_cost
[0m[49m[38;5;10m+     786[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     787[0m:[38;5;10m[49m             # Augmented reward includes Lagrangian penalty terms
[0m[49m[38;5;10m+     788[0m:[38;5;10m[49m             augmented_reward = (
[0m[49m[38;5;10m+     789[0m:[38;5;10m[49m                 reward
[0m[49m[38;5;10m+     790[0m:[38;5;10m[49m                 - lambda_staffing * step_staffing_cost
[0m[49m[38;5;10m+     791[0m:[38;5;10m[49m                 - lambda_capacity * step_capacity_cost
[0m[49m[38;5;10m+     792[0m:[38;5;10m[49m                 - lambda_boarding * step_boarding_cost
[0m[49m[38;5;10m+     793[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+     794[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     795[0m:[38;5;10m[49m             total_reward += reward
[0m[49m[38;5;10m+     796[0m:[38;5;10m[49m             state = next_state
[0m[49m[38;5;10m+     797[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     798[0m:[38;5;10m[49m         # --- Update Lagrange multipliers (dual gradient ascent) ---
[0m[49m[38;5;10m+     799[0m:[38;5;10m[49m         # If constraints are violated more than threshold, increase penalty.
[0m[49m[38;5;10m+     800[0m:[38;5;10m[49m         # If satisfied, decrease it. This is how the policy learns to respect
[0m[49m[38;5;10m+     801[0m:[38;5;10m[49m         # constraints without us manually tuning penalty weights.
[0m[49m[38;5;10m+     802[0m:[38;5;10m[49m         lambda_staffing += lr_dual * (
[0m[49m[38;5;10m+     803[0m:[38;5;10m[49m             episode_staffing_cost - thresholds["staffing_violations_per_day"]
[0m[49m[38;5;10m+     804[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     805[0m:[38;5;10m[49m         lambda_capacity += lr_dual * (
[0m[49m[38;5;10m+     806[0m:[38;5;10m[49m             episode_capacity_cost - thresholds["capacity_overflows_per_day"]
[0m[49m[38;5;10m+     807[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     808[0m:[38;5;10m[49m         lambda_boarding += lr_dual * (
[0m[49m[38;5;10m+     809[0m:[38;5;10m[49m             episode_boarding_cost - thresholds["ed_boarding_hours_per_day"]
[0m[49m[38;5;10m+     810[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     811[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     812[0m:[38;5;10m[49m         # Clamp to non-negative (Lagrange multipliers must be >= 0)
[0m[49m[38;5;10m+     813[0m:[38;5;10m[49m         lambda_staffing = max(0.0, lambda_staffing)
[0m[49m[38;5;10m+     814[0m:[38;5;10m[49m         lambda_capacity = max(0.0, lambda_capacity)
[0m[49m[38;5;10m+     815[0m:[38;5;10m[49m         lambda_boarding = max(0.0, lambda_boarding)
[0m[49m[38;5;10m+     816[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     817[0m:[38;5;10m[49m         episode_rewards.append(total_reward)
[0m[49m[38;5;10m+     818[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     819[0m:[38;5;10m[49m         # Log progress every 100 episodes
[0m[49m[38;5;10m+     820[0m:[38;5;10m[49m         if (episode + 1) % 100 == 0:
[0m[49m[38;5;10m+     821[0m:[38;5;10m[49m             avg_reward = np.mean(episode_rewards[-100:])
[0m[49m[38;5;10m+     822[0m:[38;5;10m[49m             logger.info(
[0m[49m[38;5;10m+     823[0m:[38;5;10m[49m                 "Episode %d | Avg Reward: %.2f | Lambda staffing: %.3f | "
[0m[49m[38;5;10m+     824[0m:[38;5;10m[49m                 "Lambda capacity: %.3f | Lambda boarding: %.3f",
[0m[49m[38;5;10m+     825[0m:[38;5;10m[49m                 episode + 1, avg_reward, lambda_staffing, lambda_capacity, lambda_boarding
[0m[49m[38;5;10m+     826[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+     827[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     828[0m:[38;5;10m[49m     # NOTE: In this simplified version, we don't actually update the network weights
[0m[49m[38;5;10m+     829[0m:[38;5;10m[49m     # (that requires autograd / backpropagation, i.e., PyTorch or TensorFlow).
[0m[49m[38;5;10m+     830[0m:[38;5;10m[49m     # The structure above shows the data collection and constraint-handling logic
[0m[49m[38;5;10m+     831[0m:[38;5;10m[49m     # that wraps around the actual PPO update step in a real implementation.
[0m[49m[38;5;10m+     832[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     833[0m:[38;5;10m[49m     return policy
[0m[49m[38;5;10m+     834[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     835[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     836[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     837[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     838[0m:[38;5;10m[49m ## Step 4: Offline Policy Evaluation
[0m[49m[38;5;10m+     839[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     840[0m:[38;5;10m[49m *The pseudocode calls this `evaluate_policy_offline(policy, historical_episodes)`. Before deploying any learned policy, you estimate its performance against historical data to get evidence it would do better than the status quo.*
[0m[49m[38;5;10m+     841[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     842[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     843[0m:[38;5;10m[49m def evaluate_policy_offline(
[0m[49m[38;5;10m+     844[0m:[38;5;10m[49m     policy: PolicyNetwork,
[0m[49m[38;5;10m+     845[0m:[38;5;10m[49m     historical_data_bucket: str,
[0m[49m[38;5;10m+     846[0m:[38;5;10m[49m     historical_data_key: str,
[0m[49m[38;5;10m+     847[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+     848[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     849[0m:[38;5;10m[49m     Evaluate a learned policy against historical hospital operations data.
[0m[49m[38;5;10m+     850[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     851[0m:[38;5;10m[49m     This uses a simplified form of importance-weighted evaluation: for each
[0m[49m[38;5;10m+     852[0m:[38;5;10m[49m     historical state, we check what our policy would have recommended vs.
[0m[49m[38;5;10m+     853[0m:[38;5;10m[49m     what actually happened, and estimate the reward difference.
[0m[49m[38;5;10m+     854[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     855[0m:[38;5;10m[49m     In production, use proper Off-Policy Evaluation (OPE) methods:
[0m[49m[38;5;10m+     856[0m:[38;5;10m[49m     - Fitted Q-Evaluation (FQE) for lower-variance estimates
[0m[49m[38;5;10m+     857[0m:[38;5;10m[49m     - Doubly-robust estimators for bias-variance tradeoff
[0m[49m[38;5;10m+     858[0m:[38;5;10m[49m     - Multiple OPE methods to cross-validate each other
[0m[49m[38;5;10m+     859[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     860[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     861[0m:[38;5;10m[49m         policy: trained policy network
[0m[49m[38;5;10m+     862[0m:[38;5;10m[49m         historical_data_bucket: S3 bucket with historical episodes
[0m[49m[38;5;10m+     863[0m:[38;5;10m[49m         historical_data_key: S3 key prefix for evaluation data
[0m[49m[38;5;10m+     864[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     865[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     866[0m:[38;5;10m[49m         Dict with evaluation metrics and pass/fail recommendation
[0m[49m[38;5;10m+     867[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     868[0m:[38;5;10m[49m     s3_client = boto3.client("s3", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     869[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     870[0m:[38;5;10m[49m     # Load historical episodes from S3
[0m[49m[38;5;10m+     871[0m:[38;5;10m[49m     response = s3_client.get_object(Bucket=historical_data_bucket, Key=historical_data_key)
[0m[49m[38;5;10m+     872[0m:[38;5;10m[49m     historical_episodes = json.loads(response["Body"].read().decode("utf-8"))
[0m[49m[38;5;10m+     873[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     874[0m:[38;5;10m[49m     results = []
[0m[49m[38;5;10m+     875[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     876[0m:[38;5;10m[49m     for episode in historical_episodes:
[0m[49m[38;5;10m+     877[0m:[38;5;10m[49m         policy_reward_estimate = 0.0
[0m[49m[38;5;10m+     878[0m:[38;5;10m[49m         actual_reward = 0.0
[0m[49m[38;5;10m+     879[0m:[38;5;10m[49m         discount = 1.0
[0m[49m[38;5;10m+     880[0m:[38;5;10m[49m         gamma = TRAINING_CONFIG["gamma"]
[0m[49m[38;5;10m+     881[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     882[0m:[38;5;10m[49m         for transition in episode["transitions"]:
[0m[49m[38;5;10m+     883[0m:[38;5;10m[49m             state = np.array(transition["state"], dtype=np.float32)
[0m[49m[38;5;10m+     884[0m:[38;5;10m[49m             actual_action = transition["action"]
[0m[49m[38;5;10m+     885[0m:[38;5;10m[49m             step_reward = transition["reward"]
[0m[49m[38;5;10m+     886[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     887[0m:[38;5;10m[49m             actual_reward += discount * step_reward
[0m[49m[38;5;10m+     888[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     889[0m:[38;5;10m[49m             # What would our policy have done?
[0m[49m[38;5;10m+     890[0m:[38;5;10m[49m             feasible_mask = np.array(transition.get("feasible_mask", np.ones(NUM_ACTIONS)))
[0m[49m[38;5;10m+     891[0m:[38;5;10m[49m             policy_probs = policy.forward(state) * feasible_mask
[0m[49m[38;5;10m+     892[0m:[38;5;10m[49m             if policy_probs.sum() > 0:
[0m[49m[38;5;10m+     893[0m:[38;5;10m[49m                 policy_probs = policy_probs / policy_probs.sum()
[0m[49m[38;5;10m+     894[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     895[0m:[38;5;10m[49m             # Greedy policy action
[0m[49m[38;5;10m+     896[0m:[38;5;10m[49m             policy_action = int(np.argmax(policy_probs))
[0m[49m[38;5;10m+     897[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     898[0m:[38;5;10m[49m             # Estimate reward under policy action using the historical transition
[0m[49m[38;5;10m+     899[0m:[38;5;10m[49m             # (simplified: assume same reward if same action, slight bonus otherwise)
[0m[49m[38;5;10m+     900[0m:[38;5;10m[49m             if policy_action == actual_action:
[0m[49m[38;5;10m+     901[0m:[38;5;10m[49m                 policy_reward_estimate += discount * step_reward
[0m[49m[38;5;10m+     902[0m:[38;5;10m[49m             else:
[0m[49m[38;5;10m+     903[0m:[38;5;10m[49m                 # Conservative estimate: assume policy action gets similar reward
[0m[49m[38;5;10m+     904[0m:[38;5;10m[49m                 # Real OPE would use a learned dynamics model here
[0m[49m[38;5;10m+     905[0m:[38;5;10m[49m                 policy_reward_estimate += discount * step_reward * 0.9
[0m[49m[38;5;10m+     906[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     907[0m:[38;5;10m[49m             discount *= gamma
[0m[49m[38;5;10m+     908[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     909[0m:[38;5;10m[49m         improvement = policy_reward_estimate - actual_reward
[0m[49m[38;5;10m+     910[0m:[38;5;10m[49m         results.append({
[0m[49m[38;5;10m+     911[0m:[38;5;10m[49m             "actual_reward": actual_reward,
[0m[49m[38;5;10m+     912[0m:[38;5;10m[49m             "policy_reward_estimate": policy_reward_estimate,
[0m[49m[38;5;10m+     913[0m:[38;5;10m[49m             "improvement": improvement,
[0m[49m[38;5;10m+     914[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     915[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     916[0m:[38;5;10m[49m     # Aggregate results
[0m[49m[38;5;10m+     917[0m:[38;5;10m[49m     improvements = [r["improvement"] for r in results]
[0m[49m[38;5;10m+     918[0m:[38;5;10m[49m     avg_improvement = float(np.mean(improvements))
[0m[49m[38;5;10m+     919[0m:[38;5;10m[49m     std_improvement = float(np.std(improvements))
[0m[49m[38;5;10m+     920[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     921[0m:[38;5;10m[49m     # Bootstrap confidence interval (95%)
[0m[49m[38;5;10m+     922[0m:[38;5;10m[49m     n_bootstrap = 1000
[0m[49m[38;5;10m+     923[0m:[38;5;10m[49m     bootstrap_means = []
[0m[49m[38;5;10m+     924[0m:[38;5;10m[49m     for _ in range(n_bootstrap):
[0m[49m[38;5;10m+     925[0m:[38;5;10m[49m         sample = np.random.choice(improvements, size=len(improvements), replace=True)
[0m[49m[38;5;10m+     926[0m:[38;5;10m[49m         bootstrap_means.append(np.mean(sample))
[0m[49m[38;5;10m+     927[0m:[38;5;10m[49m     ci_lower = float(np.percentile(bootstrap_means, 2.5))
[0m[49m[38;5;10m+     928[0m:[38;5;10m[49m     ci_upper = float(np.percentile(bootstrap_means, 97.5))
[0m[49m[38;5;10m+     929[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     930[0m:[38;5;10m[49m     # Pass criteria: average improvement > 0 AND lower CI bound > 0
[0m[49m[38;5;10m+     931[0m:[38;5;10m[49m     passes = avg_improvement > 0 and ci_lower > 0
[0m[49m[38;5;10m+     932[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     933[0m:[38;5;10m[49m     evaluation_result = {
[0m[49m[38;5;10m+     934[0m:[38;5;10m[49m         "episodes_evaluated": len(results),
[0m[49m[38;5;10m+     935[0m:[38;5;10m[49m         "avg_improvement": round(avg_improvement, 4),
[0m[49m[38;5;10m+     936[0m:[38;5;10m[49m         "std_improvement": round(std_improvement, 4),
[0m[49m[38;5;10m+     937[0m:[38;5;10m[49m         "ci_95_lower": round(ci_lower, 4),
[0m[49m[38;5;10m+     938[0m:[38;5;10m[49m         "ci_95_upper": round(ci_upper, 4),
[0m[49m[38;5;10m+     939[0m:[38;5;10m[49m         "passes_threshold": passes,
[0m[49m[38;5;10m+     940[0m:[38;5;10m[49m         "recommendation": "DEPLOY" if passes else "DO_NOT_DEPLOY",
[0m[49m[38;5;10m+     941[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     942[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     943[0m:[38;5;10m[49m     logger.info("Offline evaluation complete: %s", json.dumps(evaluation_result))
[0m[49m[38;5;10m+     944[0m:[38;5;10m[49m     return evaluation_result
[0m[49m[38;5;10m+     945[0m:[38;5;10m[49m ```
