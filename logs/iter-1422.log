[0m[49m[38;5;10m+    1105[0m:[38;5;10m[49m     item = json.loads(json.dumps(payload), parse_float=Decimal)
[0m[49m[38;5;10m+    1106[0m:[38;5;10m[49m     item["ttl"] = int(time.time()) + (90 * 24 * 3600)  # 90-day retention
