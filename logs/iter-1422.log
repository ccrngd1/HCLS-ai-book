[0m[49m[38;5;10m+    1077[0m:[38;5;10m[49m             "Source unit has surplus staff above minimum. "
[0m[49m[38;5;10m+    1078[0m:[38;5;10m[49m             "Proactive float prevents violation before it occurs."
[0m[49m[38;5;10m+    1079[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    1080[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    1081[0m:[38;5;10m[49m         return "Recommended based on current state and predicted demand trajectory."
[0m[49m[38;5;10m+    1082[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1083[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1084[0m:[38;5;10m[49m def _summarize_state(state: np.ndarray) -> dict:
[0m[49m[38;5;10m+    1085[0m:[38;5;10m[49m     """Create a human-readable state summary for the dashboard."""
[0m[49m[38;5;10m+    1086[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    1087[0m:[38;5;10m[49m         "icu_occupancy": f"{state[0]:.0%}" if len(state) > 0 else "unknown",
[0m[49m[38;5;10m+    1088[0m:[38;5;10m[49m         "stepdown_occupancy": f"{state[1]:.0%}" if len(state) > 1 else "unknown",
[0m[49m[38;5;10m+    1089[0m:[38;5;10m[49m         "medsurg_occupancy": f"{(state[2] + state[3]) / 2:.0%}" if len(state) > 3 else "unknown",
[0m[49m[38;5;10m+    1090[0m:[38;5;10m[49m         "ed_boarders": int(state[11]) if len(state) > 11 else 0,
[0m[49m[38;5;10m+    1091[0m:[38;5;10m[49m         "or_cases_remaining": int(state[15]) if len(state) > 15 else 0,
[0m[49m[38;5;10m+    1092[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1093[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1094[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1095[0m:[38;5;10m[49m def _log_recommendation(payload: dict):
[0m[49m[38;5;10m+    1096[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1097[0m:[38;5;10m[49m     Write recommendation to DynamoDB for audit trail and feedback collection.
[0m[49m[38;5;10m+    1098[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1099[0m:[38;5;10m[49m     Every recommendation is logged regardless of whether the human accepts it.
[0m[49m[38;5;10m+    1100[0m:[38;5;10m[49m     Acceptance/rejection data feeds back into future training cycles.
[0m[49m[38;5;10m+    1101[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1102[0m:[38;5;10m[49m     table = dynamodb.Table("hospital-resource-recommendations")
[0m[49m[38;5;10m+    1103[0m:[38;5;10m[49m 
