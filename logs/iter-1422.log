[0m[49m[38;5;10m+     947[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     948[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     949[0m:[38;5;10m[49m ## Step 5: Deploy as Decision Support with Constraint Checking
[0m[49m[38;5;10m+     950[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     951[0m:[38;5;10m[49m *The pseudocode calls this `generate_recommendation(hospital_id)`. The trained policy produces ranked recommendations that a human bed coordinator reviews. Every recommendation passes through a hard constraint checker before being shown.*
[0m[49m[38;5;10m+     952[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     953[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     954[0m:[38;5;10m[49m # In production, the model artifact is loaded from SageMaker Model Registry.
[0m[49m[38;5;10m+     955[0m:[38;5;10m[49m # For this example, we'll assume the policy object is available.
[0m[49m[38;5;10m+     956[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     957[0m:[38;5;10m[49m sagemaker_runtime = boto3.client("sagemaker-runtime", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     958[0m:[38;5;10m[49m dynamodb_client = boto3.client("dynamodb", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     959[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     960[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     961[0m:[38;5;10m[49m def generate_recommendation(hospital_id: str, policy: PolicyNetwork) -> dict:
[0m[49m[38;5;10m+     962[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     963[0m:[38;5;10m[49m     Generate resource allocation recommendations for the current hospital state.
[0m[49m[38;5;10m+     964[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     965[0m:[38;5;10m[49m     This is the inference path: called every 15-30 minutes by a scheduled
[0m[49m[38;5;10m+     966[0m:[38;5;10m[49m     Lambda or triggered by significant state changes (e.g., new ED boarder).
[0m[49m[38;5;10m+     967[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     968[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     969[0m:[38;5;10m[49m         hospital_id: facility identifier
[0m[49m[38;5;10m+     970[0m:[38;5;10m[49m         policy: trained policy network (in production, loaded from model registry)
[0m[49m[38;5;10m+     971[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     972[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     973[0m:[38;5;10m[49m         Recommendation payload for the capacity dashboard
[0m[49m[38;5;10m+     974[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     975[0m:[38;5;10m[49m     timestamp = time.time()
[0m[49m[38;5;10m+     976[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     977[0m:[38;5;10m[49m     # Build current state
[0m[49m[38;5;10m+     978[0m:[38;5;10m[49m     state = build_state_vector(hospital_id, timestamp)
[0m[49m[38;5;10m+     979[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     980[0m:[38;5;10m[49m     # Get action probabilities from policy
[0m[49m[38;5;10m+     981[0m:[38;5;10m[49m     action_probs = policy.forward(state)
[0m[49m[38;5;10m+     982[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     983[0m:[38;5;10m[49m     # Build feasibility mask from current constraints
[0m[49m[38;5;10m+     984[0m:[38;5;10m[49m     # In production, this calls the constraint checker with real hospital state
[0m[49m[38;5;10m+     985[0m:[38;5;10m[49m     sim = HospitalSimulator()  # temporary, just for constraint checking structure
[0m[49m[38;5;10m+     986[0m:[38;5;10m[49m     feasible_mask = np.ones(NUM_ACTIONS)
[0m[49m[38;5;10m+     987[0m:[38;5;10m[49m     # (In production, you'd check actual constraints against real state)
[0m[49m[38;5;10m+     988[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     989[0m:[38;5;10m[49m     # Mask and get top-K recommendations
[0m[49m[38;5;10m+     990[0m:[38;5;10m[49m     masked_probs = action_probs * feasible_mask
[0m[49m[38;5;10m+     991[0m:[38;5;10m[49m     if masked_probs.sum() > 0:
[0m[49m[38;5;10m+     992[0m:[38;5;10m[49m         masked_probs = masked_probs / masked_probs.sum()
[0m[49m[38;5;10m+     993[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     994[0m:[38;5;10m[49m     # Get top 3 actions
[0m[49m[38;5;10m+     995[0m:[38;5;10m[49m     top_k = 3
[0m[49m[38;5;10m+     996[0m:[38;5;10m[49m     top_indices = np.argsort(masked_probs)[::-1][:top_k]
[0m[49m[38;5;10m+     997[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     998[0m:[38;5;10m[49m     recommendations = []
[0m[49m[38;5;10m+     999[0m:[38;5;10m[49m     for idx in top_indices:
[0m[49m[38;5;10m+    1000[0m:[38;5;10m[49m         action_name = ACTION_SPACE[idx]
[0m[49m[38;5;10m+    1001[0m:[38;5;10m[49m         confidence = float(masked_probs[idx])
[0m[49m[38;5;10m+    1002[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1003[0m:[38;5;10m[49m         if confidence < 0.05:
[0m[49m[38;5;10m+    1004[0m:[38;5;10m[49m             continue  # skip very low-confidence actions
[0m[49m[38;5;10m+    1005[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1006[0m:[38;5;10m[49m         recommendations.append({
[0m[49m[38;5;10m+    1007[0m:[38;5;10m[49m             "action": action_name,
[0m[49m[38;5;10m+    1008[0m:[38;5;10m[49m             "action_description": _describe_action(action_name),
[0m[49m[38;5;10m+    1009[0m:[38;5;10m[49m             "confidence": round(confidence, 3),
[0m[49m[38;5;10m+    1010[0m:[38;5;10m[49m             "explanation": _generate_explanation(action_name, state),
[0m[49m[38;5;10m+    1011[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    1012[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1013[0m:[38;5;10m[49m     # Build the full recommendation payload
[0m[49m[38;5;10m+    1014[0m:[38;5;10m[49m     recommendation_id = str(uuid.uuid4())
[0m[49m[38;5;10m+    1015[0m:[38;5;10m[49m     payload = {
[0m[49m[38;5;10m+    1016[0m:[38;5;10m[49m         "recommendation_id": recommendation_id,
[0m[49m[38;5;10m+    1017[0m:[38;5;10m[49m         "hospital_id": hospital_id,
[0m[49m[38;5;10m+    1018[0m:[38;5;10m[49m         "timestamp": int(timestamp),
[0m[49m[38;5;10m+    1019[0m:[38;5;10m[49m         "recommendations": recommendations,
[0m[49m[38;5;10m+    1020[0m:[38;5;10m[49m         "state_summary": _summarize_state(state),
[0m[49m[38;5;10m+    1021[0m:[38;5;10m[49m         "constraint_status": "all_satisfied",
[0m[49m[38;5;10m+    1022[0m:[38;5;10m[49m         "model_version": "v1.0.0-demo",
[0m[49m[38;5;10m+    1023[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1024[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1025[0m:[38;5;10m[49m     # Log for audit trail and future training
[0m[49m[38;5;10m+    1026[0m:[38;5;10m[49m     _log_recommendation(payload)
[0m[49m[38;5;10m+    1027[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1028[0m:[38;5;10m[49m     return payload
[0m[49m[38;5;10m+    1029[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1030[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1031[0m:[38;5;10m[49m def _describe_action(action_name: str) -> str:
[0m[49m[38;5;10m+    1032[0m:[38;5;10m[49m     """Human-readable description of each action."""
[0m[49m[38;5;10m+    1033[0m:[38;5;10m[49m     descriptions = {
[0m[49m[38;5;10m+    1034[0m:[38;5;10m[49m         "no_action": "No intervention needed at this time",
[0m[49m[38;5;10m+    1035[0m:[38;5;10m[49m         "assign_ed_boarder_medsurg_a": "Move ED boarder to Med-Surg A",
[0m[49m[38;5;10m+    1036[0m:[38;5;10m[49m         "assign_ed_boarder_medsurg_b": "Move ED boarder to Med-Surg B",
[0m[49m[38;5;10m+    1037[0m:[38;5;10m[49m         "assign_ed_boarder_telemetry": "Move ED boarder to Telemetry",
[0m[49m[38;5;10m+    1038[0m:[38;5;10m[49m         "assign_ed_boarder_stepdown": "Move ED boarder to Step-Down",
[0m[49m[38;5;10m+    1039[0m:[38;5;10m[49m         "transfer_icu_to_stepdown": "Transfer stable ICU patient to Step-Down",
[0m[49m[38;5;10m+    1040[0m:[38;5;10m[49m         "transfer_stepdown_to_medsurg": "Transfer step-down patient to Med-Surg floor",
[0m[49m[38;5;10m+    1041[0m:[38;5;10m[49m         "float_nurse_to_icu": "Float nurse from lower-acuity unit to ICU",
[0m[49m[38;5;10m+    1042[0m:[38;5;10m[49m         "float_nurse_to_ed": "Float nurse to ED for boarding patient care",
[0m[49m[38;5;10m+    1043[0m:[38;5;10m[49m         "activate_overflow": "Activate overflow capacity section",
[0m[49m[38;5;10m+    1044[0m:[38;5;10m[49m         "request_early_discharge_review": "Flag patients for expedited discharge review",
[0m[49m[38;5;10m+    1045[0m:[38;5;10m[49m         "hold_or_bed_for_post_op": "Reserve bed for upcoming OR case completion",
[0m[49m[38;5;10m+    1046[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1047[0m:[38;5;10m[49m     return descriptions.get(action_name, action_name)
[0m[49m[38;5;10m+    1048[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1049[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1050[0m:[38;5;10m[49m def _generate_explanation(action_name: str, state: np.ndarray) -> str:
[0m[49m[38;5;10m+    1051[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1052[0m:[38;5;10m[49m     Generate a brief explanation of why this action was recommended.
[0m[49m[38;5;10m+    1053[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1054[0m:[38;5;10m[49m     In production, this would use SHAP values or attention weights from the
[0m[49m[38;5;10m+    1055[0m:[38;5;10m[49m     policy network to identify which state features most influenced the
[0m[49m[38;5;10m+    1056[0m:[38;5;10m[49m     recommendation. Here we use rule-based heuristics as a placeholder.
