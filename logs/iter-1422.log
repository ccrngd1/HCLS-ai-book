[0m[49m[38;5;10m+      13[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+      14[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      15[0m:[38;5;10m[49m Your environment needs AWS credentials configured (via environment variables, instance profile, or `~/.aws/credentials`). The IAM role or user needs `sagemaker:CreateTrainingJob`, `sagemaker:DescribeTrainingJob`, `sagemaker:InvokeEndpoint`, `dynamodb:PutItem`, `dynamodb:GetItem`, `dynamodb:Query`, `kinesis:GetRecords`, `kinesis:PutRecord`, `s3:GetObject`, `s3:PutObject`, and `states:StartExecution`.
[0m[49m[38;5;10m+      16[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      17[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+      18[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      19[0m:[38;5;10m[49m ## Config and Constants
[0m[49m[38;5;10m+      20[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      21[0m:[38;5;10m[49m Before the logic, here's the configuration that defines the hospital domain. These constants encode operational knowledge about resource allocation: what units exist, what actions are possible, what constraints are non-negotiable, and how to score outcomes. In a real system, these would be developed with hospital operations leadership and validated against your specific facility's data.
[0m[49m[38;5;10m+      22[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      23[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+      24[0m:[38;5;10m[49m import numpy as np
[0m[49m[38;5;10m+      25[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+      26[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+      27[0m:[38;5;10m[49m import time
[0m[49m[38;5;10m+      28[0m:[38;5;10m[49m import uuid
[0m[49m[38;5;10m+      29[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+      30[0m:[38;5;10m[49m from typing import Optional
[0m[49m[38;5;10m+      31[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      32[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+      33[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+      34[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      35[0m:[38;5;10m[49m # Structured logging. In production, use JSON format for CloudWatch Logs Insights.
[0m[49m[38;5;10m+      36[0m:[38;5;10m[49m # Never log patient identifiers, room numbers tied to patients, or PHI values.
[0m[49m[38;5;10m+      37[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+      38[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+      39[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      40[0m:[38;5;10m[49m # Retry config for AWS calls. Adaptive mode handles throttling gracefully.
[0m[49m[38;5;10m+      41[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+      42[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      43[0m:[38;5;10m[49m # --- Hospital Configuration ---
[0m[49m[38;5;10m+      44[0m:[38;5;10m[49m # Each unit has a name, capacity, type, and minimum staffing ratio (nurses:patients).
[0m[49m[38;5;10m+      45[0m:[38;5;10m[49m # This models a mid-size community hospital (~250 beds). Your facility will differ.
[0m[49m[38;5;10m+      46[0m:[38;5;10m[49m UNITS = [
[0m[49m[38;5;10m+      47[0m:[38;5;10m[49m     {"name": "icu", "capacity": 20, "type": "critical", "min_ratio": 0.5},
[0m[49m[38;5;10m+      48[0m:[38;5;10m[49m     {"name": "stepdown", "capacity": 24, "type": "intermediate", "min_ratio": 0.33},
[0m[49m[38;5;10m+      49[0m:[38;5;10m[49m     {"name": "medsurg_a", "capacity": 36, "type": "general", "min_ratio": 0.2},
[0m[49m[38;5;10m+      50[0m:[38;5;10m[49m     {"name": "medsurg_b", "capacity": 36, "type": "general", "min_ratio": 0.2},
[0m[49m[38;5;10m+      51[0m:[38;5;10m[49m     {"name": "telemetry", "capacity": 28, "type": "monitored", "min_ratio": 0.25},
[0m[49m[38;5;10m+      52[0m:[38;5;10m[49m     {"name": "ed_holding", "capacity": 12, "type": "emergency", "min_ratio": 0.33},
[0m[49m[38;5;10m+      53[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+      54[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      55[0m:[38;5;10m[49m TOTAL_BEDS = sum(u["capacity"] for u in UNITS)
[0m[49m[38;5;10m+      56[0m:[38;5;10m[49m NUM_UNITS = len(UNITS)
[0m[49m[38;5;10m+      57[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      58[0m:[38;5;10m[49m # --- Action Space ---
[0m[49m[38;5;10m+      59[0m:[38;5;10m[49m # Discrete actions the RL agent can recommend. Each represents a common
[0m[49m[38;5;10m+      60[0m:[38;5;10m[49m # resource allocation decision that bed coordinators make dozens of times daily.
[0m[49m[38;5;10m+      61[0m:[38;5;10m[49m ACTION_SPACE = [
[0m[49m[38;5;10m+      62[0m:[38;5;10m[49m     "no_action",                        # 0: hold, no change needed right now
[0m[49m[38;5;10m+      63[0m:[38;5;10m[49m     "assign_ed_boarder_medsurg_a",      # 1: move ED boarder to med-surg A
[0m[49m[38;5;10m+      64[0m:[38;5;10m[49m     "assign_ed_boarder_medsurg_b",      # 2: move ED boarder to med-surg B
[0m[49m[38;5;10m+      65[0m:[38;5;10m[49m     "assign_ed_boarder_telemetry",      # 3: move ED boarder to telemetry
[0m[49m[38;5;10m+      66[0m:[38;5;10m[49m     "assign_ed_boarder_stepdown",       # 4: move ED boarder to step-down
[0m[49m[38;5;10m+      67[0m:[38;5;10m[49m     "transfer_icu_to_stepdown",         # 5: step down an ICU patient
[0m[49m[38;5;10m+      68[0m:[38;5;10m[49m     "transfer_stepdown_to_medsurg",     # 6: move step-down patient to floor
[0m[49m[38;5;10m+      69[0m:[38;5;10m[49m     "float_nurse_to_icu",              # 7: float a nurse from low-acuity unit to ICU
[0m[49m[38;5;10m+      70[0m:[38;5;10m[49m     "float_nurse_to_ed",               # 8: float a nurse to ED
[0m[49m[38;5;10m+      71[0m:[38;5;10m[49m     "activate_overflow",               # 9: open overflow beds (high cost)
[0m[49m[38;5;10m+      72[0m:[38;5;10m[49m     "request_early_discharge_review",  # 10: flag patients for expedited discharge
[0m[49m[38;5;10m+      73[0m:[38;5;10m[49m     "hold_or_bed_for_post_op",         # 11: reserve bed for upcoming OR case
[0m[49m[38;5;10m+      74[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+      75[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      76[0m:[38;5;10m[49m NUM_ACTIONS = len(ACTION_SPACE)
[0m[49m[38;5;10m+      77[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      78[0m:[38;5;10m[49m # --- State Feature Definitions ---
