[0m[49m[38;5;10m+    1068[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    1069[0m:[38;5;10m[49m     elif "transfer_icu" in action_name:
[0m[49m[38;5;10m+    1070[0m:[38;5;10m[49m         return (
[0m[49m[38;5;10m+    1071[0m:[38;5;10m[49m             f"ICU at {icu_occ:.0%} capacity with pending admissions. "
[0m[49m[38;5;10m+    1072[0m:[38;5;10m[49m             f"Stepping down stable patient creates buffer for anticipated demand."
[0m[49m[38;5;10m+    1073[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    1074[0m:[38;5;10m[49m     elif "float_nurse" in action_name:
[0m[49m[38;5;10m+    1075[0m:[38;5;10m[49m         return (
