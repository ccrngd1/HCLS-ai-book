[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m def aggregate_arrivals_to_hourly(adt_records):
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m     """Step 1: Bucket ADT records into hourly arrival counts per ESI level.
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m 
