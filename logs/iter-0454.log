[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m     of rows, one per (ed_id, local_hour) pair, with per-ESI-level
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m     counts plus a total. A real pipeline reads from Kinesis with a
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m     five-minute watermark for late records; the demo assumes
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m     in-order arrival because the synthetic data is generated
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m     sequentially.
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m     # 1a. Bucket each arrival into a (ed_id, local_hour) pair.
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m     # Hour boundaries are local time at the ED. The demo uses
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m     # naive datetimes; production tags each record with the ED's
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m     # IANA timezone identifier and floors against the local
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m     # wall-clock hour, not UTC.
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m     hourly_buckets = defaultdict(lambda: {
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m         "esi_1": 0, "esi_2": 0, "esi_3": 0, "esi_4": 0, "esi_5": 0,
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m         "esi_unknown": 0, "total": 0,
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m     for record in adt_records:
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m         arrival_ts = datetime.fromisoformat(record["arrival_ts"])
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m         # Floor to the hour. Production uses the ED's local
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m         # timezone; the demo uses naive local times so the
