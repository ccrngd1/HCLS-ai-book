[0m[49m[38;5;10m+     49[0m:[38;5;10m[49m ## Configuration and Constants
[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m Everything that is configuration rather than logic lives here. Resource names, the modeling horizons, the prediction-interval levels, the validation window length, the per-ESI default shares, and the synthetic-data parameters are what you would change between environments.
[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m import math
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m import random
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m import uuid
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m from collections import defaultdict
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m from datetime import date, datetime, timedelta, timezone
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m from statistics import mean, stdev
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m # Structured logging. In production, ship JSON-formatted records
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m # to CloudWatch Logs Insights for cross-call investigation.
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m # ADT registration messages contain PHI directly (patient name,
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m # MRN, demographics, chief complaint). The aggregation step
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m # strips identifiers; everything downstream of the Glue boundary
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m # is hourly-count aggregates without per-patient identifiers.
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m # Log structural metadata only (run_id, ed_id, hour_local,
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m # arrival_count, mean_error, runtime_ms), never raw ADT records,
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m # never per-patient timestamps tied to identifiable visits.
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m # Adaptive retry handles throttling from S3, DynamoDB, EventBridge,
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m # CloudWatch, Kinesis, and SageMaker. The hourly inference cycle
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m # is a scheduled batch job with a charge-nurse waiting on the
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m # refreshed dashboard, so retries should be quick and capped.
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m # A stuck dependency must not balloon a 90-second hourly cycle
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m # into a multi-minute incident.
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m     retries={"max_attempts": 5, "mode": "adaptive"})
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m # Module-level clients. Reused across function calls within the
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m # pipeline so each call does not pay the connection cost. The
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m # demo wires up MockS3 / MockTable / MockEventBus / MockCloudWatch
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m # via run_demo() and never touches these real handles; they are
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m # staged here so production wiring is a one-line swap. boto3
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m # client and resource construction is lazy (no network call
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m # until first use), so the unused handles are free at import.
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m REGION = "us-east-1"
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m s3_client          = boto3.client("s3",
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m                                   region_name=REGION,
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m                                   config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m dynamodb           = boto3.resource("dynamodb",
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m                                     region_name=REGION,
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m                                     config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m kinesis_client     = boto3.client("kinesis",
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m                                   region_name=REGION,
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m                                   config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m eventbridge_client = boto3.client("events",
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m                                   region_name=REGION,
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m                                   config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m cloudwatch_client  = boto3.client("cloudwatch",
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m                                   region_name=REGION,
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m                                   config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m sagemaker_client   = boto3.client("sagemaker",
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m                                   region_name=REGION,
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m                                   config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m # --- Resource Names ---
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m # Fill these in with your actual resource names. The demo prints
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m # what it would write rather than failing if the resources do
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m # not exist; see run_demo() at the bottom.
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m ADT_KINESIS_STREAM_NAME    = "ed-adt-registration-stream"
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m HOURLY_ARRIVALS_BUCKET     = "ed-forecast-arrivals-hourly"
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m WEATHER_BUCKET             = "ed-forecast-weather"
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m FLU_INDEX_BUCKET           = "ed-forecast-flu-index"
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m EVENT_CALENDAR_BUCKET      = "ed-forecast-event-calendar"
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m MODEL_ARTIFACT_BUCKET      = "ed-forecast-models"
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m FORECAST_OUTPUT_BUCKET     = "ed-forecast-outputs"
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m ED_FORECASTS_TABLE         = "ed-forecast-records"
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m FORECAST_EVENT_BUS_NAME    = "ed-forecast-events-bus"
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m CLOUDWATCH_NAMESPACE       = "EDArrivalForecast"
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m # --- Versioning ---
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m # Every forecast record carries the model version active at the
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m # time of generation. This is how a future audit reconstructs
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m # which model produced which dashboard reading on which night.
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m PIPELINE_VERSION       = "ed-arrivals-v1.4"
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m VOLUME_MODEL_VERSION   = "poisson-glm-2026-04-08"
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m ACUITY_MODEL_VERSION   = "multinomial-2026-04-08"
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m # --- ED and Time Configuration ---
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m # Synthetic ED for the demo. Production reads the ED list from
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m # a registry table and runs the pipeline per-ED in a Step
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m # Functions Map state.
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m SYNTHETIC_ED_ID       = "regional-medical-center-001"
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m SYNTHETIC_ED_TIMEZONE = "US/Eastern"   # for documentation only; demo uses naive local times
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m # --- Forecast Horizons ---
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m # Three operational horizons cover the typical ED decision
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m # surface: 4 hours for charge-nurse call-in decisions, 12 hours
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m # for shift-staffing tweaks, 24 hours for next-day shift planning.
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m # Each horizon is evaluated separately because accuracy degrades
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m # with horizon length.
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m FORECAST_HORIZONS_HOURS = [4, 12, 24]
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m # --- Validation Window ---
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m # 90 days of recent history held out from training and used for
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m # computing forecast-error metrics and the residual standard
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m # deviation that drives prediction intervals. Less than 60 days
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m # does not span enough day-of-week and weather variation; more
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m # than 120 days starves the training set without proportional
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m # benefit.
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m VALIDATION_WINDOW_DAYS = 90
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m # --- Prediction Interval Levels ---
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m # 80% interval for typical operational planning, 95% for the
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m # upper-bound surge-plan trigger. The z-scores correspond to
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m # the standard normal approximation; production with a true
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m # Poisson or negative-binomial model would use the actual
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m # distribution's quantile.
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m PREDICTION_INTERVAL_LEVELS = {
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m     "80": Decimal("1.282"),
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m     "95": Decimal("1.960"),
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m # --- Acuity / ESI Levels ---
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m # Emergency Severity Index ranges from 1 (resuscitation) to 5
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m # (routine). Level 1 and Level 2 demand immediate room and
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m # physician attention; Level 4 and Level 5 can be handled in a
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m # fast-track lane with an advanced practice provider.
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m ESI_LEVELS = [1, 2, 3, 4, 5]
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m # Default mix used as a fallback when the acuity classifier
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m # cannot produce a confident split (e.g., very early hours of
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m # new ED onboarding before enough triage history has accumulated).
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m # The defaults below are illustrative; production reads the
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m # baseline mix from the institution's ESI mix history.
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m DEFAULT_ACUITY_SHARES = {
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m     1: Decimal("0.02"),
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m     2: Decimal("0.18"),
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m     3: Decimal("0.46"),
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m     4: Decimal("0.24"),
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m     5: Decimal("0.10"),
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m # --- Synthetic Data ---
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m # Knobs for the demo's synthetic-arrivals generator. The ranges
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m # produce a small but realistic-shaped two-year history with
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m # daily, weekly, and seasonal patterns plus weather effects and
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m # flu-season uplift.
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m SYNTHETIC_HISTORY_DAYS = 730     # two years of hourly history
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m SYNTHETIC_RANDOM_SEED  = 42
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m # Deploy-time guardrail. Any blank resource name is a deploy-time
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m # bug, not a runtime surprise.
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m for _name, _value in [
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m     ("ADT_KINESIS_STREAM_NAME",    ADT_KINESIS_STREAM_NAME),
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m     ("HOURLY_ARRIVALS_BUCKET",     HOURLY_ARRIVALS_BUCKET),
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m     ("WEATHER_BUCKET",             WEATHER_BUCKET),
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m     ("FLU_INDEX_BUCKET",           FLU_INDEX_BUCKET),
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m     ("EVENT_CALENDAR_BUCKET",      EVENT_CALENDAR_BUCKET),
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m     ("MODEL_ARTIFACT_BUCKET",      MODEL_ARTIFACT_BUCKET),
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m     ("FORECAST_OUTPUT_BUCKET",     FORECAST_OUTPUT_BUCKET),
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m     ("ED_FORECASTS_TABLE",         ED_FORECASTS_TABLE),
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m     ("FORECAST_EVENT_BUS_NAME",    FORECAST_EVENT_BUS_NAME),
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m     ("CLOUDWATCH_NAMESPACE",       CLOUDWATCH_NAMESPACE),
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m ]:
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     assert _value, f"{_name} must be set before deploying."
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m def _to_decimal(value):
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m     """Convert numeric values to Decimal for DynamoDB-safe writes.
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m     DynamoDB rejects Python float at the SDK boundary because
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m     floating-point cannot represent every decimal value exactly.
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m     Pass everything numeric through this helper before any
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m     PutItem, BatchWriteItem, or UpdateItem call. Pandas and
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m     numpy types are not Decimal-friendly out of the box, so the
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m     helper covers the common cases (int, float, str-of-number,
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m     None) and lets exotic types fail loudly rather than silently.
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m     if value is None:
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m     if isinstance(value, Decimal):
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m         return value
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m     if isinstance(value, bool):
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m         # bool is a subclass of int in Python; route it explicitly
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m         # so True does not become Decimal('1') unexpectedly.
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m         return value
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m     if isinstance(value, (int, float)):
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m         # Round float through string to avoid the float->Decimal
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m         # repr surprise (Decimal(0.1) is not Decimal('0.1')).
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m         return Decimal(str(value))
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m     if isinstance(value, str):
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m         return Decimal(value)
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m     raise TypeError(f"Cannot convert {type(value).__name__} to Decimal")
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m ```
