[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m         ed_ids = sorted({r["ed_id"] for r in output})
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m         filled = []
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m         for ed in ed_ids:
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m             ed_rows = [r for r in output if r["ed_id"] == ed]
