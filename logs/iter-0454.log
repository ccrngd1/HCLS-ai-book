[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m             bucket["esi_unknown"] += 1
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m             bucket[f"esi_{esi}"] += 1
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m         bucket["total"] += 1
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m     # 1b. Materialize the hourly rows. Production writes these to
