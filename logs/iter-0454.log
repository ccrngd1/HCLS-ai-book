[0m[49m[38;5;10m+     782[0m:[38;5;10m[49m         """Convert a Step-2 feature row into the numeric vector."""
[0m[49m[38;5;10m+     783[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+     784[0m:[38;5;10m[49m             "hour_of_day":        float(row["hour_of_day"]),
[0m[49m[38;5;10m+     785[0m:[38;5;10m[49m             "day_of_week":        float(row["day_of_week"]),
[0m[49m[38;5;10m+     786[0m:[38;5;10m[49m             "month":              float(row["month"]),
[0m[49m[38;5;10m+     787[0m:[38;5;10m[49m             "is_weekend_int":     1.0 if row["is_weekend"] else 0.0,
[0m[49m[38;5;10m+     788[0m:[38;5;10m[49m             "is_holiday_int":     1.0 if row["is_holiday"] else 0.0,
[0m[49m[38;5;10m+     789[0m:[38;5;10m[49m             "holiday_distance_d": float(row["holiday_distance_d"]),
[0m[49m[38;5;10m+     790[0m:[38;5;10m[49m             "temperature_f":      float(row["temperature_f"]),
[0m[49m[38;5;10m+     791[0m:[38;5;10m[49m             "precipitation_in":   float(row["precipitation_in"]),
[0m[49m[38;5;10m+     792[0m:[38;5;10m[49m             "wind_speed_mph":     float(row["wind_speed_mph"]),
[0m[49m[38;5;10m+     793[0m:[38;5;10m[49m             "is_severe_int":      1.0 if row["is_severe_weather"] else 0.0,
[0m[49m[38;5;10m+     794[0m:[38;5;10m[49m             "flu_index":          float(row["flu_index"]),
[0m[49m[38;5;10m+     795[0m:[38;5;10m[49m             "has_event_int":      1.0 if row["has_local_event"] else 0.0,
[0m[49m[38;5;10m+     796[0m:[38;5;10m[49m             "lag_1h":             float(row["lag_1h"]),
[0m[49m[38;5;10m+     797[0m:[38;5;10m[49m             "lag_24h":            float(row["lag_24h"]),
[0m[49m[38;5;10m+     798[0m:[38;5;10m[49m             "lag_168h":           float(row["lag_168h"]),
[0m[49m[38;5;10m+     799[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+     800[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     801[0m:[38;5;10m[49m     def _predict_one(self, x):
[0m[49m[38;5;10m+     802[0m:[38;5;10m[49m         """Linear combination plus exponential link."""
[0m[49m[38;5;10m+     803[0m:[38;5;10m[49m         z = self.intercept
[0m[49m[38;5;10m+     804[0m:[38;5;10m[49m         for name, val in x.items():
