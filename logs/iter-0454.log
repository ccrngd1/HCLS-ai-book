[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m                 else:
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m                     filled.append({
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m                         "ed_id":       ed,
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m                         "local_hour":  key,
