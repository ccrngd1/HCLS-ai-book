[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m         bucket = hourly_buckets[key]
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m         # ESI level is assigned at triage. Production sees ~10-30%
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m         # of registrations arrive without an ESI level and
