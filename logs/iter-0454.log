[0m[49m[38;5;10m+     810[0m:[38;5;10m[49m     def fit(self, training_rows, n_iters=8, lr=0.001):
[0m[49m[38;5;10m+     811[0m:[38;5;10m[49m         """Iterative coordinate descent on the log-link squared error.
[0m[49m[38;5;10m+     812[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     813[0m:[38;5;10m[49m         A real Poisson GLM uses iteratively reweighted least
[0m[49m[38;5;10m+     814[0m:[38;5;10m[49m         squares against the deviance. The demo uses gradient
[0m[49m[38;5;10m+     815[0m:[38;5;10m[49m         descent on the squared-error objective for readability;
[0m[49m[38;5;10m+     816[0m:[38;5;10m[49m         it produces a model close enough to demonstrate the
[0m[49m[38;5;10m+     817[0m:[38;5;10m[49m         forecast pipeline.
[0m[49m[38;5;10m+     818[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     819[0m:[38;5;10m[49m         if not training_rows:
[0m[49m[38;5;10m+     820[0m:[38;5;10m[49m             return self
[0m[49m[38;5;10m+     821[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     822[0m:[38;5;10m[49m         # Initialize the intercept to log of the mean count so
[0m[49m[38;5;10m+     823[0m:[38;5;10m[49m         # the optimizer starts in the right neighborhood.
[0m[49m[38;5;10m+     824[0m:[38;5;10m[49m         mean_count = max(0.5, mean(r["target_total"] for r in training_rows))
[0m[49m[38;5;10m+     825[0m:[38;5;10m[49m         self.intercept = math.log(mean_count)
[0m[49m[38;5;10m+     826[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     827[0m:[38;5;10m[49m         # Standardize numeric features so gradient descent
[0m[49m[38;5;10m+     828[0m:[38;5;10m[49m         # behaves. Production GLM solvers handle this internally;
[0m[49m[38;5;10m+     829[0m:[38;5;10m[49m         # the demo does it explicitly so the math is visible.
[0m[49m[38;5;10m+     830[0m:[38;5;10m[49m         feat_means = {name: 0.0 for name in self.FEATURE_NAMES}
[0m[49m[38;5;10m+     831[0m:[38;5;10m[49m         feat_sds   = {name: 1.0 for name in self.FEATURE_NAMES}
[0m[49m[38;5;10m+     832[0m:[38;5;10m[49m         n          = len(training_rows)
[0m[49m[38;5;10m+     833[0m:[38;5;10m[49m         vectors    = [self._row_to_vector(r) for r in training_rows]
[0m[49m[38;5;10m+     834[0m:[38;5;10m[49m         for name in self.FEATURE_NAMES:
[0m[49m[38;5;10m+     835[0m:[38;5;10m[49m             vals      = [v[name] for v in vectors]
[0m[49m[38;5;10m+     836[0m:[38;5;10m[49m             feat_means[name] = sum(vals) / n
[0m[49m[38;5;10m+     837[0m:[38;5;10m[49m             sd = stdev(vals) if n > 1 else 1.0
[0m[49m[38;5;10m+     838[0m:[38;5;10m[49m             feat_sds[name]   = sd if sd > 1e-9 else 1.0
[0m[49m[38;5;10m+     839[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     840[0m:[38;5;10m[49m         def standardize(v):
[0m[49m[38;5;10m+     841[0m:[38;5;10m[49m             return {name: (v[name] - feat_means[name]) / feat_sds[name]
[0m[49m[38;5;10m+     842[0m:[38;5;10m[49m                     for name in self.FEATURE_NAMES}
[0m[49m[38;5;10m+     843[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     844[0m:[38;5;10m[49m         # Gradient descent loop.
[0m[49m[38;5;10m+     845[0m:[38;5;10m[49m         for _ in range(n_iters):
[0m[49m[38;5;10m+     846[0m:[38;5;10m[49m             grad_intercept = 0.0
[0m[49m[38;5;10m+     847[0m:[38;5;10m[49m             grad_coef      = {name: 0.0 for name in self.FEATURE_NAMES}
[0m[49m[38;5;10m+     848[0m:[38;5;10m[49m             for row, v in zip(training_rows, vectors):
[0m[49m[38;5;10m+     849[0m:[38;5;10m[49m                 vs    = standardize(v)
[0m[49m[38;5;10m+     850[0m:[38;5;10m[49m                 pred  = self._predict_one(vs)
[0m[49m[38;5;10m+     851[0m:[38;5;10m[49m                 err   = pred - row["target_total"]
[0m[49m[38;5;10m+     852[0m:[38;5;10m[49m                 grad_intercept += err
[0m[49m[38;5;10m+     853[0m:[38;5;10m[49m                 for name in self.FEATURE_NAMES:
[0m[49m[38;5;10m+     854[0m:[38;5;10m[49m                     grad_coef[name] += err * vs[name]
[0m[49m[38;5;10m+     855[0m:[38;5;10m[49m             self.intercept -= lr * grad_intercept / n
[0m[49m[38;5;10m+     856[0m:[38;5;10m[49m             for name in self.FEATURE_NAMES:
[0m[49m[38;5;10m+     857[0m:[38;5;10m[49m                 self.coef[name] -= lr * grad_coef[name] / n
[0m[49m[38;5;10m+     858[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     859[0m:[38;5;10m[49m         # Compute residual sigma on training data. Production
[0m[49m[38;5;10m+     860[0m:[38;5;10m[49m         # computes it on the held-out validation window because
[0m[49m[38;5;10m+     861[0m:[38;5;10m[49m         # training residuals understate the operational error.
[0m[49m[38;5;10m+     862[0m:[38;5;10m[49m         residuals = []
[0m[49m[38;5;10m+     863[0m:[38;5;10m[49m         self._feat_means = feat_means
[0m[49m[38;5;10m+     864[0m:[38;5;10m[49m         self._feat_sds   = feat_sds
[0m[49m[38;5;10m+     865[0m:[38;5;10m[49m         for row, v in zip(training_rows, vectors):
[0m[49m[38;5;10m+     866[0m:[38;5;10m[49m             vs   = standardize(v)
[0m[49m[38;5;10m+     867[0m:[38;5;10m[49m             pred = self._predict_one(vs)
[0m[49m[38;5;10m+     868[0m:[38;5;10m[49m             residuals.append(row["target_total"] - pred)
[0m[49m[38;5;10m+     869[0m:[38;5;10m[49m         if len(residuals) > 1:
[0m[49m[38;5;10m+     870[0m:[38;5;10m[49m             self.sigma = stdev(residuals)
[0m[49m[38;5;10m+     871[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+     872[0m:[38;5;10m[49m             self.sigma = 1.0
[0m[49m[38;5;10m+     873[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     874[0m:[38;5;10m[49m         return self
[0m[49m[38;5;10m+     875[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     876[0m:[38;5;10m[49m     def predict(self, row):
[0m[49m[38;5;10m+     877[0m:[38;5;10m[49m         """Predict expected hourly arrivals for a single feature row."""
[0m[49m[38;5;10m+     878[0m:[38;5;10m[49m         v = self._row_to_vector(row)
[0m[49m[38;5;10m+     879[0m:[38;5;10m[49m         if not hasattr(self, "_feat_means"):
[0m[49m[38;5;10m+     880[0m:[38;5;10m[49m             return self._predict_one(v)
[0m[49m[38;5;10m+     881[0m:[38;5;10m[49m         vs = {name: (v[name] - self._feat_means[name]) / self._feat_sds[name]
[0m[49m[38;5;10m+     882[0m:[38;5;10m[49m               for name in self.FEATURE_NAMES}
[0m[49m[38;5;10m+     883[0m:[38;5;10m[49m         return self._predict_one(vs)
[0m[49m[38;5;10m+     884[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     885[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     886[0m:[38;5;10m[49m class MultinomialAcuityClassifier:
[0m[49m[38;5;10m+     887[0m:[38;5;10m[49m     """Pedagogical multinomial classifier for per-ESI share.
[0m[49m[38;5;10m+     888[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     889[0m:[38;5;10m[49m     Production uses scikit-learn's LogisticRegression with
[0m[49m[38;5;10m+     890[0m:[38;5;10m[49m     multi_class='multinomial', or a gradient-boosted classifier
[0m[49m[38;5;10m+     891[0m:[38;5;10m[49m     when the relationships are non-linear. The demo computes
[0m[49m[38;5;10m+     892[0m:[38;5;10m[49m     smoothed per-feature share averages and combines them so
[0m[49m[38;5;10m+     893[0m:[38;5;10m[49m     you can see the full pipeline run without a sklearn dependency.
[0m[49m[38;5;10m+     894[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     895[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     896[0m:[38;5;10m[49m     # Coarse buckets for hour-of-day and month; the model conditions
[0m[49m[38;5;10m+     897[0m:[38;5;10m[49m     # the share on these to capture the time-of-day and seasonal
[0m[49m[38;5;10m+     898[0m:[38;5;10m[49m     # acuity drift.
[0m[49m[38;5;10m+     899[0m:[38;5;10m[49m     HOUR_BUCKETS  = [(0, 6), (6, 12), (12, 18), (18, 24)]
[0m[49m[38;5;10m+     900[0m:[38;5;10m[49m     MONTH_BUCKETS = [(1, 4), (4, 7), (7, 10), (10, 13)]
[0m[49m[38;5;10m+     901[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     902[0m:[38;5;10m[49m     def __init__(self):
[0m[49m[38;5;10m+     903[0m:[38;5;10m[49m         # share_table[(hour_bucket, month_bucket, severe_flag)] = {esi -> share}
[0m[49m[38;5;10m+     904[0m:[38;5;10m[49m         self.share_table = {}
[0m[49m[38;5;10m+     905[0m:[38;5;10m[49m         self.fallback    = dict(DEFAULT_ACUITY_SHARES)
[0m[49m[38;5;10m+     906[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     907[0m:[38;5;10m[49m     def _bucket(self, value, buckets):
[0m[49m[38;5;10m+     908[0m:[38;5;10m[49m         for i, (lo, hi) in enumerate(buckets):
[0m[49m[38;5;10m+     909[0m:[38;5;10m[49m             if lo <= value < hi:
[0m[49m[38;5;10m+     910[0m:[38;5;10m[49m                 return i
[0m[49m[38;5;10m+     911[0m:[38;5;10m[49m         return len(buckets) - 1
[0m[49m[38;5;10m+     912[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     913[0m:[38;5;10m[49m     def fit(self, training_rows):
[0m[49m[38;5;10m+     914[0m:[38;5;10m[49m         """Estimate per-bucket per-ESI share from training data."""
[0m[49m[38;5;10m+     915[0m:[38;5;10m[49m         # Counts per (bucket_key, esi_level)
[0m[49m[38;5;10m+     916[0m:[38;5;10m[49m         counts = defaultdict(lambda: {esi: 0 for esi in ESI_LEVELS})
[0m[49m[38;5;10m+     917[0m:[38;5;10m[49m         totals = defaultdict(int)
[0m[49m[38;5;10m+     918[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     919[0m:[38;5;10m[49m         for row in training_rows:
[0m[49m[38;5;10m+     920[0m:[38;5;10m[49m             hour_b  = self._bucket(row["hour_of_day"], self.HOUR_BUCKETS)
[0m[49m[38;5;10m+     921[0m:[38;5;10m[49m             month_b = self._bucket(row["month"], self.MONTH_BUCKETS)
[0m[49m[38;5;10m+     922[0m:[38;5;10m[49m             severe  = bool(row["is_severe_weather"])
[0m[49m[38;5;10m+     923[0m:[38;5;10m[49m             key     = (hour_b, month_b, severe)
[0m[49m[38;5;10m+     924[0m:[38;5;10m[49m             for esi in ESI_LEVELS:
[0m[49m[38;5;10m+     925[0m:[38;5;10m[49m                 c = row[f"target_esi_{esi}"]
[0m[49m[38;5;10m+     926[0m:[38;5;10m[49m                 counts[key][esi] += c
[0m[49m[38;5;10m+     927[0m:[38;5;10m[49m                 totals[key]      += c
[0m[49m[38;5;10m+     928[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     929[0m:[38;5;10m[49m         # Convert to shares with Laplace smoothing so unseen
[0m[49m[38;5;10m+     930[0m:[38;5;10m[49m         # buckets do not produce zero shares (which the
[0m[49m[38;5;10m+     931[0m:[38;5;10m[49m         # multinomial cross-entropy can't handle).
[0m[49m[38;5;10m+     932[0m:[38;5;10m[49m         for key, esi_counts in counts.items():
[0m[49m[38;5;10m+     933[0m:[38;5;10m[49m             total = totals[key]
[0m[49m[38;5;10m+     934[0m:[38;5;10m[49m             smoothed_total = total + len(ESI_LEVELS)
[0m[49m[38;5;10m+     935[0m:[38;5;10m[49m             self.share_table[key] = {
[0m[49m[38;5;10m+     936[0m:[38;5;10m[49m                 esi: (esi_counts[esi] + 1) / smoothed_total
[0m[49m[38;5;10m+     937[0m:[38;5;10m[49m                 for esi in ESI_LEVELS
[0m[49m[38;5;10m+     938[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+     939[0m:[38;5;10m[49m         return self
[0m[49m[38;5;10m+     940[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     941[0m:[38;5;10m[49m     def predict_shares(self, row):
[0m[49m[38;5;10m+     942[0m:[38;5;10m[49m         """Return a dict {esi_level -> share} for a feature row."""
[0m[49m[38;5;10m+     943[0m:[38;5;10m[49m         hour_b  = self._bucket(row["hour_of_day"], self.HOUR_BUCKETS)
[0m[49m[38;5;10m+     944[0m:[38;5;10m[49m         month_b = self._bucket(row["month"], self.MONTH_BUCKETS)
[0m[49m[38;5;10m+     945[0m:[38;5;10m[49m         severe  = bool(row["is_severe_weather"])
[0m[49m[38;5;10m+     946[0m:[38;5;10m[49m         key     = (hour_b, month_b, severe)
[0m[49m[38;5;10m+     947[0m:[38;5;10m[49m         if key in self.share_table:
[0m[49m[38;5;10m+     948[0m:[38;5;10m[49m             return dict(self.share_table[key])
[0m[49m[38;5;10m+     949[0m:[38;5;10m[49m         return {esi: float(s) for esi, s in self.fallback.items()}
[0m[49m[38;5;10m+     950[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     951[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     952[0m:[38;5;10m[49m def train_volume_and_acuity_models(feature_table):
[0m[49m[38;5;10m+     953[0m:[38;5;10m[49m     """Step 3: Fit both models on training history with held-out validation.
[0m[49m[38;5;10m+     954[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     955[0m:[38;5;10m[49m     See pseudocode Step 3 in the main recipe. Returns a dict with
[0m[49m[38;5;10m+     956[0m:[38;5;10m[49m     the fitted models, validation metrics, and the model versions.
[0m[49m[38;5;10m+     957[0m:[38;5;10m[49m     Production runs each model as a separate SageMaker training
[0m[49m[38;5;10m+     958[0m:[38;5;10m[49m     job in parallel via Step Functions; the demo collapses both
[0m[49m[38;5;10m+     959[0m:[38;5;10m[49m     into a single in-process call.
[0m[49m[38;5;10m+     960[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     961[0m:[38;5;10m[49m     if not feature_table:
[0m[49m[38;5;10m+     962[0m:[38;5;10m[49m         raise ValueError("feature_table is empty; cannot train")
[0m[49m[38;5;10m+     963[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     964[0m:[38;5;10m[49m     # 3a. Sort and split into training and validation windows.
[0m[49m[38;5;10m+     965[0m:[38;5;10m[49m     rows_sorted = sorted(feature_table, key=lambda r: r["local_hour"])
[0m[49m[38;5;10m+     966[0m:[38;5;10m[49m     last_hour   = datetime.fromisoformat(rows_sorted[-1]["local_hour"])
[0m[49m[38;5;10m+     967[0m:[38;5;10m[49m     cutoff      = last_hour - timedelta(days=VALIDATION_WINDOW_DAYS)
[0m[49m[38;5;10m+     968[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     969[0m:[38;5;10m[49m     training   = [r for r in rows_sorted
[0m[49m[38;5;10m+     970[0m:[38;5;10m[49m                   if datetime.fromisoformat(r["local_hour"]) < cutoff]
[0m[49m[38;5;10m+     971[0m:[38;5;10m[49m     validation = [r for r in rows_sorted
[0m[49m[38;5;10m+     972[0m:[38;5;10m[49m                   if datetime.fromisoformat(r["local_hour"]) >= cutoff]
[0m[49m[38;5;10m+     973[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+     974[0m:[38;5;10m[49m         "Train/validation split: %d training rows, %d validation rows",
[0m[49m[38;5;10m+     975[0m:[38;5;10m[49m         len(training), len(validation))
[0m[49m[38;5;10m+     976[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     977[0m:[38;5;10m[49m     # 3b. Fit the volume model.
[0m[49m[38;5;10m+     978[0m:[38;5;10m[49m     volume_model = PoissonGLM().fit(training)
[0m[49m[38;5;10m+     979[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     980[0m:[38;5;10m[49m     # 3c. Fit the acuity classifier.
[0m[49m[38;5;10m+     981[0m:[38;5;10m[49m     acuity_model = MultinomialAcuityClassifier().fit(training)
[0m[49m[38;5;10m+     982[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     983[0m:[38;5;10m[49m     # 3d. Evaluate on the held-out window. MAPE for volume,
[0m[49m[38;5;10m+     984[0m:[38;5;10m[49m     # macro-F1 for acuity (computed against the dominant class
[0m[49m[38;5;10m+     985[0m:[38;5;10m[49m     # per row for simplicity).
[0m[49m[38;5;10m+     986[0m:[38;5;10m[49m     abs_pct_errors = []
[0m[49m[38;5;10m+     987[0m:[38;5;10m[49m     for row in validation:
[0m[49m[38;5;10m+     988[0m:[38;5;10m[49m         if row["target_total"] == 0:
[0m[49m[38;5;10m+     989[0m:[38;5;10m[49m             continue   # avoid divide-by-zero in MAPE
[0m[49m[38;5;10m+     990[0m:[38;5;10m[49m         pred = volume_model.predict(row)
[0m[49m[38;5;10m+     991[0m:[38;5;10m[49m         abs_pct_errors.append(abs(pred - row["target_total"]) / row["target_total"])
[0m[49m[38;5;10m+     992[0m:[38;5;10m[49m     volume_mape = (sum(abs_pct_errors) / len(abs_pct_errors)
[0m[49m[38;5;10m+     993[0m:[38;5;10m[49m                    if abs_pct_errors else float("nan"))
[0m[49m[38;5;10m+     994[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     995[0m:[38;5;10m[49m     # Acuity macro-F1 against the dominant ESI per row.
[0m[49m[38;5;10m+     996[0m:[38;5;10m[49m     tp = defaultdict(int); fp = defaultdict(int); fn = defaultdict(int)
