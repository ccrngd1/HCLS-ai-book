[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m ## Mocks and Synthetic Data
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m The demo never touches a real Kinesis stream, S3 bucket, DynamoDB table, EventBridge bus, or SageMaker endpoint. The mocks below stand in for those services so the focus stays on the forecasting logic. They print what they would write rather than failing, which makes the demo runnable without any AWS resources provisioned.
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m class MockS3:
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m     """In-memory stand-in for an S3 bucket.
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m     Production uses boto3.client('s3').get_object / put_object.
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m     The mock stores objects keyed by (bucket, key) so the demo
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m     can show what would have been written and what would have
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m     been read at each pipeline stage.
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m     def __init__(self):
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m         self.objects = {}    # (bucket, key) -> bytes
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m     def put_object(self, Bucket, Key, Body, **kwargs):
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m         if isinstance(Body, str):
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m             Body = Body.encode("utf-8")
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m         self.objects[(Bucket, Key)] = Body
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m         return {"ETag": '"' + str(uuid.uuid4()) + '"'}
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m     def get_object(self, Bucket, Key, **kwargs):
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m         if (Bucket, Key) not in self.objects:
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m             raise KeyError(f"NoSuchKey: s3://{Bucket}/{Key}")
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m         body = self.objects[(Bucket, Key)]
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m         class _StreamingBody:
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m             def __init__(self, b):
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m                 self._b = b
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m             def read(self):
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m                 return self._b
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m         return {"Body": _StreamingBody(body)}
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m class MockTable:
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m     """In-memory stand-in for a DynamoDB table.
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m     Production uses boto3.resource('dynamodb').Table(name). The
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m     mock supports the operations the demo calls: batch_writer,
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m     put_item, query, get_item. It is not a complete DynamoDB
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m     emulation; it covers what this pipeline needs.
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m     def __init__(self, name):
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m         self.name        = name
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m         self.items       = {}    # (pk, sk) -> item dict
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m         self.write_count = 0
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m     class _BatchWriter:
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m         def __init__(self, table):
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m             self.table = table
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m         def __enter__(self):
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m             return self
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m         def __exit__(self, *exc):
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m             return False
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m         def put_item(self, Item):
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m             pk = Item["ed_id"]
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m             sk = Item["forecast_for_hour_generated_at"]
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m             self.table.items[(pk, sk)] = dict(Item)
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m             self.table.write_count += 1
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m     def batch_writer(self):
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m         return self._BatchWriter(self)
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m     def put_item(self, Item):
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m         pk = Item["ed_id"]
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m         sk = Item["forecast_for_hour_generated_at"]
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m         self.items[(pk, sk)] = dict(Item)
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m         self.write_count += 1
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m class MockEventBus:
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m     """In-memory stand-in for EventBridge.
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m     Production uses boto3.client('events').put_events(...). The
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m     mock accumulates events so the demo can show what would have
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m     been emitted to the ed-forecast-events bus at each pipeline
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m     stage.
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m     def __init__(self, name):
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m         self.name   = name
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m         self.events = []
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m     def put_events(self, Entries):
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m         self.events.extend(Entries)
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m         return {"FailedEntryCount": 0}
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m class MockCloudWatch:
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m     """In-memory stand-in for CloudWatch.
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m     Production uses boto3.client('cloudwatch').put_metric_data(...).
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m     The mock accumulates metrics so the demo can show what would
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m     have been emitted (per-horizon MAPE, per-ESI macro F1,
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m     inference latency, records-written count).
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m     def __init__(self):
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m         self.metrics = defaultdict(list)
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m     def put_metric_data(self, Namespace, MetricData):
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m         for m in MetricData:
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m             self.metrics[f"{Namespace}/{m['MetricName']}"].append({
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m                 "Value": m["Value"],
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m                 "Unit":  m.get("Unit", "None"),
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m                 "Time":  datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m def generate_synthetic_adt_records(history_days=SYNTHETIC_HISTORY_DAYS,
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m                                     seed=SYNTHETIC_RANDOM_SEED):
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m     """Generate synthetic ADT-A04 registration records.
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m     Production reads from a Kinesis Data Stream populated by the
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m     EHR's HL7 outbound feed. The demo synthesizes records with
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m     realistic daily, weekly, and seasonal arrival patterns plus
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m     weather-driven variability and a flu-season uplift.
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m     Pattern summary:
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m       - Hourly base rate has a daily curve peaking at ~18:00.
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m       - Mondays and weekends carry distinct weekly uplifts.
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m       - Cold months (Dec-Feb) carry a flu-season uplift.
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m       - Severe-weather days suppress walk-ins by ~25%.
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m       - Per-arrival ESI level is sampled from a baseline mix
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m         with hour-of-day skew (high acuity slightly more common
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m         in early-morning hours).
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m     rng = random.Random(seed)
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m     # End the synthetic history at midnight today so the demo's
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m     # "current" time is well-defined.
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m     end_d   = date.today()
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m     start_d = end_d - timedelta(days=history_days)
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m     # Synthesize a parallel weather and flu-index series so the
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m     # downstream feature engineering has something to join on.
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m     weather_by_date   = {}
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m     flu_index_by_date = {}
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m     for i in range(history_days + 1):
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m         d = start_d + timedelta(days=i)
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m         # Temperature: rough sinusoid by month plus daily noise.
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m         seasonal_t = 50 + 30 * math.sin(2 * math.pi * (d.timetuple().tm_yday - 100) / 365)
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m         temp_f     = seasonal_t + rng.gauss(0, 8)
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m         precip_in  = max(0.0, rng.gauss(0.05, 0.2))
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m         wind_mph   = max(0.0, rng.gauss(8, 4))
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m         # Severe weather flag triggered by extremes.
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m         is_severe = (temp_f < 10 or temp_f > 100 or
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m                      precip_in > 1.0 or wind_mph > 30)
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m         weather_by_date[d.isoformat()] = {
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m             "temperature_f":    round(temp_f, 1),
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m             "precipitation_in": round(precip_in, 2),
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m             "wind_speed_mph":   round(wind_mph, 1),
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m             "is_severe":        is_severe,
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m         # Flu index: rises Dec-Feb, falls otherwise.
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m         is_flu_season = d.month in (12, 1, 2)
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m         flu_index_by_date[d.isoformat()] = round(
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m             (45 if is_flu_season else 12) + rng.gauss(0, 5), 1)
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m     records   = []
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m     arrival_n = 0
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m     for i in range(history_days):
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m         d = start_d + timedelta(days=i)
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m         weather   = weather_by_date[d.isoformat()]
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m         flu_index = flu_index_by_date[d.isoformat()]
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m         is_weekend = d.weekday() in (5, 6)
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m         is_monday  = d.weekday() == 0
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m         # Daily seasonal uplift based on flu index.
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m         flu_uplift = 1.0 + (flu_index - 12) / 80.0
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m         # Severe-weather suppression.
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m         weather_factor = 0.75 if weather["is_severe"] else 1.0
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m         # Weekly factor: Mondays a bit busier, weekends mixed.
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m         weekly_factor = 1.10 if is_monday else (1.05 if is_weekend else 1.0)
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m         for hour in range(24):
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m             # Hourly intensity curve: low overnight, ramps to a
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m             # late-afternoon peak around 18:00, falls into evening.
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m             hourly_curve = (3.5
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m                             + 4.0 * math.exp(-((hour - 18) ** 2) / 18.0)
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m                             + 1.5 * math.exp(-((hour - 10) ** 2) / 8.0))
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m             mu = (hourly_curve
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m                   * flu_uplift
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m                   * weather_factor
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m                   * weekly_factor)
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m             # Sample a Poisson-ish count from the rate. Use the
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m             # standard sum-of-exponentials trick for small means;
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m             # close enough for a demo.
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m             count = 0
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m             t = 0.0
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m             while True:
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m                 t += rng.expovariate(1.0)
