[0m[49m[38;5;10m+    1462[0m:[38;5;10m[49m   horizon= 4h point= 17 80%=( 12.. 22) 95%=(  9.. 25) esi={'esi_1': 0, 'esi_2': 3, 'esi_3': 8, 'esi_4': 4, 'esi_5': 2}
[0m[49m[38;5;10m+    1463[0m:[38;5;10m[49m   horizon=12h point= 12 80%=(  6.. 18) 95%=(  3.. 21) esi={'esi_1': 0, 'esi_2': 2, 'esi_3': 6, 'esi_4': 3, 'esi_5': 1}
[0m[49m[38;5;10m+    1464[0m:[38;5;10m[49m   horizon=24h point= 18 80%=( 10.. 26) 95%=(  5.. 31) esi={'esi_1': 0, 'esi_2': 3, 'esi_3': 9, 'esi_4': 4, 'esi_5': 2}
