[0m[49m[38;5;10m+     767[0m:[38;5;10m[49m     # built in Step 2.
[0m[49m[38;5;10m+     768[0m:[38;5;10m[49m     FEATURE_NAMES = [
[0m[49m[38;5;10m+     769[0m:[38;5;10m[49m         "hour_of_day", "day_of_week", "month",
[0m[49m[38;5;10m+     770[0m:[38;5;10m[49m         "is_weekend_int", "is_holiday_int", "holiday_distance_d",
[0m[49m[38;5;10m+     771[0m:[38;5;10m[49m         "temperature_f", "precipitation_in", "wind_speed_mph",
[0m[49m[38;5;10m+     772[0m:[38;5;10m[49m         "is_severe_int", "flu_index", "has_event_int",
