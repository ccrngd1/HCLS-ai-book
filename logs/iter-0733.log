[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m         "population_scored": n_patients,
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m         "trajectories_computed": len(trajectories[trajectories["status"] == "COMPUTED"]),
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m         "insufficient_history": len(trajectories[trajectories["status"] == "INSUFFICIENT_HISTORY"]),
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m         "rising_risk_flagged": len(flagged),
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m         "severity_distribution": (
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m             flagged["severity"].value_counts().to_dict() if len(flagged) > 0 else {}
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m         ),
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m     for key, value in summary.items():
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m         print(f"  {key}: {value}")
