[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m     sns_client.publish(
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m         TopicArn=topic_arn,
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m         Subject=f"High-Risk Discharge: {patient_id}",
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m         Message=message,
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m         MessageAttributes={
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m             "risk_tier": {"DataType": "String", "StringValue": "HIGH"},
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m             "patient_id": {"DataType": "String", "StringValue": patient_id},
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m     print(f"  Alert sent for {patient_id}")
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m ## Step 8: Invoke SageMaker Endpoint (Production Path)
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m *In production, the model lives on a SageMaker real-time endpoint rather than in local memory. This function shows how you'd call that endpoint. The endpoint accepts a CSV-formatted feature vector and returns a probability.*
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m def invoke_sagemaker_endpoint(
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m     feature_vector: dict,
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m     feature_columns: list,
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m     endpoint_name: str = "readmission-risk-v2",
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m ) -> float:
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    717[0m:[38;5;10m[49m     Call the SageMaker real-time endpoint for readmission scoring.
[0m[49m[38;5;10m+    718[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    719[0m:[38;5;10m[49m     The endpoint hosts the trained XGBoost model and returns a raw probability.
[0m[49m[38;5;10m+    720[0m:[38;5;10m[49m     You still need to apply Platt scaling on the client side (or bake it into
[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m     a SageMaker inference pipeline).
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m     In production, this call happens inside a Lambda function triggered by
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m     Step Functions as part of the discharge scoring workflow.
[0m[49m[38;5;10m+    725[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    726[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    727[0m:[38;5;10m[49m         feature_vector: Dict of feature_name -> value.
[0m[49m[38;5;10m+    728[0m:[38;5;10m[49m         feature_columns: Ordered list of feature names.
[0m[49m[38;5;10m+    729[0m:[38;5;10m[49m         endpoint_name: Name of the deployed SageMaker endpoint.
[0m[49m[38;5;10m+    730[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    731[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    732[0m:[38;5;10m[49m         Raw model probability (before calibration).
[0m[49m[38;5;10m+    733[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    734[0m:[38;5;10m[49m     sagemaker_runtime = boto3.client("sagemaker-runtime", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    735[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    736[0m:[38;5;10m[49m     # Assemble features as CSV (SageMaker XGBoost expects CSV input)
[0m[49m[38;5;10m+    737[0m:[38;5;10m[49m     values = []
[0m[49m[38;5;10m+    738[0m:[38;5;10m[49m     for col in feature_columns:
[0m[49m[38;5;10m+    739[0m:[38;5;10m[49m         val = feature_vector.get(col)
[0m[49m[38;5;10m+    740[0m:[38;5;10m[49m         if val is None or (isinstance(val, float) and np.isnan(val)):
[0m[49m[38;5;10m+    741[0m:[38;5;10m[49m             values.append("")  # empty string = missing for XGBoost
[0m[49m[38;5;10m+    742[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    743[0m:[38;5;10m[49m             values.append(str(val))
[0m[49m[38;5;10m+    744[0m:[38;5;10m[49m     csv_payload = ",".join(values)
[0m[49m[38;5;10m+    745[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    746[0m:[38;5;10m[49m     response = sagemaker_runtime.invoke_endpoint(
[0m[49m[38;5;10m+    747[0m:[38;5;10m[49m         EndpointName=endpoint_name,
[0m[49m[38;5;10m+    748[0m:[38;5;10m[49m         ContentType="text/csv",
[0m[49m[38;5;10m+    749[0m:[38;5;10m[49m         Body=csv_payload.encode("utf-8"),
[0m[49m[38;5;10m+    750[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    751[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    752[0m:[38;5;10m[49m     raw_probability = float(response["Body"].read().decode("utf-8"))
[0m[49m[38;5;10m+    753[0m:[38;5;10m[49m     return raw_probability
[0m[49m[38;5;10m+    754[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    755[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    756[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    757[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    758[0m:[38;5;10m[49m ## Full Pipeline: Score a Batch of Discharges
[0m[49m[38;5;10m+    759[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    760[0m:[38;5;10m[49m *This assembles all the steps into a single callable function that processes a batch of discharges. In production, each discharge would be processed individually as events arrive via EventBridge. Here we process a batch to demonstrate the full flow and show aggregate statistics.*
[0m[49m[38;5;10m+    761[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    762[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    763[0m:[38;5;10m[49m def run_scoring_pipeline(model, feature_columns: list, discharges: pd.DataFrame) -> pd.DataFrame:
[0m[49m[38;5;10m+    764[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    765[0m:[38;5;10m[49m     Score a batch of discharges and route interventions.
[0m[49m[38;5;10m+    766[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    767[0m:[38;5;10m[49m     This simulates what happens when discharge events flow through the pipeline.
[0m[49m[38;5;10m+    768[0m:[38;5;10m[49m     Each patient gets scored, stratified, assigned interventions, and (in production)
[0m[49m[38;5;10m+    769[0m:[38;5;10m[49m     stored in DynamoDB with alerts sent for high-risk patients.
[0m[49m[38;5;10m+    770[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    771[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    772[0m:[38;5;10m[49m         model: Trained model.
[0m[49m[38;5;10m+    773[0m:[38;5;10m[49m         feature_columns: Feature column names.
[0m[49m[38;5;10m+    774[0m:[38;5;10m[49m         discharges: DataFrame of patients to score.
[0m[49m[38;5;10m+    775[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    776[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    777[0m:[38;5;10m[49m         DataFrame with scores, tiers, and interventions added.
[0m[49m[38;5;10m+    778[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    779[0m:[38;5;10m[49m     results = []
[0m[49m[38;5;10m+    780[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    781[0m:[38;5;10m[49m     print(f"\n── Scoring {len(discharges)} discharges ──\n")
[0m[49m[38;5;10m+    782[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    783[0m:[38;5;10m[49m     for _, row in discharges.iterrows():
[0m[49m[38;5;10m+    784[0m:[38;5;10m[49m         # Assemble feature vector from the discharge record
[0m[49m[38;5;10m+    785[0m:[38;5;10m[49m         feature_vector = {col: row.get(col) for col in FEATURE_COLUMNS}
[0m[49m[38;5;10m+    786[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    787[0m:[38;5;10m[49m         # Add missingness indicators (same as training)
[0m[49m[38;5;10m+    788[0m:[38;5;10m[49m         for col in ["albumin_last", "creatinine_last", "hemoglobin_last"]:
[0m[49m[38;5;10m+    789[0m:[38;5;10m[49m             feature_vector[f"{col}_missing"] = 1 if pd.isna(row.get(col)) else 0
[0m[49m[38;5;10m+    790[0m:[38;5;10m[49m             if pd.isna(row.get(col)):
[0m[49m[38;5;10m+    791[0m:[38;5;10m[49m                 # Use training median as imputation (in production, store this with model)
[0m[49m[38;5;10m+    792[0m:[38;5;10m[49m                 feature_vector[col] = {"albumin_last": 3.5, "creatinine_last": 1.1,
[0m[49m[38;5;10m+    793[0m:[38;5;10m[49m                                        "hemoglobin_last": 12.0}[col]
[0m[49m[38;5;10m+    794[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    795[0m:[38;5;10m[49m         # Score the patient
[0m[49m[38;5;10m+    796[0m:[38;5;10m[49m         score_result = score_patient(model, feature_vector, feature_columns)
[0m[49m[38;5;10m+    797[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    798[0m:[38;5;10m[49m         # Route interventions
[0m[49m[38;5;10m+    799[0m:[38;5;10m[49m         interventions = route_interventions(score_result, feature_vector)
[0m[49m[38;5;10m+    800[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    801[0m:[38;5;10m[49m         results.append({
[0m[49m[38;5;10m+    802[0m:[38;5;10m[49m             "patient_id": row["patient_id"],
[0m[49m[38;5;10m+    803[0m:[38;5;10m[49m             "encounter_id": row["encounter_id"],
[0m[49m[38;5;10m+    804[0m:[38;5;10m[49m             "discharge_date": row["discharge_date"],
[0m[49m[38;5;10m+    805[0m:[38;5;10m[49m             "probability": score_result.get("probability"),
[0m[49m[38;5;10m+    806[0m:[38;5;10m[49m             "risk_tier": score_result["risk_tier"],
[0m[49m[38;5;10m+    807[0m:[38;5;10m[49m             "risk_drivers": score_result.get("risk_drivers", []),
[0m[49m[38;5;10m+    808[0m:[38;5;10m[49m             "interventions": interventions,
[0m[49m[38;5;10m+    809[0m:[38;5;10m[49m             "actual_readmitted": row.get("readmitted_30d"),
[0m[49m[38;5;10m+    810[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    811[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    812[0m:[38;5;10m[49m     results_df = pd.DataFrame(results)
[0m[49m[38;5;10m+    813[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    814[0m:[38;5;10m[49m     # Print summary statistics
[0m[49m[38;5;10m+    815[0m:[38;5;10m[49m     print(f"\n── Scoring Summary ──")
[0m[49m[38;5;10m+    816[0m:[38;5;10m[49m     tier_counts = results_df["risk_tier"].value_counts()
[0m[49m[38;5;10m+    817[0m:[38;5;10m[49m     for tier in ["HIGH", "MEDIUM", "LOW"]:
[0m[49m[38;5;10m+    818[0m:[38;5;10m[49m         count = tier_counts.get(tier, 0)
[0m[49m[38;5;10m+    819[0m:[38;5;10m[49m         tier_patients = results_df[results_df["risk_tier"] == tier]
[0m[49m[38;5;10m+    820[0m:[38;5;10m[49m         actual_rate = tier_patients["actual_readmitted"].mean() if len(tier_patients) > 0 else 0
[0m[49m[38;5;10m+    821[0m:[38;5;10m[49m         print(f"  {tier}: {count} patients ({count/len(results_df):.1%}), "
[0m[49m[38;5;10m+    822[0m:[38;5;10m[49m               f"actual readmission rate: {actual_rate:.1%}")
[0m[49m[38;5;10m+    823[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    824[0m:[38;5;10m[49m     # Overall discrimination
[0m[49m[38;5;10m+    825[0m:[38;5;10m[49m     scored = results_df[results_df["probability"].notna()]
[0m[49m[38;5;10m+    826[0m:[38;5;10m[49m     if len(scored) > 0:
[0m[49m[38;5;10m+    827[0m:[38;5;10m[49m         auc = roc_auc_score(scored["actual_readmitted"], scored["probability"])
[0m[49m[38;5;10m+    828[0m:[38;5;10m[49m         print(f"\n  Scoring AUC: {auc:.4f}")
[0m[49m[38;5;10m+    829[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    830[0m:[38;5;10m[49m     return results_df
[0m[49m[38;5;10m+    831[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    832[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    833[0m:[38;5;10m[49m # ─── Run the full pipeline ──────────────────────────────────────────────────
[0m[49m[38;5;10m+    834[0m:[38;5;10m[49m if __name__ == "__main__":
[0m[49m[38;5;10m+    835[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    836[0m:[38;5;10m[49m     print("30-Day Readmission Risk Scoring Pipeline")
[0m[49m[38;5;10m+    837[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    838[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    839[0m:[38;5;10m[49m     # Step 1: Generate synthetic discharge data
[0m[49m[38;5;10m+    840[0m:[38;5;10m[49m     print("\n[1/4] Generating synthetic discharge data...")
[0m[49m[38;5;10m+    841[0m:[38;5;10m[49m     df = generate_synthetic_discharges(n_patients=3000)
[0m[49m[38;5;10m+    842[0m:[38;5;10m[49m     print(f"  Generated {len(df)} discharges, "
[0m[49m[38;5;10m+    843[0m:[38;5;10m[49m           f"{df['readmitted_30d'].sum()} readmissions "
[0m[49m[38;5;10m+    844[0m:[38;5;10m[49m           f"({df['readmitted_30d'].mean():.1%} rate)")
[0m[49m[38;5;10m+    845[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    846[0m:[38;5;10m[49m     # Step 2: Train the model
[0m[49m[38;5;10m+    847[0m:[38;5;10m[49m     print("\n[2/4] Training readmission prediction model...")
[0m[49m[38;5;10m+    848[0m:[38;5;10m[49m     model, feature_cols, metrics = train_readmission_model(df)
[0m[49m[38;5;10m+    849[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    850[0m:[38;5;10m[49m     # Step 3: Score a batch of new discharges (simulating real-time scoring)
[0m[49m[38;5;10m+    851[0m:[38;5;10m[49m     print("\n[3/4] Scoring new discharges...")
[0m[49m[38;5;10m+    852[0m:[38;5;10m[49m     # Use the test portion as "new" discharges to score
[0m[49m[38;5;10m+    853[0m:[38;5;10m[49m     new_discharges = df.sample(n=200, random_state=99)
[0m[49m[38;5;10m+    854[0m:[38;5;10m[49m     results = run_scoring_pipeline(model, feature_cols, new_discharges)
[0m[49m[38;5;10m+    855[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    856[0m:[38;5;10m[49m     # Step 4: Show example high-risk patient
[0m[49m[38;5;10m+    857[0m:[38;5;10m[49m     print("\n[4/4] Example high-risk patient detail:")
[0m[49m[38;5;10m+    858[0m:[38;5;10m[49m     high_risk = results[results["risk_tier"] == "HIGH"].iloc[0]
[0m[49m[38;5;10m+    859[0m:[38;5;10m[49m     print(f"  Patient: {high_risk['patient_id']}")
[0m[49m[38;5;10m+    860[0m:[38;5;10m[49m     print(f"  Probability: {high_risk['probability']:.1%}")
[0m[49m[38;5;10m+    861[0m:[38;5;10m[49m     print(f"  Risk Drivers: {high_risk['risk_drivers'][:3]}")
[0m[49m[38;5;10m+    862[0m:[38;5;10m[49m     print(f"  Interventions: {high_risk['interventions']}")
[0m[49m[38;5;10m+    863[0m:[38;5;10m[49m     print(f"  Actually readmitted: {'Yes' if high_risk['actual_readmitted'] else 'No'}")
[0m[49m[38;5;10m+    864[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    865[0m:[38;5;10m[49m     print("\n" + "=" * 60)
[0m[49m[38;5;10m+    866[0m:[38;5;10m[49m     print("Pipeline complete. In production, scores would be written to")
[0m[49m[38;5;10m+    867[0m:[38;5;10m[49m     print("DynamoDB and high-risk alerts sent via SNS.")
[0m[49m[38;5;10m+    868[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    869[0m:[38;5;10m[49m ```
