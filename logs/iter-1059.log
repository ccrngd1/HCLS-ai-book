[0m[49m[38;5;10m+     121[0m:[38;5;10m[49m     {
[0m[49m[38;5;10m+     122[0m:[38;5;10m[49m         "id": "OR-04",
[0m[49m[38;5;10m+     123[0m:[38;5;10m[49m         "name": "Operating Room 4",
