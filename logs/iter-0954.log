[0m[49m[39m  656, 656[0m:[39m[49m     # *0.. means "zero or more hops," which includes the starting node itself.
[0m[49m[38;5;10m+      657[0m:[38;5;10m[49m     # Edge direction: child -[:IS_SUBSPECIALTY]-> parent (child points to its parent).
[0m[49m[38;5;10m+      658[0m:[38;5;10m[49m     # So (child)-[:IS_SUBSPECIALTY*0..]->(root) finds all nodes that can
[0m[49m[38;5;10m+      659[0m:[38;5;10m[49m     # reach root by following parent pointers upward, giving us the full
[0m[49m[38;5;10m+      660[0m:[38;5;10m[49m     # subtree beneath root (all descendants + root itself via *0..).
[0m[49m[39m  657, 661[0m:[39m[49m     query = """
[0m[49m[39m  658, 662[0m:[39m[49m     MATCH (root:Specialty {nucc_code: $root_code})
[0m[49m[39m  659, 663[0m:[39m[49m     MATCH (child:Specialty)-[:IS_SUBSPECIALTY*0..]->(root)
[0m[49m[39m  660, 664[0m:[39m[49m     RETURN collect(DISTINCT child.nucc_code) AS codes
[0m[49m[39m  661, 665[0m:[39m[49m     """
