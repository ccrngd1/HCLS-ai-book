[0m[49m[39m  233, 272[0m:[39m[49m         content_type  = "application/x-image"    // or "application/json" depending on model server
[0m[49m[39m  234, 273[0m:[39m[49m         body          = preprocessed_payload
[0m[49m[39m  235, 274[0m:[39m[49m 
[0m[49m[39m  236, 275[0m:[39m[49m     // Parse the model's output: probability for each triage category.
[0m[49m[39m  237, 276[0m:[39m[49m     // Example output: { "benign": 0.15, "suspicious": 0.72, "urgent": 0.13 }
[0m[49m[39m  238, 277[0m:[39m[49m     predictions = parse_response(response.Body)
[0m[49m[39m  239, 278[0m:[39m[49m 
[0m[49m[39m  240, 279[0m:[39m[49m     RETURN predictions
[0m[49m[39m  241, 280[0m:[39m[49m ```
[0m[49m[39m  242, 281[0m:[39m[49m 
[0m[49m[38;5;9m- 243     [0m:[38;5;9m[49m **Step 4: Triage decision logic.** Raw model probabilities need to be translated into actionable triage decisions. This is where clinical judgment meets engineering. The thresholds determine the sensitivity/specificity tradeoff: lower the "urgent" threshold and you catch more true positives but flood the queue with false alarms. Raise it and you miss cases. These thresholds should be set in collaboration with dermatologists and validated on a held-out dataset with known outcomes. They're configuration, not code, and they will need adjustment over time as you gather real-world performance data.
[0m[49m[38;5;10m+      282[0m:[38;5;10m[49m **Step 5: Triage decision logic.** Raw model probabilities need to be translated into actionable triage decisions. This is where clinical judgment meets engineering. The thresholds determine the sensitivity/specificity tradeoff: lower the "urgent" threshold and you catch more true positives but flood the queue with false alarms. Raise it and you miss cases. These thresholds should be set in collaboration with dermatologists and validated on a held-out dataset with known outcomes. They're configuration, not code, and they will need adjustment over time as you gather real-world performance data.
[0m[49m[39m  244, 283[0m:[39m[49m 
[0m[49m[39m  245, 284[0m:[39m[49m ```
[0m[49m[39m  246, 285[0m:[39m[49m // Triage thresholds. These are clinical decisions, not engineering decisions.
[0m[49m[39m  247, 286[0m:[39m[49m // Set in collaboration with dermatology leadership. Review quarterly.
[0m[49m[39m  248, 287[0m:[39m[49m URGENT_THRESHOLD     = 0.70  // above this: immediate dermatology review
[0m[49m[39m  249, 288[0m:[39m[49m SUSPICIOUS_THRESHOLD = 0.40  // above this: expedited scheduling (within 2 weeks)
[0m[49m[39m  250, 289[0m:[39m[49m // Below suspicious threshold: standard follow-up recommendation
[0m[49m[39m  251, 290[0m:[39m[49m 
[0m[49m[39m  252, 291[0m:[39m[49m FUNCTION determine_triage(predictions):
[0m[49m[39m  253, 292[0m:[39m[49m     urgent_score     = predictions["urgent"]
[0m[49m[39m  254, 293[0m:[39m[49m     suspicious_score = predictions["suspicious"]
[0m[49m[39m  255, 294[0m:[39m[49m     benign_score     = predictions["benign"]
[0m[49m[39m  256, 295[0m:[39m[49m 
[0m[49m[39m  257, 296[0m:[39m[49m     // Priority logic: check urgent first, then suspicious, then default to routine.
[0m[49m[39m  258, 297[0m:[39m[49m     // If both urgent and suspicious are high, urgent wins.
[0m[49m[39m  259, 298[0m:[39m[49m     IF urgent_score >= URGENT_THRESHOLD:
[0m[49m[39m  260, 299[0m:[39m[49m         RETURN {
[0m[49m[39m  261, 300[0m:[39m[49m             category:    "URGENT",
[0m[49m[39m  262, 301[0m:[39m[49m             action:      "Immediate dermatology review recommended",
[0m[49m[39m  263, 302[0m:[39m[49m             confidence:  urgent_score,
[0m[49m[39m  264, 303[0m:[39m[49m             all_scores:  predictions
[0m[49m[39m  265, 304[0m:[39m[49m         }
[0m[49m[39m  266, 305[0m:[39m[49m 
[0m[49m[39m  267, 306[0m:[39m[49m     IF suspicious_score >= SUSPICIOUS_THRESHOLD:
[0m[49m[39m  268, 307[0m:[39m[49m         RETURN {
[0m[49m[39m  269, 308[0m:[39m[49m             category:    "SUSPICIOUS",
[0m[49m[39m  270, 309[0m:[39m[49m             action:      "Expedited dermatology appointment recommended (within 2 weeks)",
[0m[49m[39m  271, 310[0m:[39m[49m             confidence:  suspicious_score,
[0m[49m[39m  272, 311[0m:[39m[49m             all_scores:  predictions
[0m[49m[39m  273, 312[0m:[39m[49m         }
[0m[49m[39m  274, 313[0m:[39m[49m 
[0m[49m[39m  275, 314[0m:[39m[49m     RETURN {
[0m[49m[39m  276, 315[0m:[39m[49m         category:    "ROUTINE",
[0m[49m[39m  277, 316[0m:[39m[49m         action:      "Standard monitoring. Follow up if changes observed.",
[0m[49m[39m  278, 317[0m:[39m[49m         confidence:  benign_score,
[0m[49m[39m  279, 318[0m:[39m[49m         all_scores:  predictions
[0m[49m[39m  280, 319[0m:[39m[49m     }
[0m[49m[39m  281, 320[0m:[39m[49m ```
[0m[49m[39m  282, 321[0m:[39m[49m 
[0m[49m[38;5;9m- 283     [0m:[38;5;9m[49m **Step 5: Store results and notify.** Every triage case gets a permanent record: the image reference, model output, triage decision, and timestamps. This serves three purposes: (1) the dermatologist review queue needs to pull cases by priority, (2) the audit trail must show what the AI recommended and when, and (3) outcome tracking (what did the dermatologist actually find?) enables model performance monitoring over time. For urgent cases, an immediate notification ensures the dermatology team is alerted without waiting for someone to check the queue.
[0m[49m[38;5;10m+      322[0m:[38;5;10m[49m **Step 6: Store results and notify.** Every triage case gets a permanent record: the image reference, model output, triage decision, and timestamps. This serves three purposes: (1) the dermatologist review queue needs to pull cases by priority, (2) the audit trail must show what the AI recommended and when, and (3) outcome tracking (what did the dermatologist actually find?) enables model performance monitoring over time. For urgent cases, an immediate notification ensures the dermatology team is alerted without waiting for someone to check the queue.
[0m[49m[39m  284, 323[0m:[39m[49m 
[0m[49m[39m  285, 324[0m:[39m[49m ```
[0m[49m[39m  286, 325[0m:[39m[49m FUNCTION store_and_notify(case_id, patient_id, image_key, triage_result):
[0m[49m[39m  287, 326[0m:[39m[49m     // Write the complete triage record to the database.
[0m[49m[39m  288, 327[0m:[39m[49m     write to DynamoDB table "triage-cases":
[0m[49m[39m  289, 328[0m:[39m[49m         case_id              = case_id
[0m[49m[39m  290, 329[0m:[39m[49m         patient_id           = patient_id
[0m[49m[39m  291, 330[0m:[39m[49m         image_key            = image_key                          // S3 reference to the original image
[0m[49m[39m  292, 331[0m:[39m[49m         triage_category      = triage_result.category             // URGENT, SUSPICIOUS, or ROUTINE
[0m[49m[39m  293, 332[0m:[39m[49m         triage_action        = triage_result.action               // human-readable recommendation
[0m[49m[39m  294, 333[0m:[39m[49m         model_confidence     = triage_result.confidence           // primary category confidence
[0m[49m[39m  295, 334[0m:[39m[49m         all_scores           = triage_result.all_scores           // full probability distribution
[0m[49m[39m  296, 335[0m:[39m[49m         submitted_at         = current UTC timestamp (ISO 8601)
[0m[49m[39m  297, 336[0m:[39m[49m         reviewed_by          = null                               // populated when dermatologist reviews
[0m[49m[39m  298, 337[0m:[39m[49m         dermatologist_dx     = null                               // populated with actual diagnosis
[0m[49m[39m  299, 338[0m:[39m[49m         status               = "PENDING_REVIEW"
[0m[49m[39m  300, 339[0m:[39m[49m 
[0m[49m[39m  301, 340[0m:[39m[49m     // For urgent cases, send an immediate notification.
[0m[49m[39m  302, 341[0m:[39m[49m     // Don't rely on someone polling the queue for time-sensitive findings.
[0m[49m[38;5;10m+      342[0m:[38;5;10m[49m     // Note: the notification contains only the case_id, not patient identifiers.
[0m[49m[38;5;10m+      343[0m:[38;5;10m[49m     // The dermatologist accesses patient details through the secure review queue.
[0m[49m[39m  303, 344[0m:[39m[49m     IF triage_result.category == "URGENT":
[0m[49m[39m  304, 345[0m:[39m[49m         publish to SNS topic "urgent-derm-triage":
[0m[49m[38;5;9m- 305     [0m:[38;5;9m[49m             message = "Urgent lesion triage: Case {case_id}, Patient {patient_id}. "
[0m[49m[38;5;10m+      346[0m:[38;5;10m[49m             message = "Urgent lesion triage: Case {case_id}. "
[0m[49m[39m  306, 347[0m:[39m[49m                     + "Model confidence: {triage_result.confidence}. "
[0m[49m[38;5;9m- 307     [0m:[38;5;9m[49m                     + "Immediate dermatology review recommended."
[0m[49m[38;5;10m+      348[0m:[38;5;10m[49m                     + "Immediate dermatology review recommended. "
[0m[49m[38;5;10m+      349[0m:[38;5;10m[49m                     + "Access patient details in the secure review queue."
[0m[49m[38;5;10m+      350[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      351[0m:[38;5;10m[49m     RETURN case_id
[0m[49m[38;5;10m+      352[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+      353[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      354[0m:[38;5;10m[49m **Error handling: what happens when inference fails.** If the SageMaker endpoint times out or returns an error (GPU cold starts, transient failures, endpoint scaling), the case must not be lost. Write the case to DynamoDB with status `PENDING_INFERENCE` and route the message to the SQS dead letter queue for retry. A scheduled Lambda processes the DLQ and retries inference. If retries are exhausted, route the case to the dermatology queue with a `MANUAL_REVIEW` flag so a human triages it manually.
[0m[49m[38;5;10m+      355[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      356[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+      357[0m:[38;5;10m[49m FUNCTION handle_inference_failure(case_id, patient_id, image_key, error):
[0m[49m[38;5;10m+      358[0m:[38;5;10m[49m     // Write a record so the case is tracked even though inference failed.
[0m[49m[38;5;10m+      359[0m:[38;5;10m[49m     write to DynamoDB table "triage-cases":
[0m[49m[38;5;10m+      360[0m:[38;5;10m[49m         case_id         = case_id
[0m[49m[38;5;10m+      361[0m:[38;5;10m[49m         patient_id      = patient_id
[0m[49m[38;5;10m+      362[0m:[38;5;10m[49m         image_key       = image_key
[0m[49m[38;5;10m+      363[0m:[38;5;10m[49m         status          = "PENDING_INFERENCE"
[0m[49m[38;5;10m+      364[0m:[38;5;10m[49m         error_message   = error.message
[0m[49m[38;5;10m+      365[0m:[38;5;10m[49m         submitted_at    = current UTC timestamp (ISO 8601)
[0m[49m[38;5;10m+      366[0m:[38;5;10m[49m         retry_count     = 0
[0m[49m[38;5;10m+      367[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      368[0m:[38;5;10m[49m     // Send to DLQ for retry processing.
[0m[49m[38;5;10m+      369[0m:[38;5;10m[49m     send to SQS dead letter queue:
[0m[49m[38;5;10m+      370[0m:[38;5;10m[49m         message_body = { case_id: case_id, image_key: image_key }
[0m[49m[39m  308, 371[0m:[39m[49m 
[0m[49m[38;5;10m+      372[0m:[38;5;10m[49m     // Alert operations team if DLQ depth exceeds threshold.
[0m[49m[38;5;10m+      373[0m:[38;5;10m[49m     // A growing DLQ means the endpoint is unhealthy.
[0m[49m[39m  309, 374[0m:[39m[49m     RETURN case_id
[0m[49m[39m  310, 375[0m:[39m[49m ```
[0m[49m[39m  311, 376[0m:[39m[49m 
