[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m       "assertion": "HISTORICAL",
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m       "section": "PMH",
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m       "confidence": 0.89,
