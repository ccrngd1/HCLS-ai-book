[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m       "icd10": [{"Code": "N18.3", "Description": "Chronic kidney disease, stage 3 (moderate)", "Score": 0.90}]
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m     {
