[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m       "icd10": [{"Code": "E11.9", "Description": "Type 2 diabetes mellitus without complications", "Score": 0.91}]
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m     {
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m       "text": "chronic kidney disease stage 3",
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m       "assertion": "PRESENT",
