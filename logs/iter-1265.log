[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m   "problems_extracted": [
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m     {
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m       "text": "type 2 diabetes",
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m       "assertion": "PRESENT",
