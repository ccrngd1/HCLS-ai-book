[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m   "timestamp": "2026-03-15T14:30:00Z",
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m   "current_state_summary": {
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m     "hours_on_vent": 72,
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m     "fio2": 40,
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m     "peep": 5,
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m     "pressure_support": 10,
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m     "spo2": 96,
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m     "rass": -1,
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m     "respiratory_rate": 18,
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m     "failed_sbt_count": 0
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m   },
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m   "recommendation": {
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m     "action": "initiate_sbt",
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m     "confidence": 0.72,
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m     "reasoning": "Patient meets SBT criteria. Stable on minimal support for 6+ hours. Similar patients in training data had 78% SBT success rate at this state."
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m   },
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m   "alternative_actions": [
