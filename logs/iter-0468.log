[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m     RETURN summary_stats(enriched)
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m **Step 2: Estimate per-payer payment timing distributions from history.** For each (payer, claim type, branch) combination, the pipeline computes the empirical distribution of days-from-submission-to-payment using a rolling window of historical remits. These distributions are the heart of the timing model and need to be refreshed often enough to catch payer behavior shifts.
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m ```text
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m FUNCTION estimate_timing_distributions(remit_history_path, output_path,
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m                                         window_days = 365, min_observations = 50):
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m     // Load the historical remits restricted to the rolling window.
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m     remits = read_parquet(remit_history_path)
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m         .filter(payment_date >= today() - window_days)
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m     // Compute days-to-remit for each cleanly paid claim.
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m     // Joining back to the original submission date lets us measure the
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m     // full lifecycle, including reworked claims (which use the most
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m     // recent resubmission date as the timing anchor).
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m     timed = remits
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m         .with_column(days_to_remit = payment_date - effective_submission_date)
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m         .filter(days_to_remit >= 0 AND days_to_remit <= 365)
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m     // Group by (payer, claim type, branch) and compute the empirical
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m     // distribution. We store both a coarse histogram and a kernel density
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m     // estimate. The histogram is fast to sample from in the simulator;
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m     // the KDE captures the tails better.
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m     distributions = []
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m     FOR each group in timed.group_by(payer_id, claim_type, branch):
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m         IF count(group) < min_observations:
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m             // Not enough data; fall back to a payer-level distribution
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m             // that pools across claim types, or to a global default.
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m             log warning "insufficient data; using fallback for " + group.key
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m             distribution = fallback_distribution(group.key)
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m         ELSE:
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m             histogram = compute_histogram(group.days_to_remit, bin_width = 1)
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m             kde       = fit_kde(group.days_to_remit, bandwidth = "scott")
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m             distribution = {
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m                 payer_id:         group.payer_id,
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m                 claim_type:       group.claim_type,
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m                 branch:           group.branch,
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m                 histogram:        histogram,
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m                 kde:              kde,
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m                 sample_count:     count(group),
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m                 window_start:     min(group.payment_date),
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m                 window_end:       max(group.payment_date),
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m                 median_days:      median(group.days_to_remit),
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m                 p10_days:         percentile(group.days_to_remit, 10),
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m                 p90_days:         percentile(group.days_to_remit, 90)
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m         distributions.append(distribution)
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m     // Sanity check: flag distributions that have shifted materially since
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m     // the previous run. A jump in median days-to-remit > 5 days at a
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m     // major payer is a model-validity event that the on-call team should see.
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m     drift_report = compare_to_previous(distributions, output_path)
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m     write_drift_report(drift_report)
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m     write_parquet(distributions, output_path)
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m     RETURN summary_stats(distributions)
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m **Step 3: Train and apply the per-claim probability model.** A gradient-boosted model produces, for each open claim, the probability of clean payment versus initial denial, the probability of successful rework given denial, and the expected reimbursement amount conditional on payment. These outputs feed into the simulator in Step 4.
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m ```text
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m FUNCTION train_and_apply_claim_model(feature_table_path, model_path):
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m     features = read_parquet(feature_table_path)
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m     // Split into training (resolved historical claims) and inference
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m     // (currently open claims).
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m     training = features.filter(model_branch in (resolved_clean, resolved_denied,
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m                                                 resolved_reworked, written_off))
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m     open     = features.filter(model_branch in (clean, reworked, in_appeal))
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m     // Train three models. Keep them small and explainable; XGBoost or
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m     // LightGBM with default hyperparameters tuned via cross-validation
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m     // gets you most of the way.
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m     // Model 1: probability of initial denial, given features.
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m     denial_model = train_classifier(
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m         training,
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m         label = "was_initially_denied",
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m         features = ["payer_id", "claim_type", "place_of_service",
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m                     "primary_procedure_code", "primary_diagnosis_code",
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m                     "claim_dollar_band", "payer_recent_denial_rate"]
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m     // Model 2: probability of successful rework, given that a claim was denied.
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m     rework_model = train_classifier(
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m         training.filter(was_initially_denied = true),
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m         label = "was_eventually_paid",
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m         features = denial_model.features + ["denial_reason_code"]
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m     // Model 3: expected reimbursement amount, given that the claim is paid.
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m     amount_model = train_regressor(
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m         training.filter(was_eventually_paid = true),
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m         label = "paid_amount",
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m         features = ["payer_id", "claim_type", "billed_amount",
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m                     "expected_reimbursement", "primary_procedure_code"]
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m     // Apply the models to the open claims to produce per-claim parameters
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m     // that the simulator will consume.
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m     open = open
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m         .with_column(p_initial_denial      = denial_model.predict_proba(open))
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m         .with_column(p_rework_success      = rework_model.predict_proba(open))
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m         .with_column(predicted_paid_amount = amount_model.predict(open))
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m     write_parquet(open, model_path + "/open-claims-with-probs/")
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m     save_models(denial_model, rework_model, amount_model, model_path)
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m     RETURN summary_stats(open)
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m **Step 4: Run the Monte Carlo simulator to produce forecast distributions.** With per-claim probabilities and per-payer timing distributions in hand, the simulator runs many forward paths of cash receipt and aggregates them into forecast distributions at multiple horizons and granularities. The simulation is the linchpin: it is what produces calibrated prediction intervals rather than just point estimates.
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m ```text
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m FUNCTION run_monte_carlo_simulator(open_claims_path, distributions_path,
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m                                     deterministic_events_path, output_path,
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m                                     n_simulations = 10000, horizon_days = 90):
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m     open_claims  = read_parquet(open_claims_path)
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m     timing_dists = read_parquet(distributions_path)
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m     deterministic = read_parquet(deterministic_events_path)
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m     // Deterministic events are capitation drops, scheduled settlements,
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m     // and any other contractually defined cash that is not subject to
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m     // payer payment-timing uncertainty.
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m     // Pre-compute the distribution lookup so the inner loop is fast.
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m     dist_lookup = build_lookup(timing_dists, key = (payer_id, claim_type, branch))
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m     // Initialize the simulation matrix: one row per simulation, one
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m     // column per day in the forecast horizon.
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m     sim_matrix = zero_matrix(n_simulations, horizon_days)
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m     FOR sim_index in range(n_simulations):
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m         FOR claim in open_claims:
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m             // Draw the model branch this claim takes in this simulation.
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m             // Branches: clean payment, denial -> rework -> payment,
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m             // denial -> appeal -> payment, denial -> writeoff.
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m             branch = sample_branch(
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m                 p_initial_denial   = claim.p_initial_denial,
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m                 p_rework_success   = claim.p_rework_success
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m             IF branch == "writeoff":
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m                 // No cash from this claim in this simulation.
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m                 CONTINUE
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m             // Look up the appropriate timing distribution for the chosen branch.
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m             timing_dist = dist_lookup.get(claim.payer_id, claim.claim_type, branch)
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m             // Sample a payment day from the distribution. Reworked and
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m             // appealed claims sample from longer-tailed distributions.
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m             days_to_pay = sample_from_distribution(timing_dist)
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m             // Translate to absolute date relative to today.
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m             payment_day_index = (claim.submission_date - today()) + days_to_pay
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m             IF payment_day_index >= 0 AND payment_day_index < horizon_days:
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m                 // Sample the paid amount around the expected value.
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m                 paid_amount = sample_paid_amount(claim.predicted_paid_amount,
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m                                                   branch_specific_variance(branch))
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m                 sim_matrix[sim_index, payment_day_index] += paid_amount
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m         // Add the deterministic events to this simulation. Identical
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m         // across simulations (no uncertainty in capitation timing under
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m         // normal operations) but included so the aggregation reflects
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m         // total cash, not just stochastic AR cash.
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m         FOR event in deterministic:
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m             day_index = event.expected_date - today()
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m             IF day_index >= 0 AND day_index < horizon_days:
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m                 sim_matrix[sim_index, day_index] += event.expected_amount
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m     // Aggregate the simulation matrix into forecast distributions.
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m     // Daily forecast: one distribution per day (mean, p10, p50, p90).
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m     daily_forecast = []
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m     FOR day_index in range(horizon_days):
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m         col = sim_matrix[:, day_index]
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m         daily_forecast.append({
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m             forecast_date:   today() + day_index,
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m             mean:            mean(col),
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m             p10:             percentile(col, 10),
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m             p50:             percentile(col, 50),
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m             p90:             percentile(col, 90),
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m             std_dev:         std_dev(col)
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m     // Weekly and monthly aggregates derived from the same simulations.
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m     weekly_forecast  = aggregate_to_period(sim_matrix, period = "weekly")
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m     monthly_forecast = aggregate_to_period(sim_matrix, period = "monthly")
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m     write_parquet(daily_forecast, output_path + "/daily/")
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m     write_parquet(weekly_forecast, output_path + "/weekly/")
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m     write_parquet(monthly_forecast, output_path + "/monthly/")
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m     // Per-claim risk scores: average expected days-to-cash and probability
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m     // of slipping past 60 days, for the PFS worklist consumer.
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m     per_claim_scores = compute_per_claim_scores(sim_matrix, open_claims)
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m     write_parquet(per_claim_scores, output_path + "/claim-scores/")
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m     RETURN { daily: daily_forecast, weekly: weekly_forecast,
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m              monthly: monthly_forecast, claim_scores: per_claim_scores }
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m **Step 5: Publish forecasts and risk scores to the consumer surfaces.** The simulator outputs get loaded into DynamoDB (for low-latency dashboard queries and worklist tooling) and partitioned in S3 (for historical analytics and back-testing). Alarms watch for confidence interval widening and forecast-versus-actual drift.
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m ```text
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m FUNCTION publish_outputs(forecasts, claim_scores, dynamo_forecast_table,
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m                           dynamo_claim_table):
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m     // Load daily, weekly, monthly forecasts into the cash-forecasts table.
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m     // Partition key: forecast_horizon (daily/weekly/monthly).
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m     // Sort key: forecast_date or forecast_period.
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m     forecast_items = []
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m     FOR each forecast in (forecasts.daily, forecasts.weekly, forecasts.monthly):
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m         FOR each row in forecast:
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m             forecast_items.append({
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m                 forecast_horizon: forecast.granularity,
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m                 forecast_period:  row.forecast_date or row.period_label,
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m                 mean:             row.mean,
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m                 p10:              row.p10,
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m                 p50:              row.p50,
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m                 p90:              row.p90,
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m                 std_dev:          row.std_dev,
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m                 generated_at_ts:  now(),
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m                 model_version:    current_model_version()
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m     batches = chunk forecast_items into groups of 25
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m     FOR each batch in batches:
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m         write batch to dynamo_forecast_table
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m         retry unprocessed items with exponential backoff
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m     // Load per-claim risk scores into the claim-risk-scores table.
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m     // Partition key: claim_id.
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m     claim_items = [build_claim_item(score) FOR score in claim_scores]
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m     batches = chunk claim_items into groups of 25
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m     FOR each batch in batches:
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m         write batch to dynamo_claim_table
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m         retry unprocessed items
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m     // Emit accuracy metrics by comparing previous forecasts to actuals
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m     // that have since materialized. This is the metric that earns trust
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m     // with the treasury team over time.
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m     actuals = load_recent_actuals(lookback_days = 30)
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m     accuracy = compute_forecast_accuracy(actuals, dynamo_forecast_table)
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m     emit_cloudwatch_metric("forecast.mape_30day", accuracy.mape)
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m     emit_cloudwatch_metric("forecast.bias_30day", accuracy.bias)
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m     emit_cloudwatch_metric("forecast.pi_coverage_80",
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m                             accuracy.coverage_at_80_interval)
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m     // Watch for sudden interval widening, which often signals payer
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m     // behavior shift or an upstream data issue.
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m     IF accuracy.recent_pi_width > accuracy.baseline_pi_width * 1.5:
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m         send_alert(SNS_TOPIC, "Forecast prediction intervals have widened")
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m     RETURN accuracy
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m 
