[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m   "p90": 471200.00,
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m   "std_dev": 44100.00,
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m   "decomposition": {
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m     "medicare_part_a": 142800.00,
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m     "medicare_part_b": 67400.00,
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m     "medicaid": 38900.00,
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m     "commercial_managed_care": 121600.00,
