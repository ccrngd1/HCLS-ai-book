[0m[49m[38;5;10m+     111[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     112[0m:[38;5;10m[49m     Generate synthetic resolved claims with known outcomes.
[0m[49m[38;5;10m+     113[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     114[0m:[38;5;10m[49m     Key design choices:
[0m[49m[38;5;10m+     115[0m:[38;5;10m[49m     - Denial probability depends on payer + procedure + PA status interactions
[0m[49m[38;5;10m+     116[0m:[38;5;10m[49m     - Only KNOWN_PAYERS appear here (novel payers are reserved for test set)
[0m[49m[38;5;10m+     117[0m:[38;5;10m[49m     - Each claim gets a denial_reason if denied, which we use for clustering
[0m[49m[38;5;10m+     118[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     119[0m:[38;5;10m[49m     rng = np.random.default_rng(seed)
[0m[49m[38;5;10m+     120[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     121[0m:[38;5;10m[49m     cpt_list = list(CPT_CODES.keys())
[0m[49m[38;5;10m+     122[0m:[38;5;10m[49m     payer_denial_rates = {
[0m[49m[38;5;10m+     123[0m:[38;5;10m[49m         "BCBS": 0.09, "UnitedHealthcare": 0.14, "Aetna": 0.11,
[0m[49m[38;5;10m+     124[0m:[38;5;10m[49m         "Cigna": 0.10, "Humana": 0.13, "Medicare": 0.07,
[0m[49m[38;5;10m+     125[0m:[38;5;10m[49m         "Medicaid": 0.16, "Tricare": 0.08,
[0m[49m[38;5;10m+     126[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     127[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     128[0m:[38;5;10m[49m     data = {
[0m[49m[38;5;10m+     129[0m:[38;5;10m[49m         "claim_id": [f"HIST-{i:07d}" for i in range(n_claims)],
[0m[49m[38;5;10m+     130[0m:[38;5;10m[49m         "payer": rng.choice(KNOWN_PAYERS, n_claims),
[0m[49m[38;5;10m+     131[0m:[38;5;10m[49m         "cpt_code": rng.choice(cpt_list, n_claims),
[0m[49m[38;5;10m+     132[0m:[38;5;10m[49m         "icd10_primary": rng.choice(ICD10_CODES, n_claims),
[0m[49m[38;5;10m+     133[0m:[38;5;10m[49m         "place_of_service": rng.choice(PLACE_OF_SERVICE, n_claims),
[0m[49m[38;5;10m+     134[0m:[38;5;10m[49m         "provider_type": rng.choice(PROVIDER_TYPES, n_claims),
[0m[49m[38;5;10m+     135[0m:[38;5;10m[49m         "claim_amount": np.round(rng.lognormal(6.0, 1.2, n_claims), 2),
[0m[49m[38;5;10m+     136[0m:[38;5;10m[49m         "patient_age": rng.integers(18, 90, n_claims),
[0m[49m[38;5;10m+     137[0m:[38;5;10m[49m         "num_modifiers": rng.integers(0, 4, n_claims),
[0m[49m[38;5;10m+     138[0m:[38;5;10m[49m         "has_modifier_25": rng.choice([0, 1], n_claims, p=[0.8, 0.2]),
[0m[49m[38;5;10m+     139[0m:[38;5;10m[49m         "has_modifier_59": rng.choice([0, 1], n_claims, p=[0.85, 0.15]),
[0m[49m[38;5;10m+     140[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     141[0m:[38;5;10m[49m     df = pd.DataFrame(data)
[0m[49m[38;5;10m+     142[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     143[0m:[38;5;10m[49m     # Prior auth logic: high-risk procedures more likely to require PA
[0m[49m[38;5;10m+     144[0m:[38;5;10m[49m     pa_required_prob = df["cpt_code"].map(
[0m[49m[38;5;10m+     145[0m:[38;5;10m[49m         lambda c: 0.7 if CPT_CODES.get(c, 1.0) > 1.3 else 0.1
[0m[49m[38;5;10m+     146[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     147[0m:[38;5;10m[49m     df["pa_required"] = rng.binomial(1, pa_required_prob)
[0m[49m[38;5;10m+     148[0m:[38;5;10m[49m     df["pa_on_file"] = np.where(
[0m[49m[38;5;10m+     149[0m:[38;5;10m[49m         df["pa_required"] == 1, rng.binomial(1, 0.70, n_claims), 0
[0m[49m[38;5;10m+     150[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     151[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     152[0m:[38;5;10m[49m     # Compute denial probability from feature interactions
[0m[49m[38;5;10m+     153[0m:[38;5;10m[49m     denial_prob = df["payer"].map(payer_denial_rates).values.astype(float)
[0m[49m[38;5;10m+     154[0m:[38;5;10m[49m     cpt_mult = df["cpt_code"].map(CPT_CODES).fillna(1.0).values
[0m[49m[38;5;10m+     155[0m:[38;5;10m[49m     denial_prob = denial_prob * cpt_mult
[0m[49m[38;5;10m+     156[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     157[0m:[38;5;10m[49m     # PA missing = near-guarantee of denial
[0m[49m[38;5;10m+     158[0m:[38;5;10m[49m     pa_missing = (df["pa_required"] == 1) & (df["pa_on_file"] == 0)
[0m[49m[38;5;10m+     159[0m:[38;5;10m[49m     denial_prob = np.where(pa_missing, np.clip(denial_prob + 0.55, 0, 0.95), denial_prob)
[0m[49m[38;5;10m+     160[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     161[0m:[38;5;10m[49m     # High claim amounts get more scrutiny
[0m[49m[38;5;10m+     162[0m:[38;5;10m[49m     denial_prob = np.where(df["claim_amount"] > 5000, denial_prob * 1.15, denial_prob)
[0m[49m[38;5;10m+     163[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     164[0m:[38;5;10m[49m     # Add noise, clip, generate binary outcome
[0m[49m[38;5;10m+     165[0m:[38;5;10m[49m     denial_prob = np.clip(denial_prob + rng.normal(0, 0.03, n_claims), 0.01, 0.95)
[0m[49m[38;5;10m+     166[0m:[38;5;10m[49m     df["denied"] = rng.binomial(1, denial_prob)
[0m[49m[38;5;10m+     167[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     168[0m:[38;5;10m[49m     # Assign denial reasons (only for denied claims)
[0m[49m[38;5;10m+     169[0m:[38;5;10m[49m     # Weight reasons based on features for realistic clustering patterns
[0m[49m[38;5;10m+     170[0m:[38;5;10m[49m     denied_mask = df["denied"] == 1
[0m[49m[38;5;10m+     171[0m:[38;5;10m[49m     n_denied = denied_mask.sum()
[0m[49m[38;5;10m+     172[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     173[0m:[38;5;10m[49m     # PA-missing claims get "no_prior_auth" reason
[0m[49m[38;5;10m+     174[0m:[38;5;10m[49m     reasons = np.full(n_claims, "", dtype=object)
[0m[49m[38;5;10m+     175[0m:[38;5;10m[49m     pa_denial_mask = denied_mask & pa_missing
[0m[49m[38;5;10m+     176[0m:[38;5;10m[49m     reasons[pa_denial_mask] = "no_prior_auth"
[0m[49m[38;5;10m+     177[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     178[0m:[38;5;10m[49m     # Remaining denied claims get other reasons
[0m[49m[38;5;10m+     179[0m:[38;5;10m[49m     remaining_denied = denied_mask & ~pa_denial_mask
[0m[49m[38;5;10m+     180[0m:[38;5;10m[49m     n_remaining = remaining_denied.sum()
[0m[49m[38;5;10m+     181[0m:[38;5;10m[49m     other_reasons = ["medical_necessity", "timely_filing", "bundling_error",
[0m[49m[38;5;10m+     182[0m:[38;5;10m[49m                      "coding_error", "not_covered"]
[0m[49m[38;5;10m+     183[0m:[38;5;10m[49m     reasons[remaining_denied] = rng.choice(other_reasons, n_remaining)
[0m[49m[38;5;10m+     184[0m:[38;5;10m[49m     df["denial_reason"] = reasons
[0m[49m[38;5;10m+     185[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     186[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+     187[0m:[38;5;10m[49m         "Generated %d historical claims. Denial rate: %.1f%%",
[0m[49m[38;5;10m+     188[0m:[38;5;10m[49m         n_claims, df["denied"].mean() * 100
[0m[49m[38;5;10m+     189[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     190[0m:[38;5;10m[49m     return df
[0m[49m[38;5;10m+     191[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     192[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     193[0m:[38;5;10m[49m def generate_novel_claims(n_claims: int = NUM_NOVEL_CLAIMS,
[0m[49m[38;5;10m+     194[0m:[38;5;10m[49m                           seed: int = 99) -> pd.DataFrame:
[0m[49m[38;5;10m+     195[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     196[0m:[38;5;10m[49m     Generate claims that are deliberately OUT OF DISTRIBUTION.
[0m[49m[38;5;10m+     197[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     198[0m:[38;5;10m[49m     These use novel payers (not in training history) and unusual
[0m[49m[38;5;10m+     199[0m:[38;5;10m[49m     payer-procedure combinations. This is the cold-start scenario
[0m[49m[38;5;10m+     200[0m:[38;5;10m[49m     the novelty detector should catch.
[0m[49m[38;5;10m+     201[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     202[0m:[38;5;10m[49m     rng = np.random.default_rng(seed)
[0m[49m[38;5;10m+     203[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     204[0m:[38;5;10m[49m     cpt_list = list(CPT_CODES.keys())
[0m[49m[38;5;10m+     205[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     206[0m:[38;5;10m[49m     data = {
[0m[49m[38;5;10m+     207[0m:[38;5;10m[49m         "claim_id": [f"NOVEL-{i:05d}" for i in range(n_claims)],
[0m[49m[38;5;10m+     208[0m:[38;5;10m[49m         # Mix of novel payers and known payers with unusual combos
[0m[49m[38;5;10m+     209[0m:[38;5;10m[49m         "payer": rng.choice(NOVEL_PAYERS + ["Medicare"], n_claims, p=[0.3, 0.3, 0.3, 0.1]),
[0m[49m[38;5;10m+     210[0m:[38;5;10m[49m         "cpt_code": rng.choice(cpt_list, n_claims),
[0m[49m[38;5;10m+     211[0m:[38;5;10m[49m         "icd10_primary": rng.choice(ICD10_CODES, n_claims),
[0m[49m[38;5;10m+     212[0m:[38;5;10m[49m         "place_of_service": rng.choice(PLACE_OF_SERVICE, n_claims),
[0m[49m[38;5;10m+     213[0m:[38;5;10m[49m         "provider_type": rng.choice(PROVIDER_TYPES, n_claims),
[0m[49m[38;5;10m+     214[0m:[38;5;10m[49m         "claim_amount": np.round(rng.lognormal(7.0, 1.5, n_claims), 2),
[0m[49m[38;5;10m+     215[0m:[38;5;10m[49m         "patient_age": rng.integers(18, 90, n_claims),
[0m[49m[38;5;10m+     216[0m:[38;5;10m[49m         "num_modifiers": rng.integers(0, 4, n_claims),
[0m[49m[38;5;10m+     217[0m:[38;5;10m[49m         "has_modifier_25": rng.choice([0, 1], n_claims, p=[0.7, 0.3]),
[0m[49m[38;5;10m+     218[0m:[38;5;10m[49m         "has_modifier_59": rng.choice([0, 1], n_claims, p=[0.75, 0.25]),
[0m[49m[38;5;10m+     219[0m:[38;5;10m[49m         "pa_required": rng.choice([0, 1], n_claims, p=[0.4, 0.6]),
[0m[49m[38;5;10m+     220[0m:[38;5;10m[49m         "pa_on_file": rng.choice([0, 1], n_claims, p=[0.5, 0.5]),
[0m[49m[38;5;10m+     221[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     222[0m:[38;5;10m[49m     df = pd.DataFrame(data)
[0m[49m[38;5;10m+     223[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     224[0m:[38;5;10m[49m     # Novel claims don't have outcomes yet (they're new, unresolved)
[0m[49m[38;5;10m+     225[0m:[38;5;10m[49m     # But for evaluation, we assign ground truth so we can measure accuracy
[0m[49m[38;5;10m+     226[0m:[38;5;10m[49m     df["denied"] = rng.choice([0, 1], n_claims, p=[0.4, 0.6])
[0m[49m[38;5;10m+     227[0m:[38;5;10m[49m     df["denial_reason"] = np.where(
[0m[49m[38;5;10m+     228[0m:[38;5;10m[49m         df["denied"] == 1,
[0m[49m[38;5;10m+     229[0m:[38;5;10m[49m         rng.choice(DENIAL_REASONS, n_claims),
[0m[49m[38;5;10m+     230[0m:[38;5;10m[49m         ""
[0m[49m[38;5;10m+     231[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     232[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     233[0m:[38;5;10m[49m     logger.info("Generated %d novel/OOD claims for testing", n_claims)
[0m[49m[38;5;10m+     234[0m:[38;5;10m[49m     return df
[0m[49m[38;5;10m+     235[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     236[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     237[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     238[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     239[0m:[38;5;10m[49m ## Step 2: Build Feature Vectors with Proper Encoding and Scaling
[0m[49m[38;5;10m+     240[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     241[0m:[38;5;10m[49m *The main recipe's Step 1 describes computing claim embeddings. kNN is notoriously scale-sensitive: if billed amount ranges from $10 to $500,000 and categorical features are 0/1, the distance metric is dominated by dollar differences. Here we handle categorical encoding (one-hot for low-cardinality, frequency encoding for high-cardinality) and standard scaling so all features contribute proportionally.*
[0m[49m[38;5;10m+     242[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     243[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     244[0m:[38;5;10m[49m from sklearn.preprocessing import StandardScaler, OneHotEncoder
[0m[49m[38;5;10m+     245[0m:[38;5;10m[49m from sklearn.compose import ColumnTransformer
[0m[49m[38;5;10m+     246[0m:[38;5;10m[49m from sklearn.pipeline import Pipeline
[0m[49m[38;5;10m+     247[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     248[0m:[38;5;10m[49m # Feature columns grouped by type
[0m[49m[38;5;10m+     249[0m:[38;5;10m[49m CATEGORICAL_FEATURES = ["payer", "cpt_code", "icd10_primary",
[0m[49m[38;5;10m+     250[0m:[38;5;10m[49m                         "place_of_service", "provider_type"]
[0m[49m[38;5;10m+     251[0m:[38;5;10m[49m NUMERIC_FEATURES = ["claim_amount", "patient_age", "num_modifiers",
[0m[49m[38;5;10m+     252[0m:[38;5;10m[49m                     "has_modifier_25", "has_modifier_59",
[0m[49m[38;5;10m+     253[0m:[38;5;10m[49m                     "pa_required", "pa_on_file"]
[0m[49m[38;5;10m+     254[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     255[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     256[0m:[38;5;10m[49m def build_embedding_pipeline() -> ColumnTransformer:
[0m[49m[38;5;10m+     257[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     258[0m:[38;5;10m[49m     Build a sklearn ColumnTransformer that encodes claims into fixed-length
[0m[49m[38;5;10m+     259[0m:[38;5;10m[49m     numeric vectors suitable for distance computation.
[0m[49m[38;5;10m+     260[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     261[0m:[38;5;10m[49m     For kNN, feature scaling matters enormously. Without it, high-magnitude
[0m[49m[38;5;10m+     262[0m:[38;5;10m[49m     features (claim_amount) dominate the distance metric and low-magnitude
[0m[49m[38;5;10m+     263[0m:[38;5;10m[49m     features (binary flags) become irrelevant.
[0m[49m[38;5;10m+     264[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     265[0m:[38;5;10m[49m     We use:
[0m[49m[38;5;10m+     266[0m:[38;5;10m[49m     - OneHotEncoder for categoricals (creates sparse binary columns)
[0m[49m[38;5;10m+     267[0m:[38;5;10m[49m     - StandardScaler for numerics (mean=0, std=1)
[0m[49m[38;5;10m+     268[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     269[0m:[38;5;10m[49m     The output is a dense matrix where all features are on comparable scales.
[0m[49m[38;5;10m+     270[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     271[0m:[38;5;10m[49m     preprocessor = ColumnTransformer(
[0m[49m[38;5;10m+     272[0m:[38;5;10m[49m         transformers=[
[0m[49m[38;5;10m+     273[0m:[38;5;10m[49m             ("cat", OneHotEncoder(handle_unknown="ignore", sparse_output=False),
[0m[49m[38;5;10m+     274[0m:[38;5;10m[49m              CATEGORICAL_FEATURES),
[0m[49m[38;5;10m+     275[0m:[38;5;10m[49m             ("num", StandardScaler(), NUMERIC_FEATURES),
[0m[49m[38;5;10m+     276[0m:[38;5;10m[49m         ],
[0m[49m[38;5;10m+     277[0m:[38;5;10m[49m         remainder="drop"
[0m[49m[38;5;10m+     278[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     279[0m:[38;5;10m[49m     return preprocessor
[0m[49m[38;5;10m+     280[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     281[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     282[0m:[38;5;10m[49m def compute_embeddings(df: pd.DataFrame, preprocessor: ColumnTransformer,
[0m[49m[38;5;10m+     283[0m:[38;5;10m[49m                        fit: bool = False) -> np.ndarray:
[0m[49m[38;5;10m+     284[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     285[0m:[38;5;10m[49m     Transform a claims DataFrame into a numeric embedding matrix.
[0m[49m[38;5;10m+     286[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     287[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     288[0m:[38;5;10m[49m         df: Claims data with the expected feature columns
[0m[49m[38;5;10m+     289[0m:[38;5;10m[49m         preprocessor: Fitted (or to-be-fitted) ColumnTransformer
[0m[49m[38;5;10m+     290[0m:[38;5;10m[49m         fit: If True, fit the transformer on this data first
[0m[49m[38;5;10m+     291[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     292[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     293[0m:[38;5;10m[49m         numpy array of shape (n_claims, embedding_dim)
[0m[49m[38;5;10m+     294[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     295[0m:[38;5;10m[49m     if fit:
[0m[49m[38;5;10m+     296[0m:[38;5;10m[49m         embeddings = preprocessor.fit_transform(df)
[0m[49m[38;5;10m+     297[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+     298[0m:[38;5;10m[49m         embeddings = preprocessor.transform(df)
[0m[49m[38;5;10m+     299[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     300[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+     301[0m:[38;5;10m[49m         "Computed embeddings: %d claims x %d dimensions",
[0m[49m[38;5;10m+     302[0m:[38;5;10m[49m         embeddings.shape[0], embeddings.shape[1]
[0m[49m[38;5;10m+     303[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     304[0m:[38;5;10m[49m     return embeddings
[0m[49m[38;5;10m+     305[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     306[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     307[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     308[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     309[0m:[38;5;10m[49m ## Step 3: k-Nearest Neighbors Retrieval and Prediction
[0m[49m[38;5;10m+     310[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     311[0m:[38;5;10m[49m *The main recipe's Step 3 queries the vector index for neighbors. Here we implement the full kNN retrieval locally using scikit-learn's NearestNeighbors (which uses a ball tree or KD-tree for efficient search). For each new claim, we find the k most similar resolved claims, derive a weighted-vote prediction from their outcomes, and compute distance-based confidence.*
[0m[49m[38;5;10m+     312[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     313[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     314[0m:[38;5;10m[49m from sklearn.neighbors import NearestNeighbors
[0m[49m[38;5;10m+     315[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     316[0m:[38;5;10m[49m def build_knn_index(history_embeddings: np.ndarray,
[0m[49m[38;5;10m+     317[0m:[38;5;10m[49m                     n_neighbors: int = K_NEIGHBORS) -> NearestNeighbors:
[0m[49m[38;5;10m+     318[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     319[0m:[38;5;10m[49m     Build a k-NN index over historical claim embeddings.
[0m[49m[38;5;10m+     320[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     321[0m:[38;5;10m[49m     We use cosine distance (metric="cosine") because it handles the mix of
[0m[49m[38;5;10m+     322[0m:[38;5;10m[49m     one-hot encoded categoricals and scaled numerics well. Cosine measures
[0m[49m[38;5;10m+     323[0m:[38;5;10m[49m     the angle between vectors, not the magnitude, so a high-dollar claim
[0m[49m[38;5;10m+     324[0m:[38;5;10m[49m     and a low-dollar claim with the same feature pattern will still be
[0m[49m[38;5;10m+     325[0m:[38;5;10m[49m     "close" in cosine space.
[0m[49m[38;5;10m+     326[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     327[0m:[38;5;10m[49m     In production, this index lives in OpenSearch. Here we use sklearn
[0m[49m[38;5;10m+     328[0m:[38;5;10m[49m     for demonstration.
[0m[49m[38;5;10m+     329[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     330[0m:[38;5;10m[49m     knn = NearestNeighbors(
[0m[49m[38;5;10m+     331[0m:[38;5;10m[49m         n_neighbors=n_neighbors,
[0m[49m[38;5;10m+     332[0m:[38;5;10m[49m         metric="cosine",
[0m[49m[38;5;10m+     333[0m:[38;5;10m[49m         algorithm="brute",  # brute-force is fine for <100k vectors
[0m[49m[38;5;10m+     334[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     335[0m:[38;5;10m[49m     knn.fit(history_embeddings)
[0m[49m[38;5;10m+     336[0m:[38;5;10m[49m     logger.info("Built kNN index over %d vectors", history_embeddings.shape[0])
[0m[49m[38;5;10m+     337[0m:[38;5;10m[49m     return knn
[0m[49m[38;5;10m+     338[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     339[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     340[0m:[38;5;10m[49m def retrieve_neighbors(knn_index: NearestNeighbors,
[0m[49m[38;5;10m+     341[0m:[38;5;10m[49m                        query_embedding: np.ndarray,
[0m[49m[38;5;10m+     342[0m:[38;5;10m[49m                        history_df: pd.DataFrame,
[0m[49m[38;5;10m+     343[0m:[38;5;10m[49m                        k: int = K_NEIGHBORS) -> list:
[0m[49m[38;5;10m+     344[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     345[0m:[38;5;10m[49m     For a single new claim embedding, find the k nearest resolved claims.
[0m[49m[38;5;10m+     346[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     347[0m:[38;5;10m[49m     Returns a list of dicts with neighbor metadata, outcome, and distance.
[0m[49m[38;5;10m+     348[0m:[38;5;10m[49m     Distance here is cosine distance (0 = identical, 1 = orthogonal).
[0m[49m[38;5;10m+     349[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     350[0m:[38;5;10m[49m     # query_embedding should be shape (1, n_features)
[0m[49m[38;5;10m+     351[0m:[38;5;10m[49m     if query_embedding.ndim == 1:
[0m[49m[38;5;10m+     352[0m:[38;5;10m[49m         query_embedding = query_embedding.reshape(1, -1)
[0m[49m[38;5;10m+     353[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     354[0m:[38;5;10m[49m     distances, indices = knn_index.kneighbors(query_embedding, n_neighbors=k)
[0m[49m[38;5;10m+     355[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     356[0m:[38;5;10m[49m     neighbors = []
[0m[49m[38;5;10m+     357[0m:[38;5;10m[49m     for dist, idx in zip(distances[0], indices[0]):
[0m[49m[38;5;10m+     358[0m:[38;5;10m[49m         row = history_df.iloc[idx]
[0m[49m[38;5;10m+     359[0m:[38;5;10m[49m         neighbors.append({
[0m[49m[38;5;10m+     360[0m:[38;5;10m[49m             "claim_id": row["claim_id"],
[0m[49m[38;5;10m+     361[0m:[38;5;10m[49m             "distance": float(dist),          # cosine distance
[0m[49m[38;5;10m+     362[0m:[38;5;10m[49m             "similarity": 1.0 - float(dist),  # convert to similarity
[0m[49m[38;5;10m+     363[0m:[38;5;10m[49m             "outcome": "denied" if row["denied"] == 1 else "paid",
[0m[49m[38;5;10m+     364[0m:[38;5;10m[49m             "denial_reason": row["denial_reason"],
[0m[49m[38;5;10m+     365[0m:[38;5;10m[49m             "payer": row["payer"],
[0m[49m[38;5;10m+     366[0m:[38;5;10m[49m             "cpt_code": row["cpt_code"],
[0m[49m[38;5;10m+     367[0m:[38;5;10m[49m             "claim_amount": float(row["claim_amount"]),
[0m[49m[38;5;10m+     368[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     369[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     370[0m:[38;5;10m[49m     return neighbors
[0m[49m[38;5;10m+     371[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     372[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     373[0m:[38;5;10m[49m def compute_knn_prediction(neighbors: list,
[0m[49m[38;5;10m+     374[0m:[38;5;10m[49m                            k_vote: int = K_VOTE) -> dict:
[0m[49m[38;5;10m+     375[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     376[0m:[38;5;10m[49m     From retrieved neighbors, compute:
[0m[49m[38;5;10m+     377[0m:[38;5;10m[49m     1. kNN denial probability (similarity-weighted vote)
[0m[49m[38;5;10m+     378[0m:[38;5;10m[49m     2. Novelty score (mean distance to top-5 neighbors)
[0m[49m[38;5;10m+     379[0m:[38;5;10m[49m     3. Top denial reasons from the neighborhood
[0m[49m[38;5;10m+     380[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     381[0m:[38;5;10m[49m     The novelty score is the key insight: if even the closest neighbors
[0m[49m[38;5;10m+     382[0m:[38;5;10m[49m     are far away, this claim is out of distribution.
[0m[49m[38;5;10m+     383[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     384[0m:[38;5;10m[49m     # Novelty: mean cosine distance to top-5 neighbors
[0m[49m[38;5;10m+     385[0m:[38;5;10m[49m     # Higher = more novel (nothing in history looks like this)
[0m[49m[38;5;10m+     386[0m:[38;5;10m[49m     top_5_distances = [n["distance"] for n in neighbors[:5]]
[0m[49m[38;5;10m+     387[0m:[38;5;10m[49m     novelty_score = float(np.mean(top_5_distances))
[0m[49m[38;5;10m+     388[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     389[0m:[38;5;10m[49m     # Weighted vote: closer neighbors get more influence
[0m[49m[38;5;10m+     390[0m:[38;5;10m[49m     # Use similarity (1 - distance) as weight
[0m[49m[38;5;10m+     391[0m:[38;5;10m[49m     voting_neighbors = neighbors[:k_vote]
[0m[49m[38;5;10m+     392[0m:[38;5;10m[49m     denied_weight = 0.0
[0m[49m[38;5;10m+     393[0m:[38;5;10m[49m     total_weight = 0.0
[0m[49m[38;5;10m+     394[0m:[38;5;10m[49m     for n in voting_neighbors:
[0m[49m[38;5;10m+     395[0m:[38;5;10m[49m         weight = n["similarity"]
[0m[49m[38;5;10m+     396[0m:[38;5;10m[49m         if n["outcome"] == "denied":
[0m[49m[38;5;10m+     397[0m:[38;5;10m[49m             denied_weight += weight
[0m[49m[38;5;10m+     398[0m:[38;5;10m[49m         total_weight += weight
[0m[49m[38;5;10m+     399[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     400[0m:[38;5;10m[49m     knn_denial_prob = denied_weight / total_weight if total_weight > 0 else 0.5
[0m[49m[38;5;10m+     401[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     402[0m:[38;5;10m[49m     # Denial reason distribution among denied neighbors
[0m[49m[38;5;10m+     403[0m:[38;5;10m[49m     denied_neighbors = [n for n in voting_neighbors if n["outcome"] == "denied"]
[0m[49m[38;5;10m+     404[0m:[38;5;10m[49m     reason_counts = {}
[0m[49m[38;5;10m+     405[0m:[38;5;10m[49m     for n in denied_neighbors:
[0m[49m[38;5;10m+     406[0m:[38;5;10m[49m         r = n["denial_reason"]
[0m[49m[38;5;10m+     407[0m:[38;5;10m[49m         if r:
[0m[49m[38;5;10m+     408[0m:[38;5;10m[49m             reason_counts[r] = reason_counts.get(r, 0) + 1
[0m[49m[38;5;10m+     409[0m:[38;5;10m[49m     top_reasons = sorted(reason_counts.items(), key=lambda x: -x[1])[:3]
[0m[49m[38;5;10m+     410[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     411[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     412[0m:[38;5;10m[49m         "knn_denial_probability": knn_denial_prob,
[0m[49m[38;5;10m+     413[0m:[38;5;10m[49m         "novelty_score": novelty_score,
[0m[49m[38;5;10m+     414[0m:[38;5;10m[49m         "nearest_distance": neighbors[0]["distance"] if neighbors else 1.0,
[0m[49m[38;5;10m+     415[0m:[38;5;10m[49m         "top_denial_reasons": [{"reason": r, "count": c} for r, c in top_reasons],
[0m[49m[38;5;10m+     416[0m:[38;5;10m[49m         "supporting_cases": neighbors[:5],
[0m[49m[38;5;10m+     417[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     418[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     419[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     420[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     421[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     422[0m:[38;5;10m[49m ## Step 4: Novelty Detection and Human Review Routing
[0m[49m[38;5;10m+     423[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     424[0m:[38;5;10m[49m *The main recipe's Step 4 describes using distance as a confidence signal. Here we implement the decision logic: claims with high novelty scores (far from any historical precedent) get routed to human review rather than auto-processed. This is the safety net that catches cold-start payers and out-of-distribution procedure combinations.*
[0m[49m[38;5;10m+     425[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     426[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     427[0m:[38;5;10m[49m def route_claim(novelty_result: dict,
[0m[49m[38;5;10m+     428[0m:[38;5;10m[49m                 primary_model_score: float,
[0m[49m[38;5;10m+     429[0m:[38;5;10m[49m                 payer_claim_count: int) -> dict:
[0m[49m[38;5;10m+     430[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     431[0m:[38;5;10m[49m     Hybrid decision engine combining the primary XGBoost score (from Recipe 7.11)
[0m[49m[38;5;10m+     432[0m:[38;5;10m[49m     with the similarity-based novelty signal.
[0m[49m[38;5;10m+     433[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     434[0m:[38;5;10m[49m     Logic:
[0m[49m[38;5;10m+     435[0m:[38;5;10m[49m     - Novel claim (high distance)? Route to human review.
[0m[49m[38;5;10m+     436[0m:[38;5;10m[49m     - Cold-start payer (<50 claims)? Use kNN as predictor, flag for review.
[0m[49m[38;5;10m+     437[0m:[38;5;10m[49m     - Primary model and kNN disagree? Flag the disagreement.
[0m[49m[38;5;10m+     438[0m:[38;5;10m[49m     - Everything agrees? Trust the primary model.
[0m[49m[38;5;10m+     439[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     440[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     441[0m:[38;5;10m[49m         novelty_result: Output from compute_knn_prediction()
[0m[49m[38;5;10m+     442[0m:[38;5;10m[49m         primary_model_score: Denial probability from XGBoost (Recipe 7.11)
[0m[49m[38;5;10m+     443[0m:[38;5;10m[49m         payer_claim_count: Number of historical claims for this payer
[0m[49m[38;5;10m+     444[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     445[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     446[0m:[38;5;10m[49m         Final hybrid decision with confidence, recommendation, and explanation.
[0m[49m[38;5;10m+     447[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     448[0m:[38;5;10m[49m     novelty_score = novelty_result["novelty_score"]
[0m[49m[38;5;10m+     449[0m:[38;5;10m[49m     knn_prob = novelty_result["knn_denial_probability"]
[0m[49m[38;5;10m+     450[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     451[0m:[38;5;10m[49m     if novelty_score > NOVELTY_THRESHOLD:
[0m[49m[38;5;10m+     452[0m:[38;5;10m[49m         # Novel claim: primary model is unreliable for this input
[0m[49m[38;5;10m+     453[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+     454[0m:[38;5;10m[49m             "final_denial_probability": knn_prob,
[0m[49m[38;5;10m+     455[0m:[38;5;10m[49m             "confidence": "low",
[0m[49m[38;5;10m+     456[0m:[38;5;10m[49m             "recommendation": "human_review",
[0m[49m[38;5;10m+     457[0m:[38;5;10m[49m             "explanation": (
[0m[49m[38;5;10m+     458[0m:[38;5;10m[49m                 f"This claim is unlike anything in our history "
[0m[49m[38;5;10m+     459[0m:[38;5;10m[49m                 f"(novelty score: {novelty_score:.3f}). "
[0m[49m[38;5;10m+     460[0m:[38;5;10m[49m                 f"Nearest resolved cases shown for reference."
[0m[49m[38;5;10m+     461[0m:[38;5;10m[49m             ),
[0m[49m[38;5;10m+     462[0m:[38;5;10m[49m             "primary_model_score": primary_model_score,
[0m[49m[38;5;10m+     463[0m:[38;5;10m[49m             "knn_score": knn_prob,
[0m[49m[38;5;10m+     464[0m:[38;5;10m[49m             "novelty_score": novelty_score,
[0m[49m[38;5;10m+     465[0m:[38;5;10m[49m             "supporting_cases": novelty_result["supporting_cases"],
[0m[49m[38;5;10m+     466[0m:[38;5;10m[49m             "top_denial_reasons": novelty_result["top_denial_reasons"],
[0m[49m[38;5;10m+     467[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+     468[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     469[0m:[38;5;10m[49m     elif payer_claim_count < COLD_START_MIN_CLAIMS:
[0m[49m[38;5;10m+     470[0m:[38;5;10m[49m         # Cold start: limited payer-specific data
[0m[49m[38;5;10m+     471[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+     472[0m:[38;5;10m[49m             "final_denial_probability": knn_prob,
[0m[49m[38;5;10m+     473[0m:[38;5;10m[49m             "confidence": "medium",
[0m[49m[38;5;10m+     474[0m:[38;5;10m[49m             "recommendation": "review_suggested",
[0m[49m[38;5;10m+     475[0m:[38;5;10m[49m             "explanation": (
[0m[49m[38;5;10m+     476[0m:[38;5;10m[49m                 f"Limited history for this payer ({payer_claim_count} claims). "
[0m[49m[38;5;10m+     477[0m:[38;5;10m[49m                 f"Prediction based on similar claims from comparable payers."
[0m[49m[38;5;10m+     478[0m:[38;5;10m[49m             ),
[0m[49m[38;5;10m+     479[0m:[38;5;10m[49m             "primary_model_score": primary_model_score,
[0m[49m[38;5;10m+     480[0m:[38;5;10m[49m             "knn_score": knn_prob,
[0m[49m[38;5;10m+     481[0m:[38;5;10m[49m             "novelty_score": novelty_score,
[0m[49m[38;5;10m+     482[0m:[38;5;10m[49m             "supporting_cases": novelty_result["supporting_cases"],
[0m[49m[38;5;10m+     483[0m:[38;5;10m[49m             "top_denial_reasons": novelty_result["top_denial_reasons"],
[0m[49m[38;5;10m+     484[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+     485[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     486[0m:[38;5;10m[49m     elif abs(primary_model_score - knn_prob) > DISAGREEMENT_THRESHOLD:
[0m[49m[38;5;10m+     487[0m:[38;5;10m[49m         # Disagreement between primary model and neighbor evidence
[0m[49m[38;5;10m+     488[0m:[38;5;10m[49m         avg_score = (primary_model_score + knn_prob) / 2.0
[0m[49m[38;5;10m+     489[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+     490[0m:[38;5;10m[49m             "final_denial_probability": avg_score,
[0m[49m[38;5;10m+     491[0m:[38;5;10m[49m             "confidence": "medium",
[0m[49m[38;5;10m+     492[0m:[38;5;10m[49m             "recommendation": "review_suggested",
[0m[49m[38;5;10m+     493[0m:[38;5;10m[49m             "explanation": (
[0m[49m[38;5;10m+     494[0m:[38;5;10m[49m                 f"Model prediction ({primary_model_score:.0%}) and historical "
[0m[49m[38;5;10m+     495[0m:[38;5;10m[49m                 f"precedent ({knn_prob:.0%}) diverge. Averaging as compromise."
[0m[49m[38;5;10m+     496[0m:[38;5;10m[49m             ),
[0m[49m[38;5;10m+     497[0m:[38;5;10m[49m             "primary_model_score": primary_model_score,
[0m[49m[38;5;10m+     498[0m:[38;5;10m[49m             "knn_score": knn_prob,
[0m[49m[38;5;10m+     499[0m:[38;5;10m[49m             "novelty_score": novelty_score,
[0m[49m[38;5;10m+     500[0m:[38;5;10m[49m             "supporting_cases": novelty_result["supporting_cases"],
[0m[49m[38;5;10m+     501[0m:[38;5;10m[49m             "top_denial_reasons": novelty_result["top_denial_reasons"],
[0m[49m[38;5;10m+     502[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+     503[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     504[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+     505[0m:[38;5;10m[49m         # Concordant, well-supported prediction
[0m[49m[38;5;10m+     506[0m:[38;5;10m[49m         action = "auto_flag" if primary_model_score > 0.6 else "pass"
[0m[49m[38;5;10m+     507[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+     508[0m:[38;5;10m[49m             "final_denial_probability": primary_model_score,
[0m[49m[38;5;10m+     509[0m:[38;5;10m[49m             "confidence": "high",
[0m[49m[38;5;10m+     510[0m:[38;5;10m[49m             "recommendation": action,
[0m[49m[38;5;10m+     511[0m:[38;5;10m[49m             "explanation": (
[0m[49m[38;5;10m+     512[0m:[38;5;10m[49m                 f"Prediction well-supported by "
[0m[49m[38;5;10m+     513[0m:[38;5;10m[49m                 f"{len(novelty_result['supporting_cases'])} similar resolved cases."
[0m[49m[38;5;10m+     514[0m:[38;5;10m[49m             ),
[0m[49m[38;5;10m+     515[0m:[38;5;10m[49m             "primary_model_score": primary_model_score,
[0m[49m[38;5;10m+     516[0m:[38;5;10m[49m             "knn_score": knn_prob,
[0m[49m[38;5;10m+     517[0m:[38;5;10m[49m             "novelty_score": novelty_score,
[0m[49m[38;5;10m+     518[0m:[38;5;10m[49m             "supporting_cases": novelty_result["supporting_cases"],
[0m[49m[38;5;10m+     519[0m:[38;5;10m[49m             "top_denial_reasons": novelty_result["top_denial_reasons"],
[0m[49m[38;5;10m+     520[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+     521[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     522[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     523[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     524[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     525[0m:[38;5;10m[49m ## Step 5: Denial Archetype Clustering (k-Means)
[0m[49m[38;5;10m+     526[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     527[0m:[38;5;10m[49m *The main recipe contrasts kNN retrieval (per-claim prediction) with clustering (population segmentation). Here we run k-means on the denied claims to discover denial archetypes: natural groupings that correspond to distinct root causes. This is operationally useful for routing denied claims to specialized rework teams.*
[0m[49m[38;5;10m+     528[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     529[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     530[0m:[38;5;10m[49m from sklearn.cluster import KMeans
[0m[49m[38;5;10m+     531[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     532[0m:[38;5;10m[49m def cluster_denial_archetypes(denied_embeddings: np.ndarray,
[0m[49m[38;5;10m+     533[0m:[38;5;10m[49m                               denied_df: pd.DataFrame,
[0m[49m[38;5;10m+     534[0m:[38;5;10m[49m                               n_clusters: int = N_DENIAL_CLUSTERS) -> dict:
[0m[49m[38;5;10m+     535[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     536[0m:[38;5;10m[49m     Segment denied claims into archetype clusters.
[0m[49m[38;5;10m+     537[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     538[0m:[38;5;10m[49m     Unlike kNN (which answers "what happened to similar claims?"), clustering
[0m[49m[38;5;10m+     539[0m:[38;5;10m[49m     answers "what are the major denial patterns in our data?"
[0m[49m[38;5;10m+     540[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     541[0m:[38;5;10m[49m     Each cluster ideally corresponds to a distinct denial root cause:
[0m[49m[38;5;10m+     542[0m:[38;5;10m[49m     - Cluster 0: Missing prior auth (surgical, specific payers)
[0m[49m[38;5;10m+     543[0m:[38;5;10m[49m     - Cluster 1: Coding/bundling issues (multi-modifier claims)
[0m[49m[38;5;10m+     544[0m:[38;5;10m[49m     - Cluster 2: Medical necessity challenges (imaging, high-cost)
[0m[49m[38;5;10m+     545[0m:[38;5;10m[49m     - etc.
[0m[49m[38;5;10m+     546[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     547[0m:[38;5;10m[49m     Returns cluster labels and a summary of each cluster's characteristics.
[0m[49m[38;5;10m+     548[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     549[0m:[38;5;10m[49m     kmeans = KMeans(n_clusters=n_clusters, random_state=42, n_init=10)
[0m[49m[38;5;10m+     550[0m:[38;5;10m[49m     cluster_labels = kmeans.fit_predict(denied_embeddings)
[0m[49m[38;5;10m+     551[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     552[0m:[38;5;10m[49m     # Analyze each cluster's composition
[0m[49m[38;5;10m+     553[0m:[38;5;10m[49m     denied_with_clusters = denied_df.copy()
[0m[49m[38;5;10m+     554[0m:[38;5;10m[49m     denied_with_clusters["cluster"] = cluster_labels
[0m[49m[38;5;10m+     555[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     556[0m:[38;5;10m[49m     cluster_summary = {}
[0m[49m[38;5;10m+     557[0m:[38;5;10m[49m     for c in range(n_clusters):
[0m[49m[38;5;10m+     558[0m:[38;5;10m[49m         cluster_mask = denied_with_clusters["cluster"] == c
[0m[49m[38;5;10m+     559[0m:[38;5;10m[49m         cluster_data = denied_with_clusters[cluster_mask]
[0m[49m[38;5;10m+     560[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     561[0m:[38;5;10m[49m         # Top denial reasons in this cluster
[0m[49m[38;5;10m+     562[0m:[38;5;10m[49m         reason_dist = cluster_data["denial_reason"].value_counts().head(3)
[0m[49m[38;5;10m+     563[0m:[38;5;10m[49m         # Top payers
[0m[49m[38;5;10m+     564[0m:[38;5;10m[49m         payer_dist = cluster_data["payer"].value_counts().head(3)
[0m[49m[38;5;10m+     565[0m:[38;5;10m[49m         # Top CPT codes
[0m[49m[38;5;10m+     566[0m:[38;5;10m[49m         cpt_dist = cluster_data["cpt_code"].value_counts().head(3)
[0m[49m[38;5;10m+     567[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     568[0m:[38;5;10m[49m         cluster_summary[c] = {
[0m[49m[38;5;10m+     569[0m:[38;5;10m[49m             "size": int(cluster_mask.sum()),
[0m[49m[38;5;10m+     570[0m:[38;5;10m[49m             "pct_of_denials": float(cluster_mask.sum() / len(denied_with_clusters) * 100),
[0m[49m[38;5;10m+     571[0m:[38;5;10m[49m             "top_reasons": reason_dist.to_dict(),
[0m[49m[38;5;10m+     572[0m:[38;5;10m[49m             "top_payers": payer_dist.to_dict(),
[0m[49m[38;5;10m+     573[0m:[38;5;10m[49m             "top_cpt_codes": cpt_dist.to_dict(),
[0m[49m[38;5;10m+     574[0m:[38;5;10m[49m             "avg_amount": float(cluster_data["claim_amount"].mean()),
[0m[49m[38;5;10m+     575[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+     576[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     577[0m:[38;5;10m[49m     logger.info("Clustered %d denied claims into %d archetypes",
[0m[49m[38;5;10m+     578[0m:[38;5;10m[49m                 len(denied_embeddings), n_clusters)
[0m[49m[38;5;10m+     579[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     580[0m:[38;5;10m[49m         "labels": cluster_labels,
[0m[49m[38;5;10m+     581[0m:[38;5;10m[49m         "centroids": kmeans.cluster_centers_,
[0m[49m[38;5;10m+     582[0m:[38;5;10m[49m         "summary": cluster_summary,
[0m[49m[38;5;10m+     583[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     584[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     585[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     586[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     587[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     588[0m:[38;5;10m[49m ## Step 6: AWS Implementation with OpenSearch k-NN (boto3)
[0m[49m[38;5;10m+     589[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     590[0m:[38;5;10m[49m *The main recipe uses Amazon OpenSearch Service with the k-NN plugin for production vector search. Here we show the boto3 calls to create a k-NN index, bulk-index claim embeddings, and query for nearest neighbors. In production, this replaces the sklearn NearestNeighbors from Step 3 with a managed, scalable vector store.*
[0m[49m[38;5;10m+     591[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     592[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     593[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+     594[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+     595[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+     596[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     597[0m:[38;5;10m[49m # Retry config for OpenSearch API calls. Adaptive mode handles throttling
[0m[49m[38;5;10m+     598[0m:[38;5;10m[49m # with exponential backoff and jitter.
[0m[49m[38;5;10m+     599[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+     600[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     601[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     602[0m:[38;5;10m[49m def get_opensearch_client():
[0m[49m[38;5;10m+     603[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     604[0m:[38;5;10m[49m     Create a boto3 client for OpenSearch HTTP operations.
[0m[49m[38;5;10m+     605[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     606[0m:[38;5;10m[49m     In production, you'd sign requests using SigV4 (AWS request signing)
[0m[49m[38;5;10m+     607[0m:[38;5;10m[49m     rather than using the basic REST client. The opensearchpy library with
[0m[49m[38;5;10m+     608[0m:[38;5;10m[49m     AWSV4SignerAuth is the standard approach. Here we show the raw HTTP
[0m[49m[38;5;10m+     609[0m:[38;5;10m[49m     structure so you understand what's happening at the API level.
[0m[49m[38;5;10m+     610[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     611[0m:[38;5;10m[49m     # For production, use the opensearch-py library with IAM auth:
[0m[49m[38;5;10m+     612[0m:[38;5;10m[49m     #   from opensearchpy import OpenSearch, RequestsHttpConnection
[0m[49m[38;5;10m+     613[0m:[38;5;10m[49m     #   from requests_aws4auth import AWS4Auth
[0m[49m[38;5;10m+     614[0m:[38;5;10m[49m     #
[0m[49m[38;5;10m+     615[0m:[38;5;10m[49m     #   credentials = boto3.Session().get_credentials()
[0m[49m[38;5;10m+     616[0m:[38;5;10m[49m     #   auth = AWS4Auth(credentials.access_key, credentials.secret_key,
[0m[49m[38;5;10m+     617[0m:[38;5;10m[49m     #                   region, 'es', session_token=credentials.token)
[0m[49m[38;5;10m+     618[0m:[38;5;10m[49m     #   client = OpenSearch(hosts=[{'host': endpoint, 'port': 443}],
[0m[49m[38;5;10m+     619[0m:[38;5;10m[49m     #                       http_auth=auth, use_ssl=True,
[0m[49m[38;5;10m+     620[0m:[38;5;10m[49m     #                       connection_class=RequestsHttpConnection)
[0m[49m[38;5;10m+     621[0m:[38;5;10m[49m     #
[0m[49m[38;5;10m+     622[0m:[38;5;10m[49m     # For this example, we show the index/query JSON structures.
[0m[49m[38;5;10m+     623[0m:[38;5;10m[49m     session = boto3.Session()
[0m[49m[38;5;10m+     624[0m:[38;5;10m[49m     return session.client("opensearch", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     625[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     626[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     627[0m:[38;5;10m[49m def create_knn_index_mapping() -> dict:
[0m[49m[38;5;10m+     628[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     629[0m:[38;5;10m[49m     Returns the OpenSearch index mapping for a k-NN vector index.
[0m[49m[38;5;10m+     630[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     631[0m:[38;5;10m[49m     Key decisions:
[0m[49m[38;5;10m+     632[0m:[38;5;10m[49m     - HNSW algorithm: best latency for sub-100ms queries at scale
[0m[49m[38;5;10m+     633[0m:[38;5;10m[49m     - cosinesimil space: matches our embedding design (direction > magnitude)
[0m[49m[38;5;10m+     634[0m:[38;5;10m[49m     - ef_construction=256: higher = better recall during indexing, slower builds
[0m[49m[38;5;10m+     635[0m:[38;5;10m[49m     - m=16: connections per node in the HNSW graph (16 is a good default)
[0m[49m[38;5;10m+     636[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     637[0m:[38;5;10m[49m     The mapping also includes keyword fields for claim metadata so we can
[0m[49m[38;5;10m+     638[0m:[38;5;10m[49m     return full case details without a separate lookup.
[0m[49m[38;5;10m+     639[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     640[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     641[0m:[38;5;10m[49m         "settings": {
[0m[49m[38;5;10m+     642[0m:[38;5;10m[49m             "index": {
[0m[49m[38;5;10m+     643[0m:[38;5;10m[49m                 "knn": True,
[0m[49m[38;5;10m+     644[0m:[38;5;10m[49m                 "knn.algo_param.ef_search": 100,  # query-time recall parameter
[0m[49m[38;5;10m+     645[0m:[38;5;10m[49m                 "number_of_shards": 2,
[0m[49m[38;5;10m+     646[0m:[38;5;10m[49m                 "number_of_replicas": 1,
[0m[49m[38;5;10m+     647[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+     648[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+     649[0m:[38;5;10m[49m         "mappings": {
[0m[49m[38;5;10m+     650[0m:[38;5;10m[49m             "properties": {
[0m[49m[38;5;10m+     651[0m:[38;5;10m[49m                 "claim_embedding": {
[0m[49m[38;5;10m+     652[0m:[38;5;10m[49m                     "type": "knn_vector",
[0m[49m[38;5;10m+     653[0m:[38;5;10m[49m                     "dimension": EMBEDDING_DIM,
[0m[49m[38;5;10m+     654[0m:[38;5;10m[49m                     "method": {
[0m[49m[38;5;10m+     655[0m:[38;5;10m[49m                         "name": "hnsw",
[0m[49m[38;5;10m+     656[0m:[38;5;10m[49m                         "space_type": "cosinesimil",
[0m[49m[38;5;10m+     657[0m:[38;5;10m[49m                         "engine": "nmslib",
[0m[49m[38;5;10m+     658[0m:[38;5;10m[49m                         "parameters": {
[0m[49m[38;5;10m+     659[0m:[38;5;10m[49m                             "ef_construction": 256,
[0m[49m[38;5;10m+     660[0m:[38;5;10m[49m                             "m": 16
[0m[49m[38;5;10m+     661[0m:[38;5;10m[49m                         }
[0m[49m[38;5;10m+     662[0m:[38;5;10m[49m                     }
[0m[49m[38;5;10m+     663[0m:[38;5;10m[49m                 },
[0m[49m[38;5;10m+     664[0m:[38;5;10m[49m                 "claim_id": {"type": "keyword"},
[0m[49m[38;5;10m+     665[0m:[38;5;10m[49m                 "payer": {"type": "keyword"},
[0m[49m[38;5;10m+     666[0m:[38;5;10m[49m                 "cpt_code": {"type": "keyword"},
[0m[49m[38;5;10m+     667[0m:[38;5;10m[49m                 "outcome": {"type": "keyword"},
[0m[49m[38;5;10m+     668[0m:[38;5;10m[49m                 "denial_reason": {"type": "keyword"},
[0m[49m[38;5;10m+     669[0m:[38;5;10m[49m                 "claim_amount": {"type": "float"},
[0m[49m[38;5;10m+     670[0m:[38;5;10m[49m                 "place_of_service": {"type": "keyword"},
[0m[49m[38;5;10m+     671[0m:[38;5;10m[49m                 "provider_type": {"type": "keyword"},
[0m[49m[38;5;10m+     672[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+     673[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+     674[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     675[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     676[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     677[0m:[38;5;10m[49m def bulk_index_embeddings(embeddings: np.ndarray,
