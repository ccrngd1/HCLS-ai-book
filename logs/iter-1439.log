[0m[49m[38;5;10m+      41[0m:[38;5;10m[49m # where prediction accuracy drops below acceptable levels.
[0m[49m[38;5;10m+      42[0m:[38;5;10m[49m NOVELTY_THRESHOLD = 0.4          # Mean distance to top-5 neighbors above this = novel
[0m[49m[38;5;10m+      43[0m:[38;5;10m[49m DISAGREEMENT_THRESHOLD = 0.25    # |primary_score - knn_score| above this = conflicting
[0m[49m[38;5;10m+      44[0m:[38;5;10m[49m COLD_START_MIN_CLAIMS = 50       # Minimum payer history to trust primary model
[0m[49m[38;5;10m+      45[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      46[0m:[38;5;10m[49m # --- kNN retrieval parameters ---
