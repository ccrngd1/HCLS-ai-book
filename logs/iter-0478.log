[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m written = 0
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m with table.batch_writer() as bw:
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m     for rec in forecast_records:
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m         item = { ... }
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m         bw.put_item(Item=item)
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m         written += 1
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m ```
