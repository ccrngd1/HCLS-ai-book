[0m[49m[39m  478, 489[0m:[39m[49m     "hospital_id": "HOSP-GWU",
[0m[49m[39m  479, 490[0m:[39m[49m     "name": "GW University Hospital",
[0m[49m[39m  480, 491[0m:[39m[49m     "capabilities": ["cath_lab", "interventional_cardiology", "level_1_trauma"],
[0m[49m[39m  481, 492[0m:[39m[49m     "estimated_transport_minutes": 8,
