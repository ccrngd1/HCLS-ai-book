[0m[49m[39m  466, 477[0m:[39m[49m   "call_id": "CAD-2026-0601-1847",
[0m[49m[39m  467, 478[0m:[39m[49m   "call_priority": 1,
[0m[49m[39m  468, 479[0m:[39m[49m   "call_location": {"lat": 38.9072, "lng": -77.0369},
[0m[49m[39m  469, 480[0m:[39m[49m   "nature_code": "CHEST_PAIN",
[0m[49m[39m  470, 481[0m:[39m[49m   "assigned_unit": {
