[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m SAMPLE_TRIAL_CRITERIA = {
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m     "trial_id": "NCT05891234",
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m     "trial_name": "GLP-1 Combination Therapy for T2DM",
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m     "criteria": [
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m         {
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m             "criterion_id": "crit-001",
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m             "criterion_type": "INCLUSION",
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m             "raw_text": "Adults aged 30-65",
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m             "data_source": "STRUCTURED",
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m             "logic": {"field": "age", "operator": "BETWEEN", "value_low": 30, "value_high": 65},
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m         },
