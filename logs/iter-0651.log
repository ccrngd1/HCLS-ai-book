[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m ## Step 1: Structured Pre-Screen
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m *The main recipe's pseudocode calls this `structured_prescreen()`. It evaluates all criteria that can be resolved from structured data alone (demographics, labs, medications, diagnosis codes). This eliminates the majority of the population quickly and cheaply.*
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m In production, this would be an Athena SQL query against your patient data lake. Here we implement the logic in Python against our synthetic data to show the evaluation mechanics.
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m def evaluate_structured_criterion(patient: dict, criterion: dict, reference_date: datetime) -> dict:
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m     Evaluate a single structured criterion against a patient record.
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m     Returns a dict with:
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m         status: "PASS", "FAIL", or "UNCERTAIN"
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m         confidence: 0.0-1.0 (structured criteria are typically 1.0 or 0.0)
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m         evidence: human-readable explanation of the determination
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m     logic = criterion["logic"]
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m     # Handle criteria that have both structured and NLP components.
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m     # For the structured evaluation, use the "structured" sub-logic.
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m     if "structured" in logic:
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m         logic = logic["structured"]
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m     field = logic["field"]
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m     operator = logic["operator"]
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m     # Age check
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m     if field == "age":
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m         age = patient.get("age")
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m         if age is None:
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m             return {"status": "UNCERTAIN", "confidence": 0.0, "evidence": "Age not available"}
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m         if operator == "BETWEEN":
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m             passed = logic["value_low"] <= age <= logic["value_high"]
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m             return {
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m                 "status": "PASS" if passed else "FAIL",
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m                 "confidence": 1.0,
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m                 "evidence": f"Age: {age} (required: {logic['value_low']}-{logic['value_high']})",
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m     # Diagnosis code prefix check
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m     if field == "diagnosis_codes":
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m         codes = patient.get("diagnosis_codes", [])
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m         prefix = logic["value"]
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m         has_match = any(code.startswith(prefix) for code in codes)
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m         if operator == "HAS_PREFIX":
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m             # For INCLUSION: having the code is a PASS
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m             # For EXCLUSION: having the code is a FAIL (handled by caller)
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m             return {
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m                 "status": "PASS" if has_match else "FAIL",
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m                 "confidence": 1.0,
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m                 "evidence": f"Codes matching '{prefix}*': {[c for c in codes if c.startswith(prefix)]}",
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m     # Lab value checks (with recency)
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m     if field.startswith("lab_"):
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m         lab_key = field  # e.g., "lab_a1c" or "lab_egfr"
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m         lab_data = patient.get(lab_key)
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m         if lab_data is None:
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m             return {"status": "UNCERTAIN", "confidence": 0.0, "evidence": f"No {lab_key} on record"}
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m         lab_value = lab_data["value"]
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m         lab_date = datetime.strptime(lab_data["date"], "%Y-%m-%d").replace(tzinfo=timezone.utc)
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m         # Check recency if specified
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m         recency_days = logic.get("recency_days")
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m         if recency_days:
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m             cutoff = reference_date - timedelta(days=recency_days)
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m             if lab_date < cutoff:
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m                 return {
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m                     "status": "UNCERTAIN",
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m                     "confidence": 0.3,
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m                     "evidence": f"{lab_key} value {lab_value} is from {lab_data['date']} (older than {recency_days} days)",
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m                 }
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m         # Evaluate the value against the operator
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m         if operator == "BETWEEN":
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m             passed = logic["value_low"] <= lab_value <= logic["value_high"]
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m         elif operator == "GTE":
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m             passed = lab_value >= logic["value"]
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m         elif operator == "GT":
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m             passed = lab_value > logic["value"]
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m             passed = False
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m             "status": "PASS" if passed else "FAIL",
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m             "confidence": 1.0,
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m             "evidence": f"{lab_key}: {lab_value} (from {lab_data['date']})",
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m     # BMI check
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m     if field == "bmi":
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m         bmi = patient.get("bmi")
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m         if bmi is None:
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m             return {"status": "UNCERTAIN", "confidence": 0.0, "evidence": "BMI not available"}
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m         if operator == "GT":
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m             passed = bmi > logic["value"]
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m             return {
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m                 "status": "PASS" if passed else "FAIL",
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m                 "confidence": 1.0,
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m                 "evidence": f"BMI: {bmi} (required: >{logic['value']})",
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m     # Medication check (with duration)
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m     if field == "active_medications":
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m         meds = patient.get("active_medications", [])
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m         target_med = logic["value"].lower()
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m         duration_days = logic.get("duration_days", 0)
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m         matching_med = None
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m         for med in meds:
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m             if target_med in med["name"].lower():
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m                 matching_med = med
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m                 break
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m         if matching_med is None:
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m             return {
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m                 "status": "FAIL",
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m                 "confidence": 1.0,
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m                 "evidence": f"'{target_med}' not found in active medications",
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m         # Check duration
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m         if duration_days > 0:
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m             start = datetime.strptime(matching_med["start_date"], "%Y-%m-%d").replace(tzinfo=timezone.utc)
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m             days_on_med = (reference_date - start).days
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m             if days_on_med < duration_days:
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m                 return {
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m                     "status": "FAIL",
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m                     "confidence": 0.9,
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m                     "evidence": f"On {target_med} for {days_on_med} days (required: {duration_days}+)",
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m                 }
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m             "status": "PASS",
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m             "confidence": 1.0,
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m             "evidence": f"On {target_med} since {matching_med['start_date']}",
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m     # Fallback for unrecognized fields
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m     return {"status": "UNCERTAIN", "confidence": 0.0, "evidence": f"Cannot evaluate field '{field}'"}
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m def structured_prescreen(patients: list, criteria: list, reference_date: datetime) -> list:
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m     Apply all structured criteria to the patient population.
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m     Returns candidates who pass all structured inclusion criteria
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m     and don't definitively fail any structured exclusion criteria.
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m     structured_criteria = [
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m         c for c in criteria if c["data_source"] in ("STRUCTURED", "BOTH")
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m     candidates = []
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m     for patient in patients:
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m         results = {}
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m         disqualified = False
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m         for criterion in structured_criteria:
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m             result = evaluate_structured_criterion(patient, criterion, reference_date)
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m             results[criterion["criterion_id"]] = result
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m             # Apply inclusion/exclusion logic
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m             if criterion["criterion_type"] == "INCLUSION" and result["status"] == "FAIL":
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m                 disqualified = True
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m                 break
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m             if criterion["criterion_type"] == "EXCLUSION" and result["status"] == "PASS":
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m                 # For exclusion criteria, a PASS on the condition means the patient IS excluded
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m                 disqualified = True
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m                 break
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m         if not disqualified:
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m             candidates.append({
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m                 "patient_id": patient["patient_id"],
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m                 "structured_results": results,
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m                 "patient_data": patient,
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m     return candidates
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m ## Step 2: NLP Deep Screen with Comprehend Medical
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m *The main recipe's pseudocode calls this `nlp_deep_screen()`. For candidates that passed structured pre-screening, we run NLP on their clinical notes to evaluate criteria that require unstructured data (like "no history of pancreatitis" documented only in notes).*
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m In production, you'd call Amazon Comprehend Medical's `DetectEntitiesV2` API. Here we show the real boto3 call structure and how to interpret the response, including negation detection.
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m def call_comprehend_medical(text: str) -> list:
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m     Call Amazon Comprehend Medical to extract medical entities from clinical text.
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m     Comprehend Medical returns entities with:
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m     - Text: the extracted term
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m     - Category: MEDICAL_CONDITION, MEDICATION, TEST_TREATMENT_PROCEDURE, etc.
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m     - Type: more specific (DX_NAME, GENERIC_NAME, PROCEDURE_NAME, etc.)
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m     - Traits: includes NEGATION, SIGN, SYMPTOM, DIAGNOSIS
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m     - Score: confidence (0.0-1.0)
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m     The NEGATION trait is critical for trial matching. "No history of pancreatitis"
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m     should return an entity for "pancreatitis" WITH the NEGATION trait, meaning
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m     the patient does NOT have this condition.
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m     # Comprehend Medical has a 20,000 character limit per request.
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m     # For longer notes, you'd chunk the text. For this example, we assume
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m     # notes fit within the limit.
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m     if len(text) > 20000:
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m         text = text[:20000]
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m         logger.warning("Note truncated to 20,000 chars for Comprehend Medical")
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m     response = comprehend_medical.detect_entities_v2(Text=text)
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m     entities = []
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m     for entity in response.get("Entities", []):
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m         # Check if this entity has a NEGATION trait
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m         is_negated = any(
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m             trait["Name"] == "NEGATION" and trait["Score"] > 0.7
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m             for trait in entity.get("Traits", [])
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m         entities.append({
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m             "text": entity["Text"],
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m             "category": entity["Category"],
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m             "type": entity.get("Type", ""),
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m             "score": entity["Score"],
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m             "is_negated": is_negated,
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m             "begin_offset": entity["BeginOffset"],
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m             "end_offset": entity["EndOffset"],
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m     return entities
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m def evaluate_nlp_criterion(criterion: dict, notes: list) -> dict:
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m     Evaluate a single NLP-based criterion against a patient's clinical notes.
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m     For exclusion criteria like "no history of pancreatitis":
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m     - If we find "pancreatitis" WITHOUT negation: patient HAS the condition (FAIL for exclusion)
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m     - If we find "pancreatitis" WITH negation: patient explicitly DOESN'T have it (PASS)
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m     - If we find no mention at all: uncertain (absence of evidence != evidence of absence)
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m     logic = criterion["logic"]
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m     # For criteria with both structured and NLP components, use the NLP sub-logic
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m     nlp_logic = logic.get("nlp", logic)
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m     search_terms = nlp_logic.get("search_terms", [])
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m     all_entities = []
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m     for note_text in notes:
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m         entities = call_comprehend_medical(note_text)
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m         all_entities.extend(entities)
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m     # Look for entities matching our search terms
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m     matching_entities = []
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m     for entity in all_entities:
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m         entity_text_lower = entity["text"].lower()
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m         for term in search_terms:
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m             if term.lower() in entity_text_lower:
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m                 matching_entities.append(entity)
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m                 break
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m     if not matching_entities:
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m         # No mention found. This is UNCERTAIN, not a definitive pass.
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m         # The condition might exist but not be documented in available notes.
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m             "status": "UNCERTAIN",
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m             "confidence": 0.5,
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m             "evidence": f"No mentions of {search_terms} found in {len(notes)} notes",
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m     # Check negation status of matches
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m     affirmed = [e for e in matching_entities if not e["is_negated"]]
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m     negated = [e for e in matching_entities if e["is_negated"]]
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m     if affirmed:
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m         # Found a non-negated mention. Patient likely HAS this condition.
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m         best_match = max(affirmed, key=lambda e: e["score"])
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m             "status": "PASS",  # The condition IS present
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m             "confidence": best_match["score"],
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m             "evidence": f"Found '{best_match['text']}' (confidence: {best_match['score']:.2f}, not negated)",
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m     if negated:
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m         # Only negated mentions found. Patient explicitly DOESN'T have this.
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m         best_match = max(negated, key=lambda e: e["score"])
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m             "status": "FAIL",  # The condition is NOT present (negated)
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m             "confidence": best_match["score"] * 0.9,  # Slight discount for negation complexity
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m             "evidence": f"Found negated '{best_match['text']}' (confidence: {best_match['score']:.2f})",
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m     return {"status": "UNCERTAIN", "confidence": 0.4, "evidence": "Ambiguous NLP results"}
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m def nlp_deep_screen(candidates: list, criteria: list) -> list:
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m     Run NLP-based screening on candidates that passed structured pre-screen.
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m     Evaluates criteria that require clinical note analysis.
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m     nlp_criteria = [
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m         c for c in criteria if c["data_source"] in ("UNSTRUCTURED", "BOTH")
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m     if not nlp_criteria:
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m         return candidates  # No NLP criteria to evaluate
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m     screened = []
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m     for candidate in candidates:
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m         notes = candidate["patient_data"].get("clinical_notes", [])
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m         nlp_results = {}
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m         disqualified = False
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m         for criterion in nlp_criteria:
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m             result = evaluate_nlp_criterion(criterion, notes)
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m             nlp_results[criterion["criterion_id"]] = result
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m             # For EXCLUSION criteria:
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m             # - NLP status "PASS" means the condition IS present -> patient is excluded
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m             # - NLP status "FAIL" means the condition is NOT present (negated) -> patient passes
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m             if criterion["criterion_type"] == "EXCLUSION":
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m                 if result["status"] == "PASS" and result["confidence"] > NLP_CONFIDENCE_THRESHOLD:
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m                     disqualified = True
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m                     break
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m         if not disqualified:
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m             candidate["nlp_results"] = nlp_results
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m             screened.append(candidate)
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m     return screened
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m ## Step 3: Score and Rank Candidates
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m *The main recipe's pseudocode calls this `score_candidates()`. Each candidate gets a composite eligibility score based on how confidently they meet each criterion. Higher scores surface first in the coordinator worklist.*
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m def score_candidates(candidates: list, criteria: list) -> list:
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m     Assign each candidate a composite eligibility score.
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m     The score reflects:
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m     - How many criteria the patient definitively passes
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m     - The confidence level of each determination
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m     - Whether uncertain criteria exist (which need coordinator review)
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m     Scores range from 0.0 to 1.0. A score of 1.0 means every criterion
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m     was evaluated with high confidence and passed.
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m     scored = []
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m     for candidate in candidates:
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m         total_score = 0.0
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m         max_possible = 0.0
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m         details = []
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m         # Combine structured and NLP results
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m         all_results = {}
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m         all_results.update(candidate.get("structured_results", {}))
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m         all_results.update(candidate.get("nlp_results", {}))
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m         for criterion in criteria:
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m             cid = criterion["criterion_id"]
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m             weight = SCORING_WEIGHTS.get(criterion["data_source"], 0.8)
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m             max_possible += weight
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m             result = all_results.get(cid)
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m             if result is None:
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m                 # Criterion wasn't evaluated (maybe it's NLP-only and patient
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m                 # was already disqualified). Treat as uncertain.
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m                 criterion_score = 0.0
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m                 status = "NOT_EVALUATED"
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m                 confidence = 0.0
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m                 evidence = "Not evaluated"
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m             else:
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m                 status = result["status"]
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m                 confidence = result["confidence"]
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m                 evidence = result["evidence"]
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m                 if criterion["criterion_type"] == "INCLUSION":
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m                     if status == "PASS":
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m                         criterion_score = weight * confidence
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m                     elif status == "UNCERTAIN":
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m                         criterion_score = weight * 0.5 * confidence
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m                     else:
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m                         criterion_score = 0.0
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m                 else:  # EXCLUSION
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m                     # For exclusion: FAIL means condition NOT present (good)
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m                     # PASS means condition IS present (bad, should have been filtered)
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m                     if status == "FAIL":
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m                         criterion_score = weight * confidence
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m                     elif status == "UNCERTAIN":
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m                         criterion_score = weight * 0.5
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m                     else:
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m                         criterion_score = 0.0
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m             total_score += criterion_score
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m             details.append({
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m                 "criterion_id": cid,
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m                 "raw_text": criterion["raw_text"],
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m                 "status": status,
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m                 "confidence": confidence,
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m                 "evidence": evidence,
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m         eligibility_score = total_score / max_possible if max_possible > 0 else 0.0
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m         uncertain_count = sum(1 for d in details if d["status"] == "UNCERTAIN")
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m         scored.append({
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m             "patient_id": candidate["patient_id"],
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m             "eligibility_score": round(eligibility_score, 3),
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m             "uncertain_count": uncertain_count,
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m             "criterion_details": details,
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m     # Sort by score descending
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m     scored.sort(key=lambda x: x["eligibility_score"], reverse=True)
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m     return scored
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m ## Step 4: Store Results in DynamoDB
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m *The main recipe's pseudocode stores scored candidates in DynamoDB for coordinator access. Each record includes the trial ID, patient ID, score, and per-criterion evidence.*
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m def store_candidates(trial_id: str, scored_candidates: list) -> int:
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m     Write scored candidates to DynamoDB for the coordinator worklist.
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m     Each item uses trial_id as partition key and patient_id as sort key,
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m     allowing efficient queries for "all candidates for trial X, sorted by score."
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m     Returns the number of candidates stored.
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m     table = dynamodb.Table(CANDIDATES_TABLE)
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m     stored_count = 0
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m     for candidate in scored_candidates:
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m         item = {
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m             "trial_id": trial_id,
[0m[49m[38;5;10m+    717[0m:[38;5;10m[49m             "patient_id": candidate["patient_id"],
[0m[49m[38;5;10m+    718[0m:[38;5;10m[49m             "eligibility_score": Decimal(str(candidate["eligibility_score"])),
[0m[49m[38;5;10m+    719[0m:[38;5;10m[49m             "uncertain_count": candidate["uncertain_count"],
[0m[49m[38;5;10m+    720[0m:[38;5;10m[49m             "status": "PENDING_REVIEW",
[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m             "scored_at": datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m             # Store criterion details as a JSON string to avoid DynamoDB's
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m             # nested attribute limitations for complex queries.
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m             "criterion_details_json": json.dumps(candidate["criterion_details"]),
[0m[49m[38;5;10m+    725[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    726[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    727[0m:[38;5;10m[49m         table.put_item(Item=item)
[0m[49m[38;5;10m+    728[0m:[38;5;10m[49m         stored_count += 1
[0m[49m[38;5;10m+    729[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    730[0m:[38;5;10m[49m     return stored_count
[0m[49m[38;5;10m+    731[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    732[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    733[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    734[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    735[0m:[38;5;10m[49m ## Putting It All Together
[0m[49m[38;5;10m+    736[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    737[0m:[38;5;10m[49m Here's the full pipeline assembled into a single function. This is what your Step Functions workflow would invoke (broken into Lambda functions per stage in production).
[0m[49m[38;5;10m+    738[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    739[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    740[0m:[38;5;10m[49m def run_trial_matching_pipeline(trial_criteria: dict, patients: list) -> list:
[0m[49m[38;5;10m+    741[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    742[0m:[38;5;10m[49m     Run the complete clinical trial patient matching pipeline.
[0m[49m[38;5;10m+    743[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    744[0m:[38;5;10m[49m     Stages:
[0m[49m[38;5;10m+    745[0m:[38;5;10m[49m     1. Structured pre-screen (fast, cheap, eliminates most patients)
[0m[49m[38;5;10m+    746[0m:[38;5;10m[49m     2. NLP deep screen (slower, more expensive, catches note-based exclusions)
[0m[49m[38;5;10m+    747[0m:[38;5;10m[49m     3. Score and rank (prioritize coordinator review)
[0m[49m[38;5;10m+    748[0m:[38;5;10m[49m     4. Store results (make available to coordinator worklist)
[0m[49m[38;5;10m+    749[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    750[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    751[0m:[38;5;10m[49m         trial_criteria: Parsed trial criteria (see SAMPLE_TRIAL_CRITERIA)
[0m[49m[38;5;10m+    752[0m:[38;5;10m[49m         patients: List of patient records to screen
[0m[49m[38;5;10m+    753[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    754[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    755[0m:[38;5;10m[49m         Scored and ranked candidate list
[0m[49m[38;5;10m+    756[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    757[0m:[38;5;10m[49m     trial_id = trial_criteria["trial_id"]
[0m[49m[38;5;10m+    758[0m:[38;5;10m[49m     criteria = trial_criteria["criteria"]
[0m[49m[38;5;10m+    759[0m:[38;5;10m[49m     reference_date = datetime.now(timezone.utc)
[0m[49m[38;5;10m+    760[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    761[0m:[38;5;10m[49m     logger.info("=== Clinical Trial Matching Pipeline ===")
[0m[49m[38;5;10m+    762[0m:[38;5;10m[49m     logger.info("Trial: %s (%s)", trial_id, trial_criteria["trial_name"])
[0m[49m[38;5;10m+    763[0m:[38;5;10m[49m     logger.info("Screening %d patients", len(patients))
[0m[49m[38;5;10m+    764[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    765[0m:[38;5;10m[49m     # Stage 1: Structured pre-screen
[0m[49m[38;5;10m+    766[0m:[38;5;10m[49m     logger.info("--- Stage 1: Structured Pre-Screen ---")
[0m[49m[38;5;10m+    767[0m:[38;5;10m[49m     candidates = structured_prescreen(patients, criteria, reference_date)
[0m[49m[38;5;10m+    768[0m:[38;5;10m[49m     logger.info("  %d/%d patients passed structured pre-screen", len(candidates), len(patients))
[0m[49m[38;5;10m+    769[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    770[0m:[38;5;10m[49m     if not candidates:
[0m[49m[38;5;10m+    771[0m:[38;5;10m[49m         logger.info("No candidates passed structured pre-screen. Pipeline complete.")
[0m[49m[38;5;10m+    772[0m:[38;5;10m[49m         return []
[0m[49m[38;5;10m+    773[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    774[0m:[38;5;10m[49m     # Stage 2: NLP deep screen
[0m[49m[38;5;10m+    775[0m:[38;5;10m[49m     logger.info("--- Stage 2: NLP Deep Screen ---")
[0m[49m[38;5;10m+    776[0m:[38;5;10m[49m     logger.info("  Running Comprehend Medical on %d candidates", len(candidates))
[0m[49m[38;5;10m+    777[0m:[38;5;10m[49m     screened = nlp_deep_screen(candidates, criteria)
[0m[49m[38;5;10m+    778[0m:[38;5;10m[49m     logger.info("  %d/%d candidates passed NLP deep screen", len(screened), len(candidates))
[0m[49m[38;5;10m+    779[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    780[0m:[38;5;10m[49m     if not screened:
[0m[49m[38;5;10m+    781[0m:[38;5;10m[49m         logger.info("No candidates passed NLP deep screen. Pipeline complete.")
[0m[49m[38;5;10m+    782[0m:[38;5;10m[49m         return []
[0m[49m[38;5;10m+    783[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    784[0m:[38;5;10m[49m     # Stage 3: Score and rank
[0m[49m[38;5;10m+    785[0m:[38;5;10m[49m     logger.info("--- Stage 3: Scoring ---")
[0m[49m[38;5;10m+    786[0m:[38;5;10m[49m     scored = score_candidates(screened, criteria)
[0m[49m[38;5;10m+    787[0m:[38;5;10m[49m     for candidate in scored:
[0m[49m[38;5;10m+    788[0m:[38;5;10m[49m         logger.info(
[0m[49m[38;5;10m+    789[0m:[38;5;10m[49m             "  %s: score=%.3f, uncertain=%d",
[0m[49m[38;5;10m+    790[0m:[38;5;10m[49m             candidate["patient_id"],
[0m[49m[38;5;10m+    791[0m:[38;5;10m[49m             candidate["eligibility_score"],
[0m[49m[38;5;10m+    792[0m:[38;5;10m[49m             candidate["uncertain_count"],
[0m[49m[38;5;10m+    793[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    794[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    795[0m:[38;5;10m[49m     # Stage 4: Store results
[0m[49m[38;5;10m+    796[0m:[38;5;10m[49m     logger.info("--- Stage 4: Storing Results ---")
[0m[49m[38;5;10m+    797[0m:[38;5;10m[49m     count = store_candidates(trial_id, scored)
[0m[49m[38;5;10m+    798[0m:[38;5;10m[49m     logger.info("  Stored %d candidates in DynamoDB", count)
[0m[49m[38;5;10m+    799[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    800[0m:[38;5;10m[49m     logger.info("=== Pipeline Complete ===")
[0m[49m[38;5;10m+    801[0m:[38;5;10m[49m     return scored
[0m[49m[38;5;10m+    802[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    803[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    804[0m:[38;5;10m[49m # Run the pipeline against synthetic data
[0m[49m[38;5;10m+    805[0m:[38;5;10m[49m if __name__ == "__main__":
[0m[49m[38;5;10m+    806[0m:[38;5;10m[49m     results = run_trial_matching_pipeline(SAMPLE_TRIAL_CRITERIA, SYNTHETIC_PATIENTS)
[0m[49m[38;5;10m+    807[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    808[0m:[38;5;10m[49m     print("\n" + "=" * 60)
[0m[49m[38;5;10m+    809[0m:[38;5;10m[49m     print("TRIAL MATCHING RESULTS")
[0m[49m[38;5;10m+    810[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    811[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    812[0m:[38;5;10m[49m     if not results:
[0m[49m[38;5;10m+    813[0m:[38;5;10m[49m         print("No eligible candidates found.")
[0m[49m[38;5;10m+    814[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    815[0m:[38;5;10m[49m         for candidate in results:
[0m[49m[38;5;10m+    816[0m:[38;5;10m[49m             print(f"\nPatient: {candidate['patient_id']}")
[0m[49m[38;5;10m+    817[0m:[38;5;10m[49m             print(f"  Eligibility Score: {candidate['eligibility_score']:.1%}")
[0m[49m[38;5;10m+    818[0m:[38;5;10m[49m             print(f"  Uncertain Criteria: {candidate['uncertain_count']}")
[0m[49m[38;5;10m+    819[0m:[38;5;10m[49m             print("  Criterion Details:")
[0m[49m[38;5;10m+    820[0m:[38;5;10m[49m             for detail in candidate["criterion_details"]:
[0m[49m[38;5;10m+    821[0m:[38;5;10m[49m                 status_icon = {"PASS": "✓", "FAIL": "✗", "UNCERTAIN": "?", "NOT_EVALUATED": "-"}
[0m[49m[38;5;10m+    822[0m:[38;5;10m[49m                 icon = status_icon.get(detail["status"], "?")
[0m[49m[38;5;10m+    823[0m:[38;5;10m[49m                 print(f"    [{icon}] {detail['raw_text']}")
[0m[49m[38;5;10m+    824[0m:[38;5;10m[49m                 print(f"        {detail['evidence']}")
[0m[49m[38;5;10m+    825[0m:[38;5;10m[49m ```
