[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m           "evidence_level": "B",
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m           "derivation": "nlp_extracted",
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m           "last_validated": "2025-08-03"
