[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m           "last_validated": "2025-09-22"
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m       ],
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m       "consensus_score": 1.0,
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m       "source_count": 2
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m     {
