[0m[49m[38;5;10m+    1023[0m:[38;5;10m[49m ## Step 8: Querying the Knowledge Graph
[0m[49m[38;5;10m+    1024[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1025[0m:[38;5;10m[49m *This isn't in the pseudocode as a pipeline step, but it's what makes the whole thing useful. Once you've built the graph, you need to query it.*
[0m[49m[38;5;10m+    1026[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1027[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    1028[0m:[38;5;10m[49m def query_drug_relationships(drug_label: str, max_results: int = 10) -> list[dict]:
[0m[49m[38;5;10m+    1029[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1030[0m:[38;5;10m[49m     Query the knowledge graph for all relationships involving a specific drug.
[0m[49m[38;5;10m+    1031[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1032[0m:[38;5;10m[49m     This is the kind of query a clinician or researcher would run:
[0m[49m[38;5;10m+    1033[0m:[38;5;10m[49m     "What does the literature say about metformin?"
[0m[49m[38;5;10m+    1034[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1035[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    1036[0m:[38;5;10m[49m         drug_label: The canonical drug name (e.g., "metformin")
[0m[49m[38;5;10m+    1037[0m:[38;5;10m[49m         max_results: Maximum relationships to return
[0m[49m[38;5;10m+    1038[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1039[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    1040[0m:[38;5;10m[49m         List of relationship dicts with subject, predicate, object, and evidence.
[0m[49m[38;5;10m+    1041[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1042[0m:[38;5;10m[49m     client = get_neptune_client()
[0m[49m[38;5;10m+    1043[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1044[0m:[38;5;10m[49m     # Find all outgoing edges from this drug node
[0m[49m[38;5;10m+    1045[0m:[38;5;10m[49m     query = (
[0m[49m[38;5;10m+    1046[0m:[38;5;10m[49m         "g.V().has('entity', 'label_text', drug_label)"
[0m[49m[38;5;10m+    1047[0m:[38;5;10m[49m         ".outE('relationship')"
[0m[49m[38;5;10m+    1048[0m:[38;5;10m[49m         ".order().by('evidence_score', decr)"
[0m[49m[38;5;10m+    1049[0m:[38;5;10m[49m         ".limit(max_results)"
[0m[49m[38;5;10m+    1050[0m:[38;5;10m[49m         ".project('predicate', 'target', 'evidence_score', 'support_count', 'is_negated')"
[0m[49m[38;5;10m+    1051[0m:[38;5;10m[49m         ".by(values('predicate'))"
[0m[49m[38;5;10m+    1052[0m:[38;5;10m[49m         ".by(inV().values('label_text'))"
[0m[49m[38;5;10m+    1053[0m:[38;5;10m[49m         ".by(values('evidence_score'))"
[0m[49m[38;5;10m+    1054[0m:[38;5;10m[49m         ".by(values('support_count'))"
[0m[49m[38;5;10m+    1055[0m:[38;5;10m[49m         ".by(values('is_negated'))"
[0m[49m[38;5;10m+    1056[0m:[38;5;10m[49m         ".toList()"
[0m[49m[38;5;10m+    1057[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    1058[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1059[0m:[38;5;10m[49m     results = client.submit(
[0m[49m[38;5;10m+    1060[0m:[38;5;10m[49m         query,
[0m[49m[38;5;10m+    1061[0m:[38;5;10m[49m         bindings={"drug_label": drug_label, "max_results": max_results},
[0m[49m[38;5;10m+    1062[0m:[38;5;10m[49m     ).all().result()
[0m[49m[38;5;10m+    1063[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1064[0m:[38;5;10m[49m     return results
[0m[49m[38;5;10m+    1065[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1066[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1067[0m:[38;5;10m[49m def find_path_between_entities(entity_a_id: str, entity_b_id: str, max_hops: int = 3) -> list[dict]:
[0m[49m[38;5;10m+    1068[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1069[0m:[38;5;10m[49m     Find shortest paths between two entities in the knowledge graph.
[0m[49m[38;5;10m+    1070[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1071[0m:[38;5;10m[49m     This answers questions like: "Is there a known connection between
[0m[49m[38;5;10m+    1072[0m:[38;5;10m[49m     gene X and disease Y?" The path might go through intermediate nodes
[0m[49m[38;5;10m+    1073[0m:[38;5;10m[49m     (gene -> protein -> pathway -> disease).
[0m[49m[38;5;10m+    1074[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1075[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    1076[0m:[38;5;10m[49m         entity_a_id: Canonical ID of the starting entity
[0m[49m[38;5;10m+    1077[0m:[38;5;10m[49m         entity_b_id: Canonical ID of the target entity
[0m[49m[38;5;10m+    1078[0m:[38;5;10m[49m         max_hops:    Maximum path length to search
[0m[49m[38;5;10m+    1079[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1080[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    1081[0m:[38;5;10m[49m         List of paths, each containing the sequence of nodes and edges.
[0m[49m[38;5;10m+    1082[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1083[0m:[38;5;10m[49m     client = get_neptune_client()
[0m[49m[38;5;10m+    1084[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1085[0m:[38;5;10m[49m     query = (
[0m[49m[38;5;10m+    1086[0m:[38;5;10m[49m         "g.V().has('entity', 'entity_id', start_id)"
[0m[49m[38;5;10m+    1087[0m:[38;5;10m[49m         ".repeat(bothE('relationship').otherV().simplePath())"
[0m[49m[38;5;10m+    1088[0m:[38;5;10m[49m         ".until(has('entity_id', end_id).or().loops().is(max_hops))"
[0m[49m[38;5;10m+    1089[0m:[38;5;10m[49m         ".has('entity_id', end_id)"
[0m[49m[38;5;10m+    1090[0m:[38;5;10m[49m         ".path()"
[0m[49m[38;5;10m+    1091[0m:[38;5;10m[49m         ".limit(5)"
[0m[49m[38;5;10m+    1092[0m:[38;5;10m[49m         ".toList()"
[0m[49m[38;5;10m+    1093[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    1094[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1095[0m:[38;5;10m[49m     results = client.submit(
[0m[49m[38;5;10m+    1096[0m:[38;5;10m[49m         query,
[0m[49m[38;5;10m+    1097[0m:[38;5;10m[49m         bindings={
[0m[49m[38;5;10m+    1098[0m:[38;5;10m[49m             "start_id": entity_a_id,
[0m[49m[38;5;10m+    1099[0m:[38;5;10m[49m             "end_id": entity_b_id,
[0m[49m[38;5;10m+    1100[0m:[38;5;10m[49m             "max_hops": max_hops,
[0m[49m[38;5;10m+    1101[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    1102[0m:[38;5;10m[49m     ).all().result()
[0m[49m[38;5;10m+    1103[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1104[0m:[38;5;10m[49m     return results
[0m[49m[38;5;10m+    1105[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    1106[0m:[38;5;10m[49m 
