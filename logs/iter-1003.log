[0m[49m[38;5;10m+      62[0m:[38;5;10m[49m REVIEW_QUEUE_URL = "https://sqs.us-east-1.amazonaws.com/123456789012/literature-kg-review"
[0m[49m[38;5;10m+      63[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      64[0m:[38;5;10m[49m # --- NER confidence threshold ---
[0m[49m[38;5;10m+      65[0m:[38;5;10m[49m # Entities below this score are discarded. 0.75 is a reasonable starting point
[0m[49m[38;5;10m+      66[0m:[38;5;10m[49m # for biomedical text. Lower it if you're missing too many entities; raise it
