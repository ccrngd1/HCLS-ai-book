[0m[49m[38;5;10m+    1014[0m:[38;5;10m[49m             "new_count": new_count,
[0m[49m[38;5;10m+    1015[0m:[38;5;10m[49m             "new_score": round(new_score, 4),
[0m[49m[38;5;10m+    1016[0m:[38;5;10m[49m             "now": now,
[0m[49m[38;5;10m+    1017[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    1018[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    1019[0m:[38;5;10m[49m ```
