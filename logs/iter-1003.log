[0m[49m[38;5;10m+      68[0m:[38;5;10m[49m NER_CONFIDENCE_THRESHOLD = 0.75
[0m[49m[38;5;10m+      69[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      70[0m:[38;5;10m[49m # --- Relation extraction confidence threshold ---
[0m[49m[38;5;10m+      71[0m:[38;5;10m[49m # Relations below this score are discarded. 0.70 balances precision and recall
[0m[49m[38;5;10m+      72[0m:[38;5;10m[49m # for biomedical RE. In production, you'd tune this against a held-out test set.
[0m[49m[38;5;10m+      73[0m:[38;5;10m[49m RE_CONFIDENCE_THRESHOLD = 0.70
[0m[49m[38;5;10m+      74[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      75[0m:[38;5;10m[49m # --- Evidence scoring weights ---
[0m[49m[38;5;10m+      76[0m:[38;5;10m[49m # These weights reflect the hierarchy of evidence in biomedical research.
