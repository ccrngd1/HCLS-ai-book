[0m[49m[38;5;10m+      31[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      32[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+      33[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+      34[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+      35[0m:[38;5;10m[49m import time
[0m[49m[38;5;10m+      36[0m:[38;5;10m[49m from datetime import datetime, timezone
[0m[49m[38;5;10m+      37[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+      38[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      39[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+      40[0m:[38;5;10m[49m import requests
[0m[49m[38;5;10m+      41[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+      42[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      43[0m:[38;5;10m[49m # Structured logging. Never log extracted PHI or full article text.
[0m[49m[38;5;10m+      44[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+      45[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+      46[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      47[0m:[38;5;10m[49m # Retry config for AWS service calls. Adaptive mode handles throttling gracefully.
[0m[49m[38;5;10m+      48[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+      49[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      50[0m:[38;5;10m[49m # --- Service clients ---
[0m[49m[38;5;10m+      51[0m:[38;5;10m[49m comprehend_medical = boto3.client("comprehend-medical", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+      52[0m:[38;5;10m[49m sagemaker_runtime = boto3.client("sagemaker-runtime", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+      53[0m:[38;5;10m[49m s3 = boto3.client("s3", config=BOTO3_RETRY_CONFIG)
