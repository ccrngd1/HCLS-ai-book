[0m[49m[38;5;10m+     141[0m:[38;5;10m[49m PUBMED_API_KEY = None  # Set this to your NCBI API key for higher rate limits
[0m[49m[38;5;10m+     142[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     143[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     144[0m:[38;5;10m[49m def fetch_new_articles(last_watermark: str, max_results: int = 100) -> list[dict]:
[0m[49m[38;5;10m+     145[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     146[0m:[38;5;10m[49m     Query PubMed for articles published since the last watermark date.
[0m[49m[38;5;10m+     147[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     148[0m:[38;5;10m[49m     This function searches for pharmacogenomics and drug-disease literature,
[0m[49m[38;5;10m+     149[0m:[38;5;10m[49m     fetches metadata and abstracts, and stores raw XML in S3.
[0m[49m[38;5;10m+     150[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     151[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     152[0m:[38;5;10m[49m         last_watermark: Date string in YYYY/MM/DD format. Only articles
[0m[49m[38;5;10m+     153[0m:[38;5;10m[49m                         published after this date are fetched.
[0m[49m[38;5;10m+     154[0m:[38;5;10m[49m         max_results:    Maximum articles to fetch per call. PubMed caps at 10,000
[0m[49m[38;5;10m+     155[0m:[38;5;10m[49m                         per query; use pagination for larger batches.
[0m[49m[38;5;10m+     156[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     157[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     158[0m:[38;5;10m[49m         List of article metadata dicts with keys: pmid, title, abstract, pub_date, mesh_terms
[0m[49m[38;5;10m+     159[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     160[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     161[0m:[38;5;10m[49m     # Step 1a: Search for matching article IDs
[0m[49m[38;5;10m+     162[0m:[38;5;10m[49m     # The query targets pharmacogenomics and drug-disease literature.
[0m[49m[38;5;10m+     163[0m:[38;5;10m[49m     # PDAT is the publication date field in PubMed's query syntax.
[0m[49m[38;5;10m+     164[0m:[38;5;10m[49m     search_params = {
[0m[49m[38;5;10m+     165[0m:[38;5;10m[49m         "db": "pubmed",
[0m[49m[38;5;10m+     166[0m:[38;5;10m[49m         "term": (
[0m[49m[38;5;10m+     167[0m:[38;5;10m[49m             "(pharmacogenomics OR drug-disease interaction OR gene-phenotype) "
[0m[49m[38;5;10m+     168[0m:[38;5;10m[49m             f"AND {last_watermark}[PDAT] : 3000[PDAT]"
[0m[49m[38;5;10m+     169[0m:[38;5;10m[49m         ),
[0m[49m[38;5;10m+     170[0m:[38;5;10m[49m         "retmax": max_results,
[0m[49m[38;5;10m+     171[0m:[38;5;10m[49m         "retmode": "json",
[0m[49m[38;5;10m+     172[0m:[38;5;10m[49m         "sort": "pub_date",
[0m[49m[38;5;10m+     173[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     174[0m:[38;5;10m[49m     if PUBMED_API_KEY:
[0m[49m[38;5;10m+     175[0m:[38;5;10m[49m         search_params["api_key"] = PUBMED_API_KEY
[0m[49m[38;5;10m+     176[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     177[0m:[38;5;10m[49m     search_response = requests.get(
[0m[49m[38;5;10m+     178[0m:[38;5;10m[49m         f"{PUBMED_BASE_URL}/esearch.fcgi", params=search_params
[0m[49m[38;5;10m+     179[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     180[0m:[38;5;10m[49m     search_response.raise_for_status()
[0m[49m[38;5;10m+     181[0m:[38;5;10m[49m     search_data = search_response.json()
[0m[49m[38;5;10m+     182[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     183[0m:[38;5;10m[49m     pmids = search_data.get("esearchresult", {}).get("idlist", [])
[0m[49m[38;5;10m+     184[0m:[38;5;10m[49m     logger.info("Found %d new articles since %s", len(pmids), last_watermark)
[0m[49m[38;5;10m+     185[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     186[0m:[38;5;10m[49m     if not pmids:
[0m[49m[38;5;10m+     187[0m:[38;5;10m[49m         return []
[0m[49m[38;5;10m+     188[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     189[0m:[38;5;10m[49m     # Step 1b: Fetch full metadata and abstracts for each article
[0m[49m[38;5;10m+     190[0m:[38;5;10m[49m     # efetch returns structured XML with title, abstract, MeSH terms, etc.
[0m[49m[38;5;10m+     191[0m:[38;5;10m[49m     fetch_params = {
[0m[49m[38;5;10m+     192[0m:[38;5;10m[49m         "db": "pubmed",
[0m[49m[38;5;10m+     193[0m:[38;5;10m[49m         "id": ",".join(pmids),
[0m[49m[38;5;10m+     194[0m:[38;5;10m[49m         "retmode": "xml",
[0m[49m[38;5;10m+     195[0m:[38;5;10m[49m         "rettype": "abstract",
[0m[49m[38;5;10m+     196[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     197[0m:[38;5;10m[49m     if PUBMED_API_KEY:
[0m[49m[38;5;10m+     198[0m:[38;5;10m[49m         fetch_params["api_key"] = PUBMED_API_KEY
[0m[49m[38;5;10m+     199[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     200[0m:[38;5;10m[49m     fetch_response = requests.get(
[0m[49m[38;5;10m+     201[0m:[38;5;10m[49m         f"{PUBMED_BASE_URL}/efetch.fcgi", params=fetch_params
[0m[49m[38;5;10m+     202[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     203[0m:[38;5;10m[49m     fetch_response.raise_for_status()
[0m[49m[38;5;10m+     204[0m:[38;5;10m[49m     raw_xml = fetch_response.text
[0m[49m[38;5;10m+     205[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     206[0m:[38;5;10m[49m     # Store the raw XML in S3 for reprocessing capability.
[0m[49m[38;5;10m+     207[0m:[38;5;10m[49m     # When you improve your NLP models later, you can re-run the pipeline
[0m[49m[38;5;10m+     208[0m:[38;5;10m[49m     # against this stored corpus without re-fetching from PubMed.
[0m[49m[38;5;10m+     209[0m:[38;5;10m[49m     timestamp = datetime.now(timezone.utc).strftime("%Y/%m/%d/%H%M%S")
[0m[49m[38;5;10m+     210[0m:[38;5;10m[49m     s3_key = f"documents/pubmed/batch-{timestamp}.xml"
[0m[49m[38;5;10m+     211[0m:[38;5;10m[49m     s3.put_object(
[0m[49m[38;5;10m+     212[0m:[38;5;10m[49m         Bucket=DOCUMENT_BUCKET,
[0m[49m[38;5;10m+     213[0m:[38;5;10m[49m         Key=s3_key,
[0m[49m[38;5;10m+     214[0m:[38;5;10m[49m         Body=raw_xml.encode("utf-8"),
[0m[49m[38;5;10m+     215[0m:[38;5;10m[49m         ContentType="application/xml",
[0m[49m[38;5;10m+     216[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     217[0m:[38;5;10m[49m     logger.info("Stored raw XML at s3://%s/%s", DOCUMENT_BUCKET, s3_key)
[0m[49m[38;5;10m+     218[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     219[0m:[38;5;10m[49m     # Step 1c: Parse the XML into structured article records.
[0m[49m[38;5;10m+     220[0m:[38;5;10m[49m     # In production, use xml.etree.ElementTree or lxml for proper XML parsing.
[0m[49m[38;5;10m+     221[0m:[38;5;10m[49m     # Here we show the pattern with a simplified parser.
[0m[49m[38;5;10m+     222[0m:[38;5;10m[49m     articles = parse_pubmed_xml(raw_xml)
[0m[49m[38;5;10m+     223[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     224[0m:[38;5;10m[49m     return articles
[0m[49m[38;5;10m+     225[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     226[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     227[0m:[38;5;10m[49m def parse_pubmed_xml(xml_text: str) -> list[dict]:
[0m[49m[38;5;10m+     228[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     229[0m:[38;5;10m[49m     Parse PubMed XML into structured article records.
[0m[49m[38;5;10m+     230[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     231[0m:[38;5;10m[49m     This is a simplified parser that extracts the fields we need.
[0m[49m[38;5;10m+     232[0m:[38;5;10m[49m     Production code would use lxml with proper namespace handling.
[0m[49m[38;5;10m+     233[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     234[0m:[38;5;10m[49m     import xml.etree.ElementTree as ET
[0m[49m[38;5;10m+     235[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     236[0m:[38;5;10m[49m     articles = []
[0m[49m[38;5;10m+     237[0m:[38;5;10m[49m     root = ET.fromstring(xml_text)
[0m[49m[38;5;10m+     238[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     239[0m:[38;5;10m[49m     for article_elem in root.findall(".//PubmedArticle"):
[0m[49m[38;5;10m+     240[0m:[38;5;10m[49m         pmid_elem = article_elem.find(".//PMID")
[0m[49m[38;5;10m+     241[0m:[38;5;10m[49m         title_elem = article_elem.find(".//ArticleTitle")
[0m[49m[38;5;10m+     242[0m:[38;5;10m[49m         abstract_elem = article_elem.find(".//AbstractText")
[0m[49m[38;5;10m+     243[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     244[0m:[38;5;10m[49m         # Extract MeSH terms for study type classification later
[0m[49m[38;5;10m+     245[0m:[38;5;10m[49m         mesh_terms = []
[0m[49m[38;5;10m+     246[0m:[38;5;10m[49m         for mesh in article_elem.findall(".//MeshHeading/DescriptorName"):
[0m[49m[38;5;10m+     247[0m:[38;5;10m[49m             mesh_terms.append(mesh.text)
[0m[49m[38;5;10m+     248[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     249[0m:[38;5;10m[49m         # Extract publication types (used for evidence grading)
[0m[49m[38;5;10m+     250[0m:[38;5;10m[49m         pub_types = []
[0m[49m[38;5;10m+     251[0m:[38;5;10m[49m         for pt in article_elem.findall(".//PublicationType"):
[0m[49m[38;5;10m+     252[0m:[38;5;10m[49m             pub_types.append(pt.text)
[0m[49m[38;5;10m+     253[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     254[0m:[38;5;10m[49m         articles.append({
[0m[49m[38;5;10m+     255[0m:[38;5;10m[49m             "pmid": pmid_elem.text if pmid_elem is not None else None,
[0m[49m[38;5;10m+     256[0m:[38;5;10m[49m             "title": title_elem.text if title_elem is not None else "",
[0m[49m[38;5;10m+     257[0m:[38;5;10m[49m             "abstract": abstract_elem.text if abstract_elem is not None else "",
[0m[49m[38;5;10m+     258[0m:[38;5;10m[49m             "mesh_terms": mesh_terms,
[0m[49m[38;5;10m+     259[0m:[38;5;10m[49m             "pub_types": pub_types,
[0m[49m[38;5;10m+     260[0m:[38;5;10m[49m             "pub_date": extract_pub_date(article_elem),
[0m[49m[38;5;10m+     261[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     262[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     263[0m:[38;5;10m[49m     return [a for a in articles if a["pmid"] and a["abstract"]]
[0m[49m[38;5;10m+     264[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     265[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     266[0m:[38;5;10m[49m def extract_pub_date(article_elem) -> str:
[0m[49m[38;5;10m+     267[0m:[38;5;10m[49m     """Extract publication date from PubMed XML article element."""
[0m[49m[38;5;10m+     268[0m:[38;5;10m[49m     year = article_elem.find(".//PubDate/Year")
[0m[49m[38;5;10m+     269[0m:[38;5;10m[49m     month = article_elem.find(".//PubDate/Month")
[0m[49m[38;5;10m+     270[0m:[38;5;10m[49m     day = article_elem.find(".//PubDate/Day")
[0m[49m[38;5;10m+     271[0m:[38;5;10m[49m     parts = []
[0m[49m[38;5;10m+     272[0m:[38;5;10m[49m     if year is not None:
[0m[49m[38;5;10m+     273[0m:[38;5;10m[49m         parts.append(year.text)
[0m[49m[38;5;10m+     274[0m:[38;5;10m[49m     if month is not None:
[0m[49m[38;5;10m+     275[0m:[38;5;10m[49m         parts.append(month.text.zfill(2))
[0m[49m[38;5;10m+     276[0m:[38;5;10m[49m     if day is not None:
[0m[49m[38;5;10m+     277[0m:[38;5;10m[49m         parts.append(day.text.zfill(2))
[0m[49m[38;5;10m+     278[0m:[38;5;10m[49m     return "/".join(parts) if parts else "unknown"
[0m[49m[38;5;10m+     279[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     280[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     281[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     282[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     283[0m:[38;5;10m[49m ## Step 2: Sentence Segmentation
[0m[49m[38;5;10m+     284[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     285[0m:[38;5;10m[49m *The pseudocode calls this `parse_and_segment(document_s3_key)`. It splits article abstracts into individual sentences, tagging each with its source location for provenance tracking.*
[0m[49m[38;5;10m+     286[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     287[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     288[0m:[38;5;10m[49m def segment_into_sentences(article: dict) -> list[dict]:
[0m[49m[38;5;10m+     289[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     290[0m:[38;5;10m[49m     Split an article's abstract into individual sentences with metadata.
[0m[49m[38;5;10m+     291[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     292[0m:[38;5;10m[49m     Biomedical text has tricky sentence boundaries: "Fig. 2", "et al.",
[0m[49m[38;5;10m+     293[0m:[38;5;10m[49m     "p < 0.05" all contain periods that aren't sentence endings. A proper
[0m[49m[38;5;10m+     294[0m:[38;5;10m[49m     implementation would use a biomedical sentence splitter like SciSpacy's
[0m[49m[38;5;10m+     295[0m:[38;5;10m[49m     sentencizer. Here we use a simplified approach for illustration.
[0m[49m[38;5;10m+     296[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     297[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     298[0m:[38;5;10m[49m         article: Dict with keys pmid, title, abstract, mesh_terms, pub_types
[0m[49m[38;5;10m+     299[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     300[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     301[0m:[38;5;10m[49m         List of sentence dicts, each with text, source metadata, and position.
[0m[49m[38;5;10m+     302[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     303[0m:[38;5;10m[49m     # In production, use scispacy or a biomedical-trained sentence splitter.
[0m[49m[38;5;10m+     304[0m:[38;5;10m[49m     # The naive split on ". " fails on abbreviations. This simplified version
[0m[49m[38;5;10m+     305[0m:[38;5;10m[49m     # handles the most common biomedical abbreviations.
[0m[49m[38;5;10m+     306[0m:[38;5;10m[49m     abstract = article["abstract"]
[0m[49m[38;5;10m+     307[0m:[38;5;10m[49m     if not abstract:
[0m[49m[38;5;10m+     308[0m:[38;5;10m[49m         return []
[0m[49m[38;5;10m+     309[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     310[0m:[38;5;10m[49m     # Simple sentence splitting (production would use scispacy)
[0m[49m[38;5;10m+     311[0m:[38;5;10m[49m     # Replace common abbreviations to protect their periods
[0m[49m[38;5;10m+     312[0m:[38;5;10m[49m     protected = abstract
[0m[49m[38;5;10m+     313[0m:[38;5;10m[49m     abbreviations = ["et al.", "Fig.", "vs.", "i.e.", "e.g.", "Dr.", "approx."]
[0m[49m[38;5;10m+     314[0m:[38;5;10m[49m     for abbr in abbreviations:
[0m[49m[38;5;10m+     315[0m:[38;5;10m[49m         protected = protected.replace(abbr, abbr.replace(".", "<DOT>"))
[0m[49m[38;5;10m+     316[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     317[0m:[38;5;10m[49m     # Split on sentence-ending punctuation followed by space and uppercase
[0m[49m[38;5;10m+     318[0m:[38;5;10m[49m     raw_sentences = []
[0m[49m[38;5;10m+     319[0m:[38;5;10m[49m     current = ""
[0m[49m[38;5;10m+     320[0m:[38;5;10m[49m     for char in protected:
[0m[49m[38;5;10m+     321[0m:[38;5;10m[49m         current += char
[0m[49m[38;5;10m+     322[0m:[38;5;10m[49m         if char in ".!?" and len(current.strip()) > 10:
[0m[49m[38;5;10m+     323[0m:[38;5;10m[49m             raw_sentences.append(current.strip())
[0m[49m[38;5;10m+     324[0m:[38;5;10m[49m             current = ""
[0m[49m[38;5;10m+     325[0m:[38;5;10m[49m     if current.strip():
[0m[49m[38;5;10m+     326[0m:[38;5;10m[49m         raw_sentences.append(current.strip())
[0m[49m[38;5;10m+     327[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     328[0m:[38;5;10m[49m     # Restore protected periods and build sentence records
[0m[49m[38;5;10m+     329[0m:[38;5;10m[49m     sentences = []
[0m[49m[38;5;10m+     330[0m:[38;5;10m[49m     for i, sent in enumerate(raw_sentences):
[0m[49m[38;5;10m+     331[0m:[38;5;10m[49m         restored = sent.replace("<DOT>", ".")
[0m[49m[38;5;10m+     332[0m:[38;5;10m[49m         if len(restored.split()) < 4:
[0m[49m[38;5;10m+     333[0m:[38;5;10m[49m             continue  # skip fragments too short to contain a relationship
[0m[49m[38;5;10m+     334[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     335[0m:[38;5;10m[49m         sentences.append({
[0m[49m[38;5;10m+     336[0m:[38;5;10m[49m             "text": restored,
[0m[49m[38;5;10m+     337[0m:[38;5;10m[49m             "pmid": article["pmid"],
[0m[49m[38;5;10m+     338[0m:[38;5;10m[49m             "section": "abstract",  # for abstract-only processing
[0m[49m[38;5;10m+     339[0m:[38;5;10m[49m             "position": i,
[0m[49m[38;5;10m+     340[0m:[38;5;10m[49m             "sentence_id": f"{article['pmid']}:abstract:{i}",
[0m[49m[38;5;10m+     341[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     342[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     343[0m:[38;5;10m[49m     return sentences
[0m[49m[38;5;10m+     344[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     345[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     346[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     347[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     348[0m:[38;5;10m[49m ## Step 3: Named Entity Recognition with Comprehend Medical
[0m[49m[38;5;10m+     349[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     350[0m:[38;5;10m[49m *The pseudocode calls this `extract_entities(sentences)`. It sends each sentence through Amazon Comprehend Medical to identify drugs, diseases, genes, and other biomedical entities.*
[0m[49m[38;5;10m+     351[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     352[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     353[0m:[38;5;10m[49m def extract_entities(sentences: list[dict]) -> list[dict]:
[0m[49m[38;5;10m+     354[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     355[0m:[38;5;10m[49m     Run biomedical NER on each sentence using Amazon Comprehend Medical.
[0m[49m[38;5;10m+     356[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     357[0m:[38;5;10m[49m     Comprehend Medical identifies: MEDICATION, MEDICAL_CONDITION,
[0m[49m[38;5;10m+     358[0m:[38;5;10m[49m     TEST_TREATMENT_PROCEDURE, ANATOMY, and their attributes (dosage,
[0m[49m[38;5;10m+     359[0m:[38;5;10m[49m     frequency, negation). For gene/variant entities, you'd supplement
[0m[49m[38;5;10m+     360[0m:[38;5;10m[49m     with a custom SageMaker model. Here we show the Comprehend Medical
[0m[49m[38;5;10m+     361[0m:[38;5;10m[49m     pattern.
[0m[49m[38;5;10m+     362[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     363[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     364[0m:[38;5;10m[49m         sentences: List of sentence dicts from segment_into_sentences()
[0m[49m[38;5;10m+     365[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     366[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     367[0m:[38;5;10m[49m         List of entity mention dicts with type, confidence, position, and traits.
[0m[49m[38;5;10m+     368[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     369[0m:[38;5;10m[49m     all_entities = []
[0m[49m[38;5;10m+     370[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     371[0m:[38;5;10m[49m     for sentence in sentences:
[0m[49m[38;5;10m+     372[0m:[38;5;10m[49m         text = sentence["text"]
[0m[49m[38;5;10m+     373[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     374[0m:[38;5;10m[49m         # Comprehend Medical has a 20,000 character limit per call.
[0m[49m[38;5;10m+     375[0m:[38;5;10m[49m         # Individual sentences are well under this, but check anyway.
[0m[49m[38;5;10m+     376[0m:[38;5;10m[49m         if len(text) > 20000:
[0m[49m[38;5;10m+     377[0m:[38;5;10m[49m             logger.warning("Sentence too long for Comprehend Medical, skipping: %s", sentence["sentence_id"])
[0m[49m[38;5;10m+     378[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     379[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     380[0m:[38;5;10m[49m         # Call Comprehend Medical's DetectEntitiesV2 API.
[0m[49m[38;5;10m+     381[0m:[38;5;10m[49m         # This is the newer version that returns richer entity attributes.
[0m[49m[38;5;10m+     382[0m:[38;5;10m[49m         response = comprehend_medical.detect_entities_v2(Text=text)
[0m[49m[38;5;10m+     383[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     384[0m:[38;5;10m[49m         for entity in response.get("Entities", []):
[0m[49m[38;5;10m+     385[0m:[38;5;10m[49m             # Apply confidence threshold. Low-confidence detections
[0m[49m[38;5;10m+     386[0m:[38;5;10m[49m             # introduce noise that propagates through the entire pipeline.
[0m[49m[38;5;10m+     387[0m:[38;5;10m[49m             if entity["Score"] < NER_CONFIDENCE_THRESHOLD:
[0m[49m[38;5;10m+     388[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+     389[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     390[0m:[38;5;10m[49m             # Check for negation trait. Comprehend Medical flags negated
[0m[49m[38;5;10m+     391[0m:[38;5;10m[49m             # entities (e.g., "no evidence of diabetes") with a NEGATION trait.
[0m[49m[38;5;10m+     392[0m:[38;5;10m[49m             is_negated = any(
[0m[49m[38;5;10m+     393[0m:[38;5;10m[49m                 trait["Name"] == "NEGATION" and trait["Score"] > 0.8
[0m[49m[38;5;10m+     394[0m:[38;5;10m[49m                 for trait in entity.get("Traits", [])
[0m[49m[38;5;10m+     395[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+     396[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     397[0m:[38;5;10m[49m             all_entities.append({
[0m[49m[38;5;10m+     398[0m:[38;5;10m[49m                 "text": entity["Text"],
[0m[49m[38;5;10m+     399[0m:[38;5;10m[49m                 "type": entity["Category"],  # MEDICATION, MEDICAL_CONDITION, etc.
[0m[49m[38;5;10m+     400[0m:[38;5;10m[49m                 "subtype": entity.get("Type", ""),  # GENERIC_NAME, DX_NAME, etc.
[0m[49m[38;5;10m+     401[0m:[38;5;10m[49m                 "score": entity["Score"],
[0m[49m[38;5;10m+     402[0m:[38;5;10m[49m                 "begin_offset": entity["BeginOffset"],
[0m[49m[38;5;10m+     403[0m:[38;5;10m[49m                 "end_offset": entity["EndOffset"],
[0m[49m[38;5;10m+     404[0m:[38;5;10m[49m                 "is_negated": is_negated,
[0m[49m[38;5;10m+     405[0m:[38;5;10m[49m                 "sentence_id": sentence["sentence_id"],
[0m[49m[38;5;10m+     406[0m:[38;5;10m[49m                 "sentence_text": text,
[0m[49m[38;5;10m+     407[0m:[38;5;10m[49m                 "pmid": sentence["pmid"],
[0m[49m[38;5;10m+     408[0m:[38;5;10m[49m                 "section": sentence["section"],
[0m[49m[38;5;10m+     409[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+     410[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     411[0m:[38;5;10m[49m     logger.info("Extracted %d entities from %d sentences", len(all_entities), len(sentences))
[0m[49m[38;5;10m+     412[0m:[38;5;10m[49m     return all_entities
[0m[49m[38;5;10m+     413[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     414[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     415[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     416[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     417[0m:[38;5;10m[49m ## Step 4: Relation Extraction
[0m[49m[38;5;10m+     418[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     419[0m:[38;5;10m[49m *The pseudocode calls this `extract_relations(sentences, entity_mentions)`. It takes entity pairs within the same sentence and classifies the relationship between them using a custom SageMaker-hosted model.*
[0m[49m[38;5;10m+     420[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     421[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     422[0m:[38;5;10m[49m # Valid entity pair combinations for relation extraction.
[0m[49m[38;5;10m+     423[0m:[38;5;10m[49m # Not all entity type pairs can have meaningful relationships.
[0m[49m[38;5;10m+     424[0m:[38;5;10m[49m # This filter prevents wasting inference calls on impossible pairs.
[0m[49m[38;5;10m+     425[0m:[38;5;10m[49m VALID_PAIR_TYPES = {
[0m[49m[38;5;10m+     426[0m:[38;5;10m[49m     ("MEDICATION", "MEDICAL_CONDITION"),  # drug-disease relationships
[0m[49m[38;5;10m+     427[0m:[38;5;10m[49m     ("MEDICAL_CONDITION", "MEDICATION"),
[0m[49m[38;5;10m+     428[0m:[38;5;10m[49m     ("MEDICATION", "MEDICATION"),          # drug-drug interactions
[0m[49m[38;5;10m+     429[0m:[38;5;10m[49m     ("MEDICATION", "GENE_OR_VARIANT"),     # pharmacogenomics
[0m[49m[38;5;10m+     430[0m:[38;5;10m[49m     ("GENE_OR_VARIANT", "MEDICAL_CONDITION"),  # gene-disease associations
[0m[49m[38;5;10m+     431[0m:[38;5;10m[49m     ("MEDICAL_CONDITION", "MEDICAL_CONDITION"),  # disease-disease comorbidity
[0m[49m[38;5;10m+     432[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     433[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     434[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     435[0m:[38;5;10m[49m def extract_relations(entity_mentions: list[dict]) -> list[dict]:
[0m[49m[38;5;10m+     436[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     437[0m:[38;5;10m[49m     Classify relationships between entity pairs in the same sentence.
[0m[49m[38;5;10m+     438[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     439[0m:[38;5;10m[49m     For each sentence containing two or more entities, generate candidate
[0m[49m[38;5;10m+     440[0m:[38;5;10m[49m     pairs and send them to the relation extraction model. The model returns
[0m[49m[38;5;10m+     441[0m:[38;5;10m[49m     a relationship type (treats, causes, inhibits, associated_with, etc.)
[0m[49m[38;5;10m+     442[0m:[38;5;10m[49m     along with confidence and negation/speculation flags.
[0m[49m[38;5;10m+     443[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     444[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     445[0m:[38;5;10m[49m         entity_mentions: List of entity dicts from extract_entities()
[0m[49m[38;5;10m+     446[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     447[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     448[0m:[38;5;10m[49m         List of extracted triple dicts ready for normalization.
[0m[49m[38;5;10m+     449[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     450[0m:[38;5;10m[49m     # Group entities by sentence
[0m[49m[38;5;10m+     451[0m:[38;5;10m[49m     entities_by_sentence = {}
[0m[49m[38;5;10m+     452[0m:[38;5;10m[49m     for entity in entity_mentions:
[0m[49m[38;5;10m+     453[0m:[38;5;10m[49m         sid = entity["sentence_id"]
[0m[49m[38;5;10m+     454[0m:[38;5;10m[49m         if sid not in entities_by_sentence:
[0m[49m[38;5;10m+     455[0m:[38;5;10m[49m             entities_by_sentence[sid] = []
[0m[49m[38;5;10m+     456[0m:[38;5;10m[49m         entities_by_sentence[sid].append(entity)
[0m[49m[38;5;10m+     457[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     458[0m:[38;5;10m[49m     extracted_triples = []
[0m[49m[38;5;10m+     459[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     460[0m:[38;5;10m[49m     for sentence_id, entities in entities_by_sentence.items():
[0m[49m[38;5;10m+     461[0m:[38;5;10m[49m         # Need at least 2 entities in a sentence to form a pair
[0m[49m[38;5;10m+     462[0m:[38;5;10m[49m         if len(entities) < 2:
[0m[49m[38;5;10m+     463[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     464[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     465[0m:[38;5;10m[49m         # Generate valid candidate pairs
[0m[49m[38;5;10m+     466[0m:[38;5;10m[49m         for i, entity_a in enumerate(entities):
[0m[49m[38;5;10m+     467[0m:[38;5;10m[49m             for entity_b in entities[i + 1:]:
[0m[49m[38;5;10m+     468[0m:[38;5;10m[49m                 pair_types = (entity_a["type"], entity_b["type"])
[0m[49m[38;5;10m+     469[0m:[38;5;10m[49m                 if pair_types not in VALID_PAIR_TYPES:
[0m[49m[38;5;10m+     470[0m:[38;5;10m[49m                     continue
[0m[49m[38;5;10m+     471[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     472[0m:[38;5;10m[49m                 # Call the relation extraction model hosted on SageMaker.
[0m[49m[38;5;10m+     473[0m:[38;5;10m[49m                 # The model expects the sentence with entity markers inserted.
[0m[49m[38;5;10m+     474[0m:[38;5;10m[49m                 prediction = call_relation_extraction_model(
[0m[49m[38;5;10m+     475[0m:[38;5;10m[49m                     sentence_text=entity_a["sentence_text"],
[0m[49m[38;5;10m+     476[0m:[38;5;10m[49m                     entity_a=entity_a,
[0m[49m[38;5;10m+     477[0m:[38;5;10m[49m                     entity_b=entity_b,
[0m[49m[38;5;10m+     478[0m:[38;5;10m[49m                 )
[0m[49m[38;5;10m+     479[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     480[0m:[38;5;10m[49m                 if prediction is None:
[0m[49m[38;5;10m+     481[0m:[38;5;10m[49m                     continue
[0m[49m[38;5;10m+     482[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     483[0m:[38;5;10m[49m                 if (
[0m[49m[38;5;10m+     484[0m:[38;5;10m[49m                     prediction["confidence"] >= RE_CONFIDENCE_THRESHOLD
[0m[49m[38;5;10m+     485[0m:[38;5;10m[49m                     and prediction["relation_type"] != "NO_RELATION"
[0m[49m[38;5;10m+     486[0m:[38;5;10m[49m                 ):
[0m[49m[38;5;10m+     487[0m:[38;5;10m[49m                     extracted_triples.append({
[0m[49m[38;5;10m+     488[0m:[38;5;10m[49m                         "subject": entity_a["text"],
[0m[49m[38;5;10m+     489[0m:[38;5;10m[49m                         "subject_type": entity_a["type"],
[0m[49m[38;5;10m+     490[0m:[38;5;10m[49m                         "predicate": prediction["relation_type"],
[0m[49m[38;5;10m+     491[0m:[38;5;10m[49m                         "object": entity_b["text"],
[0m[49m[38;5;10m+     492[0m:[38;5;10m[49m                         "object_type": entity_b["type"],
[0m[49m[38;5;10m+     493[0m:[38;5;10m[49m                         "confidence": prediction["confidence"],
[0m[49m[38;5;10m+     494[0m:[38;5;10m[49m                         "is_negated": prediction.get("is_negated", entity_a["is_negated"]),
[0m[49m[38;5;10m+     495[0m:[38;5;10m[49m                         "is_speculative": prediction.get("is_speculative", False),
[0m[49m[38;5;10m+     496[0m:[38;5;10m[49m                         "source_sentence": entity_a["sentence_text"],
[0m[49m[38;5;10m+     497[0m:[38;5;10m[49m                         "source_pmid": entity_a["pmid"],
[0m[49m[38;5;10m+     498[0m:[38;5;10m[49m                         "source_section": entity_a["section"],
[0m[49m[38;5;10m+     499[0m:[38;5;10m[49m                     })
[0m[49m[38;5;10m+     500[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     501[0m:[38;5;10m[49m     logger.info("Extracted %d relations from %d sentences", len(extracted_triples), len(entities_by_sentence))
[0m[49m[38;5;10m+     502[0m:[38;5;10m[49m     return extracted_triples
[0m[49m[38;5;10m+     503[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     504[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     505[0m:[38;5;10m[49m def call_relation_extraction_model(
[0m[49m[38;5;10m+     506[0m:[38;5;10m[49m     sentence_text: str, entity_a: dict, entity_b: dict
[0m[49m[38;5;10m+     507[0m:[38;5;10m[49m ) -> dict | None:
[0m[49m[38;5;10m+     508[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     509[0m:[38;5;10m[49m     Call the SageMaker-hosted relation extraction model.
[0m[49m[38;5;10m+     510[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     511[0m:[38;5;10m[49m     The model is a BioBERT or PubMedBERT transformer fine-tuned on
[0m[49m[38;5;10m+     512[0m:[38;5;10m[49m     biomedical relation extraction datasets (BioRED, ChemProt).
[0m[49m[38;5;10m+     513[0m:[38;5;10m[49m     It expects input with entity markers: [E1]...[/E1] and [E2]...[/E2].
[0m[49m[38;5;10m+     514[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     515[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     516[0m:[38;5;10m[49m         Dict with relation_type, confidence, is_negated, is_speculative.
[0m[49m[38;5;10m+     517[0m:[38;5;10m[49m         None if the model call fails.
[0m[49m[38;5;10m+     518[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     519[0m:[38;5;10m[49m     # Insert entity markers into the sentence text.
[0m[49m[38;5;10m+     520[0m:[38;5;10m[49m     # The model uses these markers to identify which entities to classify.
[0m[49m[38;5;10m+     521[0m:[38;5;10m[49m     marked_text = sentence_text
[0m[49m[38;5;10m+     522[0m:[38;5;10m[49m     # Insert markers for entity_b first (higher offset) to preserve positions
[0m[49m[38;5;10m+     523[0m:[38;5;10m[49m     if entity_b["begin_offset"] > entity_a["begin_offset"]:
[0m[49m[38;5;10m+     524[0m:[38;5;10m[49m         marked_text = (
[0m[49m[38;5;10m+     525[0m:[38;5;10m[49m             marked_text[:entity_b["begin_offset"]]
[0m[49m[38;5;10m+     526[0m:[38;5;10m[49m             + "[E2]" + entity_b["text"] + "[/E2]"
[0m[49m[38;5;10m+     527[0m:[38;5;10m[49m             + marked_text[entity_b["end_offset"]:]
[0m[49m[38;5;10m+     528[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     529[0m:[38;5;10m[49m         marked_text = (
[0m[49m[38;5;10m+     530[0m:[38;5;10m[49m             marked_text[:entity_a["begin_offset"]]
[0m[49m[38;5;10m+     531[0m:[38;5;10m[49m             + "[E1]" + entity_a["text"] + "[/E1]"
[0m[49m[38;5;10m+     532[0m:[38;5;10m[49m             + marked_text[entity_a["end_offset"]:]
[0m[49m[38;5;10m+     533[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     534[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+     535[0m:[38;5;10m[49m         marked_text = (
[0m[49m[38;5;10m+     536[0m:[38;5;10m[49m             marked_text[:entity_a["begin_offset"]]
[0m[49m[38;5;10m+     537[0m:[38;5;10m[49m             + "[E1]" + entity_a["text"] + "[/E1]"
[0m[49m[38;5;10m+     538[0m:[38;5;10m[49m             + marked_text[entity_a["end_offset"]:]
[0m[49m[38;5;10m+     539[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     540[0m:[38;5;10m[49m         marked_text = (
[0m[49m[38;5;10m+     541[0m:[38;5;10m[49m             marked_text[:entity_b["begin_offset"]]
[0m[49m[38;5;10m+     542[0m:[38;5;10m[49m             + "[E2]" + entity_b["text"] + "[/E2]"
[0m[49m[38;5;10m+     543[0m:[38;5;10m[49m             + marked_text[entity_b["end_offset"]:]
[0m[49m[38;5;10m+     544[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     545[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     546[0m:[38;5;10m[49m     payload = json.dumps({
[0m[49m[38;5;10m+     547[0m:[38;5;10m[49m         "text": marked_text,
[0m[49m[38;5;10m+     548[0m:[38;5;10m[49m         "entity_a_type": entity_a["type"],
[0m[49m[38;5;10m+     549[0m:[38;5;10m[49m         "entity_b_type": entity_b["type"],
[0m[49m[38;5;10m+     550[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+     551[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     552[0m:[38;5;10m[49m     try:
[0m[49m[38;5;10m+     553[0m:[38;5;10m[49m         response = sagemaker_runtime.invoke_endpoint(
[0m[49m[38;5;10m+     554[0m:[38;5;10m[49m             EndpointName=SAGEMAKER_RE_ENDPOINT,
[0m[49m[38;5;10m+     555[0m:[38;5;10m[49m             ContentType="application/json",
[0m[49m[38;5;10m+     556[0m:[38;5;10m[49m             Body=payload,
[0m[49m[38;5;10m+     557[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     558[0m:[38;5;10m[49m         result = json.loads(response["Body"].read().decode("utf-8"))
[0m[49m[38;5;10m+     559[0m:[38;5;10m[49m         return result
[0m[49m[38;5;10m+     560[0m:[38;5;10m[49m     except Exception as e:
[0m[49m[38;5;10m+     561[0m:[38;5;10m[49m         logger.error("RE model invocation failed: %s", str(e))
[0m[49m[38;5;10m+     562[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+     563[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     564[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     565[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     566[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     567[0m:[38;5;10m[49m ## Step 5: Entity Normalization
[0m[49m[38;5;10m+     568[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     569[0m:[38;5;10m[49m *The pseudocode calls this `normalize_entities(triples)`. It maps extracted entity surface forms to canonical identifiers in standard biomedical ontologies (RxNorm, SNOMED CT, HGNC).*
[0m[49m[38;5;10m+     570[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     571[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     572[0m:[38;5;10m[49m def normalize_entities(triples: list[dict]) -> list[dict]:
[0m[49m[38;5;10m+     573[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     574[0m:[38;5;10m[49m     Map extracted entity mentions to canonical ontology identifiers.
[0m[49m[38;5;10m+     575[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     576[0m:[38;5;10m[49m     "Metformin," "Glucophage," and "metformin hydrochloride" all become
[0m[49m[38;5;10m+     577[0m:[38;5;10m[49m     RxNorm:6809. Without this step, your graph would have separate nodes
[0m[49m[38;5;10m+     578[0m:[38;5;10m[49m     for each surface form, fragmenting the knowledge.
[0m[49m[38;5;10m+     579[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     580[0m:[38;5;10m[49m     In production, this would call a UMLS API or a local lookup service
[0m[49m[38;5;10m+     581[0m:[38;5;10m[49m     built from the UMLS Metathesaurus. Here we use the simplified lookup
[0m[49m[38;5;10m+     582[0m:[38;5;10m[49m     dictionaries defined in the config section.
[0m[49m[38;5;10m+     583[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     584[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     585[0m:[38;5;10m[49m         triples: List of extracted triple dicts from extract_relations()
[0m[49m[38;5;10m+     586[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     587[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     588[0m:[38;5;10m[49m         List of normalized triple dicts with canonical IDs, or empty if
[0m[49m[38;5;10m+     589[0m:[38;5;10m[49m         normalization failed for either entity.
[0m[49m[38;5;10m+     590[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     591[0m:[38;5;10m[49m     normalized = []
[0m[49m[38;5;10m+     592[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     593[0m:[38;5;10m[49m     for triple in triples:
[0m[49m[38;5;10m+     594[0m:[38;5;10m[49m         subject_canonical = normalize_single_entity(
[0m[49m[38;5;10m+     595[0m:[38;5;10m[49m             triple["subject"], triple["subject_type"]
[0m[49m[38;5;10m+     596[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     597[0m:[38;5;10m[49m         object_canonical = normalize_single_entity(
[0m[49m[38;5;10m+     598[0m:[38;5;10m[49m             triple["object"], triple["object_type"]
[0m[49m[38;5;10m+     599[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     600[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     601[0m:[38;5;10m[49m         # Only keep triples where both entities resolved to canonical IDs.
[0m[49m[38;5;10m+     602[0m:[38;5;10m[49m         # Unnormalized entities would create orphan nodes that can't be
[0m[49m[38;5;10m+     603[0m:[38;5;10m[49m         # connected to anything else in the graph.
[0m[49m[38;5;10m+     604[0m:[38;5;10m[49m         if subject_canonical is None or object_canonical is None:
[0m[49m[38;5;10m+     605[0m:[38;5;10m[49m             logger.debug(
[0m[49m[38;5;10m+     606[0m:[38;5;10m[49m                 "Skipping triple: could not normalize '%s' or '%s'",
[0m[49m[38;5;10m+     607[0m:[38;5;10m[49m                 triple["subject"], triple["object"],
[0m[49m[38;5;10m+     608[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+     609[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     610[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     611[0m:[38;5;10m[49m         normalized.append({
[0m[49m[38;5;10m+     612[0m:[38;5;10m[49m             "subject_id": subject_canonical["id"],
[0m[49m[38;5;10m+     613[0m:[38;5;10m[49m             "subject_label": subject_canonical["label"],
[0m[49m[38;5;10m+     614[0m:[38;5;10m[49m             "subject_type": triple["subject_type"],
[0m[49m[38;5;10m+     615[0m:[38;5;10m[49m             "predicate": triple["predicate"],
[0m[49m[38;5;10m+     616[0m:[38;5;10m[49m             "object_id": object_canonical["id"],
[0m[49m[38;5;10m+     617[0m:[38;5;10m[49m             "object_label": object_canonical["label"],
[0m[49m[38;5;10m+     618[0m:[38;5;10m[49m             "object_type": triple["object_type"],
[0m[49m[38;5;10m+     619[0m:[38;5;10m[49m             "confidence": triple["confidence"],
[0m[49m[38;5;10m+     620[0m:[38;5;10m[49m             "is_negated": triple["is_negated"],
[0m[49m[38;5;10m+     621[0m:[38;5;10m[49m             "is_speculative": triple["is_speculative"],
[0m[49m[38;5;10m+     622[0m:[38;5;10m[49m             "provenance": {
[0m[49m[38;5;10m+     623[0m:[38;5;10m[49m                 "pmid": triple["source_pmid"],
[0m[49m[38;5;10m+     624[0m:[38;5;10m[49m                 "sentence": triple["source_sentence"],
[0m[49m[38;5;10m+     625[0m:[38;5;10m[49m                 "section": triple["source_section"],
[0m[49m[38;5;10m+     626[0m:[38;5;10m[49m             },
[0m[49m[38;5;10m+     627[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     628[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     629[0m:[38;5;10m[49m     logger.info("Normalized %d of %d triples", len(normalized), len(triples))
[0m[49m[38;5;10m+     630[0m:[38;5;10m[49m     return normalized
[0m[49m[38;5;10m+     631[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     632[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     633[0m:[38;5;10m[49m def normalize_single_entity(text: str, entity_type: str) -> dict | None:
[0m[49m[38;5;10m+     634[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     635[0m:[38;5;10m[49m     Look up a single entity in the appropriate ontology dictionary.
[0m[49m[38;5;10m+     636[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     637[0m:[38;5;10m[49m     Tries exact match first (fast, reliable), then lowercase match.
[0m[49m[38;5;10m+     638[0m:[38;5;10m[49m     Production would add fuzzy matching and embedding-based similarity.
[0m[49m[38;5;10m+     639[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     640[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     641[0m:[38;5;10m[49m         Dict with 'id' and 'label' keys, or None if not found.
[0m[49m[38;5;10m+     642[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     643[0m:[38;5;10m[49m     # Select lookup table based on entity type
[0m[49m[38;5;10m+     644[0m:[38;5;10m[49m     if entity_type == "MEDICATION":
[0m[49m[38;5;10m+     645[0m:[38;5;10m[49m         lookup = DRUG_SYNONYMS
[0m[49m[38;5;10m+     646[0m:[38;5;10m[49m     elif entity_type == "MEDICAL_CONDITION":
[0m[49m[38;5;10m+     647[0m:[38;5;10m[49m         lookup = DISEASE_SYNONYMS
[0m[49m[38;5;10m+     648[0m:[38;5;10m[49m     elif entity_type == "GENE_OR_VARIANT":
[0m[49m[38;5;10m+     649[0m:[38;5;10m[49m         lookup = GENE_SYNONYMS
[0m[49m[38;5;10m+     650[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+     651[0m:[38;5;10m[49m         return None  # unsupported entity type for this example
[0m[49m[38;5;10m+     652[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     653[0m:[38;5;10m[49m     # Try exact lowercase match
[0m[49m[38;5;10m+     654[0m:[38;5;10m[49m     normalized_text = text.lower().strip()
[0m[49m[38;5;10m+     655[0m:[38;5;10m[49m     if normalized_text in lookup:
[0m[49m[38;5;10m+     656[0m:[38;5;10m[49m         return lookup[normalized_text]
[0m[49m[38;5;10m+     657[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     658[0m:[38;5;10m[49m     # In production: try fuzzy match, then embedding similarity
[0m[49m[38;5;10m+     659[0m:[38;5;10m[49m     # For this example, we just return None for unmatched entities
[0m[49m[38;5;10m+     660[0m:[38;5;10m[49m     return None
[0m[49m[38;5;10m+     661[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     662[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     663[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     664[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     665[0m:[38;5;10m[49m ## Step 6: Evidence Grading
[0m[49m[38;5;10m+     666[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     667[0m:[38;5;10m[49m *The pseudocode calls this `grade_and_resolve(normalized_triples, existing_graph)`. It scores each triple based on source quality and detects conflicts with existing graph edges.*
[0m[49m[38;5;10m+     668[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     669[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     670[0m:[38;5;10m[49m def grade_evidence(normalized_triples: list[dict], article_metadata: dict) -> list[dict]:
[0m[49m[38;5;10m+     671[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     672[0m:[38;5;10m[49m     Assign evidence scores to each extracted triple based on source quality.
[0m[49m[38;5;10m+     673[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     674[0m:[38;5;10m[49m     The score combines: study type weight (RCT > case report), NLP extraction
[0m[49m[38;5;10m+     675[0m:[38;5;10m[49m     confidence, and section weight (Results > Discussion). This produces a
[0m[49m[38;5;10m+     676[0m:[38;5;10m[49m     single number between 0 and 1 that represents how much you should trust
[0m[49m[38;5;10m+     677[0m:[38;5;10m[49m     this particular extraction.
[0m[49m[38;5;10m+     678[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     679[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     680[0m:[38;5;10m[49m         normalized_triples: List of normalized triple dicts
[0m[49m[38;5;10m+     681[0m:[38;5;10m[49m         article_metadata:   Dict mapping PMID to article metadata (pub_types, etc.)
[0m[49m[38;5;10m+     682[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     683[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     684[0m:[38;5;10m[49m         Same triples with evidence_score added to each.
[0m[49m[38;5;10m+     685[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     686[0m:[38;5;10m[49m     scored = []
[0m[49m[38;5;10m+     687[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     688[0m:[38;5;10m[49m     for triple in normalized_triples:
[0m[49m[38;5;10m+     689[0m:[38;5;10m[49m         pmid = triple["provenance"]["pmid"]
[0m[49m[38;5;10m+     690[0m:[38;5;10m[49m         metadata = article_metadata.get(pmid, {})
[0m[49m[38;5;10m+     691[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     692[0m:[38;5;10m[49m         # Classify study type from publication types
[0m[49m[38;5;10m+     693[0m:[38;5;10m[49m         study_type = classify_study_type(metadata.get("pub_types", []))
[0m[49m[38;5;10m+     694[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     695[0m:[38;5;10m[49m         # Calculate composite evidence score
[0m[49m[38;5;10m+     696[0m:[38;5;10m[49m         study_weight = STUDY_TYPE_WEIGHTS.get(study_type, 0.4)
[0m[49m[38;5;10m+     697[0m:[38;5;10m[49m         section_weight = SECTION_WEIGHTS.get(triple["provenance"]["section"], 0.5)
[0m[49m[38;5;10m+     698[0m:[38;5;10m[49m         nlp_confidence = triple["confidence"]
[0m[49m[38;5;10m+     699[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     700[0m:[38;5;10m[49m         evidence_score = study_weight * section_weight * nlp_confidence
[0m[49m[38;5;10m+     701[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     702[0m:[38;5;10m[49m         triple["evidence_score"] = round(evidence_score, 4)
[0m[49m[38;5;10m+     703[0m:[38;5;10m[49m         triple["study_type"] = study_type
[0m[49m[38;5;10m+     704[0m:[38;5;10m[49m         scored.append(triple)
[0m[49m[38;5;10m+     705[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     706[0m:[38;5;10m[49m     return scored
[0m[49m[38;5;10m+     707[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     708[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     709[0m:[38;5;10m[49m def classify_study_type(pub_types: list[str]) -> str:
[0m[49m[38;5;10m+     710[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     711[0m:[38;5;10m[49m     Determine study type from PubMed publication type annotations.
[0m[49m[38;5;10m+     712[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     713[0m:[38;5;10m[49m     PubMed tags articles with publication types like "Randomized Controlled Trial",
[0m[49m[38;5;10m+     714[0m:[38;5;10m[49m     "Meta-Analysis", "Case Reports", etc. We map these to our evidence hierarchy.
[0m[49m[38;5;10m+     715[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     716[0m:[38;5;10m[49m     pub_types_lower = [pt.lower() for pt in pub_types]
[0m[49m[38;5;10m+     717[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     718[0m:[38;5;10m[49m     if "meta-analysis" in pub_types_lower:
[0m[49m[38;5;10m+     719[0m:[38;5;10m[49m         return "meta-analysis"
[0m[49m[38;5;10m+     720[0m:[38;5;10m[49m     if "systematic review" in pub_types_lower:
[0m[49m[38;5;10m+     721[0m:[38;5;10m[49m         return "systematic-review"
[0m[49m[38;5;10m+     722[0m:[38;5;10m[49m     if "randomized controlled trial" in pub_types_lower:
[0m[49m[38;5;10m+     723[0m:[38;5;10m[49m         return "rct"
[0m[49m[38;5;10m+     724[0m:[38;5;10m[49m     if "cohort study" in pub_types_lower or "observational study" in pub_types_lower:
[0m[49m[38;5;10m+     725[0m:[38;5;10m[49m         return "cohort"
[0m[49m[38;5;10m+     726[0m:[38;5;10m[49m     if "case-control study" in pub_types_lower:
[0m[49m[38;5;10m+     727[0m:[38;5;10m[49m         return "case-control"
[0m[49m[38;5;10m+     728[0m:[38;5;10m[49m     if "case reports" in pub_types_lower:
[0m[49m[38;5;10m+     729[0m:[38;5;10m[49m         return "case-report"
[0m[49m[38;5;10m+     730[0m:[38;5;10m[49m     if "review" in pub_types_lower:
[0m[49m[38;5;10m+     731[0m:[38;5;10m[49m         return "review"
[0m[49m[38;5;10m+     732[0m:[38;5;10m[49m     return "unknown"
[0m[49m[38;5;10m+     733[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     734[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     735[0m:[38;5;10m[49m def detect_conflicts(scored_triples: list[dict], existing_edges: list[dict]) -> list[dict]:
[0m[49m[38;5;10m+     736[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     737[0m:[38;5;10m[49m     Check new triples against existing graph edges for contradictions.
[0m[49m[38;5;10m+     738[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     739[0m:[38;5;10m[49m     A contradiction occurs when the same entity pair has opposing assertions:
[0m[49m[38;5;10m+     740[0m:[38;5;10m[49m     e.g., one paper says "drug X treats disease Y" and another says
[0m[49m[38;5;10m+     741[0m:[38;5;10m[49m     "drug X does NOT treat disease Y" (negated relationship).
[0m[49m[38;5;10m+     742[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     743[0m:[38;5;10m[49m     Conflicts above a threshold on both sides go to the human review queue.
[0m[49m[38;5;10m+     744[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     745[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     746[0m:[38;5;10m[49m         scored_triples: New triples with evidence scores
[0m[49m[38;5;10m+     747[0m:[38;5;10m[49m         existing_edges: Current edges from Neptune for the same entity pairs
[0m[49m[38;5;10m+     748[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     749[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     750[0m:[38;5;10m[49m         Triples with status field: "READY" or "PENDING_REVIEW"
[0m[49m[38;5;10m+     751[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     752[0m:[38;5;10m[49m     # Build lookup of existing edges by entity pair
[0m[49m[38;5;10m+     753[0m:[38;5;10m[49m     existing_by_pair = {}
[0m[49m[38;5;10m+     754[0m:[38;5;10m[49m     for edge in existing_edges:
[0m[49m[38;5;10m+     755[0m:[38;5;10m[49m         pair_key = f"{edge['subject_id']}:{edge['object_id']}:{edge['predicate']}"
[0m[49m[38;5;10m+     756[0m:[38;5;10m[49m         existing_by_pair[pair_key] = edge
[0m[49m[38;5;10m+     757[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     758[0m:[38;5;10m[49m     for triple in scored_triples:
[0m[49m[38;5;10m+     759[0m:[38;5;10m[49m         pair_key = f"{triple['subject_id']}:{triple['object_id']}:{triple['predicate']}"
[0m[49m[38;5;10m+     760[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     761[0m:[38;5;10m[49m         if pair_key in existing_by_pair:
[0m[49m[38;5;10m+     762[0m:[38;5;10m[49m             existing = existing_by_pair[pair_key]
[0m[49m[38;5;10m+     763[0m:[38;5;10m[49m             # Check for negation conflict
[0m[49m[38;5;10m+     764[0m:[38;5;10m[49m             if triple["is_negated"] != existing.get("is_negated", False):
[0m[49m[38;5;10m+     765[0m:[38;5;10m[49m                 # Contradiction detected. Send to human review.
[0m[49m[38;5;10m+     766[0m:[38;5;10m[49m                 triple["status"] = "PENDING_REVIEW"
[0m[49m[38;5;10m+     767[0m:[38;5;10m[49m                 triple["conflict_with"] = existing
[0m[49m[38;5;10m+     768[0m:[38;5;10m[49m                 send_to_review_queue(triple, existing)
[0m[49m[38;5;10m+     769[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+     770[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     771[0m:[38;5;10m[49m         triple["status"] = "READY"
[0m[49m[38;5;10m+     772[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     773[0m:[38;5;10m[49m     return scored_triples
[0m[49m[38;5;10m+     774[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     775[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     776[0m:[38;5;10m[49m def send_to_review_queue(new_triple: dict, existing_edge: dict):
[0m[49m[38;5;10m+     777[0m:[38;5;10m[49m     """Send a conflicting triple to the SQS review queue for human adjudication."""
[0m[49m[38;5;10m+     778[0m:[38;5;10m[49m     message = {
[0m[49m[38;5;10m+     779[0m:[38;5;10m[49m         "conflict_type": "CONTRADICTORY_ASSERTION",
[0m[49m[38;5;10m+     780[0m:[38;5;10m[49m         "new_triple": {
[0m[49m[38;5;10m+     781[0m:[38;5;10m[49m             "subject": new_triple["subject_label"],
[0m[49m[38;5;10m+     782[0m:[38;5;10m[49m             "predicate": new_triple["predicate"],
[0m[49m[38;5;10m+     783[0m:[38;5;10m[49m             "object": new_triple["object_label"],
[0m[49m[38;5;10m+     784[0m:[38;5;10m[49m             "is_negated": new_triple["is_negated"],
[0m[49m[38;5;10m+     785[0m:[38;5;10m[49m             "evidence_score": new_triple["evidence_score"],
[0m[49m[38;5;10m+     786[0m:[38;5;10m[49m             "source_pmid": new_triple["provenance"]["pmid"],
[0m[49m[38;5;10m+     787[0m:[38;5;10m[49m             "source_sentence": new_triple["provenance"]["sentence"],
[0m[49m[38;5;10m+     788[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+     789[0m:[38;5;10m[49m         "existing_edge": {
[0m[49m[38;5;10m+     790[0m:[38;5;10m[49m             "subject": existing_edge.get("subject_label", ""),
[0m[49m[38;5;10m+     791[0m:[38;5;10m[49m             "predicate": existing_edge.get("predicate", ""),
[0m[49m[38;5;10m+     792[0m:[38;5;10m[49m             "object": existing_edge.get("object_label", ""),
[0m[49m[38;5;10m+     793[0m:[38;5;10m[49m             "is_negated": existing_edge.get("is_negated", False),
[0m[49m[38;5;10m+     794[0m:[38;5;10m[49m             "evidence_score": existing_edge.get("evidence_score", 0),
[0m[49m[38;5;10m+     795[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+     796[0m:[38;5;10m[49m         "timestamp": datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+     797[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     798[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     799[0m:[38;5;10m[49m     sqs.send_message(
[0m[49m[38;5;10m+     800[0m:[38;5;10m[49m         QueueUrl=REVIEW_QUEUE_URL,
[0m[49m[38;5;10m+     801[0m:[38;5;10m[49m         MessageBody=json.dumps(message),
[0m[49m[38;5;10m+     802[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     803[0m:[38;5;10m[49m     logger.info("Sent conflict to review queue: %s vs existing", new_triple["subject_label"])
[0m[49m[38;5;10m+     804[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     805[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     806[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     807[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     808[0m:[38;5;10m[49m ## Step 7: Graph Insertion into Neptune
[0m[49m[38;5;10m+     809[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     810[0m:[38;5;10m[49m *The pseudocode calls this `insert_into_graph(scored_triples)`. It upserts nodes and edges into Amazon Neptune, accumulating evidence when the same relationship is extracted from multiple papers.*
[0m[49m[38;5;10m+     811[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     812[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     813[0m:[38;5;10m[49m from gremlin_python.driver import client as gremlin_client
[0m[49m[38;5;10m+     814[0m:[38;5;10m[49m from gremlin_python.driver.serializer import GraphSONSerializersV2d0
[0m[49m[38;5;10m+     815[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     816[0m:[38;5;10m[49m # Neptune connection. In production, use IAM authentication via
[0m[49m[38;5;10m+     817[0m:[38;5;10m[49m # the neptune-python-utils library or SigV4 signing.
[0m[49m[38;5;10m+     818[0m:[38;5;10m[49m # This example uses the basic Gremlin client for clarity.
[0m[49m[38;5;10m+     819[0m:[38;5;10m[49m neptune_gremlin_client = None
[0m[49m[38;5;10m+     820[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     821[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     822[0m:[38;5;10m[49m def get_neptune_client():
[0m[49m[38;5;10m+     823[0m:[38;5;10m[49m     """Lazy-initialize the Neptune Gremlin client."""
[0m[49m[38;5;10m+     824[0m:[38;5;10m[49m     global neptune_gremlin_client
[0m[49m[38;5;10m+     825[0m:[38;5;10m[49m     if neptune_gremlin_client is None:
[0m[49m[38;5;10m+     826[0m:[38;5;10m[49m         neptune_gremlin_client = gremlin_client.Client(
[0m[49m[38;5;10m+     827[0m:[38;5;10m[49m             f"wss://{NEPTUNE_ENDPOINT}:{NEPTUNE_PORT}/gremlin",
[0m[49m[38;5;10m+     828[0m:[38;5;10m[49m             "g",
[0m[49m[38;5;10m+     829[0m:[38;5;10m[49m             message_serializer=GraphSONSerializersV2d0(),
[0m[49m[38;5;10m+     830[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     831[0m:[38;5;10m[49m     return neptune_gremlin_client
[0m[49m[38;5;10m+     832[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     833[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     834[0m:[38;5;10m[49m def insert_into_graph(scored_triples: list[dict]):
[0m[49m[38;5;10m+     835[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     836[0m:[38;5;10m[49m     Insert approved triples into Neptune as graph edges between entity nodes.
[0m[49m[38;5;10m+     837[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     838[0m:[38;5;10m[49m     For each triple:
[0m[49m[38;5;10m+     839[0m:[38;5;10m[49m     1. Upsert the subject node (create if new, update timestamp if exists)
[0m[49m[38;5;10m+     840[0m:[38;5;10m[49m     2. Upsert the object node
[0m[49m[38;5;10m+     841[0m:[38;5;10m[49m     3. Check if this exact edge already exists
[0m[49m[38;5;10m+     842[0m:[38;5;10m[49m     4. If exists: accumulate evidence (add provenance, update score)
[0m[49m[38;5;10m+     843[0m:[38;5;10m[49m     5. If new: create the edge with full metadata
[0m[49m[38;5;10m+     844[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     845[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     846[0m:[38;5;10m[49m         scored_triples: List of triples with status "READY" or "PENDING_REVIEW"
[0m[49m[38;5;10m+     847[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     848[0m:[38;5;10m[49m     client = get_neptune_client()
[0m[49m[38;5;10m+     849[0m:[38;5;10m[49m     inserted = 0
[0m[49m[38;5;10m+     850[0m:[38;5;10m[49m     updated = 0
[0m[49m[38;5;10m+     851[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     852[0m:[38;5;10m[49m     for triple in scored_triples:
[0m[49m[38;5;10m+     853[0m:[38;5;10m[49m         if triple["status"] != "READY":
[0m[49m[38;5;10m+     854[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     855[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     856[0m:[38;5;10m[49m         # Upsert subject node
[0m[49m[38;5;10m+     857[0m:[38;5;10m[49m         upsert_node(
[0m[49m[38;5;10m+     858[0m:[38;5;10m[49m             client,
[0m[49m[38;5;10m+     859[0m:[38;5;10m[49m             node_id=triple["subject_id"],
[0m[49m[38;5;10m+     860[0m:[38;5;10m[49m             label=triple["subject_label"],
[0m[49m[38;5;10m+     861[0m:[38;5;10m[49m             node_type=triple["subject_type"],
[0m[49m[38;5;10m+     862[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     863[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     864[0m:[38;5;10m[49m         # Upsert object node
[0m[49m[38;5;10m+     865[0m:[38;5;10m[49m         upsert_node(
[0m[49m[38;5;10m+     866[0m:[38;5;10m[49m             client,
[0m[49m[38;5;10m+     867[0m:[38;5;10m[49m             node_id=triple["object_id"],
[0m[49m[38;5;10m+     868[0m:[38;5;10m[49m             label=triple["object_label"],
[0m[49m[38;5;10m+     869[0m:[38;5;10m[49m             node_type=triple["object_type"],
[0m[49m[38;5;10m+     870[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     871[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     872[0m:[38;5;10m[49m         # Check for existing edge between these nodes with same predicate
[0m[49m[38;5;10m+     873[0m:[38;5;10m[49m         existing = find_existing_edge(
[0m[49m[38;5;10m+     874[0m:[38;5;10m[49m             client,
[0m[49m[38;5;10m+     875[0m:[38;5;10m[49m             subject_id=triple["subject_id"],
[0m[49m[38;5;10m+     876[0m:[38;5;10m[49m             object_id=triple["object_id"],
[0m[49m[38;5;10m+     877[0m:[38;5;10m[49m             predicate=triple["predicate"],
[0m[49m[38;5;10m+     878[0m:[38;5;10m[49m             is_negated=triple["is_negated"],
[0m[49m[38;5;10m+     879[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     880[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     881[0m:[38;5;10m[49m         if existing:
[0m[49m[38;5;10m+     882[0m:[38;5;10m[49m             # Edge exists: accumulate evidence from this new source
[0m[49m[38;5;10m+     883[0m:[38;5;10m[49m             update_edge_evidence(client, existing, triple)
[0m[49m[38;5;10m+     884[0m:[38;5;10m[49m             updated += 1
[0m[49m[38;5;10m+     885[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+     886[0m:[38;5;10m[49m             # New edge: create it with full metadata
[0m[49m[38;5;10m+     887[0m:[38;5;10m[49m             create_edge(client, triple)
[0m[49m[38;5;10m+     888[0m:[38;5;10m[49m             inserted += 1
[0m[49m[38;5;10m+     889[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     890[0m:[38;5;10m[49m     logger.info("Graph update complete: %d inserted, %d updated", inserted, updated)
[0m[49m[38;5;10m+     891[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     892[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     893[0m:[38;5;10m[49m def upsert_node(client, node_id: str, label: str, node_type: str):
[0m[49m[38;5;10m+     894[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     895[0m:[38;5;10m[49m     Create a node if it doesn't exist, or update its timestamp if it does.
[0m[49m[38;5;10m+     896[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     897[0m:[38;5;10m[49m     Neptune Gremlin uses the fold/coalesce/unfold pattern for upserts.
[0m[49m[38;5;10m+     898[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     899[0m:[38;5;10m[49m     now = datetime.now(timezone.utc).isoformat()
[0m[49m[38;5;10m+     900[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     901[0m:[38;5;10m[49m     # The fold().coalesce().unfold() pattern is Neptune's idiomatic upsert.
[0m[49m[38;5;10m+     902[0m:[38;5;10m[49m     # If the vertex exists, update it. If not, create it.
[0m[49m[38;5;10m+     903[0m:[38;5;10m[49m     query = (
[0m[49m[38;5;10m+     904[0m:[38;5;10m[49m         "g.V().has('entity', 'entity_id', entity_id)"
[0m[49m[38;5;10m+     905[0m:[38;5;10m[49m         ".fold()"
[0m[49m[38;5;10m+     906[0m:[38;5;10m[49m         ".coalesce("
[0m[49m[38;5;10m+     907[0m:[38;5;10m[49m         "  unfold().property('updated_at', now),"
[0m[49m[38;5;10m+     908[0m:[38;5;10m[49m         "  addV('entity').property('entity_id', entity_id)"
[0m[49m[38;5;10m+     909[0m:[38;5;10m[49m         "    .property('label_text', label)"
[0m[49m[38;5;10m+     910[0m:[38;5;10m[49m         "    .property('entity_type', node_type)"
[0m[49m[38;5;10m+     911[0m:[38;5;10m[49m         "    .property('created_at', now)"
[0m[49m[38;5;10m+     912[0m:[38;5;10m[49m         "    .property('updated_at', now)"
[0m[49m[38;5;10m+     913[0m:[38;5;10m[49m         ")"
[0m[49m[38;5;10m+     914[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     915[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     916[0m:[38;5;10m[49m     client.submit(
[0m[49m[38;5;10m+     917[0m:[38;5;10m[49m         query,
[0m[49m[38;5;10m+     918[0m:[38;5;10m[49m         bindings={
[0m[49m[38;5;10m+     919[0m:[38;5;10m[49m             "entity_id": node_id,
[0m[49m[38;5;10m+     920[0m:[38;5;10m[49m             "label": label,
[0m[49m[38;5;10m+     921[0m:[38;5;10m[49m             "node_type": node_type,
[0m[49m[38;5;10m+     922[0m:[38;5;10m[49m             "now": now,
[0m[49m[38;5;10m+     923[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+     924[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     925[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     926[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     927[0m:[38;5;10m[49m def find_existing_edge(client, subject_id: str, object_id: str, predicate: str, is_negated: bool) -> dict | None:
[0m[49m[38;5;10m+     928[0m:[38;5;10m[49m     """Check if an edge already exists between two nodes with the same predicate."""
[0m[49m[38;5;10m+     929[0m:[38;5;10m[49m     query = (
[0m[49m[38;5;10m+     930[0m:[38;5;10m[49m         "g.V().has('entity', 'entity_id', subject_id)"
[0m[49m[38;5;10m+     931[0m:[38;5;10m[49m         ".outE('relationship').has('predicate', predicate).has('is_negated', is_negated)"
[0m[49m[38;5;10m+     932[0m:[38;5;10m[49m         ".where(inV().has('entity_id', object_id))"
[0m[49m[38;5;10m+     933[0m:[38;5;10m[49m         ".valueMap(true).toList()"
[0m[49m[38;5;10m+     934[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     935[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     936[0m:[38;5;10m[49m     result = client.submit(
[0m[49m[38;5;10m+     937[0m:[38;5;10m[49m         query,
[0m[49m[38;5;10m+     938[0m:[38;5;10m[49m         bindings={
[0m[49m[38;5;10m+     939[0m:[38;5;10m[49m             "subject_id": subject_id,
[0m[49m[38;5;10m+     940[0m:[38;5;10m[49m             "object_id": object_id,
[0m[49m[38;5;10m+     941[0m:[38;5;10m[49m             "predicate": predicate,
[0m[49m[38;5;10m+     942[0m:[38;5;10m[49m             "is_negated": is_negated,
[0m[49m[38;5;10m+     943[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+     944[0m:[38;5;10m[49m     ).all().result()
[0m[49m[38;5;10m+     945[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     946[0m:[38;5;10m[49m     if result:
[0m[49m[38;5;10m+     947[0m:[38;5;10m[49m         return result[0]
[0m[49m[38;5;10m+     948[0m:[38;5;10m[49m     return None
[0m[49m[38;5;10m+     949[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     950[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     951[0m:[38;5;10m[49m def create_edge(client, triple: dict):
[0m[49m[38;5;10m+     952[0m:[38;5;10m[49m     """Create a new edge in Neptune with full provenance metadata."""
[0m[49m[38;5;10m+     953[0m:[38;5;10m[49m     now = datetime.now(timezone.utc).isoformat()
[0m[49m[38;5;10m+     954[0m:[38;5;10m[49m     provenance_json = json.dumps([triple["provenance"]])
[0m[49m[38;5;10m+     955[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     956[0m:[38;5;10m[49m     query = (
[0m[49m[38;5;10m+     957[0m:[38;5;10m[49m         "g.V().has('entity', 'entity_id', subject_id)"
[0m[49m[38;5;10m+     958[0m:[38;5;10m[49m         ".addE('relationship')"
[0m[49m[38;5;10m+     959[0m:[38;5;10m[49m         ".to(g.V().has('entity', 'entity_id', object_id))"
[0m[49m[38;5;10m+     960[0m:[38;5;10m[49m         ".property('predicate', predicate)"
[0m[49m[38;5;10m+     961[0m:[38;5;10m[49m         ".property('is_negated', is_negated)"
[0m[49m[38;5;10m+     962[0m:[38;5;10m[49m         ".property('is_speculative', is_speculative)"
[0m[49m[38;5;10m+     963[0m:[38;5;10m[49m         ".property('evidence_score', evidence_score)"
[0m[49m[38;5;10m+     964[0m:[38;5;10m[49m         ".property('support_count', 1)"
[0m[49m[38;5;10m+     965[0m:[38;5;10m[49m         ".property('provenance', provenance_json)"
[0m[49m[38;5;10m+     966[0m:[38;5;10m[49m         ".property('first_seen', now)"
[0m[49m[38;5;10m+     967[0m:[38;5;10m[49m         ".property('last_updated', now)"
[0m[49m[38;5;10m+     968[0m:[38;5;10m[49m         ".property('status', 'ACTIVE')"
[0m[49m[38;5;10m+     969[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     970[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     971[0m:[38;5;10m[49m     client.submit(
[0m[49m[38;5;10m+     972[0m:[38;5;10m[49m         query,
[0m[49m[38;5;10m+     973[0m:[38;5;10m[49m         bindings={
[0m[49m[38;5;10m+     974[0m:[38;5;10m[49m             "subject_id": triple["subject_id"],
[0m[49m[38;5;10m+     975[0m:[38;5;10m[49m             "object_id": triple["object_id"],
[0m[49m[38;5;10m+     976[0m:[38;5;10m[49m             "predicate": triple["predicate"],
[0m[49m[38;5;10m+     977[0m:[38;5;10m[49m             "is_negated": triple["is_negated"],
[0m[49m[38;5;10m+     978[0m:[38;5;10m[49m             "is_speculative": triple["is_speculative"],
[0m[49m[38;5;10m+     979[0m:[38;5;10m[49m             "evidence_score": triple["evidence_score"],
[0m[49m[38;5;10m+     980[0m:[38;5;10m[49m             "provenance_json": provenance_json,
[0m[49m[38;5;10m+     981[0m:[38;5;10m[49m             "now": now,
[0m[49m[38;5;10m+     982[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+     983[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     984[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     985[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     986[0m:[38;5;10m[49m def update_edge_evidence(client, existing_edge: dict, new_triple: dict):
[0m[49m[38;5;10m+     987[0m:[38;5;10m[49m     """Add new provenance to an existing edge and recalculate evidence score."""
[0m[49m[38;5;10m+     988[0m:[38;5;10m[49m     now = datetime.now(timezone.utc).isoformat()
[0m[49m[38;5;10m+     989[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     990[0m:[38;5;10m[49m     # In production, you'd fetch the existing provenance list, append,
[0m[49m[38;5;10m+     991[0m:[38;5;10m[49m     # and recalculate the aggregate score. Here we show the update pattern.
[0m[49m[38;5;10m+     992[0m:[38;5;10m[49m     # Neptune doesn't support array append natively in Gremlin, so you'd
[0m[49m[38;5;10m+     993[0m:[38;5;10m[49m     # typically store provenance as a JSON string and parse/update it.
[0m[49m[38;5;10m+     994[0m:[38;5;10m[49m     query = (
[0m[49m[38;5;10m+     995[0m:[38;5;10m[49m         "g.E(edge_id)"
[0m[49m[38;5;10m+     996[0m:[38;5;10m[49m         ".property('support_count', new_count)"
[0m[49m[38;5;10m+     997[0m:[38;5;10m[49m         ".property('evidence_score', new_score)"
[0m[49m[38;5;10m+     998[0m:[38;5;10m[49m         ".property('last_updated', now)"
[0m[49m[38;5;10m+     999[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    1000[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1001[0m:[38;5;10m[49m     # Simple evidence aggregation: average of all supporting evidence scores
[0m[49m[38;5;10m+    1002[0m:[38;5;10m[49m     old_count = existing_edge.get("support_count", [1])[0] if isinstance(existing_edge.get("support_count"), list) else existing_edge.get("support_count", 1)
[0m[49m[38;5;10m+    1003[0m:[38;5;10m[49m     old_score = existing_edge.get("evidence_score", [0.5])[0] if isinstance(existing_edge.get("evidence_score"), list) else existing_edge.get("evidence_score", 0.5)
[0m[49m[38;5;10m+    1004[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1005[0m:[38;5;10m[49m     new_count = old_count + 1
[0m[49m[38;5;10m+    1006[0m:[38;5;10m[49m     new_score = ((old_score * old_count) + new_triple["evidence_score"]) / new_count
[0m[49m[38;5;10m+    1007[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1008[0m:[38;5;10m[49m     edge_id = existing_edge.get("id", existing_edge.get("T.id"))
[0m[49m[38;5;10m+    1009[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1010[0m:[38;5;10m[49m     client.submit(
[0m[49m[38;5;10m+    1011[0m:[38;5;10m[49m         query,
[0m[49m[38;5;10m+    1012[0m:[38;5;10m[49m         bindings={
