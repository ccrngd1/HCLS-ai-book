[0m[49m[38;5;10m+     23[0m:[38;5;10m[49m This example runs locally for demonstration. In practice, the training step runs on SageMaker with GPU instances, and the inference step runs behind a SageMaker endpoint.
[0m[49m[38;5;10m+     24[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     25[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     26[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     27[0m:[38;5;10m[49m ## Config and Constants
[0m[49m[38;5;10m+     28[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     29[0m:[38;5;10m[49m Before we get to the logic, here's the configuration that drives the entire system. These constants encode clinical knowledge and value judgments. The reward weights in particular are not learned parameters; they're decisions made by oncologists about how to balance efficacy against toxicity. Different institutions might set them differently, and that's fine.
[0m[49m[38;5;10m+     30[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     31[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     32[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+     33[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+     34[0m:[38;5;10m[49m import uuid
[0m[49m[38;5;10m+     35[0m:[38;5;10m[49m from datetime import datetime
[0m[49m[38;5;10m+     36[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+     37[0m:[38;5;10m[49m from typing import Dict, List, Tuple, Optional
[0m[49m[38;5;10m+     38[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     39[0m:[38;5;10m[49m import numpy as np
[0m[49m[38;5;10m+     40[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+     41[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+     42[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     43[0m:[38;5;10m[49m # --- Logging ---
[0m[49m[38;5;10m+     44[0m:[38;5;10m[49m # Never log PHI (patient identifiers, lab values, diagnosis text).
[0m[49m[38;5;10m+     45[0m:[38;5;10m[49m # Log operational metrics only: counts, latencies, error types.
[0m[49m[38;5;10m+     46[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+     47[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+     48[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     49[0m:[38;5;10m[49m # --- AWS Configuration ---
[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m AWS_REGION = "us-east-1"
[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m # --- Clinical Constants ---
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m # These define the state space boundaries and safety thresholds.
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m # They come from oncology guidelines (NCCN, ASCO) and institutional protocols.
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m # Absolute neutrophil count thresholds (cells/microL)
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m ANC_HOLD_THRESHOLD = 1000       # Below this: hold treatment entirely
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m ANC_REDUCE_THRESHOLD = 1500     # Below this: consider dose reduction
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m # Platelet thresholds (cells/microL)
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m PLT_HOLD_THRESHOLD = 50000      # Below this: hold treatment
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m PLT_REDUCE_THRESHOLD = 75000    # Below this: max 50% dose
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m # Bilirubin threshold (mg/dL). Upper limit of normal is ~1.2.
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m BILIRUBIN_ULN = 1.2
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m # ECOG Performance Status: 0 = fully active, 4 = completely disabled
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m MAX_ECOG_FOR_TREATMENT = 2      # ECOG 3+ generally too poor for cytotoxic chemo
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m # --- Reward Function Weights ---
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m # These encode the efficacy-toxicity tradeoff. They are clinical value judgments.
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m # A more aggressive oncologist might increase TUMOR_WEIGHT.
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m # A more conservative one might increase TOXICITY_PENALTIES.
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m TUMOR_WEIGHT = 10.0
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m MODERATE_TOXICITY_PENALTY = 3.0     # Grade 3 adverse event
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m SEVERE_TOXICITY_PENALTY = 15.0      # Grade 4 adverse event (life-threatening)
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m DISCONTINUATION_PENALTY = 25.0      # Treatment had to stop entirely
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m DOSE_INTENSITY_BONUS = 1.0          # Maintaining >= 85% relative dose intensity
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m # --- Action Space ---
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m # Discrete dose levels as fractions of protocol dose.
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m # In practice, oncologists think in these increments.
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m DOSE_LEVELS = [0.0, 0.25, 0.50, 0.75, 1.0]
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m # Delay options (days). 0 = on schedule.
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m DELAY_OPTIONS = [0, 7, 14]
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m # G-CSF (growth factor support) options.
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m GCSF_OPTIONS = [False, True]
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m # Total number of discrete actions:
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m # 5 dose levels * 3 delay options * 2 G-CSF options = 30 actions
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m NUM_ACTIONS = len(DOSE_LEVELS) * len(DELAY_OPTIONS) * len(GCSF_OPTIONS)
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m # --- State Space ---
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m # 13 features representing what the clinician knows at decision time.
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m STATE_DIM = 13
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m # --- Training Hyperparameters ---
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m GAMMA = 0.99            # Discount factor (value future rewards almost as much as immediate)
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m CQL_ALPHA = 1.0         # CQL conservatism weight (higher = more conservative)
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m LEARNING_RATE = 3e-4
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m BATCH_SIZE = 64
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m NUM_EPOCHS = 100
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m EVAL_INTERVAL = 10
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m # --- DynamoDB Table Names ---
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m STATE_TABLE = "chemo-dose-patient-states"
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m RECOMMENDATION_TABLE = "chemo-dose-recommendations"
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m ## Step 1: Define the State Representation
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m *The main recipe describes a 13-feature state vector capturing labs, tumor status, toxicity, and patient characteristics. This step builds that vector from raw clinical data.*
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m ```python
