[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m ```pseudocode
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m FUNCTION map_to_taxonomy(findings):
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m     structured_findings = empty list
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m     FOR each finding in findings WHERE finding.assertion == "POSITIVE":
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m         // Look up the primary SDOH domain for this finding
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m         primary_domain = finding.sdoh_domains[0].label
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m         // Get the standardized codes from the crosswalk
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m         codes = SDOH_TAXONOMY_MAP[primary_domain]
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m         IF codes is not NULL:
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m             append to structured_findings: {
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m                 patient_id:       metadata.patient_id,
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m                 encounter_id:     metadata.encounter_id,
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m                 sdoh_domain:      primary_domain,
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m                 extracted_text:   finding.text,
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m                 source_sentence:  finding.source_sentence,
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m                 source_section:   finding.section,
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m                 assertion:        finding.assertion,
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m                 confidence:       finding.confidence,
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m                 suggested_icd10:  codes.icd10,
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m                 gravity_codes:    codes.gravity_project,
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m                 display_terms:    codes.display,
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m                 extraction_time:  current UTC timestamp
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m     RETURN structured_findings
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m **Step 6: Store and surface findings.** Write structured SDOH findings to DynamoDB with keys that support the queries care management platforms need: "all SDOH findings for patient X," "all patients with active housing instability," "all findings from encounter Y." Include the full provenance chain (which note, which section, which sentence) so reviewers can verify accuracy. Set a TTL strategy if your organization requires SDOH data to age out, though most will want longitudinal tracking.
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m ```pseudocode
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m FUNCTION store_findings(structured_findings):
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m     FOR each finding in structured_findings:
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m         // Write to DynamoDB with composite keys for flexible querying
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m         // Partition key: patient_id (enables all-findings-for-patient queries)
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m         // Sort key: domain#timestamp (enables filtering by domain and time ordering)
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m         write record to DynamoDB table "sdoh-findings":
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m             pk                = finding.patient_id
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m             sk                = finding.sdoh_domain + "#" + finding.extraction_time
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m             encounter_id      = finding.encounter_id
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m             domain            = finding.sdoh_domain
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m             extracted_text    = finding.extracted_text
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m             source_sentence   = finding.source_sentence
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m             source_section    = finding.source_section
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m             assertion         = finding.assertion
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m             confidence        = finding.confidence
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m             suggested_icd10   = finding.suggested_icd10
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m             gravity_codes     = finding.gravity_codes
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m             needs_review      = (finding.confidence < 0.80)
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m             reviewed          = false
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m             review_outcome    = NULL
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m     // Also write a summary record for population health queries
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m     // "How many patients have active food insecurity?"
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m     update_population_health_counters(structured_findings)
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m     RETURN count of findings written
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m > **Curious how this looks in Python?** The pseudocode above covers the concepts. If you'd like to see sample Python code that demonstrates these patterns using boto3, check out the [Python Example](chapter08.06-python-example). It walks through each step with inline comments and notes on what you'd need to change for a real deployment.
