[0m[49m[38;5;10m+      338[0m:[38;5;10m[49m             "confidence": "degraded",
[0m[49m[38;5;10m+      339[0m:[38;5;10m[49m             "recommendation": "review_suggested",
[0m[49m[38;5;10m+      340[0m:[38;5;10m[49m             "explanation": "Similarity layer unavailable. Using primary model only.",
[0m[49m[38;5;10m+      341[0m:[38;5;10m[49m             "similarity_available": false
