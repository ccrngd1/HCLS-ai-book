[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m     The denial probability for each claim is driven by interactions between
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m     features, mimicking how real payer adjudication works:
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m     - Certain payer + procedure combinations have high denial rates
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m     - Missing prior auth when required almost guarantees denial
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m     - Provider history and place of service modify risk
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m     Returns a DataFrame with features and a binary 'denied' label.
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m     rng = np.random.default_rng(seed)
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m     # --- Generate base features ---
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m     payers = list(PAYER_DENIAL_RATES.keys())
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m     cpt_codes = list(CPT_RISK_MULTIPLIERS.keys())
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m     pos_codes = list(PLACE_OF_SERVICE.keys())
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m     provider_types = ["MD", "DO", "NP", "PA", "Facility"]
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m     specialties = [
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m         "Family Medicine", "Internal Medicine", "Orthopedics",
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m         "Cardiology", "Radiology", "Emergency Medicine",
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m         "Psychiatry", "General Surgery", "Gastroenterology",
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m         "Neurology",
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m     # Sample ICD-10 codes (simplified; real data has 70k+ codes)
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m     icd10_codes = [
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m         "M17.11", "M54.5", "I10", "E11.9", "J06.9",
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m         "K21.0", "G43.909", "F32.1", "M79.3", "R10.9",
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m         "Z00.00", "Z12.31", "S82.001A", "M25.511", "J18.9",
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m     # Modifiers that affect denial risk
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m     modifier_options = [None, "25", "26", "59", "76", "LT", "RT"]
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m     # Build the claims DataFrame
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m     data = {
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m         "claim_id": [f"CLM-{i:07d}" for i in range(n_claims)],
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m         "payer": rng.choice(payers, n_claims),
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m         "cpt_code": rng.choice(cpt_codes, n_claims),
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m         "icd10_primary": rng.choice(icd10_codes, n_claims),
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m         "num_diagnoses": rng.integers(1, 6, n_claims),
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m         "place_of_service": rng.choice(pos_codes, n_claims),
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m         "provider_type": rng.choice(provider_types, n_claims),
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m         "specialty": rng.choice(specialties, n_claims),
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m         "patient_age": rng.integers(18, 90, n_claims),
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m         "claim_amount": np.round(rng.lognormal(mean=6.0, sigma=1.2, size=n_claims), 2),
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m         "num_line_items": rng.integers(1, 8, n_claims),
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m         "modifier_1": rng.choice(modifier_options, n_claims),
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m         "has_secondary_insurance": rng.choice([0, 1], n_claims, p=[0.7, 0.3]),
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m         "is_resubmission": rng.choice([0, 1], n_claims, p=[0.92, 0.08]),
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m         "days_since_service": rng.integers(1, 45, n_claims),
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m     df = pd.DataFrame(data)
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m     # --- Assign prior-auth requirement and status ---
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m     # High-risk CPT codes (multiplier > 1.3) are more likely to require PA.
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m     pa_required_prob = df["cpt_code"].map(
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m         lambda c: 0.7 if CPT_RISK_MULTIPLIERS.get(c, 1.0) > 1.3 else 0.1
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m     df["pa_required"] = rng.binomial(1, pa_required_prob)
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m     # If PA is required, it's present ~70% of the time (some are missed).
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m     df["pa_on_file"] = np.where(
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m         df["pa_required"] == 1,
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m         rng.binomial(1, 0.70, n_claims),
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m         0  # If not required, field is 0
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m     # --- Compute denial probability as a function of feature interactions ---
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m     # This is the "oracle" that mimics payer adjudication logic.
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m     # Start with payer base denial rate
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m     denial_prob = df["payer"].map(PAYER_DENIAL_RATES).values.astype(float)
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m     # Apply CPT risk multiplier (interaction: payer rate * procedure risk)
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m     cpt_mult = df["cpt_code"].map(CPT_RISK_MULTIPLIERS).fillna(1.0).values
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m     denial_prob = denial_prob * cpt_mult
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m     # PA required but missing is a near-guarantee of denial
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m     pa_missing = (df["pa_required"] == 1) & (df["pa_on_file"] == 0)
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m     denial_prob = np.where(pa_missing, np.clip(denial_prob + 0.55, 0, 0.95), denial_prob)
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m     # Place of service interactions (outpatient surgery scrutinized more)
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m     outpatient_surgical = df["place_of_service"].isin(["22", "24"])
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m     denial_prob = np.where(outpatient_surgical, denial_prob * 1.2, denial_prob)
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m     # High claim amounts get more scrutiny
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m     high_amount = df["claim_amount"] > 5000
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m     denial_prob = np.where(high_amount, denial_prob * 1.15, denial_prob)
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m     # Resubmissions have slightly lower denial (issue was fixed)
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m     denial_prob = np.where(df["is_resubmission"] == 1, denial_prob * 0.7, denial_prob)
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m     # Late submissions (>30 days) get timely filing denials
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m     late_filing = df["days_since_service"] > 30
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m     denial_prob = np.where(late_filing, denial_prob + 0.10, denial_prob)
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     # Add noise and clip to [0, 1]
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m     denial_prob = np.clip(denial_prob + rng.normal(0, 0.03, n_claims), 0.01, 0.95)
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m     # Generate binary outcome
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m     df["denied"] = rng.binomial(1, denial_prob)
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m         "Generated %d claims. Denial rate: %.1f%% (%d denied, %d paid)",
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m         n_claims,
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m         df["denied"].mean() * 100,
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m         df["denied"].sum(),
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m         (1 - df["denied"]).sum(),
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m     return df
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m ## Step 2: Feature Engineering and Encoding
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m *The main recipe discusses how categorical features (CPT codes, payers, etc.) need careful encoding for tree models. Here we handle that encoding plus derived interaction features that carry most of the predictive signal.*
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m from sklearn.model_selection import train_test_split
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m from sklearn.preprocessing import LabelEncoder
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m def prepare_features(df: pd.DataFrame) -> tuple:
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m     Encode categorical features and split into train/test sets.
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m     For gradient-boosted trees, we use label encoding for categoricals
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m     (trees can split on ordinal-encoded categoricals just fine, unlike
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     linear models which need one-hot encoding). For the logistic regression
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m     baseline, we'll one-hot encode separately.
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m         X_train, X_test, y_train, y_test, feature_names, label_encoders
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m     # Create a copy so we don't mutate the original
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m     features = df.copy()
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m     # --- Derived interaction features ---
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m     # These capture the payer-procedure interactions that drive most denials.
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m     # Payer + CPT interaction (the single most predictive feature)
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m     features["payer_cpt"] = features["payer"] + "_" + features["cpt_code"]
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m     # PA gap: required but not on file
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m     features["pa_gap"] = (
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m         (features["pa_required"] == 1) & (features["pa_on_file"] == 0)
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m     ).astype(int)
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m     # Log-transformed claim amount (reduces skew for the model)
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m     features["claim_amount_log"] = np.log1p(features["claim_amount"])
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m     # --- Label-encode categoricals ---
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m     categorical_cols = [
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m         "payer", "cpt_code", "icd10_primary", "place_of_service",
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m         "provider_type", "specialty", "modifier_1", "payer_cpt",
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m     label_encoders = {}
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m     for col in categorical_cols:
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m         le = LabelEncoder()
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m         # Handle None/NaN in modifier column
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m         features[col] = features[col].fillna("NONE")
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m         features[col] = le.fit_transform(features[col])
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m         label_encoders[col] = le
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m     # --- Select model features ---
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m     feature_cols = [
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m         "payer", "cpt_code", "icd10_primary", "place_of_service",
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m         "provider_type", "specialty", "modifier_1", "payer_cpt",
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m         "num_diagnoses", "patient_age", "claim_amount_log",
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m         "num_line_items", "pa_required", "pa_on_file", "pa_gap",
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m         "has_secondary_insurance", "is_resubmission", "days_since_service",
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m     X = features[feature_cols]
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m     y = features["denied"]
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m     # Stratified split preserves the class imbalance ratio in both sets
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m     X_train, X_test, y_train, y_test = train_test_split(
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m         X, y, test_size=0.2, random_state=42, stratify=y
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m         "Train set: %d claims (%.1f%% denied). Test set: %d claims (%.1f%% denied)",
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m         len(y_train), y_train.mean() * 100,
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m         len(y_test), y_test.mean() * 100,
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m     return X_train, X_test, y_train, y_test, feature_cols, label_encoders
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m ## Step 3: Train Logistic Regression Baseline
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m *Always start with a simple baseline. Logistic regression gives you a floor to beat and helps validate that the signal is in the data. If logistic regression gets 0.75+ AUC, you know a more complex model will do even better.*
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m from sklearn.linear_model import LogisticRegression
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m from sklearn.preprocessing import StandardScaler
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m from sklearn.metrics import roc_auc_score, average_precision_score
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m def train_baseline(X_train, X_test, y_train, y_test) -> dict:
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m     Train a logistic regression baseline with class weighting.
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m     Logistic regression needs scaled features (unlike trees) and handles
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m     class imbalance via the class_weight parameter. It's fast, interpretable,
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m     and sets a performance floor.
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m     # Scale features for logistic regression (trees don't need this)
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m     scaler = StandardScaler()
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m     X_train_scaled = scaler.fit_transform(X_train)
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m     X_test_scaled = scaler.transform(X_test)
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m     # class_weight='balanced' adjusts weights inversely proportional to
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m     # class frequency. Equivalent to oversampling the minority class.
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m     lr_model = LogisticRegression(
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m         class_weight="balanced",
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m         max_iter=1000,
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m         random_state=42,
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m         solver="lbfgs",
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m     lr_model.fit(X_train_scaled, y_train)
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m     # Predict probabilities (not hard labels) for threshold-independent evaluation
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m     y_pred_proba = lr_model.predict_proba(X_test_scaled)[:, 1]
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m     roc_auc = roc_auc_score(y_test, y_pred_proba)
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m     pr_auc = average_precision_score(y_test, y_pred_proba)
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m     logger.info("Logistic Regression baseline: ROC-AUC=%.4f, PR-AUC=%.4f", roc_auc, pr_auc)
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m         "model": lr_model,
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m         "scaler": scaler,
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m         "roc_auc": roc_auc,
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m         "pr_auc": pr_auc,
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m ## Step 4: Train XGBoost with Class Imbalance Handling
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m *This is the main model. XGBoost handles the heterogeneous feature landscape (categoricals, numerics, binary flags) and discovers non-linear interactions automatically. The critical parameter for imbalanced data is `scale_pos_weight`, which tells the model to penalize misclassifying the minority class more heavily.*
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m import xgboost as xgb
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m def train_xgboost(X_train, X_test, y_train, y_test) -> dict:
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m     Train an XGBoost classifier with class imbalance handling.
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m     Key choices:
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m     - scale_pos_weight: ratio of negative to positive examples. Tells the
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m       model that missing a denial is ~7x worse than a false alarm.
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m     - eval_metric 'aucpr': optimizes for precision-recall AUC, which is
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m       more informative than ROC-AUC for imbalanced data.
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m     - early_stopping_rounds: prevents overfitting by stopping when
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m       validation performance plateaus.
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m     # Compute class weight ratio
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m     # If 12% denial rate: (1 - 0.12) / 0.12 = 7.3
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m     n_positive = y_train.sum()
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m     n_negative = len(y_train) - n_positive
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m     scale_pos_weight = n_negative / n_positive
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m         "Class balance: %d denied (%.1f%%), %d paid. scale_pos_weight=%.2f",
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m         n_positive, (n_positive / len(y_train)) * 100,
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m         n_negative, scale_pos_weight,
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m     # Create DMatrix objects (XGBoost's optimized data structure)
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m     dtrain = xgb.DMatrix(X_train, label=y_train)
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m     dtest = xgb.DMatrix(X_test, label=y_test)
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m     params = {
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m         "objective": "binary:logistic",
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m         "eval_metric": "aucpr",            # precision-recall AUC
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m         "max_depth": 6,                    # tree depth (6 is a good default)
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m         "eta": 0.03,                       # learning rate (low for stability)
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m         "subsample": 0.8,                  # row subsampling per tree
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m         "colsample_bytree": 0.7,           # feature subsampling per tree
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m         "scale_pos_weight": scale_pos_weight,
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m         "min_child_weight": 10,            # minimum samples per leaf
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m         "gamma": 0.1,                      # minimum loss reduction for split
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m         "tree_method": "hist",             # faster training with histograms
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m         "random_state": 42,
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m     # Train with early stopping on validation set
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m     model = xgb.train(
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m         params,
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m         dtrain,
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m         num_boost_round=500,
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m         evals=[(dtrain, "train"), (dtest, "val")],
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m         early_stopping_rounds=20,
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m         verbose_eval=50,                   # print every 50 rounds
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m     # Evaluate
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m     y_pred_proba = model.predict(dtest)
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m     roc_auc = roc_auc_score(y_test, y_pred_proba)
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m     pr_auc = average_precision_score(y_test, y_pred_proba)
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m     logger.info("XGBoost: ROC-AUC=%.4f, PR-AUC=%.4f", roc_auc, pr_auc)
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m         "model": model,
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m         "roc_auc": roc_auc,
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m         "pr_auc": pr_auc,
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m         "best_iteration": model.best_iteration,
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m ## Step 5: Evaluate with Imbalance-Appropriate Metrics
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m *Raw accuracy is meaningless for imbalanced data. A model predicting "paid" for everything gets 88% accuracy but catches zero denials. We evaluate with precision-recall curves, PR-AUC, confusion matrices at chosen thresholds, and threshold-specific operating points.*
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m from sklearn.metrics import (
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m     precision_recall_curve,
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m     confusion_matrix,
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m     classification_report,
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m )
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m def evaluate_model(y_test, y_pred_proba, threshold: float = 0.40) -> dict:
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m     Evaluate predictions with metrics appropriate for class imbalance.
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m     Key metrics:
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m     - PR-AUC: area under precision-recall curve (the single best summary
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m       statistic for imbalanced binary classification)
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m     - Precision at chosen recall: "if we want to catch X% of denials,
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m       what fraction of our flags are correct?"
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m     - Confusion matrix at operational threshold: shows the actual
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m       true/false positive/negative counts at the threshold you'd deploy with
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m     # --- Precision-Recall curve ---
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m     precision, recall, thresholds = precision_recall_curve(y_test, y_pred_proba)
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m     pr_auc = average_precision_score(y_test, y_pred_proba)
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m     roc_auc = roc_auc_score(y_test, y_pred_proba)
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m     # --- Find operational points ---
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m     # "At what threshold do we catch 80% of denials?"
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m     recall_target = 0.80
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m     idx_80_recall = np.argmin(np.abs(recall - recall_target))
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m     threshold_at_80_recall = thresholds[idx_80_recall] if idx_80_recall < len(thresholds) else 0.5
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m     precision_at_80_recall = precision[idx_80_recall]
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m     # --- Confusion matrix at the chosen operational threshold ---
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m     y_pred_binary = (y_pred_proba >= threshold).astype(int)
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m     cm = confusion_matrix(y_test, y_pred_binary)
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m     tn, fp, fn, tp = cm.ravel()
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m     report = classification_report(y_test, y_pred_binary, target_names=["Paid", "Denied"])
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m     results = {
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m         "roc_auc": roc_auc,
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m         "pr_auc": pr_auc,
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m         "threshold_used": threshold,
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m         "precision_at_80_recall": precision_at_80_recall,
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m         "threshold_for_80_recall": threshold_at_80_recall,
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m         "confusion_matrix": {
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m             "true_negatives": int(tn),
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m             "false_positives": int(fp),
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m             "false_negatives": int(fn),
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m             "true_positives": int(tp),
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m         "classification_report": report,
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m     logger.info("ROC-AUC: %.4f | PR-AUC: %.4f", roc_auc, pr_auc)
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m     logger.info("At threshold %.2f: TP=%d, FP=%d, FN=%d, TN=%d", threshold, tp, fp, fn, tn)
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m         "To catch 80%% of denials, use threshold=%.3f (precision=%.2f at that point)",
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m         threshold_at_80_recall, precision_at_80_recall,
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m     print(report)
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m     return results
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m ## Step 6: SHAP Explainability
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m *Every flagged claim needs a human-readable reason. SHAP decomposes each prediction into per-feature contributions so a biller can see exactly why the model flagged the claim and decide what to fix. Without this, the model is a black box that nobody trusts.*
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m import shap
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m def explain_prediction(model, X_test, feature_names: list, claim_index: int = 0) -> dict:
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m     Generate SHAP explanations for a single claim prediction.
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m     SHAP values tell you: "This feature pushed the denial probability
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m     up by 0.15" or "This feature pushed it down by 0.08." The sum of
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m     all SHAP values plus the base rate equals the final prediction.
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m     For operational use, we translate the top contributing features into
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m     natural-language explanations that a biller can act on.
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m     # TreeExplainer is optimized for tree models (exact, fast)
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m     explainer = shap.TreeExplainer(model)
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m     # Compute SHAP values for the test set (or a single instance)
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m     dmatrix = xgb.DMatrix(X_test)
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m     shap_values = explainer.shap_values(X_test)
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m     # Get the explanation for one specific claim
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m     claim_shap = shap_values[claim_index]
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m     claim_features = X_test.iloc[claim_index]
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m     base_value = explainer.expected_value
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m     # Sort features by absolute SHAP contribution (most important first)
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m     feature_importance = sorted(
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m         zip(feature_names, claim_shap, claim_features),
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m         key=lambda x: abs(x[1]),
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m         reverse=True,
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m     # Build human-readable explanation for top 5 contributors
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m     explanations = []
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m     for feat_name, shap_val, feat_val in feature_importance[:5]:
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m         direction = "increases" if shap_val > 0 else "decreases"
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m         explanations.append({
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m             "feature": feat_name,
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m             "shap_value": round(float(shap_val), 4),
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m             "feature_value": feat_val,
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m             "direction": direction,
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m             "narrative": _feature_to_narrative(feat_name, shap_val, feat_val),
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m     prediction = float(base_value + sum(claim_shap))
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m         "Claim %d: prediction=%.3f (base=%.3f + shap_sum=%.3f)",
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m         claim_index, prediction, base_value, sum(claim_shap),
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m     for exp in explanations:
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m         logger.info("  %s: SHAP=%.4f (%s)", exp["feature"], exp["shap_value"], exp["narrative"])
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m         "claim_index": claim_index,
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m         "prediction": round(prediction, 4),
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m         "base_value": round(float(base_value), 4),
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m         "top_factors": explanations,
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m def _feature_to_narrative(feature_name: str, shap_value: float, feature_value) -> str:
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m     Map a SHAP feature contribution to a human-readable explanation.
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m     In production, this mapping would be much richer, pulling in actual
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m     payer names, procedure descriptions, and historical rates from your
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m     feature store. This simplified version shows the pattern.
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m     direction = "higher" if shap_value > 0 else "lower"
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m     narratives = {
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m         "pa_gap": f"Prior auth gap (required but missing) pushes denial risk {direction}",
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m         "pa_required": f"PA requirement status pushes denial risk {direction}",
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m         "pa_on_file": f"PA on file status pushes denial risk {direction}",
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m         "payer_cpt": f"This payer-procedure combination pushes denial risk {direction}",
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m         "payer": f"This payer's overall denial behavior pushes risk {direction}",
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m         "cpt_code": f"This procedure code's denial history pushes risk {direction}",
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m         "claim_amount_log": f"Claim amount pushes denial risk {direction}",
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m         "days_since_service": f"Days since service pushes risk {direction}",
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m         "place_of_service": f"Place of service pushes denial risk {direction}",
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m         "modifier_1": f"Modifier status pushes denial risk {direction}",
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m     return narratives.get(feature_name, f"{feature_name} pushes denial risk {direction}")
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m ## Step 7: SageMaker Training Integration
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m *This shows how you'd train the same model on SageMaker instead of locally. SageMaker handles distributed training, automatic model artifact storage, and seamless deployment to endpoints. The built-in XGBoost container matches our local training exactly.*
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m import sagemaker
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m from sagemaker.inputs import TrainingInput
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m from sagemaker.xgboost import XGBoost
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m def train_on_sagemaker(
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m     training_data_s3_uri: str,
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m     validation_data_s3_uri: str,
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m     denial_rate: float = OVERALL_DENIAL_RATE,
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m ) -> str:
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m     Train the denial prediction model on SageMaker.
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m     This mirrors the local XGBoost training but runs on managed infrastructure.
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m     The model artifact is stored in S3 and can be deployed directly to an endpoint.
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m         training_data_s3_uri: S3 path to training CSV (no header, label in first column)
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m         validation_data_s3_uri: S3 path to validation CSV
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m         denial_rate: observed denial rate for computing scale_pos_weight
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m         S3 URI of the trained model artifact
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m     sess = sagemaker.Session()
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m     scale_pos_weight = (1 - denial_rate) / denial_rate
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m     # The SageMaker XGBoost container matches our local training parameters
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m     xgb_estimator = XGBoost(
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m         entry_point="train.py",        # Not needed for built-in algo; included for custom preprocessing
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m         framework_version="1.7-1",     # XGBoost version in the container
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m         role=SAGEMAKER_ROLE_ARN,
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m         instance_count=1,
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m         instance_type="ml.m5.2xlarge",
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m         output_path=f"s3://{S3_BUCKET}/{MODEL_PREFIX}/",
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m         sagemaker_session=sess,
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m         hyperparameters={
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m             "objective": "binary:logistic",
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m             "eval_metric": "aucpr",
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m             "num_round": 500,
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m             "max_depth": 6,
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m             "eta": 0.03,
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m             "subsample": 0.8,
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m             "colsample_bytree": 0.7,
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m             "scale_pos_weight": scale_pos_weight,
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m             "min_child_weight": 10,
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m             "gamma": 0.1,
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m             "early_stopping_rounds": 20,
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m         # Encrypt training volume with KMS (PHI requirement)
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m         volume_kms_key="alias/sagemaker-training-key",
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m         # Run in VPC for network isolation
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m         subnets=["subnet-abc123"],
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m         security_group_ids=["sg-xyz789"],
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m     # SageMaker expects data in specific channels
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m     train_input = TrainingInput(
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m         training_data_s3_uri,
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m         content_type="text/csv",
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m     val_input = TrainingInput(
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m         validation_data_s3_uri,
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m         content_type="text/csv",
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m     xgb_estimator.fit({"train": train_input, "validation": val_input})
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m     model_artifact = xgb_estimator.model_data
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m     logger.info("Model artifact stored at: %s", model_artifact)
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m     return model_artifact
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m ## Step 8: Deploy Real-Time Endpoint and Score Claims
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m *Once trained, the model needs to serve predictions in real-time (when a coder finalizes a claim) and in batch (nightly scoring of all pending claims). This shows both patterns.*
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m def deploy_realtime_endpoint(model_artifact_s3: str) -> str:
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m     Deploy the trained model as a SageMaker real-time endpoint.
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m     Real-time inference adds ~50-150ms latency per claim, which is
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m     acceptable for inline billing system integration.
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m     sess = sagemaker.Session()
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m     sm_client = boto3.client("sagemaker")
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m     # Create model object pointing to the artifact
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m     model_name = "denial-prediction-model-latest"
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m     sm_client.create_model(
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m         ModelName=model_name,
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m         PrimaryContainer={
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m             "Image": sagemaker.image_uris.retrieve("xgboost", sess.boto_region_name, "1.7-1"),
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m             "ModelDataUrl": model_artifact_s3,
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m         ExecutionRoleArn=SAGEMAKER_ROLE_ARN,
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m         # VPC config for PHI data isolation
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m         VpcConfig={
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m             "SecurityGroupIds": ["sg-xyz789"],
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m             "Subnets": ["subnet-abc123"],
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m     # Create endpoint config
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m     endpoint_config_name = "denial-prediction-endpoint-config"
[0m[49m[38;5;10m+    717[0m:[38;5;10m[49m     sm_client.create_endpoint_config(
[0m[49m[38;5;10m+    718[0m:[38;5;10m[49m         EndpointConfigName=endpoint_config_name,
[0m[49m[38;5;10m+    719[0m:[38;5;10m[49m         ProductionVariants=[{
[0m[49m[38;5;10m+    720[0m:[38;5;10m[49m             "VariantName": "primary",
[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m             "ModelName": model_name,
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m             "InstanceType": "ml.m5.xlarge",
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m             "InitialInstanceCount": 1,
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m         }],
[0m[49m[38;5;10m+    725[0m:[38;5;10m[49m         # Encrypt model artifacts on the endpoint instance
[0m[49m[38;5;10m+    726[0m:[38;5;10m[49m         KmsKeyId="alias/sagemaker-endpoint-key",
[0m[49m[38;5;10m+    727[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    728[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    729[0m:[38;5;10m[49m     # Create (or update) the endpoint
[0m[49m[38;5;10m+    730[0m:[38;5;10m[49m     endpoint_name = "denial-prediction-prod"
[0m[49m[38;5;10m+    731[0m:[38;5;10m[49m     sm_client.create_endpoint(
[0m[49m[38;5;10m+    732[0m:[38;5;10m[49m         EndpointName=endpoint_name,
[0m[49m[38;5;10m+    733[0m:[38;5;10m[49m         EndpointConfigName=endpoint_config_name,
[0m[49m[38;5;10m+    734[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    735[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    736[0m:[38;5;10m[49m     logger.info("Endpoint '%s' creating. Wait for InService status.", endpoint_name)
[0m[49m[38;5;10m+    737[0m:[38;5;10m[49m     return endpoint_name
[0m[49m[38;5;10m+    738[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    739[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    740[0m:[38;5;10m[49m def score_claim_realtime(endpoint_name: str, claim_features: dict) -> dict:
[0m[49m[38;5;10m+    741[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    742[0m:[38;5;10m[49m     Score a single claim against the real-time endpoint.
[0m[49m[38;5;10m+    743[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    744[0m:[38;5;10m[49m     Called by the billing system when a coder finalizes a claim.
[0m[49m[38;5;10m+    745[0m:[38;5;10m[49m     Returns the denial probability for immediate display.
[0m[49m[38;5;10m+    746[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    747[0m:[38;5;10m[49m     sm_runtime = boto3.client("sagemaker-runtime")
[0m[49m[38;5;10m+    748[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    749[0m:[38;5;10m[49m     # Serialize features as CSV (SageMaker XGBoost expects CSV input)
[0m[49m[38;5;10m+    750[0m:[38;5;10m[49m     # Order must match training feature order exactly
[0m[49m[38;5;10m+    751[0m:[38;5;10m[49m     feature_values = [str(claim_features.get(f, 0)) for f in claim_features]
[0m[49m[38;5;10m+    752[0m:[38;5;10m[49m     payload = ",".join(feature_values)
[0m[49m[38;5;10m+    753[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    754[0m:[38;5;10m[49m     response = sm_runtime.invoke_endpoint(
[0m[49m[38;5;10m+    755[0m:[38;5;10m[49m         EndpointName=endpoint_name,
[0m[49m[38;5;10m+    756[0m:[38;5;10m[49m         ContentType="text/csv",
[0m[49m[38;5;10m+    757[0m:[38;5;10m[49m         Body=payload.encode("utf-8"),
[0m[49m[38;5;10m+    758[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    759[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    760[0m:[38;5;10m[49m     denial_probability = float(response["Body"].read().decode("utf-8"))
[0m[49m[38;5;10m+    761[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    762[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    763[0m:[38;5;10m[49m         "denial_probability": round(denial_probability, 4),
[0m[49m[38;5;10m+    764[0m:[38;5;10m[49m         "risk_tier": _classify_risk(denial_probability),
[0m[49m[38;5;10m+    765[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    766[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    767[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    768[0m:[38;5;10m[49m def _classify_risk(probability: float) -> str:
[0m[49m[38;5;10m+    769[0m:[38;5;10m[49m     """Map probability to operational risk tier."""
[0m[49m[38;5;10m+    770[0m:[38;5;10m[49m     if probability >= HIGH_RISK_THRESHOLD:
[0m[49m[38;5;10m+    771[0m:[38;5;10m[49m         return "HIGH"
[0m[49m[38;5;10m+    772[0m:[38;5;10m[49m     if probability >= MEDIUM_RISK_THRESHOLD:
[0m[49m[38;5;10m+    773[0m:[38;5;10m[49m         return "MEDIUM"
[0m[49m[38;5;10m+    774[0m:[38;5;10m[49m     return "LOW"
[0m[49m[38;5;10m+    775[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    776[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    777[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    778[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    779[0m:[38;5;10m[49m ## Step 9: Batch Scoring with SageMaker Batch Transform
[0m[49m[38;5;10m+    780[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    781[0m:[38;5;10m[49m *Nightly batch scoring evaluates all pending claims and populates worklists for the next day. Batch transform is more cost-effective than keeping a real-time endpoint running for overnight scoring of large claim volumes.*
[0m[49m[38;5;10m+    782[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    783[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    784[0m:[38;5;10m[49m def run_batch_scoring(model_artifact_s3: str, input_s3_uri: str, output_s3_uri: str):
[0m[49m[38;5;10m+    785[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    786[0m:[38;5;10m[49m     Run batch transform to score all pending claims overnight.
[0m[49m[38;5;10m+    787[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    788[0m:[38;5;10m[49m     Batch transform is ideal for the nightly scoring run:
[0m[49m[38;5;10m+    789[0m:[38;5;10m[49m     - Spins up compute, scores all claims, writes results, shuts down
[0m[49m[38;5;10m+    790[0m:[38;5;10m[49m     - More cost-effective than keeping an endpoint running for large batch jobs
[0m[49m[38;5;10m+    791[0m:[38;5;10m[49m     - Handles arbitrarily large claim volumes with automatic splitting
[0m[49m[38;5;10m+    792[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    793[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    794[0m:[38;5;10m[49m         model_artifact_s3: S3 URI of the trained model
[0m[49m[38;5;10m+    795[0m:[38;5;10m[49m         input_s3_uri: S3 path containing claim feature CSVs to score
[0m[49m[38;5;10m+    796[0m:[38;5;10m[49m         output_s3_uri: S3 path to write prediction results
[0m[49m[38;5;10m+    797[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    798[0m:[38;5;10m[49m     sess = sagemaker.Session()
[0m[49m[38;5;10m+    799[0m:[38;5;10m[49m     sm_client = boto3.client("sagemaker")
[0m[49m[38;5;10m+    800[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    801[0m:[38;5;10m[49m     model_name = "denial-prediction-batch-model"
[0m[49m[38;5;10m+    802[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    803[0m:[38;5;10m[49m     # Create model (reuse artifact from training)
[0m[49m[38;5;10m+    804[0m:[38;5;10m[49m     sm_client.create_model(
[0m[49m[38;5;10m+    805[0m:[38;5;10m[49m         ModelName=model_name,
[0m[49m[38;5;10m+    806[0m:[38;5;10m[49m         PrimaryContainer={
[0m[49m[38;5;10m+    807[0m:[38;5;10m[49m             "Image": sagemaker.image_uris.retrieve("xgboost", sess.boto_region_name, "1.7-1"),
[0m[49m[38;5;10m+    808[0m:[38;5;10m[49m             "ModelDataUrl": model_artifact_s3,
[0m[49m[38;5;10m+    809[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    810[0m:[38;5;10m[49m         ExecutionRoleArn=SAGEMAKER_ROLE_ARN,
[0m[49m[38;5;10m+    811[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    812[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    813[0m:[38;5;10m[49m     # Launch batch transform job
[0m[49m[38;5;10m+    814[0m:[38;5;10m[49m     transform_job_name = f"denial-scoring-nightly-{pd.Timestamp.now().strftime('%Y%m%d')}"
[0m[49m[38;5;10m+    815[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    816[0m:[38;5;10m[49m     sm_client.create_transform_job(
[0m[49m[38;5;10m+    817[0m:[38;5;10m[49m         TransformJobName=transform_job_name,
[0m[49m[38;5;10m+    818[0m:[38;5;10m[49m         ModelName=model_name,
[0m[49m[38;5;10m+    819[0m:[38;5;10m[49m         TransformInput={
[0m[49m[38;5;10m+    820[0m:[38;5;10m[49m             "DataSource": {
[0m[49m[38;5;10m+    821[0m:[38;5;10m[49m                 "S3DataSource": {
[0m[49m[38;5;10m+    822[0m:[38;5;10m[49m                     "S3DataType": "S3Prefix",
[0m[49m[38;5;10m+    823[0m:[38;5;10m[49m                     "S3Uri": input_s3_uri,
[0m[49m[38;5;10m+    824[0m:[38;5;10m[49m                 }
[0m[49m[38;5;10m+    825[0m:[38;5;10m[49m             },
[0m[49m[38;5;10m+    826[0m:[38;5;10m[49m             "ContentType": "text/csv",
[0m[49m[38;5;10m+    827[0m:[38;5;10m[49m             "SplitType": "Line",       # Each line is one claim
[0m[49m[38;5;10m+    828[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    829[0m:[38;5;10m[49m         TransformOutput={
[0m[49m[38;5;10m+    830[0m:[38;5;10m[49m             "S3OutputPath": output_s3_uri,
[0m[49m[38;5;10m+    831[0m:[38;5;10m[49m             "AssembleWith": "Line",
[0m[49m[38;5;10m+    832[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    833[0m:[38;5;10m[49m         TransformResources={
[0m[49m[38;5;10m+    834[0m:[38;5;10m[49m             "InstanceType": "ml.m5.2xlarge",
[0m[49m[38;5;10m+    835[0m:[38;5;10m[49m             "InstanceCount": 1,
[0m[49m[38;5;10m+    836[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    837[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    838[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    839[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    840[0m:[38;5;10m[49m         "Batch transform job '%s' started. Input: %s, Output: %s",
[0m[49m[38;5;10m+    841[0m:[38;5;10m[49m         transform_job_name, input_s3_uri, output_s3_uri,
[0m[49m[38;5;10m+    842[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    843[0m:[38;5;10m[49m     return transform_job_name
[0m[49m[38;5;10m+    844[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    845[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    846[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    847[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    848[0m:[38;5;10m[49m ## Putting It All Together
[0m[49m[38;5;10m+    849[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    850[0m:[38;5;10m[49m Here's the full local pipeline assembled into a single function. This demonstrates the end-to-end flow: generate data, train both models, evaluate, and explain.
[0m[49m[38;5;10m+    851[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    852[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    853[0m:[38;5;10m[49m def run_full_pipeline():
[0m[49m[38;5;10m+    854[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    855[0m:[38;5;10m[49m     Run the complete claim denial prediction pipeline locally.
[0m[49m[38;5;10m+    856[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    857[0m:[38;5;10m[49m     This demonstrates the end-to-end workflow:
[0m[49m[38;5;10m+    858[0m:[38;5;10m[49m     1. Generate synthetic claims with realistic denial patterns
[0m[49m[38;5;10m+    859[0m:[38;5;10m[49m     2. Engineer features and encode categoricals
[0m[49m[38;5;10m+    860[0m:[38;5;10m[49m     3. Train logistic regression baseline
[0m[49m[38;5;10m+    861[0m:[38;5;10m[49m     4. Train XGBoost with class imbalance handling
[0m[49m[38;5;10m+    862[0m:[38;5;10m[49m     5. Evaluate both models with imbalance-appropriate metrics
[0m[49m[38;5;10m+    863[0m:[38;5;10m[49m     6. Generate SHAP explanations for flagged claims
[0m[49m[38;5;10m+    864[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    865[0m:[38;5;10m[49m     print("=" * 70)
[0m[49m[38;5;10m+    866[0m:[38;5;10m[49m     print("CLAIM DENIAL PREDICTION PIPELINE")
[0m[49m[38;5;10m+    867[0m:[38;5;10m[49m     print("=" * 70)
[0m[49m[38;5;10m+    868[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    869[0m:[38;5;10m[49m     # Step 1: Generate synthetic claims
[0m[49m[38;5;10m+    870[0m:[38;5;10m[49m     print("\n[Step 1] Generating synthetic claims data...")
[0m[49m[38;5;10m+    871[0m:[38;5;10m[49m     claims_df = generate_synthetic_claims(n_claims=NUM_CLAIMS)
[0m[49m[38;5;10m+    872[0m:[38;5;10m[49m     print(f"  Generated {len(claims_df)} claims")
[0m[49m[38;5;10m+    873[0m:[38;5;10m[49m     print(f"  Denial rate: {claims_df['denied'].mean():.1%}")
[0m[49m[38;5;10m+    874[0m:[38;5;10m[49m     print(f"  Denied: {claims_df['denied'].sum()}, Paid: {(1 - claims_df['denied']).sum()}")
[0m[49m[38;5;10m+    875[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    876[0m:[38;5;10m[49m     # Step 2: Feature engineering
[0m[49m[38;5;10m+    877[0m:[38;5;10m[49m     print("\n[Step 2] Preparing features and train/test split...")
[0m[49m[38;5;10m+    878[0m:[38;5;10m[49m     X_train, X_test, y_train, y_test, feature_names, encoders = prepare_features(claims_df)
