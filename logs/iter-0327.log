[0m[49m[38;5;10m+     765[0m:[38;5;10m[49m     # in the upstream warehouse pipeline.
[0m[49m[38;5;10m+     766[0m:[38;5;10m[49m     _put_metric("CohortsForecasted",
[0m[49m[38;5;10m+     767[0m:[38;5;10m[49m                  manifest["cohort_count"], {
[0m[49m[38;5;10m+     768[0m:[38;5;10m[49m                     "RunId": manifest["run_id"],
[0m[49m[38;5;10m+     769[0m:[38;5;10m[49m                 }, unit="Count")
[0m[49m[38;5;10m+     770[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     771[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     772[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     773[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     774[0m:[38;5;10m[49m ## Step 7: Backtest Against Last Week's Forecast and Last Week's Actuals
[0m[49m[38;5;10m+     775[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     776[0m:[38;5;10m[49m *The pseudocode calls this `backtest(history_df)`. Pull last week's forecast (the one generated 7 days ago, which forecasted yesterday through 7 days back) from the immutable S3 copy. Join against last week's actuals from `pull_history`. Compute MAPE and bias per cohort. Emit them to CloudWatch. The on-call alarm fires on a 7-day rolling MAPE above 20%.*
[0m[49m[38;5;10m+     777[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     778[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     779[0m:[38;5;10m[49m def backtest_last_week(history_df: pd.DataFrame) -> dict:
[0m[49m[38;5;10m+     780[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     781[0m:[38;5;10m[49m     Score last week's forecast against last week's actuals.
[0m[49m[38;5;10m+     782[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     783[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     784[0m:[38;5;10m[49m         Dict keyed by (clinic_code, channel) with the per-cohort
[0m[49m[38;5;10m+     785[0m:[38;5;10m[49m         MAPE, bias, and absolute mean error. Returns an empty
[0m[49m[38;5;10m+     786[0m:[38;5;10m[49m         dict if last week's forecast cannot be located (which
[0m[49m[38;5;10m+     787[0m:[38;5;10m[49m         happens for the first week after deployment).
[0m[49m[38;5;10m+     788[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     789[0m:[38;5;10m[49m     target_date = (
[0m[49m[38;5;10m+     790[0m:[38;5;10m[49m         _today_utc_date() - timedelta(days=BACKTEST_DAYS))
[0m[49m[38;5;10m+     791[0m:[38;5;10m[49m     target_date_str = target_date.date().isoformat()
[0m[49m[38;5;10m+     792[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     793[0m:[38;5;10m[49m     # List the immutable forecast files for that day. We take the
[0m[49m[38;5;10m+     794[0m:[38;5;10m[49m     # most-recent run for that day in case the pipeline ran twice.
[0m[49m[38;5;10m+     795[0m:[38;5;10m[49m     prefix = (
[0m[49m[38;5;10m+     796[0m:[38;5;10m[49m         f"{FORECAST_OUTPUT_PREFIX}"
[0m[49m[38;5;10m+     797[0m:[38;5;10m[49m         f"forecast_run_date={target_date_str}/")
[0m[49m[38;5;10m+     798[0m:[38;5;10m[49m     response = s3_client.list_objects_v2(
[0m[49m[38;5;10m+     799[0m:[38;5;10m[49m         Bucket=FORECAST_OUTPUT_BUCKET, Prefix=prefix)
[0m[49m[38;5;10m+     800[0m:[38;5;10m[49m     if "Contents" not in response:
[0m[49m[38;5;10m+     801[0m:[38;5;10m[49m         logger.info(
[0m[49m[38;5;10m+     802[0m:[38;5;10m[49m             "No prior forecast at %s; skipping backtest", prefix)
[0m[49m[38;5;10m+     803[0m:[38;5;10m[49m         return {}
[0m[49m[38;5;10m+     804[0m:[38;5;10m[49m     prior_objects = sorted(
[0m[49m[38;5;10m+     805[0m:[38;5;10m[49m         response["Contents"],
[0m[49m[38;5;10m+     806[0m:[38;5;10m[49m         key=lambda o: o["LastModified"],
[0m[49m[38;5;10m+     807[0m:[38;5;10m[49m         reverse=True)
[0m[49m[38;5;10m+     808[0m:[38;5;10m[49m     prior_key = prior_objects[0]["Key"]
[0m[49m[38;5;10m+     809[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     810[0m:[38;5;10m[49m     # Read the prior forecast.
[0m[49m[38;5;10m+     811[0m:[38;5;10m[49m     prior_response = s3_client.get_object(
[0m[49m[38;5;10m+     812[0m:[38;5;10m[49m         Bucket=FORECAST_OUTPUT_BUCKET, Key=prior_key)
[0m[49m[38;5;10m+     813[0m:[38;5;10m[49m     prior_df = pd.read_parquet(
[0m[49m[38;5;10m+     814[0m:[38;5;10m[49m         io.BytesIO(prior_response["Body"].read()))
[0m[49m[38;5;10m+     815[0m:[38;5;10m[49m     prior_df["ds"] = pd.to_datetime(prior_df["ds"])
[0m[49m[38;5;10m+     816[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     817[0m:[38;5;10m[49m     # Pull actuals for the same window from the history df.
[0m[49m[38;5;10m+     818[0m:[38;5;10m[49m     actuals = history_df.copy()
[0m[49m[38;5;10m+     819[0m:[38;5;10m[49m     actuals = actuals.rename(columns={"appt_date": "ds"})
[0m[49m[38;5;10m+     820[0m:[38;5;10m[49m     backtest_window_start = target_date
[0m[49m[38;5;10m+     821[0m:[38;5;10m[49m     backtest_window_end = (
[0m[49m[38;5;10m+     822[0m:[38;5;10m[49m         target_date + timedelta(days=BACKTEST_DAYS - 1))
[0m[49m[38;5;10m+     823[0m:[38;5;10m[49m     actuals = actuals[
[0m[49m[38;5;10m+     824[0m:[38;5;10m[49m         (actuals["ds"] >= backtest_window_start)
[0m[49m[38;5;10m+     825[0m:[38;5;10m[49m         & (actuals["ds"] <= backtest_window_end)]
[0m[49m[38;5;10m+     826[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     827[0m:[38;5;10m[49m     # Join on (ds, clinic_code, channel).
[0m[49m[38;5;10m+     828[0m:[38;5;10m[49m     joined = prior_df.merge(
[0m[49m[38;5;10m+     829[0m:[38;5;10m[49m         actuals,
[0m[49m[38;5;10m+     830[0m:[38;5;10m[49m         on=["ds", "clinic_code", "channel"],
[0m[49m[38;5;10m+     831[0m:[38;5;10m[49m         how="inner",
[0m[49m[38;5;10m+     832[0m:[38;5;10m[49m         suffixes=("_pred", "_actual"))
[0m[49m[38;5;10m+     833[0m:[38;5;10m[49m     if len(joined) == 0:
[0m[49m[38;5;10m+     834[0m:[38;5;10m[49m         logger.info("No overlap between prior forecast and "
[0m[49m[38;5;10m+     835[0m:[38;5;10m[49m                      "actuals; skipping backtest scoring")
[0m[49m[38;5;10m+     836[0m:[38;5;10m[49m         return {}
[0m[49m[38;5;10m+     837[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     838[0m:[38;5;10m[49m     metrics_by_cohort = {}
[0m[49m[38;5;10m+     839[0m:[38;5;10m[49m     for cohort_key, cohort_df in joined.groupby(
[0m[49m[38;5;10m+     840[0m:[38;5;10m[49m             ["clinic_code", "channel"]):
[0m[49m[38;5;10m+     841[0m:[38;5;10m[49m         actual = cohort_df["appt_count"].astype(float)
[0m[49m[38;5;10m+     842[0m:[38;5;10m[49m         predicted = cohort_df["yhat"].astype(float)
[0m[49m[38;5;10m+     843[0m:[38;5;10m[49m         # MAPE; protect against division by zero by skipping
[0m[49m[38;5;10m+     844[0m:[38;5;10m[49m         # zero-actual days. A clinic-closed day with predicted
[0m[49m[38;5;10m+     845[0m:[38;5;10m[49m         # near zero is correct but undefined under MAPE.
[0m[49m[38;5;10m+     846[0m:[38;5;10m[49m         nonzero_mask = actual > 0
[0m[49m[38;5;10m+     847[0m:[38;5;10m[49m         if nonzero_mask.sum() == 0:
[0m[49m[38;5;10m+     848[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     849[0m:[38;5;10m[49m         mape = (
[0m[49m[38;5;10m+     850[0m:[38;5;10m[49m             (actual[nonzero_mask] - predicted[nonzero_mask])
[0m[49m[38;5;10m+     851[0m:[38;5;10m[49m                 .abs()
[0m[49m[38;5;10m+     852[0m:[38;5;10m[49m             / actual[nonzero_mask]).mean()
[0m[49m[38;5;10m+     853[0m:[38;5;10m[49m         bias = (predicted - actual).mean()
[0m[49m[38;5;10m+     854[0m:[38;5;10m[49m         mae = (predicted - actual).abs().mean()
[0m[49m[38;5;10m+     855[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     856[0m:[38;5;10m[49m         metrics_by_cohort[cohort_key] = {
[0m[49m[38;5;10m+     857[0m:[38;5;10m[49m             "mape": float(mape),
[0m[49m[38;5;10m+     858[0m:[38;5;10m[49m             "bias": float(bias),
[0m[49m[38;5;10m+     859[0m:[38;5;10m[49m             "mae":  float(mae),
[0m[49m[38;5;10m+     860[0m:[38;5;10m[49m             "n":    int(nonzero_mask.sum()),
[0m[49m[38;5;10m+     861[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+     862[0m:[38;5;10m[49m         clinic_code, channel = cohort_key
[0m[49m[38;5;10m+     863[0m:[38;5;10m[49m         _put_metric("BacktestMAPE", float(mape), {
[0m[49m[38;5;10m+     864[0m:[38;5;10m[49m             "Clinic":  clinic_code,
[0m[49m[38;5;10m+     865[0m:[38;5;10m[49m             "Channel": channel,
[0m[49m[38;5;10m+     866[0m:[38;5;10m[49m         }, unit="None")
[0m[49m[38;5;10m+     867[0m:[38;5;10m[49m         _put_metric("BacktestBias", float(bias), {
[0m[49m[38;5;10m+     868[0m:[38;5;10m[49m             "Clinic":  clinic_code,
[0m[49m[38;5;10m+     869[0m:[38;5;10m[49m             "Channel": channel,
[0m[49m[38;5;10m+     870[0m:[38;5;10m[49m         }, unit="None")
[0m[49m[38;5;10m+     871[0m:[38;5;10m[49m         _put_metric("BacktestMAE", float(mae), {
[0m[49m[38;5;10m+     872[0m:[38;5;10m[49m             "Clinic":  clinic_code,
[0m[49m[38;5;10m+     873[0m:[38;5;10m[49m             "Channel": channel,
[0m[49m[38;5;10m+     874[0m:[38;5;10m[49m         }, unit="Count")
[0m[49m[38;5;10m+     875[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     876[0m:[38;5;10m[49m         if mape > BACKTEST_MAPE_ALARM:
[0m[49m[38;5;10m+     877[0m:[38;5;10m[49m             logger.warning(
[0m[49m[38;5;10m+     878[0m:[38;5;10m[49m                 "Cohort %s/%s MAPE %.2f exceeds alarm %.2f",
[0m[49m[38;5;10m+     879[0m:[38;5;10m[49m                 clinic_code, channel, mape,
[0m[49m[38;5;10m+     880[0m:[38;5;10m[49m                 BACKTEST_MAPE_ALARM)
[0m[49m[38;5;10m+     881[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     882[0m:[38;5;10m[49m     return metrics_by_cohort
[0m[49m[38;5;10m+     883[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     884[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     885[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     886[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     887[0m:[38;5;10m[49m ## Putting It All Together
[0m[49m[38;5;10m+     888[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     889[0m:[38;5;10m[49m Here is the full pipeline assembled into a single callable function. In a real deployment, this is the entrypoint of a Lambda container image (or the `script.py` of a SageMaker Processing job) that EventBridge Scheduler invokes daily.
[0m[49m[38;5;10m+     890[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     891[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     892[0m:[38;5;10m[49m def run_daily_forecast() -> dict:
[0m[49m[38;5;10m+     893[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     894[0m:[38;5;10m[49m     Run the full daily forecasting pipeline.
[0m[49m[38;5;10m+     895[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     896[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     897[0m:[38;5;10m[49m         The manifest of the forecast run.
[0m[49m[38;5;10m+     898[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     899[0m:[38;5;10m[49m     logger.info("=== Daily appointment forecast run starting ===")
[0m[49m[38;5;10m+     900[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     901[0m:[38;5;10m[49m     # Step 1: pull history.
[0m[49m[38;5;10m+     902[0m:[38;5;10m[49m     history_df = pull_history(
[0m[49m[38;5;10m+     903[0m:[38;5;10m[49m         lookback_days=HISTORY_LOOKBACK_DAYS)
[0m[49m[38;5;10m+     904[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     905[0m:[38;5;10m[49m     # Step 2: prepare per-cohort series.
[0m[49m[38;5;10m+     906[0m:[38;5;10m[49m     series_by_cohort = prepare_series(history_df)
[0m[49m[38;5;10m+     907[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     908[0m:[38;5;10m[49m     # Load holidays once and reuse across cohorts.
[0m[49m[38;5;10m+     909[0m:[38;5;10m[49m     holidays_df = load_holidays()
[0m[49m[38;5;10m+     910[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     911[0m:[38;5;10m[49m     # Steps 3-4: fit and forecast per cohort.
[0m[49m[38;5;10m+     912[0m:[38;5;10m[49m     forecast_by_cohort = {}
[0m[49m[38;5;10m+     913[0m:[38;5;10m[49m     for cohort_key, series_df in series_by_cohort.items():
[0m[49m[38;5;10m+     914[0m:[38;5;10m[49m         clinic_code, channel = cohort_key
[0m[49m[38;5;10m+     915[0m:[38;5;10m[49m         if len(series_df) < MIN_HISTORY_DAYS_PER_COHORT:
[0m[49m[38;5;10m+     916[0m:[38;5;10m[49m             # Skip cohorts with insufficient history. In production
[0m[49m[38;5;10m+     917[0m:[38;5;10m[49m             # the fallback is to scale the parent clinic's
[0m[49m[38;5;10m+     918[0m:[38;5;10m[49m             # forecast by the cohort's historical share of total.
[0m[49m[38;5;10m+     919[0m:[38;5;10m[49m             # The demo simply skips.
[0m[49m[38;5;10m+     920[0m:[38;5;10m[49m             logger.info(
[0m[49m[38;5;10m+     921[0m:[38;5;10m[49m                 "Skipping cohort %s/%s: only %d days of history",
[0m[49m[38;5;10m+     922[0m:[38;5;10m[49m                 clinic_code, channel, len(series_df))
[0m[49m[38;5;10m+     923[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     924[0m:[38;5;10m[49m         try:
[0m[49m[38;5;10m+     925[0m:[38;5;10m[49m             model = fit_model(series_df, holidays_df)
[0m[49m[38;5;10m+     926[0m:[38;5;10m[49m             forecast_df = make_forecast(
[0m[49m[38;5;10m+     927[0m:[38;5;10m[49m                 model=model,
[0m[49m[38;5;10m+     928[0m:[38;5;10m[49m                 training_frame=series_df,
[0m[49m[38;5;10m+     929[0m:[38;5;10m[49m                 horizon_days=FORECAST_HORIZON_DAYS,
[0m[49m[38;5;10m+     930[0m:[38;5;10m[49m                 holidays_df=holidays_df)
[0m[49m[38;5;10m+     931[0m:[38;5;10m[49m             forecast_by_cohort[cohort_key] = forecast_df
[0m[49m[38;5;10m+     932[0m:[38;5;10m[49m         except Exception as exc:
[0m[49m[38;5;10m+     933[0m:[38;5;10m[49m             logger.error(
[0m[49m[38;5;10m+     934[0m:[38;5;10m[49m                 "Forecast failed for cohort %s/%s: %s",
[0m[49m[38;5;10m+     935[0m:[38;5;10m[49m                 clinic_code, channel, exc)
[0m[49m[38;5;10m+     936[0m:[38;5;10m[49m             _put_metric("CohortFailures", 1, {
[0m[49m[38;5;10m+     937[0m:[38;5;10m[49m                 "Clinic":  clinic_code,
[0m[49m[38;5;10m+     938[0m:[38;5;10m[49m                 "Channel": channel,
[0m[49m[38;5;10m+     939[0m:[38;5;10m[49m             }, unit="Count")
[0m[49m[38;5;10m+     940[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     941[0m:[38;5;10m[49m     if not forecast_by_cohort:
[0m[49m[38;5;10m+     942[0m:[38;5;10m[49m         raise RuntimeError(
[0m[49m[38;5;10m+     943[0m:[38;5;10m[49m             "No cohorts produced a forecast; aborting publish")
[0m[49m[38;5;10m+     944[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     945[0m:[38;5;10m[49m     # Step 5: publish to S3.
[0m[49m[38;5;10m+     946[0m:[38;5;10m[49m     manifest = publish_forecast(forecast_by_cohort)
[0m[49m[38;5;10m+     947[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     948[0m:[38;5;10m[49m     # Step 6: emit operational metrics.
[0m[49m[38;5;10m+     949[0m:[38;5;10m[49m     publish_metrics(forecast_by_cohort, manifest)
[0m[49m[38;5;10m+     950[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     951[0m:[38;5;10m[49m     # Step 7: backtest last week against last week's actuals.
[0m[49m[38;5;10m+     952[0m:[38;5;10m[49m     backtest_metrics = backtest_last_week(history_df)
[0m[49m[38;5;10m+     953[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+     954[0m:[38;5;10m[49m         "Backtest scored %d cohorts", len(backtest_metrics))
[0m[49m[38;5;10m+     955[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     956[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+     957[0m:[38;5;10m[49m         "=== Daily appointment forecast run complete: %s ===",
[0m[49m[38;5;10m+     958[0m:[38;5;10m[49m         manifest["run_id"])
[0m[49m[38;5;10m+     959[0m:[38;5;10m[49m     return manifest
[0m[49m[38;5;10m+     960[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     961[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     962[0m:[38;5;10m[49m if __name__ == "__main__":
[0m[49m[38;5;10m+     963[0m:[38;5;10m[49m     logging.basicConfig(
[0m[49m[38;5;10m+     964[0m:[38;5;10m[49m         level=logging.INFO,
[0m[49m[38;5;10m+     965[0m:[38;5;10m[49m         format="%(asctime)s %(levelname)s %(message)s")
[0m[49m[38;5;10m+     966[0m:[38;5;10m[49m     run_daily_forecast()
[0m[49m[38;5;10m+     967[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     968[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     969[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     970[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     971[0m:[38;5;10m[49m ## The Gap Between This and Production
[0m[49m[38;5;10m+     972[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     973[0m:[38;5;10m[49m This demo runs end-to-end and produces a publishable forecast, but the distance between it and a real appointment-volume forecasting service is real. Here is where that distance lives.
[0m[49m[38;5;10m+     974[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     975[0m:[38;5;10m[49m **Real Athena workgroup with data-usage controls.** The demo uses a workgroup name placeholder. Production has the workgroup configured with a per-query data scan limit (e.g., 100 GB) and a per-workgroup-per-day limit, with the limits set to alarm before they cap, with the query results bucket lifecycle-managed (Athena does not clean up after itself), and with an enforced `OutputLocation` so a misconfigured query cannot write results to an unintended bucket. The Glue Data Catalog table has partition projection enabled if the appointment-fact table is date-partitioned (which it usually is) so the query does not pay the partition-listing cost.
[0m[49m[38;5;10m+     976[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     977[0m:[38;5;10m[49m **Real SageMaker Processing job (or a container in ECS Fargate).** The demo runs inline in a Lambda. Lambda's 15-minute timeout and memory limits make it a tight fit even for modest cohort counts. Production runs the fit step in a SageMaker Processing job (or an ECS Fargate task) where memory, CPU, and runtime are properly sized, with the container image pinned by digest, with VPC and KMS configured, with CloudWatch Logs for the job's stdout/stderr, and with the pipeline orchestrated by Step Functions or AWS Glue Workflows so the steps' dependencies and retries are explicit.
[0m[49m[38;5;10m+     978[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     979[0m:[38;5;10m[49m **Curated holidays calendar.** The demo loads holidays from a CSV in S3. The hard part is not the loading; it is the curation. Operations needs the calendar to include every clinic-closed date (which differs per clinic), every half-day, every day-after-Thanksgiving when half the staff is on PTO, every weather-driven closure, and every system-outage-driven artificial-zero day. The calendar is owned by the operations-data team, lives in version control, and is reviewed quarterly. The forecast quality is bounded above by the calendar's quality.
[0m[49m[38;5;10m+     980[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     981[0m:[38;5;10m[49m **Outlier and anomaly handling.** The demo has an anomaly-overrides file but does not implement automated outlier detection. Production runs an anomaly check on the daily series (rolling z-score, isolation forest on residuals, or a tuned threshold) that flags candidate anomalies for the operations team to review and add to the overrides file. The check is a recommendation system, not an autopilot; humans decide which dates were genuinely weird and which were a real signal the model needs to learn.
[0m[49m[38;5;10m+     982[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     983[0m:[38;5;10m[49m **Per-cohort models with hierarchical fallback.** The demo treats each (clinic, channel) cohort independently. Cohorts with sparse history get skipped. Production uses a hierarchical model: fit at the level the data supports, fall back to the parent cohort's seasonal pattern scaled by the child cohort's average ratio when child-level history is insufficient. Common implementations use Prophet for the parent fit and a seasonal-naive fallback for the child cohorts; more sophisticated shops use a hierarchical Bayesian model that pools the seasonal estimates across cohorts.
[0m[49m[38;5;10m+     984[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     985[0m:[38;5;10m[49m **Multiple model candidates with model selection.** Prophet is one choice. SARIMA, Holt-Winters exponential smoothing, gradient-boosted trees on engineered calendar features, and the SageMaker DeepAR built-in algorithm are others. Production runs a daily backtest across model candidates and picks the per-cohort winner via cross-validation MAPE. The model registry tracks which model is winning where and emits a metric when the best model changes, so a regression in one model is observable.
[0m[49m[38;5;10m+     986[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     987[0m:[38;5;10m[49m **Drift detection and re-fit triggers.** The demo re-fits daily, which is mild overkill for a series whose seasonal pattern shifts slowly. Production re-fits on a cadence (weekly is plenty for stable cohorts) plus on demand when drift is detected: rolling-MAPE crosses a threshold, the level shifts (population growth at the clinic, opening of a new urgent-care option down the street), or the seasonality changes (a new physician with a different schedule joins the cohort). The detect-then-trigger flow keeps the pipeline cheap on stable cohorts and responsive on changing ones.
[0m[49m[38;5;10m+     988[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     989[0m:[38;5;10m[49m **Forecast bias decomposition.** A 20% MAPE means something different on a high-volume cohort (large absolute miss) than on a low-volume one. The dashboard breaks the per-cohort MAPE down by day-of-week, by month-of-year, and by holiday-vs-non-holiday so the team can see where the model is weak. Most projects discover that holiday handling drives most of the residual error, which leads back to the holidays-calendar work.
[0m[49m[38;5;10m+     990[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     991[0m:[38;5;10m[49m **Schema versioning and consumer contracts.** The demo writes a schema version into every row but does not enforce backward compatibility. Production has a contract test that the staffing tool runs as part of its CI: read the latest forecast, parse it under the consumer's expected schema version, and fail the build if the schema does not match. The publish step on the forecast side has a parallel contract test that fails the daily run if the produced schema does not match the published spec. Version bumps require coordinated rollouts.
[0m[49m[38;5;10m+     992[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     993[0m:[38;5;10m[49m **KMS customer-managed keys.** The demo uses `ServerSideEncryption="aws:kms"` (the default key). Production uses customer-managed keys with key rotation enabled, scoped by IAM grants to the specific principals that read or write each bucket prefix, with CloudTrail logging every key-use event. The forecast bucket and the warehouse bucket use different keys for blast-radius containment.
[0m[49m[38;5;10m+     994[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     995[0m:[38;5;10m[49m **VPC and VPC endpoints.** The demo's clients call AWS over the public internet. Production runs the pipeline in a VPC with VPC endpoints for Athena, S3, KMS, CloudWatch, and SageMaker so AWS-internal traffic stays off the public internet. Endpoint policies pin access to the specific resources the pipeline uses; no wildcards.
[0m[49m[38;5;10m+     996[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     997[0m:[38;5;10m[49m **EventBridge Scheduler with retry and DLQ.** The demo's main function is the entrypoint but is not wired to a scheduler. Production has an EventBridge Scheduler one-time-per-day rule (typically firing at 02:00 in the local business timezone, after the warehouse's nightly load completes) invoking the pipeline with retry-on-failure, an SQS dead-letter queue for the cases where retry exhausts, and an alarm on the DLQ depth. The pipeline is idempotent: the same `ClientRequestToken` on the Athena query and the same run-date in the S3 path mean a retried run does not double-publish.
[0m[49m[38;5;10m+     998[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     999[0m:[38;5;10m[49m **Per-cohort fairness checks.** Volume forecasting is operational, not clinical, but cohort-level inequities still matter. If the forecast systematically under-predicts demand at a clinic that serves a lower-income population, the staffing decisions that flow from it under-staff that clinic, and the patient experience there suffers. The dashboard tracks per-cohort MAPE and bias by clinic demographics (where the data supports it) so a regression that disproportionately affects one population is visible. Per-cohort coverage threshold compliance is a launch gate, not just a metric.
[0m[49m[38;5;10m+    1000[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1001[0m:[38;5;10m[49m **Chaos testing the failure modes.** Things break. The warehouse load is late. Athena throttles. The S3 write hits a transient 503. Prophet's compiled Stan model fails to load on an unfamiliar Linux kernel. The pipeline is exercised against each of these in staging on a quarterly cadence: kill the warehouse load and verify the staleness alarm fires; throttle Athena to the workgroup's data-scan limit and verify the failure mode is graceful; corrupt the holidays CSV and verify the run fails closed rather than silently dropping holidays. A pipeline that has never been tested against its failure modes will surprise you on the day it matters.
[0m[49m[38;5;10m+    1002[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1003[0m:[38;5;10m[49m **Audit trail and reproducibility.** Every forecast run produces an immutable copy under `forecast_run_date=YYYY-MM-DD/`, which is the right primitive for audit. Production extends this with metadata stamping every run: the Athena query ID, the input row count, the holidays-file version (use the file's S3 ETag), the anomaly-overrides-file version, the Prophet version, and the model parameters. A future "what was the forecast for clinic X on date Y, and what produced it" question has a deterministic answer.
[0m[49m[38;5;10m+    1004[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1005[0m:[38;5;10m[49m **Cost monitoring and per-cohort attribution.** The fit step is the expensive part: a Prophet fit on three years of daily data takes a few seconds per cohort, and a hospital with dozens of clinics times multiple channels easily produces hundreds of cohorts. Some cohorts have so little volume that fitting them is more expensive than the staffing decisions they inform. The cost-per-cohort dashboard lets the operations team see which cohorts are economically efficient to forecast and which should fall back to a cheaper baseline (seasonal-naive, persistence). Build the dashboard.
[0m[49m[38;5;10m+    1006[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1007[0m:[38;5;10m[49m **Testing.** There are no tests in this demo. A production pipeline has unit tests for the prep step (anomaly overrides apply correctly, the daily index is complete, the regressors are populated for the right dates), the fit step (the model converges on representative data; the holiday regressors have the expected sign), the forecast step (the future frame has the right horizon; the prediction intervals widen with the horizon as expected), the publish step (the schema matches the contract; the latest pointer is atomic from the consumer's perspective), and the backtest (MAPE math is right; the bias direction is right). Integration tests against a non-production warehouse and a non-production forecast bucket. End-to-end tests that simulate the daily run with synthetic data. Never use real patient data in test fixtures, even though aggregates are not strictly PHI.
[0m[49m[38;5;10m+    1008[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1009[0m:[38;5;10m[49m **Observability beyond metrics.** The demo emits CloudWatch metrics but no traces and no structured logs ready for cross-call investigation. Production runs CloudWatch Logs Insights queries that join across the Athena query logs, the pipeline-run logs, the staffing-tool consumption logs, and the actuals-vs-forecast scoring logs by run_id. AWS X-Ray traces show the latency contribution of each step. When a single run goes wrong, the on-call engineer needs to reconstruct the trace in seconds, not minutes.
