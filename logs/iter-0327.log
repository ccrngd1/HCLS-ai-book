[0m[49m[38;5;10m+     714[0m:[38;5;10m[49m         ContentType="application/json",
[0m[49m[38;5;10m+     715[0m:[38;5;10m[49m         ServerSideEncryption="aws:kms")
[0m[49m[38;5;10m+     716[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     717[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+     718[0m:[38;5;10m[49m         "Published forecast run %s with %d rows across %d cohorts",
[0m[49m[38;5;10m+     719[0m:[38;5;10m[49m         run_id, len(output_df), len(forecast_by_cohort))
[0m[49m[38;5;10m+     720[0m:[38;5;10m[49m     return manifest
[0m[49m[38;5;10m+     721[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     722[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     723[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     724[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     725[0m:[38;5;10m[49m ## Step 6: Publish Operational Metrics
[0m[49m[38;5;10m+     726[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     727[0m:[38;5;10m[49m *The pseudocode calls this `publish_metrics(forecast_run, prior_run)`. The pipeline emits metrics so the on-call team can see freshness, fit quality, and per-cohort coverage at a glance. Slice by cohort because the institution-wide average can hide a single clinic's regression.*
[0m[49m[38;5;10m+     728[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     729[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     730[0m:[38;5;10m[49m def publish_metrics(forecast_by_cohort: dict,
[0m[49m[38;5;10m+     731[0m:[38;5;10m[49m                      manifest: dict) -> None:
[0m[49m[38;5;10m+     732[0m:[38;5;10m[49m     """Emit per-run forecast metrics to CloudWatch."""
[0m[49m[38;5;10m+     733[0m:[38;5;10m[49m     # Freshness: how many hours since the run started. The on-call
[0m[49m[38;5;10m+     734[0m:[38;5;10m[49m     # alarm fires when this exceeds 30 hours (one full day plus a
[0m[49m[38;5;10m+     735[0m:[38;5;10m[49m     # six-hour grace window).
[0m[49m[38;5;10m+     736[0m:[38;5;10m[49m     run_ts = datetime.fromisoformat(
[0m[49m[38;5;10m+     737[0m:[38;5;10m[49m         manifest["forecast_run_ts"].replace("Z", "+00:00"))
[0m[49m[38;5;10m+     738[0m:[38;5;10m[49m     age_hours = (
[0m[49m[38;5;10m+     739[0m:[38;5;10m[49m         datetime.now(timezone.utc) - run_ts).total_seconds() / 3600
[0m[49m[38;5;10m+     740[0m:[38;5;10m[49m     _put_metric("ForecastAgeHours", age_hours, {
[0m[49m[38;5;10m+     741[0m:[38;5;10m[49m         "RunId": manifest["run_id"],
[0m[49m[38;5;10m+     742[0m:[38;5;10m[49m     }, unit="None")
[0m[49m[38;5;10m+     743[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     744[0m:[38;5;10m[49m     # Per-cohort coverage. A cohort that produces zero forecast
[0m[49m[38;5;10m+     745[0m:[38;5;10m[49m     # rows is a silent failure that should alarm.
[0m[49m[38;5;10m+     746[0m:[38;5;10m[49m     for (clinic_code, channel), forecast_df in (
[0m[49m[38;5;10m+     747[0m:[38;5;10m[49m             forecast_by_cohort.items()):
[0m[49m[38;5;10m+     748[0m:[38;5;10m[49m         _put_metric("ForecastRowCount",
[0m[49m[38;5;10m+     749[0m:[38;5;10m[49m                      len(forecast_df), {
[0m[49m[38;5;10m+     750[0m:[38;5;10m[49m                         "Clinic":  clinic_code,
[0m[49m[38;5;10m+     751[0m:[38;5;10m[49m                         "Channel": channel,
[0m[49m[38;5;10m+     752[0m:[38;5;10m[49m                     }, unit="Count")
[0m[49m[38;5;10m+     753[0m:[38;5;10m[49m         # Mean forecast volume, useful for spotting cohorts
[0m[49m[38;5;10m+     754[0m:[38;5;10m[49m         # that have collapsed to near-zero (likely a data feed
[0m[49m[38;5;10m+     755[0m:[38;5;10m[49m         # break) without needing to look at the raw data.
[0m[49m[38;5;10m+     756[0m:[38;5;10m[49m         if len(forecast_df) > 0:
[0m[49m[38;5;10m+     757[0m:[38;5;10m[49m             _put_metric("ForecastMean",
[0m[49m[38;5;10m+     758[0m:[38;5;10m[49m                          float(forecast_df["yhat"].mean()),
[0m[49m[38;5;10m+     759[0m:[38;5;10m[49m                          {
[0m[49m[38;5;10m+     760[0m:[38;5;10m[49m                             "Clinic":  clinic_code,
[0m[49m[38;5;10m+     761[0m:[38;5;10m[49m                             "Channel": channel,
[0m[49m[38;5;10m+     762[0m:[38;5;10m[49m                         }, unit="None")
[0m[49m[38;5;10m+     763[0m:[38;5;10m[49m 
