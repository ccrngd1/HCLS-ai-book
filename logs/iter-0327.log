[0m[49m[38;5;10m+     696[0m:[38;5;10m[49m     # to verify schema_version, row count, and the run_id of the
[0m[49m[38;5;10m+     697[0m:[38;5;10m[49m     # forecast it is consuming.
[0m[49m[38;5;10m+     698[0m:[38;5;10m[49m     manifest = {
[0m[49m[38;5;10m+     699[0m:[38;5;10m[49m         "schema_version":     FORECAST_SCHEMA_VERSION,
[0m[49m[38;5;10m+     700[0m:[38;5;10m[49m         "run_id":             run_id,
[0m[49m[38;5;10m+     701[0m:[38;5;10m[49m         "forecast_run_date":  run_date_str,
[0m[49m[38;5;10m+     702[0m:[38;5;10m[49m         "forecast_run_ts":    _now_iso(),
[0m[49m[38;5;10m+     703[0m:[38;5;10m[49m         "horizon_days":       FORECAST_HORIZON_DAYS,
[0m[49m[38;5;10m+     704[0m:[38;5;10m[49m         "cohort_count":       len(forecast_by_cohort),
[0m[49m[38;5;10m+     705[0m:[38;5;10m[49m         "row_count":          len(output_df),
[0m[49m[38;5;10m+     706[0m:[38;5;10m[49m         "immutable_key":      immutable_key,
[0m[49m[38;5;10m+     707[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     708[0m:[38;5;10m[49m     manifest_key = (
[0m[49m[38;5;10m+     709[0m:[38;5;10m[49m         f"{FORECAST_OUTPUT_PREFIX}latest/manifest.json")
[0m[49m[38;5;10m+     710[0m:[38;5;10m[49m     s3_client.put_object(
[0m[49m[38;5;10m+     711[0m:[38;5;10m[49m         Bucket=FORECAST_OUTPUT_BUCKET,
