[0m[49m[38;5;10m+     478[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     479[0m:[38;5;10m[49m     # Local import. Prophet's first import is heavy and we do not
[0m[49m[38;5;10m+     480[0m:[38;5;10m[49m     # want to pay it on cold-start of a Lambda that does not need
[0m[49m[38;5;10m+     481[0m:[38;5;10m[49m     # to fit (e.g., the staffing-tool reader Lambda).
[0m[49m[38;5;10m+     482[0m:[38;5;10m[49m     from prophet import Prophet
[0m[49m[38;5;10m+     483[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     484[0m:[38;5;10m[49m     # weekly_seasonality and yearly_seasonality are auto-enabled
[0m[49m[38;5;10m+     485[0m:[38;5;10m[49m     # for daily data with sufficient history. daily_seasonality
[0m[49m[38;5;10m+     486[0m:[38;5;10m[49m     # is off because we have one row per day. The seasonality_mode
[0m[49m[38;5;10m+     487[0m:[38;5;10m[49m     # is "additive" by default; switch to "multiplicative" if
[0m[49m[38;5;10m+     488[0m:[38;5;10m[49m     # absolute volume scales with the trend (most clinic-volume
[0m[49m[38;5;10m+     489[0m:[38;5;10m[49m     # series are mildly multiplicative; the operations team can
[0m[49m[38;5;10m+     490[0m:[38;5;10m[49m     # override per cohort via a config file).
[0m[49m[38;5;10m+     491[0m:[38;5;10m[49m     model = Prophet(
[0m[49m[38;5;10m+     492[0m:[38;5;10m[49m         growth="linear",
[0m[49m[38;5;10m+     493[0m:[38;5;10m[49m         weekly_seasonality=True,
[0m[49m[38;5;10m+     494[0m:[38;5;10m[49m         yearly_seasonality=True,
[0m[49m[38;5;10m+     495[0m:[38;5;10m[49m         daily_seasonality=False,
[0m[49m[38;5;10m+     496[0m:[38;5;10m[49m         holidays=holidays_df,
[0m[49m[38;5;10m+     497[0m:[38;5;10m[49m         # Wider intervals to be honest about uncertainty.
[0m[49m[38;5;10m+     498[0m:[38;5;10m[49m         # Staffing tools should plan to the 80% interval, not
[0m[49m[38;5;10m+     499[0m:[38;5;10m[49m         # the point estimate.
[0m[49m[38;5;10m+     500[0m:[38;5;10m[49m         interval_width=0.8,
[0m[49m[38;5;10m+     501[0m:[38;5;10m[49m         # mcmc_samples=0 (default) gives MAP estimates which are
[0m[49m[38;5;10m+     502[0m:[38;5;10m[49m         # fast and good enough for operational forecasts.
[0m[49m[38;5;10m+     503[0m:[38;5;10m[49m         mcmc_samples=0)
[0m[49m[38;5;10m+     504[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     505[0m:[38;5;10m[49m     # Add the calendar regressors so the model can learn the
[0m[49m[38;5;10m+     506[0m:[38;5;10m[49m     # closed-day and post-holiday-recovery effects on top of
[0m[49m[38;5;10m+     507[0m:[38;5;10m[49m     # the seasonal pattern.
[0m[49m[38;5;10m+     508[0m:[38;5;10m[49m     model.add_regressor("closed_day")
[0m[49m[38;5;10m+     509[0m:[38;5;10m[49m     model.add_regressor("post_holiday_recovery")
[0m[49m[38;5;10m+     510[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     511[0m:[38;5;10m[49m     # Suppress Prophet's noisy stdout during fit. Logs go to our
[0m[49m[38;5;10m+     512[0m:[38;5;10m[49m     # logger instead.
[0m[49m[38;5;10m+     513[0m:[38;5;10m[49m     import logging as stdlogging
[0m[49m[38;5;10m+     514[0m:[38;5;10m[49m     stdlogging.getLogger("prophet").setLevel(stdlogging.WARNING)
[0m[49m[38;5;10m+     515[0m:[38;5;10m[49m     stdlogging.getLogger("cmdstanpy").setLevel(stdlogging.WARNING)
[0m[49m[38;5;10m+     516[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     517[0m:[38;5;10m[49m     model.fit(series_df)
[0m[49m[38;5;10m+     518[0m:[38;5;10m[49m     return model
[0m[49m[38;5;10m+     519[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     520[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     521[0m:[38;5;10m[49m def load_holidays() -> pd.DataFrame:
[0m[49m[38;5;10m+     522[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     523[0m:[38;5;10m[49m     Pull the operations-curated holidays file from S3. Columns:
[0m[49m[38;5;10m+     524[0m:[38;5;10m[49m     holiday (str, name), ds (date), lower_window (int, days
[0m[49m[38;5;10m+     525[0m:[38;5;10m[49m     before; default 0), upper_window (int, days after; default 0).
[0m[49m[38;5;10m+     526[0m:[38;5;10m[49m     The lower_window and upper_window let the model spread the
[0m[49m[38;5;10m+     527[0m:[38;5;10m[49m     effect across adjacent days (e.g., the day before Thanksgiving
[0m[49m[38;5;10m+     528[0m:[38;5;10m[49m     runs hot; the day after runs cold).
[0m[49m[38;5;10m+     529[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     530[0m:[38;5;10m[49m     try:
[0m[49m[38;5;10m+     531[0m:[38;5;10m[49m         response = s3_client.get_object(
[0m[49m[38;5;10m+     532[0m:[38;5;10m[49m             Bucket=FORECAST_OUTPUT_BUCKET,
[0m[49m[38;5;10m+     533[0m:[38;5;10m[49m             Key=HOLIDAYS_OVERRIDES_KEY)
[0m[49m[38;5;10m+     534[0m:[38;5;10m[49m         df = pd.read_csv(io.BytesIO(response["Body"].read()))
[0m[49m[38;5;10m+     535[0m:[38;5;10m[49m         df["ds"] = pd.to_datetime(df["ds"])
[0m[49m[38;5;10m+     536[0m:[38;5;10m[49m         if "lower_window" not in df.columns:
[0m[49m[38;5;10m+     537[0m:[38;5;10m[49m             df["lower_window"] = 0
[0m[49m[38;5;10m+     538[0m:[38;5;10m[49m         if "upper_window" not in df.columns:
[0m[49m[38;5;10m+     539[0m:[38;5;10m[49m             df["upper_window"] = 0
[0m[49m[38;5;10m+     540[0m:[38;5;10m[49m         return df
[0m[49m[38;5;10m+     541[0m:[38;5;10m[49m     except s3_client.exceptions.NoSuchKey:
[0m[49m[38;5;10m+     542[0m:[38;5;10m[49m         logger.warning(
[0m[49m[38;5;10m+     543[0m:[38;5;10m[49m             "No holidays file at s3://%s/%s; "
[0m[49m[38;5;10m+     544[0m:[38;5;10m[49m             "proceeding with empty holiday set",
[0m[49m[38;5;10m+     545[0m:[38;5;10m[49m             FORECAST_OUTPUT_BUCKET, HOLIDAYS_OVERRIDES_KEY)
[0m[49m[38;5;10m+     546[0m:[38;5;10m[49m         return pd.DataFrame(columns=[
[0m[49m[38;5;10m+     547[0m:[38;5;10m[49m             "holiday", "ds", "lower_window", "upper_window"])
[0m[49m[38;5;10m+     548[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     549[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     550[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     551[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     552[0m:[38;5;10m[49m ## Step 4: Generate the Forecast with Prediction Intervals
[0m[49m[38;5;10m+     553[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     554[0m:[38;5;10m[49m *The pseudocode calls this `make_forecast(model, horizon_days)`. Build a future-date frame extending past the end of the training data, populate the regressors for the future dates (closed days from the holidays calendar; post-holiday-recovery flags), and let Prophet produce the forecast with prediction intervals. The intervals matter: staffing decisions should plan to the upper-80 of demand, not the point estimate.*
[0m[49m[38;5;10m+     555[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     556[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     557[0m:[38;5;10m[49m def make_forecast(model,
[0m[49m[38;5;10m+     558[0m:[38;5;10m[49m                    training_frame: pd.DataFrame,
[0m[49m[38;5;10m+     559[0m:[38;5;10m[49m                    horizon_days: int = FORECAST_HORIZON_DAYS,
[0m[49m[38;5;10m+     560[0m:[38;5;10m[49m                    holidays_df: Optional[pd.DataFrame] = None
[0m[49m[38;5;10m+     561[0m:[38;5;10m[49m                    ) -> pd.DataFrame:
[0m[49m[38;5;10m+     562[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     563[0m:[38;5;10m[49m     Generate forecasts for the next horizon_days days.
[0m[49m[38;5;10m+     564[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     565[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     566[0m:[38;5;10m[49m         DataFrame with columns: ds, yhat (point), yhat_lower
[0m[49m[38;5;10m+     567[0m:[38;5;10m[49m         (lower 80% bound), yhat_upper (upper 80% bound), plus
[0m[49m[38;5;10m+     568[0m:[38;5;10m[49m         the seasonal components for diagnostics.
[0m[49m[38;5;10m+     569[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     570[0m:[38;5;10m[49m     # Build the future frame.
[0m[49m[38;5;10m+     571[0m:[38;5;10m[49m     future = model.make_future_dataframe(
[0m[49m[38;5;10m+     572[0m:[38;5;10m[49m         periods=horizon_days, freq="D",
[0m[49m[38;5;10m+     573[0m:[38;5;10m[49m         include_history=False)
[0m[49m[38;5;10m+     574[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     575[0m:[38;5;10m[49m     # Populate the regressors for the future dates. closed_day
[0m[49m[38;5;10m+     576[0m:[38;5;10m[49m     # comes from the holidays calendar (any date with a holiday
[0m[49m[38;5;10m+     577[0m:[38;5;10m[49m     # marked closed_day=True); post_holiday_recovery is the day
[0m[49m[38;5;10m+     578[0m:[38;5;10m[49m     # after a closed_day.
[0m[49m[38;5;10m+     579[0m:[38;5;10m[49m     future["closed_day"] = 0
[0m[49m[38;5;10m+     580[0m:[38;5;10m[49m     future["post_holiday_recovery"] = 0
[0m[49m[38;5;10m+     581[0m:[38;5;10m[49m     if holidays_df is not None and len(holidays_df) > 0:
[0m[49m[38;5;10m+     582[0m:[38;5;10m[49m         closed_dates = set(
[0m[49m[38;5;10m+     583[0m:[38;5;10m[49m             holidays_df[holidays_df["holiday"]
[0m[49m[38;5;10m+     584[0m:[38;5;10m[49m                          .str.contains("clinic_closed",
[0m[49m[38;5;10m+     585[0m:[38;5;10m[49m                                        case=False,
[0m[49m[38;5;10m+     586[0m:[38;5;10m[49m                                        na=False)]
[0m[49m[38;5;10m+     587[0m:[38;5;10m[49m             ["ds"])
[0m[49m[38;5;10m+     588[0m:[38;5;10m[49m         for ix, row in future.iterrows():
[0m[49m[38;5;10m+     589[0m:[38;5;10m[49m             if row["ds"] in closed_dates:
[0m[49m[38;5;10m+     590[0m:[38;5;10m[49m                 future.at[ix, "closed_day"] = 1
[0m[49m[38;5;10m+     591[0m:[38;5;10m[49m             elif (row["ds"] - timedelta(days=1)) in closed_dates:
[0m[49m[38;5;10m+     592[0m:[38;5;10m[49m                 future.at[ix, "post_holiday_recovery"] = 1
[0m[49m[38;5;10m+     593[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     594[0m:[38;5;10m[49m     forecast = model.predict(future)
[0m[49m[38;5;10m+     595[0m:[38;5;10m[49m     # Trim columns to what downstream consumers need.
[0m[49m[38;5;10m+     596[0m:[38;5;10m[49m     return forecast[[
[0m[49m[38;5;10m+     597[0m:[38;5;10m[49m         "ds", "yhat", "yhat_lower", "yhat_upper",
[0m[49m[38;5;10m+     598[0m:[38;5;10m[49m         "trend", "weekly", "yearly"]]
[0m[49m[38;5;10m+     599[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     600[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     601[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     602[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     603[0m:[38;5;10m[49m ## Step 5: Write the Forecast to S3 in a Stable Schema
[0m[49m[38;5;10m+     604[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     605[0m:[38;5;10m[49m *The pseudocode calls this `publish_forecast(forecast_df, run_date)`. Forecasts go to S3 partitioned by `forecast_run_date=YYYY-MM-DD`, and the latest forecast also lands at a stable `latest/` prefix the staffing tool reads. The write uses a manifest plus a content-hash check so the staffing tool never reads a half-written forecast.*
[0m[49m[38;5;10m+     606[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     607[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     608[0m:[38;5;10m[49m def publish_forecast(forecast_by_cohort: dict,
[0m[49m[38;5;10m+     609[0m:[38;5;10m[49m                       run_date: Optional[datetime] = None
[0m[49m[38;5;10m+     610[0m:[38;5;10m[49m                       ) -> dict:
[0m[49m[38;5;10m+     611[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     612[0m:[38;5;10m[49m     Write the forecast to S3 in a stable schema.
[0m[49m[38;5;10m+     613[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     614[0m:[38;5;10m[49m     The output has two prefixes:
[0m[49m[38;5;10m+     615[0m:[38;5;10m[49m       1. forecast_run_date=YYYY-MM-DD/  (immutable, audit trail)
[0m[49m[38;5;10m+     616[0m:[38;5;10m[49m       2. latest/                          (atomic pointer; the
[0m[49m[38;5;10m+     617[0m:[38;5;10m[49m                                            staffing tool reads here)
[0m[49m[38;5;10m+     618[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     619[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     620[0m:[38;5;10m[49m         forecast_by_cohort: Dict keyed by (clinic_code, channel)
[0m[49m[38;5;10m+     621[0m:[38;5;10m[49m                             of forecast DataFrames from Step 4.
[0m[49m[38;5;10m+     622[0m:[38;5;10m[49m         run_date: When this run executed (UTC). Defaults to today.
[0m[49m[38;5;10m+     623[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     624[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     625[0m:[38;5;10m[49m         Dict with run_date, prefix, and the manifest.
[0m[49m[38;5;10m+     626[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     627[0m:[38;5;10m[49m     run_date = run_date or _today_utc_date()
[0m[49m[38;5;10m+     628[0m:[38;5;10m[49m     run_date_str = run_date.date().isoformat()
[0m[49m[38;5;10m+     629[0m:[38;5;10m[49m     run_id = uuid.uuid4().hex[:12]
[0m[49m[38;5;10m+     630[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     631[0m:[38;5;10m[49m     # Assemble the per-cohort forecasts into a single tall frame
[0m[49m[38;5;10m+     632[0m:[38;5;10m[49m     # the staffing tool reads. The schema is the contract.
[0m[49m[38;5;10m+     633[0m:[38;5;10m[49m     rows = []
[0m[49m[38;5;10m+     634[0m:[38;5;10m[49m     for (clinic_code, channel), forecast_df in (
[0m[49m[38;5;10m+     635[0m:[38;5;10m[49m             forecast_by_cohort.items()):
[0m[49m[38;5;10m+     636[0m:[38;5;10m[49m         for _, fcst in forecast_df.iterrows():
[0m[49m[38;5;10m+     637[0m:[38;5;10m[49m             rows.append({
[0m[49m[38;5;10m+     638[0m:[38;5;10m[49m                 "schema_version":      FORECAST_SCHEMA_VERSION,
[0m[49m[38;5;10m+     639[0m:[38;5;10m[49m                 "run_id":              run_id,
[0m[49m[38;5;10m+     640[0m:[38;5;10m[49m                 "forecast_run_date":   run_date_str,
[0m[49m[38;5;10m+     641[0m:[38;5;10m[49m                 "forecast_run_ts":     _now_iso(),
[0m[49m[38;5;10m+     642[0m:[38;5;10m[49m                 "ds":                  fcst["ds"]
[0m[49m[38;5;10m+     643[0m:[38;5;10m[49m                                             .strftime("%Y-%m-%d"),
[0m[49m[38;5;10m+     644[0m:[38;5;10m[49m                 "clinic_code":         clinic_code,
[0m[49m[38;5;10m+     645[0m:[38;5;10m[49m                 "channel":             channel,
[0m[49m[38;5;10m+     646[0m:[38;5;10m[49m                 "yhat":                float(fcst["yhat"]),
[0m[49m[38;5;10m+     647[0m:[38;5;10m[49m                 "yhat_lower":          float(fcst["yhat_lower"]),
[0m[49m[38;5;10m+     648[0m:[38;5;10m[49m                 "yhat_upper":          float(fcst["yhat_upper"]),
[0m[49m[38;5;10m+     649[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+     650[0m:[38;5;10m[49m     output_df = pd.DataFrame(rows)
[0m[49m[38;5;10m+     651[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     652[0m:[38;5;10m[49m     # Write the immutable copy first.
[0m[49m[38;5;10m+     653[0m:[38;5;10m[49m     immutable_key = (
[0m[49m[38;5;10m+     654[0m:[38;5;10m[49m         f"{FORECAST_OUTPUT_PREFIX}"
[0m[49m[38;5;10m+     655[0m:[38;5;10m[49m         f"forecast_run_date={run_date_str}/"
[0m[49m[38;5;10m+     656[0m:[38;5;10m[49m         f"forecast-{run_id}.parquet")
[0m[49m[38;5;10m+     657[0m:[38;5;10m[49m     parquet_buffer = io.BytesIO()
[0m[49m[38;5;10m+     658[0m:[38;5;10m[49m     output_df.to_parquet(parquet_buffer, index=False)
[0m[49m[38;5;10m+     659[0m:[38;5;10m[49m     parquet_buffer.seek(0)
[0m[49m[38;5;10m+     660[0m:[38;5;10m[49m     s3_client.put_object(
[0m[49m[38;5;10m+     661[0m:[38;5;10m[49m         Bucket=FORECAST_OUTPUT_BUCKET,
[0m[49m[38;5;10m+     662[0m:[38;5;10m[49m         Key=immutable_key,
[0m[49m[38;5;10m+     663[0m:[38;5;10m[49m         Body=parquet_buffer.getvalue(),
[0m[49m[38;5;10m+     664[0m:[38;5;10m[49m         ContentType="application/octet-stream",
[0m[49m[38;5;10m+     665[0m:[38;5;10m[49m         ServerSideEncryption="aws:kms")
[0m[49m[38;5;10m+     666[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     667[0m:[38;5;10m[49m     # Write the latest-pointer copy. Two-step write: a temporary
[0m[49m[38;5;10m+     668[0m:[38;5;10m[49m     # key followed by a copy to the canonical key. The staffing
[0m[49m[38;5;10m+     669[0m:[38;5;10m[49m     # tool reads the canonical key; the copy is atomic from the
[0m[49m[38;5;10m+     670[0m:[38;5;10m[49m     # tool's perspective.
[0m[49m[38;5;10m+     671[0m:[38;5;10m[49m     latest_temp_key = (
[0m[49m[38;5;10m+     672[0m:[38;5;10m[49m         f"{FORECAST_OUTPUT_PREFIX}latest/"
[0m[49m[38;5;10m+     673[0m:[38;5;10m[49m         f"forecast.parquet.tmp.{run_id}")
[0m[49m[38;5;10m+     674[0m:[38;5;10m[49m     latest_canonical_key = (
[0m[49m[38;5;10m+     675[0m:[38;5;10m[49m         f"{FORECAST_OUTPUT_PREFIX}latest/forecast.parquet")
[0m[49m[38;5;10m+     676[0m:[38;5;10m[49m     parquet_buffer.seek(0)
[0m[49m[38;5;10m+     677[0m:[38;5;10m[49m     s3_client.put_object(
[0m[49m[38;5;10m+     678[0m:[38;5;10m[49m         Bucket=FORECAST_OUTPUT_BUCKET,
[0m[49m[38;5;10m+     679[0m:[38;5;10m[49m         Key=latest_temp_key,
[0m[49m[38;5;10m+     680[0m:[38;5;10m[49m         Body=parquet_buffer.getvalue(),
[0m[49m[38;5;10m+     681[0m:[38;5;10m[49m         ContentType="application/octet-stream",
[0m[49m[38;5;10m+     682[0m:[38;5;10m[49m         ServerSideEncryption="aws:kms")
[0m[49m[38;5;10m+     683[0m:[38;5;10m[49m     s3_client.copy_object(
[0m[49m[38;5;10m+     684[0m:[38;5;10m[49m         Bucket=FORECAST_OUTPUT_BUCKET,
[0m[49m[38;5;10m+     685[0m:[38;5;10m[49m         Key=latest_canonical_key,
[0m[49m[38;5;10m+     686[0m:[38;5;10m[49m         CopySource={
[0m[49m[38;5;10m+     687[0m:[38;5;10m[49m             "Bucket": FORECAST_OUTPUT_BUCKET,
[0m[49m[38;5;10m+     688[0m:[38;5;10m[49m             "Key":    latest_temp_key,
[0m[49m[38;5;10m+     689[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+     690[0m:[38;5;10m[49m         ServerSideEncryption="aws:kms")
[0m[49m[38;5;10m+     691[0m:[38;5;10m[49m     s3_client.delete_object(
[0m[49m[38;5;10m+     692[0m:[38;5;10m[49m         Bucket=FORECAST_OUTPUT_BUCKET,
[0m[49m[38;5;10m+     693[0m:[38;5;10m[49m         Key=latest_temp_key)
[0m[49m[38;5;10m+     694[0m:[38;5;10m[49m 
