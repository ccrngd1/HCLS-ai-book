[0m[49m[38;5;10m+    1192[0m:[38;5;10m[49m         cursor, keys = redis_client.scan(cursor=cursor, match="ddi:*", count=100)
[0m[49m[38;5;10m+    1193[0m:[38;5;10m[49m         if keys:
[0m[49m[38;5;10m+    1194[0m:[38;5;10m[49m             redis_client.delete(*keys)
[0m[49m[38;5;10m+    1195[0m:[38;5;10m[49m             deleted += len(keys)
[0m[49m[38;5;10m+    1196[0m:[38;5;10m[49m         if cursor == 0:
[0m[49m[38;5;10m+    1197[0m:[38;5;10m[49m             break
[0m[49m[38;5;10m+    1198[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1199[0m:[38;5;10m[49m     logger.info(f"Cache invalidated. {deleted} keys deleted.")
[0m[49m[38;5;10m+    1200[0m:[38;5;10m[49m ```
