[49m[38;5;10m+       1[0m:[38;5;10m[49m # Recipe 13.4: Python Implementation Example
[0m[49m[38;5;10m+       2[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+       3[0m:[38;5;10m[49m > **Heads up:** This is a deliberately simple, illustrative implementation of the pseudocode walkthrough from Recipe 13.4. It shows one way you could translate drug interaction knowledge graph concepts into working Python code using boto3 and Neptune's openCypher endpoint. It is not production-ready. There's no connection pooling, no retry logic, no input validation, no proper error handling. Think of it as the sketchpad version: useful for understanding how drug interaction data flows into a graph and how mechanism-based traversal queries work, not something you'd deploy to a pharmacy system on Monday morning. A starting point, not a destination.
[0m[49m[38;5;10m+       4[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+       5[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+       6[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+       7[0m:[38;5;10m[49m ## Setup
[0m[49m[38;5;10m+       8[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+       9[0m:[38;5;10m[49m You'll need the AWS SDK for Python and a few supporting libraries:
[0m[49m[38;5;10m+      10[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      11[0m:[38;5;10m[49m ```bash
[0m[49m[38;5;10m+      12[0m:[38;5;10m[49m pip install boto3 requests redis
[0m[49m[38;5;10m+      13[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+      14[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      15[0m:[38;5;10m[49m Your environment needs credentials configured (via environment variables, an instance profile, or `~/.aws/credentials`). The IAM role or user needs permissions for Neptune (`neptune-db:ReadDataViaQuery`, `neptune-db:WriteDataViaQuery` scoped to your cluster), S3 (`s3:GetObject` on the source data bucket), Comprehend Medical (`comprehend:DetectEntitiesV2`, `comprehend:InferRxNorm`), and network access to Neptune from within your VPC.
[0m[49m[38;5;10m+      16[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      17[0m:[38;5;10m[49m Neptune doesn't use IAM for query authentication by default (it uses VPC-level network isolation). If you've enabled IAM auth on your cluster, you'll need to sign requests with SigV4. This example assumes VPC network access without IAM auth for simplicity.
[0m[49m[38;5;10m+      18[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      19[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+      20[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      21[0m:[38;5;10m[49m ## Config and Constants
[0m[49m[38;5;10m+      22[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      23[0m:[38;5;10m[49m Before we get to the steps, here's the configuration that drives the pipeline. These constants define the Neptune endpoint, the graph schema for drug interactions, and the severity classification logic that determines which interactions actually matter clinically.
[0m[49m[38;5;10m+      24[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      25[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+      26[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+      27[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+      28[0m:[38;5;10m[49m import hashlib
[0m[49m[38;5;10m+      29[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+      30[0m:[38;5;10m[49m import requests
[0m[49m[38;5;10m+      31[0m:[38;5;10m[49m import redis
[0m[49m[38;5;10m+      32[0m:[38;5;10m[49m from itertools import combinations
[0m[49m[38;5;10m+      33[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      34[0m:[38;5;10m[49m # Configure logging. In production, use structured JSON logging
[0m[49m[38;5;10m+      35[0m:[38;5;10m[49m # for CloudWatch Logs Insights queries.
[0m[49m[38;5;10m+      36[0m:[38;5;10m[49m # PHI Safety: Patient medication lists are PHI. Never log specific
[0m[49m[38;5;10m+      37[0m:[38;5;10m[49m # patient medication combinations or patient identifiers.
[0m[49m[38;5;10m+      38[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+      39[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+      40[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      41[0m:[38;5;10m[49m # Neptune cluster endpoint. Use the writer endpoint for loads,
[0m[49m[38;5;10m+      42[0m:[38;5;10m[49m # reader endpoint for queries. In production, separate these.
[0m[49m[38;5;10m+      43[0m:[38;5;10m[49m #
[0m[49m[38;5;10m+      44[0m:[38;5;10m[49m # Neptune runs inside your VPC. This code must execute from within
[0m[49m[38;5;10m+      45[0m:[38;5;10m[49m # the same VPC (Lambda in VPC, EC2, ECS, etc.) to reach it.
[0m[49m[38;5;10m+      46[0m:[38;5;10m[49m NEPTUNE_WRITER_ENDPOINT = "your-neptune-cluster.cluster-xxxxxxxxxxxx.us-east-1.neptune.amazonaws.com"
[0m[49m[38;5;10m+      47[0m:[38;5;10m[49m NEPTUNE_READER_ENDPOINT = "your-neptune-cluster.cluster-ro-xxxxxxxxxxxx.us-east-1.neptune.amazonaws.com"
[0m[49m[38;5;10m+      48[0m:[38;5;10m[49m NEPTUNE_PORT = 8182
[0m[49m[38;5;10m+      49[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      50[0m:[38;5;10m[49m # Neptune exposes openCypher queries via HTTPS POST to this path.
[0m[49m[38;5;10m+      51[0m:[38;5;10m[49m NEPTUNE_WRITER_URL = f"https://{NEPTUNE_WRITER_ENDPOINT}:{NEPTUNE_PORT}/openCypher"
[0m[49m[38;5;10m+      52[0m:[38;5;10m[49m NEPTUNE_READER_URL = f"https://{NEPTUNE_READER_ENDPOINT}:{NEPTUNE_PORT}/openCypher"
[0m[49m[38;5;10m+      53[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      54[0m:[38;5;10m[49m # S3 bucket for staging source data files (RxNorm, DrugBank, FDA SPL).
[0m[49m[38;5;10m+      55[0m:[38;5;10m[49m SOURCE_BUCKET = "my-ddi-source-data"
[0m[49m[38;5;10m+      56[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      57[0m:[38;5;10m[49m # AWS region for all service calls.
[0m[49m[38;5;10m+      58[0m:[38;5;10m[49m AWS_REGION = "us-east-1"
[0m[49m[38;5;10m+      59[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      60[0m:[38;5;10m[49m # Redis endpoint for caching interaction query results.
[0m[49m[38;5;10m+      61[0m:[38;5;10m[49m REDIS_HOST = "your-redis-cluster.xxxxxxxxxxxx.use1.cache.amazonaws.com"
[0m[49m[38;5;10m+      62[0m:[38;5;10m[49m REDIS_PORT = 6379
[0m[49m[38;5;10m+      63[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      64[0m:[38;5;10m[49m # Cache TTL: 7 days. Interaction knowledge base updates weekly.
[0m[49m[38;5;10m+      65[0m:[38;5;10m[49m # Flush cache explicitly when new source data is loaded.
[0m[49m[38;5;10m+      66[0m:[38;5;10m[49m CACHE_TTL_SECONDS = 604800
[0m[49m[38;5;10m+      67[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      68[0m:[38;5;10m[49m # Clinical significance threshold. Interactions scoring below this
[0m[49m[38;5;10m+      69[0m:[38;5;10m[49m # are suppressed from clinical alerts. This is the single most important
[0m[49m[38;5;10m+      70[0m:[38;5;10m[49m # tuning parameter for alert fatigue. Start conservative (low threshold,
[0m[49m[38;5;10m+      71[0m:[38;5;10m[49m # more alerts) and raise it as you validate the scoring model.
[0m[49m[38;5;10m+      72[0m:[38;5;10m[49m #
[0m[49m[38;5;10m+      73[0m:[38;5;10m[49m # 0.3 is deliberately permissive for a new system. Production systems
[0m[49m[38;5;10m+      74[0m:[38;5;10m[49m # with validated scoring typically use 0.4-0.6.
[0m[49m[38;5;10m+      75[0m:[38;5;10m[49m SIGNIFICANCE_THRESHOLD = 0.3
[0m[49m[38;5;10m+      76[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      77[0m:[38;5;10m[49m # Severity weights for scoring. These multiply with evidence quality
[0m[49m[38;5;10m+      78[0m:[38;5;10m[49m # and patient context factors to produce the final significance score.
[0m[49m[38;5;10m+      79[0m:[38;5;10m[49m SEVERITY_WEIGHTS = {
[0m[49m[38;5;10m+      80[0m:[38;5;10m[49m     "Contraindicated": 1.0,
[0m[49m[38;5;10m+      81[0m:[38;5;10m[49m     "Major": 0.85,
[0m[49m[38;5;10m+      82[0m:[38;5;10m[49m     "Moderate": 0.5,
[0m[49m[38;5;10m+      83[0m:[38;5;10m[49m     "Minor": 0.2,
[0m[49m[38;5;10m+      84[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+      85[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      86[0m:[38;5;10m[49m # Evidence level weights. An interaction supported by an RCT gets
[0m[49m[38;5;10m+      87[0m:[38;5;10m[49m # more weight than one based on a single case report.
[0m[49m[38;5;10m+      88[0m:[38;5;10m[49m EVIDENCE_WEIGHTS = {
[0m[49m[38;5;10m+      89[0m:[38;5;10m[49m     "Established": 1.0,    # Multiple controlled studies
[0m[49m[38;5;10m+      90[0m:[38;5;10m[49m     "Probable": 0.8,       # Strong pharmacological basis + clinical evidence
[0m[49m[38;5;10m+      91[0m:[38;5;10m[49m     "Suspected": 0.5,      # Pharmacological basis, limited clinical evidence
[0m[49m[38;5;10m+      92[0m:[38;5;10m[49m     "Possible": 0.3,       # Case reports or theoretical only
[0m[49m[38;5;10m+      93[0m:[38;5;10m[49m     "Inferred": 0.4,       # Mechanism-based inference (no direct evidence for this pair)
[0m[49m[38;5;10m+      94[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+      95[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      96[0m:[38;5;10m[49m # Inhibition strength multipliers for mechanism-based inference.
[0m[49m[38;5;10m+      97[0m:[38;5;10m[49m # A strong CYP inhibitor (like ketoconazole for CYP3A4) causes much
[0m[49m[38;5;10m+      98[0m:[38;5;10m[49m # larger substrate concentration increases than a weak one (like cimetidine).
[0m[49m[38;5;10m+      99[0m:[38;5;10m[49m INHIBITION_STRENGTH_MULTIPLIERS = {
[0m[49m[38;5;10m+     100[0m:[38;5;10m[49m     "strong": 1.0,
[0m[49m[38;5;10m+     101[0m:[38;5;10m[49m     "moderate": 0.6,
[0m[49m[38;5;10m+     102[0m:[38;5;10m[49m     "weak": 0.3,
[0m[49m[38;5;10m+     103[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     104[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     105[0m:[38;5;10m[49m # Node labels in our graph schema.
[0m[49m[38;5;10m+     106[0m:[38;5;10m[49m NODE_LABELS = {
[0m[49m[38;5;10m+     107[0m:[38;5;10m[49m     "drug": "Drug",
[0m[49m[38;5;10m+     108[0m:[38;5;10m[49m     "enzyme": "Enzyme",
[0m[49m[38;5;10m+     109[0m:[38;5;10m[49m     "transporter": "Transporter",
[0m[49m[38;5;10m+     110[0m:[38;5;10m[49m     "clinical_effect": "ClinicalEffect",
[0m[49m[38;5;10m+     111[0m:[38;5;10m[49m     "evidence": "Evidence",
[0m[49m[38;5;10m+     112[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     113[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     114[0m:[38;5;10m[49m # Edge types connecting our nodes.
[0m[49m[38;5;10m+     115[0m:[38;5;10m[49m EDGE_TYPES = {
[0m[49m[38;5;10m+     116[0m:[38;5;10m[49m     "substrate_of": "SUBSTRATE_OF",
[0m[49m[38;5;10m+     117[0m:[38;5;10m[49m     "inhibits": "INHIBITS",
[0m[49m[38;5;10m+     118[0m:[38;5;10m[49m     "induces": "INDUCES",
[0m[49m[38;5;10m+     119[0m:[38;5;10m[49m     "interacts_with": "INTERACTS_WITH",
[0m[49m[38;5;10m+     120[0m:[38;5;10m[49m     "contributes_to": "CONTRIBUTES_TO",
[0m[49m[38;5;10m+     121[0m:[38;5;10m[49m     "supported_by": "SUPPORTED_BY",
[0m[49m[38;5;10m+     122[0m:[38;5;10m[49m     "has_ingredient": "HAS_INGREDIENT",
[0m[49m[38;5;10m+     123[0m:[38;5;10m[49m     "tradename_of": "TRADENAME_OF",
[0m[49m[38;5;10m+     124[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     125[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     126[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     127[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     128[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     129[0m:[38;5;10m[49m ## Step 1: Ingest and Normalize Drug Data from RxNorm
[0m[49m[38;5;10m+     130[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     131[0m:[38;5;10m[49m *The pseudocode calls this `ingest_rxnorm(rxnorm_file_path)`. It reads the RxNorm RRF files (pipe-delimited relational files from the NLM UMLS distribution) and loads drug concept nodes into Neptune. RxNorm provides the canonical drug identifiers that anchor the entire graph. Without these, you can't reliably link interaction data from different sources because everyone calls drugs by different names.*
[0m[49m[38;5;10m+     132[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     133[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     134[0m:[38;5;10m[49m s3_client = boto3.client("s3", region_name=AWS_REGION)
[0m[49m[38;5;10m+     135[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     136[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     137[0m:[38;5;10m[49m def run_opencypher_query(query: str, parameters: dict = None, use_writer: bool = False) -> dict:
[0m[49m[38;5;10m+     138[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     139[0m:[38;5;10m[49m     Execute an openCypher query against Neptune and return the response.
[0m[49m[38;5;10m+     140[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     141[0m:[38;5;10m[49m     Neptune's openCypher endpoint accepts POST requests with the query
[0m[49m[38;5;10m+     142[0m:[38;5;10m[49m     as a form parameter. Parameters are passed as a JSON-encoded string.
[0m[49m[38;5;10m+     143[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     144[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     145[0m:[38;5;10m[49m         query: openCypher query string (MATCH, MERGE, CREATE, etc.)
[0m[49m[38;5;10m+     146[0m:[38;5;10m[49m         parameters: Dict of query parameters (referenced as $param_name in query)
[0m[49m[38;5;10m+     147[0m:[38;5;10m[49m         use_writer: If True, send to writer endpoint (for mutations).
[0m[49m[38;5;10m+     148[0m:[38;5;10m[49m                     If False, send to reader endpoint (for queries).
[0m[49m[38;5;10m+     149[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     150[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     151[0m:[38;5;10m[49m         Parsed JSON response from Neptune.
[0m[49m[38;5;10m+     152[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     153[0m:[38;5;10m[49m     url = NEPTUNE_WRITER_URL if use_writer else NEPTUNE_READER_URL
[0m[49m[38;5;10m+     154[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     155[0m:[38;5;10m[49m     payload = {"query": query}
[0m[49m[38;5;10m+     156[0m:[38;5;10m[49m     if parameters:
[0m[49m[38;5;10m+     157[0m:[38;5;10m[49m         payload["parameters"] = json.dumps(parameters)
[0m[49m[38;5;10m+     158[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     159[0m:[38;5;10m[49m     response = requests.post(url, data=payload)
[0m[49m[38;5;10m+     160[0m:[38;5;10m[49m     response.raise_for_status()
[0m[49m[38;5;10m+     161[0m:[38;5;10m[49m     return response.json()
[0m[49m[38;5;10m+     162[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     163[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     164[0m:[38;5;10m[49m def ingest_rxnorm_concepts(bucket: str, key: str) -> int:
[0m[49m[38;5;10m+     165[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     166[0m:[38;5;10m[49m     Parse RxNorm RXNCONSO.RRF and load drug concept nodes into Neptune.
[0m[49m[38;5;10m+     167[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     168[0m:[38;5;10m[49m     RxNorm's RXNCONSO file contains one row per concept-name pair. Each row
[0m[49m[38;5;10m+     169[0m:[38;5;10m[49m     has a CUI (concept unique identifier), a term type (TTY), and the name string.
[0m[49m[38;5;10m+     170[0m:[38;5;10m[49m     We care about specific term types:
[0m[49m[38;5;10m+     171[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     172[0m:[38;5;10m[49m       IN  = Ingredient (the actual molecule, e.g., "warfarin")
[0m[49m[38;5;10m+     173[0m:[38;5;10m[49m       BN  = Brand Name (e.g., "Coumadin")
[0m[49m[38;5;10m+     174[0m:[38;5;10m[49m       SCD = Semantic Clinical Drug (ingredient + strength + dose form)
[0m[49m[38;5;10m+     175[0m:[38;5;10m[49m       SBD = Semantic Branded Drug (brand + strength + dose form)
[0m[49m[38;5;10m+     176[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     177[0m:[38;5;10m[49m     We load IN and BN as primary drug nodes. SCD/SBD become linked nodes
[0m[49m[38;5;10m+     178[0m:[38;5;10m[49m     that let us resolve specific formulations back to their ingredient.
[0m[49m[38;5;10m+     179[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     180[0m:[38;5;10m[49m     The RRF format is pipe-delimited with these columns:
[0m[49m[38;5;10m+     181[0m:[38;5;10m[49m     RXCUI|LAT|TS|LUI|STT|SUI|ISPREF|RXAUI|SAUI|SCUI|SDUI|SAB|TTY|CODE|STR|...
[0m[49m[38;5;10m+     182[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     183[0m:[38;5;10m[49m     We only want rows where SAB (source abbreviation) = "RXNORM" to avoid
[0m[49m[38;5;10m+     184[0m:[38;5;10m[49m     duplicates from other vocabularies included in the file.
[0m[49m[38;5;10m+     185[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     186[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     187[0m:[38;5;10m[49m         bucket: S3 bucket containing the RxNorm download
[0m[49m[38;5;10m+     188[0m:[38;5;10m[49m         key: S3 key to RXNCONSO.RRF
[0m[49m[38;5;10m+     189[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     190[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     191[0m:[38;5;10m[49m         Count of drug nodes loaded.
[0m[49m[38;5;10m+     192[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     193[0m:[38;5;10m[49m     logger.info(f"Loading RxNorm concepts from s3://{bucket}/{key}")
[0m[49m[38;5;10m+     194[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     195[0m:[38;5;10m[49m     response = s3_client.get_object(Bucket=bucket, Key=key)
[0m[49m[38;5;10m+     196[0m:[38;5;10m[49m     content = response["Body"].read().decode("utf-8")
[0m[49m[38;5;10m+     197[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     198[0m:[38;5;10m[49m     # Term types we want as primary drug nodes.
[0m[49m[38;5;10m+     199[0m:[38;5;10m[49m     target_ttys = {"IN", "BN", "SCD", "SBD"}
[0m[49m[38;5;10m+     200[0m:[38;5;10m[49m     nodes_loaded = 0
[0m[49m[38;5;10m+     201[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     202[0m:[38;5;10m[49m     for line in content.strip().split("\n"):
[0m[49m[38;5;10m+     203[0m:[38;5;10m[49m         fields = line.split("|")
[0m[49m[38;5;10m+     204[0m:[38;5;10m[49m         if len(fields) < 15:
[0m[49m[38;5;10m+     205[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     206[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     207[0m:[38;5;10m[49m         rxcui = fields[0]
[0m[49m[38;5;10m+     208[0m:[38;5;10m[49m         sab = fields[11]   # Source abbreviation
[0m[49m[38;5;10m+     209[0m:[38;5;10m[49m         tty = fields[12]   # Term type
[0m[49m[38;5;10m+     210[0m:[38;5;10m[49m         name = fields[14]  # The actual drug name string
[0m[49m[38;5;10m+     211[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     212[0m:[38;5;10m[49m         # Only load RXNORM-sourced entries to avoid duplicates.
[0m[49m[38;5;10m+     213[0m:[38;5;10m[49m         if sab != "RXNORM":
[0m[49m[38;5;10m+     214[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     215[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     216[0m:[38;5;10m[49m         if tty not in target_ttys:
[0m[49m[38;5;10m+     217[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     218[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     219[0m:[38;5;10m[49m         # MERGE ensures we don't create duplicates if we re-run the load.
[0m[49m[38;5;10m+     220[0m:[38;5;10m[49m         # Properties get updated on each run (name might change between versions).
[0m[49m[38;5;10m+     221[0m:[38;5;10m[49m         query = """
[0m[49m[38;5;10m+     222[0m:[38;5;10m[49m         MERGE (d:Drug {rxcui: $rxcui})
[0m[49m[38;5;10m+     223[0m:[38;5;10m[49m         SET d.name = $name,
[0m[49m[38;5;10m+     224[0m:[38;5;10m[49m             d.term_type = $tty,
[0m[49m[38;5;10m+     225[0m:[38;5;10m[49m             d.source = 'RxNorm',
[0m[49m[38;5;10m+     226[0m:[38;5;10m[49m             d.last_updated = $today
[0m[49m[38;5;10m+     227[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     228[0m:[38;5;10m[49m         run_opencypher_query(
[0m[49m[38;5;10m+     229[0m:[38;5;10m[49m             query,
[0m[49m[38;5;10m+     230[0m:[38;5;10m[49m             parameters={
[0m[49m[38;5;10m+     231[0m:[38;5;10m[49m                 "rxcui": rxcui,
[0m[49m[38;5;10m+     232[0m:[38;5;10m[49m                 "name": name,
[0m[49m[38;5;10m+     233[0m:[38;5;10m[49m                 "tty": tty,
[0m[49m[38;5;10m+     234[0m:[38;5;10m[49m                 "today": str(date.today()),
[0m[49m[38;5;10m+     235[0m:[38;5;10m[49m             },
[0m[49m[38;5;10m+     236[0m:[38;5;10m[49m             use_writer=True,
[0m[49m[38;5;10m+     237[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     238[0m:[38;5;10m[49m         nodes_loaded += 1
[0m[49m[38;5;10m+     239[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     240[0m:[38;5;10m[49m         if nodes_loaded % 1000 == 0:
[0m[49m[38;5;10m+     241[0m:[38;5;10m[49m             logger.info(f"  Loaded {nodes_loaded} drug nodes...")
[0m[49m[38;5;10m+     242[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     243[0m:[38;5;10m[49m     logger.info(f"RxNorm ingestion complete. {nodes_loaded} nodes loaded.")
[0m[49m[38;5;10m+     244[0m:[38;5;10m[49m     return nodes_loaded
[0m[49m[38;5;10m+     245[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     246[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     247[0m:[38;5;10m[49m def ingest_rxnorm_relationships(bucket: str, key: str) -> int:
[0m[49m[38;5;10m+     248[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     249[0m:[38;5;10m[49m     Parse RxNorm RXNREL.RRF and load drug-to-drug relationships into Neptune.
[0m[49m[38;5;10m+     250[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     251[0m:[38;5;10m[49m     RXNREL contains relationships between concepts. The ones we care about:
[0m[49m[38;5;10m+     252[0m:[38;5;10m[49m       - has_ingredient: links SCD/SBD to their IN (ingredient)
[0m[49m[38;5;10m+     253[0m:[38;5;10m[49m       - tradename_of: links BN to IN
[0m[49m[38;5;10m+     254[0m:[38;5;10m[49m       - isa: hierarchical "is-a" relationships
[0m[49m[38;5;10m+     255[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     256[0m:[38;5;10m[49m     These let us resolve "Coumadin 5mg tablet" -> "warfarin" so that
[0m[49m[38;5;10m+     257[0m:[38;5;10m[49m     interaction checks work regardless of whether the EHR sends us a
[0m[49m[38;5;10m+     258[0m:[38;5;10m[49m     brand name, generic, or specific formulation.
[0m[49m[38;5;10m+     259[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     260[0m:[38;5;10m[49m     RXNREL format: RXCUI1|RXAUI1|STYPE1|REL|RXCUI2|RXAUI2|STYPE2|RELA|RUI|...
[0m[49m[38;5;10m+     261[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     262[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     263[0m:[38;5;10m[49m         bucket: S3 bucket containing the RxNorm download
[0m[49m[38;5;10m+     264[0m:[38;5;10m[49m         key: S3 key to RXNREL.RRF
[0m[49m[38;5;10m+     265[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     266[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     267[0m:[38;5;10m[49m         Count of relationship edges loaded.
[0m[49m[38;5;10m+     268[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     269[0m:[38;5;10m[49m     logger.info(f"Loading RxNorm relationships from s3://{bucket}/{key}")
[0m[49m[38;5;10m+     270[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     271[0m:[38;5;10m[49m     response = s3_client.get_object(Bucket=bucket, Key=key)
[0m[49m[38;5;10m+     272[0m:[38;5;10m[49m     content = response["Body"].read().decode("utf-8")
[0m[49m[38;5;10m+     273[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     274[0m:[38;5;10m[49m     # Relationship types we want to load.
[0m[49m[38;5;10m+     275[0m:[38;5;10m[49m     target_relas = {"has_ingredient", "tradename_of", "isa"}
[0m[49m[38;5;10m+     276[0m:[38;5;10m[49m     edges_loaded = 0
[0m[49m[38;5;10m+     277[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     278[0m:[38;5;10m[49m     for line in content.strip().split("\n"):
[0m[49m[38;5;10m+     279[0m:[38;5;10m[49m         fields = line.split("|")
[0m[49m[38;5;10m+     280[0m:[38;5;10m[49m         if len(fields) < 10:
[0m[49m[38;5;10m+     281[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     282[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     283[0m:[38;5;10m[49m         rxcui1 = fields[0]
[0m[49m[38;5;10m+     284[0m:[38;5;10m[49m         rxcui2 = fields[4]
[0m[49m[38;5;10m+     285[0m:[38;5;10m[49m         rela = fields[7]  # Relationship attribute (the specific relationship type)
[0m[49m[38;5;10m+     286[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     287[0m:[38;5;10m[49m         if rela not in target_relas:
[0m[49m[38;5;10m+     288[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     289[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     290[0m:[38;5;10m[49m         # Map RxNorm relationship names to our graph edge types.
[0m[49m[38;5;10m+     291[0m:[38;5;10m[49m         edge_type = EDGE_TYPES.get(rela.lower(), rela.upper())
[0m[49m[38;5;10m+     292[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     293[0m:[38;5;10m[49m         query = f"""
[0m[49m[38;5;10m+     294[0m:[38;5;10m[49m         MATCH (a:Drug {{rxcui: $rxcui1}})
[0m[49m[38;5;10m+     295[0m:[38;5;10m[49m         MATCH (b:Drug {{rxcui: $rxcui2}})
[0m[49m[38;5;10m+     296[0m:[38;5;10m[49m         MERGE (a)-[r:{edge_type}]->(b)
[0m[49m[38;5;10m+     297[0m:[38;5;10m[49m         SET r.source = 'RxNorm',
[0m[49m[38;5;10m+     298[0m:[38;5;10m[49m             r.last_updated = $today
[0m[49m[38;5;10m+     299[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     300[0m:[38;5;10m[49m         run_opencypher_query(
[0m[49m[38;5;10m+     301[0m:[38;5;10m[49m             query,
[0m[49m[38;5;10m+     302[0m:[38;5;10m[49m             parameters={
[0m[49m[38;5;10m+     303[0m:[38;5;10m[49m                 "rxcui1": rxcui1,
[0m[49m[38;5;10m+     304[0m:[38;5;10m[49m                 "rxcui2": rxcui2,
[0m[49m[38;5;10m+     305[0m:[38;5;10m[49m                 "today": str(date.today()),
[0m[49m[38;5;10m+     306[0m:[38;5;10m[49m             },
[0m[49m[38;5;10m+     307[0m:[38;5;10m[49m             use_writer=True,
[0m[49m[38;5;10m+     308[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     309[0m:[38;5;10m[49m         edges_loaded += 1
[0m[49m[38;5;10m+     310[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     311[0m:[38;5;10m[49m     logger.info(f"RxNorm relationships loaded. {edges_loaded} edges.")
[0m[49m[38;5;10m+     312[0m:[38;5;10m[49m     return edges_loaded
[0m[49m[38;5;10m+     313[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     314[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     315[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     316[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     317[0m:[38;5;10m[49m ## Step 2: Load Enzyme and Transporter Relationships from DrugBank
[0m[49m[38;5;10m+     318[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     319[0m:[38;5;10m[49m *The pseudocode calls this `ingest_drugbank_mechanisms(drugbank_xml_path)`. DrugBank provides the mechanistic layer: which enzymes metabolize which drugs, and whether a drug is a substrate, inhibitor, or inducer of each enzyme. This is the data that enables mechanism-based inference (finding interactions that nobody has explicitly curated as a pair).*
[0m[49m[38;5;10m+     320[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     321[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     322[0m:[38;5;10m[49m import xml.etree.ElementTree as ET
[0m[49m[38;5;10m+     323[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     324[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     325[0m:[38;5;10m[49m def ingest_drugbank_mechanisms(bucket: str, key: str) -> int:
[0m[49m[38;5;10m+     326[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     327[0m:[38;5;10m[49m     Parse DrugBank XML and load enzyme/transporter relationships into Neptune.
[0m[49m[38;5;10m+     328[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     329[0m:[38;5;10m[49m     DrugBank's full database XML contains a <drug> element for each drug entry.
[0m[49m[38;5;10m+     330[0m:[38;5;10m[49m     Within each drug, <enzymes>, <transporters>, and <carriers> sections list
[0m[49m[38;5;10m+     331[0m:[38;5;10m[49m     the proteins that interact with that drug, along with the action type
[0m[49m[38;5;10m+     332[0m:[38;5;10m[49m     (substrate, inhibitor, inducer) and supporting references.
[0m[49m[38;5;10m+     333[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     334[0m:[38;5;10m[49m     The critical insight: if Drug A is a SUBSTRATE of CYP2C9, and Drug B
[0m[49m[38;5;10m+     335[0m:[38;5;10m[49m     INHIBITS CYP2C9, then Drug B will increase Drug A's plasma concentration.
[0m[49m[38;5;10m+     336[0m:[38;5;10m[49m     We don't need someone to have explicitly curated "Drug A interacts with
[0m[49m[38;5;10m+     337[0m:[38;5;10m[49m     Drug B" if we know their enzyme relationships.
[0m[49m[38;5;10m+     338[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     339[0m:[38;5;10m[49m     DrugBank XML structure (simplified):
[0m[49m[38;5;10m+     340[0m:[38;5;10m[49m     <drug>
[0m[49m[38;5;10m+     341[0m:[38;5;10m[49m       <drugbank-id>DB00001</drugbank-id>
[0m[49m[38;5;10m+     342[0m:[38;5;10m[49m       <name>Lepirudin</name>
[0m[49m[38;5;10m+     343[0m:[38;5;10m[49m       <enzymes>
[0m[49m[38;5;10m+     344[0m:[38;5;10m[49m         <enzyme>
[0m[49m[38;5;10m+     345[0m:[38;5;10m[49m           <id>BE0000017</id>
[0m[49m[38;5;10m+     346[0m:[38;5;10m[49m           <name>Cytochrome P450 2C9</name>
[0m[49m[38;5;10m+     347[0m:[38;5;10m[49m           <actions><action>substrate</action></actions>
[0m[49m[38;5;10m+     348[0m:[38;5;10m[49m           <references>...</references>
[0m[49m[38;5;10m+     349[0m:[38;5;10m[49m           <known-action>yes</known-action>
[0m[49m[38;5;10m+     350[0m:[38;5;10m[49m           <inhibition-strength>N/A</inhibition-strength>
[0m[49m[38;5;10m+     351[0m:[38;5;10m[49m         </enzyme>
[0m[49m[38;5;10m+     352[0m:[38;5;10m[49m       </enzymes>
[0m[49m[38;5;10m+     353[0m:[38;5;10m[49m     </drug>
[0m[49m[38;5;10m+     354[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     355[0m:[38;5;10m[49m     Note: DrugBank requires a license for commercial use. The academic
[0m[49m[38;5;10m+     356[0m:[38;5;10m[49m     version is free but has restrictions. Check their terms before deploying.
[0m[49m[38;5;10m+     357[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     358[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     359[0m:[38;5;10m[49m         bucket: S3 bucket containing the DrugBank XML export
[0m[49m[38;5;10m+     360[0m:[38;5;10m[49m         key: S3 key to the full_database.xml file
[0m[49m[38;5;10m+     361[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     362[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     363[0m:[38;5;10m[49m         Count of mechanism edges loaded.
[0m[49m[38;5;10m+     364[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     365[0m:[38;5;10m[49m     logger.info(f"Loading DrugBank mechanisms from s3://{bucket}/{key}")
[0m[49m[38;5;10m+     366[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     367[0m:[38;5;10m[49m     # DrugBank XML is large (1-2 GB). In production, use streaming XML parsing
[0m[49m[38;5;10m+     368[0m:[38;5;10m[49m     # (iterparse) instead of loading the entire tree into memory.
[0m[49m[38;5;10m+     369[0m:[38;5;10m[49m     # This simplified version loads it all for clarity.
[0m[49m[38;5;10m+     370[0m:[38;5;10m[49m     response = s3_client.get_object(Bucket=bucket, Key=key)
[0m[49m[38;5;10m+     371[0m:[38;5;10m[49m     content = response["Body"].read().decode("utf-8")
[0m[49m[38;5;10m+     372[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     373[0m:[38;5;10m[49m     root = ET.fromstring(content)
[0m[49m[38;5;10m+     374[0m:[38;5;10m[49m     # DrugBank uses a namespace. All elements are prefixed.
[0m[49m[38;5;10m+     375[0m:[38;5;10m[49m     ns = {"db": "http://www.drugbank.ca"}
[0m[49m[38;5;10m+     376[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     377[0m:[38;5;10m[49m     edges_loaded = 0
[0m[49m[38;5;10m+     378[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     379[0m:[38;5;10m[49m     for drug_elem in root.findall("db:drug", ns):
[0m[49m[38;5;10m+     380[0m:[38;5;10m[49m         drug_name = drug_elem.findtext("db:name", default="", namespaces=ns)
[0m[49m[38;5;10m+     381[0m:[38;5;10m[49m         drugbank_id = drug_elem.findtext("db:drugbank-id[@primary='true']", default="", namespaces=ns)
[0m[49m[38;5;10m+     382[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     383[0m:[38;5;10m[49m         # We need to map DrugBank entries to RxNorm CUIs.
[0m[49m[38;5;10m+     384[0m:[38;5;10m[49m         # DrugBank includes external identifiers including RxNorm.
[0m[49m[38;5;10m+     385[0m:[38;5;10m[49m         rxcui = None
[0m[49m[38;5;10m+     386[0m:[38;5;10m[49m         ext_ids = drug_elem.find("db:external-identifiers", ns)
[0m[49m[38;5;10m+     387[0m:[38;5;10m[49m         if ext_ids is not None:
[0m[49m[38;5;10m+     388[0m:[38;5;10m[49m             for ext_id in ext_ids.findall("db:external-identifier", ns):
[0m[49m[38;5;10m+     389[0m:[38;5;10m[49m                 resource = ext_id.findtext("db:resource", default="", namespaces=ns)
[0m[49m[38;5;10m+     390[0m:[38;5;10m[49m                 if resource == "RxCUI":
[0m[49m[38;5;10m+     391[0m:[38;5;10m[49m                     rxcui = ext_id.findtext("db:identifier", default="", namespaces=ns)
[0m[49m[38;5;10m+     392[0m:[38;5;10m[49m                     break
[0m[49m[38;5;10m+     393[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     394[0m:[38;5;10m[49m         if not rxcui:
[0m[49m[38;5;10m+     395[0m:[38;5;10m[49m             # No RxNorm mapping. We can't link this to our drug nodes.
[0m[49m[38;5;10m+     396[0m:[38;5;10m[49m             # In production, you'd maintain a separate mapping table for these.
[0m[49m[38;5;10m+     397[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     398[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     399[0m:[38;5;10m[49m         # Process enzyme relationships.
[0m[49m[38;5;10m+     400[0m:[38;5;10m[49m         enzymes_elem = drug_elem.find("db:enzymes", ns)
[0m[49m[38;5;10m+     401[0m:[38;5;10m[49m         if enzymes_elem is not None:
[0m[49m[38;5;10m+     402[0m:[38;5;10m[49m             for enzyme_elem in enzymes_elem.findall("db:enzyme", ns):
[0m[49m[38;5;10m+     403[0m:[38;5;10m[49m                 edges_loaded += _load_protein_relationship(
[0m[49m[38;5;10m+     404[0m:[38;5;10m[49m                     rxcui, enzyme_elem, "Enzyme", ns
[0m[49m[38;5;10m+     405[0m:[38;5;10m[49m                 )
[0m[49m[38;5;10m+     406[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     407[0m:[38;5;10m[49m         # Process transporter relationships.
[0m[49m[38;5;10m+     408[0m:[38;5;10m[49m         transporters_elem = drug_elem.find("db:transporters", ns)
[0m[49m[38;5;10m+     409[0m:[38;5;10m[49m         if transporters_elem is not None:
[0m[49m[38;5;10m+     410[0m:[38;5;10m[49m             for transporter_elem in transporters_elem.findall("db:transporter", ns):
[0m[49m[38;5;10m+     411[0m:[38;5;10m[49m                 edges_loaded += _load_protein_relationship(
[0m[49m[38;5;10m+     412[0m:[38;5;10m[49m                     rxcui, transporter_elem, "Transporter", ns
[0m[49m[38;5;10m+     413[0m:[38;5;10m[49m                 )
[0m[49m[38;5;10m+     414[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     415[0m:[38;5;10m[49m     logger.info(f"DrugBank mechanisms loaded. {edges_loaded} edges.")
[0m[49m[38;5;10m+     416[0m:[38;5;10m[49m     return edges_loaded
[0m[49m[38;5;10m+     417[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     418[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     419[0m:[38;5;10m[49m def _load_protein_relationship(rxcui: str, protein_elem, protein_type: str, ns: dict) -> int:
[0m[49m[38;5;10m+     420[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     421[0m:[38;5;10m[49m     Helper: load a single drug-protein relationship into Neptune.
[0m[49m[38;5;10m+     422[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     423[0m:[38;5;10m[49m     Creates the protein node (enzyme or transporter) if it doesn't exist,
[0m[49m[38;5;10m+     424[0m:[38;5;10m[49m     then creates the typed edge (SUBSTRATE_OF, INHIBITS, or INDUCES)
[0m[49m[38;5;10m+     425[0m:[38;5;10m[49m     between the drug and the protein.
[0m[49m[38;5;10m+     426[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     427[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     428[0m:[38;5;10m[49m         rxcui: The drug's RxNorm CUI (already in our graph)
[0m[49m[38;5;10m+     429[0m:[38;5;10m[49m         protein_elem: XML element for the enzyme/transporter
[0m[49m[38;5;10m+     430[0m:[38;5;10m[49m         protein_type: "Enzyme" or "Transporter"
[0m[49m[38;5;10m+     431[0m:[38;5;10m[49m         ns: XML namespace dict
[0m[49m[38;5;10m+     432[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     433[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     434[0m:[38;5;10m[49m         1 if an edge was loaded, 0 if skipped.
[0m[49m[38;5;10m+     435[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     436[0m:[38;5;10m[49m     protein_id = protein_elem.findtext("db:id", default="", namespaces=ns)
[0m[49m[38;5;10m+     437[0m:[38;5;10m[49m     protein_name = protein_elem.findtext("db:name", default="", namespaces=ns)
[0m[49m[38;5;10m+     438[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     439[0m:[38;5;10m[49m     if not protein_id or not protein_name:
[0m[49m[38;5;10m+     440[0m:[38;5;10m[49m         return 0
[0m[49m[38;5;10m+     441[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     442[0m:[38;5;10m[49m     # Get the action type (substrate, inhibitor, inducer).
[0m[49m[38;5;10m+     443[0m:[38;5;10m[49m     actions_elem = protein_elem.find("db:actions", ns)
[0m[49m[38;5;10m+     444[0m:[38;5;10m[49m     if actions_elem is None:
[0m[49m[38;5;10m+     445[0m:[38;5;10m[49m         return 0
[0m[49m[38;5;10m+     446[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     447[0m:[38;5;10m[49m     action = actions_elem.findtext("db:action", default="", namespaces=ns).lower()
[0m[49m[38;5;10m+     448[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     449[0m:[38;5;10m[49m     # Map DrugBank action terms to our edge types.
[0m[49m[38;5;10m+     450[0m:[38;5;10m[49m     action_to_edge = {
[0m[49m[38;5;10m+     451[0m:[38;5;10m[49m         "substrate": "SUBSTRATE_OF",
[0m[49m[38;5;10m+     452[0m:[38;5;10m[49m         "inhibitor": "INHIBITS",
[0m[49m[38;5;10m+     453[0m:[38;5;10m[49m         "inducer": "INDUCES",
[0m[49m[38;5;10m+     454[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     455[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     456[0m:[38;5;10m[49m     edge_type = action_to_edge.get(action)
[0m[49m[38;5;10m+     457[0m:[38;5;10m[49m     if not edge_type:
[0m[49m[38;5;10m+     458[0m:[38;5;10m[49m         return 0  # Unknown action type (e.g., "unknown", "binder")
[0m[49m[38;5;10m+     459[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     460[0m:[38;5;10m[49m     # Get inhibition strength if available (only relevant for inhibitors).
[0m[49m[38;5;10m+     461[0m:[38;5;10m[49m     strength = protein_elem.findtext("db:inhibition-strength", default="unknown", namespaces=ns)
[0m[49m[38;5;10m+     462[0m:[38;5;10m[49m     if strength == "N/A":
[0m[49m[38;5;10m+     463[0m:[38;5;10m[49m         strength = "unknown"
[0m[49m[38;5;10m+     464[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     465[0m:[38;5;10m[49m     # Create the protein node (MERGE = create if not exists).
[0m[49m[38;5;10m+     466[0m:[38;5;10m[49m     protein_query = f"""
[0m[49m[38;5;10m+     467[0m:[38;5;10m[49m     MERGE (p:{protein_type} {{protein_id: $protein_id}})
[0m[49m[38;5;10m+     468[0m:[38;5;10m[49m     SET p.name = $name,
[0m[49m[38;5;10m+     469[0m:[38;5;10m[49m         p.source = 'DrugBank',
[0m[49m[38;5;10m+     470[0m:[38;5;10m[49m         p.last_updated = $today
[0m[49m[38;5;10m+     471[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     472[0m:[38;5;10m[49m     run_opencypher_query(
[0m[49m[38;5;10m+     473[0m:[38;5;10m[49m         protein_query,
[0m[49m[38;5;10m+     474[0m:[38;5;10m[49m         parameters={
[0m[49m[38;5;10m+     475[0m:[38;5;10m[49m             "protein_id": protein_id,
[0m[49m[38;5;10m+     476[0m:[38;5;10m[49m             "name": protein_name,
[0m[49m[38;5;10m+     477[0m:[38;5;10m[49m             "today": str(date.today()),
[0m[49m[38;5;10m+     478[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+     479[0m:[38;5;10m[49m         use_writer=True,
[0m[49m[38;5;10m+     480[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     481[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     482[0m:[38;5;10m[49m     # Create the relationship edge between drug and protein.
[0m[49m[38;5;10m+     483[0m:[38;5;10m[49m     edge_query = f"""
[0m[49m[38;5;10m+     484[0m:[38;5;10m[49m     MATCH (d:Drug {{rxcui: $rxcui}})
[0m[49m[38;5;10m+     485[0m:[38;5;10m[49m     MATCH (p:{protein_type} {{protein_id: $protein_id}})
[0m[49m[38;5;10m+     486[0m:[38;5;10m[49m     MERGE (d)-[r:{edge_type}]->(p)
[0m[49m[38;5;10m+     487[0m:[38;5;10m[49m     SET r.strength = $strength,
[0m[49m[38;5;10m+     488[0m:[38;5;10m[49m         r.source = 'DrugBank',
[0m[49m[38;5;10m+     489[0m:[38;5;10m[49m         r.last_updated = $today
[0m[49m[38;5;10m+     490[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     491[0m:[38;5;10m[49m     run_opencypher_query(
[0m[49m[38;5;10m+     492[0m:[38;5;10m[49m         edge_query,
[0m[49m[38;5;10m+     493[0m:[38;5;10m[49m         parameters={
[0m[49m[38;5;10m+     494[0m:[38;5;10m[49m             "rxcui": rxcui,
[0m[49m[38;5;10m+     495[0m:[38;5;10m[49m             "protein_id": protein_id,
[0m[49m[38;5;10m+     496[0m:[38;5;10m[49m             "strength": strength,
[0m[49m[38;5;10m+     497[0m:[38;5;10m[49m             "today": str(date.today()),
[0m[49m[38;5;10m+     498[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+     499[0m:[38;5;10m[49m         use_writer=True,
[0m[49m[38;5;10m+     500[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     501[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     502[0m:[38;5;10m[49m     return 1
[0m[49m[38;5;10m+     503[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     504[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     505[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     506[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     507[0m:[38;5;10m[49m ## Step 3: Extract Interactions from FDA Drug Labels
[0m[49m[38;5;10m+     508[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     509[0m:[38;5;10m[49m *The pseudocode calls this `extract_fda_label_interactions(spl_xml_path)`. FDA Structured Product Labeling files contain a "Drug Interactions" section with semi-structured text. We use Amazon Comprehend Medical to extract medication entities from that text, then create graph edges representing the FDA-reviewed interactions.*
[0m[49m[38;5;10m+     510[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     511[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     512[0m:[38;5;10m[49m comprehend_medical_client = boto3.client("comprehendmedical", region_name=AWS_REGION)
[0m[49m[38;5;10m+     513[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     514[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     515[0m:[38;5;10m[49m def extract_fda_label_interactions(bucket: str, key: str) -> int:
[0m[49m[38;5;10m+     516[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     517[0m:[38;5;10m[49m     Parse an FDA SPL XML file, extract the Drug Interactions section,
[0m[49m[38;5;10m+     518[0m:[38;5;10m[49m     use Comprehend Medical to identify medication entities, and load
[0m[49m[38;5;10m+     519[0m:[38;5;10m[49m     the resulting interaction edges into Neptune.
[0m[49m[38;5;10m+     520[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     521[0m:[38;5;10m[49m     FDA SPL files are XML documents with a specific structure. The drug
[0m[49m[38;5;10m+     522[0m:[38;5;10m[49m     interactions section has a code attribute of "34073-7" (LOINC code
[0m[49m[38;5;10m+     523[0m:[38;5;10m[49m     for "Drug interactions"). The text within that section describes
[0m[49m[38;5;10m+     524[0m:[38;5;10m[49m     known interactions in natural language.
[0m[49m[38;5;10m+     525[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     526[0m:[38;5;10m[49m     Comprehend Medical's DetectEntitiesV2 API identifies medication mentions
[0m[49m[38;5;10m+     527[0m:[38;5;10m[49m     and their attributes (dosage, frequency, route). InferRxNorm links those
[0m[49m[38;5;10m+     528[0m:[38;5;10m[49m     mentions to RxNorm CUIs so we can connect them to our graph.
[0m[49m[38;5;10m+     529[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     530[0m:[38;5;10m[49m     This is where the graph gets its "Established" evidence level edges.
[0m[49m[38;5;10m+     531[0m:[38;5;10m[49m     FDA-reviewed interaction information is the gold standard for US-marketed drugs.
[0m[49m[38;5;10m+     532[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     533[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     534[0m:[38;5;10m[49m         bucket: S3 bucket containing FDA SPL XML files
[0m[49m[38;5;10m+     535[0m:[38;5;10m[49m         key: S3 key to a specific SPL XML file
[0m[49m[38;5;10m+     536[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     537[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     538[0m:[38;5;10m[49m         Count of interaction edges loaded from this label.
[0m[49m[38;5;10m+     539[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     540[0m:[38;5;10m[49m     logger.info(f"Processing FDA label: s3://{bucket}/{key}")
[0m[49m[38;5;10m+     541[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     542[0m:[38;5;10m[49m     response = s3_client.get_object(Bucket=bucket, Key=key)
[0m[49m[38;5;10m+     543[0m:[38;5;10m[49m     content = response["Body"].read().decode("utf-8")
[0m[49m[38;5;10m+     544[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     545[0m:[38;5;10m[49m     # Parse the SPL XML to find the drug interactions section.
[0m[49m[38;5;10m+     546[0m:[38;5;10m[49m     root = ET.fromstring(content)
[0m[49m[38;5;10m+     547[0m:[38;5;10m[49m     # SPL uses HL7 namespace.
[0m[49m[38;5;10m+     548[0m:[38;5;10m[49m     ns = {"hl7": "urn:hl7-org:v3"}
[0m[49m[38;5;10m+     549[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     550[0m:[38;5;10m[49m     # Find the subject drug (the drug this label is for).
[0m[49m[38;5;10m+     551[0m:[38;5;10m[49m     subject_name = root.findtext(".//hl7:manufacturedProduct/hl7:name", default="", namespaces=ns)
[0m[49m[38;5;10m+     552[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     553[0m:[38;5;10m[49m     # Find the Drug Interactions section by LOINC code.
[0m[49m[38;5;10m+     554[0m:[38;5;10m[49m     interaction_section = None
[0m[49m[38;5;10m+     555[0m:[38;5;10m[49m     for section in root.findall(".//hl7:section", ns):
[0m[49m[38;5;10m+     556[0m:[38;5;10m[49m         code_elem = section.find("hl7:code", ns)
[0m[49m[38;5;10m+     557[0m:[38;5;10m[49m         if code_elem is not None and code_elem.get("code") == "34073-7":
[0m[49m[38;5;10m+     558[0m:[38;5;10m[49m             interaction_section = section
[0m[49m[38;5;10m+     559[0m:[38;5;10m[49m             break
[0m[49m[38;5;10m+     560[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     561[0m:[38;5;10m[49m     if interaction_section is None:
[0m[49m[38;5;10m+     562[0m:[38;5;10m[49m         logger.info(f"  No drug interactions section found in {key}")
[0m[49m[38;5;10m+     563[0m:[38;5;10m[49m         return 0
[0m[49m[38;5;10m+     564[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     565[0m:[38;5;10m[49m     # Extract all text from the interactions section.
[0m[49m[38;5;10m+     566[0m:[38;5;10m[49m     interaction_text = _extract_section_text(interaction_section, ns)
[0m[49m[38;5;10m+     567[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     568[0m:[38;5;10m[49m     if not interaction_text or len(interaction_text) < 20:
[0m[49m[38;5;10m+     569[0m:[38;5;10m[49m         return 0
[0m[49m[38;5;10m+     570[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     571[0m:[38;5;10m[49m     # Use Comprehend Medical to find medication entities in the text.
[0m[49m[38;5;10m+     572[0m:[38;5;10m[49m     # The API has a 20,000 character limit per call. Split if needed.
[0m[49m[38;5;10m+     573[0m:[38;5;10m[49m     medication_entities = _extract_medications_from_text(interaction_text)
[0m[49m[38;5;10m+     574[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     575[0m:[38;5;10m[49m     # Get the RxNorm CUI for the subject drug.
[0m[49m[38;5;10m+     576[0m:[38;5;10m[49m     subject_rxcui = _infer_rxnorm_cui(subject_name)
[0m[49m[38;5;10m+     577[0m:[38;5;10m[49m     if not subject_rxcui:
[0m[49m[38;5;10m+     578[0m:[38;5;10m[49m         logger.warning(f"  Could not resolve subject drug to RxNorm: {subject_name}")
[0m[49m[38;5;10m+     579[0m:[38;5;10m[49m         return 0
[0m[49m[38;5;10m+     580[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     581[0m:[38;5;10m[49m     edges_loaded = 0
[0m[49m[38;5;10m+     582[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     583[0m:[38;5;10m[49m     for entity in medication_entities:
[0m[49m[38;5;10m+     584[0m:[38;5;10m[49m         # Skip if it's the subject drug itself (labels mention their own drug).
[0m[49m[38;5;10m+     585[0m:[38;5;10m[49m         if entity["rxcui"] == subject_rxcui:
[0m[49m[38;5;10m+     586[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+     587[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     588[0m:[38;5;10m[49m         # Create a direct INTERACTS_WITH edge between the two drugs.
[0m[49m[38;5;10m+     589[0m:[38;5;10m[49m         # FDA label = Established evidence level.
[0m[49m[38;5;10m+     590[0m:[38;5;10m[49m         query = """
[0m[49m[38;5;10m+     591[0m:[38;5;10m[49m         MATCH (a:Drug {rxcui: $rxcui_a})
[0m[49m[38;5;10m+     592[0m:[38;5;10m[49m         MATCH (b:Drug {rxcui: $rxcui_b})
[0m[49m[38;5;10m+     593[0m:[38;5;10m[49m         MERGE (a)-[r:INTERACTS_WITH]-(b)
[0m[49m[38;5;10m+     594[0m:[38;5;10m[49m         SET r.source = 'FDA_SPL',
[0m[49m[38;5;10m+     595[0m:[38;5;10m[49m             r.evidence_level = 'Established',
[0m[49m[38;5;10m+     596[0m:[38;5;10m[49m             r.label_text = $context,
[0m[49m[38;5;10m+     597[0m:[38;5;10m[49m             r.last_updated = $today
[0m[49m[38;5;10m+     598[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     599[0m:[38;5;10m[49m         run_opencypher_query(
[0m[49m[38;5;10m+     600[0m:[38;5;10m[49m             query,
[0m[49m[38;5;10m+     601[0m:[38;5;10m[49m             parameters={
[0m[49m[38;5;10m+     602[0m:[38;5;10m[49m                 "rxcui_a": subject_rxcui,
[0m[49m[38;5;10m+     603[0m:[38;5;10m[49m                 "rxcui_b": entity["rxcui"],
[0m[49m[38;5;10m+     604[0m:[38;5;10m[49m                 "context": entity.get("context", "")[:500],  # Truncate for storage
[0m[49m[38;5;10m+     605[0m:[38;5;10m[49m                 "today": str(date.today()),
[0m[49m[38;5;10m+     606[0m:[38;5;10m[49m             },
[0m[49m[38;5;10m+     607[0m:[38;5;10m[49m             use_writer=True,
[0m[49m[38;5;10m+     608[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     609[0m:[38;5;10m[49m         edges_loaded += 1
[0m[49m[38;5;10m+     610[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     611[0m:[38;5;10m[49m     logger.info(f"  Loaded {edges_loaded} interaction edges from {subject_name} label.")
[0m[49m[38;5;10m+     612[0m:[38;5;10m[49m     return edges_loaded
[0m[49m[38;5;10m+     613[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     614[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     615[0m:[38;5;10m[49m def _extract_section_text(section_elem, ns: dict) -> str:
[0m[49m[38;5;10m+     616[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     617[0m:[38;5;10m[49m     Recursively extract all text content from an SPL section element.
[0m[49m[38;5;10m+     618[0m:[38;5;10m[49m     SPL sections contain nested <paragraph>, <list>, <item> elements.
[0m[49m[38;5;10m+     619[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     620[0m:[38;5;10m[49m     texts = []
[0m[49m[38;5;10m+     621[0m:[38;5;10m[49m     for elem in section_elem.iter():
[0m[49m[38;5;10m+     622[0m:[38;5;10m[49m         if elem.text:
[0m[49m[38;5;10m+     623[0m:[38;5;10m[49m             texts.append(elem.text.strip())
[0m[49m[38;5;10m+     624[0m:[38;5;10m[49m         if elem.tail:
[0m[49m[38;5;10m+     625[0m:[38;5;10m[49m             texts.append(elem.tail.strip())
[0m[49m[38;5;10m+     626[0m:[38;5;10m[49m     return " ".join(t for t in texts if t)
[0m[49m[38;5;10m+     627[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     628[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     629[0m:[38;5;10m[49m def _extract_medications_from_text(text: str) -> list[dict]:
[0m[49m[38;5;10m+     630[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     631[0m:[38;5;10m[49m     Use Comprehend Medical to extract medication entities from text
[0m[49m[38;5;10m+     632[0m:[38;5;10m[49m     and resolve them to RxNorm CUIs.
[0m[49m[38;5;10m+     633[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     634[0m:[38;5;10m[49m     Comprehend Medical's DetectEntitiesV2 identifies MEDICATION entities
[0m[49m[38;5;10m+     635[0m:[38;5;10m[49m     with attributes like dosage, route, and frequency. We then use
[0m[49m[38;5;10m+     636[0m:[38;5;10m[49m     InferRxNorm to link each medication mention to its RxNorm concept.
[0m[49m[38;5;10m+     637[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     638[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     639[0m:[38;5;10m[49m         text: Natural language text containing medication mentions.
[0m[49m[38;5;10m+     640[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     641[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     642[0m:[38;5;10m[49m         List of dicts with keys: name, rxcui, confidence, context
[0m[49m[38;5;10m+     643[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     644[0m:[38;5;10m[49m     medications = []
[0m[49m[38;5;10m+     645[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     646[0m:[38;5;10m[49m     # Comprehend Medical has a 20,000 character limit per request.
[0m[49m[38;5;10m+     647[0m:[38;5;10m[49m     # Split text into chunks if needed.
[0m[49m[38;5;10m+     648[0m:[38;5;10m[49m     chunks = [text[i:i + 19000] for i in range(0, len(text), 19000)]
[0m[49m[38;5;10m+     649[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     650[0m:[38;5;10m[49m     for chunk in chunks:
[0m[49m[38;5;10m+     651[0m:[38;5;10m[49m         # Step 1: Detect medication entities.
[0m[49m[38;5;10m+     652[0m:[38;5;10m[49m         detect_response = comprehend_medical_client.detect_entities_v2(Text=chunk)
[0m[49m[38;5;10m+     653[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     654[0m:[38;5;10m[49m         for entity in detect_response.get("Entities", []):
[0m[49m[38;5;10m+     655[0m:[38;5;10m[49m             if entity["Category"] != "MEDICATION":
[0m[49m[38;5;10m+     656[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+     657[0m:[38;5;10m[49m             if entity["Score"] < 0.7:
[0m[49m[38;5;10m+     658[0m:[38;5;10m[49m                 continue  # Low confidence, skip
[0m[49m[38;5;10m+     659[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     660[0m:[38;5;10m[49m             med_name = entity["Text"]
[0m[49m[38;5;10m+     661[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     662[0m:[38;5;10m[49m             # Step 2: Resolve to RxNorm CUI.
[0m[49m[38;5;10m+     663[0m:[38;5;10m[49m             rxcui = _infer_rxnorm_cui(med_name)
[0m[49m[38;5;10m+     664[0m:[38;5;10m[49m             if not rxcui:
[0m[49m[38;5;10m+     665[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+     666[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     667[0m:[38;5;10m[49m             # Grab surrounding context for the label_text property.
[0m[49m[38;5;10m+     668[0m:[38;5;10m[49m             start = max(0, entity["BeginOffset"] - 100)
[0m[49m[38;5;10m+     669[0m:[38;5;10m[49m             end = min(len(chunk), entity["EndOffset"] + 100)
[0m[49m[38;5;10m+     670[0m:[38;5;10m[49m             context = chunk[start:end]
[0m[49m[38;5;10m+     671[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     672[0m:[38;5;10m[49m             medications.append({
[0m[49m[38;5;10m+     673[0m:[38;5;10m[49m                 "name": med_name,
[0m[49m[38;5;10m+     674[0m:[38;5;10m[49m                 "rxcui": rxcui,
[0m[49m[38;5;10m+     675[0m:[38;5;10m[49m                 "confidence": entity["Score"],
[0m[49m[38;5;10m+     676[0m:[38;5;10m[49m                 "context": context,
[0m[49m[38;5;10m+     677[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+     678[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     679[0m:[38;5;10m[49m     return medications
[0m[49m[38;5;10m+     680[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     681[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     682[0m:[38;5;10m[49m def _infer_rxnorm_cui(medication_text: str) -> str | None:
[0m[49m[38;5;10m+     683[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     684[0m:[38;5;10m[49m     Use Comprehend Medical InferRxNorm to resolve a medication name
[0m[49m[38;5;10m+     685[0m:[38;5;10m[49m     to its RxNorm CUI.
[0m[49m[38;5;10m+     686[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     687[0m:[38;5;10m[49m     InferRxNorm takes free text and returns the best-matching RxNorm
[0m[49m[38;5;10m+     688[0m:[38;5;10m[49m     concepts with confidence scores. We take the top result if it's
[0m[49m[38;5;10m+     689[0m:[38;5;10m[49m     above our confidence threshold.
[0m[49m[38;5;10m+     690[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     691[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     692[0m:[38;5;10m[49m         medication_text: Drug name string (e.g., "warfarin", "Coumadin 5mg")
[0m[49m[38;5;10m+     693[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     694[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     695[0m:[38;5;10m[49m         RxNorm CUI string, or None if no confident match.
[0m[49m[38;5;10m+     696[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     697[0m:[38;5;10m[49m     try:
[0m[49m[38;5;10m+     698[0m:[38;5;10m[49m         response = comprehend_medical_client.infer_rx_norm(Text=medication_text)
[0m[49m[38;5;10m+     699[0m:[38;5;10m[49m     except Exception as e:
[0m[49m[38;5;10m+     700[0m:[38;5;10m[49m         logger.warning(f"  InferRxNorm failed for '{medication_text}': {e}")
[0m[49m[38;5;10m+     701[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+     702[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     703[0m:[38;5;10m[49m     entities = response.get("Entities", [])
[0m[49m[38;5;10m+     704[0m:[38;5;10m[49m     if not entities:
[0m[49m[38;5;10m+     705[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+     706[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     707[0m:[38;5;10m[49m     # Take the top-scoring concept.
[0m[49m[38;5;10m+     708[0m:[38;5;10m[49m     top = entities[0]
[0m[49m[38;5;10m+     709[0m:[38;5;10m[49m     if top.get("Score", 0) < 0.7:
[0m[49m[38;5;10m+     710[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+     711[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     712[0m:[38;5;10m[49m     # RxNorm concepts are in the RxNormConcepts list.
[0m[49m[38;5;10m+     713[0m:[38;5;10m[49m     concepts = top.get("RxNormConcepts", [])
[0m[49m[38;5;10m+     714[0m:[38;5;10m[49m     if not concepts:
[0m[49m[38;5;10m+     715[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+     716[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     717[0m:[38;5;10m[49m     # Prefer ingredient-level concepts (TTY = "IN") for interaction matching.
[0m[49m[38;5;10m+     718[0m:[38;5;10m[49m     for concept in concepts:
[0m[49m[38;5;10m+     719[0m:[38;5;10m[49m         if concept.get("Score", 0) >= 0.7:
[0m[49m[38;5;10m+     720[0m:[38;5;10m[49m             return concept.get("Code")
[0m[49m[38;5;10m+     721[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     722[0m:[38;5;10m[49m     return None
[0m[49m[38;5;10m+     723[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     724[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     725[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     726[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     727[0m:[38;5;10m[49m ## Step 4: Build the Interaction Query Engine
[0m[49m[38;5;10m+     728[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     729[0m:[38;5;10m[49m *The pseudocode calls this `check_interactions(medication_list, patient_context)`. This is the core clinical function. Given a patient's medication list, it traverses the graph to find interaction paths using two strategies: direct curated edges (fast, catches known pairs) and mechanism-based inference (catches interactions that nobody has explicitly curated). It then scores each interaction by clinical significance and returns ranked results.*
[0m[49m[38;5;10m+     730[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     731[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     732[0m:[38;5;10m[49m def check_interactions(medication_list: list[dict], patient_context: dict = None) -> dict:
[0m[49m[38;5;10m+     733[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     734[0m:[38;5;10m[49m     Check a patient's medication list for drug-drug interactions.
[0m[49m[38;5;10m+     735[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     736[0m:[38;5;10m[49m     This is the function that clinical systems call at the point of prescribing.
[0m[49m[38;5;10m+     737[0m:[38;5;10m[49m     It combines two strategies:
[0m[49m[38;5;10m+     738[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     739[0m:[38;5;10m[49m     1. Direct lookup: Check for explicitly curated INTERACTS_WITH edges between
[0m[49m[38;5;10m+     740[0m:[38;5;10m[49m        drug pairs. These come from FDA labels, DrugBank, and other curated sources.
[0m[49m[38;5;10m+     741[0m:[38;5;10m[49m        Fast and high-confidence, but only catches known pairs.
[0m[49m[38;5;10m+     742[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     743[0m:[38;5;10m[49m     2. Mechanism-based inference: Find drugs that share enzyme/transporter targets
[0m[49m[38;5;10m+     744[0m:[38;5;10m[49m        with conflicting relationships (one is a substrate, the other is an inhibitor
[0m[49m[38;5;10m+     745[0m:[38;5;10m[49m        or inducer of the same enzyme). This catches interactions that haven't been
[0m[49m[38;5;10m+     746[0m:[38;5;10m[49m        explicitly curated but are pharmacologically predictable.
[0m[49m[38;5;10m+     747[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     748[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     749[0m:[38;5;10m[49m         medication_list: List of dicts, each with at minimum:
[0m[49m[38;5;10m+     750[0m:[38;5;10m[49m             - rxcui: RxNorm CUI for the drug
[0m[49m[38;5;10m+     751[0m:[38;5;10m[49m             - name: Drug name (for display)
[0m[49m[38;5;10m+     752[0m:[38;5;10m[49m             Optional (improve scoring):
[0m[49m[38;5;10m+     753[0m:[38;5;10m[49m             - dose: Current dose
[0m[49m[38;5;10m+     754[0m:[38;5;10m[49m             - frequency: Dosing frequency
[0m[49m[38;5;10m+     755[0m:[38;5;10m[49m             - duration_days: How long the patient has been on this drug
[0m[49m[38;5;10m+     756[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     757[0m:[38;5;10m[49m         patient_context: Optional dict with patient factors that modulate
[0m[49m[38;5;10m+     758[0m:[38;5;10m[49m             interaction severity:
[0m[49m[38;5;10m+     759[0m:[38;5;10m[49m             - age: Patient age in years
[0m[49m[38;5;10m+     760[0m:[38;5;10m[49m             - renal_function: eGFR value (mL/min/1.73m2)
[0m[49m[38;5;10m+     761[0m:[38;5;10m[49m             - hepatic_function: "normal", "mild_impairment", "moderate_impairment", "severe_impairment"
[0m[49m[38;5;10m+     762[0m:[38;5;10m[49m             - weight_kg: Patient weight
[0m[49m[38;5;10m+     763[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     764[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     765[0m:[38;5;10m[49m         Dict with interaction results, counts, and processing metadata.
[0m[49m[38;5;10m+     766[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     767[0m:[38;5;10m[49m     if patient_context is None:
[0m[49m[38;5;10m+     768[0m:[38;5;10m[49m         patient_context = {}
[0m[49m[38;5;10m+     769[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     770[0m:[38;5;10m[49m     all_interactions = []
[0m[49m[38;5;10m+     771[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     772[0m:[38;5;10m[49m     # Generate all unique pairs from the medication list.
[0m[49m[38;5;10m+     773[0m:[38;5;10m[49m     med_pairs = list(combinations(medication_list, 2))
[0m[49m[38;5;10m+     774[0m:[38;5;10m[49m     logger.info(f"Checking {len(med_pairs)} medication pairs for interactions.")
[0m[49m[38;5;10m+     775[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     776[0m:[38;5;10m[49m     # Strategy 1: Direct curated interaction edges.
[0m[49m[38;5;10m+     777[0m:[38;5;10m[49m     for med_a, med_b in med_pairs:
[0m[49m[38;5;10m+     778[0m:[38;5;10m[49m         direct_results = _check_direct_interactions(med_a["rxcui"], med_b["rxcui"])
[0m[49m[38;5;10m+     779[0m:[38;5;10m[49m         for result in direct_results:
[0m[49m[38;5;10m+     780[0m:[38;5;10m[49m             result["drug_a"] = med_a
[0m[49m[38;5;10m+     781[0m:[38;5;10m[49m             result["drug_b"] = med_b
[0m[49m[38;5;10m+     782[0m:[38;5;10m[49m             all_interactions.append(result)
[0m[49m[38;5;10m+     783[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     784[0m:[38;5;10m[49m     # Strategy 2: Mechanism-based inference.
[0m[49m[38;5;10m+     785[0m:[38;5;10m[49m     # First, get enzyme/transporter targets for each drug.
[0m[49m[38;5;10m+     786[0m:[38;5;10m[49m     drug_targets = {}
[0m[49m[38;5;10m+     787[0m:[38;5;10m[49m     for med in medication_list:
[0m[49m[38;5;10m+     788[0m:[38;5;10m[49m         drug_targets[med["rxcui"]] = _get_drug_targets(med["rxcui"])
[0m[49m[38;5;10m+     789[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     790[0m:[38;5;10m[49m     # Check for conflicting relationships on shared targets.
[0m[49m[38;5;10m+     791[0m:[38;5;10m[49m     for med_a, med_b in med_pairs:
[0m[49m[38;5;10m+     792[0m:[38;5;10m[49m         inferred = _check_mechanism_interactions(
[0m[49m[38;5;10m+     793[0m:[38;5;10m[49m             med_a, med_b,
[0m[49m[38;5;10m+     794[0m:[38;5;10m[49m             drug_targets.get(med_a["rxcui"], []),
[0m[49m[38;5;10m+     795[0m:[38;5;10m[49m             drug_targets.get(med_b["rxcui"], []),
[0m[49m[38;5;10m+     796[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     797[0m:[38;5;10m[49m         all_interactions.extend(inferred)
[0m[49m[38;5;10m+     798[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     799[0m:[38;5;10m[49m     # Score each interaction by clinical significance.
[0m[49m[38;5;10m+     800[0m:[38;5;10m[49m     scored = []
[0m[49m[38;5;10m+     801[0m:[38;5;10m[49m     for interaction in all_interactions:
[0m[49m[38;5;10m+     802[0m:[38;5;10m[49m         score = _calculate_significance_score(interaction, patient_context)
[0m[49m[38;5;10m+     803[0m:[38;5;10m[49m         interaction["score"] = score
[0m[49m[38;5;10m+     804[0m:[38;5;10m[49m         interaction["recommendation"] = _generate_recommendation(interaction)
[0m[49m[38;5;10m+     805[0m:[38;5;10m[49m         scored.append(interaction)
[0m[49m[38;5;10m+     806[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     807[0m:[38;5;10m[49m     # Sort by score descending (most clinically significant first).
[0m[49m[38;5;10m+     808[0m:[38;5;10m[49m     scored.sort(key=lambda x: x["score"], reverse=True)
[0m[49m[38;5;10m+     809[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     810[0m:[38;5;10m[49m     # Split into significant (alert-worthy) and suppressed.
[0m[49m[38;5;10m+     811[0m:[38;5;10m[49m     significant = [i for i in scored if i["score"] >= SIGNIFICANCE_THRESHOLD]
[0m[49m[38;5;10m+     812[0m:[38;5;10m[49m     suppressed = [i for i in scored if i["score"] < SIGNIFICANCE_THRESHOLD]
[0m[49m[38;5;10m+     813[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     814[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     815[0m:[38;5;10m[49m         "interactions": significant,
[0m[49m[38;5;10m+     816[0m:[38;5;10m[49m         "suppressed_interactions": suppressed,
[0m[49m[38;5;10m+     817[0m:[38;5;10m[49m         "pairs_evaluated": len(med_pairs),
[0m[49m[38;5;10m+     818[0m:[38;5;10m[49m         "total_found": len(all_interactions),
[0m[49m[38;5;10m+     819[0m:[38;5;10m[49m         "total_significant": len(significant),
[0m[49m[38;5;10m+     820[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     821[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     822[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     823[0m:[38;5;10m[49m def _check_direct_interactions(rxcui_a: str, rxcui_b: str) -> list[dict]:
[0m[49m[38;5;10m+     824[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     825[0m:[38;5;10m[49m     Query Neptune for direct INTERACTS_WITH edges between two drugs.
[0m[49m[38;5;10m+     826[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     827[0m:[38;5;10m[49m     These edges come from curated sources (FDA labels, DrugBank, MED-RT).
[0m[49m[38;5;10m+     828[0m:[38;5;10m[49m     They represent explicitly documented interactions with evidence.
[0m[49m[38;5;10m+     829[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     830[0m:[38;5;10m[49m     query = """
[0m[49m[38;5;10m+     831[0m:[38;5;10m[49m     MATCH (a:Drug {rxcui: $rxcui_a})-[r:INTERACTS_WITH]-(b:Drug {rxcui: $rxcui_b})
[0m[49m[38;5;10m+     832[0m:[38;5;10m[49m     RETURN r.source AS source,
[0m[49m[38;5;10m+     833[0m:[38;5;10m[49m            r.evidence_level AS evidence_level,
[0m[49m[38;5;10m+     834[0m:[38;5;10m[49m            r.severity AS severity,
[0m[49m[38;5;10m+     835[0m:[38;5;10m[49m            r.mechanism AS mechanism,
[0m[49m[38;5;10m+     836[0m:[38;5;10m[49m            r.clinical_effect AS clinical_effect,
[0m[49m[38;5;10m+     837[0m:[38;5;10m[49m            r.label_text AS label_text
[0m[49m[38;5;10m+     838[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     839[0m:[38;5;10m[49m     response = run_opencypher_query(
[0m[49m[38;5;10m+     840[0m:[38;5;10m[49m         query,
[0m[49m[38;5;10m+     841[0m:[38;5;10m[49m         parameters={"rxcui_a": rxcui_a, "rxcui_b": rxcui_b},
[0m[49m[38;5;10m+     842[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     843[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     844[0m:[38;5;10m[49m     results = []
[0m[49m[38;5;10m+     845[0m:[38;5;10m[49m     for record in response.get("results", []):
[0m[49m[38;5;10m+     846[0m:[38;5;10m[49m         results.append({
[0m[49m[38;5;10m+     847[0m:[38;5;10m[49m             "type": "direct",
[0m[49m[38;5;10m+     848[0m:[38;5;10m[49m             "source": record.get("source", "Unknown"),
[0m[49m[38;5;10m+     849[0m:[38;5;10m[49m             "evidence_level": record.get("evidence_level", "Suspected"),
[0m[49m[38;5;10m+     850[0m:[38;5;10m[49m             "severity": record.get("severity", "Moderate"),
[0m[49m[38;5;10m+     851[0m:[38;5;10m[49m             "mechanism": record.get("mechanism", "Unknown"),
[0m[49m[38;5;10m+     852[0m:[38;5;10m[49m             "clinical_effect": record.get("clinical_effect", ""),
[0m[49m[38;5;10m+     853[0m:[38;5;10m[49m             "label_text": record.get("label_text", ""),
[0m[49m[38;5;10m+     854[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     855[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     856[0m:[38;5;10m[49m     return results
[0m[49m[38;5;10m+     857[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     858[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     859[0m:[38;5;10m[49m def _get_drug_targets(rxcui: str) -> list[dict]:
[0m[49m[38;5;10m+     860[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     861[0m:[38;5;10m[49m     Get all enzyme and transporter relationships for a drug.
[0m[49m[38;5;10m+     862[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     863[0m:[38;5;10m[49m     Returns a list of targets with the relationship type (SUBSTRATE_OF,
[0m[49m[38;5;10m+     864[0m:[38;5;10m[49m     INHIBITS, INDUCES) and strength.
[0m[49m[38;5;10m+     865[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     866[0m:[38;5;10m[49m     query = """
[0m[49m[38;5;10m+     867[0m:[38;5;10m[49m     MATCH (d:Drug {rxcui: $rxcui})-[r]->(t)
[0m[49m[38;5;10m+     868[0m:[38;5;10m[49m     WHERE t:Enzyme OR t:Transporter
[0m[49m[38;5;10m+     869[0m:[38;5;10m[49m     RETURN t.protein_id AS target_id,
[0m[49m[38;5;10m+     870[0m:[38;5;10m[49m            t.name AS target_name,
[0m[49m[38;5;10m+     871[0m:[38;5;10m[49m            type(r) AS relationship,
[0m[49m[38;5;10m+     872[0m:[38;5;10m[49m            r.strength AS strength,
[0m[49m[38;5;10m+     873[0m:[38;5;10m[49m            labels(t)[0] AS target_type
[0m[49m[38;5;10m+     874[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     875[0m:[38;5;10m[49m     response = run_opencypher_query(query, parameters={"rxcui": rxcui})
[0m[49m[38;5;10m+     876[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     877[0m:[38;5;10m[49m     targets = []
[0m[49m[38;5;10m+     878[0m:[38;5;10m[49m     for record in response.get("results", []):
[0m[49m[38;5;10m+     879[0m:[38;5;10m[49m         targets.append({
[0m[49m[38;5;10m+     880[0m:[38;5;10m[49m             "target_id": record.get("target_id"),
[0m[49m[38;5;10m+     881[0m:[38;5;10m[49m             "target_name": record.get("target_name"),
[0m[49m[38;5;10m+     882[0m:[38;5;10m[49m             "relationship": record.get("relationship"),
[0m[49m[38;5;10m+     883[0m:[38;5;10m[49m             "strength": record.get("strength", "unknown"),
[0m[49m[38;5;10m+     884[0m:[38;5;10m[49m             "target_type": record.get("target_type"),
[0m[49m[38;5;10m+     885[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     886[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     887[0m:[38;5;10m[49m     return targets
[0m[49m[38;5;10m+     888[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     889[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     890[0m:[38;5;10m[49m def _check_mechanism_interactions(
[0m[49m[38;5;10m+     891[0m:[38;5;10m[49m     med_a: dict, med_b: dict,
[0m[49m[38;5;10m+     892[0m:[38;5;10m[49m     targets_a: list[dict], targets_b: list[dict],
[0m[49m[38;5;10m+     893[0m:[38;5;10m[49m ) -> list[dict]:
[0m[49m[38;5;10m+     894[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     895[0m:[38;5;10m[49m     Infer interactions based on shared enzyme/transporter targets.
[0m[49m[38;5;10m+     896[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     897[0m:[38;5;10m[49m     The logic: if Drug A is a SUBSTRATE_OF enzyme X, and Drug B INHIBITS
[0m[49m[38;5;10m+     898[0m:[38;5;10m[49m     enzyme X, then Drug B will reduce the metabolism of Drug A, increasing
[0m[49m[38;5;10m+     899[0m:[38;5;10m[49m     its plasma concentration. This is a pharmacokinetic interaction.
[0m[49m[38;5;10m+     900[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     901[0m:[38;5;10m[49m     Similarly, if Drug B INDUCES enzyme X, it will increase metabolism of
[0m[49m[38;5;10m+     902[0m:[38;5;10m[49m     Drug A, potentially reducing its therapeutic effect.
[0m[49m[38;5;10m+     903[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     904[0m:[38;5;10m[49m     We check both directions (A affects B, B affects A) for each shared target.
[0m[49m[38;5;10m+     905[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     906[0m:[38;5;10m[49m     interactions = []
[0m[49m[38;5;10m+     907[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     908[0m:[38;5;10m[49m     # Build lookup maps for each drug's targets.
[0m[49m[38;5;10m+     909[0m:[38;5;10m[49m     targets_a_by_id = {t["target_id"]: t for t in targets_a}
[0m[49m[38;5;10m+     910[0m:[38;5;10m[49m     targets_b_by_id = {t["target_id"]: t for t in targets_b}
[0m[49m[38;5;10m+     911[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     912[0m:[38;5;10m[49m     # Find shared targets (both drugs interact with the same enzyme/transporter).
[0m[49m[38;5;10m+     913[0m:[38;5;10m[49m     shared_target_ids = set(targets_a_by_id.keys()) & set(targets_b_by_id.keys())
[0m[49m[38;5;10m+     914[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     915[0m:[38;5;10m[49m     for target_id in shared_target_ids:
[0m[49m[38;5;10m+     916[0m:[38;5;10m[49m         rel_a = targets_a_by_id[target_id]
[0m[49m[38;5;10m+     917[0m:[38;5;10m[49m         rel_b = targets_b_by_id[target_id]
[0m[49m[38;5;10m+     918[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     919[0m:[38;5;10m[49m         # Case 1: A is substrate, B inhibits -> B increases A's levels.
[0m[49m[38;5;10m+     920[0m:[38;5;10m[49m         if rel_a["relationship"] == "SUBSTRATE_OF" and rel_b["relationship"] == "INHIBITS":
[0m[49m[38;5;10m+     921[0m:[38;5;10m[49m             interactions.append({
[0m[49m[38;5;10m+     922[0m:[38;5;10m[49m                 "drug_a": med_a,
