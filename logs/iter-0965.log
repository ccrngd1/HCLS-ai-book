[0m[49m[38;5;10m+     992[0m:[38;5;10m[49m def _infer_severity_from_strength(inhibition_strength: str) -> str:
[0m[49m[38;5;10m+     993[0m:[38;5;10m[49m     """Map inhibition strength to a severity estimate for inferred interactions."""
[0m[49m[38;5;10m+     994[0m:[38;5;10m[49m     strength_to_severity = {
[0m[49m[38;5;10m+     995[0m:[38;5;10m[49m         "strong": "Major",
[0m[49m[38;5;10m+     996[0m:[38;5;10m[49m         "moderate": "Moderate",
[0m[49m[38;5;10m+     997[0m:[38;5;10m[49m         "weak": "Minor",
[0m[49m[38;5;10m+     998[0m:[38;5;10m[49m         "unknown": "Moderate",  # Conservative default
[0m[49m[38;5;10m+     999[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1000[0m:[38;5;10m[49m     return strength_to_severity.get(inhibition_strength, "Moderate")
[0m[49m[38;5;10m+    1001[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1002[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1003[0m:[38;5;10m[49m def _calculate_significance_score(interaction: dict, patient_context: dict) -> float:
[0m[49m[38;5;10m+    1004[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1005[0m:[38;5;10m[49m     Calculate a clinical significance score for an interaction.
[0m[49m[38;5;10m+    1006[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1007[0m:[38;5;10m[49m     The score combines:
[0m[49m[38;5;10m+    1008[0m:[38;5;10m[49m     - Severity weight (how dangerous is this type of interaction?)
[0m[49m[38;5;10m+    1009[0m:[38;5;10m[49m     - Evidence weight (how confident are we this interaction is real?)
[0m[49m[38;5;10m+    1010[0m:[38;5;10m[49m     - Inhibition strength (for mechanism-based: how strong is the effect?)
[0m[49m[38;5;10m+    1011[0m:[38;5;10m[49m     - Patient factors (age, organ function modify the risk)
[0m[49m[38;5;10m+    1012[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1013[0m:[38;5;10m[49m     Score range: 0.0 to 1.0. Higher = more clinically significant.
[0m[49m[38;5;10m+    1014[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1015[0m:[38;5;10m[49m     severity = interaction.get("severity", "Moderate")
[0m[49m[38;5;10m+    1016[0m:[38;5;10m[49m     evidence = interaction.get("evidence_level", "Suspected")
[0m[49m[38;5;10m+    1017[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1018[0m:[38;5;10m[49m     base_score = SEVERITY_WEIGHTS.get(severity, 0.5)
[0m[49m[38;5;10m+    1019[0m:[38;5;10m[49m     evidence_multiplier = EVIDENCE_WEIGHTS.get(evidence, 0.5)
[0m[49m[38;5;10m+    1020[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1021[0m:[38;5;10m[49m     score = base_score * evidence_multiplier
[0m[49m[38;5;10m+    1022[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1023[0m:[38;5;10m[49m     # For inferred interactions, factor in inhibition strength.
[0m[49m[38;5;10m+    1024[0m:[38;5;10m[49m     if interaction.get("type") == "inferred":
[0m[49m[38;5;10m+    1025[0m:[38;5;10m[49m         strength = interaction.get("inhibitor_strength", "unknown")
[0m[49m[38;5;10m+    1026[0m:[38;5;10m[49m         strength_mult = INHIBITION_STRENGTH_MULTIPLIERS.get(strength, 0.5)
[0m[49m[38;5;10m+    1027[0m:[38;5;10m[49m         score *= strength_mult
[0m[49m[38;5;10m+    1028[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1029[0m:[38;5;10m[49m     # Patient context modifiers.
[0m[49m[38;5;10m+    1030[0m:[38;5;10m[49m     age = patient_context.get("age")
[0m[49m[38;5;10m+    1031[0m:[38;5;10m[49m     if age and age > 75:
[0m[49m[38;5;10m+    1032[0m:[38;5;10m[49m         # Elderly patients have reduced clearance. Interactions hit harder.
[0m[49m[38;5;10m+    1033[0m:[38;5;10m[49m         score *= 1.15
[0m[49m[38;5;10m+    1034[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1035[0m:[38;5;10m[49m     hepatic = patient_context.get("hepatic_function", "normal")
[0m[49m[38;5;10m+    1036[0m:[38;5;10m[49m     if hepatic in ("moderate_impairment", "severe_impairment"):
[0m[49m[38;5;10m+    1037[0m:[38;5;10m[49m         # Impaired liver function means CYP-mediated interactions are amplified.
[0m[49m[38;5;10m+    1038[0m:[38;5;10m[49m         if "ENZYME" in interaction.get("mechanism", ""):
[0m[49m[38;5;10m+    1039[0m:[38;5;10m[49m             score *= 1.2
[0m[49m[38;5;10m+    1040[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1041[0m:[38;5;10m[49m     # Cap at 1.0.
[0m[49m[38;5;10m+    1042[0m:[38;5;10m[49m     return min(score, 1.0)
[0m[49m[38;5;10m+    1043[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1044[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1045[0m:[38;5;10m[49m def _generate_recommendation(interaction: dict) -> str:
[0m[49m[38;5;10m+    1046[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1047[0m:[38;5;10m[49m     Generate a brief clinical recommendation based on the interaction type.
[0m[49m[38;5;10m+    1048[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1049[0m:[38;5;10m[49m     In production, these would come from a curated recommendation database
[0m[49m[38;5;10m+    1050[0m:[38;5;10m[49m     or clinical decision support rules. This is a simplified placeholder
[0m[49m[38;5;10m+    1051[0m:[38;5;10m[49m     that demonstrates the pattern.
[0m[49m[38;5;10m+    1052[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1053[0m:[38;5;10m[49m     mechanism = interaction.get("mechanism", "")
[0m[49m[38;5;10m+    1054[0m:[38;5;10m[49m     severity = interaction.get("severity", "Moderate")
[0m[49m[38;5;10m+    1055[0m:[38;5;10m[49m     target = interaction.get("target_name", "")
[0m[49m[38;5;10m+    1056[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1057[0m:[38;5;10m[49m     if severity == "Contraindicated":
[0m[49m[38;5;10m+    1058[0m:[38;5;10m[49m         return "Avoid combination. Consider therapeutic alternative."
[0m[49m[38;5;10m+    1059[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1060[0m:[38;5;10m[49m     if mechanism == "PK_ENZYME_INHIBITION":
[0m[49m[38;5;10m+    1061[0m:[38;5;10m[49m         drug_a_name = interaction.get("drug_a", {}).get("name", "substrate drug")
[0m[49m[38;5;10m+    1062[0m:[38;5;10m[49m         return (
[0m[49m[38;5;10m+    1063[0m:[38;5;10m[49m             f"Monitor for increased {drug_a_name} effects. "
[0m[49m[38;5;10m+    1064[0m:[38;5;10m[49m             f"Consider dose reduction or enhanced monitoring. "
[0m[49m[38;5;10m+    1065[0m:[38;5;10m[49m             f"Mechanism: {target} inhibition."
[0m[49m[38;5;10m+    1066[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    1067[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1068[0m:[38;5;10m[49m     if mechanism == "PK_ENZYME_INDUCTION":
[0m[49m[38;5;10m+    1069[0m:[38;5;10m[49m         drug_a_name = interaction.get("drug_a", {}).get("name", "substrate drug")
[0m[49m[38;5;10m+    1070[0m:[38;5;10m[49m         return (
[0m[49m[38;5;10m+    1071[0m:[38;5;10m[49m             f"Monitor for decreased {drug_a_name} efficacy. "
[0m[49m[38;5;10m+    1072[0m:[38;5;10m[49m             f"Consider dose increase or therapeutic drug monitoring. "
[0m[49m[38;5;10m+    1073[0m:[38;5;10m[49m             f"Mechanism: {target} induction."
[0m[49m[38;5;10m+    1074[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    1075[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1076[0m:[38;5;10m[49m     return "Monitor patient. Review clinical significance for this combination."
[0m[49m[38;5;10m+    1077[0m:[38;5;10m[49m ```
