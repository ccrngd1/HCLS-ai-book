[0m[49m[38;5;10m+    1135[0m:[38;5;10m[49m         raw_interactions = json.loads(cached)
[0m[49m[38;5;10m+    1136[0m:[38;5;10m[49m         logger.info(f"Cache hit for {cache_key}. Re-scoring {len(raw_interactions)} interactions.")
[0m[49m[38;5;10m+    1137[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1138[0m:[38;5;10m[49m         scored = []
[0m[49m[38;5;10m+    1139[0m:[38;5;10m[49m         for interaction in raw_interactions:
[0m[49m[38;5;10m+    1140[0m:[38;5;10m[49m             score = _calculate_significance_score(interaction, patient_context)
[0m[49m[38;5;10m+    1141[0m:[38;5;10m[49m             interaction["score"] = score
[0m[49m[38;5;10m+    1142[0m:[38;5;10m[49m             interaction["recommendation"] = _generate_recommendation(interaction)
