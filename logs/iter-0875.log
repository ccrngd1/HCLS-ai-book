[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m     print(f"  Uploaded to: s3://{S3_BUCKET}/{s3_key}")
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m     # Step 2: Detect reference marker
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m     print("\n[Step 2] Detecting reference marker...")
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m     marker_result = detect_reference_marker(image)
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m     if not marker_result["detected"]:
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m         print("  WARNING: No reference marker detected!")
