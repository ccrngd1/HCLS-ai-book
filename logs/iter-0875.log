[49m[38;5;10m+      1[0m:[38;5;10m[49m # Recipe 9.3: Python Implementation Example
[0m[49m[38;5;10m+      2[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      3[0m:[38;5;10m[49m > **Heads up:** This is a deliberately simple, illustrative implementation of the pseudocode walkthrough from Recipe 9.3. It shows one way you could translate wound photography measurement concepts into working Python code. It is not production-ready. There's no error handling to speak of, no retry logic, no input validation beyond the basics. Think of it as the sketchpad version: useful for understanding the shape of the solution, not something you'd deploy to a wound care clinic on Monday morning. Consider it a starting point, not a destination.
[0m[49m[38;5;10m+      4[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      5[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+      6[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      7[0m:[38;5;10m[49m ## Setup
[0m[49m[38;5;10m+      8[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      9[0m:[38;5;10m[49m You'll need the AWS SDK for Python and a few image processing libraries:
[0m[49m[38;5;10m+     10[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     11[0m:[38;5;10m[49m ```bash
[0m[49m[38;5;10m+     12[0m:[38;5;10m[49m pip install boto3 numpy pillow
[0m[49m[38;5;10m+     13[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     14[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     15[0m:[38;5;10m[49m Your environment needs credentials configured (via environment variables, an instance profile, or `~/.aws/credentials`). The IAM role or user needs:
[0m[49m[38;5;10m+     16[0m:[38;5;10m[49m - `s3:PutObject`, `s3:GetObject` (wound image storage)
[0m[49m[38;5;10m+     17[0m:[38;5;10m[49m - `sagemaker:InvokeEndpoint` (segmentation model inference)
[0m[49m[38;5;10m+     18[0m:[38;5;10m[49m - `dynamodb:PutItem`, `dynamodb:Query` (measurement storage)
[0m[49m[38;5;10m+     19[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     20[0m:[38;5;10m[49m For local testing without a trained SageMaker model, we'll include a synthetic segmentation function that simulates what a real U-Net endpoint would return.
[0m[49m[38;5;10m+     21[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     22[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     23[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     24[0m:[38;5;10m[49m ## Config and Constants
[0m[49m[38;5;10m+     25[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     26[0m:[38;5;10m[49m These go at the top of your module. The reference marker specs and measurement thresholds are configuration, not logic. Readers should see these before the functions that use them.
[0m[49m[38;5;10m+     27[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     28[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     29[0m:[38;5;10m[49m import io
[0m[49m[38;5;10m+     30[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+     31[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+     32[0m:[38;5;10m[49m import datetime
[0m[49m[38;5;10m+     33[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+     34[0m:[38;5;10m[49m from datetime import timezone
[0m[49m[38;5;10m+     35[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     36[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+     37[0m:[38;5;10m[49m import numpy as np
[0m[49m[38;5;10m+     38[0m:[38;5;10m[49m from PIL import Image, ImageDraw
[0m[49m[38;5;10m+     39[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+     40[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     41[0m:[38;5;10m[49m # Configure logging. In production, use JSON-formatted output for
[0m[49m[38;5;10m+     42[0m:[38;5;10m[49m # CloudWatch Logs Insights queries. Never log PHI (patient identifiers,
[0m[49m[38;5;10m+     43[0m:[38;5;10m[49m # wound images, or measurement values tied to a patient).
[0m[49m[38;5;10m+     44[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+     45[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+     46[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     47[0m:[38;5;10m[49m # Retry config for AWS API calls. Adaptive mode uses exponential backoff
[0m[49m[38;5;10m+     48[0m:[38;5;10m[49m # with jitter, which handles burst throttling gracefully.
[0m[49m[38;5;10m+     49[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m # --- Reference Marker Configuration ---
[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m # We use a circular blue calibration sticker with a known physical diameter.
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m # The system detects this circle in the image to compute pixels-per-cm.
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m MARKER_DIAMETER_CM = 2.5  # Physical diameter of the reference marker
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m MARKER_COLOR_RANGE = {
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m     # HSV color range for detecting the blue marker.
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m     # These values work for the standard blue calibration stickers.
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m     # You'll need to tune these if you use a different colored marker.
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m     "hue_min": 100,
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m     "hue_max": 130,
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m     "sat_min": 100,
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m     "sat_max": 255,
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m     "val_min": 80,
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m     "val_max": 255,
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m # --- Measurement Thresholds ---
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m # Minimum pixels-per-cm for a valid scale factor. Below this, the marker
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m # is too small in the image (camera too far away) for reliable measurement.
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m MIN_PIXELS_PER_CM = 10
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m # Maximum pixels-per-cm. Above this, something is wrong (marker too close,
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m # or a false detection).
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m MAX_PIXELS_PER_CM = 100
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m # Segmentation confidence threshold. Below this, flag for human review.
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m SEGMENTATION_CONFIDENCE_THRESHOLD = 0.7
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m # Wound area change threshold for alerting (percentage increase).
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m WOUND_GROWTH_ALERT_THRESHOLD_PCT = 10.0
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m # --- AWS Resource Names ---
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m # Replace these with your actual resource names.
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m S3_BUCKET = "wound-images-bucket"
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m SAGEMAKER_ENDPOINT = "wound-segmentation-unet"
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m DYNAMODB_TABLE = "wound-measurements"
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m # --- Clients ---
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m s3_client = boto3.client("s3", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m sagemaker_runtime = boto3.client("sagemaker-runtime", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m ## Synthetic Test Data
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m For testing without real wound images (which are PHI and require proper data governance), we generate synthetic images with a known "wound" region and reference marker. This lets you validate the measurement pipeline end-to-end.
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m def generate_synthetic_wound_image(
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m     image_size=(1024, 768),
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m     wound_center=(500, 400),
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m     wound_axes=(80, 55),
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m     marker_center=(200, 600),
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m     marker_radius_px=53,
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m ):
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m     Generate a synthetic wound image for testing.
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m     Creates an image with:
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m     - A skin-toned background (simulating periwound tissue)
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m     - An elliptical red region (simulating a wound bed)
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m     - A blue circle (simulating the calibration marker)
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m     The known dimensions let us verify that our measurement pipeline
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m     produces correct results. If the marker is 53px radius and represents
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m     a 2.5cm diameter circle, then pixels_per_cm = (53*2) / 2.5 = 42.4.
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m         tuple: (PIL Image, dict of ground truth values)
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m     img = Image.new("RGB", image_size, color=(210, 180, 160))  # skin tone
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m     draw = ImageDraw.Draw(img)
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m     # Draw the "wound" as a red ellipse
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m     wound_bbox = [
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m         wound_center[0] - wound_axes[0],
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m         wound_center[1] - wound_axes[1],
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m         wound_center[0] + wound_axes[0],
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m         wound_center[1] + wound_axes[1],
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m     draw.ellipse(wound_bbox, fill=(180, 40, 40))  # dark red, granulation tissue
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m     # Draw the reference marker as a blue circle
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m     marker_bbox = [
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m         marker_center[0] - marker_radius_px,
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m         marker_center[1] - marker_radius_px,
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m         marker_center[0] + marker_radius_px,
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m         marker_center[1] + marker_radius_px,
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m     draw.ellipse(marker_bbox, fill=(30, 60, 200))  # blue calibration marker
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m     # Compute ground truth measurements
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m     pixels_per_cm = (marker_radius_px * 2) / MARKER_DIAMETER_CM
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m     # Ellipse area = pi * a * b (in pixels), then convert to cm²
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m     area_px = np.pi * wound_axes[0] * wound_axes[1]
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m     area_cm2 = area_px / (pixels_per_cm ** 2)
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m     length_cm = (wound_axes[0] * 2) / pixels_per_cm
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m     width_cm = (wound_axes[1] * 2) / pixels_per_cm
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m     ground_truth = {
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m         "pixels_per_cm": round(pixels_per_cm, 2),
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m         "area_cm2": round(area_cm2, 2),
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m         "length_cm": round(length_cm, 2),
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m         "width_cm": round(width_cm, 2),
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m     return img, ground_truth
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m ## Step 1: Validate and Upload the Wound Image
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m *Maps to pseudocode Step 1 in the main recipe. We check basic image properties and upload to S3 with metadata for the audit trail.*
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m def validate_and_upload(
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m     image: Image.Image,
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m     patient_id: str,
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m     wound_id: str,
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m     wound_location: str,
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m     clinician_id: str,
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m ) -> str:
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m     Validate image quality and upload to S3.
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m         image: PIL Image of the wound photograph
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m         patient_id: Patient identifier
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m         wound_id: Unique wound identifier (patient can have multiple wounds)
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m         wound_location: Anatomical location (e.g., "sacrum", "left heel")
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m         clinician_id: Who took the photo
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m         The S3 key where the image was stored.
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m     Raises:
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m         ValueError: If image fails validation checks.
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m     # Check minimum resolution. Below 640x640, wound boundary detection
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m     # becomes unreliable because there aren't enough pixels to distinguish
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m     # wound edge from periwound tissue.
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m     width, height = image.size
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m     if width < 640 or height < 640:
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m         raise ValueError(
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m             f"Image resolution {width}x{height} too low. "
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m             f"Minimum 640x640 required for reliable measurement."
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m     # Generate the S3 key with a path structure that supports efficient
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m     # querying by patient and wound.
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m     timestamp = datetime.datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%S")
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m     s3_key = f"wound-images/{patient_id}/{wound_id}/{timestamp}.jpg"
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m     # Convert to bytes for upload
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m     buffer = io.BytesIO()
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m     image.save(buffer, format="JPEG", quality=95)
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m     buffer.seek(0)
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m     # Upload with server-side encryption and metadata.
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m     # The metadata fields are NOT PHI themselves (they're identifiers),
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m     # but they link to PHI, so the bucket must be under BAA.
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m     s3_client.put_object(
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m         Bucket=S3_BUCKET,
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m         Key=s3_key,
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m         Body=buffer.getvalue(),
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m         ContentType="image/jpeg",
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m         ServerSideEncryption="aws:kms",
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m         Metadata={
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m             "patient_id": patient_id,
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m             "wound_id": wound_id,
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m             "wound_location": wound_location,
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m             "clinician_id": clinician_id,
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m             "capture_timestamp": timestamp,
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m     logger.info(f"Uploaded wound image to s3://{S3_BUCKET}/{s3_key}")
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m     return s3_key
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m ## Step 2: Detect Reference Marker and Compute Scale
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m *Maps to pseudocode Step 2. We find the blue calibration circle in the image and compute how many pixels equal one centimeter.*
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m def detect_reference_marker(image: Image.Image) -> dict:
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m     Detect the circular reference marker and compute pixels-per-cm.
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m     This uses a simple color-based detection approach: find the largest
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m     cluster of blue pixels, fit a circle to it, and use the known physical
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m     diameter to compute scale.
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     In production, you'd use a more robust approach (Hough circle transform,
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m     or a small trained detector). This simplified version works for the
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m     synthetic test images and demonstrates the concept.
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m         image: PIL Image containing the wound and reference marker.
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m         dict with keys:
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m         - "detected": bool, whether a valid marker was found
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m         - "pixels_per_cm": float, the scale factor (if detected)
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m         - "marker_center": tuple (x, y) pixel coordinates of marker center
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m         - "marker_radius_px": float, detected radius in pixels
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m     img_array = np.array(image)
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m     # Simple color thresholding for blue marker detection.
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m     # We work in RGB here for simplicity. A production system would
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m     # convert to HSV for more robust color detection under varying lighting.
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m     r, g, b = img_array[:, :, 0], img_array[:, :, 1], img_array[:, :, 2]
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m     # Blue marker: high blue channel, low red and green
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m     blue_mask = (b > 150) & (r < 100) & (g < 120)
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m     # Count blue pixels
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m     blue_pixel_count = np.sum(blue_mask)
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m     if blue_pixel_count < 100:
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m         # Not enough blue pixels to be a marker
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m         logger.warning("No reference marker detected in image.")
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m         return {"detected": False, "pixels_per_cm": None}
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m     # Find the centroid of blue pixels (marker center)
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m     blue_coords = np.argwhere(blue_mask)  # returns (row, col) pairs
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m     center_row = np.mean(blue_coords[:, 0])
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m     center_col = np.mean(blue_coords[:, 1])
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m     # Estimate radius from the area of blue pixels.
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m     # Area of circle = pi * r^2, so r = sqrt(area / pi)
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m     estimated_radius_px = np.sqrt(blue_pixel_count / np.pi)
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m     # Compute pixels per centimeter from the known marker diameter
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m     marker_diameter_px = estimated_radius_px * 2
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m     pixels_per_cm = marker_diameter_px / MARKER_DIAMETER_CM
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m     # Sanity check: is the scale factor in a reasonable range?
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m     if pixels_per_cm < MIN_PIXELS_PER_CM or pixels_per_cm > MAX_PIXELS_PER_CM:
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m         logger.warning(
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m             f"Scale factor {pixels_per_cm:.1f} px/cm outside expected range "
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m             f"[{MIN_PIXELS_PER_CM}, {MAX_PIXELS_PER_CM}]. "
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m             f"Check marker positioning and camera distance."
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m         return {"detected": False, "pixels_per_cm": None}
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m         "detected": True,
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m         "pixels_per_cm": round(pixels_per_cm, 2),
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m         "marker_center": (int(center_col), int(center_row)),
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m         "marker_radius_px": round(estimated_radius_px, 1),
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m ## Step 3: Segment the Wound
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m *Maps to pseudocode Step 3. In production, this calls a SageMaker endpoint hosting a trained U-Net model. For testing, we include a synthetic segmentation function that uses color thresholding to simulate what the model would return.*
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m def segment_wound_synthetic(image: Image.Image) -> tuple:
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m     Synthetic wound segmentation for testing.
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m     In production, you'd call a SageMaker endpoint with a trained U-Net.
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m     This function simulates that by detecting the red wound region using
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m     color thresholding. It returns the same data structure a real model would.
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m         image: PIL Image of the wound.
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m         tuple: (binary_mask as numpy array, confidence score)
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m     img_array = np.array(image)
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m     r, g, b = img_array[:, :, 0], img_array[:, :, 1], img_array[:, :, 2]
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m     # Detect red wound region (high red, low green and blue)
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m     wound_mask = (r > 120) & (g < 100) & (b < 100)
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m     # Simulate a confidence score (in reality, this comes from the model's
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m     # output probabilities averaged over wound pixels)
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m     confidence = 0.91 if np.sum(wound_mask) > 500 else 0.45
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m     return wound_mask.astype(np.uint8), confidence
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m def segment_wound_sagemaker(image: Image.Image) -> tuple:
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m     Call SageMaker endpoint for wound segmentation.
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m     This is what you'd use in production. The endpoint hosts a trained
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m     U-Net model that takes an image and returns a probability mask.
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m         image: PIL Image of the wound.
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m         tuple: (binary_mask as numpy array, confidence score)
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m     # Resize to model's expected input dimensions.
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m     # Most U-Net variants expect square inputs. 512x512 is common.
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m     original_size = image.size  # (width, height)
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m     resized = image.resize((512, 512))
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m     # Convert to bytes for the SageMaker endpoint
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m     buffer = io.BytesIO()
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m     resized.save(buffer, format="JPEG")
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m     payload = buffer.getvalue()
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m     # Invoke the SageMaker endpoint
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m     response = sagemaker_runtime.invoke_endpoint(
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m         EndpointName=SAGEMAKER_ENDPOINT,
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m         ContentType="image/jpeg",
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m         Accept="application/json",
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m         Body=payload,
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m     # Parse the response. The model returns a probability mask as a
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m     # flattened array of floats (0.0 to 1.0 per pixel).
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m     result = json.loads(response["Body"].read().decode("utf-8"))
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m     probability_mask = np.array(result["mask"]).reshape((512, 512))
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m     # Threshold to binary
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m     binary_mask = (probability_mask > 0.5).astype(np.uint8)
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m     # Compute confidence: mean probability of pixels classified as wound
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m     wound_probs = probability_mask[binary_mask == 1]
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m     confidence = float(np.mean(wound_probs)) if len(wound_probs) > 0 else 0.0
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m     # Resize mask back to original image dimensions
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m     mask_image = Image.fromarray(binary_mask * 255)
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m     mask_resized = mask_image.resize(original_size, resample=Image.NEAREST)
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m     final_mask = (np.array(mask_resized) > 127).astype(np.uint8)
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m     return final_mask, confidence
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m ## Step 4: Compute Wound Measurements
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m *Maps to pseudocode Step 4. Given the segmentation mask and scale factor, we compute area, length, width, perimeter, and circularity in real-world units.*
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m def compute_measurements(segmentation_mask: np.ndarray, pixels_per_cm: float) -> dict:
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m     Compute wound measurements from the segmentation mask.
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m     This is where pixels become centimeters. The scale factor from the
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m     reference marker converts pixel counts into physical dimensions that
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m     clinicians can use for treatment decisions.
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m         segmentation_mask: Binary numpy array (1 = wound, 0 = background)
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m         pixels_per_cm: Scale factor from marker detection
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m         dict with area_cm2, length_cm, width_cm, perimeter_cm, circularity
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m     # Count wound pixels for area
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m     wound_pixel_count = int(np.sum(segmentation_mask))
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m     if wound_pixel_count == 0:
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m             "area_cm2": 0.0,
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m             "length_cm": 0.0,
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m             "width_cm": 0.0,
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m             "perimeter_cm": 0.0,
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m             "circularity": 0.0,
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m     # Convert pixel area to cm²
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m     # Each pixel represents (1/pixels_per_cm)² square centimeters
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m     area_cm2 = wound_pixel_count / (pixels_per_cm ** 2)
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m     # Find wound boundary pixels for perimeter calculation.
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m     # A boundary pixel is a wound pixel that has at least one non-wound neighbor.
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m     # We use a simple erosion approach: erode the mask by 1 pixel, then
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m     # subtract from original to get the boundary.
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m     from scipy import ndimage  # only needed for morphological operations
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m     eroded = ndimage.binary_erosion(segmentation_mask)
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m     boundary = segmentation_mask.astype(int) - eroded.astype(int)
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m     perimeter_px = int(np.sum(boundary))
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m     perimeter_cm = perimeter_px / pixels_per_cm
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m     # Find bounding box for length and width.
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m     # We use the minimum bounding rectangle of the wound region.
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m     wound_coords = np.argwhere(segmentation_mask == 1)  # (row, col) pairs
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m     # Simple approach: axis-aligned bounding box
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m     min_row, min_col = wound_coords.min(axis=0)
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m     max_row, max_col = wound_coords.max(axis=0)
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m     bbox_height_px = max_row - min_row
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m     bbox_width_px = max_col - min_col
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m     # Length = longer dimension, Width = shorter dimension
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m     length_px = max(bbox_height_px, bbox_width_px)
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m     width_px = min(bbox_height_px, bbox_width_px)
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m     length_cm = length_px / pixels_per_cm
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m     width_cm = width_px / pixels_per_cm
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m     # Circularity: how round is the wound? 1.0 = perfect circle.
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m     # Formula: 4 * pi * area / perimeter^2
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m     # Useful for tracking wound shape changes over time.
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m     if perimeter_px > 0:
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m         circularity = (4 * np.pi * wound_pixel_count) / (perimeter_px ** 2)
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m         circularity = 0.0
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m         "area_cm2": round(float(area_cm2), 2),
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m         "length_cm": round(float(length_cm), 2),
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m         "width_cm": round(float(width_cm), 2),
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m         "perimeter_cm": round(float(perimeter_cm), 2),
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m         "circularity": round(float(circularity), 3),
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m ## Step 5: Store Measurement and Compute Healing Trajectory
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m *Maps to pseudocode Step 5. We write the measurement to DynamoDB and compare against previous measurements to compute healing rate.*
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m def store_measurement(
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m     patient_id: str,
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m     wound_id: str,
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m     measurements: dict,
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m     confidence: float,
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m     image_s3_key: str,
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m     metadata: dict,
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m     Store the wound measurement in DynamoDB and compute healing trajectory.
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m     The table uses a composite key:
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m     - Partition key: patient_id (groups all data for one patient)
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m     - Sort key: wound_id#timestamp (orders measurements chronologically per wound)
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m     This key design supports two access patterns efficiently:
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m     1. Get latest measurement for a specific wound (query with sort key prefix)
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m     2. Get full timeline for a wound (query with sort key begins_with)
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m         patient_id: Patient identifier
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m         wound_id: Wound identifier
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m         measurements: Dict from compute_measurements()
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m         confidence: Segmentation confidence score
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m         image_s3_key: S3 key of the original image
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m         metadata: Additional context (clinician, location, device)
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m         The complete record that was stored, including healing trajectory.
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m     table = dynamodb.Table(DYNAMODB_TABLE)
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m     now = datetime.datetime.now(timezone.utc)
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m     timestamp_str = now.isoformat()
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m     # Build the measurement record.
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m     # DynamoDB requires Decimal for numeric values, not float.
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m     # This is a common gotcha that causes TypeError at runtime.
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m     record = {
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m         "patient_id": patient_id,
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m         "wound_id_timestamp": f"{wound_id}#{timestamp_str}",
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m         "wound_id": wound_id,
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m         "measurement_date": timestamp_str,
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m         "area_cm2": Decimal(str(measurements["area_cm2"])),
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m         "length_cm": Decimal(str(measurements["length_cm"])),
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m         "width_cm": Decimal(str(measurements["width_cm"])),
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m         "perimeter_cm": Decimal(str(measurements["perimeter_cm"])),
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m         "circularity": Decimal(str(measurements["circularity"])),
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m         "confidence": Decimal(str(round(confidence, 3))),
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m         "image_s3_key": image_s3_key,
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m         "clinician_id": metadata.get("clinician_id", "unknown"),
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m         "wound_location": metadata.get("wound_location", "unspecified"),
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m         "device_info": metadata.get("device_info", "unknown"),
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m     # Query for the most recent previous measurement of this wound
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m     # to compute healing trajectory.
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m     response = table.query(
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m         KeyConditionExpression="patient_id = :pid AND begins_with(wound_id_timestamp, :wid)",
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m         ExpressionAttributeValues={
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m             ":pid": patient_id,
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m             ":wid": wound_id,
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m         ScanIndexForward=False,  # Descending order (most recent first)
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m         Limit=1,
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m     healing_trajectory = None
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m     previous_items = response.get("Items", [])
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m     if previous_items:
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m         prev = previous_items[0]
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m         prev_area = float(prev["area_cm2"])
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m         prev_date = datetime.datetime.fromisoformat(prev["measurement_date"])
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m         days_elapsed = (now - prev_date).days
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m         if days_elapsed > 0 and prev_area > 0:
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m             current_area = measurements["area_cm2"]
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m             area_change_pct = ((current_area - prev_area) / prev_area) * 100
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m             healing_rate = (prev_area - current_area) / days_elapsed
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m             healing_trajectory = {
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m                 "previous_area_cm2": Decimal(str(prev_area)),
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m                 "area_change_pct": Decimal(str(round(area_change_pct, 1))),
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m                 "days_since_last": days_elapsed,
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m                 "healing_rate_cm2_per_day": Decimal(str(round(healing_rate, 4))),
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m             # Alert if wound is growing significantly
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m             if area_change_pct > WOUND_GROWTH_ALERT_THRESHOLD_PCT:
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m                 logger.warning(
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m                     f"ALERT: Wound {wound_id} for patient {patient_id} "
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m                     f"increased {area_change_pct:.1f}% over {days_elapsed} days."
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m                 )
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m             record["healing_trajectory"] = healing_trajectory
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m     # Write to DynamoDB
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m     table.put_item(Item=record)
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m     logger.info(f"Stored measurement for {patient_id}/{wound_id}")
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m     return record
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m ## Full Pipeline: End-to-End Wound Measurement
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m This assembles all the steps into a single callable function. The print statements show progress so you can trace execution during development.
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m def measure_wound(
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m     image: Image.Image,
