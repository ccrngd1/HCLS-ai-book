[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m     print(f"\n{'='*60}")
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m     print(f"WOUND MEASUREMENT PIPELINE")
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m     print(f"Patient: {patient_id} | Wound: {wound_id} | Location: {wound_location}")
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m     print(f"{'='*60}\n")
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m     # Step 1: Validate and upload
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m     print("[Step 1] Validating image and uploading to S3...")
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m     s3_key = validate_and_upload(
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m         image=image,
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m         patient_id=patient_id,
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m         wound_id=wound_id,
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m         wound_location=wound_location,
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m         clinician_id=clinician_id,
