[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m             "status": "MARKER_NOT_DETECTED",
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m             "image_s3_key": s3_key,
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m             "message": "Reference marker not found. Manual review required.",
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m     pixels_per_cm = marker_result["pixels_per_cm"]
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m     print(f"  Marker detected at {marker_result['marker_center']}")
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m     print(f"  Scale factor: {pixels_per_cm} pixels/cm")
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m     # Step 3: Segment the wound
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m     print("\n[Step 3] Segmenting wound region...")
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m     if use_sagemaker:
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m         mask, confidence = segment_wound_sagemaker(image)
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m         mask, confidence = segment_wound_synthetic(image)
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m     wound_pixel_count = int(np.sum(mask))
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m     print(f"  Wound pixels detected: {wound_pixel_count}")
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m     print(f"  Segmentation confidence: {confidence:.3f}")
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m     if confidence < SEGMENTATION_CONFIDENCE_THRESHOLD:
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m         print(f"  WARNING: Confidence below threshold ({SEGMENTATION_CONFIDENCE_THRESHOLD})")
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m         print("  Measurement will be flagged for review.")
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m     # Step 4: Compute measurements
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m     print("\n[Step 4] Computing wound measurements...")
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m     measurements = compute_measurements(mask, pixels_per_cm)
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m     print(f"  Area:        {measurements['area_cm2']} cm²")
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m     print(f"  Length:      {measurements['length_cm']} cm")
