[0m[49m[38;5;10m+      361[0m:[38;5;10m[49m     // Publish metrics to CloudWatch for dashboarding and alarming.
[0m[49m[38;5;10m+      362[0m:[38;5;10m[49m     publish to CloudWatch namespace "ChurnModel/Performance":
[0m[49m[38;5;10m+      363[0m:[38;5;10m[49m         metric "AUC-PR" = auc_pr, dimensions = { model_version, evaluation_month }
[0m[49m[38;5;10m+      364[0m:[38;5;10m[49m         metric "ECE"    = ece,    dimensions = { model_version, evaluation_month }
