[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m ## Step 2: Assemble Patient Facts
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m *The main recipe's Step 2 gathers the patient's clinical state from multiple data sources. Here we simulate that assembly. In production, this would query claims databases, EHR extracts, and lab feeds via AWS Glue or direct database connections.*
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m def assemble_patient_facts(patient_id: str) -> dict:
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m     Assemble a patient's clinical fact set for reasoning.
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m     In production, this queries multiple data sources:
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m     - Claims DB for diagnoses and procedures
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m     - EHR extract for problem lists
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m     - Lab feeds for recent results
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m     - Pharmacy data for medications
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m     Here we return a synthetic patient to demonstrate the pattern.
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m     The structure is what matters: conditions as ICD-10 codes, services
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m     with dates and CPT/LOINC codes, medications with fill dates.
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m         A dict representing the patient's current clinical state.
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m     # Synthetic patient: 62-year-old male with Type 2 Diabetes and Hypertension.
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     # Last HbA1c was 14 months ago. No retinal exam in 18 months.
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m     # No statin on medication list despite meeting criteria.
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m     # This patient should trigger 3 care gaps.
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m     if patient_id == "PAT-2026-00482":
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m             "patient_id": "PAT-2026-00482",
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m             "demographics": {
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m                 "age": 62,
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m                 "sex": "M",
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m                 "enrollment_status": "active",
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m             },
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m             "conditions": [
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m                 {"icd10_code": "E11.9", "description": "Type 2 Diabetes without complications"},
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m                 {"icd10_code": "I10", "description": "Essential hypertension"},
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m             ],
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m             "recent_services": [
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m                 # HbA1c done 14 months ago (outside the 6-month window)
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m                 {"cpt_code": "83036", "loinc_code": "4548-4", "service_date": "2025-03-10"},
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m                 # Blood pressure check 2 months ago (within 6-month window)
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m                 {"cpt_code": "99213", "loinc_code": "85354-9", "service_date": "2026-03-20"},
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m                 # Retinal exam 18 months ago (outside the 12-month window)
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m                 {"cpt_code": "92004", "loinc_code": None, "service_date": "2024-11-20"},
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m             ],
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m             "medications": [
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m                 {"drug_name": "Metformin", "drug_class": "biguanide", "fill_date": "2026-04-15"},
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m                 {"drug_name": "Lisinopril", "drug_class": "ace_inhibitor", "fill_date": "2026-04-15"},
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m                 # Note: no statin in the medication list
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m             ],
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m     # Default: empty patient (no data found)
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m         "patient_id": patient_id,
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m         "demographics": {"age": 0, "sex": "unknown", "enrollment_status": "unknown"},
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m         "conditions": [],
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m         "recent_services": [],
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m         "medications": [],
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m ## Step 3: Query Neptune for Applicable Recommendations
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m *The main recipe's Step 3 uses ontological reasoning to determine which guidelines apply to a patient. This is where the knowledge graph earns its keep. The SPARQL query leverages rdfs:subClassOf inference so that a patient with E11.9 (Type 2 Diabetes) matches guidelines that apply to DiabetesMellitus (the parent class).*
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m def find_applicable_recommendations(
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m     patient_facts: dict, neptune_endpoint: str
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m ) -> list:
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m     Query Neptune to find all guideline recommendations that apply to this patient.
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m     The SPARQL query uses ontological reasoning: if the patient has a condition
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m     that is a subclass of a condition referenced by a recommendation, the
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m     recommendation applies. This is the core value of the knowledge graph
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m     approach over flat rule tables.
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m     We also check:
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m     - Age constraints (if the recommendation has age_minimum/age_maximum)
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m     - Exclusion conditions (if the patient has any, skip the recommendation)
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m         patient_facts: The patient's assembled clinical state.
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m         neptune_endpoint: The Neptune SPARQL endpoint URL.
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m         A list of applicable recommendations with their metadata.
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m     # Extract the patient's ICD-10 code prefixes. We use prefixes because
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m     # ICD-10 codes have varying specificity (E11 vs E11.9 vs E11.65).
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m     # Our ontology maps at the 3-character level (E11 -> Type2Diabetes).
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m     patient_condition_codes = [
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m         c["icd10_code"][:3] for c in patient_facts["conditions"]
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m     if not patient_condition_codes:
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m         logger.info("Patient has no conditions. No recommendations apply.")
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m         return []
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m     patient_age = patient_facts["demographics"]["age"]
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m     # Build a SPARQL query that finds recommendations whose preconditions
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m     # are satisfied by this patient's conditions.
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m     #
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m     # The key insight: we use rdfs:subClassOf* (the transitive closure)
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m     # so that E11 (Type2Diabetes) matches guidelines targeting DiabetesMellitus.
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m     # Neptune's reasoner handles this traversal automatically.
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m     # Build a VALUES clause for the patient's condition codes.
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m     values_clause = " ".join(f'"{code}"' for code in patient_condition_codes)
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m     query = SPARQL_PREFIXES + f"""
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m     SELECT ?rec ?recId ?actionDesc ?freqMonths ?measureId ?priority ?condCode ?excludedByCode
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m     WHERE {{
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m         # Find recommendations
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m         ?rec rdf:type ont:Recommendation ;
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m              ont:recommendationId ?recId ;
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m              ont:recommendedAction ?action ;
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m              ont:frequencyMonths ?freqMonths ;
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m              ont:measureId ?measureId ;
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m              ont:priority ?priority ;
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m              ont:appliesWhen ?appliesCondition .
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m         ?action ont:description ?actionDesc .
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m         # Match patient conditions using subclass reasoning.
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m         # ?appliesCondition is the condition class the recommendation targets.
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m         # ?patientCondClass is the specific condition class matching the patient's code.
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m         # rdfs:subClassOf* means "is the same class or a subclass of."
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m         ?patientCondClass rdfs:subClassOf* ?appliesCondition ;
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m                           ont:icd10Code ?condCode .
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m         # Filter to only this patient's conditions
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m         VALUES ?condCode {{ {values_clause} }}
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m         # Age check (optional properties)
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m         OPTIONAL {{ ?rec ont:ageMinimum ?ageMin . }}
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m         FILTER (!BOUND(?ageMin) || {patient_age} >= ?ageMin)
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m         OPTIONAL {{ ?rec ont:ageMaximum ?ageMax . }}
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m         FILTER (!BOUND(?ageMax) || {patient_age} <= ?ageMax)
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m         # Get exclusion conditions (we'll check these in Python)
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m         OPTIONAL {{
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m             ?rec ont:excludedBy ?excludedClass .
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m             ?excludedClass ont:icd10Code ?excludedByCode .
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m         }}
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m     }}
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m     # Execute the SPARQL query against Neptune.
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m     response = requests.post(
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m         neptune_endpoint,
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m         data={"query": query},
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m         headers={"Accept": "application/sparql-results+json"},
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m     if response.status_code != 200:
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m         logger.error("Neptune query failed: %s", response.text)
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m         return []
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m     results = response.json().get("results", {}).get("bindings", [])
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m     # Process results: group by recommendation and check exclusions.
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m     recommendations = {}
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m     exclusions_by_rec = {}
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m     for row in results:
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m         rec_id = row["recId"]["value"]
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m         # Collect exclusion codes for each recommendation
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m         if "excludedByCode" in row and row["excludedByCode"]["value"]:
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m             exclusions_by_rec.setdefault(rec_id, set()).add(
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m                 row["excludedByCode"]["value"]
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m         # Store recommendation details (dedup by rec_id)
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m         if rec_id not in recommendations:
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m             recommendations[rec_id] = {
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m                 "recommendation_id": rec_id,
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m                 "action_needed": row["actionDesc"]["value"],
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m                 "frequency_months": int(row["freqMonths"]["value"]),
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m                 "measure_id": row["measureId"]["value"],
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m                 "priority": row["priority"]["value"],
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m                 "triggered_by_code": row["condCode"]["value"],
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m     # Now check exclusions: if the patient has any excluded condition, remove
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m     # that recommendation from the applicable list.
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m     patient_code_prefixes = set(patient_condition_codes)
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m     applicable = []
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m     for rec_id, rec in recommendations.items():
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m         excluded_codes = exclusions_by_rec.get(rec_id, set())
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m         # Check if any of the patient's conditions match an exclusion
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m         if excluded_codes & patient_code_prefixes:
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m             logger.info(
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m                 "Recommendation %s excluded: patient has %s",
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m                 rec_id,
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m                 excluded_codes & patient_code_prefixes,
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m         applicable.append(rec)
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m     logger.info("Found %d applicable recommendations for patient", len(applicable))
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m     return applicable
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m ## Step 4: Identify Care Gaps
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m *The main recipe's Step 4 checks whether each applicable recommendation has been satisfied within the required timeframe. A gap exists when the recommended action hasn't been completed recently enough.*
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m def identify_gaps(
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m     applicable_recommendations: list,
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m     patient_facts: dict,
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m     evaluation_date: Optional[str] = None,
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m ) -> list:
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m     For each applicable recommendation, check if the action has been completed
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m     within the required frequency window. If not, it's a care gap.
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m         applicable_recommendations: Output from find_applicable_recommendations.
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m         patient_facts: The patient's clinical fact set.
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m         evaluation_date: ISO date string (YYYY-MM-DD). Defaults to today.
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m         A list of care gap dicts, each describing a missing action.
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m     if evaluation_date is None:
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m         eval_date = datetime.date.today()
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m         eval_date = datetime.date.fromisoformat(evaluation_date)
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m     gaps = []
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m     for rec in applicable_recommendations:
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m         freq_months = rec["frequency_months"]
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m         # frequency_months == 0 means "ongoing" (e.g., should be on a medication).
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m         # For medication-type actions, we check the medication list instead of services.
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m         if freq_months == 0:
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m             # Check if the patient is currently on the recommended medication class.
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m             # "Currently on" = filled within the last 90 days (approximate).
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m             action_desc = rec["action_needed"].lower()
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m             if "statin" in action_desc:
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m                 has_med = any(
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m                     m["drug_class"] == "statin" for m in patient_facts["medications"]
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m                 )
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m                 if not has_med:
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m                     gaps.append({
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m                         "recommendation_id": rec["recommendation_id"],
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m                         "measure_id": rec["measure_id"],
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m                         "action_needed": rec["action_needed"],
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m                         "priority": rec["priority"],
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m                         "frequency": "ongoing",
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m                         "last_completed": "never",
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m                         "days_overdue": None,
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m                         "justification": [
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m                             f"Active condition: {rec['triggered_by_code']}"
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m                         ],
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m                     })
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m         # For time-based recommendations, calculate the cutoff date.
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m         # Any matching service after this date means the gap is closed.
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m         cutoff_date = eval_date - datetime.timedelta(days=freq_months * 30)
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m         # Find services that satisfy this recommendation.
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m         # Match by CPT code or LOINC code from the recommendation's action.
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m         # (In production, you'd query the action node in Neptune for its codes.
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m         # Here we use a simplified lookup.)
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m         action_codes = _get_action_codes(rec["action_needed"])
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m         matching_services = [
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m             s
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m             for s in patient_facts["recent_services"]
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m             if (
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m                 s.get("cpt_code") in action_codes.get("cpt", [])
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m                 or s.get("loinc_code") in action_codes.get("loinc", [])
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m             and datetime.date.fromisoformat(s["service_date"]) >= cutoff_date
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m         ]
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m         if not matching_services:
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m             # Gap found. Find the most recent matching service ever (for context).
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m             all_matching = [
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m                 s
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m                 for s in patient_facts["recent_services"]
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m                 if (
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m                     s.get("cpt_code") in action_codes.get("cpt", [])
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m                     or s.get("loinc_code") in action_codes.get("loinc", [])
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m                 )
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m             ]
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m             last_completed = "never"
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m             days_overdue = None
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m             if all_matching:
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m                 # Sort by date descending, take the most recent
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m                 most_recent = max(all_matching, key=lambda s: s["service_date"])
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m                 last_completed = most_recent["service_date"]
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m                 last_date = datetime.date.fromisoformat(last_completed)
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m                 days_overdue = (eval_date - cutoff_date).days
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m             gaps.append({
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m                 "recommendation_id": rec["recommendation_id"],
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m                 "measure_id": rec["measure_id"],
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m                 "action_needed": rec["action_needed"],
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m                 "priority": rec["priority"],
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m                 "frequency": f"{freq_months} months",
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m                 "last_completed": last_completed,
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m                 "days_overdue": days_overdue,
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m                 "justification": [
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m                     f"Active condition: {rec['triggered_by_code']}"
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m                 ],
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m     logger.info("Identified %d care gaps", len(gaps))
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m     return gaps
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m def _get_action_codes(action_description: str) -> dict:
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m     Map an action description to its CPT and LOINC codes.
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m     In production, this information lives in the Neptune graph on the Action
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m     nodes. Here we use a simple lookup for the demo actions.
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m     # This is the kind of thing that belongs in the graph, not in code.
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m     # We're doing it here to keep the example self-contained.
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m     lookup = {
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m         "HbA1c Lab Test": {"cpt": ["83036"], "loinc": ["4548-4"]},
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m         "Dilated Retinal Exam": {"cpt": ["92004", "92014"], "loinc": []},
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m         "Blood Pressure Measurement": {"cpt": ["99213"], "loinc": ["85354-9"]},
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m         "Statin Therapy Initiation": {"cpt": [], "loinc": []},
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m     return lookup.get(action_description, {"cpt": [], "loinc": []})
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m ## Step 5: Score and Prioritize Gaps
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m *The main recipe's Step 5 assigns composite priority scores so care managers focus on the highest-impact gaps first.*
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m def score_gaps(gaps: list, patient_facts: dict) -> list:
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m     Assign a composite priority score to each gap for outreach prioritization.
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m     The score combines:
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m     - Base priority from the guideline (high=3, medium=2, low=1)
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m     - How overdue the action is (longer overdue = more urgent)
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m     - Patient comorbidity count (more conditions = higher risk)
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m     - Quality measure weight (some measures impact Star Ratings more)
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m         gaps: List of care gap dicts from identify_gaps.
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m         patient_facts: Patient's clinical state (for comorbidity count).
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m         The same gaps list, sorted by composite_score descending, with
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m         composite_score added to each gap dict.
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m     priority_map = {"high": 3, "medium": 2, "low": 1}
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m     comorbidity_count = len(patient_facts["conditions"])
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m     for gap in gaps:
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m         base_score = priority_map.get(gap["priority"], 1)
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m         # Overdue factor: cap at 2.0 to prevent extreme outliers
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m         if gap["days_overdue"] is not None and gap["days_overdue"] > 0:
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m             overdue_factor = min(gap["days_overdue"] / 90.0, 2.0)
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m             overdue_factor = 1.0  # "ongoing" gaps (like missing medication)
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m         # Risk factor based on comorbidity burden
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m         risk_factor = min(comorbidity_count / 3.0, 2.0)
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m         # Quality measure weight from our lookup table
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m         measure_weight = MEASURE_WEIGHTS.get(
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m             gap["measure_id"], DEFAULT_MEASURE_WEIGHT
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m         # Composite score formula
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m         composite = (
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m             base_score * (1 + overdue_factor) * (1 + risk_factor * 0.3) * measure_weight
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m         gap["composite_score"] = round(composite, 1)
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m     # Sort by composite score descending (most urgent first)
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m     gaps.sort(key=lambda g: g["composite_score"], reverse=True)
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m     return gaps
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m ## Step 6: Store Results in DynamoDB
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m *The main recipe's Step 6 persists the evaluation results for downstream consumption by care management platforms, patient portals, and quality reporting dashboards.*
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m # Create DynamoDB resource
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m def store_gap_results(
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m     patient_id: str,
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m     evaluation_date: str,
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m     scored_gaps: list,
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m     ontology_version: str = "guidelines-2026-v2.1",
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m     Write the care gap evaluation results to DynamoDB.
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m     The record is keyed by patient_id (partition key) and evaluation_date
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m     (sort key). This supports both point lookups ("what are patient X's
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m     current gaps?") and range queries ("show me all evaluations for patient X
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m     over the last year to track gap closure").
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m         patient_id: The patient identifier.
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m         evaluation_date: ISO date string for this evaluation.
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m         scored_gaps: The scored and sorted gap list.
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m         ontology_version: Which guideline version was used (for audit).
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m         The full record that was written.
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m     table = dynamodb.Table(RESULTS_TABLE)
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m     # Convert floats to Decimal for DynamoDB.
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m     # DynamoDB's SDK rejects Python floats. You must use Decimal for all
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m     # numeric values. This is a common gotcha that causes TypeError at runtime.
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m     dynamodb_gaps = []
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m     for gap in scored_gaps:
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m         ddb_gap = {k: v for k, v in gap.items()}
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m         if ddb_gap.get("composite_score") is not None:
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m             ddb_gap["composite_score"] = Decimal(str(ddb_gap["composite_score"]))
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m         if ddb_gap.get("days_overdue") is not None:
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m             ddb_gap["days_overdue"] = Decimal(str(ddb_gap["days_overdue"]))
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m         dynamodb_gaps.append(ddb_gap)
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m     record = {
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m         "patient_id": patient_id,
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m         "evaluation_date": evaluation_date,
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m         "gap_count": len(scored_gaps),
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m         "gaps": dynamodb_gaps,
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m         "evaluated_at": datetime.datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m         "ontology_version": ontology_version,
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m     table.put_item(Item=record)
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m         "Stored %d gaps for patient %s (eval date: %s)",
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m         len(scored_gaps),
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m         patient_id,
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m         evaluation_date,
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m     return record
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m ## Putting It All Together
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m Here's the full pipeline assembled into a single function. This is what your Lambda handler would call for each patient in a batch evaluation.
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m def evaluate_patient(patient_id: str, evaluation_date: Optional[str] = None) -> dict:
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m     Run the full care gap reasoning pipeline for one patient.
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m     This is the main entry point. In a batch deployment, Step Functions
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m     would fan out Lambda invocations, each calling this function for a
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m     different patient.
[0m[49m[38;5;10m+    717[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    718[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    719[0m:[38;5;10m[49m         patient_id: The patient to evaluate.
[0m[49m[38;5;10m+    720[0m:[38;5;10m[49m         evaluation_date: ISO date string. Defaults to today.
[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m         The stored evaluation record with all identified gaps.
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    725[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    726[0m:[38;5;10m[49m     if evaluation_date is None:
[0m[49m[38;5;10m+    727[0m:[38;5;10m[49m         evaluation_date = datetime.date.today().isoformat()
[0m[49m[38;5;10m+    728[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    729[0m:[38;5;10m[49m     # Step 2: Assemble patient facts from data sources.
[0m[49m[38;5;10m+    730[0m:[38;5;10m[49m     print(f"Step 2: Assembling facts for patient {patient_id}")
[0m[49m[38;5;10m+    731[0m:[38;5;10m[49m     patient_facts = assemble_patient_facts(patient_id)
[0m[49m[38;5;10m+    732[0m:[38;5;10m[49m     print(f"  Conditions: {len(patient_facts['conditions'])}")
[0m[49m[38;5;10m+    733[0m:[38;5;10m[49m     print(f"  Recent services: {len(patient_facts['recent_services'])}")
[0m[49m[38;5;10m+    734[0m:[38;5;10m[49m     print(f"  Medications: {len(patient_facts['medications'])}")
[0m[49m[38;5;10m+    735[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    736[0m:[38;5;10m[49m     # Step 3: Query Neptune for applicable recommendations.
[0m[49m[38;5;10m+    737[0m:[38;5;10m[49m     print("Step 3: Querying Neptune for applicable recommendations")
[0m[49m[38;5;10m+    738[0m:[38;5;10m[49m     applicable = find_applicable_recommendations(patient_facts, NEPTUNE_ENDPOINT)
[0m[49m[38;5;10m+    739[0m:[38;5;10m[49m     print(f"  Found {len(applicable)} applicable recommendations")
[0m[49m[38;5;10m+    740[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    741[0m:[38;5;10m[49m     # Step 4: Identify which recommendations are not satisfied (gaps).
[0m[49m[38;5;10m+    742[0m:[38;5;10m[49m     print("Step 4: Identifying care gaps")
[0m[49m[38;5;10m+    743[0m:[38;5;10m[49m     gaps = identify_gaps(applicable, patient_facts, evaluation_date)
[0m[49m[38;5;10m+    744[0m:[38;5;10m[49m     print(f"  Identified {len(gaps)} care gaps")
[0m[49m[38;5;10m+    745[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    746[0m:[38;5;10m[49m     # Step 5: Score and prioritize gaps.
[0m[49m[38;5;10m+    747[0m:[38;5;10m[49m     print("Step 5: Scoring and prioritizing gaps")
[0m[49m[38;5;10m+    748[0m:[38;5;10m[49m     scored_gaps = score_gaps(gaps, patient_facts)
[0m[49m[38;5;10m+    749[0m:[38;5;10m[49m     for gap in scored_gaps:
