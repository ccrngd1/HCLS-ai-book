[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m # Unit staffing state: current census vs. staffed capacity.
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m # Staffed capacity is the number of patients the current nursing staff
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m # can safely manage (based on nurse-to-patient ratios and certifications).
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m UNIT_STAFFING = {
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m     "4-WEST":  {"current_census": 18, "staffed_capacity": 24, "has_cardiac_drip_nurse": True},
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m     "3-EAST":  {"current_census": 22, "staffed_capacity": 28, "has_cardiac_drip_nurse": False},
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m     "5-NORTH": {"current_census": 14, "staffed_capacity": 18, "has_cardiac_drip_nurse": True},
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m     "ICU":     {"current_census": 8,  "staffed_capacity": 10, "has_cardiac_drip_nurse": True},
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m # Patients waiting for beds. Each has requirements, priority, and context.
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m # In production, this queue is populated by ADT "pending admit" events.
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m PENDING_PATIENTS = [
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m     {
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m         "patient_id": "PAT-88291",
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m         "gender": "M",
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m         "acuity": "STEP_DOWN",
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m         "isolation": "NONE",
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m         "requires_cardiac_drip": True,
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m         "previous_unit": "4-WEST",  # was here last admission
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m         "waiting_since_minutes": 135,
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m         "priority_score": 8.5,  # composite of acuity + wait time + clinical urgency
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m     {
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m         "patient_id": "PAT-90112",
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m         "gender": "F",
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m         "acuity": "MED_SURG",
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m         "isolation": "AIRBORNE",  # needs negative-pressure room
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m         "requires_cardiac_drip": False,
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m         "previous_unit": None,
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m         "waiting_since_minutes": 90,
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m         "priority_score": 9.0,  # isolation bumps priority (infection control urgency)
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m     {
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m         "patient_id": "PAT-91003",
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m         "gender": "F",
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m         "acuity": "MED_SURG",
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m         "isolation": "NONE",
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m         "requires_cardiac_drip": False,
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m         "previous_unit": "3-EAST",
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m         "waiting_since_minutes": 45,
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m         "priority_score": 5.0,
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m     {
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m         "patient_id": "PAT-91455",
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m         "gender": "M",
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m         "acuity": "TELEMETRY",
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m         "isolation": "CONTACT",  # needs private room
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m         "requires_cardiac_drip": False,
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m         "previous_unit": None,
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m         "waiting_since_minutes": 60,
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m         "priority_score": 7.0,
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m     {
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m         "patient_id": "PAT-92001",
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m         "gender": "M",
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m         "acuity": "STEP_DOWN",
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m         "isolation": "NONE",
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m         "requires_cardiac_drip": False,
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m         "previous_unit": None,
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m         "waiting_since_minutes": 20,
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m         "priority_score": 6.0,
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m ## Step 1: Build the Available Bed List
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m *The pseudocode calls this part of `get_current_hospital_state()`. We filter the bed inventory to only beds that are actually assignable right now (or within a short window for beds in cleaning).*
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m def get_available_beds(bed_inventory: list, include_cleaning_within_minutes: int = 30) -> list:
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m     Filter bed inventory to beds that can accept a patient now or very soon.
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m     We include beds currently in cleaning if they'll be ready within the
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m     specified window. This prevents the optimizer from ignoring a bed that
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m     will be available in 10 minutes while a patient waits 15 minutes for
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m     the next optimization run.
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m         bed_inventory: Full list of bed records from the state table.
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m         include_cleaning_within_minutes: Include cleaning beds if they'll
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m             be ready within this many minutes.
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m         List of bed records that are candidates for assignment.
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m     available = []
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m     for bed in bed_inventory:
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m         if bed["status"] == "AVAILABLE":
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m             available.append(bed)
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m         elif bed["status"] == "CLEANING":
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m             # Include beds that will be ready soon. The optimizer can assign
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m             # a patient to a bed that's 20 minutes from ready if that patient
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m             # would otherwise wait 45 minutes for the next run.
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m             est_minutes = bed.get("estimated_available_minutes", 999)
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m             if est_minutes <= include_cleaning_within_minutes:
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m                 available.append(bed)
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m     return available
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m ## Step 2: Check Feasibility (Can This Patient Go in This Bed?)
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m *The pseudocode encodes these as hard constraints in the model. Here we pre-compute a feasibility matrix: for each (patient, bed) pair, is the assignment even allowed? This keeps the constraint logic readable and testable independently of the solver.*
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m def is_feasible_assignment(patient: dict, bed: dict, unit_staffing: dict) -> bool:
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     Check whether assigning this patient to this bed violates any hard constraint.
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m     Hard constraints are non-negotiable safety rules. If this function returns
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m     False, the solver will never consider this assignment. Period.
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m     This is separate from the objective function (which handles preferences
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m     and soft constraints). Feasibility is binary: safe or not safe.
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m     unit = bed["unit"]
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m     unit_type = bed["unit_type"]
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m     staffing = unit_staffing.get(unit, {})
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m     # 1. Acuity-to-unit matching.
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m     # A step-down patient cannot go to a med-surg floor. An ICU patient
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m     # cannot go anywhere but ICU. This is the most fundamental safety check.
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m     compatible_units = ACUITY_UNIT_COMPATIBILITY.get(patient["acuity"], [])
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m     if unit_type not in compatible_units:
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m         return False
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m     # 2. Isolation requirements.
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m     # Airborne isolation (TB, COVID) requires negative-pressure rooms.
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m     # Contact isolation requires at minimum a private room.
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m     required_room_types = ISOLATION_ROOM_REQUIREMENTS.get(patient["isolation"], [])
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m     if bed["room_type"] not in required_room_types:
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m         return False
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m     # 3. Gender matching for semi-private rooms.
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m     # If the room already has an occupant, the new patient must be same gender.
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m     if bed["room_type"] == "SEMI_PRIVATE" and bed["roommate_gender"] is not None:
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m         if patient["gender"] != bed["roommate_gender"]:
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m             return False
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m     # 4. Staffing capacity.
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m     # Even if a physical bed exists, the unit might not have enough nurses
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m     # to safely staff another patient. This is a real capacity limit.
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m     if staffing.get("current_census", 0) >= staffing.get("staffed_capacity", 0):
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m         return False
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m     # 5. Special equipment/certification requirements.
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m     # A patient on a cardiac drip needs a nurse certified to manage it.
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m     if patient.get("requires_cardiac_drip") and not staffing.get("has_cardiac_drip_nurse"):
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m         return False
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m     return True
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m ## Step 3: Formulate the Optimization Model
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m *The pseudocode calls this `build_assignment_model(state)`. This is the heart of the system: translating the bed assignment problem into a mathematical model that the CP-SAT solver can optimize.*
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m def build_optimization_model(
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m     patients: list,
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m     beds: list,
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m     unit_staffing: dict,
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m ) -> tuple:
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m     Formulate the bed assignment problem as a constraint programming model.
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m     The model has:
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m     - Binary decision variables: x[p][b] = 1 if patient p is assigned to bed b
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m     - Hard constraints: encoded via the feasibility matrix (infeasible pairs excluded)
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m     - Soft objectives: weighted sum of clinical fit, workload balance, continuity, etc.
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m         Tuple of (model, variables_dict, patients, beds) for the solver step.
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m     model = cp_model.CpModel()
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m     # Create binary decision variables.
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m     # x[(p_idx, b_idx)] = 1 means patient p_idx is assigned to bed b_idx.
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m     x = {}
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m     for p_idx, patient in enumerate(patients):
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m         for b_idx, bed in enumerate(beds):
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m             # Only create a variable if the assignment is feasible.
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m             # This pre-filters the search space: the solver never even
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m             # considers infeasible assignments.
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m             if is_feasible_assignment(patient, bed, unit_staffing):
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m                 x[(p_idx, b_idx)] = model.NewBoolVar(f"assign_p{p_idx}_b{b_idx}")
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m     # CONSTRAINT: Each patient assigned to at most one bed.
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m     # (We allow zero assignments: if no feasible bed exists, the patient
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m     # stays in the queue rather than getting an unsafe placement.)
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m     for p_idx in range(len(patients)):
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m         patient_vars = [x[(p_idx, b_idx)] for b_idx in range(len(beds))
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m                         if (p_idx, b_idx) in x]
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m         if patient_vars:
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m             model.Add(sum(patient_vars) <= 1)
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m     # CONSTRAINT: Each bed assigned to at most one patient.
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m     for b_idx in range(len(beds)):
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m         bed_vars = [x[(p_idx, b_idx)] for p_idx in range(len(patients))
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m                     if (p_idx, b_idx) in x]
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m         if bed_vars:
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m             model.Add(sum(bed_vars) <= 1)
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m     # OBJECTIVE FUNCTION: weighted multi-objective.
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m     # We maximize a composite score that rewards good assignments and
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m     # penalizes suboptimal ones.
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m     objective_terms = []
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m     for p_idx, patient in enumerate(patients):
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m         for b_idx, bed in enumerate(beds):
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m             if (p_idx, b_idx) not in x:
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m             var = x[(p_idx, b_idx)]
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m             score = 0
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m             # Base reward: assigning any patient is better than leaving them waiting.
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m             # Weighted by priority score so sicker/longer-waiting patients get placed first.
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m             score += int(OBJECTIVE_WEIGHTS["assignment_priority"] * patient["priority_score"])
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m             # Wait time urgency: longer-waiting patients get a per-minute bonus.
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m             score += int(OBJECTIVE_WEIGHTS["wait_time_urgency"] * patient["waiting_since_minutes"])
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m             # Clinical fit: bonus for placing patient on the ideal unit type
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m             # (vs. an acceptable-but-not-ideal unit).
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m             ideal_units = ACUITY_UNIT_COMPATIBILITY.get(patient["acuity"], [])
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m             if ideal_units and bed["unit_type"] == ideal_units[0]:
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m                 score += OBJECTIVE_WEIGHTS["clinical_fit"]
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m             # Workload balance: penalize assignments to already-busy units.
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m             # The penalty scales with how full the unit is.
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m             staffing = unit_staffing.get(bed["unit"], {})
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m             capacity = staffing.get("staffed_capacity", 1)
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m             census = staffing.get("current_census", 0)
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m             load_fraction = census / capacity  # 0.0 to 1.0
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m             score -= int(OBJECTIVE_WEIGHTS["workload_balance"] * load_fraction * 10)
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m             # Continuity of care: bonus if patient was previously on this unit.
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m             if patient.get("previous_unit") == bed["unit"]:
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m                 score += OBJECTIVE_WEIGHTS["continuity_of_care"]
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m             # Add this term to the objective.
