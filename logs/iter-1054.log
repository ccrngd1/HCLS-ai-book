[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m     solver = cp_model.CpSolver()
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m     solver.parameters.max_time_in_seconds = SOLVER_TIME_LIMIT_SECONDS
