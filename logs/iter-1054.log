[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m     # Solve the model.
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m     status = solver.Solve(model)
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m 
