[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m     "NONE":      ["PRIVATE", "SEMI_PRIVATE", "NEGATIVE_PRESSURE"],  # any room works
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m ```
