[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m             "solve_time_ms": int(solver.WallTime() * 1000),
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m             "recommendations": [],
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m             "unassigned_patients": [p["patient_id"] for p in patients],
