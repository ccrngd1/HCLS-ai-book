[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m     status_name = {
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m         cp_model.OPTIMAL: "OPTIMAL",
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m         cp_model.FEASIBLE: "FEASIBLE",       # found a solution but may not be optimal (hit time limit)
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m         cp_model.INFEASIBLE: "INFEASIBLE",   # no valid assignment exists
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m         cp_model.MODEL_INVALID: "MODEL_INVALID",
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m         cp_model.UNKNOWN: "UNKNOWN",
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m     }.get(status, "UNKNOWN")
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m     if status not in (cp_model.OPTIMAL, cp_model.FEASIBLE):
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m         return {
