[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m             if (p_idx, b_idx) in x and solver.Value(x[(p_idx, b_idx)]) == 1:
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m                 assigned_patient_indices.add(p_idx)
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m                 # Build the reasoning explanation.
