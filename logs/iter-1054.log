[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m                 recommendations.append({
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m                     "patient_id": patient["patient_id"],
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m                     "recommended_bed": bed["bed_id"],
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m                     "unit": bed["unit"],
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m                     "reasoning": reasoning,
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m                     "wait_minutes": patient["waiting_since_minutes"],
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m                     "acuity": patient["acuity"],
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m                     "isolation": patient["isolation"],
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m                 })
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m     # Identify patients who couldn't be assigned.
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m     unassigned = []
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m     for p_idx, patient in enumerate(patients):
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m         if p_idx not in assigned_patient_indices:
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m             unassigned.append({
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m                 "patient_id": patient["patient_id"],
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m                 "reason": explain_unassignment(patient, beds),
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m         "status": status_name,
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m         "solve_time_ms": int(solver.WallTime() * 1000),
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m         "objective_value": solver.ObjectiveValue(),
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m         "recommendations": recommendations,
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m         "unassigned_patients": unassigned,
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m def build_reasoning(patient: dict, bed: dict) -> list:
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m     Generate human-readable explanations for why this bed was chosen.
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m     Bed coordinators need to understand the recommendation to trust it.
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m     reasons = []
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m     # Acuity match
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m     ideal_units = ACUITY_UNIT_COMPATIBILITY.get(patient["acuity"], [])
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m     if ideal_units and bed["unit_type"] == ideal_units[0]:
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m         reasons.append(f"{patient['acuity']} acuity matches {bed['unit']} level of care")
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m         reasons.append(f"{bed['unit']} is acceptable for {patient['acuity']} acuity (not primary match)")
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m     # Continuity
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m     if patient.get("previous_unit") == bed["unit"]:
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m         reasons.append(f"Patient previously on {bed['unit']} (continuity bonus)")
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m     # Isolation
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m     if patient["isolation"] != "NONE":
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m         reasons.append(f"{patient['isolation']} isolation satisfied by {bed['room_type']} room")
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m     # Workload
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m     reasons.append(f"Unit at {UNIT_STAFFING[bed['unit']]['current_census']}/{UNIT_STAFFING[bed['unit']]['staffed_capacity']} staffed capacity")
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m     return reasons
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m def explain_unassignment(patient: dict, beds: list) -> str:
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m     Explain why a patient couldn't be assigned. This helps bed coordinators
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m     take manual action (open overflow, expedite a discharge, etc.).
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m     # Check what's blocking this patient.
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m     if patient["isolation"] == "AIRBORNE":
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m         neg_pressure_available = any(
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m             b["room_type"] == "NEGATIVE_PRESSURE" and b["status"] == "AVAILABLE"
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m             for b in beds
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m         if not neg_pressure_available:
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m             return "No negative-pressure bed available. Required for airborne isolation."
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m     compatible_units = ACUITY_UNIT_COMPATIBILITY.get(patient["acuity"], [])
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m     available_in_compatible = any(
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m         b["unit_type"] in compatible_units and b["status"] == "AVAILABLE"
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m         for b in beds
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m     if not available_in_compatible:
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m         return f"No available bed in compatible unit types: {compatible_units}"
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m     return "All compatible beds assigned to higher-priority patients."
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m ## Step 5: Store Recommendations in DynamoDB
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m *The pseudocode calls this `publish_recommendations(recommendations)`. In production, this also pushes WebSocket notifications to the bed management dashboard. Here we just persist to DynamoDB.*
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m def store_recommendations(result: dict) -> None:
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m     Write optimization results to DynamoDB for the bed management UI to read.
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m     Each recommendation gets its own record with a TTL so stale recommendations
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m     auto-expire. In production, you'd also push these via WebSocket to the
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m     coordinator's screen in real-time.
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m     table = dynamodb.Table(RECOMMENDATIONS_TABLE_NAME)
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m     now = datetime.datetime.now(timezone.utc)
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m     run_id = f"opt-{now.strftime('%Y%m%d-%H%M%S')}"
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m     # Store each recommendation as a separate item.
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m     # Partition key: patient_id (so you can query "what's the current recommendation for this patient?")
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m     # Sort key: run_id (so you can see recommendation history)
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m     for rec in result["recommendations"]:
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m         item = {
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m             "patient_id": rec["patient_id"],
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m             "run_id": run_id,
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m             "recommended_bed": rec["recommended_bed"],
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m             "unit": rec["unit"],
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m             "reasoning": rec["reasoning"],
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m             "status": "PENDING",  # PENDING -> ACCEPTED | OVERRIDDEN | EXPIRED
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m             "created_at": now.isoformat(),
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m             "expires_at": (now + datetime.timedelta(minutes=15)).isoformat(),
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m             "ttl": int((now + datetime.timedelta(hours=24)).timestamp()),
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m             "solve_status": result["status"],
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m             "solve_time_ms": Decimal(str(result["solve_time_ms"])),
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m         table.put_item(Item=item)
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m         logger.info(f"Stored recommendation: {rec['patient_id']} -> {rec['recommended_bed']}")
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m     # Store unassigned patients so the UI can show them with explanations.
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m     for unassigned in result["unassigned_patients"]:
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m         item = {
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m             "patient_id": unassigned["patient_id"],
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m             "run_id": run_id,
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m             "recommended_bed": "NONE",
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m             "unit": "UNASSIGNED",
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m             "reasoning": [unassigned["reason"]],
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m             "status": "NO_BED_AVAILABLE",
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m             "created_at": now.isoformat(),
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m             "ttl": int((now + datetime.timedelta(hours=24)).timestamp()),
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m         table.put_item(Item=item)
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m         logger.info(f"Stored unassigned: {unassigned['patient_id']} - {unassigned['reason']}")
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m ## Full Pipeline: End-to-End Optimization Run
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m This assembles all the steps into a single callable function. In production, this would be triggered by Step Functions on a hybrid schedule (event-triggered with debouncing). Here you can just call it directly.
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m def run_bed_assignment_optimization():
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m     Execute a complete bed assignment optimization cycle.
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m     In production, this runs every time the debounce timer fires (typically
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m     60 seconds after the last state change, or every 5 minutes regardless).
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m     Each run takes a fresh snapshot of hospital state and produces new
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m     recommendations.
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m     print("PATIENT FLOW BED ASSIGNMENT OPTIMIZATION")
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m     # Step 1: Get available beds from current state.
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m     print("\n[Step 1] Gathering available beds...")
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m     available_beds = get_available_beds(BED_INVENTORY)
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m     print(f"  Found {len(available_beds)} available/soon-available beds")
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m     for bed in available_beds:
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m         print(f"    {bed['bed_id']} ({bed['unit']}, {bed['room_type']}, {bed['status']})")
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m     # Step 2: Get pending patients.
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m     print(f"\n[Step 2] {len(PENDING_PATIENTS)} patients waiting for beds:")
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m     for patient in PENDING_PATIENTS:
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m         print(f"    {patient['patient_id']}: {patient['acuity']}, "
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m               f"isolation={patient['isolation']}, waiting {patient['waiting_since_minutes']}min")
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m     # Step 3: Build the optimization model.
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m     print("\n[Step 3] Building optimization model...")
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m     model, x, patients, beds = build_optimization_model(
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m         PENDING_PATIENTS, available_beds, UNIT_STAFFING
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m     num_variables = len(x)
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m     print(f"  Created {num_variables} decision variables (feasible patient-bed pairs)")
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m     print(f"  Infeasible pairs excluded: {len(patients) * len(beds) - num_variables}")
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m     # Step 4: Solve.
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m     print(f"\n[Step 4] Solving (time limit: {SOLVER_TIME_LIMIT_SECONDS}s)...")
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m     result = solve_assignment(model, x, patients, beds)
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m     print(f"  Status: {result['status']}")
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m     print(f"  Solve time: {result['solve_time_ms']}ms")
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m     if "objective_value" in result:
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m         print(f"  Objective value: {result['objective_value']}")
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m     # Step 5: Display recommendations.
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m     print(f"\n[Step 5] Recommendations ({len(result['recommendations'])} assignments):")
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m     print("-" * 60)
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m     for rec in result["recommendations"]:
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m         print(f"\n  Patient: {rec['patient_id']}")
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m         print(f"  Assign to: {rec['recommended_bed']} ({rec['unit']})")
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m         print(f"  Acuity: {rec['acuity']} | Isolation: {rec['isolation']}")
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m         print(f"  Wait time: {rec['wait_minutes']} minutes")
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m         print(f"  Reasoning:")
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m         for reason in rec["reasoning"]:
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m             print(f"    - {reason}")
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m     if result["unassigned_patients"]:
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m         print(f"\n  UNASSIGNED ({len(result['unassigned_patients'])} patients):")
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m         for unassigned in result["unassigned_patients"]:
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m             print(f"    {unassigned['patient_id']}: {unassigned['reason']}")
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m     # Step 6: Store results (uncomment when DynamoDB table exists).
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m     # print("\n[Step 6] Storing recommendations to DynamoDB...")
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m     # store_recommendations(result)
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m     # print("  Done.")
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m     print("\n" + "=" * 60)
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m     print("OPTIMIZATION COMPLETE")
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m     return result
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m # Run it.
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m if __name__ == "__main__":
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m     run_bed_assignment_optimization()
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m ## Gap to Production
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m This example demonstrates the optimization math. Here's what you'd need to add for a real deployment:
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m **Real-time state ingestion.** Replace the hardcoded `BED_INVENTORY` and `PENDING_PATIENTS` with a Kinesis consumer that processes ADT events (HL7 A01/A02/A03/A08 messages) and maintains the DynamoDB state table in real-time. Every admit, discharge, and transfer updates the state within seconds.
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m **Debounced triggering.** Instead of running on demand, use EventBridge + ElastiCache Redis to implement the hybrid trigger: state changes start a 60-second debounce timer in Redis. When the timer fires (no new changes for 60 seconds), it triggers the Step Functions workflow that runs the optimizer. A separate EventBridge rule triggers every 5 minutes regardless as a baseline.
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m **WebSocket push notifications.** When new recommendations are generated, push them to connected bed coordinators via API Gateway WebSocket. The coordinator sees the recommendation appear on their screen within seconds of the optimization completing. No polling, no refresh button.
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m **Override tracking and feedback loop.** When a coordinator accepts or overrides a recommendation, log the decision with a reason code. Aggregate override patterns weekly. If the system is consistently overridden for a specific constraint (e.g., "that room has a broken call light"), add that constraint to the model. This is how the system gets smarter over time.
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m **Error handling and retries.** The solver can fail (model invalid, timeout with no feasible solution). Step Functions handles retries with exponential backoff. If the solver consistently fails, alert the on-call engineer and fall back to a simple priority-queue heuristic (assign highest-priority patient to first available compatible bed).
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m **Input validation.** Validate all state data before feeding it to the optimizer. A corrupted bed record (missing unit type, null status) can make the model infeasible or produce nonsensical recommendations. Validate early, fail loudly.
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m **Structured logging.** Every optimization run should log: input state summary (how many beds, how many patients, constraint counts), solve time, solution quality (objective gap), and recommendation count. Use JSON-formatted logs for CloudWatch Logs Insights queries. Never log patient names or identifiers in plain text.
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m **IAM least-privilege.** The Lambda running the optimizer needs read access to the state table and write access to the recommendations table. It does not need access to the raw ADT event stream, patient demographics, or clinical data beyond what's in the state model. Scope the IAM policy tightly.
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m **VPC configuration.** In production, the optimizer Lambda runs in a VPC to access ElastiCache Redis (which is VPC-only). Configure VPC endpoints for DynamoDB and CloudWatch to avoid routing that traffic through a NAT gateway. The EHR integration (ADT event source) likely requires VPC connectivity via Direct Connect or VPN.
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m **KMS encryption.** Use customer-managed KMS keys for DynamoDB encryption at rest. The state table contains patient identifiers and clinical attributes (acuity, isolation status). Enable in-transit encryption for ElastiCache. All API Gateway endpoints use TLS.
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m **Testing.** Unit test the feasibility function exhaustively (every constraint combination). Integration test the full pipeline with synthetic ADT event sequences. Load test with realistic hospital sizes (400+ beds, 30+ pending patients) to verify solve times stay under your SLA. Test the infeasible case (more patients than beds, conflicting constraints) to ensure graceful degradation.
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m **DynamoDB Decimal handling.** Note that we already use `Decimal(str(...))` for numeric values stored in DynamoDB. The boto3 DynamoDB resource does not accept Python floats. If you skip this conversion, `put_item` raises a `TypeError`. This is a common gotcha that catches people on their first DynamoDB project.
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m **Solver warm-starting.** For the periodic re-optimization (every 5 minutes), you can warm-start the solver with the previous solution as a hint. This often cuts solve time by 50-70% because the new problem is usually similar to the previous one (only a few state changes between runs). OR-Tools CP-SAT supports solution hints via `model.AddHint()`.
