[0m[49m[38;5;10m+    30[0m:[38;5;10m[49m       if restriction_id not in seen_vertices:
[0m[49m[38;5;10m+    31[0m:[38;5;10m[49m           vertices.append({
[0m[49m[38;5;10m+    32[0m:[38;5;10m[49m               "id": restriction_id,
[0m[49m[38;5;10m+    33[0m:[38;5;10m[49m               "label": "Restriction",
[0m[49m[38;5;10m+    34[0m:[38;5;10m[49m               "properties": {"type": "PRIOR_AUTH", "plan_id": plan_id},
[0m[49m[38;5;10m+    35[0m:[38;5;10m[49m           })
[0m[49m[38;5;10m+    36[0m:[38;5;10m[49m           seen_vertices.add(restriction_id)
