[0m[49m[38;5;10m+      455[0m:[38;5;10m[49m                 max_suv: max(suv_in_region),
[0m[49m[38;5;10m+      456[0m:[38;5;10m[49m                 volume_above_threshold: count(suv_in_region > 2.5) * voxel_volume,
[0m[49m[38;5;10m+      457[0m:[38;5;10m[49m                 metabolic_tumor_volume: count(suv_in_region > 0.41 * max(suv_in_region)) * voxel_volume
