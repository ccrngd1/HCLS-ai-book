[0m[49m[38;5;9m- 520     [0m:[38;5;9m[49m     
[0m[49m[38;5;9m- 521     [0m:[38;5;9m[49m     RETURN outputs
[0m[49m[38;5;10m+      459[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      460[0m:[38;5;10m[49m     ELSE IF clinical_context == "longitudinal_comparison":
[0m[49m[38;5;10m+      461[0m:[38;5;10m[49m         // Compare the same modality at two time points (e.g., pre/post treatment).
[0m[49m[38;5;10m+      462[0m:[38;5;10m[49m         // The deformation field accounts for positioning differences.
[0m[49m[38;5;10m+      463[0m:[38;5;10m[49m         // Subtraction reveals true change vs. positioning artifact.
[0m[49m[38;5;10m+      464[0m:[38;5;10m[49m         
[0m[49m[38;5;10m+      465[0m:[38;5;10m[49m         difference_map = fixed_volume - warped_volume
[0m[49m[38;5;10m+      466[0m:[38;5;10m[49m         
[0m[49m[38;5;10m+      467[0m:[38;5;10m[49m         // Threshold to identify regions of significant change
[0m[49m[38;5;10m+      468[0m:[38;5;10m[49m         significant_change = abs(difference_map) > change_threshold
[0m[49m[38;5;10m+      469[0m:[38;5;10m[49m         fusion_products["change_map"] = difference_map
[0m[49m[38;5;10m+      470[0m:[38;5;10m[49m         fusion_products["change_regions"] = significant_change
[0m[49m[38;5;10m+      471[0m:[38;5;10m[49m 
