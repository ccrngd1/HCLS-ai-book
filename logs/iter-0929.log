[0m[49m[38;5;10m+      448[0m:[38;5;10m[49m         
[0m[49m[38;5;10m+      449[0m:[38;5;10m[49m         FOR each structure in ct_segmentation:
[0m[49m[38;5;10m+      450[0m:[38;5;10m[49m             region_mask = ct_segmentation[structure]
[0m[49m[38;5;10m+      451[0m:[38;5;10m[49m             suv_in_region = warped_volume[region_mask]
[0m[49m[39m  497, 452[0m:[39m[49m             
[0m[49m[38;5;9m- 498     [0m:[38;5;9m[49m             outputs["quantitative_metrics"] = {
[0m[49m[38;5;9m- 499     [0m:[38;5;9m[49m                 "metabolic_tumor_volume_ml": compute_volume(tumor_mask),
[0m[49m[38;5;9m- 500     [0m:[38;5;9m[49m                 "suv_max":    max(pet_within_tumor),
[0m[49m[38;5;9m- 501     [0m:[38;5;9m[49m                 "suv_mean":   mean(pet_within_tumor where value > 0),
[0m[49m[38;5;9m- 502     [0m:[38;5;9m[49m                 "suv_peak":   compute_suv_peak(pet_within_tumor),  // 1cm sphere max mean
[0m[49m[38;5;9m- 503     [0m:[38;5;9m[49m                 "heterogeneity_index": std(pet_within_tumor) / mean(pet_within_tumor),
[0m[49m[38;5;9m- 504     [0m:[38;5;9m[49m                 "tumor_dimensions_mm": compute_3d_dimensions(tumor_mask)
