[0m[49m[38;5;10m+      481[0m:[38;5;10m[49m **Step 6: Quality assurance and clinical review.** No automated registration should go directly to clinical use without quality review. This step presents the fusion results to a clinician (physicist, dosimetrist, or physician) for approval. The review interface shows the fused images with interactive tools: checkerboard overlay, sliding window comparison, contour overlay, and quantitative metrics. The clinician can accept, reject (triggering re-registration with different parameters), or manually adjust the registration. This human-in-the-loop step is non-negotiable for clinical applications.
[0m[49m[38;5;10m+      482[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      483[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+      484[0m:[38;5;10m[49m FUNCTION quality_assurance_review(fusion_result, clinical_context):
[0m[49m[38;5;10m+      485[0m:[38;5;10m[49m     // Compute automated quality metrics
[0m[49m[38;5;10m+      486[0m:[38;5;10m[49m     qa_metrics = {
[0m[49m[38;5;10m+      487[0m:[38;5;10m[49m         rigid_metric: fusion_result.rigid_registration.metric_value,
[0m[49m[38;5;10m+      488[0m:[38;5;10m[49m         deformable_dice: fusion_result.deformable_registration.dice_scores,
[0m[49m[38;5;10m+      489[0m:[38;5;10m[49m         folding_pct: fusion_result.deformable_registration.folding_percentage,
[0m[49m[38;5;10m+      490[0m:[38;5;10m[49m         max_displacement: max_magnitude(fusion_result.deformation_field),
[0m[49m[38;5;10m+      491[0m:[38;5;10m[49m         mean_displacement: mean_magnitude(fusion_result.deformation_field)
[0m[49m[38;5;10m+      492[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+      493[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      494[0m:[38;5;10m[49m     // Apply automated pass/fail criteria
[0m[49m[38;5;10m+      495[0m:[38;5;10m[49m     auto_flags = []
[0m[49m[38;5;10m+      496[0m:[38;5;10m[49m     IF qa_metrics.folding_pct > 0.5:
[0m[49m[38;5;10m+      497[0m:[38;5;10m[49m         append "Jacobian folding exceeds 0.5%" to auto_flags
[0m[49m[38;5;10m+      498[0m:[38;5;10m[49m     IF qa_metrics.max_displacement > 50:  // mm
[0m[49m[38;5;10m+      499[0m:[38;5;10m[49m         append "Maximum displacement exceeds 50mm (likely failure)" to auto_flags
[0m[49m[38;5;10m+      500[0m:[38;5;10m[49m     IF any(qa_metrics.deformable_dice.values() < 0.7):
[0m[49m[38;5;10m+      501[0m:[38;5;10m[49m         append "Structure overlap below 0.7 for one or more structures" to auto_flags
[0m[49m[38;5;10m+      502[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      503[0m:[38;5;10m[49m     // Create review task for clinical staff
[0m[49m[38;5;10m+      504[0m:[38;5;10m[49m     review_task = {
[0m[49m[38;5;10m+      505[0m:[38;5;10m[49m         study_pair: fusion_result.study_ids,
[0m[49m[38;5;10m+      506[0m:[38;5;10m[49m         patient_id: clinical_context.patient_id,
[0m[49m[38;5;10m+      507[0m:[38;5;10m[49m         qa_metrics: qa_metrics,
[0m[49m[38;5;10m+      508[0m:[38;5;10m[49m         auto_flags: auto_flags,
[0m[49m[38;5;10m+      509[0m:[38;5;10m[49m         priority: "HIGH" if len(auto_flags) > 0 else "NORMAL",
[0m[49m[38;5;10m+      510[0m:[38;5;10m[49m         visualization_url: generate_review_url(fusion_result),
[0m[49m[38;5;10m+      511[0m:[38;5;10m[49m         status: "PENDING_REVIEW"
[0m[49m[38;5;10m+      512[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+      513[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      514[0m:[38;5;10m[49m     // Store in review queue
[0m[49m[38;5;10m+      515[0m:[38;5;10m[49m     write_to_database(table="fusion-reviews", item=review_task)
[0m[49m[38;5;10m+      516[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      517[0m:[38;5;10m[49m     // If automated QA passes with no flags, mark as ready for clinical use
[0m[49m[38;5;10m+      518[0m:[38;5;10m[49m     // but still require human sign-off (regulatory requirement for treatment planning)
[0m[49m[38;5;10m+      519[0m:[38;5;10m[49m     IF len(auto_flags) == 0:
[0m[49m[38;5;10m+      520[0m:[38;5;10m[49m         review_task.suggested_action = "APPROVE"
[0m[49m[38;5;10m+      521[0m:[38;5;10m[49m     ELSE:
[0m[49m[38;5;10m+      522[0m:[38;5;10m[49m         review_task.suggested_action = "MANUAL_REVIEW_REQUIRED"
[0m[49m[38;5;10m+      523[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      524[0m:[38;5;10m[49m     RETURN review_task
[0m[49m[39m  522, 525[0m:[39m[49m ```
