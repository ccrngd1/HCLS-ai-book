[0m[49m[38;5;9m- 513     [0m:[38;5;9m[49m         status          = "COMPLETE"
[0m[49m[38;5;9m- 514     [0m:[38;5;9m[49m         outputs         = list of output paths
[0m[49m[38;5;9m- 515     [0m:[38;5;9m[49m         completed_at    = current UTC timestamp
