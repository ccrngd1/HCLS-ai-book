[0m[49m[38;5;10m+      13[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+      14[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      15[0m:[38;5;10m[49m For the RL training components:
[0m[49m[38;5;10m+      16[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      17[0m:[38;5;10m[49m ```bash
[0m[49m[38;5;10m+      18[0m:[38;5;10m[49m pip install torch
[0m[49m[38;5;10m+      19[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+      20[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      21[0m:[38;5;10m[49m Your environment needs AWS credentials configured (via environment variables, instance profile, or `~/.aws/credentials`). The IAM role needs: `sagemaker:CreateTrainingJob`, `s3:GetObject`, `s3:PutObject`, `dynamodb:PutItem`, `dynamodb:GetItem`, `lambda:InvokeFunction`.
[0m[49m[38;5;10m+      22[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      23[0m:[38;5;10m[49m This example runs locally for demonstration. In practice, the training step runs on SageMaker with GPU instances, and the inference step runs as a Lambda function invoked before each treatment fraction.
[0m[49m[38;5;10m+      24[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      25[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+      26[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      27[0m:[38;5;10m[49m ## Config and Constants
[0m[49m[38;5;10m+      28[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      29[0m:[38;5;10m[49m Before we get to the logic, here's the configuration that drives the system. These constants encode radiation physics constraints, clinical tolerances, and reward function weights. The organ-at-risk (OAR) dose tolerances come from published clinical guidelines (QUANTEC, for example). The reward weights are value judgments made by radiation oncologists about how to balance tumor control against normal tissue sparing. Different institutions, different tumor sites, different patient populations might set these differently.
[0m[49m[38;5;10m+      30[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      31[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+      32[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+      33[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+      34[0m:[38;5;10m[49m import uuid
[0m[49m[38;5;10m+      35[0m:[38;5;10m[49m from datetime import datetime
[0m[49m[38;5;10m+      36[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+      37[0m:[38;5;10m[49m from typing import Dict, List, Tuple, Optional
[0m[49m[38;5;10m+      38[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      39[0m:[38;5;10m[49m import numpy as np
[0m[49m[38;5;10m+      40[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+      41[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+      42[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      43[0m:[38;5;10m[49m # --- Logging ---
[0m[49m[38;5;10m+      44[0m:[38;5;10m[49m # Never log PHI (patient identifiers, imaging data, treatment details).
[0m[49m[38;5;10m+      45[0m:[38;5;10m[49m # Log operational metrics only: counts, latencies, error types.
[0m[49m[38;5;10m+      46[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+      47[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+      48[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      49[0m:[38;5;10m[49m # --- AWS Configuration ---
[0m[49m[38;5;10m+      50[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+      51[0m:[38;5;10m[49m AWS_REGION = "us-east-1"
[0m[49m[38;5;10m+      52[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      53[0m:[38;5;10m[49m # --- Treatment Parameters ---
[0m[49m[38;5;10m+      54[0m:[38;5;10m[49m # Head and neck cancer: typical fractionation is 70 Gy in 35 fractions (2 Gy/fraction).
[0m[49m[38;5;10m+      55[0m:[38;5;10m[49m TOTAL_FRACTIONS = 35
[0m[49m[38;5;10m+      56[0m:[38;5;10m[49m PRESCRIBED_DOSE_PER_FRACTION_GY = 2.0
[0m[49m[38;5;10m+      57[0m:[38;5;10m[49m TOTAL_PRESCRIBED_DOSE_GY = TOTAL_FRACTIONS * PRESCRIBED_DOSE_PER_FRACTION_GY  # 70 Gy
[0m[49m[38;5;10m+      58[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      59[0m:[38;5;10m[49m # --- Organ-at-Risk Dose Tolerances (Gy) ---
[0m[49m[38;5;10m+      60[0m:[38;5;10m[49m # These are hard constraints. Exceeding them causes serious complications.
[0m[49m[38;5;10m+      61[0m:[38;5;10m[49m # Values from QUANTEC guidelines (simplified for this example).
[0m[49m[38;5;10m+      62[0m:[38;5;10m[49m OAR_TOLERANCES = {
[0m[49m[38;5;10m+      63[0m:[38;5;10m[49m     "spinal_cord": 45.0,        # Myelopathy risk above this
[0m[49m[38;5;10m+      64[0m:[38;5;10m[49m     "brainstem": 54.0,          # Necrosis risk
[0m[49m[38;5;10m+      65[0m:[38;5;10m[49m     "parotid_left": 26.0,      # Mean dose; xerostomia (dry mouth) above this
[0m[49m[38;5;10m+      66[0m:[38;5;10m[49m     "parotid_right": 26.0,     # Same for contralateral
[0m[49m[38;5;10m+      67[0m:[38;5;10m[49m     "optic_nerve": 54.0,       # Vision loss risk
[0m[49m[38;5;10m+      68[0m:[38;5;10m[49m     "cochlea_left": 45.0,      # Hearing loss
[0m[49m[38;5;10m+      69[0m:[38;5;10m[49m     "cochlea_right": 45.0,
[0m[49m[38;5;10m+      70[0m:[38;5;10m[49m     "mandible": 70.0,          # Osteoradionecrosis
[0m[49m[38;5;10m+      71[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+      72[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      73[0m:[38;5;10m[49m # Safety margin: trigger warnings at this fraction of tolerance.
[0m[49m[38;5;10m+      74[0m:[38;5;10m[49m SAFETY_MARGIN_FRACTION = 0.85
[0m[49m[38;5;10m+      75[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      76[0m:[38;5;10m[49m # --- State Space ---
[0m[49m[38;5;10m+      77[0m:[38;5;10m[49m # 18 features representing what the system observes at each fraction.
[0m[49m[38;5;10m+      78[0m:[38;5;10m[49m STATE_DIM = 18
[0m[49m[38;5;10m+      79[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      80[0m:[38;5;10m[49m # --- Action Space ---
[0m[49m[38;5;10m+      81[0m:[38;5;10m[49m # Discrete actions the agent can recommend at each fraction.
[0m[49m[38;5;10m+      82[0m:[38;5;10m[49m ACTIONS = ["continue", "adjust_intensity", "replan"]
[0m[49m[38;5;10m+      83[0m:[38;5;10m[49m NUM_ACTIONS = len(ACTIONS)
[0m[49m[38;5;10m+      84[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      85[0m:[38;5;10m[49m # --- Reward Function Weights ---
[0m[49m[38;5;10m+      86[0m:[38;5;10m[49m # These encode the clinical tradeoff between tumor control and tissue sparing.
[0m[49m[38;5;10m+      87[0m:[38;5;10m[49m # TCP = tumor control probability. NTCP = normal tissue complication probability.
[0m[49m[38;5;10m+      88[0m:[38;5;10m[49m TCP_WEIGHT = 10.0               # Reward for maintaining good tumor coverage
[0m[49m[38;5;10m+      89[0m:[38;5;10m[49m NTCP_PENALTY_WEIGHT = 8.0      # Penalty for OAR dose approaching tolerance
[0m[49m[38;5;10m+      90[0m:[38;5;10m[49m REPLAN_COST = 2.0              # Cost of replanning (clinical resources, patient time)
[0m[49m[38;5;10m+      91[0m:[38;5;10m[49m COVERAGE_LOSS_PENALTY = 15.0   # Penalty for tumor underdosing
[0m[49m[38;5;10m+      92[0m:[38;5;10m[49m CONSTRAINT_VIOLATION_PENALTY = 100.0  # Hard penalty for exceeding OAR tolerance
[0m[49m[38;5;10m+      93[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      94[0m:[38;5;10m[49m # --- Training Hyperparameters ---
[0m[49m[38;5;10m+      95[0m:[38;5;10m[49m GAMMA = 0.99            # Discount factor (future fractions matter almost as much)
[0m[49m[38;5;10m+      96[0m:[38;5;10m[49m CQL_ALPHA = 2.0         # CQL conservatism (higher than chemo because stakes are higher)
[0m[49m[38;5;10m+      97[0m:[38;5;10m[49m LEARNING_RATE = 1e-4
[0m[49m[38;5;10m+      98[0m:[38;5;10m[49m BATCH_SIZE = 64
[0m[49m[38;5;10m+      99[0m:[38;5;10m[49m NUM_EPOCHS = 100
[0m[49m[38;5;10m+     100[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     101[0m:[38;5;10m[49m # --- DynamoDB Table Names ---
[0m[49m[38;5;10m+     102[0m:[38;5;10m[49m STATE_TABLE = "radiation-adaptive-patient-states"
[0m[49m[38;5;10m+     103[0m:[38;5;10m[49m RECOMMENDATION_TABLE = "radiation-adaptive-recommendations"
[0m[49m[38;5;10m+     104[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     105[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     106[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     107[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     108[0m:[38;5;10m[49m ## Step 1: Define the State Representation
[0m[49m[38;5;10m+     109[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     110[0m:[38;5;10m[49m *The main recipe describes a high-dimensional state vector capturing tumor geometry, cumulative dosimetry, and treatment trajectory. This step builds that vector from the data available at each fraction.*
[0m[49m[38;5;10m+     111[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     112[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     113[0m:[38;5;10m[49m def build_state_vector(
[0m[49m[38;5;10m+     114[0m:[38;5;10m[49m     fraction_number: int,
[0m[49m[38;5;10m+     115[0m:[38;5;10m[49m     tumor_volume_ratio: float,
[0m[49m[38;5;10m+     116[0m:[38;5;10m[49m     tumor_volume_change_rate: float,
[0m[49m[38;5;10m+     117[0m:[38;5;10m[49m     cumulative_ptv_dose_gy: float,
[0m[49m[38;5;10m+     118[0m:[38;5;10m[49m     cumulative_oar_doses: Dict[str, float],
[0m[49m[38;5;10m+     119[0m:[38;5;10m[49m     plan_conformity_index: float,
[0m[49m[38;5;10m+     120[0m:[38;5;10m[49m     plan_homogeneity_index: float,
[0m[49m[38;5;10m+     121[0m:[38;5;10m[49m     patient_weight_change_kg: float,
[0m[49m[38;5;10m+     122[0m:[38;5;10m[49m     fractions_since_replan: int,
[0m[49m[38;5;10m+     123[0m:[38;5;10m[49m     current_plan_age_fractions: int,
[0m[49m[38;5;10m+     124[0m:[38;5;10m[49m ) -> np.ndarray:
[0m[49m[38;5;10m+     125[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     126[0m:[38;5;10m[49m     Construct a normalized state vector from clinical and dosimetric data.
[0m[49m[38;5;10m+     127[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     128[0m:[38;5;10m[49m     Each feature is scaled to roughly [0, 1] so the neural network sees
[0m[49m[38;5;10m+     129[0m:[38;5;10m[49m     consistent magnitudes. The normalization constants come from typical
[0m[49m[38;5;10m+     130[0m:[38;5;10m[49m     clinical ranges for head and neck radiation therapy.
[0m[49m[38;5;10m+     131[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     132[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     133[0m:[38;5;10m[49m         fraction_number: Current fraction (1 to 35).
[0m[49m[38;5;10m+     134[0m:[38;5;10m[49m         tumor_volume_ratio: Current tumor volume / baseline volume (0.3 to 1.2 typical).
[0m[49m[38;5;10m+     135[0m:[38;5;10m[49m         tumor_volume_change_rate: Rate of volume change over last 5 fractions.
[0m[49m[38;5;10m+     136[0m:[38;5;10m[49m         cumulative_ptv_dose_gy: Total dose delivered to planning target volume so far.
[0m[49m[38;5;10m+     137[0m:[38;5;10m[49m         cumulative_oar_doses: Dict mapping OAR name to cumulative mean dose in Gy.
[0m[49m[38;5;10m+     138[0m:[38;5;10m[49m         plan_conformity_index: How well dose conforms to target (1.0 = perfect).
[0m[49m[38;5;10m+     139[0m:[38;5;10m[49m         plan_homogeneity_index: Dose uniformity within target (lower = more uniform).
[0m[49m[38;5;10m+     140[0m:[38;5;10m[49m         patient_weight_change_kg: Weight change from baseline (negative = loss).
[0m[49m[38;5;10m+     141[0m:[38;5;10m[49m         fractions_since_replan: How many fractions since the last plan change.
[0m[49m[38;5;10m+     142[0m:[38;5;10m[49m         current_plan_age_fractions: Total age of current plan in fractions.
[0m[49m[38;5;10m+     143[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     144[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     145[0m:[38;5;10m[49m         Numpy array of shape (STATE_DIM,) with normalized features.
[0m[49m[38;5;10m+     146[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     147[0m:[38;5;10m[49m     # Normalize cumulative OAR doses by their respective tolerances.
[0m[49m[38;5;10m+     148[0m:[38;5;10m[49m     # This gives us a "fraction of tolerance used" for each OAR (0 to 1+).
[0m[49m[38;5;10m+     149[0m:[38;5;10m[49m     spinal_cord_frac = cumulative_oar_doses.get("spinal_cord", 0) / OAR_TOLERANCES["spinal_cord"]
[0m[49m[38;5;10m+     150[0m:[38;5;10m[49m     parotid_l_frac = cumulative_oar_doses.get("parotid_left", 0) / OAR_TOLERANCES["parotid_left"]
[0m[49m[38;5;10m+     151[0m:[38;5;10m[49m     parotid_r_frac = cumulative_oar_doses.get("parotid_right", 0) / OAR_TOLERANCES["parotid_right"]
[0m[49m[38;5;10m+     152[0m:[38;5;10m[49m     brainstem_frac = cumulative_oar_doses.get("brainstem", 0) / OAR_TOLERANCES["brainstem"]
[0m[49m[38;5;10m+     153[0m:[38;5;10m[49m     optic_frac = cumulative_oar_doses.get("optic_nerve", 0) / OAR_TOLERANCES["optic_nerve"]
[0m[49m[38;5;10m+     154[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     155[0m:[38;5;10m[49m     # Fraction progress through treatment (0 at start, 1 at end).
[0m[49m[38;5;10m+     156[0m:[38;5;10m[49m     fraction_progress = fraction_number / TOTAL_FRACTIONS
[0m[49m[38;5;10m+     157[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     158[0m:[38;5;10m[49m     # How much of the prescribed dose has been delivered.
[0m[49m[38;5;10m+     159[0m:[38;5;10m[49m     dose_progress = cumulative_ptv_dose_gy / TOTAL_PRESCRIBED_DOSE_GY
[0m[49m[38;5;10m+     160[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     161[0m:[38;5;10m[49m     state = np.array([
[0m[49m[38;5;10m+     162[0m:[38;5;10m[49m         fraction_progress,                          # 0: where we are in treatment
[0m[49m[38;5;10m+     163[0m:[38;5;10m[49m         1.0 - fraction_progress,                    # 1: fractions remaining (normalized)
[0m[49m[38;5;10m+     164[0m:[38;5;10m[49m         tumor_volume_ratio,                         # 2: tumor shrinkage (1.0 = no change)
[0m[49m[38;5;10m+     165[0m:[38;5;10m[49m         np.clip(tumor_volume_change_rate + 0.5, 0, 1),  # 3: rate of change (centered)
[0m[49m[38;5;10m+     166[0m:[38;5;10m[49m         dose_progress,                              # 4: dose delivered vs planned
[0m[49m[38;5;10m+     167[0m:[38;5;10m[49m         spinal_cord_frac,                           # 5: spinal cord dose fraction
[0m[49m[38;5;10m+     168[0m:[38;5;10m[49m         parotid_l_frac,                             # 6: left parotid dose fraction
[0m[49m[38;5;10m+     169[0m:[38;5;10m[49m         parotid_r_frac,                             # 7: right parotid dose fraction
[0m[49m[38;5;10m+     170[0m:[38;5;10m[49m         brainstem_frac,                             # 8: brainstem dose fraction
[0m[49m[38;5;10m+     171[0m:[38;5;10m[49m         optic_frac,                                 # 9: optic nerve dose fraction
[0m[49m[38;5;10m+     172[0m:[38;5;10m[49m         np.clip(plan_conformity_index / 2.0, 0, 1),  # 10: conformity (1.0 ideal, >1 worse)
[0m[49m[38;5;10m+     173[0m:[38;5;10m[49m         np.clip(plan_homogeneity_index / 0.3, 0, 1), # 11: homogeneity (0 ideal, >0 worse)
[0m[49m[38;5;10m+     174[0m:[38;5;10m[49m         np.clip((patient_weight_change_kg + 10) / 20, 0, 1),  # 12: weight change
[0m[49m[38;5;10m+     175[0m:[38;5;10m[49m         fractions_since_replan / TOTAL_FRACTIONS,   # 13: time since last replan
[0m[49m[38;5;10m+     176[0m:[38;5;10m[49m         current_plan_age_fractions / TOTAL_FRACTIONS,  # 14: plan age
[0m[49m[38;5;10m+     177[0m:[38;5;10m[49m         # Derived safety features: how close are we to any OAR limit?
[0m[49m[38;5;10m+     178[0m:[38;5;10m[49m         max(spinal_cord_frac, parotid_l_frac, parotid_r_frac, brainstem_frac, optic_frac),  # 15: worst OAR
[0m[49m[38;5;10m+     179[0m:[38;5;10m[49m         # Is dose delivery on track? (should be ~equal to fraction_progress)
[0m[49m[38;5;10m+     180[0m:[38;5;10m[49m         np.clip(dose_progress - fraction_progress + 0.5, 0, 1),  # 16: dose tracking
[0m[49m[38;5;10m+     181[0m:[38;5;10m[49m         # Tumor response relative to expected (faster shrinkage = good)
[0m[49m[38;5;10m+     182[0m:[38;5;10m[49m         np.clip(1.0 - tumor_volume_ratio, 0, 1),   # 17: response magnitude
[0m[49m[38;5;10m+     183[0m:[38;5;10m[49m     ], dtype=np.float32)
[0m[49m[38;5;10m+     184[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     185[0m:[38;5;10m[49m     return state
[0m[49m[38;5;10m+     186[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     187[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     188[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     189[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     190[0m:[38;5;10m[49m ## Step 2: Compute the Reward
[0m[49m[38;5;10m+     191[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     192[0m:[38;5;10m[49m *The reward function balances tumor control probability against normal tissue complication probability, with a cost for replanning. This is where clinical judgment becomes math. The weights are not learned; they're decisions made by radiation oncologists.*
[0m[49m[38;5;10m+     193[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     194[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     195[0m:[38;5;10m[49m def compute_reward(
[0m[49m[38;5;10m+     196[0m:[38;5;10m[49m     current_state: np.ndarray,
[0m[49m[38;5;10m+     197[0m:[38;5;10m[49m     action: str,
[0m[49m[38;5;10m+     198[0m:[38;5;10m[49m     next_state: np.ndarray,
[0m[49m[38;5;10m+     199[0m:[38;5;10m[49m ) -> float:
[0m[49m[38;5;10m+     200[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     201[0m:[38;5;10m[49m     Compute the reward for a single fraction transition.
[0m[49m[38;5;10m+     202[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     203[0m:[38;5;10m[49m     The reward captures three things:
[0m[49m[38;5;10m+     204[0m:[38;5;10m[49m     1. Tumor coverage: is the target getting adequate dose?
[0m[49m[38;5;10m+     205[0m:[38;5;10m[49m     2. OAR sparing: are organs at risk staying below tolerance?
[0m[49m[38;5;10m+     206[0m:[38;5;10m[49m     3. Replanning cost: each replan consumes clinical resources.
[0m[49m[38;5;10m+     207[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     208[0m:[38;5;10m[49m     Hard constraint violations (OAR exceeding tolerance) get a massive
[0m[49m[38;5;10m+     209[0m:[38;5;10m[49m     penalty that dominates everything else. This ensures the policy
[0m[49m[38;5;10m+     210[0m:[38;5;10m[49m     learns to avoid them absolutely, not just on average.
[0m[49m[38;5;10m+     211[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     212[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     213[0m:[38;5;10m[49m         current_state: State vector at decision time.
[0m[49m[38;5;10m+     214[0m:[38;5;10m[49m         action: The action taken ("continue", "adjust_intensity", "replan").
[0m[49m[38;5;10m+     215[0m:[38;5;10m[49m         next_state: State vector at the next fraction.
[0m[49m[38;5;10m+     216[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     217[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     218[0m:[38;5;10m[49m         Scalar reward value.
[0m[49m[38;5;10m+     219[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     220[0m:[38;5;10m[49m     reward = 0.0
[0m[49m[38;5;10m+     221[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     222[0m:[38;5;10m[49m     # --- Tumor coverage component ---
[0m[49m[38;5;10m+     223[0m:[38;5;10m[49m     # Check if dose delivery is on track (state index 16: dose tracking).
[0m[49m[38;5;10m+     224[0m:[38;5;10m[49m     # Values near 0.5 mean on track. Below 0.5 means underdosing.
[0m[49m[38;5;10m+     225[0m:[38;5;10m[49m     dose_tracking = next_state[16]
[0m[49m[38;5;10m+     226[0m:[38;5;10m[49m     if dose_tracking < 0.45:
[0m[49m[38;5;10m+     227[0m:[38;5;10m[49m         # Underdosing the tumor. This is bad for tumor control.
[0m[49m[38;5;10m+     228[0m:[38;5;10m[49m         reward -= COVERAGE_LOSS_PENALTY * (0.45 - dose_tracking)
[0m[49m[38;5;10m+     229[0m:[38;5;10m[49m     elif dose_tracking >= 0.48 and dose_tracking <= 0.55:
[0m[49m[38;5;10m+     230[0m:[38;5;10m[49m         # On track. Small positive reward for maintaining coverage.
[0m[49m[38;5;10m+     231[0m:[38;5;10m[49m         reward += TCP_WEIGHT * 0.1
[0m[49m[38;5;10m+     232[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     233[0m:[38;5;10m[49m     # --- Tumor response component ---
[0m[49m[38;5;10m+     234[0m:[38;5;10m[49m     # Reward tumor shrinkage (state index 17: response magnitude).
[0m[49m[38;5;10m+     235[0m:[38;5;10m[49m     response = next_state[17]
[0m[49m[38;5;10m+     236[0m:[38;5;10m[49m     reward += TCP_WEIGHT * response * 0.05  # Small continuous reward for response
[0m[49m[38;5;10m+     237[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     238[0m:[38;5;10m[49m     # --- OAR sparing component ---
[0m[49m[38;5;10m+     239[0m:[38;5;10m[49m     # Penalize as OAR doses approach tolerance (state indices 5-9).
[0m[49m[38;5;10m+     240[0m:[38;5;10m[49m     oar_fractions = next_state[5:10]
[0m[49m[38;5;10m+     241[0m:[38;5;10m[49m     for oar_frac in oar_fractions:
[0m[49m[38;5;10m+     242[0m:[38;5;10m[49m         if oar_frac > 1.0:
[0m[49m[38;5;10m+     243[0m:[38;5;10m[49m             # HARD CONSTRAINT VIOLATION. This must never happen.
[0m[49m[38;5;10m+     244[0m:[38;5;10m[49m             reward -= CONSTRAINT_VIOLATION_PENALTY
[0m[49m[38;5;10m+     245[0m:[38;5;10m[49m         elif oar_frac > SAFETY_MARGIN_FRACTION:
[0m[49m[38;5;10m+     246[0m:[38;5;10m[49m             # Approaching tolerance. Increasing penalty as we get closer.
[0m[49m[38;5;10m+     247[0m:[38;5;10m[49m             overshoot = oar_frac - SAFETY_MARGIN_FRACTION
[0m[49m[38;5;10m+     248[0m:[38;5;10m[49m             reward -= NTCP_PENALTY_WEIGHT * overshoot * 5.0
[0m[49m[38;5;10m+     249[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     250[0m:[38;5;10m[49m     # --- Replanning cost ---
[0m[49m[38;5;10m+     251[0m:[38;5;10m[49m     if action == "replan":
[0m[49m[38;5;10m+     252[0m:[38;5;10m[49m         reward -= REPLAN_COST
[0m[49m[38;5;10m+     253[0m:[38;5;10m[49m     elif action == "adjust_intensity":
[0m[49m[38;5;10m+     254[0m:[38;5;10m[49m         reward -= REPLAN_COST * 0.3  # Minor adjustments are cheaper
[0m[49m[38;5;10m+     255[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     256[0m:[38;5;10m[49m     # --- Plan quality degradation ---
[0m[49m[38;5;10m+     257[0m:[38;5;10m[49m     # If conformity or homogeneity are worsening, penalize "continue."
[0m[49m[38;5;10m+     258[0m:[38;5;10m[49m     conformity_change = next_state[10] - current_state[10]
[0m[49m[38;5;10m+     259[0m:[38;5;10m[49m     if action == "continue" and conformity_change > 0.05:
[0m[49m[38;5;10m+     260[0m:[38;5;10m[49m         # Plan quality is degrading and we're not doing anything about it.
[0m[49m[38;5;10m+     261[0m:[38;5;10m[49m         reward -= 1.0
[0m[49m[38;5;10m+     262[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     263[0m:[38;5;10m[49m     return reward
[0m[49m[38;5;10m+     264[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     265[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     266[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     267[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     268[0m:[38;5;10m[49m ## Step 3: Safety Constraint Enforcement
[0m[49m[38;5;10m+     269[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     270[0m:[38;5;10m[49m *This is the most critical piece. In radiation therapy, constraint violations are not "suboptimal outcomes" that you can tolerate occasionally. They cause permanent damage. The safety layer overrides the policy whenever a recommended action would risk exceeding OAR tolerances.*
[0m[49m[38;5;10m+     271[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     272[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     273[0m:[38;5;10m[49m def check_safety_constraints(
[0m[49m[38;5;10m+     274[0m:[38;5;10m[49m     state: np.ndarray,
[0m[49m[38;5;10m+     275[0m:[38;5;10m[49m     recommended_action: str,
[0m[49m[38;5;10m+     276[0m:[38;5;10m[49m ) -> Tuple[str, List[str]]:
[0m[49m[38;5;10m+     277[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     278[0m:[38;5;10m[49m     Verify that the recommended action doesn't risk OAR tolerance violations.
[0m[49m[38;5;10m+     279[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     280[0m:[38;5;10m[49m     This function implements hard safety constraints that override the policy.
[0m[49m[38;5;10m+     281[0m:[38;5;10m[49m     Even if the RL agent is 99% confident in "continue," if continuing would
[0m[49m[38;5;10m+     282[0m:[38;5;10m[49m     push the spinal cord past 45 Gy, we override to "replan."
[0m[49m[38;5;10m+     283[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     284[0m:[38;5;10m[49m     The logic:
[0m[49m[38;5;10m+     285[0m:[38;5;10m[49m     - If any OAR is above the safety margin AND the plan is old, force replan.
[0m[49m[38;5;10m+     286[0m:[38;5;10m[49m     - If any OAR is above tolerance, force replan (emergency).
[0m[49m[38;5;10m+     287[0m:[38;5;10m[49m     - Otherwise, allow the policy's recommendation.
[0m[49m[38;5;10m+     288[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     289[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     290[0m:[38;5;10m[49m         state: Current normalized state vector.
[0m[49m[38;5;10m+     291[0m:[38;5;10m[49m         recommended_action: What the policy wants to do.
[0m[49m[38;5;10m+     292[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     293[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     294[0m:[38;5;10m[49m         Tuple of (safe_action, list_of_violations).
[0m[49m[38;5;10m+     295[0m:[38;5;10m[49m         If no violations, returns the original action with empty list.
[0m[49m[38;5;10m+     296[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     297[0m:[38;5;10m[49m     violations = []
[0m[49m[38;5;10m+     298[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     299[0m:[38;5;10m[49m     # Extract OAR dose fractions (indices 5-9).
[0m[49m[38;5;10m+     300[0m:[38;5;10m[49m     oar_names = ["spinal_cord", "parotid_left", "parotid_right", "brainstem", "optic_nerve"]
[0m[49m[38;5;10m+     301[0m:[38;5;10m[49m     oar_fractions = state[5:10]
[0m[49m[38;5;10m+     302[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     303[0m:[38;5;10m[49m     # Check for hard constraint violations (already exceeded tolerance).
[0m[49m[38;5;10m+     304[0m:[38;5;10m[49m     for name, frac in zip(oar_names, oar_fractions):
[0m[49m[38;5;10m+     305[0m:[38;5;10m[49m         if frac >= 1.0:
[0m[49m[38;5;10m+     306[0m:[38;5;10m[49m             violations.append(f"CRITICAL: {name} at {frac*100:.1f}% of tolerance (exceeded)")
[0m[49m[38;5;10m+     307[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     308[0m:[38;5;10m[49m     # If any OAR has already exceeded tolerance, force immediate replan.
[0m[49m[38;5;10m+     309[0m:[38;5;10m[49m     if any(f >= 1.0 for f in oar_fractions):
[0m[49m[38;5;10m+     310[0m:[38;5;10m[49m         return "replan", violations
[0m[49m[38;5;10m+     311[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     312[0m:[38;5;10m[49m     # Check for approaching tolerance with "continue" action.
[0m[49m[38;5;10m+     313[0m:[38;5;10m[49m     if recommended_action == "continue":
[0m[49m[38;5;10m+     314[0m:[38;5;10m[49m         fractions_remaining_ratio = state[1]  # index 1: fractions remaining normalized
[0m[49m[38;5;10m+     315[0m:[38;5;10m[49m         for name, frac in zip(oar_names, oar_fractions):
[0m[49m[38;5;10m+     316[0m:[38;5;10m[49m             if frac > SAFETY_MARGIN_FRACTION:
[0m[49m[38;5;10m+     317[0m:[38;5;10m[49m                 # OAR is above 85% of tolerance. If we have many fractions left,
[0m[49m[38;5;10m+     318[0m:[38;5;10m[49m                 # continuing the current plan will likely exceed tolerance.
[0m[49m[38;5;10m+     319[0m:[38;5;10m[49m                 if fractions_remaining_ratio > 0.3:
[0m[49m[38;5;10m+     320[0m:[38;5;10m[49m                     violations.append(
[0m[49m[38;5;10m+     321[0m:[38;5;10m[49m                         f"WARNING: {name} at {frac*100:.1f}% of tolerance "
[0m[49m[38;5;10m+     322[0m:[38;5;10m[49m                         f"with {fractions_remaining_ratio*100:.0f}% of treatment remaining"
[0m[49m[38;5;10m+     323[0m:[38;5;10m[49m                     )
[0m[49m[38;5;10m+     324[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     325[0m:[38;5;10m[49m         # If we have warnings and the plan is old, override to replan.
[0m[49m[38;5;10m+     326[0m:[38;5;10m[49m         plan_age = state[14]  # index 14: plan age normalized
[0m[49m[38;5;10m+     327[0m:[38;5;10m[49m         if violations and plan_age > 0.3:
[0m[49m[38;5;10m+     328[0m:[38;5;10m[49m             return "replan", violations
[0m[49m[38;5;10m+     329[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     330[0m:[38;5;10m[49m         # If warnings but plan is recent, suggest adjustment instead.
[0m[49m[38;5;10m+     331[0m:[38;5;10m[49m         if violations:
[0m[49m[38;5;10m+     332[0m:[38;5;10m[49m             return "adjust_intensity", violations
[0m[49m[38;5;10m+     333[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     334[0m:[38;5;10m[49m     return recommended_action, violations
[0m[49m[38;5;10m+     335[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     336[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     337[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     338[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     339[0m:[38;5;10m[49m ## Step 4: The Q-Network (Conservative Q-Learning)
[0m[49m[38;5;10m+     340[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     341[0m:[38;5;10m[49m *The policy is a neural network that maps states to Q-values for each action. We train it with Conservative Q-Learning (CQL), which penalizes Q-values for actions that weren't well-represented in the training data. This prevents the policy from being overconfident about actions it hasn't seen evidence for.*
[0m[49m[38;5;10m+     342[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     343[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     344[0m:[38;5;10m[49m import torch
[0m[49m[38;5;10m+     345[0m:[38;5;10m[49m import torch.nn as nn
[0m[49m[38;5;10m+     346[0m:[38;5;10m[49m import torch.optim as optim
[0m[49m[38;5;10m+     347[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     348[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     349[0m:[38;5;10m[49m class AdaptivePlanningQNetwork(nn.Module):
[0m[49m[38;5;10m+     350[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     351[0m:[38;5;10m[49m     Q-network for radiation therapy adaptive planning.
[0m[49m[38;5;10m+     352[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     353[0m:[38;5;10m[49m     Maps a state vector (18 features) to Q-values for 3 actions
[0m[49m[38;5;10m+     354[0m:[38;5;10m[49m     (continue, adjust_intensity, replan).
[0m[49m[38;5;10m+     355[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     356[0m:[38;5;10m[49m     Architecture is simple: two hidden layers with ReLU activation.
[0m[49m[38;5;10m+     357[0m:[38;5;10m[49m     For a 3-action discrete problem with 18 state features, this is
[0m[49m[38;5;10m+     358[0m:[38;5;10m[49m     more than sufficient. Deeper networks don't help here because the
[0m[49m[38;5;10m+     359[0m:[38;5;10m[49m     state representation already encodes the relevant features.
[0m[49m[38;5;10m+     360[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     361[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     362[0m:[38;5;10m[49m     def __init__(self, state_dim: int = STATE_DIM, action_dim: int = NUM_ACTIONS):
[0m[49m[38;5;10m+     363[0m:[38;5;10m[49m         super().__init__()
[0m[49m[38;5;10m+     364[0m:[38;5;10m[49m         self.network = nn.Sequential(
[0m[49m[38;5;10m+     365[0m:[38;5;10m[49m             nn.Linear(state_dim, 128),
[0m[49m[38;5;10m+     366[0m:[38;5;10m[49m             nn.ReLU(),
[0m[49m[38;5;10m+     367[0m:[38;5;10m[49m             nn.Linear(128, 64),
[0m[49m[38;5;10m+     368[0m:[38;5;10m[49m             nn.ReLU(),
[0m[49m[38;5;10m+     369[0m:[38;5;10m[49m             nn.Linear(64, action_dim),
[0m[49m[38;5;10m+     370[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     371[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     372[0m:[38;5;10m[49m     def forward(self, state: torch.Tensor) -> torch.Tensor:
[0m[49m[38;5;10m+     373[0m:[38;5;10m[49m         """Forward pass: state -> Q-values for all actions."""
[0m[49m[38;5;10m+     374[0m:[38;5;10m[49m         return self.network(state)
[0m[49m[38;5;10m+     375[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     376[0m:[38;5;10m[49m     def get_action(self, state: np.ndarray) -> int:
[0m[49m[38;5;10m+     377[0m:[38;5;10m[49m         """Select the action with highest Q-value (greedy policy)."""
[0m[49m[38;5;10m+     378[0m:[38;5;10m[49m         with torch.no_grad():
[0m[49m[38;5;10m+     379[0m:[38;5;10m[49m             state_tensor = torch.FloatTensor(state).unsqueeze(0)
[0m[49m[38;5;10m+     380[0m:[38;5;10m[49m             q_values = self.forward(state_tensor).squeeze(0)
[0m[49m[38;5;10m+     381[0m:[38;5;10m[49m             return int(q_values.argmax().item())
[0m[49m[38;5;10m+     382[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     383[0m:[38;5;10m[49m     def get_action_confidence(self, state: np.ndarray, action_index: int) -> float:
[0m[49m[38;5;10m+     384[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     385[0m:[38;5;10m[49m         Compute confidence as softmax probability of the chosen action.
[0m[49m[38;5;10m+     386[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     387[0m:[38;5;10m[49m         Higher confidence means the Q-value for this action is much larger
[0m[49m[38;5;10m+     388[0m:[38;5;10m[49m         than alternatives. Low confidence means the agent is uncertain
[0m[49m[38;5;10m+     389[0m:[38;5;10m[49m         (multiple actions have similar Q-values).
[0m[49m[38;5;10m+     390[0m:[38;5;10m[49m         """
[0m[49m[38;5;10m+     391[0m:[38;5;10m[49m         with torch.no_grad():
[0m[49m[38;5;10m+     392[0m:[38;5;10m[49m             state_tensor = torch.FloatTensor(state).unsqueeze(0)
[0m[49m[38;5;10m+     393[0m:[38;5;10m[49m             q_values = self.forward(state_tensor).squeeze(0)
[0m[49m[38;5;10m+     394[0m:[38;5;10m[49m             probs = torch.softmax(q_values * 2.0, dim=0)  # temperature=0.5
[0m[49m[38;5;10m+     395[0m:[38;5;10m[49m             return float(probs[action_index].item())
[0m[49m[38;5;10m+     396[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     397[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     398[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     399[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     400[0m:[38;5;10m[49m ## Step 5: CQL Training Loop
[0m[49m[38;5;10m+     401[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     402[0m:[38;5;10m[49m *Conservative Q-Learning adds a penalty term to the standard Bellman loss. It pushes down Q-values for actions not in the dataset and pushes up Q-values for actions that were actually taken. This makes the policy conservative: it won't recommend actions that differ wildly from historical clinical practice.*
[0m[49m[38;5;10m+     403[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     404[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     405[0m:[38;5;10m[49m def train_cql_policy(
[0m[49m[38;5;10m+     406[0m:[38;5;10m[49m     trajectories: List[List[Dict]],
[0m[49m[38;5;10m+     407[0m:[38;5;10m[49m     num_epochs: int = NUM_EPOCHS,
[0m[49m[38;5;10m+     408[0m:[38;5;10m[49m     batch_size: int = BATCH_SIZE,
[0m[49m[38;5;10m+     409[0m:[38;5;10m[49m ) -> AdaptivePlanningQNetwork:
[0m[49m[38;5;10m+     410[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     411[0m:[38;5;10m[49m     Train a CQL policy from offline treatment trajectories.
[0m[49m[38;5;10m+     412[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     413[0m:[38;5;10m[49m     Each trajectory is one patient's full treatment course (up to 35 fractions).
[0m[49m[38;5;10m+     414[0m:[38;5;10m[49m     Each transition contains: state, action_index, reward, next_state, done.
[0m[49m[38;5;10m+     415[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     416[0m:[38;5;10m[49m     CQL loss = standard Bellman loss + alpha * (logsumexp(Q) - Q(data_action))
[0m[49m[38;5;10m+     417[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     418[0m:[38;5;10m[49m     The second term penalizes high Q-values for actions not in the data,
[0m[49m[38;5;10m+     419[0m:[38;5;10m[49m     preventing overestimation of untested actions.
[0m[49m[38;5;10m+     420[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     421[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     422[0m:[38;5;10m[49m         trajectories: List of patient trajectories (list of transition dicts).
[0m[49m[38;5;10m+     423[0m:[38;5;10m[49m         num_epochs: Training epochs.
[0m[49m[38;5;10m+     424[0m:[38;5;10m[49m         batch_size: Mini-batch size.
[0m[49m[38;5;10m+     425[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     426[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     427[0m:[38;5;10m[49m         Trained Q-network.
[0m[49m[38;5;10m+     428[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     429[0m:[38;5;10m[49m     # Flatten trajectories into a replay buffer.
[0m[49m[38;5;10m+     430[0m:[38;5;10m[49m     buffer_states = []
[0m[49m[38;5;10m+     431[0m:[38;5;10m[49m     buffer_actions = []
[0m[49m[38;5;10m+     432[0m:[38;5;10m[49m     buffer_rewards = []
[0m[49m[38;5;10m+     433[0m:[38;5;10m[49m     buffer_next_states = []
[0m[49m[38;5;10m+     434[0m:[38;5;10m[49m     buffer_dones = []
[0m[49m[38;5;10m+     435[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     436[0m:[38;5;10m[49m     for trajectory in trajectories:
[0m[49m[38;5;10m+     437[0m:[38;5;10m[49m         for transition in trajectory:
[0m[49m[38;5;10m+     438[0m:[38;5;10m[49m             buffer_states.append(transition["state"])
[0m[49m[38;5;10m+     439[0m:[38;5;10m[49m             buffer_actions.append(transition["action_index"])
[0m[49m[38;5;10m+     440[0m:[38;5;10m[49m             buffer_rewards.append(transition["reward"])
[0m[49m[38;5;10m+     441[0m:[38;5;10m[49m             buffer_next_states.append(transition["next_state"])
[0m[49m[38;5;10m+     442[0m:[38;5;10m[49m             buffer_dones.append(transition["done"])
[0m[49m[38;5;10m+     443[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     444[0m:[38;5;10m[49m     buffer_states = np.array(buffer_states)
[0m[49m[38;5;10m+     445[0m:[38;5;10m[49m     buffer_actions = np.array(buffer_actions)
[0m[49m[38;5;10m+     446[0m:[38;5;10m[49m     buffer_rewards = np.array(buffer_rewards, dtype=np.float32)
[0m[49m[38;5;10m+     447[0m:[38;5;10m[49m     buffer_next_states = np.array(buffer_next_states)
[0m[49m[38;5;10m+     448[0m:[38;5;10m[49m     buffer_dones = np.array(buffer_dones, dtype=np.float32)
[0m[49m[38;5;10m+     449[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     450[0m:[38;5;10m[49m     num_samples = len(buffer_states)
[0m[49m[38;5;10m+     451[0m:[38;5;10m[49m     logger.info("Training CQL on %d transitions from %d trajectories", num_samples, len(trajectories))
[0m[49m[38;5;10m+     452[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     453[0m:[38;5;10m[49m     # Initialize networks.
[0m[49m[38;5;10m+     454[0m:[38;5;10m[49m     policy = AdaptivePlanningQNetwork()
[0m[49m[38;5;10m+     455[0m:[38;5;10m[49m     target_network = AdaptivePlanningQNetwork()
[0m[49m[38;5;10m+     456[0m:[38;5;10m[49m     target_network.load_state_dict(policy.state_dict())
[0m[49m[38;5;10m+     457[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     458[0m:[38;5;10m[49m     optimizer = optim.Adam(policy.parameters(), lr=LEARNING_RATE)
[0m[49m[38;5;10m+     459[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     460[0m:[38;5;10m[49m     for epoch in range(num_epochs):
[0m[49m[38;5;10m+     461[0m:[38;5;10m[49m         epoch_loss = 0.0
[0m[49m[38;5;10m+     462[0m:[38;5;10m[49m         num_batches = 0
[0m[49m[38;5;10m+     463[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     464[0m:[38;5;10m[49m         # Shuffle and iterate in mini-batches.
[0m[49m[38;5;10m+     465[0m:[38;5;10m[49m         indices = np.random.permutation(num_samples)
[0m[49m[38;5;10m+     466[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     467[0m:[38;5;10m[49m         for start in range(0, num_samples - batch_size, batch_size):
[0m[49m[38;5;10m+     468[0m:[38;5;10m[49m             batch_idx = indices[start:start + batch_size]
[0m[49m[38;5;10m+     469[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     470[0m:[38;5;10m[49m             states = torch.FloatTensor(buffer_states[batch_idx])
[0m[49m[38;5;10m+     471[0m:[38;5;10m[49m             actions = torch.LongTensor(buffer_actions[batch_idx])
[0m[49m[38;5;10m+     472[0m:[38;5;10m[49m             rewards = torch.FloatTensor(buffer_rewards[batch_idx])
[0m[49m[38;5;10m+     473[0m:[38;5;10m[49m             next_states = torch.FloatTensor(buffer_next_states[batch_idx])
[0m[49m[38;5;10m+     474[0m:[38;5;10m[49m             dones = torch.FloatTensor(buffer_dones[batch_idx])
[0m[49m[38;5;10m+     475[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     476[0m:[38;5;10m[49m             # Current Q-values for the actions that were actually taken.
[0m[49m[38;5;10m+     477[0m:[38;5;10m[49m             current_q = policy(states).gather(1, actions.unsqueeze(1)).squeeze(1)
[0m[49m[38;5;10m+     478[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     479[0m:[38;5;10m[49m             # Target Q-values (Bellman target).
[0m[49m[38;5;10m+     480[0m:[38;5;10m[49m             with torch.no_grad():
[0m[49m[38;5;10m+     481[0m:[38;5;10m[49m                 next_q = target_network(next_states).max(dim=1)[0]
[0m[49m[38;5;10m+     482[0m:[38;5;10m[49m                 target_q = rewards + GAMMA * next_q * (1.0 - dones)
[0m[49m[38;5;10m+     483[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     484[0m:[38;5;10m[49m             # Standard Bellman loss.
[0m[49m[38;5;10m+     485[0m:[38;5;10m[49m             bellman_loss = nn.functional.mse_loss(current_q, target_q)
[0m[49m[38;5;10m+     486[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     487[0m:[38;5;10m[49m             # CQL regularization term.
[0m[49m[38;5;10m+     488[0m:[38;5;10m[49m             # Push down Q-values for all actions (logsumexp), push up for data actions.
[0m[49m[38;5;10m+     489[0m:[38;5;10m[49m             all_q = policy(states)
[0m[49m[38;5;10m+     490[0m:[38;5;10m[49m             cql_penalty = (
[0m[49m[38;5;10m+     491[0m:[38;5;10m[49m                 torch.logsumexp(all_q, dim=1).mean()
[0m[49m[38;5;10m+     492[0m:[38;5;10m[49m                 - all_q.gather(1, actions.unsqueeze(1)).squeeze(1).mean()
[0m[49m[38;5;10m+     493[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+     494[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     495[0m:[38;5;10m[49m             # Combined loss.
[0m[49m[38;5;10m+     496[0m:[38;5;10m[49m             loss = bellman_loss + CQL_ALPHA * cql_penalty
[0m[49m[38;5;10m+     497[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     498[0m:[38;5;10m[49m             optimizer.zero_grad()
[0m[49m[38;5;10m+     499[0m:[38;5;10m[49m             loss.backward()
[0m[49m[38;5;10m+     500[0m:[38;5;10m[49m             optimizer.step()
[0m[49m[38;5;10m+     501[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     502[0m:[38;5;10m[49m             epoch_loss += loss.item()
[0m[49m[38;5;10m+     503[0m:[38;5;10m[49m             num_batches += 1
[0m[49m[38;5;10m+     504[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     505[0m:[38;5;10m[49m         # Update target network periodically (soft update).
[0m[49m[38;5;10m+     506[0m:[38;5;10m[49m         if (epoch + 1) % 5 == 0:
[0m[49m[38;5;10m+     507[0m:[38;5;10m[49m             for param, target_param in zip(policy.parameters(), target_network.parameters()):
[0m[49m[38;5;10m+     508[0m:[38;5;10m[49m                 target_param.data.copy_(0.95 * target_param.data + 0.05 * param.data)
[0m[49m[38;5;10m+     509[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     510[0m:[38;5;10m[49m         if (epoch + 1) % 20 == 0:
[0m[49m[38;5;10m+     511[0m:[38;5;10m[49m             avg_loss = epoch_loss / max(num_batches, 1)
[0m[49m[38;5;10m+     512[0m:[38;5;10m[49m             logger.info("  Epoch %d/%d, avg loss: %.4f", epoch + 1, num_epochs, avg_loss)
[0m[49m[38;5;10m+     513[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     514[0m:[38;5;10m[49m     return policy
[0m[49m[38;5;10m+     515[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     516[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     517[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     518[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     519[0m:[38;5;10m[49m ## Step 6: Generate Explanation for Clinician
[0m[49m[38;5;10m+     520[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     521[0m:[38;5;10m[49m *A recommendation without explanation is useless in radiation oncology. The physicist and oncologist need to understand why the system recommends replanning now rather than next week. This step identifies the key factors driving the recommendation.*
[0m[49m[38;5;10m+     522[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     523[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     524[0m:[38;5;10m[49m def generate_explanation(
[0m[49m[38;5;10m+     525[0m:[38;5;10m[49m     state: np.ndarray,
[0m[49m[38;5;10m+     526[0m:[38;5;10m[49m     policy: AdaptivePlanningQNetwork,
[0m[49m[38;5;10m+     527[0m:[38;5;10m[49m     action_index: int,
[0m[49m[38;5;10m+     528[0m:[38;5;10m[49m ) -> Dict:
[0m[49m[38;5;10m+     529[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     530[0m:[38;5;10m[49m     Generate a human-readable explanation of the recommendation.
[0m[49m[38;5;10m+     531[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     532[0m:[38;5;10m[49m     Uses perturbation-based feature importance: for each state feature,
[0m[49m[38;5;10m+     533[0m:[38;5;10m[49m     slightly change it and measure how much the Q-value changes. Features
[0m[49m[38;5;10m+     534[0m:[38;5;10m[49m     that cause large Q-value changes are the ones driving the decision.
[0m[49m[38;5;10m+     535[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     536[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     537[0m:[38;5;10m[49m         state: Current normalized state vector.
[0m[49m[38;5;10m+     538[0m:[38;5;10m[49m         policy: Trained Q-network.
[0m[49m[38;5;10m+     539[0m:[38;5;10m[49m         action_index: The recommended action index.
[0m[49m[38;5;10m+     540[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     541[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     542[0m:[38;5;10m[49m         Dictionary with primary factors and expected benefit.
[0m[49m[38;5;10m+     543[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     544[0m:[38;5;10m[49m     feature_names = [
[0m[49m[38;5;10m+     545[0m:[38;5;10m[49m         "fraction_progress", "fractions_remaining", "tumor_volume_ratio",
[0m[49m[38;5;10m+     546[0m:[38;5;10m[49m         "tumor_change_rate", "dose_progress", "spinal_cord_dose",
[0m[49m[38;5;10m+     547[0m:[38;5;10m[49m         "parotid_left_dose", "parotid_right_dose", "brainstem_dose",
[0m[49m[38;5;10m+     548[0m:[38;5;10m[49m         "optic_nerve_dose", "plan_conformity", "plan_homogeneity",
[0m[49m[38;5;10m+     549[0m:[38;5;10m[49m         "weight_change", "fractions_since_replan", "plan_age",
[0m[49m[38;5;10m+     550[0m:[38;5;10m[49m         "worst_oar_fraction", "dose_tracking", "tumor_response",
[0m[49m[38;5;10m+     551[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+     552[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     553[0m:[38;5;10m[49m     # Get baseline Q-value.
[0m[49m[38;5;10m+     554[0m:[38;5;10m[49m     with torch.no_grad():
[0m[49m[38;5;10m+     555[0m:[38;5;10m[49m         state_tensor = torch.FloatTensor(state).unsqueeze(0)
[0m[49m[38;5;10m+     556[0m:[38;5;10m[49m         baseline_q = policy(state_tensor).squeeze(0)[action_index].item()
[0m[49m[38;5;10m+     557[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     558[0m:[38;5;10m[49m     # Perturb each feature and measure Q-value change.
[0m[49m[38;5;10m+     559[0m:[38;5;10m[49m     importances = []
[0m[49m[38;5;10m+     560[0m:[38;5;10m[49m     for i, name in enumerate(feature_names):
[0m[49m[38;5;10m+     561[0m:[38;5;10m[49m         perturbed = state.copy()
[0m[49m[38;5;10m+     562[0m:[38;5;10m[49m         perturbed[i] = min(perturbed[i] + 0.1, 1.0)
[0m[49m[38;5;10m+     563[0m:[38;5;10m[49m         with torch.no_grad():
[0m[49m[38;5;10m+     564[0m:[38;5;10m[49m             perturbed_tensor = torch.FloatTensor(perturbed).unsqueeze(0)
[0m[49m[38;5;10m+     565[0m:[38;5;10m[49m             perturbed_q = policy(perturbed_tensor).squeeze(0)[action_index].item()
[0m[49m[38;5;10m+     566[0m:[38;5;10m[49m         importance = abs(perturbed_q - baseline_q)
[0m[49m[38;5;10m+     567[0m:[38;5;10m[49m         importances.append({"feature": name, "importance": round(importance, 4)})
[0m[49m[38;5;10m+     568[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     569[0m:[38;5;10m[49m     importances.sort(key=lambda x: x["importance"], reverse=True)
[0m[49m[38;5;10m+     570[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     571[0m:[38;5;10m[49m     # Translate top factors into clinical language.
[0m[49m[38;5;10m+     572[0m:[38;5;10m[49m     top_factors = []
[0m[49m[38;5;10m+     573[0m:[38;5;10m[49m     for factor in importances[:3]:
[0m[49m[38;5;10m+     574[0m:[38;5;10m[49m         feature_idx = feature_names.index(factor["feature"])
[0m[49m[38;5;10m+     575[0m:[38;5;10m[49m         value = state[feature_idx]
[0m[49m[38;5;10m+     576[0m:[38;5;10m[49m         top_factors.append(
[0m[49m[38;5;10m+     577[0m:[38;5;10m[49m             _translate_factor(factor["feature"], value, factor["importance"])
[0m[49m[38;5;10m+     578[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+     579[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     580[0m:[38;5;10m[49m     # Compute expected benefit of recommended action vs. "continue."
[0m[49m[38;5;10m+     581[0m:[38;5;10m[49m     with torch.no_grad():
[0m[49m[38;5;10m+     582[0m:[38;5;10m[49m         q_values = policy(state_tensor).squeeze(0)
[0m[49m[38;5;10m+     583[0m:[38;5;10m[49m         continue_q = q_values[0].item()  # action 0 = continue
[0m[49m[38;5;10m+     584[0m:[38;5;10m[49m         recommended_q = q_values[action_index].item()
[0m[49m[38;5;10m+     585[0m:[38;5;10m[49m         expected_benefit = recommended_q - continue_q
[0m[49m[38;5;10m+     586[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     587[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     588[0m:[38;5;10m[49m         "primary_factors": top_factors,
[0m[49m[38;5;10m+     589[0m:[38;5;10m[49m         "expected_benefit_over_continue": round(expected_benefit, 3),
[0m[49m[38;5;10m+     590[0m:[38;5;10m[49m         "top_feature_importances": importances[:5],
[0m[49m[38;5;10m+     591[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     592[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     593[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     594[0m:[38;5;10m[49m def _translate_factor(feature_name: str, value: float, importance: float) -> str:
[0m[49m[38;5;10m+     595[0m:[38;5;10m[49m     """Convert a feature name and value into a clinician-readable statement."""
[0m[49m[38;5;10m+     596[0m:[38;5;10m[49m     translations = {
[0m[49m[38;5;10m+     597[0m:[38;5;10m[49m         "tumor_volume_ratio": f"Tumor volume at {value*100:.0f}% of baseline",
[0m[49m[38;5;10m+     598[0m:[38;5;10m[49m         "parotid_left_dose": f"Left parotid at {value*100:.0f}% of tolerance",
[0m[49m[38;5;10m+     599[0m:[38;5;10m[49m         "parotid_right_dose": f"Right parotid at {value*100:.0f}% of tolerance",
[0m[49m[38;5;10m+     600[0m:[38;5;10m[49m         "spinal_cord_dose": f"Spinal cord at {value*100:.0f}% of tolerance",
[0m[49m[38;5;10m+     601[0m:[38;5;10m[49m         "brainstem_dose": f"Brainstem at {value*100:.0f}% of tolerance",
[0m[49m[38;5;10m+     602[0m:[38;5;10m[49m         "plan_age": f"Current plan is {value*TOTAL_FRACTIONS:.0f} fractions old",
[0m[49m[38;5;10m+     603[0m:[38;5;10m[49m         "fractions_since_replan": f"{value*TOTAL_FRACTIONS:.0f} fractions since last replan",
[0m[49m[38;5;10m+     604[0m:[38;5;10m[49m         "plan_conformity": f"Plan conformity index degraded to {value*2.0:.2f}",
[0m[49m[38;5;10m+     605[0m:[38;5;10m[49m         "dose_tracking": f"Dose delivery {'on track' if abs(value-0.5)<0.05 else 'off track'}",
[0m[49m[38;5;10m+     606[0m:[38;5;10m[49m         "worst_oar_fraction": f"Closest OAR at {value*100:.0f}% of tolerance",
[0m[49m[38;5;10m+     607[0m:[38;5;10m[49m         "weight_change": f"Patient weight change: {(value*20-10):.1f} kg from baseline",
[0m[49m[38;5;10m+     608[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     609[0m:[38;5;10m[49m     return translations.get(feature_name, f"{feature_name}: {value:.3f} (importance: {importance:.4f})")
[0m[49m[38;5;10m+     610[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     611[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     612[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     613[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     614[0m:[38;5;10m[49m ## Step 7: Generate Full Recommendation
[0m[49m[38;5;10m+     615[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     616[0m:[38;5;10m[49m *This assembles the policy query, safety check, and explanation into a complete recommendation package for the clinician dashboard.*
[0m[49m[38;5;10m+     617[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     618[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     619[0m:[38;5;10m[49m def generate_recommendation(
[0m[49m[38;5;10m+     620[0m:[38;5;10m[49m     patient_state: np.ndarray,
[0m[49m[38;5;10m+     621[0m:[38;5;10m[49m     policy: AdaptivePlanningQNetwork,
[0m[49m[38;5;10m+     622[0m:[38;5;10m[49m     patient_id: str,
[0m[49m[38;5;10m+     623[0m:[38;5;10m[49m     fraction_number: int,
[0m[49m[38;5;10m+     624[0m:[38;5;10m[49m ) -> Dict:
[0m[49m[38;5;10m+     625[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     626[0m:[38;5;10m[49m     Generate a complete adaptive planning recommendation.
[0m[49m[38;5;10m+     627[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     628[0m:[38;5;10m[49m     This is the function called before each treatment fraction. It:
[0m[49m[38;5;10m+     629[0m:[38;5;10m[49m     1. Queries the policy for the recommended action.
[0m[49m[38;5;10m+     630[0m:[38;5;10m[49m     2. Applies safety constraints (may override the policy).
[0m[49m[38;5;10m+     631[0m:[38;5;10m[49m     3. Generates an explanation of the recommendation.
[0m[49m[38;5;10m+     632[0m:[38;5;10m[49m     4. Packages everything for the clinician dashboard.
[0m[49m[38;5;10m+     633[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     634[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     635[0m:[38;5;10m[49m         patient_state: Normalized state vector (18 features).
[0m[49m[38;5;10m+     636[0m:[38;5;10m[49m         policy: Trained Q-network.
[0m[49m[38;5;10m+     637[0m:[38;5;10m[49m         patient_id: Patient identifier (for audit, never logged in detail).
[0m[49m[38;5;10m+     638[0m:[38;5;10m[49m         fraction_number: Current fraction number (1-35).
[0m[49m[38;5;10m+     639[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     640[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     641[0m:[38;5;10m[49m         Structured recommendation dictionary.
[0m[49m[38;5;10m+     642[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     643[0m:[38;5;10m[49m     # Get the policy's raw recommendation.
[0m[49m[38;5;10m+     644[0m:[38;5;10m[49m     action_index = policy.get_action(patient_state)
[0m[49m[38;5;10m+     645[0m:[38;5;10m[49m     recommended_action = ACTIONS[action_index]
[0m[49m[38;5;10m+     646[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     647[0m:[38;5;10m[49m     # Apply safety constraints (may override).
[0m[49m[38;5;10m+     648[0m:[38;5;10m[49m     safe_action, violations = check_safety_constraints(patient_state, recommended_action)
[0m[49m[38;5;10m+     649[0m:[38;5;10m[49m     safe_action_index = ACTIONS.index(safe_action)
[0m[49m[38;5;10m+     650[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     651[0m:[38;5;10m[49m     # Compute confidence for the safe action.
[0m[49m[38;5;10m+     652[0m:[38;5;10m[49m     confidence = policy.get_action_confidence(patient_state, safe_action_index)
[0m[49m[38;5;10m+     653[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     654[0m:[38;5;10m[49m     # If safety overrode the policy, set confidence to 0 (signals override to clinician).
[0m[49m[38;5;10m+     655[0m:[38;5;10m[49m     if safe_action != recommended_action:
[0m[49m[38;5;10m+     656[0m:[38;5;10m[49m         confidence = 0.0
[0m[49m[38;5;10m+     657[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     658[0m:[38;5;10m[49m     # Generate explanation.
[0m[49m[38;5;10m+     659[0m:[38;5;10m[49m     explanation = generate_explanation(patient_state, policy, safe_action_index)
[0m[49m[38;5;10m+     660[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     661[0m:[38;5;10m[49m     recommendation = {
[0m[49m[38;5;10m+     662[0m:[38;5;10m[49m         "recommendation_id": str(uuid.uuid4()),
[0m[49m[38;5;10m+     663[0m:[38;5;10m[49m         "timestamp": datetime.utcnow().isoformat() + "Z",
[0m[49m[38;5;10m+     664[0m:[38;5;10m[49m         "patient_id": patient_id,
[0m[49m[38;5;10m+     665[0m:[38;5;10m[49m         "fraction_number": fraction_number,
[0m[49m[38;5;10m+     666[0m:[38;5;10m[49m         "recommended_action": safe_action,
[0m[49m[38;5;10m+     667[0m:[38;5;10m[49m         "confidence": round(confidence, 3),
[0m[49m[38;5;10m+     668[0m:[38;5;10m[49m         "policy_original_action": recommended_action,
[0m[49m[38;5;10m+     669[0m:[38;5;10m[49m         "safety_overridden": safe_action != recommended_action,
[0m[49m[38;5;10m+     670[0m:[38;5;10m[49m         "safety_violations": violations,
[0m[49m[38;5;10m+     671[0m:[38;5;10m[49m         "explanation": explanation,
[0m[49m[38;5;10m+     672[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     673[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     674[0m:[38;5;10m[49m     return recommendation
[0m[49m[38;5;10m+     675[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     676[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     677[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     678[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     679[0m:[38;5;10m[49m ## Step 8: Store Recommendation in DynamoDB
[0m[49m[38;5;10m+     680[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     681[0m:[38;5;10m[49m *Every recommendation gets stored for audit trail and feedback loop purposes. This is essential for HIPAA compliance and for building the dataset that improves the policy over time.*
[0m[49m[38;5;10m+     682[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     683[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     684[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb", region_name=AWS_REGION, config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     685[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     686[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     687[0m:[38;5;10m[49m def store_recommendation(recommendation: Dict) -> None:
[0m[49m[38;5;10m+     688[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     689[0m:[38;5;10m[49m     Store a recommendation in DynamoDB for audit trail.
[0m[49m[38;5;10m+     690[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     691[0m:[38;5;10m[49m     Every recommendation is stored regardless of whether the clinician
[0m[49m[38;5;10m+     692[0m:[38;5;10m[49m     accepts it. This creates the feedback loop: we can later analyze
[0m[49m[38;5;10m+     693[0m:[38;5;10m[49m     which recommendations were followed and correlate with outcomes.
[0m[49m[38;5;10m+     694[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     695[0m:[38;5;10m[49m     DynamoDB gotcha: floats must be stored as Decimal. boto3 will
[0m[49m[38;5;10m+     696[0m:[38;5;10m[49m     raise TypeError on raw Python floats.
[0m[49m[38;5;10m+     697[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     698[0m:[38;5;10m[49m     table = dynamodb.Table(RECOMMENDATION_TABLE)
[0m[49m[38;5;10m+     699[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     700[0m:[38;5;10m[49m     item = {
[0m[49m[38;5;10m+     701[0m:[38;5;10m[49m         "recommendation_id": recommendation["recommendation_id"],
[0m[49m[38;5;10m+     702[0m:[38;5;10m[49m         "timestamp": recommendation["timestamp"],
[0m[49m[38;5;10m+     703[0m:[38;5;10m[49m         "patient_id": recommendation["patient_id"],
[0m[49m[38;5;10m+     704[0m:[38;5;10m[49m         "fraction_number": recommendation["fraction_number"],
[0m[49m[38;5;10m+     705[0m:[38;5;10m[49m         "recommended_action": recommendation["recommended_action"],
[0m[49m[38;5;10m+     706[0m:[38;5;10m[49m         "confidence": Decimal(str(recommendation["confidence"])),
[0m[49m[38;5;10m+     707[0m:[38;5;10m[49m         "safety_overridden": recommendation["safety_overridden"],
[0m[49m[38;5;10m+     708[0m:[38;5;10m[49m         "safety_violations": recommendation["safety_violations"],
[0m[49m[38;5;10m+     709[0m:[38;5;10m[49m         "policy_original_action": recommendation["policy_original_action"],
[0m[49m[38;5;10m+     710[0m:[38;5;10m[49m         "clinician_decision": "PENDING",  # Updated when clinician responds
[0m[49m[38;5;10m+     711[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     712[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     713[0m:[38;5;10m[49m     table.put_item(Item=item)
[0m[49m[38;5;10m+     714[0m:[38;5;10m[49m     logger.info("Stored recommendation %s for fraction %d",
[0m[49m[38;5;10m+     715[0m:[38;5;10m[49m                 recommendation["recommendation_id"], recommendation["fraction_number"])
[0m[49m[38;5;10m+     716[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     717[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     718[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     719[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     720[0m:[38;5;10m[49m ## Full Pipeline: Training and Inference Demo
[0m[49m[38;5;10m+     721[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     722[0m:[38;5;10m[49m *This assembles all the pieces into a runnable demonstration. It generates synthetic treatment trajectories (since we obviously can't use real patient data in an example), trains a CQL policy, and generates sample recommendations for a simulated patient mid-treatment.*
[0m[49m[38;5;10m+     723[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     724[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     725[0m:[38;5;10m[49m def simulate_tumor_dynamics(
[0m[49m[38;5;10m+     726[0m:[38;5;10m[49m     fraction: int,
[0m[49m[38;5;10m+     727[0m:[38;5;10m[49m     current_volume_ratio: float,
[0m[49m[38;5;10m+     728[0m:[38;5;10m[49m     dose_delivered: float,
[0m[49m[38;5;10m+     729[0m:[38;5;10m[49m     response_rate: float,
[0m[49m[38;5;10m+     730[0m:[38;5;10m[49m ) -> float:
[0m[49m[38;5;10m+     731[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     732[0m:[38;5;10m[49m     Simplified tumor response model.
[0m[49m[38;5;10m+     733[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     734[0m:[38;5;10m[49m     Real tumor dynamics follow the linear-quadratic model with repopulation.
[0m[49m[38;5;10m+     735[0m:[38;5;10m[49m     This is a gross simplification that captures the general shape:
[0m[49m[38;5;10m+     736[0m:[38;5;10m[49m     tumors shrink with dose, with patient-specific response rates,
[0m[49m[38;5;10m+     737[0m:[38;5;10m[49m     plus some stochastic variation.
[0m[49m[38;5;10m+     738[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     739[0m:[38;5;10m[49m     # Linear-quadratic inspired shrinkage (very simplified).
[0m[49m[38;5;10m+     740[0m:[38;5;10m[49m     kill_fraction = response_rate * (dose_delivered / TOTAL_PRESCRIBED_DOSE_GY)
[0m[49m[38;5;10m+     741[0m:[38;5;10m[49m     new_ratio = current_volume_ratio * (1.0 - kill_fraction * 0.02)
[0m[49m[38;5;10m+     742[0m:[38;5;10m[49m     # Add noise (biology is stochastic).
[0m[49m[38;5;10m+     743[0m:[38;5;10m[49m     new_ratio += np.random.normal(0, 0.005)
[0m[49m[38;5;10m+     744[0m:[38;5;10m[49m     return max(0.1, min(1.2, new_ratio))
[0m[49m[38;5;10m+     745[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     746[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     747[0m:[38;5;10m[49m def generate_synthetic_trajectories(
[0m[49m[38;5;10m+     748[0m:[38;5;10m[49m     num_patients: int = 300,
[0m[49m[38;5;10m+     749[0m:[38;5;10m[49m ) -> List[List[Dict]]:
[0m[49m[38;5;10m+     750[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     751[0m:[38;5;10m[49m     Generate synthetic radiation treatment trajectories for demonstration.
[0m[49m[38;5;10m+     752[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     753[0m:[38;5;10m[49m     Each trajectory represents one patient's full treatment course (35 fractions).
[0m[49m[38;5;10m+     754[0m:[38;5;10m[49m     We simulate: tumor shrinkage, OAR dose accumulation, plan degradation over time,
[0m[49m[38;5;10m+     755[0m:[38;5;10m[49m     and clinician replanning decisions (the behavior policy).
[0m[49m[38;5;10m+     756[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     757[0m:[38;5;10m[49m     This is NOT a validated radiobiological model. It produces data in the right
[0m[49m[38;5;10m+     758[0m:[38;5;10m[49m     shape for the RL algorithm to train on. Real data comes from treatment planning
[0m[49m[38;5;10m+     759[0m:[38;5;10m[49m     system exports and record-and-verify system logs.
[0m[49m[38;5;10m+     760[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     761[0m:[38;5;10m[49m     trajectories = []
[0m[49m[38;5;10m+     762[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     763[0m:[38;5;10m[49m     for patient_idx in range(num_patients):
[0m[49m[38;5;10m+     764[0m:[38;5;10m[49m         # Patient-specific parameters.
[0m[49m[38;5;10m+     765[0m:[38;5;10m[49m         response_rate = np.random.uniform(0.3, 0.9)  # How responsive is this tumor
[0m[49m[38;5;10m+     766[0m:[38;5;10m[49m         weight_loss_rate = np.random.uniform(0, 0.3)  # kg per fraction
[0m[49m[38;5;10m+     767[0m:[38;5;10m[49m         plan_degradation_rate = np.random.uniform(0.001, 0.01)  # How fast plan quality drops
[0m[49m[38;5;10m+     768[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     769[0m:[38;5;10m[49m         # Initial state.
[0m[49m[38;5;10m+     770[0m:[38;5;10m[49m         tumor_volume_ratio = 1.0
[0m[49m[38;5;10m+     771[0m:[38;5;10m[49m         cumulative_ptv_dose = 0.0
[0m[49m[38;5;10m+     772[0m:[38;5;10m[49m         cumulative_oar_doses = {
[0m[49m[38;5;10m+     773[0m:[38;5;10m[49m             "spinal_cord": 0.0, "parotid_left": 0.0, "parotid_right": 0.0,
[0m[49m[38;5;10m+     774[0m:[38;5;10m[49m             "brainstem": 0.0, "optic_nerve": 0.0,
[0m[49m[38;5;10m+     775[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+     776[0m:[38;5;10m[49m         weight_change = 0.0
[0m[49m[38;5;10m+     777[0m:[38;5;10m[49m         conformity = 1.0 + np.random.uniform(0, 0.1)
[0m[49m[38;5;10m+     778[0m:[38;5;10m[49m         homogeneity = np.random.uniform(0.05, 0.15)
[0m[49m[38;5;10m+     779[0m:[38;5;10m[49m         last_replan_fraction = 0
[0m[49m[38;5;10m+     780[0m:[38;5;10m[49m         plan_start_fraction = 0
[0m[49m[38;5;10m+     781[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     782[0m:[38;5;10m[49m         trajectory = []
[0m[49m[38;5;10m+     783[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     784[0m:[38;5;10m[49m         for fraction in range(1, TOTAL_FRACTIONS + 1):
[0m[49m[38;5;10m+     785[0m:[38;5;10m[49m             # Build current state.
[0m[49m[38;5;10m+     786[0m:[38;5;10m[49m             volume_change_rate = -response_rate * 0.01  # Simplified trend
[0m[49m[38;5;10m+     787[0m:[38;5;10m[49m             state = build_state_vector(
[0m[49m[38;5;10m+     788[0m:[38;5;10m[49m                 fraction_number=fraction,
[0m[49m[38;5;10m+     789[0m:[38;5;10m[49m                 tumor_volume_ratio=tumor_volume_ratio,
[0m[49m[38;5;10m+     790[0m:[38;5;10m[49m                 tumor_volume_change_rate=volume_change_rate,
[0m[49m[38;5;10m+     791[0m:[38;5;10m[49m                 cumulative_ptv_dose_gy=cumulative_ptv_dose,
[0m[49m[38;5;10m+     792[0m:[38;5;10m[49m                 cumulative_oar_doses=cumulative_oar_doses,
[0m[49m[38;5;10m+     793[0m:[38;5;10m[49m                 plan_conformity_index=conformity,
[0m[49m[38;5;10m+     794[0m:[38;5;10m[49m                 plan_homogeneity_index=homogeneity,
[0m[49m[38;5;10m+     795[0m:[38;5;10m[49m                 patient_weight_change_kg=weight_change,
[0m[49m[38;5;10m+     796[0m:[38;5;10m[49m                 fractions_since_replan=fraction - last_replan_fraction,
[0m[49m[38;5;10m+     797[0m:[38;5;10m[49m                 current_plan_age_fractions=fraction - plan_start_fraction,
[0m[49m[38;5;10m+     798[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+     799[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     800[0m:[38;5;10m[49m             # Simulate clinician behavior policy (what historically happened).
[0m[49m[38;5;10m+     801[0m:[38;5;10m[49m             # Clinicians replan at fixed intervals or when they notice problems.
[0m[49m[38;5;10m+     802[0m:[38;5;10m[49m             action = "continue"
[0m[49m[38;5;10m+     803[0m:[38;5;10m[49m             if fraction == 15 and np.random.random() < 0.4:
[0m[49m[38;5;10m+     804[0m:[38;5;10m[49m                 action = "replan"  # Some centers replan at fraction 15
[0m[49m[38;5;10m+     805[0m:[38;5;10m[49m             elif fraction == 25 and np.random.random() < 0.3:
[0m[49m[38;5;10m+     806[0m:[38;5;10m[49m                 action = "replan"  # Some replan again at fraction 25
[0m[49m[38;5;10m+     807[0m:[38;5;10m[49m             elif max(cumulative_oar_doses.values()) / max(OAR_TOLERANCES.values()) > 0.8:
[0m[49m[38;5;10m+     808[0m:[38;5;10m[49m                 if np.random.random() < 0.6:
[0m[49m[38;5;10m+     809[0m:[38;5;10m[49m                     action = "replan"  # Replan when OAR doses get high
[0m[49m[38;5;10m+     810[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     811[0m:[38;5;10m[49m             action_index = ACTIONS.index(action)
[0m[49m[38;5;10m+     812[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     813[0m:[38;5;10m[49m             # Simulate treatment delivery and response.
[0m[49m[38;5;10m+     814[0m:[38;5;10m[49m             fraction_dose = PRESCRIBED_DOSE_PER_FRACTION_GY
[0m[49m[38;5;10m+     815[0m:[38;5;10m[49m             cumulative_ptv_dose += fraction_dose
[0m[49m[38;5;10m+     816[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     817[0m:[38;5;10m[49m             # OAR doses accumulate (with some variation based on plan quality).
[0m[49m[38;5;10m+     818[0m:[38;5;10m[49m             for oar in cumulative_oar_doses:
[0m[49m[38;5;10m+     819[0m:[38;5;10m[49m                 # Each OAR gets a fraction of the target dose (depends on geometry).
[0m[49m[38;5;10m+     820[0m:[38;5;10m[49m                 oar_fraction_of_target = {
[0m[49m[38;5;10m+     821[0m:[38;5;10m[49m                     "spinal_cord": 0.55, "parotid_left": 0.35, "parotid_right": 0.30,
[0m[49m[38;5;10m+     822[0m:[38;5;10m[49m                     "brainstem": 0.40, "optic_nerve": 0.25,
[0m[49m[38;5;10m+     823[0m:[38;5;10m[49m                 }[oar]
[0m[49m[38;5;10m+     824[0m:[38;5;10m[49m                 oar_dose_this_fraction = fraction_dose * oar_fraction_of_target
[0m[49m[38;5;10m+     825[0m:[38;5;10m[49m                 # Plan degradation increases OAR dose over time.
[0m[49m[38;5;10m+     826[0m:[38;5;10m[49m                 degradation_factor = 1.0 + plan_degradation_rate * (fraction - plan_start_fraction)
[0m[49m[38;5;10m+     827[0m:[38;5;10m[49m                 cumulative_oar_doses[oar] += oar_dose_this_fraction * degradation_factor
[0m[49m[38;5;10m+     828[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     829[0m:[38;5;10m[49m             # Tumor responds.
[0m[49m[38;5;10m+     830[0m:[38;5;10m[49m             tumor_volume_ratio = simulate_tumor_dynamics(
[0m[49m[38;5;10m+     831[0m:[38;5;10m[49m                 fraction, tumor_volume_ratio, cumulative_ptv_dose, response_rate
[0m[49m[38;5;10m+     832[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+     833[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     834[0m:[38;5;10m[49m             # Plan quality degrades over time (anatomy shifts).
[0m[49m[38;5;10m+     835[0m:[38;5;10m[49m             conformity += plan_degradation_rate * np.random.uniform(0.5, 1.5)
[0m[49m[38;5;10m+     836[0m:[38;5;10m[49m             homogeneity += plan_degradation_rate * 0.5 * np.random.uniform(0.5, 1.5)
[0m[49m[38;5;10m+     837[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     838[0m:[38;5;10m[49m             # Weight loss.
[0m[49m[38;5;10m+     839[0m:[38;5;10m[49m             weight_change -= weight_loss_rate * np.random.uniform(0.5, 1.5)
[0m[49m[38;5;10m+     840[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     841[0m:[38;5;10m[49m             # If replanned, reset plan quality.
[0m[49m[38;5;10m+     842[0m:[38;5;10m[49m             if action == "replan":
[0m[49m[38;5;10m+     843[0m:[38;5;10m[49m                 conformity = 1.0 + np.random.uniform(0, 0.05)
[0m[49m[38;5;10m+     844[0m:[38;5;10m[49m                 homogeneity = np.random.uniform(0.05, 0.10)
[0m[49m[38;5;10m+     845[0m:[38;5;10m[49m                 last_replan_fraction = fraction
[0m[49m[38;5;10m+     846[0m:[38;5;10m[49m                 plan_start_fraction = fraction
[0m[49m[38;5;10m+     847[0m:[38;5;10m[49m                 # Replanning also reduces OAR dose rates going forward.
[0m[49m[38;5;10m+     848[0m:[38;5;10m[49m                 plan_degradation_rate *= 0.7
[0m[49m[38;5;10m+     849[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     850[0m:[38;5;10m[49m             # Build next state.
[0m[49m[38;5;10m+     851[0m:[38;5;10m[49m             next_state = build_state_vector(
[0m[49m[38;5;10m+     852[0m:[38;5;10m[49m                 fraction_number=min(fraction + 1, TOTAL_FRACTIONS),
[0m[49m[38;5;10m+     853[0m:[38;5;10m[49m                 tumor_volume_ratio=tumor_volume_ratio,
[0m[49m[38;5;10m+     854[0m:[38;5;10m[49m                 tumor_volume_change_rate=volume_change_rate,
[0m[49m[38;5;10m+     855[0m:[38;5;10m[49m                 cumulative_ptv_dose_gy=cumulative_ptv_dose,
[0m[49m[38;5;10m+     856[0m:[38;5;10m[49m                 cumulative_oar_doses=cumulative_oar_doses,
[0m[49m[38;5;10m+     857[0m:[38;5;10m[49m                 plan_conformity_index=conformity,
[0m[49m[38;5;10m+     858[0m:[38;5;10m[49m                 plan_homogeneity_index=homogeneity,
[0m[49m[38;5;10m+     859[0m:[38;5;10m[49m                 patient_weight_change_kg=weight_change,
[0m[49m[38;5;10m+     860[0m:[38;5;10m[49m                 fractions_since_replan=fraction - last_replan_fraction,
[0m[49m[38;5;10m+     861[0m:[38;5;10m[49m                 current_plan_age_fractions=fraction - plan_start_fraction,
[0m[49m[38;5;10m+     862[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+     863[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     864[0m:[38;5;10m[49m             # Compute reward.
[0m[49m[38;5;10m+     865[0m:[38;5;10m[49m             reward = compute_reward(state, action, next_state)
[0m[49m[38;5;10m+     866[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     867[0m:[38;5;10m[49m             trajectory.append({
[0m[49m[38;5;10m+     868[0m:[38;5;10m[49m                 "state": state,
[0m[49m[38;5;10m+     869[0m:[38;5;10m[49m                 "action_index": action_index,
[0m[49m[38;5;10m+     870[0m:[38;5;10m[49m                 "reward": reward,
[0m[49m[38;5;10m+     871[0m:[38;5;10m[49m                 "next_state": next_state,
[0m[49m[38;5;10m+     872[0m:[38;5;10m[49m                 "done": (fraction == TOTAL_FRACTIONS),
[0m[49m[38;5;10m+     873[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+     874[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     875[0m:[38;5;10m[49m         trajectories.append(trajectory)
[0m[49m[38;5;10m+     876[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     877[0m:[38;5;10m[49m     return trajectories
[0m[49m[38;5;10m+     878[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     879[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     880[0m:[38;5;10m[49m def run_demo():
[0m[49m[38;5;10m+     881[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     882[0m:[38;5;10m[49m     Full demonstration: generate data, train policy, produce recommendations.
[0m[49m[38;5;10m+     883[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     884[0m:[38;5;10m[49m     print("=" * 70)
[0m[49m[38;5;10m+     885[0m:[38;5;10m[49m     print("Radiation Therapy Adaptive Planning: CQL Training Demo")
[0m[49m[38;5;10m+     886[0m:[38;5;10m[49m     print("=" * 70)
[0m[49m[38;5;10m+     887[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     888[0m:[38;5;10m[49m     # Step 1: Generate synthetic training data.
[0m[49m[38;5;10m+     889[0m:[38;5;10m[49m     print("\n[1/3] Generating synthetic treatment trajectories...")
[0m[49m[38;5;10m+     890[0m:[38;5;10m[49m     trajectories = generate_synthetic_trajectories(num_patients=300)
[0m[49m[38;5;10m+     891[0m:[38;5;10m[49m     total_transitions = sum(len(t) for t in trajectories)
