[0m[49m[38;5;10m+      6[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      7[0m:[38;5;10m[49m ## Setup
[0m[49m[38;5;10m+      8[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      9[0m:[38;5;10m[49m You'll need the AWS SDK for Python and a few scientific computing libraries:
[0m[49m[38;5;10m+     10[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     11[0m:[38;5;10m[49m ```bash
[0m[49m[38;5;10m+     12[0m:[38;5;10m[49m pip install boto3 numpy scikit-learn
[0m[49m[38;5;10m+     13[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     14[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     15[0m:[38;5;10m[49m Your environment needs credentials configured (via environment variables, an instance profile, or `~/.aws/credentials`). The IAM role or user needs:
[0m[49m[38;5;10m+     16[0m:[38;5;10m[49m - `geo:SearchPlaceIndexForText` and `geo:BatchSearchPlaceIndexForText` (Amazon Location Service geocoding)
[0m[49m[38;5;10m+     17[0m:[38;5;10m[49m - `s3:GetObject` and `s3:PutObject` (reading address data, writing results)
[0m[49m[38;5;10m+     18[0m:[38;5;10m[49m - `dynamodb:PutItem` and `dynamodb:BatchWriteItem` (storing cluster assignments and metadata)
[0m[49m[38;5;10m+     19[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     20[0m:[38;5;10m[49m You'll also need an Amazon Location Service Place Index created in your account. The Place Index is the resource that actually performs geocoding. Create one in the console or via CLI with a data provider (Esri or HERE).
[0m[49m[38;5;10m+     21[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     22[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     23[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     24[0m:[38;5;10m[49m ## Config and Constants
[0m[49m[38;5;10m+     25[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     26[0m:[38;5;10m[49m These go at the top of your module. They're configuration, not logic. Readers should see the knobs before the functions that use them.
[0m[49m[38;5;10m+     27[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     28[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     29[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+     30[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+     31[0m:[38;5;10m[49m import datetime
[0m[49m[38;5;10m+     32[0m:[38;5;10m[49m from datetime import timezone
[0m[49m[38;5;10m+     33[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+     34[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     35[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+     36[0m:[38;5;10m[49m import numpy as np
[0m[49m[38;5;10m+     37[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+     38[0m:[38;5;10m[49m from sklearn.cluster import DBSCAN
[0m[49m[38;5;10m+     39[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     40[0m:[38;5;10m[49m # Structured logging. In production, use JSON-formatted output for
[0m[49m[38;5;10m+     41[0m:[38;5;10m[49m # CloudWatch Logs Insights queries. Never log patient addresses or coordinates.
[0m[49m[38;5;10m+     42[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+     43[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+     44[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     45[0m:[38;5;10m[49m # Retry config for AWS API calls. Adaptive mode uses exponential backoff
[0m[49m[38;5;10m+     46[0m:[38;5;10m[49m # with jitter, which handles burst throttling gracefully.
[0m[49m[38;5;10m+     47[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+     48[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     49[0m:[38;5;10m[49m # --- Geocoding Configuration ---
[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m # The name of your Amazon Location Service Place Index.
[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m # Create this in the AWS console or via CLI before running this code.
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m PLACE_INDEX_NAME = "patient-geocoding-index"
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m # Confidence threshold for geocoding results. Below this, the coordinate
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m # is too uncertain to trust for clustering. Route to manual review instead.
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m GEOCODE_CONFIDENCE_THRESHOLD = 0.85
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m # Batch size for Location Service. The API supports up to 50 addresses per call.
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m GEOCODE_BATCH_SIZE = 50
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m # --- Clustering Configuration ---
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m # DBSCAN epsilon: maximum distance (in km) between two points to be neighbors.
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m # 3 km is roughly "within a 5-minute drive in suburban areas."
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m # Smaller = tighter clusters, more noise. Larger = looser clusters.
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m EPSILON_KM = 3.0
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m # DBSCAN min_samples: minimum patients to form a cluster core.
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m # 100 means only areas with real population density become clusters.
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m MIN_SAMPLES = 100
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m # --- Service Area Bounding Box ---
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m # Define the geographic bounds of your service area.
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m # Points outside this box are excluded from clustering.
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m # This example uses a bounding box around the Cincinnati, OH metro area.
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m BOUNDING_BOX = {
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m     "min_lat": 38.8,
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m     "max_lat": 39.4,
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m     "min_lon": -84.9,
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m     "max_lon": -84.2,
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m # --- Storage Configuration ---
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m DYNAMODB_PATIENT_TABLE = "patient-clusters"
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m DYNAMODB_METADATA_TABLE = "cluster-metadata"
