[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m         center_lat, center_lon, weight = random.choices(
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m             density_centers, weights=[c[2] for c in density_centers]
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m         )[0]
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m         # Scatter around the center with Gaussian noise.
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m         # Standard deviation of ~0.02 degrees is roughly 2 km.
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m         lat = center_lat + random.gauss(0, 0.02)
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m         lon = center_lon + random.gauss(0, 0.025)
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m         # Generate a plausible age (skewed older for healthcare populations)
