[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m             "patient_id": f"PAT-{i:06d}",
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m             "address_line_1": f"{random.randint(100, 9999)} {random.choice(['Main', 'Oak', 'Elm', 'Park', 'Highland', 'River', 'Valley'])} {random.choice(['St', 'Ave', 'Dr', 'Rd', 'Blvd'])}",
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m             "city": random.choice(["Cincinnati", "Norwood", "Sharonville", "Loveland", "Florence"]),
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m             "state": random.choice(["OH", "OH", "OH", "OH", "KY"]),
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m             "zip_code": random.choice(["45202", "45203", "45206", "45219", "45220", "45241", "45140", "41042"]),
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m             "date_of_birth": date(2026 - age, random.randint(1, 12), random.randint(1, 28)).isoformat(),
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m             "primary_payer": random.choices(payers, weights=payer_weights)[0],
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m             "visit_count_12mo": max(0, int(random.gauss(4, 3))),
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m             "last_visit_date": date(2026, random.randint(1, 5), random.randint(1, 28)).isoformat(),
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m             # Pre-computed coordinates for the synthetic data.
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m             # In production, these come from the geocoding step (Step 2).
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m             "_synthetic_lat": lat,
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m             "_synthetic_lon": lon,
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m             "is_po_box": random.random() < 0.05,  # 5% PO Boxes
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m     return patients
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m ## Step 1: Extract and Prepare Address Data
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m *The pseudocode calls this `extract_patient_addresses(source_connection)`. It pulls patient records and applies basic quality filtering before geocoding.*
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m def extract_patient_addresses(patients: list[dict]) -> list[dict]:
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m     Apply basic quality filtering to patient records before geocoding.
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m     In production, this function would query your EHR or data warehouse.
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m     Here, it takes the synthetic data and filters out records that would
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m     waste geocoding API calls (missing addresses, known PO Boxes flagged
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m     for special handling).
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m         patients: Raw patient records from your source system.
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m         Cleaned records ready for geocoding. PO Boxes are flagged but retained.
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m     cleaned = []
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m     po_box_count = 0
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m     for record in patients:
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m         # Skip records with no address (can't geocode nothing)
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m         if not record.get("address_line_1"):
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m         # Standardize state abbreviation (already done in synthetic data,
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m         # but in production you'd handle "Ohio" -> "OH" here)
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m         record["state"] = record["state"].upper().strip()
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m         # Flag PO Boxes. They geocode to the post office, not the patient's home.
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m         if record.get("is_po_box"):
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m             po_box_count += 1
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m         cleaned.append(record)
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m         "Extracted %d records. %d PO Boxes flagged.", len(cleaned), po_box_count
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m     return cleaned
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m ## Step 2: Geocode Addresses to Coordinates
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m *The pseudocode calls this `geocode_addresses(records, place_index_name)`. It sends addresses to Amazon Location Service in batches and returns coordinates with confidence scores.*
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m # Create a Location Service client.
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m location_client = boto3.client("location", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m def geocode_addresses(records: list[dict]) -> tuple[list[dict], list[dict]]:
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m     Convert patient addresses to latitude/longitude coordinates using
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m     Amazon Location Service batch geocoding.
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m     Processes addresses in batches of 50 (the API limit). Each result
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m     includes a relevance score that we use as a confidence gate: low-relevance
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m     results get routed to a "failed" list rather than silently included
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m     with bad coordinates.
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m         records: Patient records with address fields populated.
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m         Tuple of (geocoded_records, failed_records).
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m         Geocoded records have latitude and longitude populated.
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m         Failed records have a failure reason attached.
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m     geocoded = []
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m     failed = []
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m     # Process in batches of GEOCODE_BATCH_SIZE
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m     for batch_start in range(0, len(records), GEOCODE_BATCH_SIZE):
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m         batch = records[batch_start : batch_start + GEOCODE_BATCH_SIZE]
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m         # Build the batch request. Each entry is a full address string.
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m         search_texts = []
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m         for record in batch:
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m             full_address = (
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m                 f"{record['address_line_1']}, "
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m                 f"{record['city']}, {record['state']} {record['zip_code']}"
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m             search_texts.append(full_address)
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m         # Call Amazon Location Service batch geocoding API.
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m         # Each text entry gets its own result in the response.
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m         response = location_client.search_place_index_for_suggestions(
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m             IndexName=PLACE_INDEX_NAME,
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m             Text=search_texts[0],  # Note: for true batch, use the loop below
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m         # In practice, you'd call SearchPlaceIndexForText per address or use
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m         # a batch pattern. Amazon Location Service doesn't have a native batch
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m         # geocode API as of early 2026, so you loop through individually or
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m         # use concurrent requests. Here's the per-address pattern:
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m         for record, address_text in zip(batch, search_texts):
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m             try:
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m                 geo_response = location_client.search_place_index_for_text(
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m                     IndexName=PLACE_INDEX_NAME,
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m                     Text=address_text,
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m                     MaxResults=1,
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m                 )
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m                 results = geo_response.get("Results", [])
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m                 if not results:
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m                     record["geocode_failure_reason"] = "no_results"
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m                     failed.append(record)
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m                     continue
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m                 # The first result is the best match.
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m                 place = results[0]["Place"]
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m                 relevance = results[0].get("Relevance", 0.0)
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m                 if relevance >= GEOCODE_CONFIDENCE_THRESHOLD:
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m                     # Coordinates are returned as [longitude, latitude] (GeoJSON order)
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m                     record["longitude"] = place["Geometry"]["Point"][0]
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m                     record["latitude"] = place["Geometry"]["Point"][1]
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m                     record["geocode_confidence"] = relevance
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m                     geocoded.append(record)
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m                 else:
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m                     record["geocode_confidence"] = relevance
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m                     record["geocode_failure_reason"] = "low_confidence"
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m                     failed.append(record)
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m             except Exception as e:
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m                 # In production: specific exception handling for throttling,
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m                 # service errors, and malformed addresses.
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m                 record["geocode_failure_reason"] = str(e)
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m                 failed.append(record)
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m         "Geocoded %d successfully. %d below confidence threshold or failed.",
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m         len(geocoded),
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m         len(failed),
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m     return geocoded, failed
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m def geocode_addresses_synthetic(records: list[dict]) -> tuple[list[dict], list[dict]]:
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m     Bypass version that uses pre-computed synthetic coordinates.
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m     Use this for local testing without making real API calls.
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m     In production, use geocode_addresses() above.
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m     geocoded = []
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m     failed = []
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m     for record in records:
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m         if "_synthetic_lat" in record and "_synthetic_lon" in record:
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m             record["latitude"] = record["_synthetic_lat"]
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m             record["longitude"] = record["_synthetic_lon"]
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m             record["geocode_confidence"] = 0.95
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m             geocoded.append(record)
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m             record["geocode_failure_reason"] = "no_synthetic_coords"
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m             failed.append(record)
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m         "Synthetic geocoding: %d success, %d failed.", len(geocoded), len(failed)
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m     return geocoded, failed
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m ## Step 3: Clean and Filter Coordinates
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m *The pseudocode calls this `clean_coordinates(geocoded_records, bounding_box)`. It removes invalid coordinates and points outside the service area.*
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m def clean_coordinates(
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m     geocoded_records: list[dict], bounding_box: dict
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m ) -> tuple[list[dict], list[dict]]:
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m     Filter geocoded records to remove invalid or out-of-bounds coordinates.
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m     Catches two common problems:
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m     1. Null Island (0, 0): geocoder returned a default instead of admitting failure.
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m     2. Out-of-bounds: patient address resolved to somewhere outside your service area
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m        (moved away, data entry error, or geocoder matched wrong city).
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m         geocoded_records: Records with latitude/longitude populated.
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m         bounding_box: Dict with min_lat, max_lat, min_lon, max_lon.
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m         Tuple of (cleaned, excluded) record lists.
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m     cleaned = []
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m     excluded = []
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m     for record in geocoded_records:
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m         lat = record["latitude"]
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m         lon = record["longitude"]
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m         # Check for null island (0, 0) which means geocoding silently failed
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m         if lat == 0 and lon == 0:
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m             record["exclusion_reason"] = "null_island"
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m             excluded.append(record)
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m         # Check bounding box
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m         if (
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m             lat < bounding_box["min_lat"]
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m             or lat > bounding_box["max_lat"]
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m             or lon < bounding_box["min_lon"]
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m             or lon > bounding_box["max_lon"]
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m         ):
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m             record["exclusion_reason"] = "outside_service_area"
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m             excluded.append(record)
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m         cleaned.append(record)
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m         "Retained %d points. Excluded %d (null island or out of bounds).",
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m         len(cleaned),
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m         len(excluded),
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m     return cleaned, excluded
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m ## Step 4: Run the Clustering Algorithm
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m *The pseudocode calls this `cluster_patients(cleaned_records)`. This is the core analytical step: DBSCAN with Haversine distance on the cleaned coordinates.*
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m def cluster_patients(cleaned_records: list[dict]) -> tuple[list[dict], int]:
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m     Run DBSCAN clustering on patient coordinates using Haversine distance.
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m     DBSCAN finds clusters of arbitrary shape without requiring you to
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m     pre-specify the number of clusters. It uses two parameters:
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m     - epsilon: max distance between neighbors (converted to radians for Haversine)
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m     - min_samples: minimum points to form a dense region
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m     Points that don't belong to any cluster get label -1 ("noise").
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m     These are isolated patients in low-density areas.
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m         cleaned_records: Records with valid latitude/longitude.
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m         Tuple of (records_with_cluster_ids, num_clusters).
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m         Each record gets a cluster_id field (-1 for noise).
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m     # Extract coordinates as a numpy array.
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m     # DBSCAN with haversine metric expects [latitude, longitude] in RADIANS.
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m     coordinates = np.array(
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m         [[record["latitude"], record["longitude"]] for record in cleaned_records]
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m     coordinates_radians = np.radians(coordinates)
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m     # Convert epsilon from km to radians.
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m     # Earth's mean radius is approximately 6371 km.
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m     epsilon_radians = EPSILON_KM / 6371.0
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m     # Run DBSCAN.
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m     # metric="haversine" computes great-circle distance (accounts for Earth's curvature).
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m     # This is critical for geographic data. Euclidean distance would distort
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m     # at higher latitudes because longitude degrees shrink toward the poles.
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m     clustering = DBSCAN(
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m         eps=epsilon_radians,
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m         min_samples=MIN_SAMPLES,
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m         metric="haversine",
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m         algorithm="ball_tree",  # required for haversine metric
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m     labels = clustering.fit_predict(coordinates_radians)
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m     # Assign cluster labels back to records.
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m     for record, label in zip(cleaned_records, labels):
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m         record["cluster_id"] = int(label)
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m     # Count results
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m     unique_labels = set(labels)
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m     num_clusters = len(unique_labels) - (1 if -1 in unique_labels else 0)
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m     noise_count = int(np.sum(labels == -1))
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m         "Found %d clusters. %d noise points (%.1f%%).",
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m         num_clusters,
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m         noise_count,
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m         100.0 * noise_count / len(labels) if labels.size > 0 else 0,
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m     return cleaned_records, num_clusters
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m ## Step 5: Enrich Clusters with Metadata
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m *The pseudocode calls this `enrich_clusters(clustered_records, num_clusters)`. It computes summary statistics for each cluster to make them actionable.*
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m def enrich_clusters(
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m     clustered_records: list[dict], num_clusters: int
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m ) -> dict[int, dict]:
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m     Compute summary statistics for each cluster.
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m     A cluster is just a set of coordinates until you attach meaning.
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m     This step computes: centroid, patient count, demographic breakdown,
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m     utilization patterns, and geographic spread. These enrichments transform
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m     "there's a dense area here" into actionable intelligence for strategy teams.
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m         clustered_records: Records with cluster_id assigned.
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m         num_clusters: Number of clusters found (excluding noise).
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m         Dict mapping cluster_id to metadata dict.
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m     from collections import Counter
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m     cluster_metadata = {}
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m     for cluster_id in range(num_clusters):
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m         # Get all patients in this cluster
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m         members = [r for r in clustered_records if r["cluster_id"] == cluster_id]
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m         if not members:
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m         # Geographic centroid (average lat/lon)
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m         lats = [m["latitude"] for m in members]
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m         lons = [m["longitude"] for m in members]
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m         centroid_lat = sum(lats) / len(lats)
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m         centroid_lon = sum(lons) / len(lons)
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m         # Geographic spread: max distance from centroid to any member (in km)
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m         max_distance_km = 0.0
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m         for m in members:
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m             # Haversine distance from centroid
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m             dlat = np.radians(m["latitude"] - centroid_lat)
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m             dlon = np.radians(m["longitude"] - centroid_lon)
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m             a = (
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m                 np.sin(dlat / 2) ** 2
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m                 + np.cos(np.radians(centroid_lat))
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m                 * np.cos(np.radians(m["latitude"]))
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m                 * np.sin(dlon / 2) ** 2
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m             dist_km = 6371.0 * 2 * np.arctan2(np.sqrt(a), np.sqrt(1 - a))
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m             max_distance_km = max(max_distance_km, dist_km)
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m         # Demographics
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m         ages = []
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m         for m in members:
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m             try:
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m                 birth_year = int(m["date_of_birth"][:4])
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m                 ages.append(2026 - birth_year)
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m             except (ValueError, TypeError):
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m                 pass
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m         avg_age = sum(ages) / len(ages) if ages else 0
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m         # Payer mix
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m         payer_counts = Counter(m["primary_payer"] for m in members)
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m         total = len(members)
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m         payer_mix = {payer: round(count / total, 2) for payer, count in payer_counts.items()}
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m         # Utilization
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m         visits = [m.get("visit_count_12mo", 0) for m in members]
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m         avg_visits = sum(visits) / len(visits) if visits else 0
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m         pct_disengaged = sum(1 for v in visits if v == 0) / len(visits) if visits else 0
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m         # Top ZIP codes
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m         zip_counts = Counter(m["zip_code"] for m in members)
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m         top_zips = [z for z, _ in zip_counts.most_common(5)]
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m         cluster_metadata[cluster_id] = {
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m             "cluster_id": cluster_id,
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m             "patient_count": len(members),
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m             "centroid": {"latitude": round(centroid_lat, 4), "longitude": round(centroid_lon, 4)},
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m             "radius_km": round(max_distance_km, 2),
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m             "avg_age": round(avg_age, 1),
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m             "payer_mix": payer_mix,
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m             "avg_visits_12mo": round(avg_visits, 1),
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m             "pct_disengaged": round(pct_disengaged, 2),
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m             "top_zip_codes": top_zips,
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m     return cluster_metadata
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m ## Step 6: Store Results
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m *The pseudocode calls this `store_results(clustered_records, cluster_metadata)`. It writes per-patient cluster assignments and cluster-level metadata to DynamoDB.*
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m s3_client = boto3.client("s3", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m def store_results(clustered_records: list[dict], cluster_metadata: dict) -> None:
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m     Persist cluster assignments and metadata to DynamoDB and S3.
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m     Two storage targets serve different access patterns:
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m     - DynamoDB: fast point lookups ("which cluster is patient X in?")
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m     - S3 (JSON): bulk analytical queries via Athena, archival
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m         clustered_records: Records with cluster_id assigned.
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m         cluster_metadata: Enriched metadata per cluster.
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m     patient_table = dynamodb.Table(DYNAMODB_PATIENT_TABLE)
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m     metadata_table = dynamodb.Table(DYNAMODB_METADATA_TABLE)
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m     timestamp = datetime.datetime.now(timezone.utc).isoformat()
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m     # Write per-patient cluster assignments to DynamoDB.
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m     # Using batch_writer for efficiency (batches of 25 automatically).
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m     with patient_table.batch_writer() as batch:
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m         for record in clustered_records:
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m             batch.put_item(
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m                 Item={
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m                     "patient_id": record["patient_id"],
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m                     "cluster_id": record["cluster_id"],
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m                     # DynamoDB requires Decimal for numbers, not float.
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m                     "latitude": Decimal(str(round(record["latitude"], 6))),
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m                     "longitude": Decimal(str(round(record["longitude"], 6))),
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m                     "computed_at": timestamp,
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m                 }
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m     # Write cluster metadata to DynamoDB.
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m     for cluster_id, metadata in cluster_metadata.items():
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m         # Convert all floats to Decimal for DynamoDB compatibility.
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m         item = {
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m             "cluster_id": cluster_id,
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m             "patient_count": metadata["patient_count"],
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m             "centroid_lat": Decimal(str(metadata["centroid"]["latitude"])),
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m             "centroid_lon": Decimal(str(metadata["centroid"]["longitude"])),
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m             "radius_km": Decimal(str(metadata["radius_km"])),
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m             "avg_age": Decimal(str(metadata["avg_age"])),
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m             "avg_visits_12mo": Decimal(str(metadata["avg_visits_12mo"])),
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m             "pct_disengaged": Decimal(str(metadata["pct_disengaged"])),
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m             "top_zip_codes": metadata["top_zip_codes"],
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m             "payer_mix": json.dumps(metadata["payer_mix"]),
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m             "computed_at": timestamp,
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m         metadata_table.put_item(Item=item)
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m     # Also write full results to S3 as JSON for Athena queries.
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m     date_prefix = datetime.date.today().isoformat()
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m     s3_client.put_object(
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m         Bucket=S3_RESULTS_BUCKET,
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m         Key=f"cluster-results/{date_prefix}/cluster-summaries.json",
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m         Body=json.dumps(cluster_metadata, indent=2, default=str),
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m         ContentType="application/json",
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m         ServerSideEncryption="aws:kms",
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m         "Stored %d patient assignments and %d cluster summaries.",
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m         len(clustered_records),
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m         len(cluster_metadata),
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m ## Putting It All Together
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m Here's the full pipeline assembled into a single function. This is what your Lambda handler or SageMaker Processing Job would call.
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m def run_geographic_clustering_pipeline(use_synthetic: bool = True) -> dict:
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m     Run the full geographic patient clustering pipeline.
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m         use_synthetic: If True, use synthetic data and skip real API calls.
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m                        Set to False when running against real data with
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m                        Location Service configured.
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m         Dict with cluster metadata and summary statistics.
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m     # Generate or load patient data
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m     logger.info("Step 1: Extracting patient addresses")
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m     if use_synthetic:
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m         raw_patients = generate_synthetic_patients(num_patients=2000)
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m         # In production: query your EHR/enrollment database here
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m         raise NotImplementedError("Replace with your data source query")
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m     cleaned_patients = extract_patient_addresses(raw_patients)
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m     logger.info("  %d records after quality filtering", len(cleaned_patients))
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m     # Geocode addresses to coordinates
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m     logger.info("Step 2: Geocoding addresses")
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m     if use_synthetic:
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m         geocoded, failed = geocode_addresses_synthetic(cleaned_patients)
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m         geocoded, failed = geocode_addresses(cleaned_patients)
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m     logger.info("  %d geocoded, %d failed", len(geocoded), len(failed))
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m     # Clean and filter coordinates
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m     logger.info("Step 3: Cleaning coordinates")
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m     cleaned, excluded = clean_coordinates(geocoded, BOUNDING_BOX)
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m     logger.info("  %d retained, %d excluded", len(cleaned), len(excluded))
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m     # Run DBSCAN clustering
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m     logger.info("Step 4: Running DBSCAN clustering")
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m     clustered, num_clusters = cluster_patients(cleaned)
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m     logger.info("  Found %d clusters", num_clusters)
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m     # Enrich clusters with metadata
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m     logger.info("Step 5: Enriching clusters with metadata")
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m     metadata = enrich_clusters(clustered, num_clusters)
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m     for cid, meta in metadata.items():
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m         logger.info(
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m             "  Cluster %d: %d patients, radius %.1f km, avg age %.0f",
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m             cid,
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m             meta["patient_count"],
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m             meta["radius_km"],
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m             meta["avg_age"],
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m     # Store results (skip in synthetic mode to avoid needing real AWS resources)
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m     if not use_synthetic:
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m         logger.info("Step 6: Storing results")
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m         store_results(clustered, metadata)
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m         logger.info("Step 6: Skipping storage (synthetic mode)")
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m     # Summary
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m     total_clustered = sum(1 for r in clustered if r["cluster_id"] != -1)
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m     total_noise = sum(1 for r in clustered if r["cluster_id"] == -1)
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m     summary = {
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m         "total_patients_processed": len(cleaned),
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m         "num_clusters": num_clusters,
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m         "patients_in_clusters": total_clustered,
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m         "noise_points": total_noise,
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m         "noise_percentage": round(100.0 * total_noise / len(cleaned), 1) if cleaned else 0,
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m         "cluster_metadata": metadata,
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m     return summary
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m # Run the pipeline with synthetic data
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m if __name__ == "__main__":
[0m[49m[38;5;10m+    717[0m:[38;5;10m[49m     logging.basicConfig(level=logging.INFO, format="%(levelname)s: %(message)s")
[0m[49m[38;5;10m+    718[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    719[0m:[38;5;10m[49m     results = run_geographic_clustering_pipeline(use_synthetic=True)
[0m[49m[38;5;10m+    720[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m     print("\n" + "=" * 60)
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m     print("GEOGRAPHIC PATIENT CLUSTERING RESULTS")
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m     print(f"Total patients processed: {results['total_patients_processed']}")
[0m[49m[38;5;10m+    725[0m:[38;5;10m[49m     print(f"Clusters found: {results['num_clusters']}")
[0m[49m[38;5;10m+    726[0m:[38;5;10m[49m     print(f"Patients in clusters: {results['patients_in_clusters']}")
[0m[49m[38;5;10m+    727[0m:[38;5;10m[49m     print(f"Noise points: {results['noise_points']} ({results['noise_percentage']}%)")
[0m[49m[38;5;10m+    728[0m:[38;5;10m[49m     print("\nCluster Details:")
[0m[49m[38;5;10m+    729[0m:[38;5;10m[49m     print("-" * 60)
