[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m ## Synthetic Data Generation
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m Since we can't use real patient data in examples (PHI, obviously), here's a function that generates realistic-looking patient records with addresses scattered around a metro area. In production, you'd pull this from your EHR extract or enrollment file.
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m import random
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m from datetime import date
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m def generate_synthetic_patients(num_patients: int = 1000) -> list[dict]:
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m     Generate synthetic patient records with addresses in the Cincinnati metro area.
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m     This creates fake but realistic-looking data for testing the pipeline.
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m     The addresses are fictional. The geographic distribution mimics real
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m     population patterns: denser in the urban core, sparser in the suburbs.
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m     In production, this function is replaced by a query against your EHR or
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m     enrollment database. The output schema should match what's shown here.
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m     # Cluster centers representing population density hotspots.
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m     # Real populations aren't uniformly distributed; they clump around
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m     # town centers, transit hubs, and commercial areas.
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m     density_centers = [
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m         (39.10, -84.51, 0.30),   # downtown Cincinnati (high density)
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m         (39.16, -84.46, 0.20),   # Norwood/Xavier area
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m         (39.05, -84.67, 0.15),   # western suburbs
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m         (39.25, -84.55, 0.10),   # northern suburbs (Sharonville)
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m         (38.95, -84.35, 0.10),   # eastern Kentucky side
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m         (39.20, -84.37, 0.08),   # Loveland/Milford area
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m         (39.07, -84.32, 0.07),   # far east (sparse)
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m     payers = ["Medicare", "Commercial", "Medicaid", "Self-Pay"]
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m     payer_weights = [0.30, 0.45, 0.18, 0.07]
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m     patients = []
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m     for i in range(num_patients):
