[0m[49m[38;5;10m+    731[0m:[38;5;10m[49m     for cid, meta in results["cluster_metadata"].items():
[0m[49m[38;5;10m+    732[0m:[38;5;10m[49m         print(f"\n  Cluster {cid}:")
[0m[49m[38;5;10m+    733[0m:[38;5;10m[49m         print(f"    Patients: {meta['patient_count']}")
[0m[49m[38;5;10m+    734[0m:[38;5;10m[49m         print(f"    Centroid: ({meta['centroid']['latitude']}, {meta['centroid']['longitude']})")
[0m[49m[38;5;10m+    735[0m:[38;5;10m[49m         print(f"    Radius: {meta['radius_km']} km")
[0m[49m[38;5;10m+    736[0m:[38;5;10m[49m         print(f"    Avg Age: {meta['avg_age']}")
[0m[49m[38;5;10m+    737[0m:[38;5;10m[49m         print(f"    Avg Visits (12mo): {meta['avg_visits_12mo']}")
[0m[49m[38;5;10m+    738[0m:[38;5;10m[49m         print(f"    Disengaged: {meta['pct_disengaged'] * 100:.0f}%")
[0m[49m[38;5;10m+    739[0m:[38;5;10m[49m         print(f"    Top ZIPs: {meta['top_zip_codes']}")
