[0m[49m[39m  190, 195[0m:[39m[49m 
[0m[49m[39m  191, 196[0m:[39m[49m ### Code
[0m[49m[39m  192, 197[0m:[39m[49m 
[0m[49m[39m  193, 198[0m:[39m[49m #### Walkthrough
[0m[49m[39m  194, 199[0m:[39m[49m 
[0m[49m[39m  195, 200[0m:[39m[49m **Step 1: Parse formulary file into graph statements.** When a new formulary file lands in S3, the parser reads it and transforms each row into graph vertices (drugs, classes, plans) and edges (tier assignments, class memberships, restrictions). CMS formulary files have a defined column layout: NDC or RxNorm code, drug name, dosage form, tier level, restriction codes, therapeutic class, and alternatives. The parser maps these columns to graph entities and relationships. This step is where you handle data quality issues: missing codes, deprecated NDCs, and inconsistent class assignments. Skip this step and you have a flat file that can only answer "what tier is drug X?" but not "what are the alternatives?"
[0m[49m[39m  196, 201[0m:[39m[49m 
[0m[49m[39m  197, 202[0m:[39m[49m ```
[0m[49m[39m  198, 203[0m:[39m[49m FUNCTION parse_formulary_file(bucket, key):
[0m[49m[39m  199, 204[0m:[39m[49m     // Read the raw formulary file from storage.
[0m[49m[39m  200, 205[0m:[39m[49m     // CMS Part D files are pipe-delimited text with a header row.
[0m[49m[39m  201, 206[0m:[39m[49m     raw_data = read file from S3 at bucket/key
[0m[49m[39m  202, 207[0m:[39m[49m     
[0m[49m[39m  203, 208[0m:[39m[49m     // Parse into rows. Each row represents one drug-plan-tier combination.
[0m[49m[39m  204, 209[0m:[39m[49m     rows = parse_delimited(raw_data, delimiter="|", has_header=true)
[0m[49m[39m  205, 210[0m:[39m[49m     
[0m[49m[39m  206, 211[0m:[39m[49m     // Accumulators for graph entities
[0m[49m[39m  207, 212[0m:[39m[49m     vertices = empty list   // nodes to create or update
[0m[49m[39m  208, 213[0m:[39m[49m     edges = empty list      // relationships to create or update
[0m[49m[39m  209, 214[0m:[39m[49m     
[0m[49m[39m  210, 215[0m:[39m[49m     FOR each row in rows:
[0m[49m[39m  211, 216[0m:[39m[49m         // Create or update the Drug vertex
[0m[49m[39m  212, 217[0m:[39m[49m         drug_id = row["RXNORM_CUI"] or row["NDC"]
[0m[49m[39m  213, 218[0m:[39m[49m         append to vertices: {
[0m[49m[39m  214, 219[0m:[39m[49m             id: drug_id,
[0m[49m[39m  215, 220[0m:[39m[49m             label: "Drug",
[0m[49m[39m  216, 221[0m:[39m[49m             properties: {
[0m[49m[39m  217, 222[0m:[39m[49m                 name: row["DRUG_NAME"],
[0m[49m[39m  218, 223[0m:[39m[49m                 dosage_form: row["DOSAGE_FORM"],
[0m[49m[39m  219, 224[0m:[39m[49m                 strength: row["STRENGTH"],
[0m[49m[39m  220, 225[0m:[39m[49m                 rxnorm_cui: row["RXNORM_CUI"]
[0m[49m[39m  221, 226[0m:[39m[49m             }
[0m[49m[39m  222, 227[0m:[39m[49m         }
[0m[49m[39m  223, 228[0m:[39m[49m         
[0m[49m[39m  224, 229[0m:[39m[49m         // Create the TherapeuticClass vertex (if not already seen)
[0m[49m[39m  225, 230[0m:[39m[49m         class_id = row["THERAPEUTIC_CLASS_CODE"]
[0m[49m[39m  226, 231[0m:[39m[49m         append to vertices: {
[0m[49m[39m  227, 232[0m:[39m[49m             id: class_id,
[0m[49m[39m  228, 233[0m:[39m[49m             label: "TherapeuticClass",
[0m[49m[39m  229, 234[0m:[39m[49m             properties: {
[0m[49m[39m  230, 235[0m:[39m[49m                 name: row["THERAPEUTIC_CLASS_NAME"],
[0m[49m[39m  231, 236[0m:[39m[49m                 classification_system: "AHFS"  // or USP, depending on plan
[0m[49m[39m  232, 237[0m:[39m[49m             }
[0m[49m[39m  233, 238[0m:[39m[49m         }
[0m[49m[39m  234, 239[0m:[39m[49m         
[0m[49m[39m  235, 240[0m:[39m[49m         // Edge: Drug belongs to TherapeuticClass
[0m[49m[39m  236, 241[0m:[39m[49m         append to edges: {
[0m[49m[39m  237, 242[0m:[39m[49m             from: drug_id,
[0m[49m[39m  238, 243[0m:[39m[49m             to: class_id,
[0m[49m[39m  239, 244[0m:[39m[49m             type: "BELONGS_TO_CLASS",
[0m[49m[39m  240, 245[0m:[39m[49m             properties: { effective_date: row["EFFECTIVE_DATE"] }
[0m[49m[39m  241, 246[0m:[39m[49m         }
[0m[49m[39m  242, 247[0m:[39m[49m         
[0m[49m[39m  243, 248[0m:[39m[49m         // Edge: Drug has tier assignment under this plan
[0m[49m[39m  244, 249[0m:[39m[49m         append to edges: {
[0m[49m[39m  245, 250[0m:[39m[49m             from: drug_id,
[0m[49m[39m  246, 251[0m:[39m[49m             to: row["PLAN_ID"],
[0m[49m[39m  247, 252[0m:[39m[49m             type: "COVERED_UNDER",
[0m[49m[39m  248, 253[0m:[39m[49m             properties: {
[0m[49m[39m  249, 254[0m:[39m[49m                 tier: row["TIER_LEVEL"],
[0m[49m[39m  250, 255[0m:[39m[49m                 effective_date: row["EFFECTIVE_DATE"],
[0m[49m[39m  251, 256[0m:[39m[49m                 termination_date: row["TERMINATION_DATE"]
[0m[49m[39m  252, 257[0m:[39m[49m             }
[0m[49m[39m  253, 258[0m:[39m[49m         }
[0m[49m[39m  254, 259[0m:[39m[49m         
[0m[49m[39m  255, 260[0m:[39m[49m         // If restriction codes present, create restriction edges
[0m[49m[39m  256, 261[0m:[39m[49m         IF row["PRIOR_AUTH_FLAG"] == "Y":
[0m[49m[39m  257, 262[0m:[39m[49m             append to edges: {
[0m[49m[39m  258, 263[0m:[39m[49m                 from: drug_id,
[0m[49m[39m  259, 264[0m:[39m[49m                 to: "PA_" + row["PLAN_ID"] + "_" + drug_id,
[0m[49m[39m  260, 265[0m:[39m[49m                 type: "HAS_RESTRICTION",
[0m[49m[39m  261, 266[0m:[39m[49m                 properties: { restriction_type: "PRIOR_AUTH", plan_id: row["PLAN_ID"] }
[0m[49m[39m  262, 267[0m:[39m[49m             }
[0m[49m[39m  263, 268[0m:[39m[49m         
[0m[49m[39m  264, 269[0m:[39m[49m         IF row["STEP_THERAPY_FLAG"] == "Y":
[0m[49m[39m  265, 270[0m:[39m[49m             append to edges: {
[0m[49m[39m  266, 271[0m:[39m[49m                 from: drug_id,
[0m[49m[39m  267, 272[0m:[39m[49m                 to: "ST_" + row["PLAN_ID"] + "_" + drug_id,
[0m[49m[39m  268, 273[0m:[39m[49m                 type: "HAS_RESTRICTION",
[0m[49m[39m  269, 274[0m:[39m[49m                 properties: { restriction_type: "STEP_THERAPY", plan_id: row["PLAN_ID"] }
[0m[49m[39m  270, 275[0m:[39m[49m             }
[0m[49m[39m  271, 276[0m:[39m[49m         
[0m[49m[39m  272, 277[0m:[39m[49m         // If alternatives are listed, create therapeutic alternative edges
[0m[49m[39m  273, 278[0m:[39m[49m         IF row["ALTERNATIVE_DRUGS"] is not empty:
[0m[49m[39m  274, 279[0m:[39m[49m             FOR each alt_drug_id in split(row["ALTERNATIVE_DRUGS"], ","):
[0m[49m[39m  275, 280[0m:[39m[49m                 append to edges: {
[0m[49m[39m  276, 281[0m:[39m[49m                     from: drug_id,
[0m[49m[39m  277, 282[0m:[39m[49m                     to: trim(alt_drug_id),
[0m[49m[39m  278, 283[0m:[39m[49m                     type: "THERAPEUTIC_ALTERNATIVE",
[0m[49m[39m  279, 284[0m:[39m[49m                     properties: { plan_id: row["PLAN_ID"], source: "formulary_file" }
[0m[49m[39m  280, 285[0m:[39m[49m                 }
[0m[49m[39m  281, 286[0m:[39m[49m     
[0m[49m[39m  282, 287[0m:[39m[49m     RETURN vertices, edges
[0m[49m[39m  283, 288[0m:[39m[49m ```
[0m[49m[39m  284, 289[0m:[39m[49m 
[0m[49m[38;5;10m+      290[0m:[38;5;10m[49m <!-- TODO (TechWriter): Expert review A1 (HIGH). Add error handling guidance for the ingest pipeline: SQS dead letter queue on the S3 event notification or Lambda async invocation config, CloudWatch alarm on DLQ messages, and note that for production the Step Functions orchestration (already mentioned as optional) should be considered mandatory for retry logic and execution history. Mention idempotency: MERGE operations prevent duplicates, but partial loads could leave the graph inconsistent without transaction boundaries. -->
[0m[49m[38;5;10m+      291[0m:[38;5;10m[49m 
[0m[49m[39m  285, 292[0m:[39m[49m **Step 2: Load graph data into Neptune.** Take the parsed vertices and edges and load them into the graph database. Neptune supports bulk loading via its loader API (for initial loads) and individual upserts via openCypher MERGE statements (for incremental updates). The key decision: on a quarterly full formulary refresh, do you drop and rebuild, or do you merge? Merging preserves any enrichment you've added (like manually curated alternative relationships), but it's slower and risks stale data if a drug is removed from the formulary. The pragmatic approach: use a versioned subgraph per formulary effective date, and point queries at the current version. Skip this step and your parsed data sits in Lambda's memory doing nothing.
[0m[49m[39m  286, 293[0m:[39m[49m 
[0m[49m[39m  287, 294[0m:[39m[49m ```
[0m[49m[39m  288, 295[0m:[39m[49m FUNCTION load_graph(vertices, edges, neptune_endpoint):
[0m[49m[39m  289, 296[0m:[39m[49m     // For bulk initial load, use Neptune's bulk loader with a CSV staging file.
[0m[49m[39m  290, 297[0m:[39m[49m     // For incremental updates, use openCypher MERGE to upsert.
[0m[49m[39m  291, 298[0m:[39m[49m     
[0m[49m[39m  292, 299[0m:[39m[49m     // Connect to Neptune's openCypher endpoint
[0m[49m[39m  293, 300[0m:[39m[49m     connection = connect_to(neptune_endpoint, port=8182, protocol="bolt")
[0m[49m[39m  294, 301[0m:[39m[49m     
[0m[49m[39m  295, 302[0m:[39m[49m     // Upsert vertices: create if new, update properties if existing
[0m[49m[39m  296, 303[0m:[39m[49m     FOR each vertex in vertices:
[0m[49m[39m  297, 304[0m:[39m[49m         execute openCypher on connection:
[0m[49m[39m  298, 305[0m:[39m[49m             MERGE (n:{vertex.label} {id: vertex.id})
[0m[49m[39m  299, 306[0m:[39m[49m             SET n += vertex.properties
[0m[49m[39m  300, 307[0m:[39m[49m             // MERGE ensures we don't create duplicates.
[0m[49m[39m  301, 308[0m:[39m[49m             // SET += updates properties without removing existing ones.
[0m[49m[39m  302, 309[0m:[39m[49m     
[0m[49m[39m  303, 310[0m:[39m[49m     // Upsert edges: create if the relationship doesn't exist yet
[0m[49m[39m  304, 311[0m:[39m[49m     FOR each edge in edges:
[0m[49m[39m  305, 312[0m:[39m[49m         execute openCypher on connection:
[0m[49m[39m  306, 313[0m:[39m[49m             MATCH (a {id: edge.from})
[0m[49m[39m  307, 314[0m:[39m[49m             MATCH (b {id: edge.to})
[0m[49m[39m  308, 315[0m:[39m[49m             MERGE (a)-[r:{edge.type}]->(b)
[0m[49m[39m  309, 316[0m:[39m[49m             SET r += edge.properties
[0m[49m[39m  310, 317[0m:[39m[49m             // MERGE on the relationship prevents duplicate edges.
[0m[49m[39m  311, 318[0m:[39m[49m             // Properties like effective_date get updated if the edge already exists.
[0m[49m[39m  312, 319[0m:[39m[49m     
[0m[49m[39m  313, 320[0m:[39m[49m     // Log load statistics for monitoring
[0m[49m[39m  314, 321[0m:[39m[49m     log("Loaded {count(vertices)} vertices, {count(edges)} edges")
[0m[49m[39m  315, 322[0m:[39m[49m     
[0m[49m[39m  316, 323[0m:[39m[49m     RETURN { vertices_loaded: count(vertices), edges_loaded: count(edges) }
[0m[49m[39m  317, 324[0m:[39m[49m ```
[0m[49m[39m  318, 325[0m:[39m[49m 
[0m[49m[39m  319, 326[0m:[39m[49m **Step 3: Query for therapeutic alternatives.** This is the core value of the graph: answering "what can my patient take instead?" in a single traversal. The query starts at the prescribed drug, finds its therapeutic class, then finds all other drugs in that class that are covered under the patient's plan, sorted by tier (cheapest first). It also checks for restrictions so the prescriber knows upfront if an alternative requires prior auth or step therapy. Without the graph, this query would be a multi-table JOIN with subqueries. With the graph, it's a pattern match.
[0m[49m[39m  320, 327[0m:[39m[49m 
[0m[49m[39m  321, 328[0m:[39m[49m ```
[0m[49m[39m  322, 329[0m:[39m[49m FUNCTION find_alternatives(drug_id, plan_id, neptune_endpoint):
[0m[49m[39m  323, 330[0m:[39m[49m     // The prescriber's question: "What's cheaper and covered for this patient?"
[0m[49m[39m  324, 331[0m:[39m[49m     // We traverse: prescribed drug -> therapeutic class -> other drugs in class -> 
[0m[49m[39m  325, 332[0m:[39m[49m     //             filter by plan coverage -> sort by tier
[0m[49m[39m  326, 333[0m:[39m[49m     
[0m[49m[39m  327, 334[0m:[39m[49m     connection = connect_to(neptune_endpoint, port=8182, protocol="bolt")
[0m[49m[39m  328, 335[0m:[39m[49m     
[0m[49m[38;5;10m+      336[0m:[38;5;10m[49m     // Note: parameterized queries ($drug_id, $plan_id) prevent graph query injection.
[0m[49m[38;5;10m+      337[0m:[38;5;10m[49m     // Never build openCypher queries via string concatenation with user input.
[0m[49m[39m  329, 338[0m:[39m[49m     query = """
[0m[49m[39m  330, 339[0m:[39m[49m         // Start at the prescribed drug
[0m[49m[39m  331, 340[0m:[39m[49m         MATCH (prescribed:Drug {id: $drug_id})
[0m[49m[39m  332, 341[0m:[39m[49m         
[0m[49m[39m  333, 342[0m:[39m[49m         // Find its therapeutic class
[0m[49m[39m  334, 343[0m:[39m[49m         -[:BELONGS_TO_CLASS]->(class:TherapeuticClass)
[0m[49m[39m  335, 344[0m:[39m[49m         
[0m[49m[39m  336, 345[0m:[39m[49m         // Find other drugs in the same class
[0m[49m[39m  337, 346[0m:[39m[49m         <-[:BELONGS_TO_CLASS]-(alternative:Drug)
[0m[49m[39m  338, 347[0m:[39m[49m         
[0m[49m[39m  339, 348[0m:[39m[49m         // That are covered under the patient's plan
[0m[49m[39m  340, 349[0m:[39m[49m         -[coverage:COVERED_UNDER]->(plan:Plan {id: $plan_id})
[0m[49m[39m  341, 350[0m:[39m[49m         
[0m[49m[39m  342, 351[0m:[39m[49m         // Don't return the drug they already prescribed
[0m[49m[39m  343, 352[0m:[39m[49m         WHERE alternative.id <> $drug_id
[0m[49m[39m  344, 353[0m:[39m[49m         
[0m[49m[39m  345, 354[0m:[39m[49m         // Check for restrictions on each alternative
[0m[49m[39m  346, 355[0m:[39m[49m         OPTIONAL MATCH (alternative)-[restriction:HAS_RESTRICTION]->()
[0m[49m[39m  347, 356[0m:[39m[49m         WHERE restriction.plan_id = $plan_id
[0m[49m[39m  348, 357[0m:[39m[49m         
[0m[49m[39m  349, 358[0m:[39m[49m         // Return alternatives sorted by tier (cheapest first)
[0m[49m[39m  350, 359[0m:[39m[49m         RETURN alternative.name AS drug_name,
[0m[49m[39m  351, 360[0m:[39m[49m                alternative.id AS drug_id,
[0m[49m[39m  352, 361[0m:[39m[49m                alternative.strength AS strength,
[0m[49m[39m  353, 362[0m:[39m[49m                coverage.tier AS tier,
[0m[49m[39m  354, 363[0m:[39m[49m                collect(DISTINCT restriction.restriction_type) AS restrictions
[0m[49m[39m  355, 364[0m:[39m[49m         ORDER BY coverage.tier ASC, alternative.name ASC
[0m[49m[39m  356, 365[0m:[39m[49m     """
[0m[49m[39m  357, 366[0m:[39m[49m     
[0m[49m[39m  358, 367[0m:[39m[49m     results = execute(connection, query, parameters={drug_id: drug_id, plan_id: plan_id})
[0m[49m[39m  359, 368[0m:[39m[49m     
[0m[49m[39m  360, 369[0m:[39m[49m     RETURN results
[0m[49m[39m  361, 370[0m:[39m[49m ```
[0m[49m[39m  362, 371[0m:[39m[49m 
[0m[49m[39m  363, 372[0m:[39m[49m **Step 4: Cache results for repeated queries.** The same drug-plan combinations get queried repeatedly. Atorvastatin under Blue Cross PPO Plan 1234 might get looked up hundreds of times a day across a health system. Caching these results in Redis avoids hitting Neptune for every request. The cache key combines drug ID and plan ID. Cache TTL aligns with formulary update frequency: set it to 24 hours during normal periods, and flush explicitly when you load new formulary data. Skip caching and your Neptune cluster will be oversized (and over-budget) to handle the query volume.
[0m[49m[39m  364, 373[0m:[39m[49m 
[0m[49m[38;5;10m+      374[0m:[38;5;10m[49m <!-- TODO (TechWriter): Expert review S2 (HIGH). Add guidance on Redis security posture: (1) Enable ElastiCache AUTH (Redis AUTH token or IAM-based access control via ElastiCache for Redis 7.0+). (2) Note that cache keys containing plan_id create an access pattern log of medication inquiries per member; recommend using plan-type identifiers rather than member-specific plan IDs where possible, or document PHI implications if member-specific caching is required. (3) Confirm TLS in-transit is required for Lambda-to-Redis connections. -->
[0m[49m[38;5;10m+      375[0m:[38;5;10m[49m 
[0m[49m[39m  365, 376[0m:[39m[49m ```
[0m[49m[39m  366, 377[0m:[39m[49m FUNCTION get_alternatives_cached(drug_id, plan_id, redis_client, neptune_endpoint):
[0m[49m[39m  367, 378[0m:[39m[49m     // Build a deterministic cache key from the query parameters
[0m[49m[39m  368, 379[0m:[39m[49m     cache_key = "alternatives:" + drug_id + ":" + plan_id
[0m[49m[39m  369, 380[0m:[39m[49m     
[0m[49m[39m  370, 381[0m:[39m[49m     // Check Redis first
[0m[49m[39m  371, 382[0m:[39m[49m     cached_result = redis_client.get(cache_key)
[0m[49m[39m  372, 383[0m:[39m[49m     
[0m[49m[39m  373, 384[0m:[39m[49m     IF cached_result is not null:
[0m[49m[39m  374, 385[0m:[39m[49m         // Cache hit. Return immediately without touching Neptune.
[0m[49m[39m  375, 386[0m:[39m[49m         RETURN deserialize(cached_result)
[0m[49m[39m  376, 387[0m:[39m[49m     
[0m[49m[39m  377, 388[0m:[39m[49m     // Cache miss. Query the graph.
[0m[49m[39m  378, 389[0m:[39m[49m     result = find_alternatives(drug_id, plan_id, neptune_endpoint)
[0m[49m[39m  379, 390[0m:[39m[49m     
[0m[49m[39m  380, 391[0m:[39m[49m     // Store in cache with 24-hour TTL.
[0m[49m[39m  381, 392[0m:[39m[49m     // Formulary data changes at most daily (quarterly full refresh, occasional mid-quarter amendments).
[0m[49m[39m  382, 393[0m:[39m[49m     redis_client.set(cache_key, serialize(result), ttl=86400)
[0m[49m[39m  383, 394[0m:[39m[49m     
[0m[49m[39m  384, 395[0m:[39m[49m     RETURN result
[0m[49m[39m  385, 396[0m:[39m[49m ```
[0m[49m[39m  386, 397[0m:[39m[49m 
[0m[49m[39m  387, 398[0m:[39m[49m **Step 5: Expose via API with plan context.** The final step wraps the graph query in a clean API that accepts what the prescriber's system knows (drug name or code, patient's plan ID) and returns what they need (ranked alternatives with tier and restriction information). The API also handles the common case where the prescribed drug IS the preferred option: it returns a confirmation rather than alternatives. This matters for UX. A prescriber doesn't want to see "no alternatives found" when they've already picked the best option; they want "this is the preferred drug in its class."
[0m[49m[39m  388, 399[0m:[39m[49m 
[0m[49m[39m  389, 400[0m:[39m[49m ```
[0m[49m[39m  390, 401[0m:[39m[49m FUNCTION handle_formulary_query(request):
[0m[49m[38;5;9m- 391     [0m:[38;5;9m[49m     // Extract parameters from the API request
[0m[49m[38;5;10m+      402[0m:[38;5;10m[49m     // Extract and validate parameters from the API request.
[0m[49m[38;5;10m+      403[0m:[38;5;10m[49m     // Validate format before querying: drug_id should match RxNorm CUI or NDC pattern,
[0m[49m[38;5;10m+      404[0m:[38;5;10m[49m     // plan_id should match expected plan identifier format.
[0m[49m[39m  392, 405[0m:[39m[49m     drug_id = request.params["drug_id"]       // RxNorm CUI or NDC
[0m[49m[39m  393, 406[0m:[39m[49m     plan_id = request.params["plan_id"]       // patient's benefit plan identifier
[0m[49m[39m  394, 407[0m:[39m[49m     
[0m[49m[38;5;10m+      408[0m:[38;5;10m[49m     IF NOT valid_drug_id_format(drug_id) OR NOT valid_plan_id_format(plan_id):
[0m[49m[38;5;10m+      409[0m:[38;5;10m[49m         RETURN { status: "INVALID_INPUT", message: "Malformed drug_id or plan_id." }
[0m[49m[38;5;10m+      410[0m:[38;5;10m[49m     
[0m[49m[39m  395, 411[0m:[39m[49m     // First, check the tier of the prescribed drug itself
[0m[49m[39m  396, 412[0m:[39m[49m     prescribed_tier = get_drug_tier(drug_id, plan_id)
[0m[49m[39m  397, 413[0m:[39m[49m     
[0m[49m[39m  398, 414[0m:[39m[49m     IF prescribed_tier is null:
[0m[49m[39m  399, 415[0m:[39m[49m         // Drug not on formulary at all
[0m[49m[39m  400, 416[0m:[39m[49m         RETURN {
[0m[49m[39m  401, 417[0m:[39m[49m             status: "NOT_COVERED",
[0m[49m[39m  402, 418[0m:[39m[49m             prescribed_drug: drug_id,
[0m[49m[39m  403, 419[0m:[39m[49m             message: "This drug is not on the formulary for this plan.",
[0m[49m[39m  404, 420[0m:[39m[49m             alternatives: get_alternatives_cached(drug_id, plan_id, redis, neptune)
[0m[49m[39m  405, 421[0m:[39m[49m         }
[0m[49m[39m  406, 422[0m:[39m[49m     
[0m[49m[39m  407, 423[0m:[39m[49m     // Get alternatives
[0m[49m[39m  408, 424[0m:[39m[49m     alternatives = get_alternatives_cached(drug_id, plan_id, redis, neptune)
[0m[49m[39m  409, 425[0m:[39m[49m     
[0m[49m[39m  410, 426[0m:[39m[49m     // Check if any alternative has a better (lower) tier
[0m[49m[39m  411, 427[0m:[39m[49m     better_alternatives = filter(alternatives, WHERE tier < prescribed_tier)
[0m[49m[39m  412, 428[0m:[39m[49m     
[0m[49m[39m  413, 429[0m:[39m[49m     IF better_alternatives is empty:
[0m[49m[39m  414, 430[0m:[39m[49m         // The prescribed drug is already the best option
[0m[49m[39m  415, 431[0m:[39m[49m         RETURN {
[0m[49m[39m  416, 432[0m:[39m[49m             status: "PREFERRED",
[0m[49m[39m  417, 433[0m:[39m[49m             prescribed_drug: drug_id,
[0m[49m[39m  418, 434[0m:[39m[49m             tier: prescribed_tier,
[0m[49m[39m  419, 435[0m:[39m[49m             message: "This is the preferred option in its therapeutic class."
[0m[49m[39m  420, 436[0m:[39m[49m         }
[0m[49m[39m  421, 437[0m:[39m[49m     ELSE:
[0m[49m[39m  422, 438[0m:[39m[49m         RETURN {
[0m[49m[39m  423, 439[0m:[39m[49m             status: "ALTERNATIVES_AVAILABLE",
[0m[49m[39m  424, 440[0m:[39m[49m             prescribed_drug: drug_id,
[0m[49m[39m  425, 441[0m:[39m[49m             prescribed_tier: prescribed_tier,
[0m[49m[39m  426, 442[0m:[39m[49m             alternatives: better_alternatives,
[0m[49m[39m  427, 443[0m:[39m[49m             message: "Lower-cost alternatives are available."
[0m[49m[39m  428, 444[0m:[39m[49m         }
[0m[49m[39m  429, 445[0m:[39m[49m ```
[0m[49m[39m  430, 446[0m:[39m[49m 
[0m[49m[39m  431, 447[0m:[39m[49m > **Curious how this looks in Python?** The pseudocode above covers the concepts. If you'd like to see sample Python code that demonstrates these patterns using boto3 and the Neptune openCypher endpoint, check out the [Python Example](chapter13.01-python-example). It walks through each step with inline comments and notes on what you'd need to change for a real deployment.
