[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m │           │                                               │
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m │           ▼                                               │
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m │   [Output: episode record; longitudinal-store update;     │
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m │    initial outreach scheduled]                            │
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m │                                                           │
