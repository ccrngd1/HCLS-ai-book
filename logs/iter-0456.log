[49m[38;5;10m+    668[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m ## Step 3: Train the Volume and Acuity Models
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m Two parallel modeling jobs: a count regression for total hourly volume and a multinomial classifier for the per-acuity share. Both are trained on history holding out the most recent 90 days for validation. The volume model is evaluated by MAPE on the held-out window; the acuity classifier is evaluated by per-class log loss and macro F1. The retraining pipeline runs weekly. The trained models get deployed to the SageMaker inference endpoint atomically.
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m The demo implements two pedagogical model classes: `PoissonVolumeModel` and `AcuityMixModel`. Both are pure-Python stand-ins for what production replaces with statsmodels' negative binomial GLM and scikit-learn's multinomial logistic regression. They are good enough to demonstrate the feature-engineering, the held-out-evaluation, and the prediction-interval math; they are not good enough to manage real ED operations.
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m class PoissonVolumeModel:
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m     """Linear-in-log-rate count model with calendar and weather features.
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m     Production replaces this with statsmodels' GLM with the
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m     Poisson or NegativeBinomial family, with Prophet using a
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m     Poisson likelihood and external regressors, or with the
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m     SageMaker DeepAR built-in algorithm. The interface (fit,
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m     predict_with_interval, mape_on) is what matters: any count
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m     model that produces a point forecast plus a prediction
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m     interval drops in.
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m     def __init__(self):
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m         # Feature coefficients learned from the training window.
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m         # Production solves a proper GLM. The demo uses simple
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m         # stratified means by hour-of-day and day-of-week, plus
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m         # a small linear correction for the continuous features.
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m         self.hour_dow_mean   = {}     # (hour, dow) -> mean total arrivals
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m         self.flu_coef        = 0.0
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m         self.severe_wx_coef  = 0.0
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m         self.event_coef      = 0.0
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m         self.global_mean     = 0.0
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m         self.sigma           = 0.0    # residual standard deviation
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m         self.holdout_mape    = float("nan")
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m     def fit(self, training_rows, validation_rows):
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m         # 3a. Stratified mean by (hour_of_day, day_of_week) is the
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m         # base level. Cycles in ED arrivals are dominated by these
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m         # two features; the others are corrections on top.
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m         groups = defaultdict(list)
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m         for r in training_rows:
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m             groups[(r["hour_of_day"], r["day_of_week"])].append(r["target_total"])
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m         self.hour_dow_mean = {k: mean(v) for k, v in groups.items()}
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m         self.global_mean   = mean(r["target_total"] for r in training_rows) \
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m             if training_rows else 0.0
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m         # 3b. Fit linear corrections for flu_index, severe_weather,
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m         # and has_local_event by computing residuals from the
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m         # base-rate prediction and regressing them on each feature
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m         # one at a time. This is a simplified backfit that keeps
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m         # the math readable; production runs a proper GLM.
[0m[49m[38;5;10m+    717[0m:[38;5;10m[49m         residuals = []
[0m[49m[38;5;10m+    718[0m:[38;5;10m[49m         for r in training_rows:
[0m[49m[38;5;10m+    719[0m:[38;5;10m[49m             base = self.hour_dow_mean.get(
[0m[49m[38;5;10m+    720[0m:[38;5;10m[49m                 (r["hour_of_day"], r["day_of_week"]), self.global_mean)
[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m             residuals.append({
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m                 "residual":          r["target_total"] - base,
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m                 "flu_index":         r["flu_index"],
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m                 "is_severe_weather": 1.0 if r["is_severe_weather"] else 0.0,
[0m[49m[38;5;10m+    725[0m:[38;5;10m[49m                 "has_local_event":   1.0 if r["has_local_event"]  else 0.0,
[0m[49m[38;5;10m+    726[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    727[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    728[0m:[38;5;10m[49m         self.flu_coef       = _simple_regression_coef(
[0m[49m[38;5;10m+    729[0m:[38;5;10m[49m             [d["residual"] for d in residuals],
[0m[49m[38;5;10m+    730[0m:[38;5;10m[49m             [d["flu_index"] for d in residuals])
[0m[49m[38;5;10m+    731[0m:[38;5;10m[49m         self.severe_wx_coef = _simple_regression_coef(
[0m[49m[38;5;10m+    732[0m:[38;5;10m[49m             [d["residual"] for d in residuals],
[0m[49m[38;5;10m+    733[0m:[38;5;10m[49m             [d["is_severe_weather"] for d in residuals])
[0m[49m[38;5;10m+    734[0m:[38;5;10m[49m         self.event_coef     = _simple_regression_coef(
[0m[49m[38;5;10m+    735[0m:[38;5;10m[49m             [d["residual"] for d in residuals],
[0m[49m[38;5;10m+    736[0m:[38;5;10m[49m             [d["has_local_event"] for d in residuals])
[0m[49m[38;5;10m+    737[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    738[0m:[38;5;10m[49m         # 3c. Residual standard deviation drives the prediction
[0m[49m[38;5;10m+    739[0m:[38;5;10m[49m         # interval. A real GLM produces this directly from the
[0m[49m[38;5;10m+    740[0m:[38;5;10m[49m         # likelihood; the demo uses the in-sample residuals after
[0m[49m[38;5;10m+    741[0m:[38;5;10m[49m         # all corrections are applied.
[0m[49m[38;5;10m+    742[0m:[38;5;10m[49m         full_residuals = [
[0m[49m[38;5;10m+    743[0m:[38;5;10m[49m             r["target_total"] - self.predict_point(r) for r in training_rows
[0m[49m[38;5;10m+    744[0m:[38;5;10m[49m         ]
[0m[49m[38;5;10m+    745[0m:[38;5;10m[49m         self.sigma = stdev(full_residuals) if len(full_residuals) > 1 else 0.0
[0m[49m[38;5;10m+    746[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    747[0m:[38;5;10m[49m         # 3d. Hold-out evaluation. MAPE is computed on the
[0m[49m[38;5;10m+    748[0m:[38;5;10m[49m         # validation window only. Training MAPE is biased
[0m[49m[38;5;10m+    749[0m:[38;5;10m[49m         # downward because the model has seen those rows.
[0m[49m[38;5;10m+    750[0m:[38;5;10m[49m         self.holdout_mape = self.mape_on(validation_rows)
[0m[49m[38;5;10m+    751[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    752[0m:[38;5;10m[49m         logger.info(
[0m[49m[38;5;10m+    753[0m:[38;5;10m[49m             "Volume model trained: holdout_mape=%.3f sigma=%.3f "
[0m[49m[38;5;10m+    754[0m:[38;5;10m[49m             "flu_coef=%.3f severe_wx_coef=%.3f event_coef=%.3f",
[0m[49m[38;5;10m+    755[0m:[38;5;10m[49m             self.holdout_mape, self.sigma,
[0m[49m[38;5;10m+    756[0m:[38;5;10m[49m             self.flu_coef, self.severe_wx_coef, self.event_coef)
[0m[49m[38;5;10m+    757[0m:[38;5;10m[49m         return self
[0m[49m[38;5;10m+    758[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    759[0m:[38;5;10m[49m     def predict_point(self, feature_row):
[0m[49m[38;5;10m+    760[0m:[38;5;10m[49m         base = self.hour_dow_mean.get(
[0m[49m[38;5;10m+    761[0m:[38;5;10m[49m             (feature_row["hour_of_day"], feature_row["day_of_week"]),
[0m[49m[38;5;10m+    762[0m:[38;5;10m[49m             self.global_mean)
[0m[49m[38;5;10m+    763[0m:[38;5;10m[49m         adj  = (
[0m[49m[38;5;10m+    764[0m:[38;5;10m[49m             self.flu_coef       * feature_row["flu_index"] +
[0m[49m[38;5;10m+    765[0m:[38;5;10m[49m             self.severe_wx_coef * (1.0 if feature_row["is_severe_weather"] else 0.0) +
[0m[49m[38;5;10m+    766[0m:[38;5;10m[49m             self.event_coef     * (1.0 if feature_row["has_local_event"]   else 0.0)
[0m[49m[38;5;10m+    767[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    768[0m:[38;5;10m[49m         return max(0.0, base + adj)
[0m[49m[38;5;10m+    769[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    770[0m:[38;5;10m[49m     def predict_with_interval(self, feature_row):
[0m[49m[38;5;10m+    771[0m:[38;5;10m[49m         point = self.predict_point(feature_row)
[0m[49m[38;5;10m+    772[0m:[38;5;10m[49m         # Production uses the model's native quantile output. The
[0m[49m[38;5;10m+    773[0m:[38;5;10m[49m         # demo uses normal-approximation intervals; for low counts
[0m[49m[38;5;10m+    774[0m:[38;5;10m[49m         # this overstates the lower-bound width (a Poisson interval
[0m[49m[38;5;10m+    775[0m:[38;5;10m[49m         # is asymmetric near zero).
[0m[49m[38;5;10m+    776[0m:[38;5;10m[49m         z80 = float(INTERVAL_Z_80)
[0m[49m[38;5;10m+    777[0m:[38;5;10m[49m         z95 = float(INTERVAL_Z_95)
[0m[49m[38;5;10m+    778[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    779[0m:[38;5;10m[49m             "point":       point,
[0m[49m[38;5;10m+    780[0m:[38;5;10m[49m             "lower_80":    max(0.0, point - z80 * self.sigma),
[0m[49m[38;5;10m+    781[0m:[38;5;10m[49m             "upper_80":          point + z80 * self.sigma,
[0m[49m[38;5;10m+    782[0m:[38;5;10m[49m             "lower_95":    max(0.0, point - z95 * self.sigma),
[0m[49m[38;5;10m+    783[0m:[38;5;10m[49m             "upper_95":          point + z95 * self.sigma,
[0m[49m[38;5;10m+    784[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    785[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    786[0m:[38;5;10m[49m     def mape_on(self, rows):
[0m[49m[38;5;10m+    787[0m:[38;5;10m[49m         if not rows:
[0m[49m[38;5;10m+    788[0m:[38;5;10m[49m             return float("nan")
[0m[49m[38;5;10m+    789[0m:[38;5;10m[49m         # MAPE skips zero-actual rows to avoid division by zero;
[0m[49m[38;5;10m+    790[0m:[38;5;10m[49m         # production uses MASE (Mean Absolute Scaled Error) on
[0m[49m[38;5;10m+    791[0m:[38;5;10m[49m         # count series for that reason. The demo uses MAPE for
[0m[49m[38;5;10m+    792[0m:[38;5;10m[49m         # readability.
[0m[49m[38;5;10m+    793[0m:[38;5;10m[49m         errors = []
[0m[49m[38;5;10m+    794[0m:[38;5;10m[49m         for r in rows:
[0m[49m[38;5;10m+    795[0m:[38;5;10m[49m             if r["target_total"] == 0:
[0m[49m[38;5;10m+    796[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    797[0m:[38;5;10m[49m             pred = self.predict_point(r)
[0m[49m[38;5;10m+    798[0m:[38;5;10m[49m             errors.append(abs(r["target_total"] - pred) / r["target_total"])
[0m[49m[38;5;10m+    799[0m:[38;5;10m[49m         return mean(errors) if errors else float("nan")
[0m[49m[38;5;10m+    800[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    801[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    802[0m:[38;5;10m[49m def _simple_regression_coef(y_values, x_values):
[0m[49m[38;5;10m+    803[0m:[38;5;10m[49m     """Ordinary least squares coefficient on a single feature.
[0m[49m[38;5;10m+    804[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    805[0m:[38;5;10m[49m     Equivalent to sklearn's LinearRegression(fit_intercept=False)
[0m[49m[38;5;10m+    806[0m:[38;5;10m[49m     for a single x. Returns 0 if the feature has zero variance.
[0m[49m[38;5;10m+    807[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    808[0m:[38;5;10m[49m     if len(x_values) < 2:
[0m[49m[38;5;10m+    809[0m:[38;5;10m[49m         return 0.0
[0m[49m[38;5;10m+    810[0m:[38;5;10m[49m     x_mean = mean(x_values)
[0m[49m[38;5;10m+    811[0m:[38;5;10m[49m     y_mean = mean(y_values)
[0m[49m[38;5;10m+    812[0m:[38;5;10m[49m     num    = sum((x - x_mean) * (y - y_mean) for x, y in zip(x_values, y_values))
[0m[49m[38;5;10m+    813[0m:[38;5;10m[49m     den    = sum((x - x_mean) ** 2 for x in x_values)
[0m[49m[38;5;10m+    814[0m:[38;5;10m[49m     return num / den if den > 0 else 0.0
[0m[49m[38;5;10m+    815[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    816[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    817[0m:[38;5;10m[49m class AcuityMixModel:
[0m[49m[38;5;10m+    818[0m:[38;5;10m[49m     """Simplified multinomial classifier for ESI mix prediction.
[0m[49m[38;5;10m+    819[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    820[0m:[38;5;10m[49m     Production replaces this with sklearn's
[0m[49m[38;5;10m+    821[0m:[38;5;10m[49m     LogisticRegression(multi_class='multinomial') with
[0m[49m[38;5;10m+    822[0m:[38;5;10m[49m     calibrated probabilities, with a gradient-boosted multinomial
[0m[49m[38;5;10m+    823[0m:[38;5;10m[49m     classifier (LightGBM, XGBoost), or with a small neural
[0m[49m[38;5;10m+    824[0m:[38;5;10m[49m     network. The demo computes stratified mix proportions by
[0m[49m[38;5;10m+    825[0m:[38;5;10m[49m     (hour_of_day, flu_bucket) and falls back to the global mix
[0m[49m[38;5;10m+    826[0m:[38;5;10m[49m     for unseen combinations.
[0m[49m[38;5;10m+    827[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    828[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    829[0m:[38;5;10m[49m     def __init__(self):
[0m[49m[38;5;10m+    830[0m:[38;5;10m[49m         self.mix_by_stratum = {}    # (hour_of_day, flu_bucket) -> {esi_n: share}
[0m[49m[38;5;10m+    831[0m:[38;5;10m[49m         self.global_mix     = {}
[0m[49m[38;5;10m+    832[0m:[38;5;10m[49m         self.holdout_logloss = float("nan")
[0m[49m[38;5;10m+    833[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    834[0m:[38;5;10m[49m     def fit(self, training_rows, validation_rows):
[0m[49m[38;5;10m+    835[0m:[38;5;10m[49m         # 3e. Compute the per-stratum ESI mix from the training
[0m[49m[38;5;10m+    836[0m:[38;5;10m[49m         # window. ESI 1 arrivals are rare; pooling across hour-of-
[0m[49m[38;5;10m+    837[0m:[38;5;10m[49m         # day and a coarse flu bucket gives the model enough
[0m[49m[38;5;10m+    838[0m:[38;5;10m[49m         # samples per stratum to estimate stable proportions.
[0m[49m[38;5;10m+    839[0m:[38;5;10m[49m         stratum_counts = defaultdict(lambda: defaultdict(int))
[0m[49m[38;5;10m+    840[0m:[38;5;10m[49m         global_counts  = defaultdict(int)
[0m[49m[38;5;10m+    841[0m:[38;5;10m[49m         for r in training_rows:
[0m[49m[38;5;10m+    842[0m:[38;5;10m[49m             flu_bucket = self._flu_bucket(r["flu_index"])
[0m[49m[38;5;10m+    843[0m:[38;5;10m[49m             stratum_key = (r["hour_of_day"], flu_bucket)
[0m[49m[38;5;10m+    844[0m:[38;5;10m[49m             for esi in ESI_LEVELS:
[0m[49m[38;5;10m+    845[0m:[38;5;10m[49m                 count = r[f"target_{esi}"]
[0m[49m[38;5;10m+    846[0m:[38;5;10m[49m                 stratum_counts[stratum_key][esi] += count
[0m[49m[38;5;10m+    847[0m:[38;5;10m[49m                 global_counts[esi] += count
[0m[49m[38;5;10m+    848[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    849[0m:[38;5;10m[49m         # Convert counts to shares per stratum.
[0m[49m[38;5;10m+    850[0m:[38;5;10m[49m         for stratum_key, counts in stratum_counts.items():
[0m[49m[38;5;10m+    851[0m:[38;5;10m[49m             total = sum(counts.values())
[0m[49m[38;5;10m+    852[0m:[38;5;10m[49m             if total > 0:
[0m[49m[38;5;10m+    853[0m:[38;5;10m[49m                 self.mix_by_stratum[stratum_key] = {
[0m[49m[38;5;10m+    854[0m:[38;5;10m[49m                     esi: counts[esi] / total for esi in ESI_LEVELS
[0m[49m[38;5;10m+    855[0m:[38;5;10m[49m                 }
[0m[49m[38;5;10m+    856[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    857[0m:[38;5;10m[49m         global_total = sum(global_counts.values())
[0m[49m[38;5;10m+    858[0m:[38;5;10m[49m         if global_total > 0:
[0m[49m[38;5;10m+    859[0m:[38;5;10m[49m             self.global_mix = {
[0m[49m[38;5;10m+    860[0m:[38;5;10m[49m                 esi: global_counts[esi] / global_total for esi in ESI_LEVELS
[0m[49m[38;5;10m+    861[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    862[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    863[0m:[38;5;10m[49m             # Uniform fallback for the empty case.
[0m[49m[38;5;10m+    864[0m:[38;5;10m[49m             self.global_mix = {esi: 0.2 for esi in ESI_LEVELS}
[0m[49m[38;5;10m+    865[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    866[0m:[38;5;10m[49m         # 3f. Held-out evaluation: per-row log loss against the
[0m[49m[38;5;10m+    867[0m:[38;5;10m[49m         # actual ESI mix in the validation window. A real
[0m[49m[38;5;10m+    868[0m:[38;5;10m[49m         # multinomial classifier produces calibrated per-arrival
[0m[49m[38;5;10m+    869[0m:[38;5;10m[49m         # probabilities; the demo evaluates the predicted mix
[0m[49m[38;5;10m+    870[0m:[38;5;10m[49m         # against the realized mix per (hour, flu_bucket) row.
[0m[49m[38;5;10m+    871[0m:[38;5;10m[49m         log_losses = []
[0m[49m[38;5;10m+    872[0m:[38;5;10m[49m         for r in validation_rows:
[0m[49m[38;5;10m+    873[0m:[38;5;10m[49m             mix    = self.predict_mix(r)
[0m[49m[38;5;10m+    874[0m:[38;5;10m[49m             total  = sum(r[f"target_{esi}"] for esi in ESI_LEVELS)
[0m[49m[38;5;10m+    875[0m:[38;5;10m[49m             if total == 0:
[0m[49m[38;5;10m+    876[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    877[0m:[38;5;10m[49m             row_ll = 0.0
[0m[49m[38;5;10m+    878[0m:[38;5;10m[49m             for esi in ESI_LEVELS:
[0m[49m[38;5;10m+    879[0m:[38;5;10m[49m                 actual_share = r[f"target_{esi}"] / total
[0m[49m[38;5;10m+    880[0m:[38;5;10m[49m                 pred_share   = max(1e-6, mix[esi])  # avoid log(0)
[0m[49m[38;5;10m+    881[0m:[38;5;10m[49m                 row_ll += -actual_share * math.log(pred_share)
[0m[49m[38;5;10m+    882[0m:[38;5;10m[49m             log_losses.append(row_ll)
[0m[49m[38;5;10m+    883[0m:[38;5;10m[49m         self.holdout_logloss = mean(log_losses) if log_losses else float("nan")
