[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m EVENTS_BUCKET                 = "ed-forecast-events-calendar"
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m FORECAST_OUTPUT_BUCKET        = "ed-forecast-outputs"
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m ED_FORECASTS_TABLE            = "ed-forecasts"
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m FORECAST_EVENT_BUS_NAME       = "ed-forecast-events-bus"
