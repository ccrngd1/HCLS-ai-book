[0m[49m[38;5;10m+    892[0m:[38;5;10m[49m     def _flu_bucket(self, flu_index):
[0m[49m[38;5;10m+    893[0m:[38;5;10m[49m         """Coarse flu buckets so the mix estimator has samples per cell."""
