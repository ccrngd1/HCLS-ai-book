[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m         "Aggregated %d ADT records into %d (ed, hour) buckets",
