[49m[38;5;10m+     46[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     47[0m:[38;5;10m[49m ## Configuration and Constants
[0m[49m[38;5;10m+     48[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     49[0m:[38;5;10m[49m Everything that is configuration rather than logic lives here. Resource names, forecast horizons, ESI level mappings, prediction-interval percentiles, and the synthetic-data parameters are what you would change between environments.
[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m import math
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m import random
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m import uuid
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m from collections import defaultdict
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m from datetime import date, datetime, timedelta, timezone
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m from statistics import mean, stdev
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m # Structured logging. In production, ship JSON-formatted records
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m # to CloudWatch Logs Insights for cross-call investigation.
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m # ADT data is PHI: an HL7 v2 A04 carries patient name, MRN,
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m # date of birth, address, and chief complaint. Log structural
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m # metadata only (run_id, ed_id, hour, record_count, mean_error,
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m # runtime_ms), never raw ADT message bodies, never patient
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m # identifiers, never chief-complaint text. The aggregated
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m # hourly counts are derived from PHI and are themselves PHI by
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m # association under the BAA; treat them with the same care.
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m # Adaptive retry handles throttling from Kinesis, S3, DynamoDB,
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m # EventBridge, CloudWatch, and SageMaker. The hourly inference
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m # pipeline has a tight cycle (the next run is only an hour
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m # away), so longer retries trade off against staleness. Cap them
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m # so a stuck dependency does not delay the next-cycle forecast
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m # beyond its operational usefulness.
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m     retries={"max_attempts": 5, "mode": "adaptive"})
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m # Module-level clients. Reused across function calls within the
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m # pipeline so each call does not pay the connection cost. The
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m # demo wires up MockTable / MockEventBus / MockCloudWatch /
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m # MockStream via run_demo() and never touches these real
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m # handles; they are staged here so production wiring is a
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m # one-line swap. boto3 client and resource construction is lazy
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m # (no network call until first use), so the unused handles are
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m # free at import.
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m REGION = "us-east-1"
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m s3_client          = boto3.client("s3",
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m                                   region_name=REGION,
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m                                   config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m dynamodb           = boto3.resource("dynamodb",
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m                                     region_name=REGION,
