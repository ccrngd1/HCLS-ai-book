[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m def _to_decimal(value):
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m     """Convert numeric values to Decimal for DynamoDB-safe writes.
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m     DynamoDB rejects Python float at the SDK boundary because
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m     floating-point cannot represent every decimal value exactly.
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m     Pass everything numeric through this helper before any
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m     PutItem, BatchWriteItem, or UpdateItem call. The helper
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m     covers the common cases (int, float, str-of-number, None)
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m     and lets exotic types fail loudly rather than silently.
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m     if value is None:
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m     if isinstance(value, Decimal):
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m         return value
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m     if isinstance(value, bool):
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m         # bool is a subclass of int in Python; route it explicitly
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m         # so a True does not become Decimal('1') unexpectedly.
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m         return value
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     if isinstance(value, (int, float)):
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m         # Round float through string to avoid the float->Decimal
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m         # repr surprise (Decimal(0.1) is not Decimal('0.1')).
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m         return Decimal(str(value))
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m     if isinstance(value, str):
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m         return Decimal(value)
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m     raise TypeError(f"Cannot convert {type(value).__name__} to Decimal")
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m 
