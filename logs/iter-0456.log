[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m         arrival_ts = datetime.fromisoformat(record["arrival_ts"])
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m         local_hour = _floor_to_hour(arrival_ts)
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m         bucket_key = (record["ed_id"], local_hour.isoformat())
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m         bucket = hourly_buckets[bucket_key]
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m         if record["esi_level"] is None:
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m             bucket["esi_unknown"] += 1
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m             bucket[f"esi_{record['esi_level']}"] += 1
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m         bucket["total"] += 1
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m     # Flatten to a list of rows. Production writes these rows to
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m     # an S3 prefix partitioned by date and ED so the downstream
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m     # feature build can read them efficiently.
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m     rows = []
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m     for (ed_id, hour_iso), counts in sorted(hourly_buckets.items()):
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m         rows.append({
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m             "ed_id":       ed_id,
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m             "local_hour":  hour_iso,
