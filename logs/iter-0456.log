[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m def build_feature_table(hourly_rows, weather, flu_index, event_dates):
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m     """Step 2: Join hourly counts with calendar, weather, and lag features.
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m     Returns a list of feature dicts, one per (ed_id, hour). Each
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m     dict carries the target counts, calendar features, weather
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m     features, surveillance features, event flags, and lag
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m     features. Production does this in an AWS Glue PySpark job
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m     that reads the hourly counts and reference feeds from S3 and
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m     writes a modeling-ready Parquet table back to S3 partitioned
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m     by (ed_id, date).
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m     # Build a lookup by (ed_id, local_hour) so lag features can
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m     # reach back to the same hour yesterday and last week.
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m     by_key = {(r["ed_id"], r["local_hour"]): r for r in hourly_rows}
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m     features = []
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m     for row in hourly_rows:
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m         local_hour_dt = datetime.fromisoformat(row["local_hour"])
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m         date_iso      = local_hour_dt.date().isoformat()
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m         # Calendar features. The model can only learn patterns it
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m         # has features for; encoding hour-of-day and day-of-week
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m         # explicitly gives the model a head start over inferring
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m         # them from raw timestamps.
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m         feature_row = {
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m             "ed_id":         row["ed_id"],
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m             "local_hour":    row["local_hour"],
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m             "target_total":  row["total"],
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m             "target_esi_1":  row["esi_1"],
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m             "target_esi_2":  row["esi_2"],
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m             "target_esi_3":  row["esi_3"],
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m             "target_esi_4":  row["esi_4"],
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m             "target_esi_5":  row["esi_5"],
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m             "hour_of_day":   local_hour_dt.hour,
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m             "day_of_week":   local_hour_dt.weekday(),
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m             "month":         local_hour_dt.month,
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m             "is_weekend":    local_hour_dt.weekday() >= 5,
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m             "is_holiday":    False,  # production reads from a holiday calendar table
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m         # Weather features at the same hour. Fall back to neutral
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m         # defaults if the exact hour is missing (the weather feed
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m         # sometimes drops readings).
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m         w = weather.get((date_iso, local_hour_dt.hour), {})
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m         feature_row["temperature_f"]    = w.get("temperature_f", 60.0)
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m         feature_row["precipitation_in"] = w.get("precipitation_in", 0.0)
