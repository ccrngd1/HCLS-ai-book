[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m class MockEventBus:
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m     """In-memory stand-in for EventBridge.
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m     Production uses boto3.client('events').put_events(...). The
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m     mock accumulates events so the demo can show what would have
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m     been emitted to the ed-forecast-events bus at each pipeline
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m     stage.
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m     def __init__(self, name):
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m         self.name   = name
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m         self.events = []
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m     def put_events(self, Entries):
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m         self.events.extend(Entries)
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m         return {"FailedEntryCount": 0}
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m class MockCloudWatch:
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m     """In-memory stand-in for CloudWatch metrics.
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m     Production uses boto3.client('cloudwatch').put_metric_data.
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m     The mock collects metrics by name so the demo can summarize
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m     what would have been emitted.
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m     def __init__(self):
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m         self.metrics = defaultdict(list)
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m     def put_metric_data(self, Namespace, MetricData):
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m         for m in MetricData:
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m             key = f"{Namespace}/{m['MetricName']}"
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m             self.metrics[key].append(m["Value"])
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m class MockStream:
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m     """In-memory stand-in for a Kinesis Data Stream of ADT records.
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m     Production reads HL7 v2 ADT-A04 messages (or FHIR
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m     Encounter resources) from a Kinesis Data Stream or
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m     Amazon HealthLake. The mock holds a list of pre-redacted
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m     arrival records so the demo can iterate them as if they
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m     arrived on the stream. Each record carries only the fields
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m     the aggregator needs: ed_id, arrival_ts (as ISO 8601 in the
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m     ED's local timezone), and esi_level (or None when triage
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m     has not yet assigned one).
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m     def __init__(self, name):
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m         self.name    = name
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m         self.records = []
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m     def append(self, record):
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m         self.records.append(record)
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m     def __iter__(self):
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m         return iter(self.records)
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m     def __len__(self):
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m         return len(self.records)
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m def generate_synthetic_adt_stream(seed=42):
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m     """Generate two years of hourly synthetic ADT registrations.
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m     Real ADT streams come from the EHR registration interface
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m     via an HL7 v2 feed (Mirth / Rhapsody / Cloverleaf) or a
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m     FHIR R4 subscription. The demo replaces that with a
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m     deterministic generator that produces a realistic-shaped
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m     arrival series at a single ED with hour-of-day, day-of-week,
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m     and weather-driven patterns plus an ESI mix that shifts
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m     across the day. Seeding makes the run reproducible.
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m     Returns a MockStream of arrival records, a dict of weather
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m     observations keyed by (date, hour), and a flu-index series
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m     keyed by date.
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m     rng        = random.Random(seed)
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m     end_date   = date(2026, 4, 14)
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m     start_date = end_date - timedelta(days=SYNTHETIC_HISTORY_DAYS - 1)
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m     stream     = MockStream(ADT_KINESIS_STREAM_NAME)
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m     # --- Weather: hourly temperature, precipitation, wind ---
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m     weather = {}
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m     for i in range(SYNTHETIC_HISTORY_DAYS):
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m         d = start_date + timedelta(days=i)
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m         # Annual temperature cycle: peaks in July (day 200ish).
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m         day_of_year = d.timetuple().tm_yday
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m         annual_base = 55 + 30 * math.sin(2 * math.pi * (day_of_year - 105) / 365)
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m         for h in range(24):
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m             # Diurnal cycle: cooler at night, warmer by mid-afternoon.
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m             diurnal = 8 * math.sin(2 * math.pi * (h - 6) / 24)
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m             temp_f  = annual_base + diurnal + rng.gauss(0, 4)
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m             precip  = max(0, rng.gauss(0, 0.05)) if rng.random() < 0.15 else 0
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m             wind    = max(0, 5 + rng.gauss(0, 4))
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m             weather[(d.isoformat(), h)] = {
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m                 "temperature_f":     round(temp_f, 1),
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m                 "precipitation_in":  round(precip, 2),
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m                 "wind_speed_mph":    round(wind, 1),
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m                 "is_severe_weather": precip > 0.5 or wind > 25 or temp_f < 10,
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m     # --- Flu index: weekly value, peaks in mid-winter ---
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m     flu_index = {}
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m     for i in range(SYNTHETIC_HISTORY_DAYS):
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m         d = start_date + timedelta(days=i)
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m         day_of_year = d.timetuple().tm_yday
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m         # Peak around early February (day 35ish).
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m         seasonal = 0.5 + 0.45 * math.cos(2 * math.pi * (day_of_year - 35) / 365)
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m         flu_index[d.isoformat()] = round(max(0, min(1, seasonal + rng.gauss(0, 0.05))), 3)
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m     # --- Local events: occasional weekend events that boost arrivals ---
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m     event_dates = set()
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m     for i in range(SYNTHETIC_HISTORY_DAYS):
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m         d = start_date + timedelta(days=i)
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m         if d.weekday() >= 5 and rng.random() < 0.10:
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m             event_dates.add(d.isoformat())
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m     # --- ADT arrival records ---
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m     # Hour-of-day pattern based on real ED arrival shapes:
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m     # quiet 00:00-05:00, ramp through morning, peak 16:00-20:00,
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m     # tapering through evening.
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m     hourly_intensity = [
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m         0.40, 0.30, 0.25, 0.22, 0.25, 0.35,   # 00-05
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m         0.55, 0.85, 1.10, 1.20, 1.25, 1.20,   # 06-11
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m         1.20, 1.25, 1.30, 1.35, 1.45, 1.50,   # 12-17
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m         1.55, 1.50, 1.30, 1.05, 0.80, 0.55,   # 18-23
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m     # Day-of-week multipliers; Monday and weekends are heavier.
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m     dow_multiplier = [1.10, 1.00, 0.95, 0.95, 1.00, 1.15, 1.20]
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m     # Baseline arrivals per hour.
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m     baseline_per_hour = 7.0
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m     for i in range(SYNTHETIC_HISTORY_DAYS):
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m         d = start_date + timedelta(days=i)
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m         for h in range(24):
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m             dow = d.weekday()
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m             w   = weather[(d.isoformat(), h)]
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m             flu = flu_index[d.isoformat()]
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m             # Compute the expected arrival rate for this hour.
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m             rate = baseline_per_hour
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m             rate *= hourly_intensity[h]
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m             rate *= dow_multiplier[dow]
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m             rate *= 1.0 + 0.6 * flu                # flu pushes volume up
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m             if w["is_severe_weather"]:
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m                 rate *= 0.85                       # severe weather suppresses walk-ins
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m             if d.isoformat() in event_dates:
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m                 rate *= 1.25                       # local events boost late-day volume
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m             # Sample the actual count from a Poisson distribution.
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m             # Python's standard library lacks a direct Poisson
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m             # sampler; approximate via normal for high rates and
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m             # by inversion for low rates.
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m             n_arrivals = _poisson_sample(rng, rate)
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m             # Assign an ESI level to each arrival. The mix shifts
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m             # by hour of day: high-acuity skews early morning and
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m             # late evening, low-acuity skews midday.
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m             for _ in range(n_arrivals):
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m                 ts = datetime(d.year, d.month, d.day, h,
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m                               rng.randint(0, 59),
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m                               rng.randint(0, 59))
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m                 esi = _sample_esi_level(rng, hour=h, flu_index=flu)
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m                 # 4% of records arrive without an ESI level
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m                 # because triage has not yet completed by the
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m                 # time the registration record is captured.
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m                 if rng.random() < 0.04:
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m                     esi = None
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m                 stream.append({
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m                     "ed_id":       SYNTHETIC_ED_ID,
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m                     "arrival_ts":  ts.isoformat(),
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m                     "esi_level":   esi,
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m                     # Production includes patient_id (MRN) and
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m                     # encounter_id here. The demo redacts both
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m                     # at generation; real pipelines redact at
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m                     # the aggregation boundary.
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m                 })
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m     return stream, weather, flu_index, event_dates
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m def _poisson_sample(rng, lam):
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m     """Draw a Poisson sample without numpy.
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m     For rates below ~30 we use Knuth's inversion algorithm; for
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m     higher rates we approximate with a normal distribution
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m     (continuity-corrected) since arrival rates above 30 are
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m     well-approximated by a Gaussian. Production uses
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m     numpy.random.poisson; the demo stays standard-library only.
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m     if lam < 30:
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m         L = math.exp(-lam)
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m         k = 0
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m         p = 1.0
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m         while True:
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m             k += 1
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m             p *= rng.random()
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m             if p <= L:
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m                 return k - 1
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m     # Normal approximation with continuity correction.
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m     return max(0, int(round(rng.gauss(lam, math.sqrt(lam)))))
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m def _sample_esi_level(rng, hour, flu_index):
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m     """Sample an ESI level given the hour of day and flu index.
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m     The mix is: ESI 1 ~2%, ESI 2 ~14%, ESI 3 ~50%, ESI 4 ~24%,
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m     ESI 5 ~10%, with shifts based on hour of day and flu index.
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m     Real ESI distributions vary by ED and patient population;
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m     these proportions are illustrative.
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m     # Shift higher-acuity proportion up overnight.
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m     acuity_shift = 1.20 if hour < 6 or hour >= 22 else 1.0
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m     # Flu pushes ESI 3 share up at the expense of ESI 4/5.
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m     flu_shift    = 1.0 + 0.3 * flu_index
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m     weights = [
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m         0.02 * acuity_shift,             # ESI 1
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m         0.14 * acuity_shift,             # ESI 2
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m         0.50 * flu_shift,                # ESI 3
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m         0.24 / flu_shift,                # ESI 4
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m         0.10 / flu_shift,                # ESI 5
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m     total = sum(weights)
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m     weights = [w / total for w in weights]
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m     r = rng.random()
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m     cumulative = 0.0
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m     for level_idx, w in enumerate(weights):
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m         cumulative += w
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m         if r <= cumulative:
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m             return level_idx + 1
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m     return 5
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m ```
