[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m         arrival_ts = datetime.fromisoformat(record["arrival_ts"])
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m         local_hour = _floor_to_hour(arrival_ts)
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m         bucket_key = (record["ed_id"], local_hour.isoformat())
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m         bucket = hourly_buckets[bucket_key]
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m         if record["esi_level"] is None:
