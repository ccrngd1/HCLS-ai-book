[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m # --- Versioning ---
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m # Every forecast record carries the model versions active at the
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m # time of generation. This is how a future audit reconstructs
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m # which calibration produced which call-in decision.
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m PIPELINE_VERSION   = "ed-forecast-v1.2"
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m VOLUME_MODEL_FAMILY = "negative-binomial-glm"
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m ACUITY_MODEL_FAMILY = "multinomial-logistic"
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m # --- Forecast Horizons ---
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m # Operational horizons that the dashboard, scheduler, and surge
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m # trigger consume. 4-hour drives charge-nurse call-in decisions,
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m # 12-hour drives end-of-shift handoff planning, 24-hour drives
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m # next-shift staffing.
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m FORECAST_HORIZONS_HOURS = [4, 12, 24]
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m MAX_HORIZON_HOURS       = max(FORECAST_HORIZONS_HOURS)
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m # --- ESI Levels ---
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m # Emergency Severity Index levels 1 (resuscitation) through 5
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m # (routine). The demo uses string keys to keep DynamoDB items
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m # readable; production typically uses numeric codes.
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m ESI_LEVELS = ["esi_1", "esi_2", "esi_3", "esi_4", "esi_5"]
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m # --- Prediction Interval Percentiles ---
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m # 80% interval drives most operational decisions. 95% interval
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m # is what the surge-plan trigger reads when deciding whether
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m # to call in additional staff. Production uses the model's
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m # native quantile output (DeepAR quantiles, statsmodels
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m # get_prediction confidence intervals) rather than reconstructing
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m # from a residual standard deviation, but the demo uses the
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m # z-score-and-sigma reconstruction for simplicity.
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m INTERVAL_Z_80 = Decimal("1.282")
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m INTERVAL_Z_95 = Decimal("1.960")
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m # --- Quality Gates ---
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m # Retraining produces a candidate model. The candidate must
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m # improve on the current production model (or at least not
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m # regress beyond a tolerance) before being promoted.
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m VOLUME_MAPE_REGRESSION_TOLERANCE = Decimal("0.20")  # +20% MAPE rejects
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m ACUITY_LOGLOSS_REGRESSION_TOLERANCE = Decimal("0.20")
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m # --- Synthetic Data ---
