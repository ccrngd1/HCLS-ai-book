[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m # not exist; see run_demo() at the bottom.
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m ADT_KINESIS_STREAM_NAME       = "ed-adt-registrations"
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m HOURLY_ARRIVALS_BUCKET        = "ed-forecast-arrivals-hourly"
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m WEATHER_BUCKET                = "ed-forecast-weather"
