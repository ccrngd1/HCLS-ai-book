[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m             self.metrics[key].append(m["Value"])
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m class MockStream:
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m     """In-memory stand-in for a Kinesis Data Stream of ADT records.
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m     Production reads HL7 v2 ADT-A04 messages (or FHIR
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m     Encounter resources) from a Kinesis Data Stream or
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m     Amazon HealthLake. The mock holds a list of pre-redacted
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m     arrival records so the demo can iterate them as if they
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m     arrived on the stream. Each record carries only the fields
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m     the aggregator needs: ed_id, arrival_ts (as ISO 8601 in the
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m     ED's local timezone), and esi_level (or None when triage
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m     has not yet assigned one).
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m     def __init__(self, name):
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m         self.name    = name
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m         self.records = []
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m 
