[0m[49m[38;5;10m+    785[0m:[38;5;10m[49m     print(f"  Sources contacted: {metadata.get('sources_contacted', 0)}")
[0m[49m[38;5;10m+    786[0m:[38;5;10m[49m     print(f"  Sources responded: {metadata.get('sources_responded', 0)}")
[0m[49m[38;5;10m+    787[0m:[38;5;10m[49m     print(f"  Sources timed out: {metadata.get('sources_timed_out', 0)}")
[0m[49m[38;5;10m+    788[0m:[38;5;10m[49m     print(f"  Total latency: {metadata.get('total_latency_ms', 0)}ms")
[0m[49m[38;5;10m+    789[0m:[38;5;10m[49m     print(f"  Results returned: {len(response.get('results', []))}")
