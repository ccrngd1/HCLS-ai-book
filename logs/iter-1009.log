[0m[49m[38;5;10m+    757[0m:[38;5;10m[49m     print(f"    Requester: {requester_institution} ({purpose})")
[0m[49m[38;5;10m+    758[0m:[38;5;10m[49m     print()
[0m[49m[38;5;10m+    759[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    760[0m:[38;5;10m[49m     # Build the federated query structure.
[0m[49m[38;5;10m+    761[0m:[38;5;10m[49m     federated_query = {
[0m[49m[38;5;10m+    762[0m:[38;5;10m[49m         "concept_code": drug_code,
[0m[49m[38;5;10m+    763[0m:[38;5;10m[49m         "relationship": "interacts_with",
[0m[49m[38;5;10m+    764[0m:[38;5;10m[49m         "context": context_code,
[0m[49m[38;5;10m+    765[0m:[38;5;10m[49m         "domains": ["drug_interactions"],
[0m[49m[38;5;10m+    766[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    767[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    768[0m:[38;5;10m[49m     # Build the requester context for authorization checks.
[0m[49m[38;5;10m+    769[0m:[38;5;10m[49m     requester_context = {
[0m[49m[38;5;10m+    770[0m:[38;5;10m[49m         "institution_id": requester_institution,
[0m[49m[38;5;10m+    771[0m:[38;5;10m[49m         "purpose": purpose,
[0m[49m[38;5;10m+    772[0m:[38;5;10m[49m         "user_role": "clinician",
[0m[49m[38;5;10m+    773[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    774[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    775[0m:[38;5;10m[49m     # Execute the federated query.
[0m[49m[38;5;10m+    776[0m:[38;5;10m[49m     print("Step 1: Finding relevant sources in federation catalog...")
[0m[49m[38;5;10m+    777[0m:[38;5;10m[49m     print("Step 2: Loading ontology mappings for each source...")
