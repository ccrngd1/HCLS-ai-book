[0m[49m[38;5;10m+     39[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     40[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+     41[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+     42[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     43[0m:[38;5;10m[49m # Structured logging. Never log PHI field values (patient IDs, diagnosis details).
[0m[49m[38;5;10m+     44[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+     45[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+     46[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     47[0m:[38;5;10m[49m # Retry config for AWS API calls.
[0m[49m[38;5;10m+     48[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+     49[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m # AWS clients
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m s3_client = boto3.client("s3", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m # Configuration
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m RESULTS_BUCKET = "multimorbidity-discovery-results"
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m DIAGNOSIS_DATA_KEY = "raw/diagnosis-history.parquet"
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m PATTERNS_TABLE = "discovered-patterns"
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m # Mining parameters
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m MIN_PREVALENCE = 0.01          # Conditions below 1% prevalence are excluded
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m MIN_SUPPORT = 0.005            # Minimum 0.5% of patients must have the combination
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m MAX_PATTERN_SIZE = 4           # Mine up to 4-condition combinations
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m MIN_LIFT = 1.5                 # Only keep patterns with lift above this threshold
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m FDR_THRESHOLD = 0.05           # Benjamini-Hochberg false discovery rate cutoff
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m BOOTSTRAP_ITERATIONS = 100     # Stability testing resamples
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m STABILITY_THRESHOLD = 0.80     # Pattern must appear in 80%+ of resamples
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m MIN_TEMPORAL_PATIENTS = 50     # Minimum patients for temporal sequence analysis
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m RANDOM_SEED = 42
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m ## Step 1: Generate Synthetic Diagnosis History
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m *The main recipe's Step 1 extracts longitudinal diagnosis data from the EHR and rolls up ICD-10 codes to clinical categories. Here we generate synthetic data that mimics what you'd get after that ETL step. The synthetic data embeds several known multi-morbidity patterns at elevated co-occurrence rates, so we can verify the mining recovers them.*
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m def generate_synthetic_diagnoses(n_patients=5000, random_state=42):
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m     Generate synthetic longitudinal diagnosis data with embedded multi-morbidity patterns.
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m     We create a population where certain condition combinations co-occur at rates
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m     higher than independence would predict. This lets us verify that the mining
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m     pipeline actually finds them.
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m     Embedded patterns:
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m     - Cardiorenal-metabolic: Diabetes + CKD + Heart Failure + Anemia (lift ~3.5)
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m     - Mental-physical: Depression + Chronic Pain + Substance Use (lift ~2.8)
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m     - Frailty triad: Osteoporosis + Falls + Cognitive Decline (lift ~3.0)
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m         DataFrame with columns: patient_id, condition, first_documented_date
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m     rng = np.random.default_rng(random_state)
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m     # Define condition categories and their base prevalences in an older population.
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m     # These are roughly realistic for a Medicare-age cohort.
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m     conditions = {
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m         "Hypertension": 0.55,
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m         "Hyperlipidemia": 0.45,
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m         "Type 2 Diabetes": 0.28,
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m         "Obesity": 0.35,
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m         "GERD": 0.20,
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m         "Osteoarthritis": 0.30,
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m         "Depression": 0.18,
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m         "Chronic Pain": 0.22,
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m         "CKD": 0.12,
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m         "Heart Failure": 0.09,
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m         "COPD": 0.11,
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m         "Atrial Fibrillation": 0.08,
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m         "Anemia": 0.10,
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m         "Osteoporosis": 0.12,
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m         "Substance Use Disorder": 0.06,
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m         "Cognitive Decline": 0.07,
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m         "Falls History": 0.09,
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m         "Peripheral Neuropathy": 0.08,
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m         "Sleep Apnea": 0.14,
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m         "Anxiety": 0.15,
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m     # Start with independent assignment based on prevalence.
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m     records = []
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m     base_date = datetime(2014, 1, 1)
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m     # Track which patients get which conditions for pattern injection.
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m     patient_conditions = {pid: set() for pid in range(n_patients)}
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m     # Assign conditions independently first.
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m     for pid in range(n_patients):
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m         for condition, prevalence in conditions.items():
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m             if rng.random() < prevalence:
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m                 patient_conditions[pid].add(condition)
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m                 # Random onset date within a 10-year window.
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m                 days_offset = int(rng.integers(0, 3650))
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m                 onset = base_date + timedelta(days=days_offset)
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m                 records.append({
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m                     "patient_id": f"PAT-{pid:05d}",
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m                     "condition": condition,
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m                     "first_documented_date": onset.strftime("%Y-%m-%d"),
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m                 })
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m     # Inject multi-morbidity patterns at elevated rates.
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m     # For patients who already have the "seed" condition, give them the
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m     # remaining conditions in the pattern with high probability.
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m     # Pattern 1: Cardiorenal-metabolic cascade
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m     # Diabetes → CKD → Anemia → Heart Failure (temporal ordering)
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m     pattern1 = ["Type 2 Diabetes", "CKD", "Anemia", "Heart Failure"]
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m     for pid in range(n_patients):
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m         if "Type 2 Diabetes" in patient_conditions[pid] and rng.random() < 0.35:
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m             # This patient gets the full cascade.
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m             cascade_start = base_date + timedelta(days=int(rng.integers(0, 1000)))
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m             for i, cond in enumerate(pattern1):
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m                 if cond not in patient_conditions[pid]:
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m                     patient_conditions[pid].add(cond)
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m                     # Each subsequent condition appears 1-3 years after the previous.
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m                     onset = cascade_start + timedelta(days=int(365 * (i * 1.5 + rng.random())))
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m                     records.append({
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m                         "patient_id": f"PAT-{pid:05d}",
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m                         "condition": cond,
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m                         "first_documented_date": onset.strftime("%Y-%m-%d"),
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m                     })
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m     # Pattern 2: Mental-physical overlap
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m     pattern2 = ["Depression", "Chronic Pain", "Substance Use Disorder"]
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m     for pid in range(n_patients):
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m         if "Depression" in patient_conditions[pid] and rng.random() < 0.30:
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m             onset_base = base_date + timedelta(days=int(rng.integers(0, 2000)))
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m             for i, cond in enumerate(pattern2):
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m                 if cond not in patient_conditions[pid]:
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m                     patient_conditions[pid].add(cond)
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m                     onset = onset_base + timedelta(days=int(365 * (i * 0.8 + rng.random())))
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m                     records.append({
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m                         "patient_id": f"PAT-{pid:05d}",
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m                         "condition": cond,
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m                         "first_documented_date": onset.strftime("%Y-%m-%d"),
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m                     })
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m     # Pattern 3: Frailty triad
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m     pattern3 = ["Osteoporosis", "Falls History", "Cognitive Decline"]
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m     for pid in range(n_patients):
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m         if "Osteoporosis" in patient_conditions[pid] and rng.random() < 0.32:
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m             onset_base = base_date + timedelta(days=int(rng.integers(1000, 3000)))
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m             for i, cond in enumerate(pattern3):
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m                 if cond not in patient_conditions[pid]:
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m                     patient_conditions[pid].add(cond)
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m                     onset = onset_base + timedelta(days=int(365 * (i * 1.2 + rng.random())))
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m                     records.append({
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m                         "patient_id": f"PAT-{pid:05d}",
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m                         "condition": cond,
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m                         "first_documented_date": onset.strftime("%Y-%m-%d"),
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m                     })
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m     df = pd.DataFrame(records)
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m     # Deduplicate: keep earliest onset per patient-condition pair.
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m     df["first_documented_date"] = pd.to_datetime(df["first_documented_date"])
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m     df = df.sort_values("first_documented_date").drop_duplicates(
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m         subset=["patient_id", "condition"], keep="first"
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m     ).reset_index(drop=True)
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m     logger.info("Generated %d diagnosis records for %d patients across %d conditions",
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m                 len(df), n_patients, df["condition"].nunique())
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m     return df
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m ## Step 2: Build Patient-Condition Matrix and Compute Baselines
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m *The main recipe's Step 2 constructs the binary patient-condition matrix and computes individual prevalences plus expected co-occurrence rates under independence. These baselines are essential for calculating lift. Without them, you'd just find that common conditions co-occur frequently (not a discovery).*
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m def build_patient_condition_matrix(diagnoses_df, min_prevalence=0.01):
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m     Transform longitudinal diagnosis records into a binary patient-condition matrix.
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m     Also computes individual condition prevalences and filters out rare conditions
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m     that lack statistical power for combination analysis.
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m         diagnoses_df: DataFrame with patient_id, condition, first_documented_date
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m         min_prevalence: Minimum fraction of patients who must have a condition
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m                         for it to be included in the analysis.
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m         Tuple of (binary_matrix DataFrame, prevalences dict, active_conditions list)
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m     # Pivot to binary matrix: rows = patients, columns = conditions, values = 0/1.
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m     binary_matrix = diagnoses_df.pivot_table(
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m         index="patient_id",
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m         columns="condition",
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m         aggfunc="size",  # count occurrences
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m         fill_value=0
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m     # Convert counts to binary (presence/absence).
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m     binary_matrix = (binary_matrix > 0).astype(int)
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m     n_patients = len(binary_matrix)
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m     logger.info("Patient-condition matrix: %d patients x %d conditions",
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m                 n_patients, binary_matrix.shape[1])
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m     # Compute prevalences.
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m     prevalences = (binary_matrix.sum() / n_patients).to_dict()
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m     # Filter to conditions meeting minimum prevalence.
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m     active_conditions = [
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m         cond for cond, prev in prevalences.items()
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m         if prev >= min_prevalence
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m     filtered_matrix = binary_matrix[active_conditions]
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m     logger.info("After prevalence filter (>= %.1f%%): %d conditions retained",
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m                 min_prevalence * 100, len(active_conditions))
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m     # Log the top conditions by prevalence for sanity checking.
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m     sorted_prev = sorted(prevalences.items(), key=lambda x: x[1], reverse=True)
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m     for cond, prev in sorted_prev[:5]:
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m         logger.info("  %s: %.1f%%", cond, prev * 100)
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m     return filtered_matrix, prevalences, active_conditions
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m ## Step 3: Association Rule Mining with FP-Growth
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m *The main recipe's Step 3 applies FP-Growth to find frequent condition combinations and computes lift, confidence, and leverage. FP-Growth is preferred over Apriori for dense datasets because it avoids expensive candidate generation. The mlxtend library provides a clean implementation that works directly with our binary DataFrame.*
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m def mine_association_rules(binary_matrix, min_support=0.005, max_len=4, min_lift=1.5):
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m     Run FP-Growth frequent itemset mining and compute association metrics.
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m     FP-Growth efficiently finds all condition combinations that appear in at
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m     least min_support fraction of patients. Then we compute lift, confidence,
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m     and leverage for each combination to identify those that co-occur more
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m     than chance would predict.
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m         binary_matrix: Binary patient-condition DataFrame (from Step 2)
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m         min_support: Minimum fraction of patients with the combination
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m         max_len: Maximum number of conditions in a pattern
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m         min_lift: Minimum lift to retain a pattern
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m         DataFrame of discovered patterns with association metrics
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m     n_patients = len(binary_matrix)
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m     # Run FP-Growth to find frequent itemsets.
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m     # This is the computationally expensive step. For 200k patients and 280 conditions,
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m     # you'd run this on a SageMaker Processing Job. For our 5k synthetic patients,
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m     # it runs in seconds locally.
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m     logger.info("Running FP-Growth (min_support=%.3f, max_len=%d)...", min_support, max_len)
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m     frequent_itemsets = fpgrowth(
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m         binary_matrix,
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m         min_support=min_support,
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m         max_len=max_len,
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m         use_colnames=True  # Use condition names instead of column indices
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m     if frequent_itemsets.empty:
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m         logger.warning("No frequent itemsets found. Try lowering min_support.")
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m         return pd.DataFrame()
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m     logger.info("Found %d frequent itemsets", len(frequent_itemsets))
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m     # Filter to multi-condition patterns (size >= 2).
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m     # Single conditions aren't "patterns" in the multi-morbidity sense.
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m     frequent_itemsets["size"] = frequent_itemsets["itemsets"].apply(len)
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m     multi_condition = frequent_itemsets[frequent_itemsets["size"] >= 2].copy()
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m     logger.info("Multi-condition itemsets (size >= 2): %d", len(multi_condition))
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m     # Compute association rules (lift, confidence, leverage).
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m     # We use lift as the primary metric because it normalizes for base rates.
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m     rules = association_rules(
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m         frequent_itemsets,
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m         metric="lift",
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m         min_threshold=min_lift
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m     if rules.empty:
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m         logger.warning("No rules above min_lift=%.1f. Try lowering threshold.", min_lift)
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m         return pd.DataFrame()
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m     # Also compute metrics for the full itemsets (not just antecedent→consequent rules).
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m     # For multi-morbidity, we care about the full combination, not directional rules.
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m     patterns = []
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m     for _, row in multi_condition.iterrows():
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m         itemset = frozenset(row["itemsets"])
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m         support = row["support"]
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m         patient_count = int(support * n_patients)
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m         # Compute expected support under independence.
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m         individual_prevalences = [
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m             binary_matrix[cond].mean() for cond in itemset
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m         ]
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m         expected_support = np.prod(individual_prevalences)
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m         # Lift: how much more often does this combination appear than expected?
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m         lift = support / expected_support if expected_support > 0 else 0
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m         # Leverage: absolute difference between observed and expected.
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m         leverage = support - expected_support
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m         if lift >= min_lift:
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m             patterns.append({
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m                 "conditions": sorted(list(itemset)),
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m                 "size": len(itemset),
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m                 "support": round(support, 4),
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m                 "patient_count": patient_count,
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m                 "expected_support": round(expected_support, 6),
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m                 "lift": round(lift, 2),
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m                 "leverage": round(leverage, 4),
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m     patterns_df = pd.DataFrame(patterns)
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m     patterns_df = patterns_df.sort_values("lift", ascending=False).reset_index(drop=True)
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m     logger.info("Patterns with lift >= %.1f: %d", min_lift, len(patterns_df))
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m     # Show top 5 for sanity check.
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m     for _, p in patterns_df.head(5).iterrows():
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m         logger.info("  %s | lift=%.2f | n=%d",
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m                     " + ".join(p["conditions"]), p["lift"], p["patient_count"])
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m     return patterns_df
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m ## Step 4: Temporal Sequence Analysis
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m *The main recipe's Step 4 analyzes the temporal ordering of condition acquisition within each discovered pattern. This is where multi-morbidity discovery gets genuinely interesting: knowing that diabetes typically precedes CKD by 4 years gives you a prevention window. Static co-occurrence alone doesn't tell you that.*
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m def analyze_temporal_sequences(patterns_df, diagnoses_df, min_patients=50):
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m     For each discovered pattern, determine the dominant temporal ordering
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m     of condition onset and compute inter-condition intervals.
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m     This transforms "these conditions co-occur" into "these conditions develop
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m     in this order with these time gaps," which is directly actionable for
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m     preventive care planning.
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m         patterns_df: DataFrame of discovered patterns (from Step 3)
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m         diagnoses_df: Original longitudinal diagnosis data with onset dates
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m         min_patients: Minimum patients with the full pattern for temporal analysis
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m         List of dicts with temporal analysis results for each pattern
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m     temporal_results = []
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m     for _, pattern_row in patterns_df.iterrows():
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m         conditions = pattern_row["conditions"]
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m         patient_count = pattern_row["patient_count"]
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m         if patient_count < min_patients:
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m         # Find patients who have ALL conditions in this pattern.
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m         pattern_diagnoses = diagnoses_df[diagnoses_df["condition"].isin(conditions)]
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m         # Group by patient and check who has the complete set.
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m         patient_cond_counts = pattern_diagnoses.groupby("patient_id")["condition"].nunique()
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m         complete_patients = patient_cond_counts[
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m             patient_cond_counts == len(conditions)
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m         ].index.tolist()
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m         if len(complete_patients) < min_patients:
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m         # For each complete patient, get the ordered sequence of condition onsets.
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m         sequences = []
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m         for pid in complete_patients:
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m             patient_data = pattern_diagnoses[pattern_diagnoses["patient_id"] == pid]
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m             # Sort by onset date to get temporal ordering.
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m             ordered = patient_data.sort_values("first_documented_date")
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m             sequence = ordered["condition"].tolist()
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m             sequences.append(sequence)
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m         # Find the most common ordering (dominant sequence).
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m         # Convert sequences to tuples for counting.
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m         sequence_tuples = [tuple(s) for s in sequences]
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m         from collections import Counter
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m         ordering_counts = Counter(sequence_tuples)
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m         dominant_ordering = ordering_counts.most_common(1)[0]
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m         dominant_sequence = list(dominant_ordering[0])
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m         dominant_fraction = dominant_ordering[1] / len(sequences)
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m         # Compute median inter-condition intervals for the dominant ordering.
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m         intervals = {}
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m         for i in range(len(dominant_sequence) - 1):
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m             cond_a = dominant_sequence[i]
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m             cond_b = dominant_sequence[i + 1]
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m             days_between = []
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m             for pid in complete_patients:
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m                 patient_data = pattern_diagnoses[pattern_diagnoses["patient_id"] == pid]
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m                 date_a = patient_data[patient_data["condition"] == cond_a][
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m                     "first_documented_date"
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m                 ].iloc[0]
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m                 date_b = patient_data[patient_data["condition"] == cond_b][
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m                     "first_documented_date"
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m                 ].iloc[0]
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m                 delta = (date_b - date_a).days
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m                 if delta > 0:  # Only count forward progressions.
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m                     days_between.append(delta)
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m             if days_between:
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m                 median_years = round(np.median(days_between) / 365.25, 1)
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m                 iqr_years = round(
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m                     (np.percentile(days_between, 75) - np.percentile(days_between, 25)) / 365.25,
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m                     1
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m                 )
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m                 intervals[f"{cond_a} → {cond_b}"] = {
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m                     "median_years": median_years,
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m                     "iqr_years": iqr_years,
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m                 }
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m         temporal_results.append({
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m             "conditions": conditions,
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m             "n_complete_patients": len(complete_patients),
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m             "dominant_ordering": dominant_sequence,
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m             "dominant_fraction": round(dominant_fraction, 2),
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m             "intervals": intervals,
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m             "n_alternative_orderings": len(ordering_counts) - 1,
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m         logger.info("Temporal: %s | dominant order: %s (%.0f%%)",
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m                     " + ".join(conditions),
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m                     " → ".join(dominant_sequence),
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m                     dominant_fraction * 100)
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m     logger.info("Temporal analysis complete for %d patterns", len(temporal_results))
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m     return temporal_results
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m ## Step 5: Comorbidity Network Construction and Community Detection
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m *The main recipe's Step 5 builds a graph where conditions are nodes and edges represent statistically significant co-occurrence. Community detection finds clusters of tightly connected conditions. In production, you'd store this in Amazon Neptune. Here we use networkx for the same algorithms.*
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m def build_comorbidity_network(patterns_df, prevalences, fdr_threshold=0.05, min_lift=1.5):
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m     Construct a comorbidity network from pairwise association patterns and
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m     run community detection to find multi-morbidity neighborhoods.
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m     Conditions become nodes. Edges connect conditions that co-occur significantly
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m     more than chance predicts (after FDR correction). Community detection groups
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m     conditions into clusters that may share underlying mechanisms.
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m         patterns_df: DataFrame of discovered patterns (from Step 3)
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m         prevalences: Dict of condition -> prevalence (from Step 2)
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m         fdr_threshold: Maximum adjusted p-value for edge inclusion
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m         min_lift: Minimum lift for edge inclusion
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m         Tuple of (networkx Graph, dict of community assignments)
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m     # Filter to pairwise patterns only (edges in the network).
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m     pairwise = patterns_df[patterns_df["size"] == 2].copy()
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m     if pairwise.empty:
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m         logger.warning("No pairwise patterns found for network construction.")
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m         return nx.Graph(), {}
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m     # Compute chi-squared p-values for each pair.
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m     # This tests whether the co-occurrence is statistically significant
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m     # beyond what prevalence alone would predict.
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m     p_values = []
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m     for _, row in pairwise.iterrows():
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m         # Chi-squared test of independence.
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m         # Observed: support * N patients have both conditions.
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m         # Expected: product of individual prevalences * N.
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m         observed = row["support"]
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m         expected = row["expected_support"]
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m         # Use a simple z-test approximation for large samples.
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m         # In production, you'd use the full chi-squared contingency test.
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m         n = row["patient_count"] / row["support"]  # total population
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m         se = np.sqrt(expected * (1 - expected) / n) if expected > 0 else 1
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m         z = (observed - expected) / se if se > 0 else 0
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m         p_value = 2 * (1 - stats.norm.cdf(abs(z)))  # two-tailed
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m         p_values.append(p_value)
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m     pairwise["p_value"] = p_values
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m     # Benjamini-Hochberg FDR correction.
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m     # When testing thousands of pairs, many will appear "significant" by chance.
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m     # FDR correction controls the expected proportion of false discoveries.
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m     sorted_indices = np.argsort(p_values)
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m     n_tests = len(p_values)
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m     adjusted_p = np.zeros(n_tests)
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m     for rank, idx in enumerate(sorted_indices, 1):
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m         adjusted_p[idx] = p_values[idx] * n_tests / rank
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m     # Enforce monotonicity (adjusted p-values should be non-decreasing).
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m     for i in range(n_tests - 2, -1, -1):
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m         adjusted_p[sorted_indices[i]] = min(
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m             adjusted_p[sorted_indices[i]],
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m             adjusted_p[sorted_indices[i + 1]] if i + 1 < n_tests else 1.0
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m     pairwise["adjusted_p"] = np.minimum(adjusted_p, 1.0)
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m     # Filter to significant edges.
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m     significant = pairwise[
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m         (pairwise["adjusted_p"] < fdr_threshold) & (pairwise["lift"] >= min_lift)
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m     logger.info("Network edges: %d significant pairs (of %d tested)",
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m                 len(significant), len(pairwise))
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m     # Build the graph.
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m     G = nx.Graph()
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m     # Add all conditions as nodes with prevalence as an attribute.
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m     for cond, prev in prevalences.items():
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m         G.add_node(cond, prevalence=prev)
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m     # Add significant co-occurrence relationships as weighted edges.
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m     for _, row in significant.iterrows():
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m         cond_a, cond_b = row["conditions"]
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m         G.add_edge(cond_a, cond_b, weight=row["lift"], support=row["support"])
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m     # Remove isolated nodes (conditions with no significant connections).
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m     isolates = list(nx.isolates(G))
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m     G.remove_nodes_from(isolates)
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m     logger.info("Network: %d nodes, %d edges (removed %d isolates)",
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m                 G.number_of_nodes(), G.number_of_edges(), len(isolates))
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m     # Community detection using Louvain algorithm.
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m     # Finds groups of conditions more densely connected to each other
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m     # than to the rest of the network. These communities represent
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m     # multi-morbidity "neighborhoods."
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m     communities_list = louvain_communities(G, weight="weight", seed=RANDOM_SEED)
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m     # Convert to node -> community_id mapping.
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m     community_map = {}
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m     for comm_id, members in enumerate(communities_list):
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m         for node in members:
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m             community_map[node] = comm_id
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m     # Assign community labels to nodes.
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m     nx.set_node_attributes(G, community_map, "community")
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m     logger.info("Detected %d communities:", len(communities_list))
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m     for comm_id, members in enumerate(communities_list):
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m         logger.info("  Community %d: %s", comm_id, ", ".join(sorted(members)))
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m     return G, community_map
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m ## Step 6: Statistical Validation and Stability Testing
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m *The main recipe's Step 6 applies rigorous statistical filters to separate genuine patterns from artifacts of demographics or multiple testing. Bootstrap resampling tests whether patterns are stable or just noise from a particular sample. Patterns that survive validation are genuinely surprising given the population's characteristics.*
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m def validate_patterns(patterns_df, binary_matrix, min_lift_adjusted=1.3):
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m     Validate discovered patterns through bootstrap stability testing.
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m     A pattern is "stable" if it appears consistently across random resamples
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m     of the patient population. Unstable patterns may be artifacts of the
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m     specific sample rather than genuine population-level associations.
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m     In production, you'd also stratify by age/sex and adjust for healthcare
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m     utilization (see the main recipe's Step 6 for the full validation approach).
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m     Here we demonstrate the bootstrap stability component.
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m         patterns_df: DataFrame of discovered patterns
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m         binary_matrix: Binary patient-condition matrix
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m         min_lift_adjusted: Minimum lift threshold for validation
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m         DataFrame of validated patterns with stability scores
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m     validated = []
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m     n_patients = len(binary_matrix)
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m     for _, pattern_row in patterns_df.iterrows():
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m         conditions = pattern_row["conditions"]
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m         # Bootstrap stability test.
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m         # Resample patients with replacement and recompute lift each time.
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m         # If the pattern's lift stays above threshold in 80%+ of resamples,
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m         # it's stable.
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m         stable_count = 0
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m         for i in range(BOOTSTRAP_ITERATIONS):
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m             # Resample patients with replacement.
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m             sample_indices = np.random.choice(
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m                 n_patients, size=int(n_patients * 0.8), replace=True
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m             sample = binary_matrix.iloc[sample_indices]
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m             # Compute support in this resample.
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m             # A patient "has the pattern" if they have ALL conditions.
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m             has_all = sample[conditions].all(axis=1)
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m             sample_support = has_all.mean()
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m             # Compute expected support under independence.
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m             individual_prevs = [sample[c].mean() for c in conditions]
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m             expected = np.prod(individual_prevs)
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m             # Compute lift.
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m             sample_lift = sample_support / expected if expected > 0 else 0
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m             if sample_lift >= min_lift_adjusted:
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m                 stable_count += 1
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m         stability = stable_count / BOOTSTRAP_ITERATIONS
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m         if stability >= STABILITY_THRESHOLD:
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m             validated.append({
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m                 **pattern_row.to_dict(),
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m                 "stability": round(stability, 2),
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m             logger.info("  VALIDATED: %s | lift=%.2f | stability=%.2f",
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m                         " + ".join(conditions), pattern_row["lift"], stability)
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m             logger.info("  REJECTED (unstable): %s | stability=%.2f",
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m                         " + ".join(conditions), stability)
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m     validated_df = pd.DataFrame(validated)
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m     logger.info("Validation complete: %d of %d patterns survived",
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m                 len(validated_df), len(patterns_df))
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m     return validated_df
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m ## Step 7: Store Results to S3 and DynamoDB
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m *This step persists the validated patterns and temporal analysis to S3 (for batch analytics and QuickSight dashboards) and DynamoDB (for real-time lookup by clinical applications). In production, you'd also write the network to Neptune for interactive graph exploration.*
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m def store_results(validated_patterns, temporal_results, network_graph, community_map):
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m     Persist discovery results to S3 and DynamoDB.
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m     S3 gets the full analysis output (patterns, temporal sequences, network metrics)
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m     for downstream analytics and visualization. DynamoDB gets individual pattern
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m     records for real-time lookup by clinical decision support systems.
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m         validated_patterns: DataFrame of validated multi-morbidity patterns
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m         temporal_results: List of temporal analysis dicts
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m         network_graph: networkx Graph of the comorbidity network
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m         community_map: Dict mapping conditions to community IDs
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m     timestamp = datetime.now(timezone.utc).isoformat()
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m     # --- Store full results to S3 ---
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m     results_payload = {
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m         "analysis_timestamp": timestamp,
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m         "n_validated_patterns": len(validated_patterns),
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m         "patterns": validated_patterns.to_dict(orient="records"),
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m         "temporal_sequences": temporal_results,
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m         "network_summary": {
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m             "n_nodes": network_graph.number_of_nodes(),
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m             "n_edges": network_graph.number_of_edges(),
