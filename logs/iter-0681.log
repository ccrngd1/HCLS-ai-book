[0m[49m[38;5;10m+     31[0m:[38;5;10m[49m from itertools import combinations
[0m[49m[38;5;10m+     32[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     33[0m:[38;5;10m[49m import numpy as np
[0m[49m[38;5;10m+     34[0m:[38;5;10m[49m import pandas as pd
