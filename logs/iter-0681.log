[0m[49m[38;5;10m+    858[0m:[38;5;10m[49m     np.random.seed(RANDOM_SEED)
[0m[49m[38;5;10m+    859[0m:[38;5;10m[49m     validated_df = validate_patterns(patterns_df, binary_matrix)
