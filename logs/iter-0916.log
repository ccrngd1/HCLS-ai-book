[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m RESULTS_TABLE = "pathology-analysis-results"
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m METADATA_TABLE = "pathology-slide-metadata"
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m ANALYSIS_QUEUE = "pathology-analysis-queue"
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m SAGEMAKER_MODEL_NAME = "pathology-feature-extractor"
