[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m     # Generate a unique slide ID for tracking
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m     slide_id = f"WSI-{datetime.date.today().isoformat()}-{uuid.uuid4().hex[:8]}"
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m 
