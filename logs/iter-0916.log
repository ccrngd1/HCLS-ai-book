[0m[49m[38;5;10m+     29[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     30[0m:[38;5;10m[49m # Patch extraction parameters.
[0m[49m[38;5;10m+     31[0m:[38;5;10m[49m # 256x256 at 20x magnification is the standard for most pathology foundation models.
[0m[49m[38;5;10m+     32[0m:[38;5;10m[49m # Larger patches (512x512) capture more context but require more GPU memory per batch.
[0m[49m[38;5;10m+     33[0m:[38;5;10m[49m # Smaller patches (128x128) are faster but lose architectural context.
[0m[49m[38;5;10m+     34[0m:[38;5;10m[49m PATCH_SIZE = 256
[0m[49m[38;5;10m+     35[0m:[38;5;10m[49m TARGET_MAGNIFICATION = 20
[0m[49m[38;5;10m+     36[0m:[38;5;10m[49m TISSUE_THRESHOLD = 0.5  # minimum fraction of patch that must be tissue to include it
[0m[49m[38;5;10m+     37[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     38[0m:[38;5;10m[49m # Feature extraction model configuration.
[0m[49m[38;5;10m+     39[0m:[38;5;10m[49m # The feature dimension depends on your chosen foundation model.
[0m[49m[38;5;10m+     40[0m:[38;5;10m[49m # Most pathology foundation models output 768-2048 dimensional vectors.
[0m[49m[38;5;10m+     41[0m:[38;5;10m[49m FEATURE_DIM = 1024
[0m[49m[38;5;10m+     42[0m:[38;5;10m[49m BATCH_SIZE = 64  # patches per GPU inference batch
[0m[49m[38;5;10m+     43[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     44[0m:[38;5;10m[49m # Confidence threshold for flagging uncertain predictions.
[0m[49m[38;5;10m+     45[0m:[38;5;10m[49m # Below this, the result goes to a pathologist review queue rather than
[0m[49m[38;5;10m+     46[0m:[38;5;10m[49m # being presented as a confident AI finding.
[0m[49m[38;5;10m+     47[0m:[38;5;10m[49m CONFIDENCE_THRESHOLD = 0.80
[0m[49m[38;5;10m+     48[0m:[38;5;10m[49m 
