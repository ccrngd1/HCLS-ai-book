[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m     table = dynamodb.Table(METADATA_TABLE)
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m     table.put_item(Item={
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m         "slide_id": slide_id,
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m         "s3_path": f"s3://{bucket}/{key}",
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m         "scanner_model": scanner_model,
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m         "magnification": magnification,
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m         "width": width,
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m         "height": height,
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m         "stain_type": stain_type,
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m         "file_size_bytes": file_size,
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m         "status": "QUEUED",
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m         "ingested_at": datetime.datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m     # Queue for analysis
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m     sqs_client.send_message(
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m         QueueUrl=ANALYSIS_QUEUE,
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m         MessageBody=json.dumps({
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m             "slide_id": slide_id,
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m             "s3_path": f"s3://{bucket}/{key}",
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m             "magnification": magnification,
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m             "width": width,
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m             "height": height,
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m         }),
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m     logger.info("Ingested slide %s (%dx%d, %s)", slide_id, width, height, stain_type)
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m     return slide_id
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m ## Step 2: Tissue Detection
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m *Maps to pseudocode Step 2: `detect_tissue(slide_id, s3_path)`. Identifies which regions of the slide contain tissue vs. empty glass. Uses a low-resolution thumbnail to avoid loading the full gigapixel image.*
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m from PIL import Image
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m import io
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m def detect_tissue(slide_id: str, thumbnail_bytes: bytes) -> tuple[np.ndarray, float]:
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m     Generate a binary tissue mask from a low-resolution slide thumbnail.
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m     In production, you'd read the lowest pyramid level of the WSI file using
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m     openslide or a similar library. Here we accept pre-extracted thumbnail bytes
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m     (which you'd get via a byte-range read of the WSI's lowest resolution level).
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m     The approach: convert to HSV color space, threshold on saturation.
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m     H&E-stained tissue has distinct saturation (pink/purple) compared to
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m     background glass (white, near-zero saturation). Otsu's method finds the
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m     optimal threshold automatically.
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m         slide_id:        Slide identifier for logging
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m         thumbnail_bytes: Raw image bytes of the slide thumbnail (lowest pyramid level)
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m         Tuple of (tissue_mask as numpy array, tissue_fraction as float)
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m     # Load the thumbnail image
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m     image = Image.open(io.BytesIO(thumbnail_bytes)).convert("RGB")
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m     img_array = np.array(image)
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m     # Convert RGB to HSV. We care about the saturation channel.
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m     # Tissue (stained pink/purple) has high saturation.
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m     # Background glass (white/clear) has near-zero saturation.
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     # This is more robust than simple grayscale thresholding because it
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m     # handles slides with varying brightness levels.
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m     from PIL import ImageFilter
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m     hsv_image = image.convert("HSV")
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m     hsv_array = np.array(hsv_image)
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m     saturation = hsv_array[:, :, 1]  # saturation channel
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m     # Otsu thresholding: automatically find the optimal threshold that
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m     # separates the two populations (tissue vs. background).
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m     # This is a histogram-based method that minimizes intra-class variance.
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m     threshold = _otsu_threshold(saturation)
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m     tissue_mask = saturation > threshold
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m     # Morphological cleanup.
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m     # Close small gaps (a tiny hole in tissue is still tissue).
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m     # Remove small isolated specks (dust, scanner artifacts).
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m     tissue_mask = _morphological_close(tissue_mask, kernel_size=5)
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m     tissue_mask = _remove_small_objects(tissue_mask, min_pixels=100)
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m     # Calculate tissue fraction
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m     tissue_fraction = float(np.sum(tissue_mask)) / tissue_mask.size
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m     if tissue_fraction < 0.05:
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m         logger.warning(
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m             "Slide %s has only %.1f%% tissue. Possible blank slide or failed scan.",
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m             slide_id, tissue_fraction * 100
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m         "Tissue detection for %s: %.1f%% tissue, mask shape %s",
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m         slide_id, tissue_fraction * 100, tissue_mask.shape
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m     return tissue_mask, tissue_fraction
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m def _otsu_threshold(channel: np.ndarray) -> int:
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m     Compute Otsu's threshold for a single-channel image.
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m     Finds the threshold that minimizes the weighted sum of intra-class variances
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m     for the two groups (foreground and background). This is the standard approach
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m     for automatic thresholding when you have a bimodal histogram.
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m     # Build histogram (256 bins for 8-bit image)
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m     hist, _ = np.histogram(channel.ravel(), bins=256, range=(0, 256))
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m     total_pixels = channel.size
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m     # Compute cumulative sums and means for all possible thresholds
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m     sum_total = np.sum(np.arange(256) * hist)
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m     sum_background = 0.0
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m     weight_background = 0
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m     max_variance = 0.0
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m     best_threshold = 0
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m     for t in range(256):
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m         weight_background += hist[t]
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m         if weight_background == 0:
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m         weight_foreground = total_pixels - weight_background
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m         if weight_foreground == 0:
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m             break
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m         sum_background += t * hist[t]
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m         mean_background = sum_background / weight_background
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m         mean_foreground = (sum_total - sum_background) / weight_foreground
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m         # Between-class variance
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m         variance = weight_background * weight_foreground * (mean_background - mean_foreground) ** 2
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m         if variance > max_variance:
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m             max_variance = variance
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m             best_threshold = t
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m     return best_threshold
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m def _morphological_close(mask: np.ndarray, kernel_size: int) -> np.ndarray:
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m     Morphological closing: dilate then erode. Fills small holes in tissue regions.
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m     from scipy import ndimage
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m     structure = np.ones((kernel_size, kernel_size))
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m     closed = ndimage.binary_dilation(mask, structure=structure)
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m     closed = ndimage.binary_erosion(closed, structure=structure)
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m     return closed
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m def _remove_small_objects(mask: np.ndarray, min_pixels: int) -> np.ndarray:
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m     Remove connected components smaller than min_pixels.
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m     Eliminates dust specks and scanner artifacts.
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m     from scipy import ndimage
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m     labeled, num_features = ndimage.label(mask)
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m     for i in range(1, num_features + 1):
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m         if np.sum(labeled == i) < min_pixels:
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m             mask[labeled == i] = False
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m     return mask
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m ## Step 3: Patch Coordinate Generation
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m *Maps to pseudocode Step 3: `generate_patch_coordinates(slide_id, tissue_mask, slide_metadata)`. Determines which patches to extract from the full-resolution image based on the tissue mask.*
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m def generate_patch_coordinates(
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m     slide_id: str,
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m     tissue_mask: np.ndarray,
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m     slide_width: int,
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m     slide_height: int,
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m ) -> list[dict]:
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m     Generate a list of (x, y) coordinates for patches that overlap with tissue.
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m     Maps the low-resolution tissue mask back to full-resolution coordinates
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m     and produces a manifest of patches to extract. Only patches where at least
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m     TISSUE_THRESHOLD fraction is tissue get included.
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m     A typical slide produces 10,000-50,000 patch coordinates. Each one will
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m     become a separate inference call in the feature extraction step.
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m         slide_id:     Slide identifier for logging
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m         tissue_mask:  Binary mask from detect_tissue (low-resolution)
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m         slide_width:  Full-resolution slide width in pixels
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m         slide_height: Full-resolution slide height in pixels
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m         List of patch coordinate dicts with x, y, width, height fields.
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m     mask_h, mask_w = tissue_mask.shape
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m     # Scale factors between mask coordinates and full-resolution coordinates
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m     scale_x = slide_width / mask_w
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m     scale_y = slide_height / mask_h
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m     # How many mask pixels correspond to one patch at full resolution?
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m     patch_mask_w = max(1, int(PATCH_SIZE / scale_x))
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m     patch_mask_h = max(1, int(PATCH_SIZE / scale_y))
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m     coordinates = []
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m     # Walk a grid across the tissue mask
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m     for mask_y in range(0, mask_h, patch_mask_h):
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m         for mask_x in range(0, mask_w, patch_mask_w):
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m             # Extract the mask region corresponding to this patch
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m             region = tissue_mask[
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m                 mask_y : mask_y + patch_mask_h,
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m                 mask_x : mask_x + patch_mask_w
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m             ]
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m             # Check tissue overlap
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m             if region.size == 0:
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m             tissue_overlap = float(np.sum(region)) / region.size
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m             if tissue_overlap >= TISSUE_THRESHOLD:
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m                 # Convert back to full-resolution coordinates
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m                 full_x = int(mask_x * scale_x)
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m                 full_y = int(mask_y * scale_y)
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m                 coordinates.append({
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m                     "x": full_x,
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m                     "y": full_y,
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m                     "width": PATCH_SIZE,
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m                     "height": PATCH_SIZE,
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m                 })
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m         "Generated %d patch coordinates for slide %s (from %dx%d mask)",
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m         len(coordinates), slide_id, mask_w, mask_h
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m     return coordinates
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m ## Step 4: Feature Extraction via SageMaker Batch Transform
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m *Maps to pseudocode Step 4: `extract_features(slide_id, s3_path, patch_coordinates)`. This is the GPU-intensive step. In production, you'd use SageMaker Batch Transform to process thousands of patches through a pre-trained pathology foundation model. Here we show how to set up and monitor that job.*
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m import time
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m sagemaker_client = boto3.client("sagemaker", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m def prepare_patch_manifest(slide_id: str, coordinates: list[dict]) -> str:
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m     Write the patch coordinate manifest to S3 as input for SageMaker Batch Transform.
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m     The manifest tells SageMaker which patches to extract and process.
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m     Each line is a JSON object with the patch location. The SageMaker
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m     inference container reads these, extracts the corresponding image region
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m     from the WSI, runs it through the model, and writes feature vectors.
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m         The S3 URI of the manifest file.
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m     manifest_key = f"manifests/{slide_id}/patch-manifest.jsonl"
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m     # Write as JSON Lines (one JSON object per line)
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m     lines = [json.dumps(coord) for coord in coordinates]
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m     manifest_body = "\n".join(lines)
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m     s3_client.put_object(
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m         Bucket=FEATURE_BUCKET,
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m         Key=manifest_key,
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m         Body=manifest_body.encode("utf-8"),
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m         ContentType="application/jsonl",
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m         ServerSideEncryption="aws:kms",
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m     return f"s3://{FEATURE_BUCKET}/{manifest_key}"
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m def start_feature_extraction(slide_id: str, manifest_uri: str) -> str:
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m     Launch a SageMaker Batch Transform job to extract features from all patches.
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m     Batch Transform is more cost-effective than a real-time endpoint for pathology
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m     because: (1) slides arrive in bursts, not continuously, (2) latency requirements
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m     are minutes not milliseconds, and (3) you can use spot instances for batch jobs.
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m     The inference container is expected to:
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m     1. Read patch coordinates from the manifest
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m     2. Extract each patch from the WSI (via byte-range reads to S3)
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m     3. Apply stain normalization
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m     4. Run the patch through the feature extractor model
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m     5. Write feature vectors to the output location
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m         The SageMaker transform job name for status polling.
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m     job_name = f"pathology-features-{slide_id}"
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m     output_uri = f"s3://{FEATURE_BUCKET}/features/{slide_id}/"
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m     sagemaker_client.create_transform_job(
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m         TransformJobName=job_name,
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m         ModelName=SAGEMAKER_MODEL_NAME,
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m         TransformInput={
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m             "DataSource": {
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m                 "S3DataSource": {
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m                     "S3DataType": "S3Prefix",
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m                     "S3Uri": manifest_uri,
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m                 }
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m             },
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m             "ContentType": "application/jsonl",
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m             "SplitType": "Line",  # each line is one inference request
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m         TransformOutput={
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m             "S3OutputPath": output_uri,
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m             "AssembleWith": "Line",
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m             "KmsKeyId": "alias/pathology-data-key",  # encrypt output at rest
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m         TransformResources={
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m             "InstanceType": "ml.g4dn.xlarge",  # NVIDIA T4 GPU, good price/performance
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m             "InstanceCount": 1,
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m             # For large slides (50K+ patches), increase to 2-4 instances.
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m             # SageMaker distributes the manifest across instances automatically.
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m         MaxPayloadInMB=6,  # each patch is small; keep payload size reasonable
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m         BatchStrategy="MultiRecord",  # process multiple patches per request
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m     logger.info("Started SageMaker transform job: %s", job_name)
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m     return job_name
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m def wait_for_feature_extraction(job_name: str, timeout_minutes: int = 30) -> str:
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m     Poll the SageMaker Batch Transform job until completion.
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m     In production, you'd use Step Functions with a Wait state and a
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m     DescribeTransformJob task rather than polling in a loop. This is
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m     the simplified version for illustration.
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m         The S3 URI where feature vectors were written.
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m     deadline = time.time() + (timeout_minutes * 60)
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m     while time.time() < deadline:
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m         response = sagemaker_client.describe_transform_job(
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m             TransformJobName=job_name
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m         status = response["TransformJobStatus"]
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m         if status == "Completed":
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m             output_uri = response["TransformOutput"]["S3OutputPath"]
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m             logger.info("Feature extraction complete: %s", output_uri)
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m             return output_uri
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m         if status == "Failed":
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m             reason = response.get("FailureReason", "Unknown")
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m             raise RuntimeError(
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m                 f"Feature extraction job {job_name} failed: {reason}"
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m         if status == "Stopped":
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m             raise RuntimeError(f"Feature extraction job {job_name} was stopped")
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m         # Still running. Wait before polling again.
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m         logger.info("Job %s status: %s. Waiting...", job_name, status)
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m         time.sleep(30)
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m     raise TimeoutError(
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m         f"Feature extraction job {job_name} did not complete within {timeout_minutes} minutes"
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m ## Step 5: MIL Aggregation and Classification
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m *Maps to pseudocode Step 5: `aggregate_and_classify(slide_id, features, patch_coordinates)`. Takes the bag of patch features and produces a slide-level prediction using attention-based Multiple Instance Learning. The attention weights tell us which patches the model considers most diagnostic.*
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m def load_features_from_s3(slide_id: str, features_uri: str) -> np.ndarray:
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m     Load the feature vectors produced by SageMaker Batch Transform.
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m     The output is a numpy array of shape [num_patches, FEATURE_DIM].
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m     Each row is the feature vector for one patch.
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m     # List all output files in the features directory
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m     prefix = f"features/{slide_id}/"
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m     response = s3_client.list_objects_v2(Bucket=FEATURE_BUCKET, Prefix=prefix)
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m     all_features = []
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m     for obj in response.get("Contents", []):
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m         # Read each output file (SageMaker may split across multiple files)
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m         body = s3_client.get_object(Bucket=FEATURE_BUCKET, Key=obj["Key"])["Body"]
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m         content = body.read().decode("utf-8")
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m         # Each line is a JSON array representing one feature vector
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m         for line in content.strip().split("\n"):
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m             if line:
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m                 feature_vector = json.loads(line)
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m                 all_features.append(feature_vector)
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m     features = np.array(all_features, dtype=np.float32)
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m     logger.info("Loaded features: shape %s", features.shape)
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m     return features
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m def attention_mil_aggregate(features: np.ndarray) -> tuple[dict, np.ndarray]:
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m     Attention-based Multiple Instance Learning aggregation.
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m     This is a simplified version of the Ilse et al. (2018) attention MIL mechanism.
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m     In production, this would be a trained PyTorch/TensorFlow model loaded from
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m     a model artifact. Here we simulate the forward pass to show the data flow.
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m     The key idea: each patch gets an attention weight (0 to 1) indicating how
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m     important it is for the slide-level prediction. The final prediction is a
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m     weighted sum of patch features, where the weights are learned during training.
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m     In a real deployment, this model is small enough to run on CPU (it's just
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m     matrix multiplications over the pre-computed features). The GPU-heavy work
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m     was done in Step 4.
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m         features: numpy array of shape [num_patches, FEATURE_DIM]
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m         Tuple of (prediction_dict, attention_weights)
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m         - prediction_dict: {"benign": prob, "malignant": prob}
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m         - attention_weights: array of shape [num_patches] with values 0-1
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m     num_patches = features.shape[0]
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m     # --- Simulated MIL forward pass ---
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m     # In production, these weight matrices come from a trained model checkpoint.
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m     # The attention mechanism learns which morphological features (encoded in the
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m     # feature vectors) are most indicative of malignancy.
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m     # Attention network: projects features to attention scores
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m     # Real architecture: features -> tanh(V * features) -> w^T -> softmax
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m     np.random.seed(42)  # deterministic for illustration
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m     attention_v = np.random.randn(FEATURE_DIM, 128).astype(np.float32) * 0.01
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m     attention_w = np.random.randn(128, 1).astype(np.float32) * 0.01
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m     # Compute attention scores
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m     hidden = np.tanh(features @ attention_v)  # [num_patches, 128]
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m     raw_attention = (hidden @ attention_w).squeeze()  # [num_patches]
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m     # Softmax to get normalized attention weights (sum to 1)
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m     exp_attention = np.exp(raw_attention - np.max(raw_attention))
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m     attention_weights = exp_attention / np.sum(exp_attention)
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m     # Weighted aggregation: slide-level representation
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m     slide_representation = attention_weights @ features  # [FEATURE_DIM]
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m     # Classification head: slide representation -> class probabilities
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m     classifier_w = np.random.randn(FEATURE_DIM, 2).astype(np.float32) * 0.01
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m     classifier_b = np.array([0.1, -0.1], dtype=np.float32)
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m     logits = slide_representation @ classifier_w + classifier_b
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m     # Softmax for class probabilities
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m     exp_logits = np.exp(logits - np.max(logits))
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m     probabilities = exp_logits / np.sum(exp_logits)
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m     prediction = {
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m         "benign": float(round(probabilities[0], 4)),
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m         "malignant": float(round(probabilities[1], 4)),
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m     return prediction, attention_weights
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m def generate_heatmap(
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m     patch_coordinates: list[dict],
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m     attention_weights: np.ndarray,
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m     top_k_percentile: float = 95.0,
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m ) -> list[dict]:
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m     Map attention weights back to slide coordinates for visualization.
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m     The heatmap shows the pathologist which regions the model focused on.
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m     Patches in the top 5% of attention are marked as "regions of interest" (ROIs).
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m     These are the areas the pathologist should examine first.
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m         List of dicts with x, y, attention, and is_roi fields.
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m     threshold = float(np.percentile(attention_weights, top_k_percentile))
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m     heatmap = []
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m     for i, coord in enumerate(patch_coordinates):
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m         weight = float(attention_weights[i])
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m         heatmap.append({
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m             "x": coord["x"],
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m             "y": coord["y"],
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m             "width": coord["width"],
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m             "height": coord["height"],
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m             "attention": round(weight, 6),
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m             "is_roi": weight >= threshold,
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m     num_rois = sum(1 for h in heatmap if h["is_roi"])
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m     logger.info("Heatmap: %d total patches, %d ROIs (top %.0f%%)",
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m                 len(heatmap), num_rois, 100 - top_k_percentile)
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m     return heatmap
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m ## Step 6: Store Results
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m *Writes the final prediction, confidence, and heatmap to DynamoDB. Updates the slide status to COMPLETED.*
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m def store_results(
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m     slide_id: str,
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m     prediction: dict,
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m     attention_weights: np.ndarray,
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m     heatmap: list[dict],
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m     num_patches: int,
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m     tissue_fraction: float,
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m     processing_start: datetime.datetime,
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m     Write analysis results to DynamoDB and update slide status.
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m     The results record is what the pathologist viewer queries to display
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m     AI findings alongside the slide image.
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m         slide_id:          Unique slide identifier
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m         prediction:        Class probability dict (e.g., {"benign": 0.08, "malignant": 0.92})
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m         attention_weights: Raw attention array (stored as S3 reference, not inline)
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m         heatmap:           List of patch coordinates with attention and ROI flags
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m         num_patches:       Total patches analyzed
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m         tissue_fraction:   Fraction of slide that was tissue
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m         processing_start:  When processing began (for latency tracking)
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m         The stored result record.
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m     # Determine the predicted class and confidence
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m     predicted_class = max(prediction, key=prediction.get)
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m     confidence = prediction[predicted_class]
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m     # Extract just the ROI patches for the summary (full heatmap stored separately)
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m     top_regions = [h for h in heatmap if h["is_roi"]]
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m     # Store the full heatmap as a separate S3 object (too large for DynamoDB item)
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m     heatmap_key = f"heatmaps/{slide_id}/attention-heatmap.json"
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m     s3_client.put_object(
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m         Bucket=FEATURE_BUCKET,
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m         Key=heatmap_key,
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m         Body=json.dumps(heatmap).encode("utf-8"),
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m         ContentType="application/json",
[0m[49m[38;5;10m+    717[0m:[38;5;10m[49m         ServerSideEncryption="aws:kms",
[0m[49m[38;5;10m+    718[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    719[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    720[0m:[38;5;10m[49m     processing_time = (datetime.datetime.now(timezone.utc) - processing_start).total_seconds()
[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m     # Write the results record
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m     # DynamoDB requires Decimal for numeric values, not float.
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m     results_table = dynamodb.Table(RESULTS_TABLE)
[0m[49m[38;5;10m+    725[0m:[38;5;10m[49m     result_record = {
[0m[49m[38;5;10m+    726[0m:[38;5;10m[49m         "slide_id": slide_id,
[0m[49m[38;5;10m+    727[0m:[38;5;10m[49m         "prediction": predicted_class,
[0m[49m[38;5;10m+    728[0m:[38;5;10m[49m         "confidence": Decimal(str(round(confidence, 4))),
[0m[49m[38;5;10m+    729[0m:[38;5;10m[49m         "class_probabilities": {
[0m[49m[38;5;10m+    730[0m:[38;5;10m[49m             k: Decimal(str(round(v, 4))) for k, v in prediction.items()
[0m[49m[38;5;10m+    731[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    732[0m:[38;5;10m[49m         "num_patches_analyzed": num_patches,
[0m[49m[38;5;10m+    733[0m:[38;5;10m[49m         "tissue_fraction": Decimal(str(round(tissue_fraction, 4))),
[0m[49m[38;5;10m+    734[0m:[38;5;10m[49m         "processing_time_seconds": Decimal(str(round(processing_time, 1))),
[0m[49m[38;5;10m+    735[0m:[38;5;10m[49m         "top_regions": top_regions[:10],  # store top 10 ROIs inline
[0m[49m[38;5;10m+    736[0m:[38;5;10m[49m         "heatmap_path": f"s3://{FEATURE_BUCKET}/{heatmap_key}",
[0m[49m[38;5;10m+    737[0m:[38;5;10m[49m         "model_version": SAGEMAKER_MODEL_NAME,
[0m[49m[38;5;10m+    738[0m:[38;5;10m[49m         "needs_review": confidence < CONFIDENCE_THRESHOLD,
[0m[49m[38;5;10m+    739[0m:[38;5;10m[49m         "completed_at": datetime.datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    740[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    741[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    742[0m:[38;5;10m[49m     results_table.put_item(Item=result_record)
[0m[49m[38;5;10m+    743[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    744[0m:[38;5;10m[49m     # Update slide status in metadata table
[0m[49m[38;5;10m+    745[0m:[38;5;10m[49m     metadata_table = dynamodb.Table(METADATA_TABLE)
[0m[49m[38;5;10m+    746[0m:[38;5;10m[49m     metadata_table.update_item(
[0m[49m[38;5;10m+    747[0m:[38;5;10m[49m         Key={"slide_id": slide_id},
[0m[49m[38;5;10m+    748[0m:[38;5;10m[49m         UpdateExpression="SET #s = :status, completed_at = :ts",
[0m[49m[38;5;10m+    749[0m:[38;5;10m[49m         ExpressionAttributeNames={"#s": "status"},
[0m[49m[38;5;10m+    750[0m:[38;5;10m[49m         ExpressionAttributeValues={
[0m[49m[38;5;10m+    751[0m:[38;5;10m[49m             ":status": "COMPLETED",
[0m[49m[38;5;10m+    752[0m:[38;5;10m[49m             ":ts": datetime.datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    753[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    754[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    755[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    756[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    757[0m:[38;5;10m[49m         "Stored results for %s: %s (confidence %.2f, %d patches, %.0fs)",
[0m[49m[38;5;10m+    758[0m:[38;5;10m[49m         slide_id, predicted_class, confidence, num_patches, processing_time
[0m[49m[38;5;10m+    759[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    760[0m:[38;5;10m[49m 
