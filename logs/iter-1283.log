[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m         "note_date": "2026-03-06",
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m         "note_type": "progress_note",
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m         "text": (
