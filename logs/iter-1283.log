[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m             "event": ae["event"],
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m             "severity": severity,
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m             "evidence_score": ae["evidence_score"],
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m             "evidence_reasons": ae["evidence_reasons"],
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m     if not detected_events:
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m         print("\n  No adverse events detected in this note.")
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m     print(f"\n{'='*60}")
