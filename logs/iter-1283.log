[49m[38;5;10m+      1[0m:[38;5;10m[49m # Recipe 8.7: Adverse Event Detection in Clinical Text - Python Example
[0m[49m[38;5;10m+      2[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      3[0m:[38;5;10m[49m > **This is an illustrative implementation, not a production-ready deployment.**
[0m[49m[38;5;10m+      4[0m:[38;5;10m[49m > It demonstrates the patterns from the pseudocode walkthrough using boto3.
[0m[49m[38;5;10m+      5[0m:[38;5;10m[49m > A real deployment needs the additions listed in the "Gap to Production" section at the end.
[0m[49m[38;5;10m+      6[0m:[38;5;10m[49m > Start here to understand the concepts. Don't ship this as-is.
[0m[49m[38;5;10m+      7[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      8[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+      9[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     10[0m:[38;5;10m[49m ## Setup
[0m[49m[38;5;10m+     11[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     12[0m:[38;5;10m[49m ```bash
[0m[49m[38;5;10m+     13[0m:[38;5;10m[49m pip install boto3
[0m[49m[38;5;10m+     14[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     15[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     16[0m:[38;5;10m[49m You'll also need:
[0m[49m[38;5;10m+     17[0m:[38;5;10m[49m - An AWS account with Amazon Comprehend Medical configured
[0m[49m[38;5;10m+     18[0m:[38;5;10m[49m - A signed AWS BAA covering PHI processing
[0m[49m[38;5;10m+     19[0m:[38;5;10m[49m - IAM permissions: `comprehend-medical:DetectEntitiesV2`, `comprehend-medical:InferRxNorm`,
[0m[49m[38;5;10m+     20[0m:[38;5;10m[49m   `dynamodb:PutItem`, `dynamodb:Query`, `s3:PutObject`, `s3:GetObject`, `sns:Publish`
[0m[49m[38;5;10m+     21[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     22[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     23[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     24[0m:[38;5;10m[49m ## Configuration
[0m[49m[38;5;10m+     25[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     26[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     27[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+     28[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+     29[0m:[38;5;10m[49m import re
[0m[49m[38;5;10m+     30[0m:[38;5;10m[49m import uuid
[0m[49m[38;5;10m+     31[0m:[38;5;10m[49m from datetime import datetime, timezone, timedelta
[0m[49m[38;5;10m+     32[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+     33[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+     34[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     35[0m:[38;5;10m[49m # -------------------------------------------------------------------------
[0m[49m[38;5;10m+     36[0m:[38;5;10m[49m # Retry configuration
[0m[49m[38;5;10m+     37[0m:[38;5;10m[49m # -------------------------------------------------------------------------
[0m[49m[38;5;10m+     38[0m:[38;5;10m[49m # Comprehend Medical throttles under burst load. Adaptive mode uses exponential
[0m[49m[38;5;10m+     39[0m:[38;5;10m[49m # backoff with jitter automatically. Apply this to every boto3 client.
[0m[49m[38;5;10m+     40[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(
[0m[49m[38;5;10m+     41[0m:[38;5;10m[49m     retries={
[0m[49m[38;5;10m+     42[0m:[38;5;10m[49m         "max_attempts": 3,
[0m[49m[38;5;10m+     43[0m:[38;5;10m[49m         "mode": "adaptive"
[0m[49m[38;5;10m+     44[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     45[0m:[38;5;10m[49m )
[0m[49m[38;5;10m+     46[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     47[0m:[38;5;10m[49m # -------------------------------------------------------------------------
[0m[49m[38;5;10m+     48[0m:[38;5;10m[49m # Clients
[0m[49m[38;5;10m+     49[0m:[38;5;10m[49m # -------------------------------------------------------------------------
[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m comprehend_medical = boto3.client("comprehendmedical", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m s3 = boto3.client("s3", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m sns = boto3.client("sns", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m # -------------------------------------------------------------------------
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m # Constants
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m # -------------------------------------------------------------------------
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m ADVERSE_EVENTS_TABLE = "adverse-events"
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m NOTES_BUCKET = "clinical-notes-archive"
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m SNS_CRITICAL_TOPIC = "arn:aws:sns:us-east-1:123456789012:ae-critical-alerts"
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m # Minimum combined evidence score to flag a drug-event pair as a potential AE.
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m AE_EVIDENCE_THRESHOLD = 0.4
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m # -------------------------------------------------------------------------
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m # Causal language patterns
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m # -------------------------------------------------------------------------
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m # These phrases, when appearing between a medication mention and a clinical
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m # event, strongly suggest the clinician intended a causal link.
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m # High precision, moderate recall: they catch explicit attributions but miss
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m # implicit ones (which are the majority in practice).
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m CAUSAL_PATTERNS = [
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m     r"due to",
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m     r"caused by",
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m     r"secondary to",
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m     r"related to",
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m     r"attributed to",
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m     r"as a result of",
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m     r"likely from",
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m     r"suspect(?:ed)? reaction to",
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m     r"discontinue.*because",
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m     r"hold.*due to",
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m     r"adverse effect of",
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m     r"side effect",
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m     r"after starting",
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m     r"since (?:starting|beginning|initiating)",
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m # -------------------------------------------------------------------------
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m # Severity indicators
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m # -------------------------------------------------------------------------
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m # Ordered from most to least severe. First match wins.
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m SEVERITY_INDICATORS = {
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m     "grade_4_life_threatening": [
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m         "icu", "intubated", "code blue", "life-threatening",
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m         "anaphylaxis", "cardiac arrest", "emergency", "resuscitat"
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m     ],
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m     "grade_3_severe": [
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m         "admitted", "hospitalized", "transfusion", "surgical intervention",
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m         "disability", "prolonged hospitalization", "transferred to"
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m     ],
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m     "grade_2_moderate": [
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m         "medication change", "dose reduction", "additional treatment",
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m         "limits activities", "switched to", "discontinued"
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m     ],
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m     "grade_1_mild": [
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m         "mild", "self-limited", "resolved", "no intervention",
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m         "tolerable", "asymptomatic", "transient"
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m     ],
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m # -------------------------------------------------------------------------
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m # Known adverse drug reactions (simplified lookup)
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m # -------------------------------------------------------------------------
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m # In production, this would be a database populated from FDA labels, SIDER,
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m # or FAERS data. Here we use a small sample for demonstration.
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m # Keys are RxNorm CUIs. Values are sets of normalized event terms.
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m KNOWN_ADR_DATABASE = {
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m     "329526": {"dizziness", "orthostatic hypotension", "edema", "fatigue", "flushing"},   # amlodipine
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m     "161": {"rash", "diarrhea", "nausea", "allergic reaction", "anaphylaxis"},            # amoxicillin
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m     "36567": {"myalgia", "rhabdomyolysis", "hepatotoxicity", "muscle weakness"},          # atorvastatin
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m     "32968": {"nausea", "insomnia", "sexual dysfunction", "weight gain", "serotonin syndrome"},  # sertraline
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m     "7052": {"gi bleed", "nausea", "renal impairment", "hypertension"},                   # naproxen
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m ## Synthetic Clinical Notes
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m # -------------------------------------------------------------------------
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m # Synthetic test data: clinical notes with planted adverse events
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m # -------------------------------------------------------------------------
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m # These are entirely synthetic. They simulate real documentation patterns
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m # without containing any actual patient information.
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m SYNTHETIC_NOTES = [
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m     {
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m         "note_id": "NOTE-20260304-11422",
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m         "patient_id": "PAT-882710",
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m         "note_date": "2026-03-04",
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m         "note_type": "progress_note",
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m         "text": (
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m             "Assessment and Plan:\n"
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m             "1. Hypertension - Patient started on amlodipine 10mg daily two weeks ago. "
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m             "Reports orthostatic dizziness every morning since starting medication. "
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m             "Dizziness is worst upon standing from bed, lasting 30-60 seconds. "
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m             "No syncope. BP today 128/78 sitting, 110/68 standing. "
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m             "Likely related to new amlodipine. Will reduce to 5mg and recheck in 2 weeks. "
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m             "If symptoms persist at lower dose, will switch to ACE inhibitor.\n"
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m             "2. Diabetes type 2 - A1c stable at 7.1%. Continue metformin 1000mg BID.\n"
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m             "3. Hyperlipidemia - Continue atorvastatin 40mg. Denies muscle pain."
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m         ),
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m     {
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m         "note_id": "NOTE-20260305-08831",
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m         "patient_id": "PAT-551203",
