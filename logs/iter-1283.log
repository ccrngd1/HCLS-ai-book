[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m     filtered_count = len(entities["conditions"]) - len(active_conditions)
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m     print(f"  Active conditions: {len(active_conditions)} (filtered out {filtered_count} negated/hypothetical)")
