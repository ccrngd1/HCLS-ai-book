[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m ## Step 1: Archive the Clinical Note
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m def archive_note(note: dict) -> str:
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m     Archive raw note to S3 before processing.
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m     Maps to pseudocode Step 1. Every note gets stored in durable storage before
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m     we touch it with NLP. This gives us an immutable audit trail and enables
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m     reprocessing when models improve.
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m     note_date = note["note_date"]
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m     year, month, _ = note_date.split("-")
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m     archive_key = f"notes-archive/{year}/{month}/{note['note_id']}.json"
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m     archive_record = {
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m         "note_id": note["note_id"],
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m         "patient_id": note["patient_id"],
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m         "note_date": note_date,
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m         "note_type": note["note_type"],
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m         "text": note["text"],
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m         "received_timestamp": datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m     s3.put_object(
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m         Bucket=NOTES_BUCKET,
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m         Key=archive_key,
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m         Body=json.dumps(archive_record),
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m         ContentType="application/json",
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m         ServerSideEncryption="aws:kms",
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m     return archive_key
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m ## Step 2: Extract Medical Entities
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m def extract_entities(note_text: str) -> dict:
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m     Call Comprehend Medical DetectEntitiesV2 to extract medications, conditions,
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     and temporal expressions.
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m     Maps to pseudocode Step 2. Comprehend Medical handles the biomedical NER:
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m     drug names, symptoms, diagnoses, and time references. Each entity comes back
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m     with confidence scores and trait attributes (negation, hypothetical, etc.)
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m     that we use in the assertion filtering step.
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m     # Comprehend Medical has a 20,000 character limit per call.
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m     # Most progress notes are well under this. Truncate if needed.
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m     truncated_text = note_text[:20000]
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m     response = comprehend_medical.detect_entities_v2(Text=truncated_text)
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m     medications = []
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m     conditions = []
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m     temporals = []
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m     for entity in response["Entities"]:
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m         base = {
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m             "text": entity["Text"],
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m             "type": entity["Type"],
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m             "score": entity["Score"],
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m             "begin_offset": entity["BeginOffset"],
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m             "end_offset": entity["EndOffset"],
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m             "traits": entity.get("Traits", []),
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m             "attributes": entity.get("Attributes", []),
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m         if entity["Category"] == "MEDICATION":
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m             medications.append(base)
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m         elif entity["Category"] == "MEDICAL_CONDITION":
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m             conditions.append(base)
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m         elif entity["Category"] == "TIME_EXPRESSION":
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m             temporals.append(base)
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m     # Normalize medication names to RxNorm codes.
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m     # This enables cross-note aggregation: "amlodipine" and "Norvasc" map to the same CUI.
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m     for med in medications:
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m         rxnorm_response = comprehend_medical.infer_rx_norm(Text=med["text"])
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m         concepts = rxnorm_response.get("Entities", [])
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m         if concepts:
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m             top_concept = concepts[0].get("RxNormConcepts", [])
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m             if top_concept and top_concept[0]["Score"] > 0.7:
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m                 med["rxnorm_code"] = top_concept[0]["Code"]
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m                 med["rxnorm_description"] = top_concept[0]["Description"]
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m         "medications": medications,
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m         "conditions": conditions,
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m         "temporals": temporals,
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m ## Step 3: Filter by Assertion Status
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m def filter_active_conditions(conditions: list) -> list:
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m     Remove negated, hypothetical, and family-history conditions.
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m     Maps to pseudocode Step 3. Comprehend Medical attaches Traits to each entity
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m     that indicate context. "Denies chest pain" gets a NEGATION trait. "If rash
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m     develops" gets a HYPOTHETICAL trait (when supported by the model).
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m     This single step typically removes 30-50% of extracted conditions, dramatically
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m     cutting false positives downstream.
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m     active = []
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m     for condition in conditions:
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m         trait_names = {t["Name"] for t in condition["traits"]}
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m         # Skip negated conditions: "denies dizziness", "no rash"
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m         if "NEGATION" in trait_names:
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m         # Skip hypothetical/conditional: "if patient develops rash"
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m         # Note: Comprehend Medical uses "HYPOTHETICAL" for conditional mentions
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m         if "HYPOTHETICAL" in trait_names:
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m         # Keep everything else. Comprehend Medical does not currently expose a
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m         # dedicated "FAMILY_HISTORY" trait on MEDICAL_CONDITION entities, so we
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m         # rely on section detection or manual rules for that in production.
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m         # TODO: verify trait coverage in latest Comprehend Medical API version
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m         active.append(condition)
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m     return active
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m ## Step 4: Detect Adverse Event Relationships
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m def detect_adverse_events(
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m     medications: list,
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m     active_conditions: list,
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m     temporals: list,
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m     note_text: str,
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m ) -> list:
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m     Core relation extraction: link clinical events to medications using layered evidence.
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m     Maps to pseudocode Step 4. For each (medication, condition) pair, we accumulate
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m     evidence from four layers:
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m       1. Explicit causal language (highest signal)
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m       2. Temporal plausibility
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m       3. Text proximity
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m       4. Known ADR match from knowledge base
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m     The combined score determines whether we flag the pair.
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m     detected_events = []
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m     for condition in active_conditions:
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m         for medication in medications:
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m             evidence_score = 0.0
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m             evidence_reasons = []
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m             # ----- Layer 1: Explicit causal language -----
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m             # Extract text between (or near) the two entity mentions and search
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m             # for phrases that explicitly link them.
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m             start = min(medication["end_offset"], condition["end_offset"])
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m             end = max(medication["begin_offset"], condition["begin_offset"])
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m             # Expand window slightly to catch phrases before/after the entities
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m             window_start = max(0, min(medication["begin_offset"], condition["begin_offset"]) - 50)
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m             window_end = min(len(note_text), max(medication["end_offset"], condition["end_offset"]) + 50)
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m             text_window = note_text[window_start:window_end].lower()
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m             for pattern in CAUSAL_PATTERNS:
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m                 if re.search(pattern, text_window):
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m                     evidence_score += 0.6
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m                     evidence_reasons.append(f"explicit_causal_language: {pattern}")
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m                     break  # one match is sufficient
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m             # ----- Layer 2: Temporal plausibility -----
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m             # Check if any temporal expression near the condition suggests
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m             # the event followed the medication.
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m             temporal_keywords = [
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m                 "since starting", "after beginning", "after starting",
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m                 "since initiating", "days after", "weeks after", "onset after"
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m             ]
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m             for temporal in temporals:
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m                 temporal_text = temporal["text"].lower()
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m                 for keyword in temporal_keywords:
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m                     if keyword in temporal_text:
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m                         evidence_score += 0.3
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m                         evidence_reasons.append(f"temporal_association: {temporal['text']}")
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m                         break
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m                 if evidence_score >= 0.3 and "temporal_association" in str(evidence_reasons):
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m                     break
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m             # ----- Layer 3: Text proximity -----
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m             # Entities in the same sentence or adjacent sentences are more likely
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m             # to be intentionally connected by the documenting clinician.
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m             char_distance = abs(condition["begin_offset"] - medication["end_offset"])
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m             if char_distance < 200:
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m                 evidence_score += 0.1
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m                 evidence_reasons.append("text_proximity")
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m             # ----- Layer 4: Known ADR match -----
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m             # Check if this drug-event pair appears in our knowledge base.
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m             rxnorm_code = medication.get("rxnorm_code", "")
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m             if rxnorm_code in KNOWN_ADR_DATABASE:
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m                 known_events = KNOWN_ADR_DATABASE[rxnorm_code]
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m                 condition_lower = condition["text"].lower()
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m                 for known_event in known_events:
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m                     if known_event in condition_lower or condition_lower in known_event:
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m                         evidence_score += 0.2
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m                         evidence_reasons.append("known_adr_match")
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m                         break
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m             # ----- Threshold decision -----
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m             if evidence_score >= AE_EVIDENCE_THRESHOLD:
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m                 detected_events.append({
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m                     "medication": medication["text"],
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m                     "rxnorm_code": rxnorm_code,
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m                     "rxnorm_description": medication.get("rxnorm_description", ""),
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m                     "event": condition["text"],
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m                     "evidence_score": round(evidence_score, 2),
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m                     "evidence_reasons": evidence_reasons,
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m                     "medication_offset": (medication["begin_offset"], medication["end_offset"]),
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m                     "condition_offset": (condition["begin_offset"], condition["end_offset"]),
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m                 })
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m     return detected_events
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m ## Step 5: Classify Severity
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m def classify_severity(detected_event: dict, note_text: str) -> tuple:
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m     Assign a CTCAE-style severity grade based on contextual clues.
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m     Maps to pseudocode Step 5. We look at text surrounding the adverse event
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m     mention for severity indicators. Clinical text rarely uses explicit grades,
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m     so we infer from outcome language: "hospitalized" implies Grade 3+,
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m     "self-limited" implies Grade 1.
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m     # Extract a window around the condition mention for context.
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m     cond_start, cond_end = detected_event["condition_offset"]
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m     window_start = max(0, cond_start - 300)
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m     window_end = min(len(note_text), cond_end + 300)
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m     context_window = note_text[window_start:window_end].lower()
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m     # Check from most severe to least. First match wins.
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m     for grade, indicators in SEVERITY_INDICATORS.items():
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m         for indicator in indicators:
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m             if indicator in context_window:
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m                 return grade, indicator
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m     # Default: if documented at all, assume moderate. Grade 1 events are
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m     # often not documented. Absence of severity language suggests the clinician
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m     # found it noteworthy enough to write down.
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m     return "grade_2_moderate", "default_no_indicators"
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m ## Step 6: Store and Alert
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m def store_adverse_event(
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m     note: dict,
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m     detected_event: dict,
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m     severity: str,
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m     severity_indicator: str,
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m     Write detected AE to DynamoDB and alert on high-severity events.
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m     Maps to pseudocode Step 6. The DynamoDB schema supports three access patterns:
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m       - By patient (partition key) for clinical review
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m       - By medication (GSI) for drug-level surveillance
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m       - By time (sort key) for trend detection
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m     ae_id = f"ae-{datetime.now(timezone.utc).strftime('%Y%m%d')}-{uuid.uuid4().hex[:8]}"
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m     ae_record = {
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m         "ae_id": ae_id,
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m         "patient_id": note["patient_id"],
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m         "note_id": note["note_id"],
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m         "note_date": note["note_date"],
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m         "medication": detected_event["medication"],
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m         "rxnorm_code": detected_event["rxnorm_code"],
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m         "event_description": detected_event["event"],
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m         "severity": severity,
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m         "severity_indicator": severity_indicator,
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m         "evidence_score": Decimal(str(detected_event["evidence_score"])),
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m         "evidence_reasons": detected_event["evidence_reasons"],
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m         "detection_timestamp": datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m         "status": "pending_review",
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m     # Write to DynamoDB.
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m     # Partition key: patient_id. Sort key: detection_timestamp.
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m     # GSI on rxnorm_code + note_date for medication-level queries.
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m     table = dynamodb.Table(ADVERSE_EVENTS_TABLE)
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m     table.put_item(Item=ae_record)
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m     # High-severity: Grade 3+ triggers immediate notification.
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m     if severity in ("grade_3_severe", "grade_4_life_threatening"):
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m         sns.publish(
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m             TopicArn=SNS_CRITICAL_TOPIC,
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m             Subject=f"High-severity adverse event detected: {severity}",
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m             Message=json.dumps(
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m                 {k: str(v) for k, v in ae_record.items()},
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m                 indent=2,
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m             ),
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m         print(f"  ** ALERT: High-severity event published to SNS **")
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m     return ae_record
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m ## Step 7: Aggregate for Signal Detection
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m def aggregate_signals(time_window_days: int = 30) -> list:
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m     Query recent AEs and apply basic disproportionality analysis.
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m     Maps to pseudocode Step 7. This runs as a scheduled batch job (daily or weekly).
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m     It queries all detected events in a time window, groups by drug-event pair,
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m     and flags combinations occurring at >2x the expected rate with 3+ patients.
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m     In production, this would query DynamoDB with a GSI scan or export to Athena
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m     for efficient aggregation. Here we demonstrate the logic.
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m     # In a real system, you'd query DynamoDB or export to S3/Athena.
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m     # This simulates reading recent events from the database.
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m     table = dynamodb.Table(ADVERSE_EVENTS_TABLE)
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m     cutoff = (datetime.now(timezone.utc) - timedelta(days=time_window_days)).isoformat()
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m     # Scan is expensive at scale. In production, use a GSI with detection_timestamp
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m     # as the sort key, or export to S3 + Athena for analytical queries.
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m     response = table.scan(
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m         FilterExpression="detection_timestamp > :cutoff",
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m         ExpressionAttributeValues={":cutoff": cutoff},
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m     recent_events = response.get("Items", [])
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m     # Group by normalized drug-event pair.
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m     pair_counts = {}
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m     for event in recent_events:
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m         pair_key = (event.get("rxnorm_code", "unknown"), event["event_description"].lower())
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m         if pair_key not in pair_counts:
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m             pair_counts[pair_key] = {"patients": set(), "total_mentions": 0}
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m         pair_counts[pair_key]["patients"].add(event["patient_id"])
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m         pair_counts[pair_key]["total_mentions"] += 1
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m     # Apply simple disproportionality analysis.
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m     # Expected rates would come from historical baseline or literature.
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m     # Here we use a placeholder of 4.0 events per 30-day window.
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m     DEFAULT_EXPECTED_RATE = 4.0
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m     signals = []
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m     for (rxnorm_code, event_term), counts in pair_counts.items():
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m         unique_patients = len(counts["patients"])
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m         if unique_patients >= 3:
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m             ratio = unique_patients / DEFAULT_EXPECTED_RATE
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m             if ratio > 2.0:
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m                 signals.append({
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m                     "rxnorm_code": rxnorm_code,
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m                     "event_term": event_term,
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m                     "unique_patients": unique_patients,
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m                     "total_mentions": counts["total_mentions"],
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m                     "expected_rate": DEFAULT_EXPECTED_RATE,
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m                     "observed_to_expected_ratio": round(ratio, 2),
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m                     "time_window_days": time_window_days,
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m                     "signal_status": "investigation_required",
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m                 })
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m     return signals
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m ```
