[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m             "payer": "self_pay",
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m             "payment_ratio": (0.32, 0.15),
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m             "write_off_ratio": (0.40, 0.15),
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m             "avg_days_to_pay": (110, 35),
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m             "utilization_intensity": (0.6, 0.4),
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m             "ed_proportion": (0.35, 0.15),
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m             "avg_complexity": (1.6, 0.7),
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m             "no_show_rate": (0.25, 0.10),
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m             "coverage_changes_24mo": (3.0, 1.5),
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m             "deductible_amount": (0, 0),
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m             "collections_count": (2.5, 1.5),
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m             "charity_app_count": (1.8, 1.2),
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m     all_patients = []
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m     for segment_name, params in segments.items():
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m         n = params["n"]
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m         patients = pd.DataFrame({
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m             "patient_id": [f"PAT-{segment_name[:3].upper()}-{i:05d}" for i in range(n)],
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m             "payer_type": params["payer"],
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m             "payment_ratio": rng.normal(params["payment_ratio"][0], params["payment_ratio"][1], n),
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m             "write_off_ratio": rng.normal(params["write_off_ratio"][0], params["write_off_ratio"][1], n),
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m             "avg_days_to_pay": rng.normal(params["avg_days_to_pay"][0], params["avg_days_to_pay"][1], n),
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m             "utilization_intensity": rng.normal(params["utilization_intensity"][0], params["utilization_intensity"][1], n),
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m             "ed_proportion": rng.normal(params["ed_proportion"][0], params["ed_proportion"][1], n),
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m             "avg_complexity": rng.normal(params["avg_complexity"][0], params["avg_complexity"][1], n),
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m             "no_show_rate": rng.normal(params["no_show_rate"][0], params["no_show_rate"][1], n),
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m             "coverage_changes_24mo": rng.normal(params["coverage_changes_24mo"][0], params["coverage_changes_24mo"][1], n),
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m             "deductible_amount": rng.normal(params["deductible_amount"][0], params["deductible_amount"][1], n),
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m             "collections_count": rng.normal(params["collections_count"][0], params["collections_count"][1], n),
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m             "charity_app_count": rng.normal(params["charity_app_count"][0], params["charity_app_count"][1], n),
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m         patients["_true_segment"] = segment_name  # for validation only; not used in clustering
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m         all_patients.append(patients)
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m     df = pd.concat(all_patients, ignore_index=True)
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m     # Clip values to realistic ranges. Ratios can't exceed 1.0 or go below 0.
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m     # Counts can't be negative. Days can't be negative.
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m     df["payment_ratio"] = df["payment_ratio"].clip(0.0, 1.0)
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m     df["write_off_ratio"] = df["write_off_ratio"].clip(0.0, 1.0)
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m     df["ed_proportion"] = df["ed_proportion"].clip(0.0, 1.0)
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m     df["no_show_rate"] = df["no_show_rate"].clip(0.0, 1.0)
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m     df["avg_days_to_pay"] = df["avg_days_to_pay"].clip(0, None)
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m     df["utilization_intensity"] = df["utilization_intensity"].clip(0, None)
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m     df["avg_complexity"] = df["avg_complexity"].clip(0.1, None)
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m     df["coverage_changes_24mo"] = df["coverage_changes_24mo"].clip(0, None).round()
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m     df["deductible_amount"] = df["deductible_amount"].clip(0, None).round(-1)  # round to nearest $10
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m     df["collections_count"] = df["collections_count"].clip(0, None).round()
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m     df["charity_app_count"] = df["charity_app_count"].clip(0, None).round()
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m     return df
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m ## Step 2: Engineer and Normalize Features
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m *The pseudocode calls this `engineer_features(patient_features)`. It encodes the payer type as an ordinal, selects the feature columns, imputes missing values, and z-score normalizes everything so no single feature dominates the distance calculation.*
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m def engineer_features(df: pd.DataFrame) -> tuple[np.ndarray, StandardScaler, pd.DataFrame]:
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m     Transform raw patient data into a normalized feature matrix ready for clustering.
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m     Three things happen here:
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m     1. Payer type gets encoded as an ordinal number (commercial=4 down to self_pay=1).
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m     2. Missing values get imputed with the column median.
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m     3. All features get z-score normalized (mean=0, std=1).
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m     That third step is critical. Without it, deductible_amount (range: $0-$7000)
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m     would completely dominate the distance calculation, and no_show_rate
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m     (range: 0.0-0.4) would be effectively invisible to the algorithm.
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m         df: Raw patient DataFrame from Step 1.
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m         Tuple of:
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m         - feature_matrix: numpy array of shape (n_patients, n_features), normalized
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m         - scaler: the fitted StandardScaler (save this for transforming new patients)
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m         - df: the DataFrame with payer_ordinal added (for profiling later)
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m     # Encode payer type as ordinal. This preserves the financial ordering
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m     # that's central to this use case. A purely one-hot encoding would lose
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m     # the information that commercial > medicare > medicaid > self_pay
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m     # in terms of expected reimbursement.
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m     df = df.copy()
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m     df["payer_ordinal"] = df["payer_type"].map(PAYER_ENCODING)
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m     # Handle any unmapped payer types (shouldn't happen with clean data,
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m     # but defensive coding for when someone adds "tricare" to the source).
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m     if df["payer_ordinal"].isna().any():
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m         unmapped = df[df["payer_ordinal"].isna()]["payer_type"].unique()
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m         logger.warning("Unmapped payer types found: %s. Defaulting to 2.", unmapped)
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m         df["payer_ordinal"] = df["payer_ordinal"].fillna(2)
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m     # Select feature columns and impute missing values with median.
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m     # Median is more robust than mean for skewed distributions (which
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m     # financial data almost always is). A patient with no payment history
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m     # gets placed in the middle of the distribution rather than at an extreme.
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m     feature_df = df[FEATURE_COLUMNS].copy()
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m     for col in FEATURE_COLUMNS:
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m         median_val = feature_df[col].median()
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m         feature_df[col] = feature_df[col].fillna(median_val)
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m     # Z-score normalization: subtract mean, divide by standard deviation.
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m     # After this, every feature has mean=0 and std=1, so they all contribute
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m     # equally to the Euclidean distance calculation in K-Means.
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m     scaler = StandardScaler()
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m     feature_matrix = scaler.fit_transform(feature_df.values)
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m     return feature_matrix, scaler, df
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m ## Step 3: Run Clustering and Evaluate
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m *The pseudocode calls this `cluster_patients(feature_matrix, k_range)`. It runs K-Means for each candidate k, computes silhouette scores, and returns the best model along with all results for comparison.*
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m def cluster_patients(feature_matrix: np.ndarray) -> tuple[KMeans, np.ndarray, list]:
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m     Run K-Means clustering for multiple values of k and select the best.
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m     "Best" here means highest silhouette score, which measures how well-separated
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m     the clusters are. But silhouette score is a starting point, not the final word.
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m     The real test is whether your finance team can look at the cluster profiles
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m     and immediately name them. If they can't, the segmentation isn't useful
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m     regardless of what the metrics say.
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m         feature_matrix: Normalized feature array from Step 2.
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m         Tuple of:
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m         - best_model: the KMeans model with the highest silhouette score
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m         - best_labels: cluster assignments for each patient
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m         - all_results: list of dicts with metrics for each k (for comparison)
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m     all_results = []
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m     for k in K_RANGE:
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m         # n_init=10: run K-Means 10 times with different random centroid
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m         # placements and keep the best result. K-Means is sensitive to
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m         # initialization; this avoids getting stuck in a bad local minimum.
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m         # random_state=42: reproducible results across runs.
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m         model = KMeans(n_clusters=k, n_init=10, random_state=42)
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m         labels = model.fit_predict(feature_matrix)
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m         # Silhouette score: measures how similar each point is to its own
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m         # cluster vs. the nearest neighboring cluster. Range: -1 to 1.
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m         # Above 0.3 is decent for real-world data. Above 0.5 is strong.
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m         sil_score = silhouette_score(feature_matrix, labels)
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m         # Inertia (within-cluster sum of squares): always decreases with k.
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m         # Useful for the elbow method but not for direct comparison.
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m         inertia = model.inertia_
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m         all_results.append({
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m             "k": k,
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m             "silhouette_score": round(sil_score, 4),
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m             "inertia": round(inertia, 2),
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m             "model": model,
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m             "labels": labels,
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m         logger.info("  k=%d: silhouette=%.4f, inertia=%.2f", k, sil_score, inertia)
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m     # Select the k with the highest silhouette score.
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m     best = max(all_results, key=lambda x: x["silhouette_score"])
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m     logger.info("Best k=%d with silhouette=%.4f", best["k"], best["silhouette_score"])
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m     return best["model"], best["labels"], all_results
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m ## Step 4: Profile Clusters
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m *The pseudocode calls this `profile_clusters(patient_data, labels, feature_columns)`. It computes summary statistics for each cluster and generates human-readable profiles that a CFO can actually use.*
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m def profile_clusters(df: pd.DataFrame, labels: np.ndarray) -> list[dict]:
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m     Compute summary statistics for each cluster and generate interpretable profiles.
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m     Raw cluster labels (0, 1, 2, 3, 4) mean nothing to a revenue cycle director.
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m     This function translates them into profiles like "High-deductible commercial
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m     patients with poor payment histories" that finance teams can act on.
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m         df: Patient DataFrame (with payer_ordinal added from Step 2).
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m         labels: Cluster assignment array from Step 3.
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m         List of profile dicts, one per cluster, sorted by cluster ID.
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m     df = df.copy()
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m     df["cluster"] = labels
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m     total_patients = len(df)
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m     profiles = []
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m     for cluster_id in sorted(df["cluster"].unique()):
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m         cluster_df = df[df["cluster"] == cluster_id]
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m         n = len(cluster_df)
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m         profile = {
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m             "cluster_id": int(cluster_id),
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m             "size": n,
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m             "percentage": round(n / total_patients * 100, 1),
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m             # Payer mix within this cluster.
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m             "payer_distribution": cluster_df["payer_type"].value_counts(normalize=True).round(3).to_dict(),
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m             # Key financial metrics (means).
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m             "avg_payment_ratio": round(cluster_df["payment_ratio"].mean(), 3),
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m             "avg_write_off_ratio": round(cluster_df["write_off_ratio"].mean(), 3),
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m             "avg_days_to_pay": round(cluster_df["avg_days_to_pay"].mean(), 1),
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m             "avg_collections_count": round(cluster_df["collections_count"].mean(), 2),
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m             "avg_charity_app_count": round(cluster_df["charity_app_count"].mean(), 2),
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m             # Utilization metrics.
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m             "avg_utilization_intensity": round(cluster_df["utilization_intensity"].mean(), 3),
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m             "avg_ed_proportion": round(cluster_df["ed_proportion"].mean(), 3),
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m             "avg_no_show_rate": round(cluster_df["no_show_rate"].mean(), 3),
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m             # Coverage stability.
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m             "avg_coverage_changes": round(cluster_df["coverage_changes_24mo"].mean(), 2),
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m             "avg_deductible": round(cluster_df["deductible_amount"].mean(), 0),
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m         # Generate a suggested label based on dominant characteristics.
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m         # This is a simple heuristic. In practice, your finance team will
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m         # rename these to something that makes sense in their context.
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m         profile["suggested_label"] = _generate_cluster_label(profile)
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m         profiles.append(profile)
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m     return profiles
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m def _generate_cluster_label(profile: dict) -> str:
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m     Heuristic label generator based on dominant cluster characteristics.
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m     This is intentionally simple. The real labels come from your finance team
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m     looking at the profiles and saying "oh, that's our HDHP non-payers."
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m     This just gives them a starting point.
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m     # Determine dominant payer.
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m     payer_dist = profile["payer_distribution"]
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m     dominant_payer = max(payer_dist, key=payer_dist.get) if payer_dist else "unknown"
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m     # Determine risk level based on write-off ratio.
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m     write_off = profile["avg_write_off_ratio"]
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m     if write_off < 0.05:
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m         risk = "Low Risk"
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m     elif write_off < 0.15:
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m         risk = "Moderate Risk"
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m         risk = "High Risk"
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m     # Determine utilization level.
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m     util = profile["avg_utilization_intensity"]
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m     if util < 0.4:
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m         util_label = "Low Util"
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m     elif util < 0.8:
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m         util_label = "Moderate Util"
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m         util_label = "High Util"
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m     payer_labels = {
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m         "commercial": "Commercial",
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m         "medicare": "Medicare",
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m         "medicaid": "Medicaid",
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m         "self_pay": "Self-Pay/Unstable",
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m     payer_label = payer_labels.get(dominant_payer, dominant_payer.title())
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m     return f"{payer_label} - {risk} - {util_label}"
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m ## Step 5: Detect Population Shifts
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m *The pseudocode calls this `detect_population_shift(current_distribution, previous_distribution, threshold)`. It compares cluster distributions between runs and fires alerts when shifts exceed the threshold.*
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m def detect_population_shift(
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m     current_profiles: list[dict],
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m     previous_profiles: list[dict],
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m     threshold_pp: float = SHIFT_THRESHOLD_PP,
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m ) -> list[dict]:
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m     Compare cluster distributions between two time periods and flag significant shifts.
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m     A 5-percentage-point shift in any cluster over a quarter is worth investigating.
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m     A 10-point shift is an alarm. This function identifies those shifts and
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m     generates alert messages for the revenue cycle team.
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m         current_profiles: Cluster profiles from the current run.
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m         previous_profiles: Cluster profiles from the previous run.
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m         threshold_pp: Minimum percentage-point change to trigger an alert.
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m         List of alert dicts for clusters that shifted beyond the threshold.
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m     # Build lookup of previous percentages by cluster ID.
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m     prev_pcts = {p["cluster_id"]: p["percentage"] for p in previous_profiles}
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m     alerts = []
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m     for profile in current_profiles:
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m         cluster_id = profile["cluster_id"]
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m         current_pct = profile["percentage"]
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m         previous_pct = prev_pcts.get(cluster_id, 0.0)
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m         shift = current_pct - previous_pct
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m         if abs(shift) >= threshold_pp:
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m             direction = "growing" if shift > 0 else "shrinking"
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m             alerts.append({
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m                 "cluster_id": cluster_id,
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m                 "label": profile.get("suggested_label", f"Cluster {cluster_id}"),
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m                 "direction": direction,
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m                 "shift_pp": round(shift, 1),
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m                 "current_pct": current_pct,
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m                 "previous_pct": previous_pct,
