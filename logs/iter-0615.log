[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m             "avg_complexity": (1.5, 0.5),
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m             "no_show_rate": (0.12, 0.06),
