[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m             "deductible_amount": (4500, 1500),
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m             "collections_count": (0.8, 0.9),
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m             "charity_app_count": (0.3, 0.5),
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m         },
