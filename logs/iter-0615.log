[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m             "payer": "medicaid",
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m             "payment_ratio": (0.70, 0.10),
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m             "write_off_ratio": (0.12, 0.06),
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m             "avg_days_to_pay": (42, 15),
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m             "utilization_intensity": (1.2, 0.5),
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m             "ed_proportion": (0.25, 0.10),
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m             "avg_complexity": (1.4, 0.5),
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m             "no_show_rate": (0.18, 0.08),
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m             "coverage_changes_24mo": (1.5, 1.0),
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m             "deductible_amount": (0, 0),
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m             "collections_count": (0.4, 0.6),
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m             "charity_app_count": (0.5, 0.7),
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m         # Coverage unstable: frequent payer changes, high write-offs, high risk.
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m         "coverage_unstable": {
