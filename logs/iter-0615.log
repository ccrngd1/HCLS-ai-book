[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m             "payment_ratio": (0.85, 0.07),
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m             "write_off_ratio": (0.05, 0.03),
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m             "avg_days_to_pay": (30, 10),
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m             "utilization_intensity": (0.7, 0.3),
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m             "ed_proportion": (0.10, 0.05),
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m             "avg_complexity": (1.8, 0.6),
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m             "no_show_rate": (0.08, 0.04),
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m             "coverage_changes_24mo": (0.1, 0.3),
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m             "deductible_amount": (200, 50),
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m             "collections_count": (0.1, 0.3),
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m             "charity_app_count": (0.05, 0.2),
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m         # Medicaid high-utilization: frequent visits, moderate payment issues.
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m         "medicaid_high_util": {
