[0m[49m[38;5;10m+      693[0m:[38;5;10m[49m     // The high-risk-substitution catalogs are per-specialty.
[0m[49m[38;5;10m+      694[0m:[38;5;10m[49m     // Each catalog entry defines:
[0m[49m[38;5;10m+      695[0m:[38;5;10m[49m     //   - A pair of confusable terms (left/right, no/not,
[0m[49m[38;5;10m+      696[0m:[38;5;10m[49m     //     morphine/naloxone, etc.)
[0m[49m[38;5;10m+      697[0m:[38;5;10m[49m     //   - A severity tier (HIGH: laterality, negation,
[0m[49m[38;5;10m+      698[0m:[38;5;10m[49m     //     drug-name; MEDIUM: dose-direction, symptom-pair)
[0m[49m[38;5;10m+      699[0m:[38;5;10m[49m     //   - The detection method (exact-match, regex, or
[0m[49m[38;5;10m+      700[0m:[38;5;10m[49m     //     NLI-based for negation-scope detection)
[0m[49m[38;5;10m+      701[0m:[38;5;10m[49m     catalog = load_critical_error_catalog(specialty)
