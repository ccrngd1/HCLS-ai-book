[0m[48;2;40;67;43m[39m+     988[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Population uplift (treated vs matched control) [38;2;192;197;206m|[38;2;192;197;206m not measured [38;2;192;197;206m|[38;2;192;197;206m quantified per evaluation cycle [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+     989[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Equity floor utilization [38;2;192;197;206m|[38;2;192;197;206m n/a [38;2;192;197;206m|[38;2;192;197;206m 80-100% (configurable target) [38;2;192;197;206m|[K
