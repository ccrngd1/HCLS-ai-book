[0m[49m[38;5;10m+    1714[0m:[38;5;10m[49m def _eval_med_discrepancy_rule(state, event):
[0m[49m[38;5;10m+    1715[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1716[0m:[38;5;10m[49m     Detect medication discrepancies between pharmacy fills
[0m[49m[38;5;10m+    1717[0m:[38;5;10m[49m     and clinician orders. Demo: thin check against the
[0m[49m[38;5;10m+    1718[0m:[38;5;10m[49m     medication list.
[0m[49m[38;5;10m+    1719[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1720[0m:[38;5;10m[49m     if event.get("type") != "medication_filled":
[0m[49m[38;5;10m+    1721[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+    1722[0m:[38;5;10m[49m     fill = event.get("payload", {})
[0m[49m[38;5;10m+    1723[0m:[38;5;10m[49m     med_list = state.get("active_medication_list", [])
[0m[49m[38;5;10m+    1724[0m:[38;5;10m[49m     # Look for a same-drug entry with a different dose. The
[0m[49m[38;5;10m+    1725[0m:[38;5;10m[49m     # production rule has rxnorm-based drug matching and
[0m[49m[38;5;10m+    1726[0m:[38;5;10m[49m     # ucum-based dose comparison; the demo runs a thin
[0m[49m[38;5;10m+    1727[0m:[38;5;10m[49m     # check.
[0m[49m[38;5;10m+    1728[0m:[38;5;10m[49m     for entry in med_list:
[0m[49m[38;5;10m+    1729[0m:[38;5;10m[49m         data = entry.get("data", {})
[0m[49m[38;5;10m+    1730[0m:[38;5;10m[49m         if (data.get("drug", "").lower() ==
[0m[49m[38;5;10m+    1731[0m:[38;5;10m[49m                 (fill.get("drug") or "").lower() and
[0m[49m[38;5;10m+    1732[0m:[38;5;10m[49m                 data.get("dose") and fill.get("dose") and
[0m[49m[38;5;10m+    1733[0m:[38;5;10m[49m                 data.get("dose") != fill.get("dose")):
[0m[49m[38;5;10m+    1734[0m:[38;5;10m[49m             return {
[0m[49m[38;5;10m+    1735[0m:[38;5;10m[49m                 "drug":             fill.get("drug"),
[0m[49m[38;5;10m+    1736[0m:[38;5;10m[49m                 "fill_dose":        fill.get("dose"),
[0m[49m[38;5;10m+    1737[0m:[38;5;10m[49m                 "recorded_dose":    data.get("dose"),
[0m[49m[38;5;10m+    1738[0m:[38;5;10m[49m                 "recorded_provenance":
[0m[49m[38;5;10m+    1739[0m:[38;5;10m[49m                     entry.get("provenance_id"),
[0m[49m[38;5;10m+    1740[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    1741[0m:[38;5;10m[49m     return None
[0m[49m[38;5;10m+    1742[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1743[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1744[0m:[38;5;10m[49m def _eval_referral_window_rule(state, event):
[0m[49m[38;5;10m+    1745[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1746[0m:[38;5;10m[49m     Detect referrals that have been ordered but have not
[0m[49m[38;5;10m+    1747[0m:[38;5;10m[49m     been scheduled within the protocol window for their
[0m[49m[38;5;10m+    1748[0m:[38;5;10m[49m     specialty and urgency tier.
[0m[49m[38;5;10m+    1749[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1750[0m:[38;5;10m[49m     referral_table = dynamodb.Table(REFERRAL_LIFECYCLE_TABLE)
[0m[49m[38;5;10m+    1751[0m:[38;5;10m[49m     findings = []
[0m[49m[38;5;10m+    1752[0m:[38;5;10m[49m     for record_list in referral_table.items.values():
[0m[49m[38;5;10m+    1753[0m:[38;5;10m[49m         for ref in record_list:
[0m[49m[38;5;10m+    1754[0m:[38;5;10m[49m             if ref.get("patient_id") != state.get(
[0m[49m[38;5;10m+    1755[0m:[38;5;10m[49m                     "patient_id"):
[0m[49m[38;5;10m+    1756[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    1757[0m:[38;5;10m[49m             if ref.get("state") != "ordered":
[0m[49m[38;5;10m+    1758[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    1759[0m:[38;5;10m[49m             ordered_at = ref.get("state_changed_at", "")
[0m[49m[38;5;10m+    1760[0m:[38;5;10m[49m             if not ordered_at:
[0m[49m[38;5;10m+    1761[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    1762[0m:[38;5;10m[49m             try:
[0m[49m[38;5;10m+    1763[0m:[38;5;10m[49m                 ordered_dt = datetime.fromisoformat(
[0m[49m[38;5;10m+    1764[0m:[38;5;10m[49m                     ordered_at)
[0m[49m[38;5;10m+    1765[0m:[38;5;10m[49m             except Exception:
[0m[49m[38;5;10m+    1766[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    1767[0m:[38;5;10m[49m             urgency = ref.get("urgency", "routine")
[0m[49m[38;5;10m+    1768[0m:[38;5;10m[49m             window_key = (
[0m[49m[38;5;10m+    1769[0m:[38;5;10m[49m                 "specialty_referral_urgent_scheduling"
[0m[49m[38;5;10m+    1770[0m:[38;5;10m[49m                 if urgency == "urgent"
[0m[49m[38;5;10m+    1771[0m:[38;5;10m[49m                 else
[0m[49m[38;5;10m+    1772[0m:[38;5;10m[49m                 "specialty_referral_routine_scheduling")
[0m[49m[38;5;10m+    1773[0m:[38;5;10m[49m             window_days = PROTOCOL_WINDOWS_DAYS.get(
[0m[49m[38;5;10m+    1774[0m:[38;5;10m[49m                 window_key, 14)
[0m[49m[38;5;10m+    1775[0m:[38;5;10m[49m             if (_now() - ordered_dt) > timedelta(
[0m[49m[38;5;10m+    1776[0m:[38;5;10m[49m                     days=window_days):
[0m[49m[38;5;10m+    1777[0m:[38;5;10m[49m                 findings.append({
[0m[49m[38;5;10m+    1778[0m:[38;5;10m[49m                     "referral_id": ref.get("referral_id"),
[0m[49m[38;5;10m+    1779[0m:[38;5;10m[49m                     "ordered_at":  ordered_at,
[0m[49m[38;5;10m+    1780[0m:[38;5;10m[49m                     "urgency":     urgency,
[0m[49m[38;5;10m+    1781[0m:[38;5;10m[49m                     "window_days": window_days,
[0m[49m[38;5;10m+    1782[0m:[38;5;10m[49m                 })
[0m[49m[38;5;10m+    1783[0m:[38;5;10m[49m     return findings or None
[0m[49m[38;5;10m+    1784[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1785[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1786[0m:[38;5;10m[49m def _eval_transition_gap_rule(state, event):
[0m[49m[38;5;10m+    1787[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1788[0m:[38;5;10m[49m     Detect post-discharge follow-up appointments missing
[0m[49m[38;5;10m+    1789[0m:[38;5;10m[49m     from the schedule when the discharge plan called for
[0m[49m[38;5;10m+    1790[0m:[38;5;10m[49m     one within a protocol window.
