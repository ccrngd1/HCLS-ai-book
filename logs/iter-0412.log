[0m[49m[38;5;10m+    2308[0m:[38;5;10m[49m         f"REGULATORY: {regulatory_position}.")
[0m[49m[38;5;10m+    2309[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2310[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2311[0m:[38;5;10m[49m def _execute_coordination_tool(tool_call,
[0m[49m[38;5;10m+    2312[0m:[38;5;10m[49m                                   coordination_context):
[0m[49m[38;5;10m+    2313[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2314[0m:[38;5;10m[49m     Execute a coordination tool call against the
