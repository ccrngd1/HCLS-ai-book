[0m[49m[38;5;10m+    3074[0m:[38;5;10m[49m             "state":      "closed",
[0m[49m[38;5;10m+    3075[0m:[38;5;10m[49m             "changed_at": _now_iso(),
[0m[49m[38;5;10m+    3076[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    3077[0m:[38;5;10m[49m         referral["history"] = history
[0m[49m[38;5;10m+    3078[0m:[38;5;10m[49m         referral_table.put_item(
