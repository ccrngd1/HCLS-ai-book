[0m[49m[38;5;10m+    2666[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2667[0m:[38;5;10m[49m     # Step 6E: append the bot turn to the conversation log.
[0m[49m[38;5;10m+    2668[0m:[38;5;10m[49m     metadata_table = dynamodb.Table(
[0m[49m[38;5;10m+    2669[0m:[38;5;10m[49m         CONVERSATION_METADATA_TABLE)
[0m[49m[38;5;10m+    2670[0m:[38;5;10m[49m     metadata_table.put_item(Item=_to_decimal({
[0m[49m[38;5;10m+    2671[0m:[38;5;10m[49m         "session_id":         session_id,
[0m[49m[38;5;10m+    2672[0m:[38;5;10m[49m         "kind":               "turn",
