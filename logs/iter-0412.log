[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m ## Shared Helpers
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m A few utilities used across steps. Keeping them together so each step's code stays focused on the pattern it teaches.
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m def _to_decimal(obj):
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m     Recursively convert floats to Decimal for DynamoDB.
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m     DynamoDB rejects Python float values; every numeric field
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m     has to pass through Decimal on the way in.
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m     if isinstance(obj, float):
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m         return Decimal(str(obj))
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m     if isinstance(obj, dict):
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m         return {k: _to_decimal(v) for k, v in obj.items()}
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m     if isinstance(obj, list):
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m         return [_to_decimal(v) for v in obj]
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m     return obj
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m def _from_decimal(obj):
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m     """Inverse of _to_decimal for JSON serialization."""
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m     if isinstance(obj, Decimal):
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m         if obj % 1 == 0:
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m             return int(obj)
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m         return float(obj)
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m     if isinstance(obj, dict):
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m         return {k: _from_decimal(v) for k, v in obj.items()}
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m     if isinstance(obj, list):
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m         return [_from_decimal(v) for v in obj]
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m     return obj
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m def _now_iso() -> str:
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m     """Current UTC time in ISO-8601 format."""
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m     return datetime.now(timezone.utc).isoformat()
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m def _now() -> datetime:
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m     """Current UTC datetime."""
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m     return datetime.now(timezone.utc)
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m def _redact_pii_for_logging(text: str) -> str:
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m     """Light redaction for log lines."""
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m     redacted = text
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m     for pattern in PHI_PATTERNS.values():
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m         redacted = pattern.sub("[REDACTED]", redacted)
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m     return redacted
