[0m[49m[38;5;10m+    2337[0m:[38;5;10m[49m                     results.append(ref)
[0m[49m[38;5;10m+    2338[0m:[38;5;10m[49m         return {"referrals": results}
[0m[49m[38;5;10m+    2339[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2340[0m:[38;5;10m[49m     if tool == "medication_list_reconcile":
[0m[49m[38;5;10m+    2341[0m:[38;5;10m[49m         state_table = dynamodb.Table(
[0m[49m[38;5;10m+    2342[0m:[38;5;10m[49m             COORDINATION_STATE_TABLE)
[0m[49m[38;5;10m+    2343[0m:[38;5;10m[49m         state = state_table.get_item(
[0m[49m[38;5;10m+    2344[0m:[38;5;10m[49m             Key={"patient_id": patient_id}).get(
[0m[49m[38;5;10m+    2345[0m:[38;5;10m[49m                 "Item", {})
[0m[49m[38;5;10m+    2346[0m:[38;5;10m[49m         return {"medication_list":
[0m[49m[38;5;10m+    2347[0m:[38;5;10m[49m                 state.get("active_medication_list", [])}
[0m[49m[38;5;10m+    2348[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2349[0m:[38;5;10m[49m     if tool == "protocol_retrieve":
[0m[49m[38;5;10m+    2350[0m:[38;5;10m[49m         return mock_protocols.retrieve(
[0m[49m[38;5;10m+    2351[0m:[38;5;10m[49m             args.get("protocol_type"))
[0m[49m[38;5;10m+    2352[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2353[0m:[38;5;10m[49m     if tool == "care_team_alert_propose":
[0m[49m[38;5;10m+    2354[0m:[38;5;10m[49m         # Just records the proposal; the actual alert
[0m[49m[38;5;10m+    2355[0m:[38;5;10m[49m         # happens in Step 6 persistence with consent gating.
[0m[49m[38;5;10m+    2356[0m:[38;5;10m[49m         return {"proposed": True,
[0m[49m[38;5;10m+    2357[0m:[38;5;10m[49m                 "alert_type": args.get("alert_type")}
