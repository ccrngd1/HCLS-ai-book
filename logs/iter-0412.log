[0m[49m[38;5;10m+    3106[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3107[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3108[0m:[38;5;10m[49m def _next_referral_action(referral, event_type):
