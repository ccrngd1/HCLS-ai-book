[0m[49m[38;5;10m+    3083[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    3084[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3085[0m:[38;5;10m[49m     return {"action": "transitioned",
[0m[49m[38;5;10m+    3086[0m:[38;5;10m[49m             "new_state": referral["state"],
[0m[49m[38;5;10m+    3087[0m:[38;5;10m[49m             "next_action": next_action}
[0m[49m[38;5;10m+    3088[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3089[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3090[0m:[38;5;10m[49m def _map_event_to_target_state(event_type):
[0m[49m[38;5;10m+    3091[0m:[38;5;10m[49m     """Map a referral event type to its target state."""
[0m[49m[38;5;10m+    3092[0m:[38;5;10m[49m     mapping = {
[0m[49m[38;5;10m+    3093[0m:[38;5;10m[49m         "ordered":              "ordered",
