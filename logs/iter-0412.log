[0m[49m[38;5;10m+    2586[0m:[38;5;10m[49m             c for c in citations
[0m[49m[38;5;10m+    2587[0m:[38;5;10m[49m             if c.get("kind") == "protocol"]
[0m[49m[38;5;10m+    2588[0m:[38;5;10m[49m         if not protocol_citations:
[0m[49m[38;5;10m+    2589[0m:[38;5;10m[49m             return {
[0m[49m[38;5;10m+    2590[0m:[38;5;10m[49m                 "passes": False,
[0m[49m[38;5;10m+    2591[0m:[38;5;10m[49m                 "reason": "protocol_instruction_uncited",
[0m[49m[38;5;10m+    2592[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    2593[0m:[38;5;10m[49m         for c in protocol_citations:
[0m[49m[38;5;10m+    2594[0m:[38;5;10m[49m             if not c.get("version"):
[0m[49m[38;5;10m+    2595[0m:[38;5;10m[49m                 return {
[0m[49m[38;5;10m+    2596[0m:[38;5;10m[49m                     "passes": False,
[0m[49m[38;5;10m+    2597[0m:[38;5;10m[49m                     "reason":
[0m[49m[38;5;10m+    2598[0m:[38;5;10m[49m                         "protocol_citation_missing_version",
