[0m[49m[38;5;10m+    2958[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    2959[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2960[0m:[38;5;10m[49m ## Step 8: Track Referral Lifecycles to Closure
[0m[49m[38;5;10m+    2961[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2962[0m:[38;5;10m[49m Referrals are first-class coordination objects with a structured lifecycle. The state machine is institutional content; the LLM operates on top of it.
[0m[49m[38;5;10m+    2963[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2964[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    2965[0m:[38;5;10m[49m def process_referral_event(*, patient_id, referral_event):
[0m[49m[38;5;10m+    2966[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2967[0m:[38;5;10m[49m     Process a referral lifecycle event. Validates the
[0m[49m[38;5;10m+    2968[0m:[38;5;10m[49m     transition, persists the new state, emits the change
[0m[49m[38;5;10m+    2969[0m:[38;5;10m[49m     event, and schedules the next protocol-driven action.
[0m[49m[38;5;10m+    2970[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2971[0m:[38;5;10m[49m     referral_id = referral_event["referral_id"]
[0m[49m[38;5;10m+    2972[0m:[38;5;10m[49m     event_type  = referral_event["event_type"]
[0m[49m[38;5;10m+    2973[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2974[0m:[38;5;10m[49m     # Step 8A: load the current referral state.
[0m[49m[38;5;10m+    2975[0m:[38;5;10m[49m     referral_table = dynamodb.Table(
[0m[49m[38;5;10m+    2976[0m:[38;5;10m[49m         REFERRAL_LIFECYCLE_TABLE)
[0m[49m[38;5;10m+    2977[0m:[38;5;10m[49m     referral = referral_table.get_item(
[0m[49m[38;5;10m+    2978[0m:[38;5;10m[49m         Key={"referral_id": referral_id}).get("Item")
[0m[49m[38;5;10m+    2979[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2980[0m:[38;5;10m[49m     # Step 8B: if the referral does not exist yet, create it
[0m[49m[38;5;10m+    2981[0m:[38;5;10m[49m     # in the ordered state. This typically happens on the
