[0m[49m[38;5;10m+    3011[0m:[38;5;10m[49m     # Step 8C: validate the transition.
[0m[49m[38;5;10m+    3012[0m:[38;5;10m[49m     current_state = referral["state"]
[0m[49m[38;5;10m+    3013[0m:[38;5;10m[49m     target_state  = _map_event_to_target_state(event_type)
[0m[49m[38;5;10m+    3014[0m:[38;5;10m[49m     if not target_state:
[0m[49m[38;5;10m+    3015[0m:[38;5;10m[49m         return {"action": "rejected",
[0m[49m[38;5;10m+    3016[0m:[38;5;10m[49m                 "reason": "unknown_event_type"}
[0m[49m[38;5;10m+    3017[0m:[38;5;10m[49m     allowed = REFERRAL_TRANSITIONS.get(
[0m[49m[38;5;10m+    3018[0m:[38;5;10m[49m         current_state, set())
