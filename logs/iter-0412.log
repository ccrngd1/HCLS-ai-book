[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m     r"show (me|us) (other|another) (patient|patients)",
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m     r"skip (the )?(consent|caregiver) (check|verification)",
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m     r"override (the )?(seam|protocol)",
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m # --- PHI Patterns for redaction in logs ---
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m PHI_PATTERNS = {
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m     "ssn_like":       re.compile(r"\b\d{3}-\d{2}-\d{4}\b"),
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m     "card_number_like":
