[0m[49m[38;5;10m+    2578[0m:[38;5;10m[49m         "within forty-eight hours",
[0m[49m[38;5;10m+    2579[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    2580[0m:[38;5;10m[49m     contains_protocol_instruction = any(
[0m[49m[38;5;10m+    2581[0m:[38;5;10m[49m         ind in text_lower
[0m[49m[38;5;10m+    2582[0m:[38;5;10m[49m         for ind in protocol_indicators)
[0m[49m[38;5;10m+    2583[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2584[0m:[38;5;10m[49m     if contains_protocol_instruction:
