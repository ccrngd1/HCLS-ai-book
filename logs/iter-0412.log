[0m[49m[38;5;10m+    2983[0m:[38;5;10m[49m     if not referral:
[0m[49m[38;5;10m+    2984[0m:[38;5;10m[49m         if event_type != "ordered":
[0m[49m[38;5;10m+    2985[0m:[38;5;10m[49m             return {"action": "rejected",
[0m[49m[38;5;10m+    2986[0m:[38;5;10m[49m                     "reason": "referral_not_found"}
[0m[49m[38;5;10m+    2987[0m:[38;5;10m[49m         referral = {
[0m[49m[38;5;10m+    2988[0m:[38;5;10m[49m             "referral_id":        referral_id,
[0m[49m[38;5;10m+    2989[0m:[38;5;10m[49m             "patient_id":         patient_id,
[0m[49m[38;5;10m+    2990[0m:[38;5;10m[49m             "specialty":
[0m[49m[38;5;10m+    2991[0m:[38;5;10m[49m                 referral_event.get("specialty",
[0m[49m[38;5;10m+    2992[0m:[38;5;10m[49m                                     "unspecified"),
[0m[49m[38;5;10m+    2993[0m:[38;5;10m[49m             "urgency":
[0m[49m[38;5;10m+    2994[0m:[38;5;10m[49m                 referral_event.get("urgency", "routine"),
[0m[49m[38;5;10m+    2995[0m:[38;5;10m[49m             "state":              "ordered",
[0m[49m[38;5;10m+    2996[0m:[38;5;10m[49m             "state_changed_at":   _now_iso(),
[0m[49m[38;5;10m+    2997[0m:[38;5;10m[49m             "history":            [{
[0m[49m[38;5;10m+    2998[0m:[38;5;10m[49m                 "state":      "ordered",
[0m[49m[38;5;10m+    2999[0m:[38;5;10m[49m                 "changed_at": _now_iso(),
[0m[49m[38;5;10m+    3000[0m:[38;5;10m[49m             }],
[0m[49m[38;5;10m+    3001[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    3002[0m:[38;5;10m[49m         referral_table.put_item(
