[0m[49m[38;5;10m+    3024[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3025[0m:[38;5;10m[49m     # Step 8D: persist the new state with the transition
[0m[49m[38;5;10m+    3026[0m:[38;5;10m[49m     # history preserved.
[0m[49m[38;5;10m+    3027[0m:[38;5;10m[49m     referral["state"] = target_state
[0m[49m[38;5;10m+    3028[0m:[38;5;10m[49m     referral["state_changed_at"] = _now_iso()
[0m[49m[38;5;10m+    3029[0m:[38;5;10m[49m     history = referral.get("history", [])
[0m[49m[38;5;10m+    3030[0m:[38;5;10m[49m     history.append({
[0m[49m[38;5;10m+    3031[0m:[38;5;10m[49m         "state":      target_state,
[0m[49m[38;5;10m+    3032[0m:[38;5;10m[49m         "changed_at": _now_iso(),
[0m[49m[38;5;10m+    3033[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    3034[0m:[38;5;10m[49m     referral["history"] = history
[0m[49m[38;5;10m+    3035[0m:[38;5;10m[49m     referral_table.put_item(Item=_to_decimal(referral))
[0m[49m[38;5;10m+    3036[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3037[0m:[38;5;10m[49m     # Step 8E: emit downstream events.
[0m[49m[38;5;10m+    3038[0m:[38;5;10m[49m     _emit_event("referral_state_changed", {
