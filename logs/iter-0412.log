[0m[49m[38;5;10m+    2572[0m:[38;5;10m[49m     # Protocol instructions must cite a versioned protocol.
[0m[49m[38;5;10m+    2573[0m:[38;5;10m[49m     protocol_indicators = [
[0m[49m[38;5;10m+    2574[0m:[38;5;10m[49m         "the protocol",
