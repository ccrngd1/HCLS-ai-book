[0m[49m[38;5;10m+    2941[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    2942[0m:[38;5;10m[49m         "id":      "post_discharge_welcome_home",
[0m[49m[38;5;10m+    2943[0m:[38;5;10m[49m         "version": base.get("version", "v1.0"),
[0m[49m[38;5;10m+    2944[0m:[38;5;10m[49m         "items":   base.get("items", []),
