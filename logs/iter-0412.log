[0m[49m[38;5;10m+    2316[0m:[38;5;10m[49m     for the few tools the mock invokes.
[0m[49m[38;5;10m+    2317[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2318[0m:[38;5;10m[49m     tool = tool_call["tool"]
[0m[49m[38;5;10m+    2319[0m:[38;5;10m[49m     args = tool_call.get("args", {})
[0m[49m[38;5;10m+    2320[0m:[38;5;10m[49m     patient_id = (args.get("patient_id") or
[0m[49m[38;5;10m+    2321[0m:[38;5;10m[49m                   coordination_context.get("patient_id"))
[0m[49m[38;5;10m+    2322[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2323[0m:[38;5;10m[49m     if tool == "coordination_state_retrieve":
[0m[49m[38;5;10m+    2324[0m:[38;5;10m[49m         state_table = dynamodb.Table(
[0m[49m[38;5;10m+    2325[0m:[38;5;10m[49m             COORDINATION_STATE_TABLE)
[0m[49m[38;5;10m+    2326[0m:[38;5;10m[49m         return state_table.get_item(
[0m[49m[38;5;10m+    2327[0m:[38;5;10m[49m             Key={"patient_id": patient_id}).get(
[0m[49m[38;5;10m+    2328[0m:[38;5;10m[49m                 "Item", {})
[0m[49m[38;5;10m+    2329[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2330[0m:[38;5;10m[49m     if tool == "referral_lifecycle_retrieve":
[0m[49m[38;5;10m+    2331[0m:[38;5;10m[49m         referral_table = dynamodb.Table(
[0m[49m[38;5;10m+    2332[0m:[38;5;10m[49m             REFERRAL_LIFECYCLE_TABLE)
[0m[49m[38;5;10m+    2333[0m:[38;5;10m[49m         results = []
[0m[49m[38;5;10m+    2334[0m:[38;5;10m[49m         for record_list in referral_table.items.values():
[0m[49m[38;5;10m+    2335[0m:[38;5;10m[49m             for ref in record_list:
