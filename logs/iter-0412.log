[0m[49m[38;5;10m+    2675[0m:[38;5;10m[49m         "citations":
[0m[49m[38;5;10m+    2676[0m:[38;5;10m[49m             response_payload.get("citations", []),
[0m[49m[38;5;10m+    2677[0m:[38;5;10m[49m         "tool_calls_summary":
[0m[49m[38;5;10m+    2678[0m:[38;5;10m[49m             [{"tool": tc["tool"]}
[0m[49m[38;5;10m+    2679[0m:[38;5;10m[49m              for tc in response_payload.get(
[0m[49m[38;5;10m+    2680[0m:[38;5;10m[49m                  "tool_calls", [])],
[0m[49m[38;5;10m+    2681[0m:[38;5;10m[49m         "disposition":
[0m[49m[38;5;10m+    2682[0m:[38;5;10m[49m             response_payload.get("disposition"),
[0m[49m[38;5;10m+    2683[0m:[38;5;10m[49m         "timestamp":          _now_iso(),
[0m[49m[38;5;10m+    2684[0m:[38;5;10m[49m     }))
[0m[49m[38;5;10m+    2685[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2686[0m:[38;5;10m[49m     state_table = dynamodb.Table(CONVERSATION_STATE_TABLE)
[0m[49m[38;5;10m+    2687[0m:[38;5;10m[49m     session = state_table.get_item(
[0m[49m[38;5;10m+    2688[0m:[38;5;10m[49m         Key={"session_id": session_id}).get("Item", {})
[0m[49m[38;5;10m+    2689[0m:[38;5;10m[49m     session["turn_count"] = int(
[0m[49m[38;5;10m+    2690[0m:[38;5;10m[49m         session.get("turn_count", 0)) + 1
[0m[49m[38;5;10m+    2691[0m:[38;5;10m[49m     state_table.put_item(Item=_to_decimal(session))
[0m[49m[38;5;10m+    2692[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2693[0m:[38;5;10m[49m     # Step 6F: persist a coordination-decision record per
[0m[49m[38;5;10m+    2694[0m:[38;5;10m[49m     # actionable decision in the response.
[0m[49m[38;5;10m+    2695[0m:[38;5;10m[49m     decision_ids = []
[0m[49m[38;5;10m+    2696[0m:[38;5;10m[49m     decision_table = dynamodb.Table(DECISION_RECORD_TABLE)
[0m[49m[38;5;10m+    2697[0m:[38;5;10m[49m     for decision in _extract_coordination_decisions(
[0m[49m[38;5;10m+    2698[0m:[38;5;10m[49m             response_payload):
[0m[49m[38;5;10m+    2699[0m:[38;5;10m[49m         decision_id = f"dec_{uuid.uuid4().hex}"
[0m[49m[38;5;10m+    2700[0m:[38;5;10m[49m         record = {
[0m[49m[38;5;10m+    2701[0m:[38;5;10m[49m             "decision_id":            decision_id,
[0m[49m[38;5;10m+    2702[0m:[38;5;10m[49m             "session_id":             session_id,
[0m[49m[38;5;10m+    2703[0m:[38;5;10m[49m             "patient_id":             patient_id,
[0m[49m[38;5;10m+    2704[0m:[38;5;10m[49m             "speaker_role":           speaker_role,
[0m[49m[38;5;10m+    2705[0m:[38;5;10m[49m             "decision_type":          decision["type"],
[0m[49m[38;5;10m+    2706[0m:[38;5;10m[49m             "decision_payload":       decision["payload"],
[0m[49m[38;5;10m+    2707[0m:[38;5;10m[49m             "citations":              decision.get(
[0m[49m[38;5;10m+    2708[0m:[38;5;10m[49m                 "citations", []),
[0m[49m[38;5;10m+    2709[0m:[38;5;10m[49m             "active_protocol_corpus_version":
[0m[49m[38;5;10m+    2710[0m:[38;5;10m[49m                 PROTOCOL_CORPUS_VERSION,
[0m[49m[38;5;10m+    2711[0m:[38;5;10m[49m             "active_seam_rule_library_version":
[0m[49m[38;5;10m+    2712[0m:[38;5;10m[49m                 SEAM_RULE_LIBRARY_VERSION,
[0m[49m[38;5;10m+    2713[0m:[38;5;10m[49m             "active_model_id":        ORCHESTRATION_MODEL_ID,
[0m[49m[38;5;10m+    2714[0m:[38;5;10m[49m             "active_prompt_version":  PROMPT_VERSION,
[0m[49m[38;5;10m+    2715[0m:[38;5;10m[49m             "active_agent_version":   AGENT_VERSION,
[0m[49m[38;5;10m+    2716[0m:[38;5;10m[49m             "active_consent_id":
[0m[49m[38;5;10m+    2717[0m:[38;5;10m[49m                 coordination_context["consent"].get(
[0m[49m[38;5;10m+    2718[0m:[38;5;10m[49m                     "consent_id"),
[0m[49m[38;5;10m+    2719[0m:[38;5;10m[49m             "timestamp":              _now_iso(),
[0m[49m[38;5;10m+    2720[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    2721[0m:[38;5;10m[49m         decision_table.put_item(Item=_to_decimal(record))
[0m[49m[38;5;10m+    2722[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2723[0m:[38;5;10m[49m         # Mirror to S3 with Object Lock for the decision-
[0m[49m[38;5;10m+    2724[0m:[38;5;10m[49m         # record archive. Retention sized to the longest
[0m[49m[38;5;10m+    2725[0m:[38;5;10m[49m         # of HIPAA's six-year minimum, state-specific
[0m[49m[38;5;10m+    2726[0m:[38;5;10m[49m         # medical-record retention, and any FDA SaMD post-
[0m[49m[38;5;10m+    2727[0m:[38;5;10m[49m         # market obligations.
[0m[49m[38;5;10m+    2728[0m:[38;5;10m[49m         s3_key = (
[0m[49m[38;5;10m+    2729[0m:[38;5;10m[49m             f"decisions/{patient_id}/"
[0m[49m[38;5;10m+    2730[0m:[38;5;10m[49m             f"{datetime.now(timezone.utc).strftime('%Y/%m/%d')}/"
[0m[49m[38;5;10m+    2731[0m:[38;5;10m[49m             f"{decision_id}.json")
[0m[49m[38;5;10m+    2732[0m:[38;5;10m[49m         s3_client.put_object(
[0m[49m[38;5;10m+    2733[0m:[38;5;10m[49m             Bucket=DECISION_RECORD_BUCKET,
[0m[49m[38;5;10m+    2734[0m:[38;5;10m[49m             Key=s3_key,
[0m[49m[38;5;10m+    2735[0m:[38;5;10m[49m             Body=json.dumps(_from_decimal(record)),
[0m[49m[38;5;10m+    2736[0m:[38;5;10m[49m             ServerSideEncryption="aws:kms",
[0m[49m[38;5;10m+    2737[0m:[38;5;10m[49m             SSEKMSKeyId=DECISION_RECORD_KMS_KEY_ID)
[0m[49m[38;5;10m+    2738[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2739[0m:[38;5;10m[49m         _emit_event("coordination_decision_recorded", {
[0m[49m[38;5;10m+    2740[0m:[38;5;10m[49m             "decision_id":   decision_id,
[0m[49m[38;5;10m+    2741[0m:[38;5;10m[49m             "decision_type": decision["type"],
