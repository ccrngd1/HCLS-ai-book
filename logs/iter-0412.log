[0m[49m[38;5;10m+    2601[0m:[38;5;10m[49m     return {"passes": True}
[0m[49m[38;5;10m+    2602[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2603[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2604[0m:[38;5;10m[49m def _speaker_role_disclosure_check(*, response_text,
[0m[49m[38;5;10m+    2605[0m:[38;5;10m[49m                                        speaker_role,
[0m[49m[38;5;10m+    2606[0m:[38;5;10m[49m                                        carve_outs):
[0m[49m[38;5;10m+    2607[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2608[0m:[38;5;10m[49m     Check that the response honors the speaker-role carve-
[0m[49m[38;5;10m+    2609[0m:[38;5;10m[49m     outs. Demo: rejects if any carve-out keyword appears
[0m[49m[38;5;10m+    2610[0m:[38;5;10m[49m     in the response text addressed to a caregiver. The
[0m[49m[38;5;10m+    2611[0m:[38;5;10m[49m     production check is more nuanced.
[0m[49m[38;5;10m+    2612[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2613[0m:[38;5;10m[49m     if speaker_role != "caregiver" or not carve_outs:
[0m[49m[38;5;10m+    2614[0m:[38;5;10m[49m         return {"violation": False}
[0m[49m[38;5;10m+    2615[0m:[38;5;10m[49m     text_lower = response_text.lower()
[0m[49m[38;5;10m+    2616[0m:[38;5;10m[49m     for carve_out in carve_outs:
[0m[49m[38;5;10m+    2617[0m:[38;5;10m[49m         if carve_out.lower() in text_lower:
[0m[49m[38;5;10m+    2618[0m:[38;5;10m[49m             return {"violation": True,
[0m[49m[38;5;10m+    2619[0m:[38;5;10m[49m                     "reason":
[0m[49m[38;5;10m+    2620[0m:[38;5;10m[49m                         f"carve_out_disclosed_{carve_out}"}
[0m[49m[38;5;10m+    2621[0m:[38;5;10m[49m     return {"violation": False}
[0m[49m[38;5;10m+    2622[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2623[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2624[0m:[38;5;10m[49m def _suggests_clinical_judgment(response_text):
[0m[49m[38;5;10m+    2625[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2626[0m:[38;5;10m[49m     Quick heuristic for whether a response is making a
[0m[49m[38;5;10m+    2627[0m:[38;5;10m[49m     clinical-judgment claim. Production runs a classifier;
[0m[49m[38;5;10m+    2628[0m:[38;5;10m[49m     the demo runs simple keyword matching.
[0m[49m[38;5;10m+    2629[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2630[0m:[38;5;10m[49m     text_lower = response_text.lower()
[0m[49m[38;5;10m+    2631[0m:[38;5;10m[49m     indicators = [
[0m[49m[38;5;10m+    2632[0m:[38;5;10m[49m         "you should",
[0m[49m[38;5;10m+    2633[0m:[38;5;10m[49m         "i recommend",
[0m[49m[38;5;10m+    2634[0m:[38;5;10m[49m         "it would be best",
[0m[49m[38;5;10m+    2635[0m:[38;5;10m[49m         "the right thing is to",
[0m[49m[38;5;10m+    2636[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    2637[0m:[38;5;10m[49m     return any(ind in text_lower for ind in indicators)
[0m[49m[38;5;10m+    2638[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2639[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2640[0m:[38;5;10m[49m def _contains_deference(response_text):
[0m[49m[38;5;10m+    2641[0m:[38;5;10m[49m     """Check whether the response defers to the care team."""
[0m[49m[38;5;10m+    2642[0m:[38;5;10m[49m     text_lower = response_text.lower()
[0m[49m[38;5;10m+    2643[0m:[38;5;10m[49m     deference_indicators = [
[0m[49m[38;5;10m+    2644[0m:[38;5;10m[49m         "your care team",
[0m[49m[38;5;10m+    2645[0m:[38;5;10m[49m         "your clinician",
[0m[49m[38;5;10m+    2646[0m:[38;5;10m[49m         "your doctor",
[0m[49m[38;5;10m+    2647[0m:[38;5;10m[49m         "your nurse",
[0m[49m[38;5;10m+    2648[0m:[38;5;10m[49m         "your prescriber",
[0m[49m[38;5;10m+    2649[0m:[38;5;10m[49m         "i'll flag this",
[0m[49m[38;5;10m+    2650[0m:[38;5;10m[49m         "let me check",
[0m[49m[38;5;10m+    2651[0m:[38;5;10m[49m         "i'm not making the",
[0m[49m[38;5;10m+    2652[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    2653[0m:[38;5;10m[49m     return any(ind in text_lower
[0m[49m[38;5;10m+    2654[0m:[38;5;10m[49m                for ind in deference_indicators)
[0m[49m[38;5;10m+    2655[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2656[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2657[0m:[38;5;10m[49m def persist_coordination_artifacts(*,
[0m[49m[38;5;10m+    2658[0m:[38;5;10m[49m                                        session_id,
