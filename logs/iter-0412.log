[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m     r"(instructions|messages|prompts)",
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m     r"disregard (all |any |the )?(previous|prior|above) "
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m     r"(instructions|messages|prompts)",
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m     r"you are now (a |an )?(doctor|nurse|clinician|"
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m     r"therapist)",
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m     r"forget (all |any |everything )?(you|your)",
