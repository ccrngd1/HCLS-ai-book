[0m[49m[38;5;10m+    3061[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    3062[0m:[38;5;10m[49m     elif next_action["type"] == "alert_care_team":
[0m[49m[38;5;10m+    3063[0m:[38;5;10m[49m         mock_clinician_queue.deliver_alert({
[0m[49m[38;5;10m+    3064[0m:[38;5;10m[49m             "alert_id":      f"alert_{uuid.uuid4().hex}",
[0m[49m[38;5;10m+    3065[0m:[38;5;10m[49m             "alert_type":
[0m[49m[38;5;10m+    3066[0m:[38;5;10m[49m                 "referral_aged_past_protocol_window",
[0m[49m[38;5;10m+    3067[0m:[38;5;10m[49m             "patient_id":    patient_id,
[0m[49m[38;5;10m+    3068[0m:[38;5;10m[49m             "referral_id":   referral_id,
[0m[49m[38;5;10m+    3069[0m:[38;5;10m[49m         })
