[0m[49m[38;5;10m+    2948[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2949[0m:[38;5;10m[49m def _select_state_machine_arn(*, destination):
[0m[49m[38;5;10m+    2950[0m:[38;5;10m[49m     """Pick the Step Functions state machine for the destination."""
