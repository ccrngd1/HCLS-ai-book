[0m[49m[38;5;10m+    2555[0m:[38;5;10m[49m                 "reason":
[0m[49m[38;5;10m+    2556[0m:[38;5;10m[49m                     "state_assertion_without_provenance",
[0m[49m[38;5;10m+    2557[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    2558[0m:[38;5;10m[49m 
