[0m[49m[38;5;10m+    3056[0m:[38;5;10m[49m                     "specialty_referral_scheduling_checkin",
[0m[49m[38;5;10m+    3057[0m:[38;5;10m[49m                 "channel_preference": "sms",
[0m[49m[38;5;10m+    3058[0m:[38;5;10m[49m                 "payload": {
[0m[49m[38;5;10m+    3059[0m:[38;5;10m[49m                     "referral_id": referral_id,
