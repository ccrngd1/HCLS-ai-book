[0m[49m[38;5;10m+    1221[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1222[0m:[38;5;10m[49m     # Step 2C: classify sensitive-record categories. Some
[0m[49m[38;5;10m+    1223[0m:[38;5;10m[49m     # categories trigger separate handling per state and
[0m[49m[38;5;10m+    1224[0m:[38;5;10m[49m     # federal rules; this is operational, not optional.
[0m[49m[38;5;10m+    1225[0m:[38;5;10m[49m     sensitivity = _classify_sensitivity(parsed)
[0m[49m[38;5;10m+    1226[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1227[0m:[38;5;10m[49m     # Step 2D: enforce per-source consent posture. If the
[0m[49m[38;5;10m+    1228[0m:[38;5;10m[49m     # patient has not consented to ingestion from this
[0m[49m[38;5;10m+    1229[0m:[38;5;10m[49m     # source, or has revoked consent, the data is dropped
[0m[49m[38;5;10m+    1230[0m:[38;5;10m[49m     # and the revocation is honored.
[0m[49m[38;5;10m+    1231[0m:[38;5;10m[49m     consent_check = _verify_consent(
[0m[49m[38;5;10m+    1232[0m:[38;5;10m[49m         patient_id=parsed["patient_id"],
[0m[49m[38;5;10m+    1233[0m:[38;5;10m[49m         source_type=source_type,
[0m[49m[38;5;10m+    1234[0m:[38;5;10m[49m         sensitivity_category=sensitivity["category"])
[0m[49m[38;5;10m+    1235[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1236[0m:[38;5;10m[49m     if not consent_check["allowed"]:
[0m[49m[38;5;10m+    1237[0m:[38;5;10m[49m         return {"action": "consent_denied"}
[0m[49m[38;5;10m+    1238[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1239[0m:[38;5;10m[49m     # Step 2E: write to the provenance journal. Provenance
[0m[49m[38;5;10m+    1240[0m:[38;5;10m[49m     # records are append-only and on a separately-managed
[0m[49m[38;5;10m+    1241[0m:[38;5;10m[49m     # KMS key for blast-radius containment.
[0m[49m[38;5;10m+    1242[0m:[38;5;10m[49m     provenance_id = _write_provenance(
[0m[49m[38;5;10m+    1243[0m:[38;5;10m[49m         patient_id=parsed["patient_id"],
[0m[49m[38;5;10m+    1244[0m:[38;5;10m[49m         source_type=source_type,
[0m[49m[38;5;10m+    1245[0m:[38;5;10m[49m         ingestion_metadata=ingestion_metadata,
[0m[49m[38;5;10m+    1246[0m:[38;5;10m[49m         parsed=parsed,
[0m[49m[38;5;10m+    1247[0m:[38;5;10m[49m         sensitivity_category=sensitivity["category"],
[0m[49m[38;5;10m+    1248[0m:[38;5;10m[49m         raw_message=raw_message)
[0m[49m[38;5;10m+    1249[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1250[0m:[38;5;10m[49m     # Step 2F: normalize to the coordination-state schema.
[0m[49m[38;5;10m+    1251[0m:[38;5;10m[49m     normalized = _normalize_event(source_type, parsed)
[0m[49m[38;5;10m+    1252[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1253[0m:[38;5;10m[49m     # Step 2G: reconcile against existing coordination state.
[0m[49m[38;5;10m+    1254[0m:[38;5;10m[49m     reconciliation = _reconcile_with_state(
[0m[49m[38;5;10m+    1255[0m:[38;5;10m[49m         patient_id=parsed["patient_id"],
[0m[49m[38;5;10m+    1256[0m:[38;5;10m[49m         normalized_event=normalized,
[0m[49m[38;5;10m+    1257[0m:[38;5;10m[49m         provenance_id=provenance_id)
[0m[49m[38;5;10m+    1258[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1259[0m:[38;5;10m[49m     # Step 2H: update the coordination-state-store with
[0m[49m[38;5;10m+    1260[0m:[38;5;10m[49m     # provenance references preserved.
[0m[49m[38;5;10m+    1261[0m:[38;5;10m[49m     _update_coordination_state(
[0m[49m[38;5;10m+    1262[0m:[38;5;10m[49m         patient_id=parsed["patient_id"],
[0m[49m[38;5;10m+    1263[0m:[38;5;10m[49m         normalized_event=normalized,
[0m[49m[38;5;10m+    1264[0m:[38;5;10m[49m         reconciliation=reconciliation,
[0m[49m[38;5;10m+    1265[0m:[38;5;10m[49m         provenance_id=provenance_id)
[0m[49m[38;5;10m+    1266[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1267[0m:[38;5;10m[49m     # Step 2I: emit care-event triggers for downstream
[0m[49m[38;5;10m+    1268[0m:[38;5;10m[49m     # protocol and seam-detection processing.
[0m[49m[38;5;10m+    1269[0m:[38;5;10m[49m     triggers = _derive_triggers(normalized, reconciliation)
[0m[49m[38;5;10m+    1270[0m:[38;5;10m[49m     for trigger in triggers:
[0m[49m[38;5;10m+    1271[0m:[38;5;10m[49m         _emit_event(trigger["type"], trigger["payload"])
[0m[49m[38;5;10m+    1272[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1273[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    1274[0m:[38;5;10m[49m         "action":          "ingested",
[0m[49m[38;5;10m+    1275[0m:[38;5;10m[49m         "provenance_id":   provenance_id,
[0m[49m[38;5;10m+    1276[0m:[38;5;10m[49m         "triggers_emitted": len(triggers),
[0m[49m[38;5;10m+    1277[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1278[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1279[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1280[0m:[38;5;10m[49m def _parse_message(source_type, raw_message):
[0m[49m[38;5;10m+    1281[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1282[0m:[38;5;10m[49m     Per-source parsing. The demo accepts pre-structured
[0m[49m[38;5;10m+    1283[0m:[38;5;10m[49m     dicts; production has dedicated parsers (hl7apy or
[0m[49m[38;5;10m+    1284[0m:[38;5;10m[49m     similar for HL7 v2; the FHIR resources from the FHIR
[0m[49m[38;5;10m+    1285[0m:[38;5;10m[49m     APIs are already structured; NCPDP for pharmacy; vendor-
[0m[49m[38;5;10m+    1286[0m:[38;5;10m[49m     specific formats for home health).
[0m[49m[38;5;10m+    1287[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1288[0m:[38;5;10m[49m     if isinstance(raw_message, dict):
[0m[49m[38;5;10m+    1289[0m:[38;5;10m[49m         return raw_message
[0m[49m[38;5;10m+    1290[0m:[38;5;10m[49m     return {}
[0m[49m[38;5;10m+    1291[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1292[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1293[0m:[38;5;10m[49m def _classify_sensitivity(parsed):
[0m[49m[38;5;10m+    1294[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1295[0m:[38;5;10m[49m     Classify the sensitive-record category. Production has
[0m[49m[38;5;10m+    1296[0m:[38;5;10m[49m     a calibrated classifier reviewed by legal counsel and
[0m[49m[38;5;10m+    1297[0m:[38;5;10m[49m     clinical leadership; the demo runs a rule-based check.
[0m[49m[38;5;10m+    1298[0m:[38;5;10m[49m     Categories include "general", "mental_health",
[0m[49m[38;5;10m+    1299[0m:[38;5;10m[49m     "substance_use_42_cfr_part_2", "hiv", "genetic", and
[0m[49m[38;5;10m+    1300[0m:[38;5;10m[49m     "adolescent_confidential".
[0m[49m[38;5;10m+    1301[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1302[0m:[38;5;10m[49m     text = json.dumps(parsed).lower()
[0m[49m[38;5;10m+    1303[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1304[0m:[38;5;10m[49m     if "substance use" in text or \
[0m[49m[38;5;10m+    1305[0m:[38;5;10m[49m             "42 cfr" in text or \
[0m[49m[38;5;10m+    1306[0m:[38;5;10m[49m             "addiction" in text:
[0m[49m[38;5;10m+    1307[0m:[38;5;10m[49m         return {"category": "substance_use_42_cfr_part_2"}
[0m[49m[38;5;10m+    1308[0m:[38;5;10m[49m     if "psychiatric" in text or \
[0m[49m[38;5;10m+    1309[0m:[38;5;10m[49m             "mental health" in text or \
[0m[49m[38;5;10m+    1310[0m:[38;5;10m[49m             "behavioral health" in text:
[0m[49m[38;5;10m+    1311[0m:[38;5;10m[49m         return {"category": "mental_health"}
[0m[49m[38;5;10m+    1312[0m:[38;5;10m[49m     if "hiv" in text:
[0m[49m[38;5;10m+    1313[0m:[38;5;10m[49m         return {"category": "hiv"}
[0m[49m[38;5;10m+    1314[0m:[38;5;10m[49m     if "genetic" in text or "brca" in text:
[0m[49m[38;5;10m+    1315[0m:[38;5;10m[49m         return {"category": "genetic"}
[0m[49m[38;5;10m+    1316[0m:[38;5;10m[49m     return {"category": "general"}
[0m[49m[38;5;10m+    1317[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1318[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1319[0m:[38;5;10m[49m def _verify_consent(*, patient_id, source_type,
[0m[49m[38;5;10m+    1320[0m:[38;5;10m[49m                        sensitivity_category):
[0m[49m[38;5;10m+    1321[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1322[0m:[38;5;10m[49m     Check the patient's consent posture against the data
[0m[49m[38;5;10m+    1323[0m:[38;5;10m[49m     source and the sensitivity category. Sensitivity
[0m[49m[38;5;10m+    1324[0m:[38;5;10m[49m     categories may require explicit category-specific
[0m[49m[38;5;10m+    1325[0m:[38;5;10m[49m     consent per state and federal rules.
[0m[49m[38;5;10m+    1326[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1327[0m:[38;5;10m[49m     consent_table = dynamodb.Table(CONSENT_RECORD_TABLE)
[0m[49m[38;5;10m+    1328[0m:[38;5;10m[49m     consent_record = consent_table.get_item(
[0m[49m[38;5;10m+    1329[0m:[38;5;10m[49m         Key={"patient_id": patient_id}).get("Item", {})
[0m[49m[38;5;10m+    1330[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1331[0m:[38;5;10m[49m     if not consent_record:
[0m[49m[38;5;10m+    1332[0m:[38;5;10m[49m         return {"allowed": False,
[0m[49m[38;5;10m+    1333[0m:[38;5;10m[49m                 "reason":  "no_consent_record"}
[0m[49m[38;5;10m+    1334[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1335[0m:[38;5;10m[49m     source_consents = consent_record.get(
[0m[49m[38;5;10m+    1336[0m:[38;5;10m[49m         "data_source_consents", {})
[0m[49m[38;5;10m+    1337[0m:[38;5;10m[49m     if source_consents.get(source_type) is False:
[0m[49m[38;5;10m+    1338[0m:[38;5;10m[49m         return {"allowed": False,
[0m[49m[38;5;10m+    1339[0m:[38;5;10m[49m                 "reason":  "source_not_consented"}
[0m[49m[38;5;10m+    1340[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1341[0m:[38;5;10m[49m     if sensitivity_category != "general":
[0m[49m[38;5;10m+    1342[0m:[38;5;10m[49m         sensitive_consents = consent_record.get(
[0m[49m[38;5;10m+    1343[0m:[38;5;10m[49m             "sensitive_record_categories", {})
[0m[49m[38;5;10m+    1344[0m:[38;5;10m[49m         if not sensitive_consents.get(
[0m[49m[38;5;10m+    1345[0m:[38;5;10m[49m                 sensitivity_category):
[0m[49m[38;5;10m+    1346[0m:[38;5;10m[49m             return {"allowed": False,
[0m[49m[38;5;10m+    1347[0m:[38;5;10m[49m                     "reason":
[0m[49m[38;5;10m+    1348[0m:[38;5;10m[49m                         f"{sensitivity_category}_not_consented"}
[0m[49m[38;5;10m+    1349[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1350[0m:[38;5;10m[49m     return {"allowed": True}
[0m[49m[38;5;10m+    1351[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1352[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1353[0m:[38;5;10m[49m def _write_provenance(*, patient_id, source_type,
[0m[49m[38;5;10m+    1354[0m:[38;5;10m[49m                          ingestion_metadata, parsed,
[0m[49m[38;5;10m+    1355[0m:[38;5;10m[49m                          sensitivity_category, raw_message):
[0m[49m[38;5;10m+    1356[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1357[0m:[38;5;10m[49m     Append the provenance record. The provenance journal
[0m[49m[38;5;10m+    1358[0m:[38;5;10m[49m     is on a separately-managed KMS key for blast-radius
[0m[49m[38;5;10m+    1359[0m:[38;5;10m[49m     containment and is mirrored to the provenance archive
[0m[49m[38;5;10m+    1360[0m:[38;5;10m[49m     in S3 with Object Lock in compliance mode.
[0m[49m[38;5;10m+    1361[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1362[0m:[38;5;10m[49m     provenance_id = f"prov_{uuid.uuid4().hex}"
[0m[49m[38;5;10m+    1363[0m:[38;5;10m[49m     record = {
[0m[49m[38;5;10m+    1364[0m:[38;5;10m[49m         "provenance_id":         provenance_id,
[0m[49m[38;5;10m+    1365[0m:[38;5;10m[49m         "patient_id":            patient_id,
[0m[49m[38;5;10m+    1366[0m:[38;5;10m[49m         "source_type":           source_type,
[0m[49m[38;5;10m+    1367[0m:[38;5;10m[49m         "source_message_id":
[0m[49m[38;5;10m+    1368[0m:[38;5;10m[49m             ingestion_metadata.get("message_id", ""),
[0m[49m[38;5;10m+    1369[0m:[38;5;10m[49m         "source_timestamp":
[0m[49m[38;5;10m+    1370[0m:[38;5;10m[49m             parsed.get("source_timestamp", _now_iso()),
[0m[49m[38;5;10m+    1371[0m:[38;5;10m[49m         "ingestion_timestamp":   _now_iso(),
[0m[49m[38;5;10m+    1372[0m:[38;5;10m[49m         "ingestion_path":
[0m[49m[38;5;10m+    1373[0m:[38;5;10m[49m             ingestion_metadata.get("path", ""),
[0m[49m[38;5;10m+    1374[0m:[38;5;10m[49m         "integrity_hash":
[0m[49m[38;5;10m+    1375[0m:[38;5;10m[49m             str(hash(json.dumps(raw_message,
[0m[49m[38;5;10m+    1376[0m:[38;5;10m[49m                                  sort_keys=True,
[0m[49m[38;5;10m+    1377[0m:[38;5;10m[49m                                  default=str))),
[0m[49m[38;5;10m+    1378[0m:[38;5;10m[49m         "sensitivity_category":  sensitivity_category,
[0m[49m[38;5;10m+    1379[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1380[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1381[0m:[38;5;10m[49m     table = dynamodb.Table(PROVENANCE_JOURNAL_TABLE)
[0m[49m[38;5;10m+    1382[0m:[38;5;10m[49m     table.put_item(Item=_to_decimal(record))
[0m[49m[38;5;10m+    1383[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1384[0m:[38;5;10m[49m     # Mirror to the separately-keyed S3 archive. Production
[0m[49m[38;5;10m+    1385[0m:[38;5;10m[49m     # uses a different KMS key from the general decision-
[0m[49m[38;5;10m+    1386[0m:[38;5;10m[49m     # record archive.
[0m[49m[38;5;10m+    1387[0m:[38;5;10m[49m     s3_key = (
[0m[49m[38;5;10m+    1388[0m:[38;5;10m[49m         f"provenance/{patient_id}/"
[0m[49m[38;5;10m+    1389[0m:[38;5;10m[49m         f"{datetime.now(timezone.utc).strftime('%Y/%m/%d')}/"
[0m[49m[38;5;10m+    1390[0m:[38;5;10m[49m         f"{provenance_id}.json")
[0m[49m[38;5;10m+    1391[0m:[38;5;10m[49m     s3_client.put_object(
[0m[49m[38;5;10m+    1392[0m:[38;5;10m[49m         Bucket=PROVENANCE_ARCHIVE_BUCKET,
[0m[49m[38;5;10m+    1393[0m:[38;5;10m[49m         Key=s3_key,
[0m[49m[38;5;10m+    1394[0m:[38;5;10m[49m         Body=json.dumps(_from_decimal(record)),
[0m[49m[38;5;10m+    1395[0m:[38;5;10m[49m         ServerSideEncryption="aws:kms",
[0m[49m[38;5;10m+    1396[0m:[38;5;10m[49m         SSEKMSKeyId=PROVENANCE_KMS_KEY_ID)
[0m[49m[38;5;10m+    1397[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1398[0m:[38;5;10m[49m     return provenance_id
[0m[49m[38;5;10m+    1399[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1400[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1401[0m:[38;5;10m[49m def _normalize_event(source_type, parsed):
[0m[49m[38;5;10m+    1402[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1403[0m:[38;5;10m[49m     Normalize the event to the coordination-state schema.
[0m[49m[38;5;10m+    1404[0m:[38;5;10m[49m     For FHIR-native sources, the event is already in
[0m[49m[38;5;10m+    1405[0m:[38;5;10m[49m     FHIR-aligned shape; for HL7 v2 and other non-FHIR
[0m[49m[38;5;10m+    1406[0m:[38;5;10m[49m     sources, this maps to FHIR-aligned shapes for
[0m[49m[38;5;10m+    1407[0m:[38;5;10m[49m     consistency. Demo: passes through with type tagging.
[0m[49m[38;5;10m+    1408[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1409[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    1410[0m:[38;5;10m[49m         "kind":        _kind_from_source_type(source_type),
[0m[49m[38;5;10m+    1411[0m:[38;5;10m[49m         "source_type": source_type,
