[0m[49m[38;5;10m+    3046[0m:[38;5;10m[49m     next_action = _next_referral_action(referral, event_type)
[0m[49m[38;5;10m+    3047[0m:[38;5;10m[49m     if next_action["type"] == "engage_patient":
[0m[49m[38;5;10m+    3048[0m:[38;5;10m[49m         _schedule_engagement(
