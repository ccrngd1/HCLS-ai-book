[0m[49m[39m  328, 342[0m:[39m[49m                 classification: classification,
[0m[49m[39m  329, 343[0m:[39m[49m                 confidence:     average_confidence(results, classification),
[0m[49m[39m  330, 344[0m:[39m[49m                 onset_time:     first_detection_timestamp(results, classification),
[0m[49m[39m  331, 345[0m:[39m[49m                 severity:       get_clinical_severity(classification),
[0m[49m[39m  332, 346[0m:[39m[49m                 evidence_window: get_evidence_samples(results, classification)
[0m[49m[39m  333, 347[0m:[39m[49m             }
[0m[49m[39m  334, 348[0m:[39m[49m 
[0m[49m[39m  335, 349[0m:[39m[49m             // Publish alert to clinical notification system.
[0m[49m[38;5;10m+      350[0m:[38;5;10m[49m             // SNS topic uses SSE-KMS encryption. Alert contains session_id (opaque),
[0m[49m[38;5;10m+      351[0m:[38;5;10m[49m             // not MRN. The receiving clinical app resolves patient identity locally.
