[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m # time bug, not a runtime surprise.
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m for _name, _value in [
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m     ("LONGITUDINAL_STORE_TABLE",     LONGITUDINAL_STORE_TABLE),
