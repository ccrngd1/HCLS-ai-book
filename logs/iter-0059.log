[0m[49m[38;5;10m+    1676[0m:[38;5;10m[49m         for keyword in config["keywords"]:
[0m[49m[38;5;10m+    1677[0m:[38;5;10m[49m             if keyword in msg_lower:
[0m[49m[38;5;10m+    1678[0m:[38;5;10m[49m                 return {
[0m[49m[38;5;10m+    1679[0m:[38;5;10m[49m                     "disclosure_detected": True,
[0m[49m[38;5;10m+    1680[0m:[38;5;10m[49m                     "category":            category,
[0m[49m[38;5;10m+    1681[0m:[38;5;10m[49m                     "route":               config["route"],
[0m[49m[38;5;10m+    1682[0m:[38;5;10m[49m                     "mandatory_reporting":
[0m[49m[38;5;10m+    1683[0m:[38;5;10m[49m                         config["mandatory_reporting"],
[0m[49m[38;5;10m+    1684[0m:[38;5;10m[49m                 }
[0m[49m[38;5;10m+    1685[0m:[38;5;10m[49m     return {"disclosure_detected": False}
[0m[49m[38;5;10m+    1686[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1687[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1688[0m:[38;5;10m[49m def _load_longitudinal_context(*, patient_id, session_id):
[0m[49m[38;5;10m+    1689[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1690[0m:[38;5;10m[49m     Load the patient's longitudinal context for response
