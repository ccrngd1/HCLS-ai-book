[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m # --- Therapeutic Content Library (illustrative) ---
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m # In production this is the institutionally-curated, version-
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m # controlled, behavioral-health-clinical-leadership-signed-off
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m # library indexed in a Bedrock Knowledge Base with metadata
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m # filters for modality, indication, contraindication,
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m # audience, language, reading level, and version. The dict
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m # below holds a few illustrative items demonstrating the
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m # structure. Production has 50-200 items per condition with
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m # defined indications and contraindications; a behavioral-
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m # activation exercise indicated for moderate depression has
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m # different contraindications from a distress-tolerance
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m # skill indicated for acute distress.
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m THERAPEUTIC_CONTENT_LIBRARY = {
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m     "grounding_5_4_3_2_1": {
