[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m         "content_version": "v1.0",
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m         "modality": "distress_tolerance",
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m         "indication": ["acute_anxiety", "panic", "spiral",
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m                        "dissociation_mild"],
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m         "contraindication": ["active_psychosis"],
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m         "audience": "adult",
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m         "language": "en-US",
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m         "reading_level": "grade_6",
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m         "duration_minutes": 5,
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m         "title": "5-4-3-2-1 Sensory Grounding",
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m         "steps": [
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m             "Find a comfortable position. Take a breath.",
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m             ("Name five things you can see right now. "
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m              "Just type them out as you notice them."),
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m             ("Name four things you can feel. Physical "
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m              "sensations, like the texture of a sleeve "
