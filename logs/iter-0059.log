[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m # --- Versioning ---
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m # Every conversation turn carries the model version, the
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m # prompt version, the Knowledge Base versions, the Guardrail
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m # version, the active therapeutic-content-corpus version,
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m # the active crisis-screen-classifier version, and the
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m # active consent version. This is how a future audit
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m # reconstructs which versions produced any given support
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m # decision.
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m PROMPT_VERSION                   = "mh-prompt-v1.0"
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m AGENT_VERSION                    = "mh-agent-v1.0"
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m THERAPEUTIC_CONTENT_VERSION      = "therapeutic-corpus-v1.0"
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m CRISIS_CLASSIFIER_VERSION        = "crisis-classifier-v1.0"
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m INSTITUTION_ID                   = "acme-health-system"
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m INSTITUTION_DISPLAY_NAME         = "Acme Behavioral Health"
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m # --- Model IDs ---
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m # Two model roles. The orchestration model handles the multi-
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m # step reasoning, the tool calls, the warm-but-boundaried
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m # language, and the final response generation. The smaller
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m # model handles intent classification, crisis pre-filtering,
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m # and routine summarization.
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m #
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m # If your region requires cross-region inference, use the
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m # inference profile ID. TODO: verify the exact model IDs
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m # available in your region and account; Bedrock model
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m # availability evolves over time.
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m SMALL_MODEL_ID                   = "anthropic.claude-3-5-haiku-20241022-v1:0"
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m ORCHESTRATION_MODEL_ID           = "anthropic.claude-3-5-sonnet-20241022-v2:0"
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m # --- Pipeline Tuning ---
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m # Below this confidence on intent classification, ask a
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m # clarifying question rather than routing to a specific tool
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m # that will produce a low-quality answer.
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m INTENT_CONFIDENCE_THRESHOLD      = Decimal("0.70")
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m # Disclosure-refresh cadence. The bot re-states "I'm a chat
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m # tool, not a person, not a therapist" at every session and
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m # at defined intra-session intervals to reinforce the
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m # relationship boundary. Skipping this is how generalist
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m # bots drift toward companion-pattern.
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m DISCLOSURE_REFRESH_TURN_INTERVAL = 20
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m # Engagement intensity defaults. The mental-health bot
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m # defaults to patient-initiated engagement to avoid
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m # surveillance flavor; bot-initiated check-ins require
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m # explicit opt-in.
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m DEFAULT_ENGAGEMENT_INTENSITY     = "patient_initiated_only"
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m # Institution regulatory positioning: "informational"
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m # indicates the deployment is positioned as informational
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m # behavioral-health support with clinician oversight in
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m # regulated edge cases; "registered_samd" indicates the
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m # deployment is registered as Software-as-a-Medical-Device
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m # with FDA SaMD post-market obligations. The disclaimer
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m # language and the audit retention scale with this.
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m INSTITUTION_REGULATORY_POSITION  = "informational"
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m ```
