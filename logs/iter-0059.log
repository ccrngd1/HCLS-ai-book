[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m INJECTION_PATTERNS = [
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m     r"ignore (all |any |the )?(previous|prior|above) "
