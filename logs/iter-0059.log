[0m[49m[38;5;10m+    2623[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2624[0m:[38;5;10m[49m def _verify_support_citations(*, response_text, citations):
[0m[49m[38;5;10m+    2625[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2626[0m:[38;5;10m[49m     Verify that therapeutic-content claims and
[0m[49m[38;5;10m+    2627[0m:[38;5;10m[49m     psychoeducation answers are grounded in cited library
[0m[49m[38;5;10m+    2628[0m:[38;5;10m[49m     content. Production runs an independent verifier model
[0m[49m[38;5;10m+    2629[0m:[38;5;10m[49m     with structured-output validation.
[0m[49m[38;5;10m+    2630[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2631[0m:[38;5;10m[49m     text_lower = response_text.lower()
[0m[49m[38;5;10m+    2632[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2633[0m:[38;5;10m[49m     # Phrases indicating therapeutic-content delivery that
[0m[49m[38;5;10m+    2634[0m:[38;5;10m[49m     # should be backed by a citation.
[0m[49m[38;5;10m+    2635[0m:[38;5;10m[49m     therapeutic_delivery_indicators = [
[0m[49m[38;5;10m+    2636[0m:[38;5;10m[49m         "exercise",
[0m[49m[38;5;10m+    2637[0m:[38;5;10m[49m         "skill",
[0m[49m[38;5;10m+    2638[0m:[38;5;10m[49m         "technique",
[0m[49m[38;5;10m+    2639[0m:[38;5;10m[49m         "practice",
[0m[49m[38;5;10m+    2640[0m:[38;5;10m[49m         "the 5-4-3-2-1",
[0m[49m[38;5;10m+    2641[0m:[38;5;10m[49m         "cognitive restructuring",
[0m[49m[38;5;10m+    2642[0m:[38;5;10m[49m         "behavioral activation",
[0m[49m[38;5;10m+    2643[0m:[38;5;10m[49m         "grounding",
[0m[49m[38;5;10m+    2644[0m:[38;5;10m[49m         "mindfulness practice",
[0m[49m[38;5;10m+    2645[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    2646[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2647[0m:[38;5;10m[49m     contains_therapeutic_delivery = any(
[0m[49m[38;5;10m+    2648[0m:[38;5;10m[49m         ind in text_lower
[0m[49m[38;5;10m+    2649[0m:[38;5;10m[49m         for ind in therapeutic_delivery_indicators)
[0m[49m[38;5;10m+    2650[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2651[0m:[38;5;10m[49m     if contains_therapeutic_delivery and not citations:
[0m[49m[38;5;10m+    2652[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    2653[0m:[38;5;10m[49m             "has_ungrounded_assertions": True,
