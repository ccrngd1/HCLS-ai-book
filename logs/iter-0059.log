[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m         "content_version": "v1.0",
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m         "modality": "behavioral_activation",
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m         "indication": ["depressed_mood", "withdrawal",
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m                        "anhedonia"],
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m         "contraindication": ["acute_crisis"],
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m         "audience": "adult",
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m         "language": "en-US",
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m         "reading_level": "grade_6",
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m         "duration_minutes": 5,
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m         "title": "One-Step Behavioral Activation",
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m         "steps": [
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m             ("What's one small thing you would normally "
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m              "do today that you haven't been able to? "
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m              "Anything counts. Showering counts."),
