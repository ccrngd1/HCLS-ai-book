[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m             "Three things you can hear.",
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m             "Two things you can smell.",
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m             ("One thing you can taste, or one slow breath "
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m              "in and out."),
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m         ],
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m         "closing": (
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m             "How are you noticing your body now compared "
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m             "to a few minutes ago?"),
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m     "cognitive_restructuring_brief": {
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m         "content_id": "cognitive_restructuring_brief",
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m         "content_version": "v1.0",
