[0m[49m[38;5;10m+    1936[0m:[38;5;10m[49m     crisis_event_id = f"crisis_{uuid.uuid4().hex}"
[0m[49m[38;5;10m+    1937[0m:[38;5;10m[49m     crisis_event = {
