[0m[49m[38;5;10m+    2002[0m:[38;5;10m[49m     # line plus warm handoff to the platform's licensed-
[0m[49m[38;5;10m+    2003[0m:[38;5;10m[49m     # clinician queue. Sub-acute: warm handoff to a
[0m[49m[38;5;10m+    2004[0m:[38;5;10m[49m     # platform clinician.
[0m[49m[38;5;10m+    2005[0m:[38;5;10m[49m     handoff_payload = _initiate_warm_handoff(
[0m[49m[38;5;10m+    2006[0m:[38;5;10m[49m         session_id=session_id,
