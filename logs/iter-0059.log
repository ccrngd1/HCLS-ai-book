[0m[49m[38;5;10m+    2718[0m:[38;5;10m[49m             if record.get("session_id") != session_id:
[0m[49m[38;5;10m+    2719[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    2720[0m:[38;5;10m[49m             if record.get("kind") != "turn":
[0m[49m[38;5;10m+    2721[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    2722[0m:[38;5;10m[49m             if record.get("speaker") != "bot":
