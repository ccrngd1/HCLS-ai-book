[0m[49m[38;5;10m+    1604[0m:[38;5;10m[49m def _screen_input(session_id, user_message):
[0m[49m[38;5;10m+    1605[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1606[0m:[38;5;10m[49m     Input safety screening. Mental-health-specific injection
