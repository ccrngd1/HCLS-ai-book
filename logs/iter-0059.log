[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m # --- Crisis-Screening Vocabulary ---
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m # Continuous crisis screening runs on every patient utterance.
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m # The categories are calibrated for the mental-health support
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m # population and use language drawn from validated screening
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m # instruments (C-SSRS, PHQ-9 item 9). In production each
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m # category is owned by behavioral-health clinical leadership,
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m # reviewed against held-out crisis-presentation cases, and
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m # layered with a tuned classifier on top of keyword detection.
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m # False-negative rate is the launch-gate metric.
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m #
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m # Note: the keyword lists below are illustrative for the
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m # demo; production crisis classifiers handle paraphrase,
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m # negation, hypotheticals ("if I were going to..."), past-
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m # tense framing ("I used to..."), and culturally and
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m # linguistically variant expressions. Keyword detection
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m # alone is not sufficient.
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m CRISIS_VOCABULARY = {
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m     "active_suicidal_ideation_with_intent": {
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m         "keywords": [
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m             "going to kill myself",
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m             "going to end my life",
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m             "tonight is the night",
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m             "have a plan to",
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m             "have the pills ready",
