[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m             "ready to die",
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m         ],
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m         "urgency": "imminent_emergency",
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m         "dimensions": ["active_ideation", "intent", "plan",
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m                        "means", "imminent"],
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m     },
