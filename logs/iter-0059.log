[0m[49m[38;5;10m+    1958[0m:[38;5;10m[49m     _emit_event("crisis_screen_triggered", {
[0m[49m[38;5;10m+    1959[0m:[38;5;10m[49m         "crisis_event_id": crisis_event_id,
