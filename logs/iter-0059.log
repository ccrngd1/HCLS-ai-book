[0m[49m[38;5;10m+    1659[0m:[38;5;10m[49m                         CRISIS_CLASSIFIER_VERSION,
[0m[49m[38;5;10m+    1660[0m:[38;5;10m[49m                 }
[0m[49m[38;5;10m+    1661[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1662[0m:[38;5;10m[49m     return {"crisis_detected": False}
[0m[49m[38;5;10m+    1663[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1664[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1665[0m:[38;5;10m[49m def _sensitive_disclosure_screen(user_message):
[0m[49m[38;5;10m+    1666[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1667[0m:[38;5;10m[49m     Detect sensitive disclosures that route to specific
[0m[49m[38;5;10m+    1668[0m:[38;5;10m[49m     institutional pathways. Mandatory-reporting categories
[0m[49m[38;5;10m+    1669[0m:[38;5;10m[49m     route to a licensed mandatory reporter; other
[0m[49m[38;5;10m+    1670[0m:[38;5;10m[49m     categories route to care-navigation or care-team-
[0m[49m[38;5;10m+    1671[0m:[38;5;10m[49m     followup.
[0m[49m[38;5;10m+    1672[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1673[0m:[38;5;10m[49m     msg_lower = user_message.lower()
[0m[49m[38;5;10m+    1674[0m:[38;5;10m[49m     for category, config in SENSITIVE_DISCLOSURE_PATTERNS\
