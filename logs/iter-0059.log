[0m[49m[38;5;10m+    2613[0m:[38;5;10m[49m         r"afraid|hurt|loved|connected)")
[0m[49m[38;5;10m+    2614[0m:[38;5;10m[49m     if first_person_emotion.search(text_lower):
[0m[49m[38;5;10m+    2615[0m:[38;5;10m[49m         return {
