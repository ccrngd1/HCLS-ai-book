[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m         "keywords": [
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m             "thinking about how i would",
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m             "been planning",
