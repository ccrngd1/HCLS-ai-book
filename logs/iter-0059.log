[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m # Structured logging. In production, ship JSON-formatted records
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m # to CloudWatch Logs Insights for cross-call investigation.
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m # Mental-health conversation logs are dense PHI of an unusually
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m # sensitive variety: psychiatric diagnoses, medication
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m # adherence, suicidality, substance use, trauma history, and
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m # disclosures with mandatory-reporting implications. Log
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m # structural metadata only (session_id, patient_id_hash,
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m # intent, tool name, tool latency, tool outcome,
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m # crisis_screen_disposition), never raw user utterances, never
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m # raw generated responses, never tool arguments that contain
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m # identifiers, never specific clinical-rule input values.
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m # Full transcripts and full tool calls live in the audit
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m # pipeline (Firehose plus Object-Lock S3) with state-specific
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m # mental-health-record retention and access controls; the
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m # sensitive-disclosure surface lives on a separately-managed
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m # KMS key.
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m # Adaptive retry handles throttling from Bedrock, DynamoDB,
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m # EventBridge, Firehose, CloudWatch, S3, Pinpoint, Connect,
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m # Step Functions, and Secrets Manager. The mental-health
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m # bot's response window is tighter than the chronic-disease
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m # coach: a patient who typed a crisis disclosure expects an
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m # anchor response within a couple of seconds, not minutes.
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(
