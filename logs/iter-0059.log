[0m[49m[38;5;10m+    2701[0m:[38;5;10m[49m     for call in tool_calls:
[0m[49m[38;5;10m+    2702[0m:[38;5;10m[49m         if call.get("tool") in forbidden_tools:
[0m[49m[38;5;10m+    2703[0m:[38;5;10m[49m             return {
[0m[49m[38;5;10m+    2704[0m:[38;5;10m[49m                 "compliant": False,
[0m[49m[38;5;10m+    2705[0m:[38;5;10m[49m                 "reason": "forbidden_tool_during_crisis",
[0m[49m[38;5;10m+    2706[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    2707[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2708[0m:[38;5;10m[49m     return {"compliant": True}
[0m[49m[38;5;10m+    2709[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2710[0m:[38;5;10m[49m 
