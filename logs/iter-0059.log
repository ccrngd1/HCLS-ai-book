[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m # --- Stanley-Brown Style Safety Plan Template ---
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m # When a patient has a safety plan on file (typically
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m # created with their therapist using the Stanley-Brown
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m # Safety Planning Intervention or a similar evidence-based
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m # template), the bot can surface specific steps when the
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m # conversation context suggests they are relevant. The bot
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m # does not modify the safety plan; modifications are done
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m # with the patient's clinician.
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m SAFETY_PLAN_STEP_LABELS = [
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m     "warning_signs",
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m     "internal_coping_strategies",
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m     "social_distractions",
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m     "people_to_ask_for_help",
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m     "professional_contacts",
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m     "make_environment_safer",
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m # --- Standard Response Templates ---
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m GREETING_WITH_DISCLOSURE = (
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m     f"Hi, I'm {INSTITUTION_DISPLAY_NAME}'s support chat "
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m     "tool. Just a reminder before we get started: I'm a "
