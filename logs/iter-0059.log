[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m pinpoint_client       = boto3.client("pinpoint",
