[0m[49m[38;5;10m+    1648[0m:[38;5;10m[49m     for category in detection_order:
[0m[49m[38;5;10m+    1649[0m:[38;5;10m[49m         config = CRISIS_VOCABULARY[category]
[0m[49m[38;5;10m+    1650[0m:[38;5;10m[49m         for keyword in config["keywords"]:
[0m[49m[38;5;10m+    1651[0m:[38;5;10m[49m             if keyword in msg_lower:
[0m[49m[38;5;10m+    1652[0m:[38;5;10m[49m                 return {
[0m[49m[38;5;10m+    1653[0m:[38;5;10m[49m                     "crisis_detected": True,
[0m[49m[38;5;10m+    1654[0m:[38;5;10m[49m                     "category":        category,
[0m[49m[38;5;10m+    1655[0m:[38;5;10m[49m                     "urgency":         config["urgency"],
[0m[49m[38;5;10m+    1656[0m:[38;5;10m[49m                     "dimensions":      config["dimensions"],
[0m[49m[38;5;10m+    1657[0m:[38;5;10m[49m                     "matched_excerpt": keyword,
