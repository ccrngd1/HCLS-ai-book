[0m[49m[38;5;10m+    1622[0m:[38;5;10m[49m def _crisis_screen(*, user_message, recent_turns):
[0m[49m[38;5;10m+    1623[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1624[0m:[38;5;10m[49m     Continuous crisis screening. Runs on every utterance.
[0m[49m[38;5;10m+    1625[0m:[38;5;10m[49m     Demo uses keyword-and-rule-based detection across the
[0m[49m[38;5;10m+    1626[0m:[38;5;10m[49m     categories in CRISIS_VOCABULARY; production layers a
[0m[49m[38;5;10m+    1627[0m:[38;5;10m[49m     tuned classifier on top with held-out validation,
[0m[49m[38;5;10m+    1628[0m:[38;5;10m[49m     handles paraphrase, negation, hypotheticals, past-tense
[0m[49m[38;5;10m+    1629[0m:[38;5;10m[49m     framing, and culturally and linguistically variant
[0m[49m[38;5;10m+    1630[0m:[38;5;10m[49m     expressions.
[0m[49m[38;5;10m+    1631[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1632[0m:[38;5;10m[49m     msg_lower = user_message.lower()
[0m[49m[38;5;10m+    1633[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1634[0m:[38;5;10m[49m     # Order matters: imminent_emergency before acute_crisis
[0m[49m[38;5;10m+    1635[0m:[38;5;10m[49m     # before sub_acute. The most-urgent matched category
[0m[49m[38;5;10m+    1636[0m:[38;5;10m[49m     # wins.
[0m[49m[38;5;10m+    1637[0m:[38;5;10m[49m     detection_order = [
[0m[49m[38;5;10m+    1638[0m:[38;5;10m[49m         "active_suicidal_ideation_with_intent",
[0m[49m[38;5;10m+    1639[0m:[38;5;10m[49m         "active_suicidal_ideation_with_plan",
[0m[49m[38;5;10m+    1640[0m:[38;5;10m[49m         "homicidal_ideation",
[0m[49m[38;5;10m+    1641[0m:[38;5;10m[49m         "overdose_risk",
[0m[49m[38;5;10m+    1642[0m:[38;5;10m[49m         "active_suicidal_ideation",
[0m[49m[38;5;10m+    1643[0m:[38;5;10m[49m         "self_harm_active",
[0m[49m[38;5;10m+    1644[0m:[38;5;10m[49m         "acute_psychotic",
