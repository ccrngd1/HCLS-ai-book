[0m[49m[38;5;10m+    2590[0m:[38;5;10m[49m def _detect_companion_pattern(*, response_text,
[0m[49m[38;5;10m+    2591[0m:[38;5;10m[49m                                   recent_responses):
[0m[49m[38;5;10m+    2592[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2593[0m:[38;5;10m[49m     Detect companion-pattern drift in the response. The
[0m[49m[38;5;10m+    2594[0m:[38;5;10m[49m     forbidden phrases are in COMPANION_PATTERN_PHRASES.
[0m[49m[38;5;10m+    2595[0m:[38;5;10m[49m     Production runs a classifier reviewed by behavioral-
[0m[49m[38;5;10m+    2596[0m:[38;5;10m[49m     health clinicians; the demo runs phrase matching.
[0m[49m[38;5;10m+    2597[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2598[0m:[38;5;10m[49m     text_lower = response_text.lower()
[0m[49m[38;5;10m+    2599[0m:[38;5;10m[49m     for phrase in COMPANION_PATTERN_PHRASES:
[0m[49m[38;5;10m+    2600[0m:[38;5;10m[49m         if phrase in text_lower:
[0m[49m[38;5;10m+    2601[0m:[38;5;10m[49m             return {
[0m[49m[38;5;10m+    2602[0m:[38;5;10m[49m                 "violation_detected": True,
[0m[49m[38;5;10m+    2603[0m:[38;5;10m[49m                 "matched_pattern":    phrase,
[0m[49m[38;5;10m+    2604[0m:[38;5;10m[49m                 "category":           "companion_pattern_drift",
[0m[49m[38;5;10m+    2605[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    2606[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2607[0m:[38;5;10m[49m     # Structural heuristic: first-person emotional claims
[0m[49m[38;5;10m+    2608[0m:[38;5;10m[49m     # ("I feel ...") in a clinical-support context drift
[0m[49m[38;5;10m+    2609[0m:[38;5;10m[49m     # toward companion pattern.
