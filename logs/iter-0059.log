[0m[49m[38;5;10m+    3202[0m:[38;5;10m[49m ## Demo Runner
[0m[49m[38;5;10m+    3203[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3204[0m:[38;5;10m[49m A small end-to-end demo that exercises enrollment with consent, a within-scope conversation that delivers therapeutic content, an out-of-scope conversation that gets safe-template-replaced, and a crisis-pathway conversation that triggers the warm handoff. Run this to see the structures populated, the events emitted, and the disposition flags on each turn.
[0m[49m[38;5;10m+    3205[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3206[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    3207[0m:[38;5;10m[49m def run_demo():
[0m[49m[38;5;10m+    3208[0m:[38;5;10m[49m     """End-to-end demo against the mock infrastructure."""
[0m[49m[38;5;10m+    3209[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    3210[0m:[38;5;10m[49m     print("MENTAL HEALTH SUPPORT BOT DEMO")
[0m[49m[38;5;10m+    3211[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    3212[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    3213[0m:[38;5;10m[49m     # Set up a synthetic patient.
[0m[49m[38;5;10m+    3214[0m:[38;5;10m[49m     patient_id = "patient-sam"
[0m[49m[38;5;10m+    3215[0m:[38;5;10m[49m     mock_ehr.add_patient(patient_id, {
[0m[49m[38;5;10m+    3216[0m:[38;5;10m[49m         "age":                                28,
[0m[49m[38;5;10m+    3217[0m:[38;5;10m[49m         "active_mental_health_diagnoses":
[0m[49m[38;5;10m+    3218[0m:[38;5;10m[49m             ["major_depressive_disorder",
[0m[49m[38;5;10m+    3219[0m:[38;5;10m[49m              "generalized_anxiety_disorder"],
