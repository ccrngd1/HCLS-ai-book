[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m         "contraindication": ["active_crisis",
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m                              "psychotic_symptoms"],
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m         "audience": "adult",
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m         "language": "en-US",
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m         "reading_level": "grade_8",
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m         "duration_minutes": 10,
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m         "title": "Brief Cognitive Restructuring",
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m         "steps": [
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m             ("First, can you name the specific thought "
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m              "that's looping? In one sentence."),
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m             ("What's the evidence that this thought is "
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m              "true? Just the strongest piece."),
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m             ("What's the evidence against it, or that the "
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m              "outcome might not be as bad as it feels?"),
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m             ("What's a more balanced way of saying the "
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m              "same thing?"),
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m         ],
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m     "behavioral_activation_one_step": {
