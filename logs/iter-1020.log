[0m[49m[38;5;10m+      2[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      3[0m:[38;5;10m[49m > **Heads up:** This is a deliberately simple, illustrative implementation of the pseudocode walkthrough from Recipe 14.1. It shows one way you could translate appointment slot optimization concepts into working Python code using PuLP (an open-source linear programming library) and SimPy (a discrete-event simulation library). It is not production-ready. Think of it as the sketchpad version: useful for understanding the shape of the solution, not something you'd deploy to your scheduling system on Monday morning. Consider it a starting point, not a destination.
[0m[49m[38;5;10m+      4[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      5[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+      6[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      7[0m:[38;5;10m[49m ## Setup
[0m[49m[38;5;10m+      8[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      9[0m:[38;5;10m[49m You'll need a few Python packages:
[0m[49m[38;5;10m+     10[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     11[0m:[38;5;10m[49m ```bash
[0m[49m[38;5;10m+     12[0m:[38;5;10m[49m pip install pulp simpy numpy boto3
[0m[49m[38;5;10m+     13[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     14[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     15[0m:[38;5;10m[49m PuLP is a modeling library for linear and mixed-integer programming. It ships with the CBC solver (open-source, no license required), which is more than sufficient for a problem this size. SimPy handles the discrete-event simulation for validation. NumPy provides the statistical distributions.
[0m[49m[38;5;10m+     16[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     17[0m:[38;5;10m[49m Your environment needs AWS credentials configured (via environment variables, an instance profile, or `~/.aws/credentials`). The IAM role or user needs `s3:GetObject`, `s3:PutObject`, and `dynamodb:PutItem`.
[0m[49m[38;5;10m+     18[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     19[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     20[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     21[0m:[38;5;10m[49m ## Config and Constants
[0m[49m[38;5;10m+     22[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     23[0m:[38;5;10m[49m Before we get to the optimization logic, here's the configuration that defines the problem. These constants represent a typical family medicine clinic session. In production, you'd pull these from your EHR data warehouse rather than hardcoding them.
[0m[49m[38;5;10m+     24[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     25[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     26[0m:[38;5;10m[49m import numpy as np
[0m[49m[38;5;10m+     27[0m:[38;5;10m[49m from dataclasses import dataclass
[0m[49m[38;5;10m+     28[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     29[0m:[38;5;10m[49m # Visit type definitions: clinical minimums, maximums, and revenue weights.
[0m[49m[38;5;10m+     30[0m:[38;5;10m[49m # These come from your medical director and billing team.
[0m[49m[38;5;10m+     31[0m:[38;5;10m[49m # Duration bounds are in minutes. Revenue weight is relative (used in the objective).
[0m[49m[38;5;10m+     32[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     33[0m:[38;5;10m[49m VISIT_TYPES = {
[0m[49m[38;5;10m+     34[0m:[38;5;10m[49m     "new_patient": {
[0m[49m[38;5;10m+     35[0m:[38;5;10m[49m         "min_duration": 30,    # clinical minimum: can't do a proper new patient in less
[0m[49m[38;5;10m+     36[0m:[38;5;10m[49m         "max_duration": 60,    # don't allocate more than an hour
[0m[49m[38;5;10m+     37[0m:[38;5;10m[49m         "revenue_weight": 3.0, # highest revenue per visit
[0m[49m[38;5;10m+     38[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+     39[0m:[38;5;10m[49m     "follow_up_complex": {
[0m[49m[38;5;10m+     40[0m:[38;5;10m[49m         "min_duration": 20,
[0m[49m[38;5;10m+     41[0m:[38;5;10m[49m         "max_duration": 40,
[0m[49m[38;5;10m+     42[0m:[38;5;10m[49m         "revenue_weight": 2.0,
[0m[49m[38;5;10m+     43[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+     44[0m:[38;5;10m[49m     "follow_up_simple": {
[0m[49m[38;5;10m+     45[0m:[38;5;10m[49m         "min_duration": 10,
[0m[49m[38;5;10m+     46[0m:[38;5;10m[49m         "max_duration": 25,
[0m[49m[38;5;10m+     47[0m:[38;5;10m[49m         "revenue_weight": 1.0,
[0m[49m[38;5;10m+     48[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+     49[0m:[38;5;10m[49m     "procedure": {
[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m         "min_duration": 20,
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m         "max_duration": 45,
[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m         "revenue_weight": 2.5,
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m     "bp_recheck": {
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m         "min_duration": 5,
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m         "max_duration": 15,
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m         "revenue_weight": 0.5,
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m     "telehealth": {
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m         "min_duration": 10,
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m         "max_duration": 25,
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m         "revenue_weight": 1.2,
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m # Session constraints: when does the provider work?
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m SESSION_START_HOUR = 8    # 8:00 AM
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m SESSION_END_HOUR = 17     # 5:00 PM
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m LUNCH_START_HOUR = 12     # noon
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m LUNCH_DURATION_MIN = 60   # one hour lunch break
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m SESSION_MINUTES = (SESSION_END_HOUR - SESSION_START_HOUR) * 60 - LUNCH_DURATION_MIN  # 480 total
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m # Overbooking constraints
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m MAX_OVERBOOK_PER_HOUR = 2  # never more than 2 extra patients in any hour block
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m # Wait time constraint
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m MAX_ACCEPTABLE_WAIT_MIN = 20  # patients should not wait more than 20 minutes on average
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m # Tradeoff parameter: how much do we penalize wait time relative to throughput?
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m # Higher lambda = more wait-averse. Start at 0.5 and tune based on organizational priorities.
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m WAIT_PENALTY_LAMBDA = 0.5
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m # Expected visit type mix for this provider (fraction of total visits).
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m # This comes from historical scheduling data. Must sum to 1.0.
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m VISIT_TYPE_MIX = {
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m     "new_patient": 0.10,
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m     "follow_up_complex": 0.30,
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m     "follow_up_simple": 0.25,
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m     "procedure": 0.10,
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m     "bp_recheck": 0.15,
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m     "telehealth": 0.10,
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m ## Historical Data: Duration and No-Show Statistics
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m In production, you'd compute these from your EHR data warehouse. Here we define them directly to keep the example self-contained. These numbers represent what you'd get from 6+ months of historical visit data for a single provider.
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m # Historical visit duration statistics (mean and standard deviation in minutes).
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m # Computed from actual check-in to checkout times, NOT scheduled durations.
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m # The standard deviation matters enormously: high-variance visit types create
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m # cascading delays that ripple through the entire session.
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m DURATION_STATS = {
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m     "new_patient":        {"mean": 42.0, "std": 12.0},
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m     "follow_up_complex":  {"mean": 27.0, "std": 8.0},
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m     "follow_up_simple":   {"mean": 16.0, "std": 5.0},
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m     "procedure":          {"mean": 32.0, "std": 10.0},
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m     "bp_recheck":         {"mean": 9.0,  "std": 3.0},
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m     "telehealth":         {"mean": 14.0, "std": 4.0},
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m # No-show rates by hour block. Computed from historical data.
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m # Morning slots tend to have lower no-show rates; late afternoon is worst.
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m # These drive the overbooking optimization: if 9am has 20% no-shows,
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m # overbooking by 1 patient at 9am just gets you back to expected panel size.
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m NOSHOW_RATES = {
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m     8:  0.08,   # early birds show up
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m     9:  0.12,
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m     10: 0.15,
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m     11: 0.14,
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m     13: 0.18,   # post-lunch is rough
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m     14: 0.20,
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m     15: 0.22,
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m     16: 0.25,   # late afternoon: highest no-show rate
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m ## Step 1: Formulate and Solve the Optimization Model
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m *The pseudocode calls this `optimize_template(features, constraints)`. We use PuLP to formulate a mixed-integer program that finds optimal slot durations and overbooking levels.*
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m import pulp
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m def optimize_template() -> dict:
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m     Formulate and solve the appointment slot optimization problem.
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m     Decision variables:
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m     - d[t]: slot duration for each visit type t (continuous, in minutes)
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m     - o[h]: overbooking count for each hour block h (integer)
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m     - b: buffer time between slots (continuous, in minutes)
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m     Objective: maximize expected throughput (weighted by revenue) minus
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m     a penalty for expected wait time.
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m     Returns a dictionary with optimal slot durations, buffer, and overbooking levels.
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m     # Create the optimization model.
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m     # "Maximize" because our objective is throughput minus wait penalty.
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m     model = pulp.LpProblem("AppointmentSlotOptimization", pulp.LpMaximize)
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m     # --- Decision Variables ---
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m     # Slot duration for each visit type (continuous variable, bounded by clinical limits)
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m     d = {}
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m     for vtype, config in VISIT_TYPES.items():
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m         d[vtype] = pulp.LpVariable(
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m             f"duration_{vtype}",
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m             lowBound=config["min_duration"],
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m             upBound=config["max_duration"],
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m             cat="Continuous",
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m     # Buffer time between slots (continuous, 0 to 15 minutes)
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m     b = pulp.LpVariable("buffer", lowBound=0, upBound=15, cat="Continuous")
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m     # Overbooking count per hour block (integer, 0 to max)
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m     o = {}
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m     for hour in NOSHOW_RATES.keys():
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m         o[hour] = pulp.LpVariable(
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m             f"overbook_{hour}",
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m             lowBound=0,
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m             upBound=MAX_OVERBOOK_PER_HOUR,
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m             cat="Integer",
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m     # --- Compute expected slots per session ---
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m     # The weighted average slot duration (including buffer) determines how many
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m     # patients fit in a session.
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m     weighted_avg_duration = pulp.lpSum(
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m         VISIT_TYPE_MIX[vtype] * (d[vtype] + b) for vtype in VISIT_TYPES
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m     # Total overbooked patients across all hour blocks
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m     total_overbook = pulp.lpSum(o[hour] for hour in NOSHOW_RATES)
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m     # Base slots: session minutes divided by average slot duration.
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m     # PuLP can't do division directly in the objective, so we linearize:
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m     # Instead of maximizing SESSION_MINUTES / weighted_avg_duration,
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m     # we minimize weighted_avg_duration (which maximizes slots per session).
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m     # We also add the overbooking benefit weighted by show probability.
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m     # --- Objective Function ---
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m     # We want to:
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m     # 1. Minimize average slot duration (more patients fit)
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m     # 2. Benefit from overbooking (weighted by probability patients actually show)
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m     # 3. Penalize for expected wait time (approximated by duration variance)
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m     # Throughput component: shorter slots = more patients.
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m     # We negate weighted_avg_duration because we're maximizing.
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m     throughput_term = -weighted_avg_duration
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m     # Overbooking benefit: each overbooked slot has value proportional to
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m     # the probability the patient shows up (1 - noshow_rate for that hour).
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     overbook_benefit = pulp.lpSum(
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m         o[hour] * (1 - NOSHOW_RATES[hour]) * 1.0  # revenue weight of 1.0 for overbooks
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m         for hour in NOSHOW_RATES
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m     # Wait time penalty: approximated by the variance contribution of each visit type.
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m     # Higher variance = more downstream waiting. This is a linearized approximation
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m     # of the Pollaczek-Khinchine formula. In production, you'd validate with simulation.
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m     wait_penalty = pulp.lpSum(
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m         VISIT_TYPE_MIX[vtype] * DURATION_STATS[vtype]["std"]
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m         for vtype in VISIT_TYPES
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m     # Combined objective
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m     model += throughput_term + overbook_benefit - WAIT_PENALTY_LAMBDA * wait_penalty
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m     # --- Constraints ---
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m     # The weighted average slot duration must allow at least some minimum number
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m     # of patients per session. We require at least 12 patients fit in a session.
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m     # SESSION_MINUTES / weighted_avg_duration >= 12
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m     # Linearized: weighted_avg_duration <= SESSION_MINUTES / 12
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m     model += weighted_avg_duration <= SESSION_MINUTES / 12, "min_patients_constraint"
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m     # Maximum session utilization: don't pack so tight that there's zero slack.
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m     # Require at least 30 minutes of slack in the session for unexpected overruns.
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m     # This means: 12 * weighted_avg_duration <= SESSION_MINUTES - 30
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m     # (assuming ~12 base patients)
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m     model += 12 * weighted_avg_duration <= SESSION_MINUTES - 30, "slack_constraint"
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m     # --- Solve ---
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m     # CBC is the default solver bundled with PuLP. No external license needed.
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m     # For a problem this small (< 50 variables), it solves in milliseconds.
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     solver = pulp.PULP_CBC_CMD(msg=0)  # msg=0 suppresses solver output
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m     model.solve(solver)
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m     # --- Extract Results ---
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m     if model.status != pulp.constants.LpStatusOptimal:
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m         raise RuntimeError(
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m             f"Solver did not find optimal solution. Status: {pulp.LpStatus[model.status]}"
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m     result = {
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m         "slot_durations": {
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m             vtype: round(pulp.value(d[vtype]), 1) for vtype in VISIT_TYPES
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m         "buffer_minutes": round(pulp.value(b), 1),
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m         "overbooking": {
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m             str(hour): int(pulp.value(o[hour])) for hour in NOSHOW_RATES
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m         "objective_value": round(pulp.value(model.objective), 3),
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m         "solver_status": pulp.LpStatus[model.status],
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m     return result
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m ## Step 2: Simulate a Clinic Day
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m *The pseudocode calls this `simulate_clinic_day(template, features, num_replications)`. We use SimPy to run a discrete-event simulation that tests the proposed template against realistic patient behavior.*
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m import simpy
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m def build_schedule_from_template(template: dict) -> list:
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m     Generate a day's schedule from the optimized template.
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m     Creates a sequence of appointment slots based on the visit type mix
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m     and optimized durations. Returns a list of slot dictionaries with
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m     scheduled times and visit types.
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m     slots = []
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m     current_time = SESSION_START_HOUR * 60  # convert to minutes from midnight
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m     session_end = SESSION_END_HOUR * 60
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m     lunch_start = LUNCH_START_HOUR * 60
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m     lunch_end = lunch_start + LUNCH_DURATION_MIN
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m     # Build the schedule by filling time with slots according to the visit type mix.
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m     # In production, you'd use the actual appointment requests. Here we simulate
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m     # a representative day using the expected mix.
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m     visit_types_list = list(VISIT_TYPE_MIX.keys())
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m     mix_weights = [VISIT_TYPE_MIX[vt] for vt in visit_types_list]
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m     slot_id = 0
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m     while current_time < session_end:
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m         # Skip lunch
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m         if lunch_start <= current_time < lunch_end:
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m             current_time = lunch_end
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m         # Pick a visit type based on the expected mix
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m         vtype = np.random.choice(visit_types_list, p=mix_weights)
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m         duration = template["slot_durations"][vtype]
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m         buffer = template["buffer_minutes"]
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m         # Check if this slot fits before session end (or lunch)
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m         slot_end = current_time + duration + buffer
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m         if current_time < lunch_start and slot_end > lunch_start:
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m             current_time = lunch_end
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m         if slot_end > session_end:
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m             break
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m         slots.append({
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m             "id": slot_id,
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m             "scheduled_time": current_time,
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m             "visit_type": vtype,
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m             "scheduled_duration": duration,
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m         current_time += duration + buffer
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m         slot_id += 1
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m     # Add overbooked patients to appropriate hour blocks
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m     for hour_str, overbook_count in template["overbooking"].items():
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m         hour = int(hour_str)
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m         hour_start = hour * 60
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m         for i in range(overbook_count):
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m             vtype = np.random.choice(visit_types_list, p=mix_weights)
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m             slots.append({
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m                 "id": slot_id,
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m                 "scheduled_time": hour_start + 15 * i,  # stagger within the hour
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m                 "visit_type": vtype,
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m                 "scheduled_duration": template["slot_durations"][vtype],
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m                 "is_overbook": True,
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m             slot_id += 1
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m     # Sort by scheduled time
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m     slots.sort(key=lambda s: s["scheduled_time"])
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m     return slots
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m def simulate_single_day(template: dict, rng: np.random.Generator) -> dict:
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m     Simulate one clinic day using the proposed template.
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m     Models patient arrivals, no-shows, variable visit durations, and
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m     tracks wait times, throughput, and overtime.
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m         template: The optimized template (slot durations, buffer, overbooking)
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m         rng: NumPy random generator for reproducibility
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m         Dictionary with day-level metrics: patients_seen, avg_wait, max_wait,
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m         overtime_minutes, idle_minutes.
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m     schedule = build_schedule_from_template(template)
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m     # Track metrics
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m     wait_times = []
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m     provider_free_at = SESSION_START_HOUR * 60  # provider starts available at session start
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m     patients_seen = 0
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m     for slot in schedule:
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m         hour = slot["scheduled_time"] // 60
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m         # Clamp hour to valid range for noshow lookup
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m         noshow_hour = max(8, min(16, hour))
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m         # Determine if patient shows up
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m         if rng.random() < NOSHOW_RATES.get(noshow_hour, 0.15):
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m             continue  # no-show: skip this patient entirely
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m         # Patient showed up. Draw actual visit duration from historical distribution.
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m         vtype = slot["visit_type"]
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m         actual_duration = max(
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m             VISIT_TYPES[vtype]["min_duration"],  # floor at clinical minimum
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m             rng.normal(
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m                 DURATION_STATS[vtype]["mean"],
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m                 DURATION_STATS[vtype]["std"],
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m             ),
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m         # Patient wait = how long after their scheduled time until provider is free
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m         patient_wait = max(0, provider_free_at - slot["scheduled_time"])
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m         wait_times.append(patient_wait)
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m         # Provider starts seeing this patient at the later of:
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m         # their scheduled time or when the provider becomes free
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m         visit_start = max(slot["scheduled_time"], provider_free_at)
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m         provider_free_at = visit_start + actual_duration
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m         patients_seen += 1
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m     session_end = SESSION_END_HOUR * 60
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m     overtime = max(0, provider_free_at - session_end)
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m     # Idle time: gaps where provider was free but no patient was scheduled
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m     # (simplified: total session time minus time spent with patients minus wait-caused delays)
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m     total_clinical_time = provider_free_at - SESSION_START_HOUR * 60 - LUNCH_DURATION_MIN
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m     idle_time = max(0, SESSION_MINUTES - total_clinical_time) if overtime == 0 else 0
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m         "patients_seen": patients_seen,
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m         "avg_wait": np.mean(wait_times) if wait_times else 0.0,
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m         "max_wait": np.max(wait_times) if wait_times else 0.0,
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m         "overtime_minutes": overtime,
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m         "idle_minutes": idle_time,
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m def run_simulation(template: dict, num_replications: int = 1000, seed: int = 42) -> dict:
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m     Run multiple simulation replications and aggregate results.
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m     This is the validation step: we test the proposed template against
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m     realistic stochastic patient behavior to see how it actually performs
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m     across many possible days.
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m         template: The optimized template to test
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m         num_replications: How many random days to simulate (1000 is a good default)
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m         seed: Random seed for reproducibility
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m         Aggregated statistics across all replications.
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m     rng = np.random.default_rng(seed)
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m     results = []
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m     for _ in range(num_replications):
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m         day_result = simulate_single_day(template, rng)
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m         results.append(day_result)
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m     # Aggregate across replications
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m     patients_seen = [r["patients_seen"] for r in results]
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m     avg_waits = [r["avg_wait"] for r in results]
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m     max_waits = [r["max_wait"] for r in results]
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m     overtimes = [r["overtime_minutes"] for r in results]
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m     idles = [r["idle_minutes"] for r in results]
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m         "mean_throughput": round(np.mean(patients_seen), 1),
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m         "std_throughput": round(np.std(patients_seen), 1),
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m         "mean_avg_wait": round(np.mean(avg_waits), 1),
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m         "p95_avg_wait": round(np.percentile(avg_waits, 95), 1),
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m         "mean_max_wait": round(np.mean(max_waits), 1),
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m         "overtime_probability": round(np.mean([o > 0 for o in overtimes]), 3),
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m         "mean_overtime_minutes": round(np.mean(overtimes), 1),
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m         "mean_idle_minutes": round(np.mean(idles), 1),
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m         "num_replications": num_replications,
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m ## Step 3: Compare Against Current Template
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m *This step runs the simulation for both the current (baseline) template and the proposed (optimized) template, then computes the improvement.*
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m def create_baseline_template() -> dict:
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m     Represent the current "one-size-fits-all" template that most clinics use.
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m     This is the thing we're trying to beat: uniform 30-minute slots,
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m     no overbooking, no buffer optimization. The scheduling equivalent of
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m     "we've always done it this way."
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m         "slot_durations": {
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m             "new_patient": 30,
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m             "follow_up_complex": 30,
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m             "follow_up_simple": 30,
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m             "procedure": 30,
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m             "bp_recheck": 30,
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m             "telehealth": 30,
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m         "buffer_minutes": 0,
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m         "overbooking": {str(h): 0 for h in NOSHOW_RATES.keys()},
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m def compare_templates(baseline: dict, proposed: dict) -> dict:
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m     Run simulation on both templates and compute the improvement.
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m     Returns a comparison dictionary showing before/after metrics
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m     and the delta for each.
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m     print("Simulating baseline template (1000 replications)...")
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m     baseline_results = run_simulation(baseline, num_replications=1000, seed=42)
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m     print("Simulating proposed template (1000 replications)...")
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m     proposed_results = run_simulation(proposed, num_replications=1000, seed=42)
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m     comparison = {
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m         "baseline": baseline_results,
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m         "proposed": proposed_results,
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m         "improvement": {
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m             "throughput_delta": round(
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m                 proposed_results["mean_throughput"] - baseline_results["mean_throughput"], 1
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m             ),
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m             "wait_delta": round(
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m                 proposed_results["mean_avg_wait"] - baseline_results["mean_avg_wait"], 1
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m             ),
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m             "overtime_delta": round(
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m                 proposed_results["overtime_probability"] - baseline_results["overtime_probability"], 3
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m             ),
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m     return comparison
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m ## Step 4: Store Results to DynamoDB
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m *The pseudocode calls this `store_and_notify(...)`. We write the proposed template and simulation comparison to DynamoDB for the review workflow.*
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m import datetime
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m from datetime import timezone
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m TABLE_NAME = "template-store"
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m def convert_floats_to_decimal(obj):
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m     Recursively convert floats to Decimal for DynamoDB compatibility.
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m     DynamoDB does not accept Python floats. You must wrap numeric values
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m     in Decimal or put_item will raise a TypeError. This helper handles
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m     nested structures so you don't have to think about it at every call site.
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m     if isinstance(obj, float):
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m         return Decimal(str(round(obj, 4)))
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m     elif isinstance(obj, dict):
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m         return {k: convert_floats_to_decimal(v) for k, v in obj.items()}
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m     elif isinstance(obj, list):
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m         return [convert_floats_to_decimal(item) for item in obj]
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m     return obj
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m def store_proposed_template(
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m     provider_id: str,
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m     template: dict,
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m     comparison: dict,
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m     Write the proposed template and simulation results to DynamoDB.
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m     The record includes the full template configuration, simulation results
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m     for both baseline and proposed, and the computed improvement metrics.
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m     Status starts as "proposed" and moves to "approved" or "rejected"
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m     after human review.
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m         provider_id: Identifier for the provider (e.g., "DR-MARTINEZ-FM")
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m         template: The optimized template (slot durations, buffer, overbooking)
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m         comparison: Simulation comparison results (baseline vs. proposed)
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m         The record that was written to DynamoDB.
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m     table = dynamodb.Table(TABLE_NAME)
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m     record = {
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m         "provider_id": provider_id,
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m         "created_at": datetime.datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m         "status": "proposed",
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m         "template": template,
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m         "simulation_baseline": comparison["baseline"],
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m         "simulation_proposed": comparison["proposed"],
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m         "improvement": comparison["improvement"],
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m     # Convert all floats to Decimal before writing
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m     dynamo_record = convert_floats_to_decimal(record)
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m     table.put_item(Item=dynamo_record)
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m     return record
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m ```
