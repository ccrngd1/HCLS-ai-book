[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m     print("Step 1: Solving optimization model...")
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m     proposed_template = optimize_template()
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m     print(f"  Solver status: {proposed_template['solver_status']}")
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m     print(f"  Optimal slot durations: {proposed_template['slot_durations']}")
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m     print(f"  Buffer: {proposed_template['buffer_minutes']} min")
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m     print(f"  Overbooking: {proposed_template['overbooking']}")
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m     # Step 2: Create baseline for comparison
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m     print("\nStep 2: Building baseline template for comparison...")
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m     baseline = create_baseline_template()
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m     # Step 3: Run simulation comparison
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m     print("\nStep 3: Running simulation comparison...")
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m     comparison = compare_templates(baseline, proposed_template)
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m     print(f"\n--- Results ---")
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m     print(f"  Baseline throughput:  {comparison['baseline']['mean_throughput']} patients/day")
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m     print(f"  Proposed throughput:  {comparison['proposed']['mean_throughput']} patients/day")
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m     print(f"  Throughput delta:     {comparison['improvement']['throughput_delta']:+.1f}")
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m     print(f"  Baseline avg wait:   {comparison['baseline']['mean_avg_wait']} min")
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m     print(f"  Proposed avg wait:   {comparison['proposed']['mean_avg_wait']} min")
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m     print(f"  Wait delta:          {comparison['improvement']['wait_delta']:+.1f} min")
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m     print(f"  Baseline overtime:   {comparison['baseline']['overtime_probability']*100:.1f}%")
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m     print(f"  Proposed overtime:   {comparison['proposed']['overtime_probability']*100:.1f}%")
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m     # Step 4: Store results (only if DynamoDB table exists)
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m     print("\nStep 4: Storing proposed template...")
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m     try:
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m         store_proposed_template(provider_id, proposed_template, comparison)
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m         print(f"  Stored to DynamoDB table '{TABLE_NAME}' with status='proposed'")
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m     except Exception as e:
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m         print(f"  Skipping DynamoDB store (table may not exist): {e}")
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m         print("  In production, this writes to DynamoDB for the review workflow.")
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m     print("\nDone. Template ready for human review.")
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m         "provider_id": provider_id,
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m         "template": proposed_template,
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m         "comparison": comparison,
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m # Run the pipeline
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m if __name__ == "__main__":
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m     result = run_optimization_pipeline()
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m     print("\n\nFull output:")
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m     print(json.dumps(result, indent=2, default=str))
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m ## The Gap Between This and Production
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m This example works. Run it and it will produce an optimized template with simulation validation. But there's meaningful distance between "works in a script" and "runs weekly optimizing templates for 200 providers." Here's where that gap lives:
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m **Real data integration.** This example uses hardcoded duration statistics and no-show rates. A production system pulls these from your EHR data warehouse (Epic Clarity, Cerner HealtheIntent, or whatever reporting database you have). That extraction step involves SQL queries against scheduling tables, data quality checks (are durations reasonable? are there outliers from data entry errors?), and handling of edge cases (providers who started mid-year, visit types that were recently added).
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m **Provider-specific models.** Each provider has different patterns. Dr. Martinez runs 5 minutes over on complex visits; Dr. Chen finishes 3 minutes early. The optimization should run per-provider with provider-specific duration distributions. This example uses one set of statistics for illustration.
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m **Solver selection for larger problems.** CBC (the solver bundled with PuLP) handles this single-provider problem easily. If you're optimizing across multiple providers with shared resources (MAs, rooms, equipment), you may need a more powerful solver. Google OR-Tools CP-SAT handles complex constraint problems well. For very large instances, commercial solvers like Gurobi or CPLEX offer better performance (but require licenses).
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m **Simulation fidelity.** The simulation here models patient arrivals and visit durations but ignores several real-world factors: late arrivals (patients who show up 10 minutes after their slot), early arrivals who want to be seen sooner, walk-ins, same-day add-ons, and shared resource contention (one MA supporting two providers). A production simulation should model these.
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m **Error handling and retries.** The DynamoDB write has no retry logic, no error handling for conditional check failures, and no dead-letter queue for failed writes. Production code wraps every external call in try/except with specific handling for throttling, service unavailability, and validation errors.
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m **IAM least-privilege.** The IAM role for this pipeline should have exactly: `s3:GetObject` on the features bucket, `s3:PutObject` on the results bucket, `dynamodb:PutItem` on the template-store table, and `dynamodb:GetItem` for reading current templates. Not `s3:*`. Not `dynamodb:*`.
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m **VPC and encryption.** Scheduling data contains patient names and visit reasons (PHI). In production, SageMaker Processing jobs run in a VPC with no internet access, using VPC endpoints for S3 and DynamoDB. All data at rest is encrypted with KMS customer-managed keys.
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m **Template change management.** This example produces a proposed template but doesn't handle the approval workflow, rollback if a new template underperforms, or gradual rollout (try the new template for one week, compare actual vs. simulated performance, then decide whether to keep it). That workflow lives in Step Functions with human approval steps.
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m **Monitoring and drift detection.** After deploying a new template, you need to monitor whether actual performance matches the simulation predictions. If the template was optimized on summer data and flu season arrives, the patient mix shifts and the template may underperform. Build in automated re-optimization triggers when actual metrics deviate from predicted by more than a threshold.
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m **Testing.** There are no tests here. A production pipeline has unit tests for the optimization formulation (does it respect constraints?), integration tests for the simulation (does it produce reasonable distributions?), and regression tests that verify known-good templates still score well after code changes.
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m *Part of the Healthcare AI/ML Cookbook. See [Recipe 14.1](chapter14.01-appointment-slot-optimization) for the full architectural walkthrough, pseudocode, and honest take on where this gets hard.*
