[0m[49m[38;5;10m+      357[0m:[38;5;10m[49m             // Temporal conflict resolution: when both positive and negative evidence
[0m[49m[38;5;10m+      358[0m:[38;5;10m[49m             // exist for the same criterion, apply the phenotype's temporal semantics.
[0m[49m[38;5;10m+      359[0m:[38;5;10m[49m             // Two common interpretations:
[0m[49m[38;5;10m+      360[0m:[38;5;10m[49m             //   "current-status" phenotypes: most recent note wins. If the latest
[0m[49m[38;5;10m+      361[0m:[38;5;10m[49m             //       documentation negates the criterion, it overrides earlier positives.
[0m[49m[38;5;10m+      362[0m:[38;5;10m[49m             //   "ever-had" phenotypes: any positive evidence is sufficient regardless
[0m[49m[38;5;10m+      363[0m:[38;5;10m[49m             //       of later negations (e.g., "history of stroke" is permanent).
[0m[49m[38;5;10m+      364[0m:[38;5;10m[49m             // The phenotype definition specifies which interpretation applies.
[0m[49m[38;5;10m+      365[0m:[38;5;10m[49m             // Default to "current-status" if unspecified.
[0m[49m[38;5;10m+      366[0m:[38;5;10m[49m             
[0m[49m[38;5;10m+      367[0m:[38;5;10m[49m             IF negative_evidence is not empty AND positive_evidence is not empty:
[0m[49m[38;5;10m+      368[0m:[38;5;10m[49m                 temporal_mode = criterion.get("temporal_semantics", "current-status")
[0m[49m[38;5;10m+      369[0m:[38;5;10m[49m                 
[0m[49m[38;5;10m+      370[0m:[38;5;10m[49m                 IF temporal_mode == "current-status":
[0m[49m[38;5;10m+      371[0m:[38;5;10m[49m                     // Most recent note takes priority for determining current state.
[0m[49m[38;5;10m+      372[0m:[38;5;10m[49m                     most_recent_negative = max(negative_evidence, by note_date)
[0m[49m[38;5;10m+      373[0m:[38;5;10m[49m                     // Keep only positive evidence that is more recent than the latest negation.
[0m[49m[38;5;10m+      374[0m:[38;5;10m[49m                     positive_evidence = filter positive_evidence where note_date > most_recent_negative.note_date
