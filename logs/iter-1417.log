[49m[38;5;10m+      1[0m:[38;5;10m[49m # Recipe 14.5: Python Implementation Example
[0m[49m[38;5;10m+      2[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      3[0m:[38;5;10m[49m > **Heads up:** This is a deliberately simple, illustrative implementation of the pseudocode walkthrough from Recipe 14.5. It demonstrates how to formulate and solve an OR block scheduling optimization problem using Python and an open-source solver. It is not production-ready. The optimization model here is intentionally small-scale so you can trace what's happening at each step. A real hospital implementation would have more constraints, messier data, and significantly more political complexity. Consider it a starting point, not a destination.
[0m[49m[38;5;10m+      4[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      5[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+      6[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      7[0m:[38;5;10m[49m ## Setup
[0m[49m[38;5;10m+      8[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      9[0m:[38;5;10m[49m You'll need the following packages installed:
[0m[49m[38;5;10m+     10[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     11[0m:[38;5;10m[49m ```bash
[0m[49m[38;5;10m+     12[0m:[38;5;10m[49m pip install boto3 pulp
[0m[49m[38;5;10m+     13[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     14[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     15[0m:[38;5;10m[49m PuLP is a Python linear programming library that provides a clean modeling interface and ships with the CBC (COIN-OR Branch and Cut) solver built in. For larger problems, you can swap in HiGHS (free, faster) or Gurobi (commercial, fastest) without changing your model code. PuLP abstracts the solver choice behind a common API.
[0m[49m[38;5;10m+     16[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     17[0m:[38;5;10m[49m Your environment needs AWS credentials configured (via environment variables, an instance profile, or `~/.aws/credentials`). The IAM role needs `s3:GetObject`, `s3:PutObject`, `dynamodb:GetItem`, `dynamodb:Query`, and `dynamodb:Scan` scoped to the relevant resources.
[0m[49m[38;5;10m+     18[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     19[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     20[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     21[0m:[38;5;10m[49m ## Configuration and Constants
[0m[49m[38;5;10m+     22[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     23[0m:[38;5;10m[49m Before we get to the optimization logic, here's the configuration that drives the model. In a real system, most of this comes from DynamoDB or your scheduling system. Here we define it inline so you can see exactly what the optimizer is working with.
[0m[49m[38;5;10m+     24[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     25[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     26[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+     27[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+     28[0m:[38;5;10m[49m from datetime import datetime, timezone
[0m[49m[38;5;10m+     29[0m:[38;5;10m[49m from typing import Any
[0m[49m[38;5;10m+     30[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     31[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+     32[0m:[38;5;10m[49m import pulp
[0m[49m[38;5;10m+     33[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+     34[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     35[0m:[38;5;10m[49m # Structured logging. Never log PHI (surgeon names linked to patient procedures
[0m[49m[38;5;10m+     36[0m:[38;5;10m[49m # count as PHI under HIPAA when combined with schedule data).
[0m[49m[38;5;10m+     37[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+     38[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+     39[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     40[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+     41[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     42[0m:[38;5;10m[49m # --- Optimization Configuration ---
[0m[49m[38;5;10m+     43[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     44[0m:[38;5;10m[49m # Weights for the multi-objective function.
[0m[49m[38;5;10m+     45[0m:[38;5;10m[49m # These encode value judgments. Adjust based on what your block committee cares about.
[0m[49m[38;5;10m+     46[0m:[38;5;10m[49m # Higher utilization weight = optimizer aggressively reshuffles for efficiency.
[0m[49m[38;5;10m+     47[0m:[38;5;10m[49m # Higher disruption weight = optimizer preserves the current schedule (conservative).
[0m[49m[38;5;10m+     48[0m:[38;5;10m[49m WEIGHTS = {
[0m[49m[38;5;10m+     49[0m:[38;5;10m[49m     "utilization": 1.0,      # reward for matching allocated hours to demand
[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m     "disruption": 0.3,       # penalty for changing a block from its current owner
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m     "fairness_bonus": 0.5,   # reward for giving underserved services more time
[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m # Solver configuration.
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m SOLVER_CONFIG = {
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m     "solver": "CBC",          # ships with PuLP, no extra install needed
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m     "max_seconds": 300,       # 5 minute time limit (more than enough for this scale)
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m     "gap_tolerance": 0.01,    # accept solutions within 1% of proven optimum
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m # Block schedule resolution: each block is a half-day slot (4 hours).
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m BLOCK_DURATION_HOURS = 4.0
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m # Minimum utilization ratio below which a service is considered "underserved"
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m # and gets a fairness bonus in the objective.
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m FAIRNESS_THRESHOLD = 0.7
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m ## Step 1: Load Input Data
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m *The pseudocode calls this `extract_optimization_inputs`. In production, this pulls from your data lake and DynamoDB. Here we load from S3 where a preprocessing step has already assembled the inputs as JSON.*
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m s3_client = boto3.client("s3", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m def load_optimization_inputs(bucket: str, prefix: str) -> dict:
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m     Load the pre-assembled optimization inputs from S3.
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m     In a real system, a separate ETL pipeline aggregates data from the EHR's
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m     surgical scheduling module into these JSON files. The optimizer doesn't
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m     talk to the EHR directly.
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m         bucket: S3 bucket containing optimization inputs
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m         prefix: S3 prefix (folder path) for this optimization run
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m         Dictionary containing all inputs the model needs.
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m     def read_json(key: str) -> Any:
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m         response = s3_client.get_object(Bucket=bucket, Key=f"{prefix}/{key}")
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m         return json.loads(response["Body"].read().decode("utf-8"))
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m     # Available blocks: each block is a room + day + time slot.
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m     # Example: {"block_id": "OR3-MON-AM", "room": "OR3", "day": "Monday",
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m     #           "slot": "AM", "duration_hours": 4.0}
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m     blocks = read_json("blocks.json")
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m     # Services requesting block time, with their demand profiles.
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m     # Example: {"service_id": "ortho", "name": "Orthopedics",
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m     #           "weekly_hours_needed": 45, "compatible_rooms": ["OR1","OR2","OR3"],
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m     #           "operating_days": ["Monday","Tuesday","Wednesday","Thursday","Friday"]}
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m     services = read_json("services.json")
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m     # Current block allocation (what the schedule looks like today).
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m     # Example: {"OR3-MON-AM": "ortho", "OR3-MON-PM": "cardiac", ...}
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m     current_allocation = read_json("current_allocation.json")
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m         "Loaded inputs: %d blocks, %d services, %d current allocations",
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m         len(blocks), len(services), len(current_allocation),
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m         "blocks": blocks,
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m         "services": services,
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m         "current_allocation": current_allocation,
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m ## Step 2: Estimate Demand
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m *The pseudocode calls this `estimate_demand`. For this example, demand is pre-calculated and included in the service profiles (the `weekly_hours_needed` field). In production, you'd run a time series model or trailing average over 6-12 months of case history.*
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m def estimate_demand(services: list[dict]) -> dict:
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m     Build demand profiles from service data.
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m     In production, this would query historical case logs and compute:
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m     - Trailing average weekly OR-hours per service
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m     - Growth/decline trends
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m     - Seasonal adjustments
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m     - Known future changes (new surgeon starting, retirements)
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m     Here we use the pre-calculated values from the input file.
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m         Map of service_id to demand profile dict.
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m     demand = {}
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m     for svc in services:
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m         demand[svc["service_id"]] = {
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m             "weekly_hours_needed": svc["weekly_hours_needed"],
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m             "compatible_rooms": svc["compatible_rooms"],
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m             "operating_days": svc["operating_days"],
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m             # Minimum useful block allocation: at least 70% of stated need.
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m             "min_hours": svc["weekly_hours_needed"] * FAIRNESS_THRESHOLD,
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m     return demand
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m ## Step 3: Formulate the Optimization Model
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m *The pseudocode calls this `formulate_model`. This is the core of the recipe: defining decision variables, constraints, and the objective function using PuLP's modeling language.*
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m def formulate_model(
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m     blocks: list[dict],
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m     services: list[dict],
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m     demand: dict,
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m     current_allocation: dict,
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m ) -> pulp.LpProblem:
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m     Build the mixed-integer programming model for block scheduling.
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m     Decision: which service gets which block?
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m     Objective: maximize utilization match + fairness, minimize disruption.
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m     Constraints: room capability, surgeon availability, one service per block.
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m     This returns a PuLP model object ready to be solved.
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m     # Create the optimization problem. We're maximizing (utilization - disruption).
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m     model = pulp.LpProblem("OR_Block_Scheduling", pulp.LpMaximize)
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m     # --- DECISION VARIABLES ---
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m     # x[service_id][block_id] = 1 if that service is assigned that block, else 0.
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m     # PuLP creates these as binary (0/1) variables.
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m     x = {}
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m     for svc in services:
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m         x[svc["service_id"]] = {}
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m         for block in blocks:
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m             var_name = f"assign_{svc['service_id']}_{block['block_id']}"
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m             x[svc["service_id"]][block["block_id"]] = pulp.LpVariable(
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m                 var_name, cat=pulp.LpBinary
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m     # --- HARD CONSTRAINTS ---
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m     # Constraint 1: Each block assigned to at most one service.
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m     # (A block can also be unassigned, which is fine. Not every slot needs filling.)
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m     for block in blocks:
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m         model += (
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m             pulp.lpSum(
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m                 x[svc["service_id"]][block["block_id"]] for svc in services
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m             <= 1,
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m             f"one_service_per_block_{block['block_id']}",
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m     # Constraint 2: Room capability. A service can only use rooms it's qualified for.
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m     # If Cardiac needs bypass infrastructure and OR3 doesn't have it, x[cardiac][OR3-*] = 0.
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m     for svc in services:
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m         sid = svc["service_id"]
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m         compatible = set(demand[sid]["compatible_rooms"])
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m         for block in blocks:
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m             if block["room"] not in compatible:
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m                 model += (
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m                     x[sid][block["block_id"]] == 0,
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m                     f"room_cap_{sid}_{block['block_id']}",
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m                 )
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m     # Constraint 3: Surgeon availability. Services can only use blocks on days
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m     # their surgeons operate.
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m     for svc in services:
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m         sid = svc["service_id"]
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m         avail_days = set(demand[sid]["operating_days"])
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m         for block in blocks:
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m             if block["day"] not in avail_days:
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m                 model += (
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m                     x[sid][block["block_id"]] == 0,
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m                     f"avail_{sid}_{block['block_id']}",
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m                 )
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m     # Constraint 4: Minimum allocation (fairness floor).
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m     # Each service gets at least min_hours of block time.
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m     for svc in services:
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m         sid = svc["service_id"]
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m         min_hrs = demand[sid]["min_hours"]
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m         model += (
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m             pulp.lpSum(
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m                 x[sid][b["block_id"]] * b["duration_hours"] for b in blocks
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m             >= min_hrs,
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m             f"min_alloc_{sid}",
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     # --- OBJECTIVE FUNCTION ---
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m     # Component 1: Utilization match.
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m     # Reward allocations that closely match demand. We penalize the gap between
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m     # what a service needs and what it gets using auxiliary variables.
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m     # (PuLP can't do abs() directly, so we use a linear approximation:
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m     #  reward = allocated_hours, capped at demand. Over-allocation gets no extra credit.)
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m     utilization_score = []
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m     for svc in services:
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m         sid = svc["service_id"]
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m         needed = demand[sid]["weekly_hours_needed"]
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m         allocated = pulp.lpSum(
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m             x[sid][b["block_id"]] * b["duration_hours"] for b in blocks
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m         # Simple linear reward: each hour allocated toward need is valuable.
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m         # Hours beyond need are wasted (but we don't penalize, just don't reward).
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m         # We cap the reward at the demand level using a min constraint trick.
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m         # For simplicity here, just use allocated hours directly. The constraint
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m         # that limits total blocks to <= actual capacity prevents gross over-allocation.
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m         utilization_score.append(allocated)
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m     # Component 2: Disruption penalty.
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m     # Every block that changes hands from the current schedule costs us.
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m     disruption_penalty = []
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m     for svc in services:
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m         sid = svc["service_id"]
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m         for block in blocks:
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m             bid = block["block_id"]
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m             current_owner = current_allocation.get(bid)
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m             if current_owner and current_owner != sid:
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m                 # Assigning this block to a service that doesn't currently own it
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m                 # incurs a disruption cost.
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m                 disruption_penalty.append(x[sid][bid])
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m     # Component 3: Fairness bonus.
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m     # Services currently below the fairness threshold get a bonus for each
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m     # additional hour they receive. This tilts the optimizer toward equity.
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m     fairness_bonus = []
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m     for svc in services:
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m         sid = svc["service_id"]
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m         needed = demand[sid]["weekly_hours_needed"]
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m         current_hours = sum(
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m             b["duration_hours"]
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m             for b in blocks
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m             if current_allocation.get(b["block_id"]) == sid
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m         if current_hours < needed * FAIRNESS_THRESHOLD:
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m             # This service is underserved. Bonus for allocating to them.
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m             allocated = pulp.lpSum(
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m                 x[sid][b["block_id"]] * b["duration_hours"] for b in blocks
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m             fairness_bonus.append(allocated)
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m     # Combine into the final objective.
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m     model += (
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m         WEIGHTS["utilization"] * pulp.lpSum(utilization_score)
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m         - WEIGHTS["disruption"] * pulp.lpSum(disruption_penalty)
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m         + WEIGHTS["fairness_bonus"] * pulp.lpSum(fairness_bonus)
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m         "Model formulated: %d variables, %d constraints",
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m         model.numVariables(),
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m         model.numConstraints(),
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m     return model, x
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m ## Step 4: Solve and Extract Solution
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m *The pseudocode calls this `solve_and_extract`. We invoke the solver and pull out the block assignments from the solution.*
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m def solve_model(
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m     model: pulp.LpProblem,
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m     x: dict,
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m     blocks: list[dict],
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m     services: list[dict],
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m     Solve the optimization model and extract the block schedule.
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m         Dictionary with status, schedule (block_id -> service_id mapping),
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m         objective value, and solve time.
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m     # Configure and invoke the solver.
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m     # CBC ships with PuLP. For better performance on large instances,
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m     # swap to HiGHS: solver = pulp.HiGHS_CMD(timeLimit=SOLVER_CONFIG["max_seconds"])
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m     solver = pulp.PULP_CBC_CMD(
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m         msg=0,  # suppress solver console output
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m         timeLimit=SOLVER_CONFIG["max_seconds"],
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m         gapRel=SOLVER_CONFIG["gap_tolerance"],
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m     start_time = datetime.now(timezone.utc)
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m     model.solve(solver)
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m     solve_seconds = (datetime.now(timezone.utc) - start_time).total_seconds()
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m     status = pulp.LpStatus[model.status]
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m     logger.info("Solver finished: status=%s, time=%.1fs", status, solve_seconds)
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m     if status == "Infeasible":
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m         # The constraints are contradictory. No valid schedule exists.
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m         # In production, you'd identify which constraints conflict.
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m         logger.error("Model is infeasible. Check constraint compatibility.")
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m             "status": "INFEASIBLE",
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m             "schedule": {},
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m             "objective_value": None,
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m             "solve_seconds": solve_seconds,
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m     # Extract the solution: which service got which block?
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m     schedule = {}
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m     for svc in services:
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m         sid = svc["service_id"]
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m         for block in blocks:
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m             bid = block["block_id"]
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m             if pulp.value(x[sid][bid]) == 1:
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m                 schedule[bid] = sid
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m         "status": status.upper(),
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m         "schedule": schedule,
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m         "objective_value": pulp.value(model.objective),
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m         "solve_seconds": solve_seconds,
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m ## Step 5: Analyze the Solution
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m *The pseudocode calls this `analyze_solution`. Compare the new schedule against the current one and compute metrics the block committee cares about.*
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m def analyze_solution(
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m     schedule: dict,
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m     blocks: list[dict],
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m     services: list[dict],
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m     demand: dict,
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m     current_allocation: dict,
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m     Compute per-service and aggregate metrics for the proposed schedule.
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m     This is what the block committee actually looks at: who gains time,
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m     who loses time, and what the expected utilization improvement is.
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m     # Build a lookup for block durations.
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m     block_hours = {b["block_id"]: b["duration_hours"] for b in blocks}
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m     analysis = {}
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m     for svc in services:
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m         sid = svc["service_id"]
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m         # Hours under the new schedule.
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m         new_hours = sum(
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m             block_hours[bid] for bid, owner in schedule.items() if owner == sid
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m         # Hours under the current schedule.
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m         current_hours = sum(
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m             block_hours[bid]
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m             for bid, owner in current_allocation.items()
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m             if owner == sid
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m         needed = demand[sid]["weekly_hours_needed"]
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m         # Expected utilization: ratio of demand to allocation.
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m         # >1.0 means under-allocated (demand exceeds supply).
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m         # <1.0 means over-allocated (some time will sit empty).
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m         expected_util = needed / new_hours if new_hours > 0 else 0.0
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m         analysis[sid] = {
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m             "service_name": svc["name"],
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m             "allocated_hours": new_hours,
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m             "previous_hours": current_hours,
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m             "change_hours": new_hours - current_hours,
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m             "weekly_demand_hours": needed,
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m             "expected_utilization": round(min(expected_util, 1.0), 2),
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m     # Aggregate metrics.
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m     total_allocated = sum(a["allocated_hours"] for a in analysis.values())
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m     total_demand = sum(a["weekly_demand_hours"] for a in analysis.values())
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m     blocks_changed = sum(
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m         1
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m         for bid, new_owner in schedule.items()
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m         if current_allocation.get(bid) != new_owner
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m     total_blocks = len(blocks)
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m     # Fairness: the worst-off service's allocation ratio.
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m     fairness_ratios = [
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m         a["allocated_hours"] / a["weekly_demand_hours"]
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m         for a in analysis.values()
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m         if a["weekly_demand_hours"] > 0
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m     min_fairness = round(min(fairness_ratios), 2) if fairness_ratios else 0.0
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m     summary = {
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m         "total_expected_utilization": round(total_demand / total_allocated, 2)
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m         if total_allocated > 0
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m         else 0.0,
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m         "blocks_changed": blocks_changed,
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m         "total_blocks": total_blocks,
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m         "disruption_pct": round(100 * blocks_changed / total_blocks, 1)
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m         if total_blocks > 0
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m         else 0.0,
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m         "fairness_min_ratio": min_fairness,
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m     return {"per_service": analysis, "summary": summary}
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m ## Step 6: Store Results
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m *The pseudocode calls this `store_and_notify`. Write the optimized schedule and analysis to S3 for the dashboard and committee review.*
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m def store_results(
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m     bucket: str,
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m     run_id: str,
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m     solution: dict,
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m     analysis: dict,
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m ) -> str:
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m     Write optimization results to S3 for downstream consumption
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m     (QuickSight dashboards, committee review tools).
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m         The S3 prefix where results were stored.
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m     output_prefix = f"optimization-results/{run_id}"
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m     def write_json(key: str, data: Any) -> None:
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m         s3_client.put_object(
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m             Bucket=bucket,
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m             Key=f"{output_prefix}/{key}",
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m             Body=json.dumps(data, indent=2, default=str).encode("utf-8"),
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m             ContentType="application/json",
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m             ServerSideEncryption="aws:kms",
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m     # The optimized block schedule.
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m     write_json("schedule.json", solution["schedule"])
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m     # Per-service analysis and summary metrics.
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m     write_json("analysis.json", analysis)
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m     # Run metadata for audit trail.
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m     metadata = {
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m         "run_id": run_id,
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m         "timestamp": datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m         "status": solution["status"],
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m         "objective_value": solution["objective_value"],
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m         "solve_seconds": solution["solve_seconds"],
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m         "solver": SOLVER_CONFIG["solver"],
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m     write_json("metadata.json", metadata)
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m     logger.info("Results stored at s3://%s/%s/", bucket, output_prefix)
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m     return f"s3://{bucket}/{output_prefix}/"
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m ## Full Pipeline
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m Assembles all steps into a single callable function. Run this to see the full optimization flow end-to-end.
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m def run_block_optimization(
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m     bucket: str,
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m     input_prefix: str,
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m     run_id: str | None = None,
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m ) -> dict:
