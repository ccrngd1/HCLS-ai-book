[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m     "I": ("9", "Diseases of the circulatory system"),
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m     "J": ("10", "Diseases of the respiratory system"),
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m     "K": ("11", "Diseases of the digestive system"),
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m     "L": ("12", "Diseases of the skin and subcutaneous tissue"),
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m     "M": ("13", "Diseases of the musculoskeletal system"),
