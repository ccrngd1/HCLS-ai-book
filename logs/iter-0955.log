[49m[38;5;10m+      1[0m:[38;5;10m[49m # Recipe 13.3: Python Implementation Example
[0m[49m[38;5;10m+      2[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      3[0m:[38;5;10m[49m > **Heads up:** This is a deliberately simple, illustrative implementation of the pseudocode walkthrough from Recipe 13.3. It shows one way you could translate those graph concepts into working Python code using boto3 and Neptune's openCypher endpoint. It is not production-ready. There's no connection pooling, no robust error handling, no input validation. Think of it as the sketchpad version: useful for understanding how ICD/CPT hierarchy data flows into a graph and how traversal queries work, not something you'd deploy to a coding department on Monday morning. A starting point, not a destination.
[0m[49m[38;5;10m+      4[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      5[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+      6[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      7[0m:[38;5;10m[49m ## Setup
[0m[49m[38;5;10m+      8[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      9[0m:[38;5;10m[49m You'll need the AWS SDK for Python and a few supporting libraries:
[0m[49m[38;5;10m+     10[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     11[0m:[38;5;10m[49m ```bash
[0m[49m[38;5;10m+     12[0m:[38;5;10m[49m pip install boto3 requests
[0m[49m[38;5;10m+     13[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     14[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     15[0m:[38;5;10m[49m Your environment needs credentials configured (via environment variables, an instance profile, or `~/.aws/credentials`). The IAM role or user needs permissions for Neptune (`neptune-db:*` scoped to your cluster), S3 (`s3:GetObject` and `s3:PutObject` on the staging bucket), and network access to Neptune from within your VPC.
[0m[49m[38;5;10m+     16[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     17[0m:[38;5;10m[49m Neptune doesn't use IAM for query authentication by default (it uses VPC-level network isolation). If you've enabled IAM auth on your cluster, you'll need to sign requests with SigV4. This example assumes VPC network access without IAM auth for simplicity.
[0m[49m[38;5;10m+     18[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     19[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     20[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     21[0m:[38;5;10m[49m ## Config and Constants
[0m[49m[38;5;10m+     22[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     23[0m:[38;5;10m[49m Before we get to the steps, here's the configuration that drives the pipeline. These constants define the Neptune endpoint, the graph schema for medical code hierarchies, and the ICD-10-CM chapter structure we'll use to derive hierarchy from code structure.
[0m[49m[38;5;10m+     24[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     25[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     26[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+     27[0m:[38;5;10m[49m import csv
[0m[49m[38;5;10m+     28[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+     29[0m:[38;5;10m[49m import io
[0m[49m[38;5;10m+     30[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+     31[0m:[38;5;10m[49m import requests
[0m[49m[38;5;10m+     32[0m:[38;5;10m[49m from datetime import date
[0m[49m[38;5;10m+     33[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     34[0m:[38;5;10m[49m # Configure logging. In production, use structured JSON logging
[0m[49m[38;5;10m+     35[0m:[38;5;10m[49m # for CloudWatch Logs Insights queries.
[0m[49m[38;5;10m+     36[0m:[38;5;10m[49m # PHI Safety: Code assignments linked to patients are part of the
[0m[49m[38;5;10m+     37[0m:[38;5;10m[49m # designated record set. Never log patient-code associations.
[0m[49m[38;5;10m+     38[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+     39[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+     40[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     41[0m:[38;5;10m[49m # Neptune cluster endpoint. Use the writer endpoint for loads,
[0m[49m[38;5;10m+     42[0m:[38;5;10m[49m # reader endpoint for queries. In production, separate these.
[0m[49m[38;5;10m+     43[0m:[38;5;10m[49m #
[0m[49m[38;5;10m+     44[0m:[38;5;10m[49m # Neptune runs inside your VPC. This code must execute from within
[0m[49m[38;5;10m+     45[0m:[38;5;10m[49m # the same VPC (Lambda in VPC, EC2, ECS, etc.) to reach it.
[0m[49m[38;5;10m+     46[0m:[38;5;10m[49m NEPTUNE_ENDPOINT = "your-neptune-cluster.cluster-xxxxxxxxxxxx.us-east-1.neptune.amazonaws.com"
[0m[49m[38;5;10m+     47[0m:[38;5;10m[49m NEPTUNE_PORT = 8182
[0m[49m[38;5;10m+     48[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     49[0m:[38;5;10m[49m # Neptune exposes openCypher queries via HTTPS POST to this path.
[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m NEPTUNE_OPENCYPHER_URL = f"https://{NEPTUNE_ENDPOINT}:{NEPTUNE_PORT}/openCypher"
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m # S3 bucket for staging source files and Neptune bulk load CSVs.
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m STAGING_BUCKET = "my-code-hierarchy-staging"
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m # Neptune bulk loader IAM role. This role must have S3 read access
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m # to the staging bucket and a trust policy allowing Neptune to assume it.
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m NEPTUNE_LOAD_ROLE_ARN = "arn:aws:iam::123456789012:role/NeptuneLoadFromS3"
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m # AWS region for all service calls.
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m AWS_REGION = "us-east-1"
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m # Redis endpoint for caching traversal results.
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m # Hierarchy queries are deterministic per version, so caching is very effective.
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m REDIS_HOST = "your-redis-cluster.xxxxxxxxxxxx.use1.cache.amazonaws.com"
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m REDIS_PORT = 6379
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m # Cache TTL: 24 hours. ICD-10 updates annually (Oct 1), CPT annually with
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m # quarterly corrections. Flush cache explicitly on version loads.
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m CACHE_TTL_SECONDS = 86400
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m # ICD-10-CM chapter ranges. The first character of the code determines
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m # the chapter. This is how we derive the top-level hierarchy from code structure.
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m ICD10_CHAPTERS = {
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m     "A": ("1", "Certain infectious and parasitic diseases"),
