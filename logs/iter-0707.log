[49m[38;5;10m+      1[0m:[38;5;10m[49m # Recipe 7.4: Python Implementation Example
[0m[49m[38;5;10m+      2[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      3[0m:[38;5;10m[49m > **Heads up:** This is a deliberately simplified, illustrative implementation of an ED visit prediction pipeline. It generates synthetic patient data, trains a gradient boosted tree model, and scores patients for 30-day ED visit risk. It is not production-ready. The feature engineering is minimal, the synthetic data is unrealistically clean, and the model evaluation skips half the things you'd need for a real deployment (fairness audits, calibration curves, clinical validation). Think of it as a sketch that shows the shape of the solution. A starting point, not a destination.
[0m[49m[38;5;10m+      4[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      5[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+      6[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      7[0m:[38;5;10m[49m ## Setup
[0m[49m[38;5;10m+      8[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      9[0m:[38;5;10m[49m You'll need the AWS SDK for Python and a few standard ML libraries:
[0m[49m[38;5;10m+     10[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     11[0m:[38;5;10m[49m ```bash
[0m[49m[38;5;10m+     12[0m:[38;5;10m[49m pip install boto3 pandas numpy scikit-learn
[0m[49m[38;5;10m+     13[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     14[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     15[0m:[38;5;10m[49m Your environment needs credentials configured (via environment variables, an instance profile, or `~/.aws/credentials`). The IAM role or user needs:
[0m[49m[38;5;10m+     16[0m:[38;5;10m[49m - `s3:GetObject`, `s3:PutObject` on your data bucket
[0m[49m[38;5;10m+     17[0m:[38;5;10m[49m - `sagemaker:CreateTrainingJob`, `sagemaker:CreateEndpoint`, `sagemaker:InvokeEndpoint`
[0m[49m[38;5;10m+     18[0m:[38;5;10m[49m - `dynamodb:PutItem`, `dynamodb:Query` on your patient risk score table
[0m[49m[38;5;10m+     19[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     20[0m:[38;5;10m[49m For the SageMaker training path, you'll also need a SageMaker execution role with S3 access. This example runs the model locally with scikit-learn for clarity, then shows how you'd deploy via SageMaker.
[0m[49m[38;5;10m+     21[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     22[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     23[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     24[0m:[38;5;10m[49m ## Config and Constants
[0m[49m[38;5;10m+     25[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     26[0m:[38;5;10m[49m These define the feature schema, risk thresholds, and model parameters. They live at the top because they're really configuration decisions, not logic. Readers should see what levers exist before seeing the code that uses them.
[0m[49m[38;5;10m+     27[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     28[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     29[0m:[38;5;10m[49m import numpy as np
[0m[49m[38;5;10m+     30[0m:[38;5;10m[49m import pandas as pd
[0m[49m[38;5;10m+     31[0m:[38;5;10m[49m from datetime import datetime, timedelta
[0m[49m[38;5;10m+     32[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     33[0m:[38;5;10m[49m # ─── Risk Tier Thresholds ───────────────────────────────────────────────────
[0m[49m[38;5;10m+     34[0m:[38;5;10m[49m # These thresholds determine which patients get outreach. They're not magic
[0m[49m[38;5;10m+     35[0m:[38;5;10m[49m # numbers: you calibrate them based on your care management team's capacity.
[0m[49m[38;5;10m+     36[0m:[38;5;10m[49m # If you can only call 200 patients per week, set HIGH_RISK_THRESHOLD so that
[0m[49m[38;5;10m+     37[0m:[38;5;10m[49m # roughly 200 patients land above it in each scoring run.
[0m[49m[38;5;10m+     38[0m:[38;5;10m[49m #
[0m[49m[38;5;10m+     39[0m:[38;5;10m[49m # The gap between medium and high matters operationally. High-risk patients
[0m[49m[38;5;10m+     40[0m:[38;5;10m[49m # get a nurse call within 48 hours. Medium-risk get a mailer and a pharmacy
[0m[49m[38;5;10m+     41[0m:[38;5;10m[49m # check-in. Low-risk get nothing (for now).
[0m[49m[38;5;10m+     42[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     43[0m:[38;5;10m[49m HIGH_RISK_THRESHOLD = 0.70    # top tier: proactive nurse outreach
[0m[49m[38;5;10m+     44[0m:[38;5;10m[49m MEDIUM_RISK_THRESHOLD = 0.40  # middle tier: automated outreach
[0m[49m[38;5;10m+     45[0m:[38;5;10m[49m # Below 0.40: no intervention (standard care)
[0m[49m[38;5;10m+     46[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     47[0m:[38;5;10m[49m # ─── Feature Configuration ──────────────────────────────────────────────────
[0m[49m[38;5;10m+     48[0m:[38;5;10m[49m # These are the features we'll engineer from claims and clinical data.
[0m[49m[38;5;10m+     49[0m:[38;5;10m[49m # In production, you'd pull these from a feature store. Here we generate
[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m # synthetic versions to demonstrate the pipeline shape.
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m FEATURE_COLUMNS = [
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m     "age",
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m     "ed_visits_last_12m",          # prior ED utilization (strongest signal)
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m     "ed_visits_last_3m",           # recent acceleration
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m     "chronic_condition_count",     # comorbidity burden
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m     "has_diabetes",
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m     "has_chf",
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m     "has_copd",
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m     "has_mental_health_dx",
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m     "missed_appointments_last_6m", # engagement proxy
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m     "days_since_last_pcp_visit",   # care continuity gap
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m     "rx_fills_last_3m",            # medication adherence proxy
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m     "inpatient_admits_last_12m",   # hospitalization history
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m     "lives_alone",                 # social isolation (if available)
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m     "distance_to_nearest_ed_miles",# geographic access
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m # ─── Model Parameters ───────────────────────────────────────────────────────
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m # Gradient boosted trees work well here because:
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m # 1. They handle mixed feature types (continuous + binary) without scaling
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m # 2. They capture non-linear interactions (age + CHF + lives alone)
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m # 3. They produce feature importance rankings for clinical explainability
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m # 4. They're robust to missing values (common in claims data)
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m MODEL_PARAMS = {
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m     "n_estimators": 200,
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m     "max_depth": 5,           # shallow trees reduce overfitting on small cohorts
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m     "learning_rate": 0.1,
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m     "min_samples_leaf": 20,   # prevents fitting to tiny subgroups
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m     "subsample": 0.8,         # row sampling for regularization
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m     "random_state": 42,
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m # ─── Prediction Window ──────────────────────────────────────────────────────
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m PREDICTION_WINDOW_DAYS = 30  # predict ED visits within next 30 days
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m ## Step 1: Generate Synthetic Patient Data
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m *In production, this data comes from your claims warehouse, EHR extracts, and ADT feeds. Here we generate realistic synthetic data to demonstrate the pipeline without touching any real PHI. The distributions are loosely based on published literature on ED utilization patterns.*
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m def generate_synthetic_patients(n_patients: int = 2000, seed: int = 42) -> pd.DataFrame:
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m     Generate synthetic patient data with realistic ED visit patterns.
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m     The key insight: ED visits cluster. A small percentage of patients account
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m     for a disproportionate share of ED utilization. Our synthetic data reflects
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m     this: roughly 15-20% of patients will have the outcome (ED visit in next
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m     30 days), with prior ED use being the strongest predictor.
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m         n_patients: Number of synthetic patients to generate.
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m         seed: Random seed for reproducibility.
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m         DataFrame with features and a binary outcome column.
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m     rng = np.random.default_rng(seed)
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m     # Age distribution: skewed toward older adults (higher ED utilization)
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m     age = rng.normal(loc=58, scale=15, size=n_patients).clip(18, 95).astype(int)
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m     # Chronic conditions: prevalence increases with age
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m     age_factor = (age - 18) / 77  # normalized 0-1
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m     has_diabetes = rng.binomial(1, 0.15 + 0.15 * age_factor, n_patients)
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m     has_chf = rng.binomial(1, 0.05 + 0.12 * age_factor, n_patients)
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m     has_copd = rng.binomial(1, 0.06 + 0.10 * age_factor, n_patients)
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m     has_mental_health_dx = rng.binomial(1, 0.20, n_patients)
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m     chronic_condition_count = has_diabetes + has_chf + has_copd + has_mental_health_dx
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m     # Add some additional conditions not individually tracked
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m     chronic_condition_count += rng.poisson(0.5, n_patients)
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m     # Prior ED utilization: the single strongest predictor of future ED use.
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m     # Most patients have 0-1 visits. A small group has 4+.
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m     ed_base_rate = 0.3 + 0.4 * (chronic_condition_count / 6)
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m     ed_visits_last_12m = rng.poisson(ed_base_rate * 1.5, n_patients)
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m     ed_visits_last_3m = rng.poisson(ed_base_rate * 0.4, n_patients)
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m     # Ensure 3-month count doesn't exceed 12-month count
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m     ed_visits_last_3m = np.minimum(ed_visits_last_3m, ed_visits_last_12m)
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m     # Care engagement signals
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m     missed_appointments_last_6m = rng.poisson(0.8, n_patients)
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m     days_since_last_pcp_visit = rng.exponential(90, n_patients).clip(0, 730).astype(int)
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m     rx_fills_last_3m = rng.poisson(3 + chronic_condition_count, n_patients)
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m     # Hospitalization history
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m     inpatient_admits_last_12m = rng.poisson(0.2 + 0.3 * (chronic_condition_count / 4), n_patients)
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m     # Social/geographic factors
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m     lives_alone = rng.binomial(1, 0.25 + 0.15 * (age > 70).astype(float), n_patients)
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m     distance_to_nearest_ed_miles = rng.exponential(8, n_patients).clip(0.5, 60)
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m     # ─── Generate outcome (ED visit in next 30 days) ────────────────────────
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m     # The outcome is driven by a combination of factors with realistic weights.
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m     # This is NOT how you'd build a real model (that's circular). This just
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m     # creates a dataset where the features have predictive signal.
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m     log_odds = (
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m         -2.5                                          # base rate ~8%
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m         + 0.6 * ed_visits_last_12m                    # strongest signal
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m         + 0.9 * ed_visits_last_3m                     # recent acceleration
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m         + 0.15 * chronic_condition_count
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m         + 0.3 * has_chf
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m         + 0.2 * has_copd
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m         + 0.25 * has_mental_health_dx
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m         + 0.1 * missed_appointments_last_6m
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m         + 0.003 * days_since_last_pcp_visit
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m         - 0.05 * rx_fills_last_3m                     # adherence is protective
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m         + 0.4 * inpatient_admits_last_12m
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m         + 0.2 * lives_alone
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m         + rng.normal(0, 0.5, n_patients)              # noise
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m     probability = 1 / (1 + np.exp(-log_odds))
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m     ed_visit_next_30d = rng.binomial(1, probability, n_patients)
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m     df = pd.DataFrame({
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m         "patient_id": [f"SYN-{i:06d}" for i in range(n_patients)],
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m         "age": age,
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m         "ed_visits_last_12m": ed_visits_last_12m,
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m         "ed_visits_last_3m": ed_visits_last_3m,
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m         "chronic_condition_count": chronic_condition_count,
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m         "has_diabetes": has_diabetes,
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m         "has_chf": has_chf,
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m         "has_copd": has_copd,
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m         "has_mental_health_dx": has_mental_health_dx,
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m         "missed_appointments_last_6m": missed_appointments_last_6m,
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m         "days_since_last_pcp_visit": days_since_last_pcp_visit,
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m         "rx_fills_last_3m": rx_fills_last_3m,
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m         "inpatient_admits_last_12m": inpatient_admits_last_12m,
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m         "lives_alone": lives_alone,
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m         "distance_to_nearest_ed_miles": distance_to_nearest_ed_miles.round(1),
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m         "ed_visit_next_30d": ed_visit_next_30d,
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m     return df
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m ## Step 2: Train the Prediction Model
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m *This step trains a gradient boosted classifier on historical data. In production, you'd run this on SageMaker with a larger dataset and proper cross-validation. Here we use scikit-learn locally to keep the focus on the pipeline logic rather than infrastructure.*
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m from sklearn.ensemble import GradientBoostingClassifier
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m from sklearn.model_selection import train_test_split
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m from sklearn.metrics import (
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m     roc_auc_score,
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m     precision_recall_curve,
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m     average_precision_score,
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m     classification_report,
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m )
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m def train_ed_prediction_model(df: pd.DataFrame) -> tuple:
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     Train a gradient boosted tree model to predict 30-day ED visits.
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m     Why gradient boosting over logistic regression? Two reasons:
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m     1. It captures interactions automatically. A 75-year-old with CHF who
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m        lives alone is much higher risk than any of those factors individually.
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m        Logistic regression needs you to manually specify those interactions.
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m     2. It handles the non-linear relationship between features and risk.
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m        The jump from 0 to 1 prior ED visits matters more than 5 to 6.
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m     Why not a neural network? For tabular data with <50 features and <100k rows,
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m     gradient boosting consistently matches or beats deep learning. It's also
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m     far easier to explain to clinicians ("prior ED visits was the top factor").
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m         df: DataFrame with features and 'ed_visit_next_30d' outcome column.
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m         Tuple of (trained_model, X_test, y_test) for evaluation.
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m     X = df[FEATURE_COLUMNS]
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m     y = df["ed_visit_next_30d"]
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m     # 80/20 train/test split. Stratify to maintain outcome ratio in both sets.
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m     # In production, you'd also hold out a temporal validation set (train on
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m     # months 1-9, validate on months 10-12) to catch concept drift.
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m     X_train, X_test, y_train, y_test = train_test_split(
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m         X, y, test_size=0.2, random_state=42, stratify=y
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m     logger.info("Training set: %d patients (%d positive, %.1f%% prevalence)",
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m                 len(y_train), y_train.sum(), 100 * y_train.mean())
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m     logger.info("Test set: %d patients (%d positive, %.1f%% prevalence)",
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m                 len(y_test), y_test.sum(), 100 * y_test.mean())
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m     # Train the model. GradientBoostingClassifier builds trees sequentially,
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m     # each one correcting the errors of the previous ensemble.
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m     model = GradientBoostingClassifier(**MODEL_PARAMS)
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m     model.fit(X_train, y_train)
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m     return model, X_test, y_test
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m ## Step 3: Evaluate Model Performance
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m *Before deploying any risk model, you need to understand how well it discriminates (AUC), how well it's calibrated (do patients scored at 0.7 actually have ~70% event rates?), and whether it performs equitably across subgroups. This step covers discrimination. Calibration and fairness audits are noted in the gap-to-production section.*
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m def evaluate_model(model, X_test: pd.DataFrame, y_test: pd.Series) -> dict:
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m     Evaluate the trained model on held-out test data.
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m     Key metrics for ED prediction:
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m     - AUC-ROC: Overall discrimination. How well does the model rank patients?
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m       An AUC of 0.75+ is typical for ED prediction models in the literature.
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m     - Average Precision (AUC-PR): More informative than AUC-ROC when the
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m       outcome is imbalanced (which it always is for ED visits).
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m     - Precision at the high-risk threshold: Of patients we flag for outreach,
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m       what fraction actually visits the ED? This drives care manager workload.
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m         model: Trained GradientBoostingClassifier.
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m         X_test: Test features.
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m         y_test: Test outcomes.
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m         Dictionary of evaluation metrics.
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m     # Get predicted probabilities (not binary predictions).
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m     # For risk scoring, we always want probabilities. Binary yes/no loses
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m     # the information about HOW high-risk someone is.
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m     y_prob = model.predict_proba(X_test)[:, 1]
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m     # AUC-ROC: probability that a randomly chosen positive patient is scored
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m     # higher than a randomly chosen negative patient.
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m     auc_roc = roc_auc_score(y_test, y_prob)
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m     # Average precision: area under the precision-recall curve.
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m     # More sensitive to performance on the minority class (ED visitors).
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m     avg_precision = average_precision_score(y_test, y_prob)
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m     # Apply our operational thresholds to see tier distribution
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m     high_risk_count = (y_prob >= HIGH_RISK_THRESHOLD).sum()
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m     medium_risk_count = ((y_prob >= MEDIUM_RISK_THRESHOLD) & (y_prob < HIGH_RISK_THRESHOLD)).sum()
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m     low_risk_count = (y_prob < MEDIUM_RISK_THRESHOLD).sum()
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m     # Precision at high-risk threshold: of patients we'd call, how many
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m     # actually have an ED visit? This is the "positive predictive value"
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m     # that care managers care about most.
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m     high_risk_mask = y_prob >= HIGH_RISK_THRESHOLD
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m     if high_risk_mask.sum() > 0:
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m         precision_at_high = y_test[high_risk_mask].mean()
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m         precision_at_high = 0.0
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m     # Feature importance: which factors drive the model's predictions?
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m     # This is critical for clinical buy-in. If the model says "prior ED visits"
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m     # is the top factor, clinicians nod. If it says "distance to ED" is #1,
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m     # they'll (rightly) question whether it's capturing access vs. acuity.
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m     importances = pd.Series(
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m         model.feature_importances_, index=FEATURE_COLUMNS
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m     ).sort_values(ascending=False)
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m     metrics = {
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m         "auc_roc": round(auc_roc, 4),
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m         "average_precision": round(avg_precision, 4),
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m         "precision_at_high_risk": round(precision_at_high, 4),
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m         "high_risk_count": int(high_risk_count),
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m         "medium_risk_count": int(medium_risk_count),
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m         "low_risk_count": int(low_risk_count),
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m         "top_features": importances.head(5).to_dict(),
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m     logger.info("AUC-ROC: %.4f", auc_roc)
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m     logger.info("Average Precision: %.4f", avg_precision)
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m     logger.info("Precision at high-risk threshold: %.4f", precision_at_high)
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m     logger.info("Risk tier distribution: %d high / %d medium / %d low",
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m                 high_risk_count, medium_risk_count, low_risk_count)
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m     logger.info("Top 5 features: %s", importances.head(5).to_dict())
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m     return metrics
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m ## Step 4: Score New Patients
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m *This is the inference step that runs on a schedule (daily or weekly). It takes the trained model and scores the current patient population, assigning each patient a risk tier and generating an outreach list for care management.*
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m def score_patients(model, patients_df: pd.DataFrame) -> pd.DataFrame:
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m     Score a batch of patients and assign risk tiers.
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m     In production, this runs as a scheduled job (daily or weekly). It pulls
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m     the latest feature values from your feature store, runs inference, and
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m     writes results to a table that the care management platform reads from.
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m     The output is an actionable worklist: patient ID, risk score, risk tier,
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m     and the top contributing factors for that specific patient.
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m         model: Trained model (or SageMaker endpoint in production).
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m         patients_df: DataFrame with current feature values for each patient.
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m         DataFrame with risk scores, tiers, and top contributing factors.
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m     X = patients_df[FEATURE_COLUMNS]
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m     # Get probability of ED visit in next 30 days
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m     risk_scores = model.predict_proba(X)[:, 1]
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m     # Assign risk tiers based on operational thresholds
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m     def assign_tier(score):
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m         if score >= HIGH_RISK_THRESHOLD:
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m             return "HIGH"
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m         elif score >= MEDIUM_RISK_THRESHOLD:
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m             return "MEDIUM"
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m         return "LOW"
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m     results = patients_df[["patient_id"]].copy()
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m     results["risk_score"] = risk_scores.round(4)
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m     results["risk_tier"] = [assign_tier(s) for s in risk_scores]
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m     results["scored_at"] = datetime.utcnow().isoformat() + "Z"
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m     results["prediction_window_days"] = PREDICTION_WINDOW_DAYS
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m     # For each patient, identify the top 3 contributing factors.
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m     # This uses a simple approach: feature value * feature importance.
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m     # In production, you'd use SHAP values for proper per-patient explanations.
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m     feature_importances = model.feature_importances_
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m     for idx in results.index:
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m         patient_features = X.iloc[idx].values
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m         contributions = patient_features * feature_importances
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m         top_indices = np.argsort(contributions)[-3:][::-1]
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m         top_factors = [FEATURE_COLUMNS[i] for i in top_indices]
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m         results.at[idx, "top_factors"] = ", ".join(top_factors)
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m     return results
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m ## Step 5: Store Risk Scores (DynamoDB)
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m *Risk scores need to be queryable by patient ID (for point-of-care alerts) and by risk tier (for generating outreach worklists). DynamoDB handles both access patterns with a partition key on patient_id and a GSI on risk_tier.*
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m # Table name. In production, this comes from environment variables or
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m # SSM Parameter Store, not hardcoded strings.
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m RISK_SCORES_TABLE = "ed-risk-scores"
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m def store_risk_scores(scored_df: pd.DataFrame) -> int:
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m     Write patient risk scores to DynamoDB for downstream consumption.
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m     Two consumers read this table:
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m     1. Care management platform: queries by risk_tier (via GSI) to build
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m        daily outreach worklists.
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m     2. EHR integration: queries by patient_id to show risk badges at the
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m        point of care (e.g., a red flag on the patient chart).
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m         scored_df: DataFrame from score_patients() with risk scores and tiers.
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m         Number of records written.
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m     table = dynamodb.Table(RISK_SCORES_TABLE)
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m     records_written = 0
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m     # Batch write for efficiency. DynamoDB batch_writer handles chunking
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m     # into groups of 25 and retries for unprocessed items.
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m     with table.batch_writer() as batch:
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m         for _, row in scored_df.iterrows():
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m             # Only store medium and high risk patients. Low-risk patients
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m             # don't need to be in the outreach table (saves cost and keeps
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m             # the worklist focused).
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m             if row["risk_tier"] == "LOW":
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m                 continue
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m             item = {
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m                 "patient_id": row["patient_id"],
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m                 "risk_score": Decimal(str(row["risk_score"])),
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m                 "risk_tier": row["risk_tier"],
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m                 "scored_at": row["scored_at"],
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m                 "prediction_window_days": PREDICTION_WINDOW_DAYS,
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m                 "top_factors": row["top_factors"],
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m                 # TTL: auto-expire records after the prediction window passes.
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m                 # No point keeping a "30-day risk" score that's 45 days old.
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m                 "ttl": int(
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m                     (datetime.utcnow() + timedelta(days=PREDICTION_WINDOW_DAYS)).timestamp()
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m                 ),
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m             batch.put_item(Item=item)
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m             records_written += 1
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m     logger.info("Wrote %d risk scores to DynamoDB (medium + high risk only)",
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m                 records_written)
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m     return records_written
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m ## Step 6: Upload Training Data to S3 (for SageMaker)
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m *When you're ready to move from local scikit-learn to SageMaker training (larger datasets, GPU instances, automated retraining), you'll need your data in S3. This step shows the handoff.*
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m import io
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m s3_client = boto3.client("s3", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m DATA_BUCKET = "my-healthcare-ml-data"
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m MODEL_PREFIX = "ed-prediction/v1"
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m def upload_training_data(df: pd.DataFrame, bucket: str = DATA_BUCKET) -> str:
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m     Upload training data to S3 in CSV format for SageMaker consumption.
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m     SageMaker's built-in XGBoost algorithm expects CSV with the target column
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m     first and no header row. We format accordingly.
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m         df: Training DataFrame with features and outcome.
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m         bucket: S3 bucket for ML artifacts.
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m         S3 URI of the uploaded training data.
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m     # SageMaker XGBoost expects: target_column, feature_1, feature_2, ...
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m     # No header row. Target must be first column.
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m     columns_ordered = ["ed_visit_next_30d"] + FEATURE_COLUMNS
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m     training_data = df[columns_ordered]
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m     # Write to CSV in memory, then upload
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m     csv_buffer = io.StringIO()
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m     training_data.to_csv(csv_buffer, index=False, header=False)
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m     s3_key = f"{MODEL_PREFIX}/train/training_data.csv"
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m     s3_client.put_object(
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m         Bucket=bucket,
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m         Key=s3_key,
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m         Body=csv_buffer.getvalue().encode("utf-8"),
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m         ServerSideEncryption="aws:kms",  # encrypt at rest with KMS
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m     s3_uri = f"s3://{bucket}/{s3_key}"
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m     logger.info("Uploaded training data to %s", s3_uri)
