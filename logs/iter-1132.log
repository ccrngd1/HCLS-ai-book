[0m[49m[38;5;10m+     770[0m:[38;5;10m[49m     # DynamoDB stores numbers as Decimal. Convert to float for numpy compatibility.
[0m[49m[38;5;10m+     771[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     772[0m:[38;5;10m[49m         "glucose_current": float(item.get("glucose_current", 0)),
[0m[49m[38;5;10m+     773[0m:[38;5;10m[49m         "glucose_prev_1": float(item.get("glucose_prev_1", 0)),
[0m[49m[38;5;10m+     774[0m:[38;5;10m[49m         "glucose_prev_2": float(item.get("glucose_prev_2", 0)),
[0m[49m[38;5;10m+     775[0m:[38;5;10m[49m         "glucose_velocity": float(item.get("glucose_velocity", 0)),
[0m[49m[38;5;10m+     776[0m:[38;5;10m[49m         "insulin_on_board": float(item.get("insulin_on_board", 0)),
[0m[49m[38;5;10m+     777[0m:[38;5;10m[49m         "insulin_infusion_rate": float(item.get("insulin_infusion_rate", 0)),
[0m[49m[38;5;10m+     778[0m:[38;5;10m[49m         "nutrition_rate": float(item.get("nutrition_rate", 0)),
[0m[49m[38;5;10m+     779[0m:[38;5;10m[49m         "vasopressor_dose": float(item.get("vasopressor_dose", 0)),
[0m[49m[38;5;10m+     780[0m:[38;5;10m[49m         "steroid_flag": float(item.get("steroid_flag", 0)),
[0m[49m[38;5;10m+     781[0m:[38;5;10m[49m         "creatinine": float(item.get("creatinine", 1.0)),
[0m[49m[38;5;10m+     782[0m:[38;5;10m[49m         "bmi": float(item.get("bmi", 25)),
[0m[49m[38;5;10m+     783[0m:[38;5;10m[49m         "apache_score": float(item.get("apache_score", 15)),
[0m[49m[38;5;10m+     784[0m:[38;5;10m[49m         "previous_dose": float(item.get("previous_dose", 0)),
[0m[49m[38;5;10m+     785[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     786[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     787[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     788[0m:[38;5;10m[49m def update_patient_state(patient_id: str, new_glucose: float, patient_data: dict):
[0m[49m[38;5;10m+     789[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     790[0m:[38;5;10m[49m     Update the patient's state in DynamoDB with the new glucose reading.
[0m[49m[38;5;10m+     791[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     792[0m:[38;5;10m[49m     Shifts the glucose history forward and recomputes velocity.
[0m[49m[38;5;10m+     793[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     794[0m:[38;5;10m[49m     # Shift history: current becomes prev_1, prev_1 becomes prev_2
[0m[49m[38;5;10m+     795[0m:[38;5;10m[49m     prev_1 = patient_data.get("glucose_current", new_glucose)
[0m[49m[38;5;10m+     796[0m:[38;5;10m[49m     prev_2 = patient_data.get("glucose_prev_1", prev_1)
[0m[49m[38;5;10m+     797[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     798[0m:[38;5;10m[49m     # Velocity: rate of change in mg/dL per hour (assuming 4-hour intervals)
[0m[49m[38;5;10m+     799[0m:[38;5;10m[49m     velocity = (new_glucose - prev_1) / 4.0 if prev_1 > 0 else 0.0
[0m[49m[38;5;10m+     800[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     801[0m:[38;5;10m[49m     state_table.put_item(
[0m[49m[38;5;10m+     802[0m:[38;5;10m[49m         Item={
[0m[49m[38;5;10m+     803[0m:[38;5;10m[49m             "patient_id": patient_id,
[0m[49m[38;5;10m+     804[0m:[38;5;10m[49m             "glucose_current": Decimal(str(round(new_glucose, 1))),
[0m[49m[38;5;10m+     805[0m:[38;5;10m[49m             "glucose_prev_1": Decimal(str(round(prev_1, 1))),
[0m[49m[38;5;10m+     806[0m:[38;5;10m[49m             "glucose_prev_2": Decimal(str(round(prev_2, 1))),
[0m[49m[38;5;10m+     807[0m:[38;5;10m[49m             "glucose_velocity": Decimal(str(round(velocity, 2))),
[0m[49m[38;5;10m+     808[0m:[38;5;10m[49m             "insulin_on_board": Decimal(str(round(
[0m[49m[38;5;10m+     809[0m:[38;5;10m[49m                 patient_data.get("insulin_on_board", 0), 1
[0m[49m[38;5;10m+     810[0m:[38;5;10m[49m             ))),
[0m[49m[38;5;10m+     811[0m:[38;5;10m[49m             "insulin_infusion_rate": Decimal(str(round(
[0m[49m[38;5;10m+     812[0m:[38;5;10m[49m                 patient_data.get("insulin_infusion_rate", 0), 1
[0m[49m[38;5;10m+     813[0m:[38;5;10m[49m             ))),
[0m[49m[38;5;10m+     814[0m:[38;5;10m[49m             "nutrition_rate": Decimal(str(round(
[0m[49m[38;5;10m+     815[0m:[38;5;10m[49m                 patient_data.get("nutrition_rate", 0), 1
[0m[49m[38;5;10m+     816[0m:[38;5;10m[49m             ))),
[0m[49m[38;5;10m+     817[0m:[38;5;10m[49m             "vasopressor_dose": Decimal(str(round(
[0m[49m[38;5;10m+     818[0m:[38;5;10m[49m                 patient_data.get("vasopressor_dose", 0), 3
[0m[49m[38;5;10m+     819[0m:[38;5;10m[49m             ))),
[0m[49m[38;5;10m+     820[0m:[38;5;10m[49m             "steroid_flag": Decimal(str(int(patient_data.get("steroid_flag", 0)))),
[0m[49m[38;5;10m+     821[0m:[38;5;10m[49m             "creatinine": Decimal(str(round(patient_data.get("creatinine", 1.0), 1))),
[0m[49m[38;5;10m+     822[0m:[38;5;10m[49m             "bmi": Decimal(str(round(patient_data.get("bmi", 25), 1))),
[0m[49m[38;5;10m+     823[0m:[38;5;10m[49m             "apache_score": Decimal(str(int(patient_data.get("apache_score", 15)))),
[0m[49m[38;5;10m+     824[0m:[38;5;10m[49m             "previous_dose": Decimal(str(round(
[0m[49m[38;5;10m+     825[0m:[38;5;10m[49m                 patient_data.get("previous_dose", 0), 1
[0m[49m[38;5;10m+     826[0m:[38;5;10m[49m             ))),
[0m[49m[38;5;10m+     827[0m:[38;5;10m[49m             "updated_at": Decimal(str(int(time.time()))),
[0m[49m[38;5;10m+     828[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+     829[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     830[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     831[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     832[0m:[38;5;10m[49m def get_policy_recommendation(state_vector: np.ndarray) -> dict:
[0m[49m[38;5;10m+     833[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     834[0m:[38;5;10m[49m     Call the SageMaker endpoint to get the RL policy's recommended dose.
[0m[49m[38;5;10m+     835[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     836[0m:[38;5;10m[49m     The endpoint hosts the trained CQL model. It takes a state vector and
[0m[49m[38;5;10m+     837[0m:[38;5;10m[49m     returns Q-values for each action, from which we pick the best.
[0m[49m[38;5;10m+     838[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     839[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     840[0m:[38;5;10m[49m         state_vector: Normalized state array from construct_state_vector.
[0m[49m[38;5;10m+     841[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     842[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     843[0m:[38;5;10m[49m         Dict with recommended_dose (units) and confidence score.
[0m[49m[38;5;10m+     844[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     845[0m:[38;5;10m[49m     payload = json.dumps({"state": state_vector.tolist()})
[0m[49m[38;5;10m+     846[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     847[0m:[38;5;10m[49m     response = sagemaker_runtime.invoke_endpoint(
[0m[49m[38;5;10m+     848[0m:[38;5;10m[49m         EndpointName=SAGEMAKER_ENDPOINT,
[0m[49m[38;5;10m+     849[0m:[38;5;10m[49m         ContentType="application/json",
[0m[49m[38;5;10m+     850[0m:[38;5;10m[49m         Body=payload,
[0m[49m[38;5;10m+     851[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     852[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     853[0m:[38;5;10m[49m     result = json.loads(response["Body"].read().decode("utf-8"))
[0m[49m[38;5;10m+     854[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     855[0m:[38;5;10m[49m     # The endpoint returns Q-values for each discrete action
[0m[49m[38;5;10m+     856[0m:[38;5;10m[49m     q_values = np.array(result["q_values"])
[0m[49m[38;5;10m+     857[0m:[38;5;10m[49m     best_action_idx = int(np.argmax(q_values))
[0m[49m[38;5;10m+     858[0m:[38;5;10m[49m     recommended_dose = ACTION_SPACE[best_action_idx]
[0m[49m[38;5;10m+     859[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     860[0m:[38;5;10m[49m     # Confidence: how much better is the best action vs. the second best?
[0m[49m[38;5;10m+     861[0m:[38;5;10m[49m     # Large gap = high confidence. Small gap = uncertain.
[0m[49m[38;5;10m+     862[0m:[38;5;10m[49m     sorted_q = np.sort(q_values)[::-1]
[0m[49m[38;5;10m+     863[0m:[38;5;10m[49m     if len(sorted_q) > 1 and sorted_q[0] != 0:
[0m[49m[38;5;10m+     864[0m:[38;5;10m[49m         confidence = min(1.0, (sorted_q[0] - sorted_q[1]) / abs(sorted_q[0]))
[0m[49m[38;5;10m+     865[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+     866[0m:[38;5;10m[49m         confidence = 0.5
[0m[49m[38;5;10m+     867[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     868[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     869[0m:[38;5;10m[49m         "recommended_dose": recommended_dose,
[0m[49m[38;5;10m+     870[0m:[38;5;10m[49m         "action_index": best_action_idx,
[0m[49m[38;5;10m+     871[0m:[38;5;10m[49m         "confidence": round(confidence, 3),
[0m[49m[38;5;10m+     872[0m:[38;5;10m[49m         "q_values": q_values.tolist(),
[0m[49m[38;5;10m+     873[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     874[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     875[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     876[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     877[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     878[0m:[38;5;10m[49m ## Full Pipeline: Generate Recommendation
[0m[49m[38;5;10m+     879[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     880[0m:[38;5;10m[49m This assembles all the steps into a single callable function. In production, this would be the Lambda handler invoked when a new glucose reading arrives from the EHR integration.
[0m[49m[38;5;10m+     881[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     882[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     883[0m:[38;5;10m[49m def generate_insulin_recommendation(patient_id: str, new_glucose: float) -> dict:
[0m[49m[38;5;10m+     884[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     885[0m:[38;5;10m[49m     End-to-end pipeline: new glucose reading in, insulin recommendation out.
[0m[49m[38;5;10m+     886[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     887[0m:[38;5;10m[49m     This is the function that gets called when a nurse enters a new glucose
[0m[49m[38;5;10m+     888[0m:[38;5;10m[49m     measurement. It:
[0m[49m[38;5;10m+     889[0m:[38;5;10m[49m     1. Fetches the patient's recent history
[0m[49m[38;5;10m+     890[0m:[38;5;10m[49m     2. Updates state with the new reading
[0m[49m[38;5;10m+     891[0m:[38;5;10m[49m     3. Constructs the RL state vector
[0m[49m[38;5;10m+     892[0m:[38;5;10m[49m     4. Gets the policy's recommendation
[0m[49m[38;5;10m+     893[0m:[38;5;10m[49m     5. Applies safety constraints
[0m[49m[38;5;10m+     894[0m:[38;5;10m[49m     6. Returns a recommendation for clinician review
[0m[49m[38;5;10m+     895[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     896[0m:[38;5;10m[49m     The clinician always has the final say. This is decision support, not
[0m[49m[38;5;10m+     897[0m:[38;5;10m[49m     autonomous control.
[0m[49m[38;5;10m+     898[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     899[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+     900[0m:[38;5;10m[49m         patient_id: Unique patient identifier.
[0m[49m[38;5;10m+     901[0m:[38;5;10m[49m         new_glucose: The new glucose reading in mg/dL.
[0m[49m[38;5;10m+     902[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     903[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+     904[0m:[38;5;10m[49m         Dict with the recommendation, reasoning, and safety information.
[0m[49m[38;5;10m+     905[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     906[0m:[38;5;10m[49m     print(f"\n{'='*60}")
[0m[49m[38;5;10m+     907[0m:[38;5;10m[49m     print(f"GLUCOSE CONTROL RL: New reading for {patient_id}")
[0m[49m[38;5;10m+     908[0m:[38;5;10m[49m     print(f"{'='*60}")
[0m[49m[38;5;10m+     909[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     910[0m:[38;5;10m[49m     # Step 1: Fetch current patient state
[0m[49m[38;5;10m+     911[0m:[38;5;10m[49m     print("\n[1/5] Fetching patient state from DynamoDB...")
[0m[49m[38;5;10m+     912[0m:[38;5;10m[49m     patient_data = fetch_patient_state(patient_id)
[0m[49m[38;5;10m+     913[0m:[38;5;10m[49m     if not patient_data:
[0m[49m[38;5;10m+     914[0m:[38;5;10m[49m         print("  WARNING: No prior state found. Using defaults.")
[0m[49m[38;5;10m+     915[0m:[38;5;10m[49m         patient_data = {"glucose_current": new_glucose, "previous_dose": 0}
[0m[49m[38;5;10m+     916[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     917[0m:[38;5;10m[49m     # Step 2: Update state with new reading
[0m[49m[38;5;10m+     918[0m:[38;5;10m[49m     print(f"[2/5] Updating state: new glucose = {new_glucose} mg/dL")
[0m[49m[38;5;10m+     919[0m:[38;5;10m[49m     update_patient_state(patient_id, new_glucose, patient_data)
[0m[49m[38;5;10m+     920[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     921[0m:[38;5;10m[49m     # Refresh patient_data with the new glucose as current
[0m[49m[38;5;10m+     922[0m:[38;5;10m[49m     patient_data["glucose_prev_2"] = patient_data.get("glucose_prev_1", new_glucose)
[0m[49m[38;5;10m+     923[0m:[38;5;10m[49m     patient_data["glucose_prev_1"] = patient_data.get("glucose_current", new_glucose)
[0m[49m[38;5;10m+     924[0m:[38;5;10m[49m     patient_data["glucose_current"] = new_glucose
[0m[49m[38;5;10m+     925[0m:[38;5;10m[49m     patient_data["glucose_velocity"] = (
[0m[49m[38;5;10m+     926[0m:[38;5;10m[49m         (new_glucose - patient_data["glucose_prev_1"]) / 4.0
[0m[49m[38;5;10m+     927[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+     928[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     929[0m:[38;5;10m[49m     # Step 3: Construct state vector
[0m[49m[38;5;10m+     930[0m:[38;5;10m[49m     print("[3/5] Constructing state vector...")
[0m[49m[38;5;10m+     931[0m:[38;5;10m[49m     state_vector = construct_state_vector(patient_data)
[0m[49m[38;5;10m+     932[0m:[38;5;10m[49m     print(f"  State vector (first 4 features): {state_vector[:4]}")
[0m[49m[38;5;10m+     933[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     934[0m:[38;5;10m[49m     # Step 4: Get policy recommendation
[0m[49m[38;5;10m+     935[0m:[38;5;10m[49m     print("[4/5] Querying RL policy endpoint...")
[0m[49m[38;5;10m+     936[0m:[38;5;10m[49m     policy_result = get_policy_recommendation(state_vector)
[0m[49m[38;5;10m+     937[0m:[38;5;10m[49m     raw_dose = policy_result["recommended_dose"]
[0m[49m[38;5;10m+     938[0m:[38;5;10m[49m     print(f"  Raw recommendation: {raw_dose} units (confidence: {policy_result['confidence']})")
[0m[49m[38;5;10m+     939[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     940[0m:[38;5;10m[49m     # Step 5: Apply safety constraints
[0m[49m[38;5;10m+     941[0m:[38;5;10m[49m     print("[5/5] Applying safety constraints...")
[0m[49m[38;5;10m+     942[0m:[38;5;10m[49m     previous_dose = patient_data.get("previous_dose", 0)
[0m[49m[38;5;10m+     943[0m:[38;5;10m[49m     safe_result = apply_safety_constraints(raw_dose, patient_data, previous_dose)
[0m[49m[38;5;10m+     944[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     945[0m:[38;5;10m[49m     if safe_result["constraints_activated"]:
[0m[49m[38;5;10m+     946[0m:[38;5;10m[49m         for constraint in safe_result["constraints_activated"]:
[0m[49m[38;5;10m+     947[0m:[38;5;10m[49m             print(f"  CONSTRAINT: {constraint}")
[0m[49m[38;5;10m+     948[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+     949[0m:[38;5;10m[49m         print("  No constraints activated.")
[0m[49m[38;5;10m+     950[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     951[0m:[38;5;10m[49m     final_dose = safe_result["final_dose"]
[0m[49m[38;5;10m+     952[0m:[38;5;10m[49m     print(f"\n  FINAL RECOMMENDATION: {final_dose} units insulin")
[0m[49m[38;5;10m+     953[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     954[0m:[38;5;10m[49m     # Package the recommendation
[0m[49m[38;5;10m+     955[0m:[38;5;10m[49m     recommendation = {
[0m[49m[38;5;10m+     956[0m:[38;5;10m[49m         "patient_id": patient_id,
[0m[49m[38;5;10m+     957[0m:[38;5;10m[49m         "timestamp": int(time.time()),
[0m[49m[38;5;10m+     958[0m:[38;5;10m[49m         "glucose_reading": new_glucose,
[0m[49m[38;5;10m+     959[0m:[38;5;10m[49m         "recommended_dose": final_dose,
[0m[49m[38;5;10m+     960[0m:[38;5;10m[49m         "dose_units": "units insulin (regular)",
[0m[49m[38;5;10m+     961[0m:[38;5;10m[49m         "confidence": policy_result["confidence"],
[0m[49m[38;5;10m+     962[0m:[38;5;10m[49m         "reasoning": {
[0m[49m[38;5;10m+     963[0m:[38;5;10m[49m             "current_glucose": new_glucose,
[0m[49m[38;5;10m+     964[0m:[38;5;10m[49m             "glucose_trend": round(patient_data["glucose_velocity"], 1),
[0m[49m[38;5;10m+     965[0m:[38;5;10m[49m             "insulin_on_board": patient_data.get("insulin_on_board", 0),
[0m[49m[38;5;10m+     966[0m:[38;5;10m[49m             "raw_policy_dose": raw_dose,
[0m[49m[38;5;10m+     967[0m:[38;5;10m[49m             "constraints_activated": safe_result["constraints_activated"],
[0m[49m[38;5;10m+     968[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+     969[0m:[38;5;10m[49m         "clinician_action": "PENDING",
[0m[49m[38;5;10m+     970[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     971[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     972[0m:[38;5;10m[49m     print(f"\n  Recommendation packaged. Awaiting clinician decision.")
[0m[49m[38;5;10m+     973[0m:[38;5;10m[49m     print(f"{'='*60}\n")
[0m[49m[38;5;10m+     974[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     975[0m:[38;5;10m[49m     return recommendation
[0m[49m[38;5;10m+     976[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     977[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     978[0m:[38;5;10m[49m # --- Example usage ---
[0m[49m[38;5;10m+     979[0m:[38;5;10m[49m if __name__ == "__main__":
[0m[49m[38;5;10m+     980[0m:[38;5;10m[49m     # Simulate a sequence of glucose readings for a patient
[0m[49m[38;5;10m+     981[0m:[38;5;10m[49m     # In production, each call would be triggered by an EHR event.
[0m[49m[38;5;10m+     982[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+     983[0m:[38;5;10m[49m     print("DEMO: Simulating glucose control recommendations")
[0m[49m[38;5;10m+     984[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+     985[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     986[0m:[38;5;10m[49m     # Note: This will fail without actual AWS resources configured.
[0m[49m[38;5;10m+     987[0m:[38;5;10m[49m     # It's here to show the calling pattern.
[0m[49m[38;5;10m+     988[0m:[38;5;10m[49m     try:
[0m[49m[38;5;10m+     989[0m:[38;5;10m[49m         result = generate_insulin_recommendation("ICU-2026-04821", 195.0)
[0m[49m[38;5;10m+     990[0m:[38;5;10m[49m         print(json.dumps(result, indent=2, default=str))
[0m[49m[38;5;10m+     991[0m:[38;5;10m[49m     except Exception as e:
[0m[49m[38;5;10m+     992[0m:[38;5;10m[49m         print(f"\nExpected error (no AWS resources): {e}")
[0m[49m[38;5;10m+     993[0m:[38;5;10m[49m         print("In production, this connects to real DynamoDB and SageMaker endpoints.")
[0m[49m[38;5;10m+     994[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     995[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     996[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     997[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     998[0m:[38;5;10m[49m ## Gap to Production
[0m[49m[38;5;10m+     999[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1000[0m:[38;5;10m[49m This example demonstrates the shape of an RL-based glucose control system. Here's the distance between this code and something you'd deploy in an ICU:
[0m[49m[38;5;10m+    1001[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1002[0m:[38;5;10m[49m **Data pipeline (the real 70% of the work):**
[0m[49m[38;5;10m+    1003[0m:[38;5;10m[49m - EHR integration via HL7 FHIR or proprietary APIs to pull glucose, insulin, nutrition, and medication data in real time
[0m[49m[38;5;10m+    1004[0m:[38;5;10m[49m - Temporal alignment of irregularly-sampled clinical data into consistent decision intervals
[0m[49m[38;5;10m+    1005[0m:[38;5;10m[49m - Handling of missing data (forward-fill, learned imputation, staleness flags)
[0m[49m[38;5;10m+    1006[0m:[38;5;10m[49m - Data validation: reject physiologically impossible values (glucose of 5000 is a meter error, not a reading)
[0m[49m[38;5;10m+    1007[0m:[38;5;10m[49m - De-identification pipeline for training data; BAA-covered access for production inference
[0m[49m[38;5;10m+    1008[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1009[0m:[38;5;10m[49m **Model training:**
[0m[49m[38;5;10m+    1010[0m:[38;5;10m[49m - Replace the tabular Q-function with a neural network (2-layer MLP with 256 hidden units is standard)
[0m[49m[38;5;10m+    1011[0m:[38;5;10m[49m - Use a proper CQL implementation (e.g., d3rlpy library or custom PyTorch)
[0m[49m[38;5;10m+    1012[0m:[38;5;10m[49m - Hyperparameter tuning: CQL alpha, discount factor, network architecture, batch size
[0m[49m[38;5;10m+    1013[0m:[38;5;10m[49m - Train on thousands of ICU stays (this example works with toy data)
[0m[49m[38;5;10m+    1014[0m:[38;5;10m[49m - Cross-validation across patient subpopulations (surgical, medical, cardiac)
[0m[49m[38;5;10m+    1015[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1016[0m:[38;5;10m[49m **Safety and validation:**
[0m[49m[38;5;10m+    1017[0m:[38;5;10m[49m - Extensive off-policy evaluation on held-out data with confidence intervals
[0m[49m[38;5;10m+    1018[0m:[38;5;10m[49m - Physiological simulator testing (glucose-insulin dynamics models)
[0m[49m[38;5;10m+    1019[0m:[38;5;10m[49m - Comparison against existing sliding scale protocols on retrospective data
[0m[49m[38;5;10m+    1020[0m:[38;5;10m[49m - Formal safety analysis: worst-case hypoglycemia rates under the learned policy
[0m[49m[38;5;10m+    1021[0m:[38;5;10m[49m - IRB approval for any prospective evaluation
[0m[49m[38;5;10m+    1022[0m:[38;5;10m[49m - FDA regulatory pathway assessment (likely Class II medical device)
[0m[49m[38;5;10m+    1023[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1024[0m:[38;5;10m[49m **Deployment:**
[0m[49m[38;5;10m+    1025[0m:[38;5;10m[49m - Shadow mode: run the system in parallel with existing protocols for months, logging recommendations without displaying them, to validate against actual clinician decisions
[0m[49m[38;5;10m+    1026[0m:[38;5;10m[49m - Clinician education and trust-building before any recommendations are shown
[0m[49m[38;5;10m+    1027[0m:[38;5;10m[49m - Gradual rollout: start with a single ICU, expand after demonstrating safety
[0m[49m[38;5;10m+    1028[0m:[38;5;10m[49m - Real-time monitoring: alert on recommendation patterns that deviate from expected distributions
[0m[49m[38;5;10m+    1029[0m:[38;5;10m[49m - Drift detection: retrain when patient population or clinical practice changes
[0m[49m[38;5;10m+    1030[0m:[38;5;10m[49m - Override logging and analysis: learn from clinician disagreements
[0m[49m[38;5;10m+    1031[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1032[0m:[38;5;10m[49m **Infrastructure hardening:**
[0m[49m[38;5;10m+    1033[0m:[38;5;10m[49m - Error handling and retries for all AWS API calls (already partially shown)
[0m[49m[38;5;10m+    1034[0m:[38;5;10m[49m - Input validation: reject malformed glucose readings, out-of-range values
[0m[49m[38;5;10m+    1035[0m:[38;5;10m[49m - Structured JSON logging with correlation IDs (never log PHI values)
[0m[49m[38;5;10m+    1036[0m:[38;5;10m[49m - IAM least-privilege: separate roles for training vs. inference vs. state management
[0m[49m[38;5;10m+    1037[0m:[38;5;10m[49m - VPC with VPC endpoints for S3, DynamoDB, SageMaker Runtime, and CloudWatch
[0m[49m[38;5;10m+    1038[0m:[38;5;10m[49m - KMS customer-managed keys for all PHI-containing resources
[0m[49m[38;5;10m+    1039[0m:[38;5;10m[49m - DynamoDB point-in-time recovery and S3 versioning for audit trail
[0m[49m[38;5;10m+    1040[0m:[38;5;10m[49m - Load testing: ensure the inference path completes within the clinical workflow timeout (< 5 seconds)
[0m[49m[38;5;10m+    1041[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1042[0m:[38;5;10m[49m **The honest gap:** This example is maybe 5% of a production system. The RL algorithm is the intellectually interesting part, but the data pipeline, safety validation, regulatory pathway, and clinician trust-building are what determine whether this ever helps a patient. Plan for 12-18 months from "working prototype" to "shadow mode in one ICU."
[0m[49m[38;5;10m+    1043[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1044[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    1045[0m:[38;5;10m[49m 
