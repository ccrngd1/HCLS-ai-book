[0m[49m[38;5;10m+      18[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      19[0m:[38;5;10m[49m ## Config and Constants
[0m[49m[38;5;10m+      20[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      21[0m:[38;5;10m[49m Before the logic, here's the configuration that defines the clinical domain. These constants encode medical knowledge about ICU glucose management: what glucose ranges are safe, how to score outcomes, and what actions are never acceptable. In a real system, these would be developed with intensivists and endocrinologists, validated against clinical guidelines, and reviewed by your institution's pharmacy and therapeutics committee.
[0m[49m[38;5;10m+      22[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      23[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+      24[0m:[38;5;10m[49m import numpy as np
[0m[49m[38;5;10m+      25[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+      26[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+      27[0m:[38;5;10m[49m import time
[0m[49m[38;5;10m+      28[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+      29[0m:[38;5;10m[49m from typing import Optional
[0m[49m[38;5;10m+      30[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      31[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+      32[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+      33[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      34[0m:[38;5;10m[49m # Structured logging. In production, use JSON format for CloudWatch Logs Insights.
[0m[49m[38;5;10m+      35[0m:[38;5;10m[49m # Never log actual patient identifiers or PHI values.
[0m[49m[38;5;10m+      36[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+      37[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+      38[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      39[0m:[38;5;10m[49m # Retry config for AWS calls. Adaptive mode handles throttling gracefully.
[0m[49m[38;5;10m+      40[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+      41[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      42[0m:[38;5;10m[49m # --- Glucose Target Range ---
[0m[49m[38;5;10m+      43[0m:[38;5;10m[49m # These define what "good control" means. The target range is 80-180 mg/dL,
[0m[49m[38;5;10m+      44[0m:[38;5;10m[49m # with the sweet spot at 120-140 mg/dL. These numbers come from the NICE-SUGAR
[0m[49m[38;5;10m+      45[0m:[38;5;10m[49m # trial and subsequent guidelines that backed off from aggressive tight control
[0m[49m[38;5;10m+      46[0m:[38;5;10m[49m # (which caused too much hypoglycemia) toward a more moderate target.
[0m[49m[38;5;10m+      47[0m:[38;5;10m[49m GLUCOSE_TARGET_LOW = 80       # mg/dL: below this is concerning
[0m[49m[38;5;10m+      48[0m:[38;5;10m[49m GLUCOSE_TARGET_HIGH = 180     # mg/dL: above this is hyperglycemic
[0m[49m[38;5;10m+      49[0m:[38;5;10m[49m GLUCOSE_SWEET_SPOT = 130      # mg/dL: ideal center of target range
[0m[49m[38;5;10m+      50[0m:[38;5;10m[49m GLUCOSE_HYPO_THRESHOLD = 70   # mg/dL: below this is hypoglycemia (dangerous)
[0m[49m[38;5;10m+      51[0m:[38;5;10m[49m GLUCOSE_SEVERE_HYPO = 40      # mg/dL: below this is severe hypoglycemia (life-threatening)
[0m[49m[38;5;10m+      52[0m:[38;5;10m[49m GLUCOSE_SEVERE_HYPER = 250    # mg/dL: above this risks osmotic complications
[0m[49m[38;5;10m+      53[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      54[0m:[38;5;10m[49m # --- Action Space ---
[0m[49m[38;5;10m+      55[0m:[38;5;10m[49m # Discretized insulin doses in units. The agent picks one of these.
[0m[49m[38;5;10m+      56[0m:[38;5;10m[49m # In practice, you might use a continuous action space (actor-critic methods),
[0m[49m[38;5;10m+      57[0m:[38;5;10m[49m # but discrete actions are simpler to implement and easier to constrain.
[0m[49m[38;5;10m+      58[0m:[38;5;10m[49m # These bins cover the typical range of subcutaneous insulin doses in an ICU.
[0m[49m[38;5;10m+      59[0m:[38;5;10m[49m ACTION_SPACE = [0, 1, 2, 3, 4, 5, 6, 8, 10, 12, 15, 20]
[0m[49m[38;5;10m+      60[0m:[38;5;10m[49m NUM_ACTIONS = len(ACTION_SPACE)
[0m[49m[38;5;10m+      61[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      62[0m:[38;5;10m[49m # --- State Features ---
[0m[49m[38;5;10m+      63[0m:[38;5;10m[49m # The state vector captures everything the RL agent needs to make a dosing decision.
[0m[49m[38;5;10m+      64[0m:[38;5;10m[49m # Each feature has a name, expected range (for normalization), and a description
[0m[49m[38;5;10m+      65[0m:[38;5;10m[49m # of why it matters for insulin dosing.
[0m[49m[38;5;10m+      66[0m:[38;5;10m[49m STATE_FEATURES = [
[0m[49m[38;5;10m+      67[0m:[38;5;10m[49m     # Current glucose and recent history
[0m[49m[38;5;10m+      68[0m:[38;5;10m[49m     {"name": "glucose_current", "min": 30, "max": 500,
[0m[49m[38;5;10m+      69[0m:[38;5;10m[49m      "why": "The primary measurement driving the decision"},
[0m[49m[38;5;10m+      70[0m:[38;5;10m[49m     {"name": "glucose_prev_1", "min": 30, "max": 500,
[0m[49m[38;5;10m+      71[0m:[38;5;10m[49m      "why": "Previous reading (4h ago) for trend calculation"},
[0m[49m[38;5;10m+      72[0m:[38;5;10m[49m     {"name": "glucose_prev_2", "min": 30, "max": 500,
[0m[49m[38;5;10m+      73[0m:[38;5;10m[49m      "why": "Two readings ago (8h ago) for acceleration detection"},
[0m[49m[38;5;10m+      74[0m:[38;5;10m[49m     {"name": "glucose_velocity", "min": -60, "max": 60,
[0m[49m[38;5;10m+      75[0m:[38;5;10m[49m      "why": "Rate of change in mg/dL per hour; negative means dropping"},
[0m[49m[38;5;10m+      76[0m:[38;5;10m[49m     # Insulin state
[0m[49m[38;5;10m+      77[0m:[38;5;10m[49m     {"name": "insulin_on_board", "min": 0, "max": 40,
[0m[49m[38;5;10m+      78[0m:[38;5;10m[49m      "why": "Total insulin given in last 4h; still pharmacologically active"},
[0m[49m[38;5;10m+      79[0m:[38;5;10m[49m     {"name": "insulin_infusion_rate", "min": 0, "max": 20,
[0m[49m[38;5;10m+      80[0m:[38;5;10m[49m      "why": "Current drip rate (units/hr); 0 if subcutaneous only"},
[0m[49m[38;5;10m+      81[0m:[38;5;10m[49m     # Nutrition (major glucose driver)
[0m[49m[38;5;10m+      82[0m:[38;5;10m[49m     {"name": "nutrition_rate", "min": 0, "max": 100,
[0m[49m[38;5;10m+      83[0m:[38;5;10m[49m      "why": "Enteral/parenteral nutrition in mL/hr; directly raises glucose"},
[0m[49m[38;5;10m+      84[0m:[38;5;10m[49m     # Medications that affect insulin sensitivity
[0m[49m[38;5;10m+      85[0m:[38;5;10m[49m     {"name": "vasopressor_dose", "min": 0, "max": 1.0,
[0m[49m[38;5;10m+      86[0m:[38;5;10m[49m      "why": "Norepinephrine equivalent (mcg/kg/min); high doses impair sensitivity"},
