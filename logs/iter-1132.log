[0m[49m[38;5;10m+      99[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     100[0m:[38;5;10m[49m # --- Safety Constraints ---
[0m[49m[38;5;10m+     101[0m:[38;5;10m[49m # Hard limits that override the RL policy. These are non-negotiable.
[0m[49m[38;5;10m+     102[0m:[38;5;10m[49m SAFETY_CONSTRAINTS = {
