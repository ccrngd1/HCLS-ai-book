[0m[49m[38;5;10m+     109[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     110[0m:[38;5;10m[49m # --- Reward Function Parameters ---
[0m[49m[38;5;10m+     111[0m:[38;5;10m[49m # These weights define the asymmetric penalty structure.
[0m[49m[38;5;10m+     112[0m:[38;5;10m[49m # Hypoglycemia is penalized much more heavily than hyperglycemia because
[0m[49m[38;5;10m+     113[0m:[38;5;10m[49m # it's immediately dangerous (seizures, brain damage) vs. gradually harmful.
[0m[49m[38;5;10m+     114[0m:[38;5;10m[49m REWARD_PARAMS = {
