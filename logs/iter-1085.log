[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m ## Step 1: Compute Travel Times
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m *The main recipe's Step 2 estimates a gravity model from historical patient flows. Here we use a simplified distance-based utility model. The math is the same; we just skip the parameter estimation step since we don't have historical data to calibrate against.*
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m def compute_travel_time(zone: dict, facility: dict) -> float:
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m     Compute approximate travel time in minutes between a demand zone
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m     and a facility using straight-line distance with a road-network multiplier.
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m     In production, you'd use a real routing API (Google Maps, HERE, OSRM)
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m     to get actual drive times. Straight-line distance with a 1.4x multiplier
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m     is a common approximation for planning purposes.
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m     # Haversine-lite: at these latitudes, 1 degree lat ~ 69 miles, 1 degree lon ~ 53 miles
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m     lat_diff = abs(zone["lat"] - facility["lat"]) * 69
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m     lon_diff = abs(zone["lon"] - facility["lon"]) * 53
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m     straight_line_miles = np.sqrt(lat_diff**2 + lon_diff**2)
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m     # Road network multiplier: roads aren't straight lines
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m     road_miles = straight_line_miles * 1.4
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m     # Assume average 30 mph in urban/suburban setting
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m     travel_minutes = (road_miles / 30) * 60
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m     return travel_minutes
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m def compute_choice_probabilities(zones: dict, facilities: dict, service_line: str) -> dict:
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m     Compute patient choice probabilities using a gravity model.
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m     The gravity model says: probability of choosing facility f from zone z
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m     is proportional to exp(-beta * travel_time(z, f)).
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m     Facilities that don't offer the service line get zero probability.
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m     This function returns probabilities assuming ALL facilities offer the service;
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m     the optimizer will zero out flows to facilities that don't.
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m     beta = DISTANCE_BETA[service_line]
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m     probabilities = {}
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m     for zone_id, zone_data in zones.items():
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m         utilities = {}
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m         for fac_id, fac_data in facilities.items():
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m             travel = compute_travel_time(zone_data, fac_data)
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m             # Gravity model: utility decays exponentially with travel time
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m             utilities[fac_id] = np.exp(-beta * travel / 60)  # normalize to hours
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m         # Convert utilities to probabilities (softmax-style normalization)
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m         total_utility = sum(utilities.values())
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m         probabilities[zone_id] = {
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m             fac_id: util / total_utility
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m             for fac_id, util in utilities.items()
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m     return probabilities
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m ## Step 2: Formulate the Optimization Model
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m *This is the core of Recipe 14.10. We translate the network design problem into a mixed-integer program. Binary variables represent open/close and service offering decisions. Continuous variables represent patient flows. Constraints enforce budget, capacity, minimum volume, and demand satisfaction.*
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m def formulate_network_model(
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m     facilities: dict,
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m     zones: dict,
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m     service_lines: dict,
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m     budget: float,
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m ) -> LpProblem:
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m     Build the mixed-integer programming model for health system network design.
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m     Decision variables:
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m     - offer[f][s]: binary, 1 if facility f offers service line s
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m     - open[f]: binary, 1 if candidate facility f is opened
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m     - flow[z][f][s]: continuous, patient volume from zone z to facility f for service s
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m     Objective: maximize net contribution margin (revenue minus fixed costs minus capital amortization)
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m     Constraints: budget, capacity, demand satisfaction, minimum volume, gravity model consistency
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m     model = LpProblem("HealthSystemNetworkDesign", LpMaximize)
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m     facility_ids = list(facilities.keys())
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m     zone_ids = list(zones.keys())
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m     service_ids = list(service_lines.keys())
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m     # --- DECISION VARIABLES ---
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m     # Binary: does facility f offer service line s?
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m     offer = {
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m         f: {s: LpVariable(f"offer_{f}_{s}", cat=LpBinary) for s in service_ids}
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m         for f in facility_ids
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m     # Binary: is candidate facility f opened?
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m     open_fac = {
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m         f: LpVariable(f"open_{f}", cat=LpBinary)
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m         for f in facility_ids
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m         if facilities[f]["type"] == "candidate"
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m     # Continuous: patient flow from zone z to facility f for service s
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m     flow = {
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m         z: {
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m             f: {s: LpVariable(f"flow_{z}_{f}_{s}", lowBound=0, cat=LpContinuous) for s in service_ids}
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m             for f in facility_ids
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m         for z in zone_ids
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m     # --- PRECOMPUTE CHOICE PROBABILITIES ---
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m     # These cap how much flow can go from each zone to each facility
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m     # (patients won't all drive past a closer facility to reach a farther one)
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m     choice_probs = {
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m         s: compute_choice_probabilities(zones, facilities, s)
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m         for s in service_ids
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m     # --- OBJECTIVE FUNCTION ---
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m     # Maximize: total revenue - fixed costs - annualized capital costs
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m     # Capital is amortized over 10 years for this simplified model.
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m     revenue = lpSum(
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m         service_lines[s]["revenue_per_case"] * flow[z][f][s]
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m         for z in zone_ids
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m         for f in facility_ids
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m         for s in service_ids
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m     fixed_costs = lpSum(
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m         service_lines[s]["fixed_annual_cost"] * offer[f][s]
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m         for f in facility_ids
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m         for s in service_ids
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m     # Capital amortization (10-year straight-line)
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m     capital_annual = LpVariable("capital_annual", lowBound=0, cat=LpContinuous)
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m     model += revenue - fixed_costs - capital_annual, "NetContributionMargin"
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m     # --- CONSTRAINTS ---
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m     # 1. Budget constraint: total capital spend cannot exceed budget
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m     capital_expr = []
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m     for f in facility_ids:
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m         if facilities[f]["type"] == "candidate":
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m             capital_expr.append(CAPITAL_COSTS["new_facility_base"] * open_fac[f])
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m         for s in service_ids:
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m             if s not in facilities[f]["current_services"]:
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m                 cost_key = f"add_{s}"
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m                 if cost_key in CAPITAL_COSTS:
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m                     capital_expr.append(CAPITAL_COSTS[cost_key] * offer[f][s])
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m     model += lpSum(capital_expr) <= budget, "BudgetLimit"
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m     model += capital_annual == lpSum(capital_expr) / 10, "CapitalAmortization"
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m     # 2. Capacity constraints: volume at each facility cannot exceed capacity
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m     for f in facility_ids:
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m         for s in service_ids:
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m             model += (
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m                 lpSum(flow[z][f][s] for z in zone_ids) <= CAPACITY_PER_FACILITY[s] * offer[f][s],
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m                 f"Capacity_{f}_{s}"
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m     # 3. Demand satisfaction: all demand must be assigned
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m     #    (in this simplified model, we allow "leakage" by not requiring 100% capture)
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m     for z in zone_ids:
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m         for s in service_ids:
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m             model += (
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m                 lpSum(flow[z][f][s] for f in facility_ids) <= zones[z]["demand"][s],
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m                 f"DemandCap_{z}_{s}"
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m     # 4. Gravity model consistency: flow cannot exceed what the choice model predicts
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m     #    Patients won't all choose a distant facility over a nearby one.
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m     for z in zone_ids:
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m         for f in facility_ids:
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m             for s in service_ids:
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m                 max_flow = zones[z]["demand"][s] * choice_probs[s][z][f]
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m                 model += (
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m                     flow[z][f][s] <= max_flow,
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m                     f"GravityBound_{z}_{f}_{s}"
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m                 )
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m     # 5. Minimum volume: if you offer a service, you must hit minimum volume
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m     #    (quality and accreditation requirement)
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m     for f in facility_ids:
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m         for s in service_ids:
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m             model += (
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m                 lpSum(flow[z][f][s] for z in zone_ids) >= service_lines[s]["min_volume_threshold"] * offer[f][s],
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m                 f"MinVolume_{f}_{s}"
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m             )
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m     # 6. Candidate facilities: can only offer services if the facility is opened
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m     for f in facility_ids:
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m         if facilities[f]["type"] == "candidate":
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m             for s in service_ids:
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m                 model += (
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m                     offer[f][s] <= open_fac[f],
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m                     f"MustBeOpen_{f}_{s}"
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m                 )
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m     # 7. Existing services: facilities already offering a service must continue
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m     #    (closing an existing service is a separate, politically charged decision)
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m     for f in facility_ids:
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m         for s in facilities[f]["current_services"]:
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m             model += offer[f][s] == 1, f"KeepExisting_{f}_{s}"
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m     return model, offer, open_fac, flow
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m ## Step 3: Solve and Extract Results
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m *Once the model is formulated, we hand it to the solver. PuLP's interface makes this a single function call. The interesting part is interpreting the solution: which facilities should offer which services, and how do patient flows redistribute?*
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m def solve_model(model: LpProblem) -> dict:
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m     Invoke the MIP solver and return solve metadata.
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m     CBC (the default PuLP solver) uses branch-and-bound with cutting planes.
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m     For this small problem it solves in under a second. For production-scale
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m     problems (50K+ variables), you'd use Gurobi or HiGHS and set a time limit.
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m     solver = PULP_CBC_CMD(
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m         msg=1,           # show solver output (set to 0 for silent)
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m         timeLimit=300,   # 5-minute time limit (generous for this size)
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m         gapRel=0.02,     # accept solutions within 2% of proven optimal
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m     model.solve(solver)
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m         "status": model.status,
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m         "status_text": model.sol_status[model.status] if hasattr(model, 'sol_status') else str(model.status),
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m         "objective_value": value(model.objective) if model.status == 1 else None,
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m def extract_solution(
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m     facilities: dict,
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m     zones: dict,
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m     service_lines: dict,
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m     offer: dict,
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m     open_fac: dict,
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m     flow: dict,
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m     Pull the optimal decisions out of the solved model variables.
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m     This is where the math becomes actionable recommendations:
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m     which facilities to open, which services to add, and how patients
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m     are expected to flow through the network.
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m     facility_ids = list(facilities.keys())
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m     zone_ids = list(zones.keys())
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m     service_ids = list(service_lines.keys())
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m     # Extract facility opening decisions
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m     new_facilities = []
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m     for f in facility_ids:
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m         if facilities[f]["type"] == "candidate" and value(open_fac[f]) > 0.5:
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m             new_facilities.append({"facility": f, "name": facilities[f]["name"]})
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m     # Extract service line decisions
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m     service_decisions = []
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m     for f in facility_ids:
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m         for s in service_ids:
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m             if value(offer[f][s]) > 0.5 and s not in facilities[f]["current_services"]:
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m                 service_decisions.append({
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m                     "facility": f,
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m                     "facility_name": facilities[f]["name"],
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m                     "service_line": s,
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m                     "action": "ADD_SERVICE_LINE",
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m                 })
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m     # Extract patient flow summary
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m     flow_summary = {}
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m     for f in facility_ids:
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m         for s in service_ids:
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m             total_flow = sum(value(flow[z][f][s]) for z in zone_ids)
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m             if total_flow > 1:  # ignore negligible flows
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m                 key = f"{f}_{s}"
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m                 flow_summary[key] = {
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m                     "facility": facilities[f]["name"],
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m                     "service_line": s,
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m                     "projected_annual_volume": round(total_flow),
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m                     "capacity_utilization": round(total_flow / CAPACITY_PER_FACILITY[s] * 100, 1),
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m                 }
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m     # Compute total capital required
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m     total_capital = 0
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m     for f in facility_ids:
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m         if facilities[f]["type"] == "candidate" and value(open_fac[f]) > 0.5:
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m             total_capital += CAPITAL_COSTS["new_facility_base"]
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m         for s in service_ids:
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m             if value(offer[f][s]) > 0.5 and s not in facilities[f]["current_services"]:
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m                 cost_key = f"add_{s}"
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m                 if cost_key in CAPITAL_COSTS:
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m                     total_capital += CAPITAL_COSTS[cost_key]
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m         "new_facilities_opened": new_facilities,
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m         "service_line_additions": service_decisions,
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m         "patient_flow_summary": flow_summary,
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m         "total_capital_required": total_capital,
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m         "budget_remaining": TOTAL_BUDGET - total_capital,
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m ## Step 4: Scenario Analysis
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m *The main recipe emphasizes that no single demand forecast is reliable. This step runs the optimization under multiple demand scenarios and identifies robust versus contingent decisions.*
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m def create_scenarios(base_zones: dict) -> dict:
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m     Define demand scenarios for sensitivity analysis.
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m     Each scenario modifies the base demand by applying multipliers.
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m     In production, these come from demographic models and market analysis.
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m     scenarios = {
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m         "base_case": {s: 1.0 for s in SERVICE_LINES},
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m         "high_growth": {s: 1.2 for s in SERVICE_LINES},
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m         "low_growth": {s: 0.85 for s in SERVICE_LINES},
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m         "cardiology_surge": {"primary_care": 1.0, "cardiology": 1.4, "orthopedics": 1.0},
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m         "competitor_entry": {s: 0.75 for s in SERVICE_LINES},  # lose 25% market share
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m     return scenarios
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m def run_scenario(
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m     facilities: dict,
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m     base_zones: dict,
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m     service_lines: dict,
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m     budget: float,
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m     demand_multipliers: dict,
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m     Run the optimization under a single demand scenario.
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m     Applies demand multipliers to the base zones, formulates, solves,
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m     and returns the solution.
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m     # Apply demand multipliers to create scenario-specific zones
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m     scenario_zones = {}
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m     for z_id, z_data in base_zones.items():
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m         scenario_zones[z_id] = {
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m             "lat": z_data["lat"],
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m             "lon": z_data["lon"],
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m             "demand": {
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m                 s: int(z_data["demand"][s] * demand_multipliers.get(s, 1.0))
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m                 for s in z_data["demand"]
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m             },
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m     model, offer, open_fac, flow = formulate_network_model(
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m         facilities, scenario_zones, service_lines, budget
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m     solve_result = solve_model(model)
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m     if solve_result["status"] != 1:
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m         return {"status": "infeasible", "solve_result": solve_result}
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m     solution = extract_solution(
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m         facilities, scenario_zones, service_lines, offer, open_fac, flow
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m     solution["objective_value"] = solve_result["objective_value"]
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m     return solution
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m def identify_robust_decisions(scenario_results: dict) -> dict:
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m     Compare solutions across scenarios to find decisions that are
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m     consistent (robust) versus those that change (contingent).
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m     A robust decision appears in every scenario's optimal solution.
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m     A contingent decision only appears in some scenarios.
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m     # Collect all service line additions across scenarios
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m     all_additions = {}
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m     for scenario_name, result in scenario_results.items():
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m         if result.get("status") == "infeasible":
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m         for addition in result.get("service_line_additions", []):
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m             key = f"{addition['facility']}_{addition['service_line']}"
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m             if key not in all_additions:
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m                 all_additions[key] = {"decision": addition, "scenarios": []}
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m             all_additions[key]["scenarios"].append(scenario_name)
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m     feasible_count = sum(
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m         1 for r in scenario_results.values() if r.get("status") != "infeasible"
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m     robust = []
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m     contingent = []
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m     for key, data in all_additions.items():
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m         if len(data["scenarios"]) == feasible_count:
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m             robust.append(data["decision"])
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m             contingent.append({
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m                 **data["decision"],
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m                 "appears_in_scenarios": data["scenarios"],
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m                 "frequency": f"{len(data['scenarios'])}/{feasible_count}",
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m     return {"robust_decisions": robust, "contingent_decisions": contingent}
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m ## Step 5: Store Results to S3
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m *The optimization results need to land somewhere durable for the executive dashboard (QuickSight) to pick up. S3 is the natural landing zone.*
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m import datetime
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m from datetime import timezone
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m s3_client = boto3.client("s3", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m RESULTS_BUCKET = "health-system-network-optimization"
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m # Replace with your actual bucket name. Must have SSE-KMS encryption enabled.
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m def store_optimization_results(run_id: str, results: dict) -> str:
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m     Write optimization results to S3 as JSON for downstream consumption.
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m     The QuickSight dashboard reads from this location. Step Functions
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m     triggers a SPICE refresh after this write completes.
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m     key = f"optimization-runs/{run_id}/results.json"
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m     output = {
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m         "run_id": run_id,
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m         "timestamp": datetime.datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m         "results": results,
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m     s3_client.put_object(
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m         Bucket=RESULTS_BUCKET,
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m         Key=key,
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m         Body=json.dumps(output, indent=2, default=str),
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m         ContentType="application/json",
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m         ServerSideEncryption="aws:kms",
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m         # In production, specify your KMS key ID with SSEKMSKeyId parameter
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m     logger.info("Results stored to s3://%s/%s", RESULTS_BUCKET, key)
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m     return f"s3://{RESULTS_BUCKET}/{key}"
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m ## Putting It All Together
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m Here's the full pipeline assembled into a single callable function. This is what your Step Functions workflow would invoke via a SageMaker Processing Job.
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m def run_network_design_optimization() -> dict:
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m     Execute the full health system network design optimization pipeline.
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m     Steps:
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m     1. Compute travel times and choice probabilities
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m     2. Formulate the base optimization model
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m     3. Solve under multiple demand scenarios
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m     4. Identify robust vs. contingent decisions
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m     5. Store results for dashboard consumption
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m     logger.info("=== Health System Network Design Optimization ===")
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m     # Step 1-2: Formulate and solve base case
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m     logger.info("Step 1: Formulating base case model...")
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m     model, offer, open_fac, flow = formulate_network_model(
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m         FACILITIES, DEMAND_ZONES, SERVICE_LINES, TOTAL_BUDGET
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m     logger.info("  Model has %d variables, %d constraints",
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m                 model.numVariables(), model.numConstraints())
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m     logger.info("Step 2: Solving base case...")
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m     base_result = solve_model(model)
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m     logger.info("  Solver status: %s", base_result)
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m     if base_result["status"] != 1:
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m         logger.error("Base case infeasible or unbounded. Check constraints.")
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m         return {"error": "Base case did not solve optimally", "details": base_result}
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m     base_solution = extract_solution(
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m         FACILITIES, DEMAND_ZONES, SERVICE_LINES, offer, open_fac, flow
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m     base_solution["objective_value"] = base_result["objective_value"]
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m     logger.info("  Base case objective: $%s annual net margin",
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m                 f"{base_result['objective_value']:,.0f}")
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m     # Step 3: Run scenario analysis
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m     logger.info("Step 3: Running scenario analysis...")
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m     scenarios = create_scenarios(DEMAND_ZONES)
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m     scenario_results = {}
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m     for scenario_name, multipliers in scenarios.items():
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m         logger.info("  Solving scenario: %s", scenario_name)
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m         result = run_scenario(
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m             FACILITIES, DEMAND_ZONES, SERVICE_LINES, TOTAL_BUDGET, multipliers
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m         scenario_results[scenario_name] = result
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m         obj = result.get("objective_value", "N/A")
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m         if obj != "N/A":
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m             logger.info("    Objective: $%s", f"{obj:,.0f}")
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m     # Step 4: Identify robust decisions
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m     logger.info("Step 4: Identifying robust vs. contingent decisions...")
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m     robustness = identify_robust_decisions(scenario_results)
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m     logger.info("  Robust decisions: %d", len(robustness["robust_decisions"]))
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m     logger.info("  Contingent decisions: %d", len(robustness["contingent_decisions"]))
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m     # Assemble final output
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m     final_output = {
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m         "base_case_solution": base_solution,
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m         "scenario_results": {
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m             name: {
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m                 "objective_value": r.get("objective_value"),
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m                 "new_facilities": r.get("new_facilities_opened", []),
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m                 "service_additions": r.get("service_line_additions", []),
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m                 "capital_required": r.get("total_capital_required", 0),
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m             for name, r in scenario_results.items()
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m             if r.get("status") != "infeasible"
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m         "robustness_analysis": robustness,
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m     # Step 5: Store results (uncomment when you have the S3 bucket configured)
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m     # run_id = f"net-design-{datetime.datetime.now(timezone.utc).strftime('%Y%m%d-%H%M%S')}"
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m     # store_optimization_results(run_id, final_output)
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m     logger.info("=== Optimization Complete ===")
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m     return final_output
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m # Run the pipeline
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m if __name__ == "__main__":
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m     results = run_network_design_optimization()
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m     print("\n" + "=" * 60)
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m     print("OPTIMIZATION RESULTS SUMMARY")
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m     base = results["base_case_solution"]
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m     print(f"\nBase Case Annual Net Margin: ${base['objective_value']:,.0f}")
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m     print(f"Total Capital Required: ${base['total_capital_required']:,.0f}")
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m     print(f"Budget Remaining: ${base['budget_remaining']:,.0f}")
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m     if base["new_facilities_opened"]:
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m         print("\nNew Facilities to Open:")
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m         for fac in base["new_facilities_opened"]:
