[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m # Structured logging. In production, ship JSON-formatted records
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m # to CloudWatch Logs Insights for cross-call investigation.
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m # Conversation logs are dense longitudinal PHI: patient symptom
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m # descriptions, medication mentions, mental-health disclosures,
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m # family details, and identifiers can all surface in coaching
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m # chat over years. Log structural metadata only (session_id,
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m # patient_id_hash, intent, tool name, tool latency, tool
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m # outcome, care_plan_id, care_plan_version), never raw user
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m # utterances, never raw generated responses, never tool
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m # arguments that contain identifiers, never specific clinical
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m # rule input values. The full transcripts and full tool calls
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m # live in the audit pipeline (Firehose plus Object-Lock S3)
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m # with appropriate access controls.
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m # Adaptive retry handles throttling from Bedrock, DynamoDB,
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m # EventBridge, Firehose, CloudWatch, S3, Pinpoint, Step
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m # Functions, and Secrets Manager. The chronic coach's response
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m # window is more relaxed than the triage bot's, but not by
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m # much: a patient typing during a check-in still expects a
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m # response within seconds.
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m     retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m # Module-level clients. Reused across Lambda invocations in
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m # warm containers so each invocation does not pay the
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m # connection cost.
