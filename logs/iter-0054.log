[0m[49m[38;5;10m+    2719[0m:[38;5;10m[49m     text_lower = response_text.lower()
[0m[49m[38;5;10m+    2720[0m:[38;5;10m[49m     primary_stage = "preparation"
[0m[49m[38;5;10m+    2721[0m:[38;5;10m[49m     for info in stages_per_goal.values():
