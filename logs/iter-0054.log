[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m     try:
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m         eventbridge_client.put_events(Entries=[{
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m             "Source":       "chronic_coach",
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m             "DetailType":   detail_type,
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m             "Detail":       json.dumps(_from_decimal(detail)),
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m             "EventBusName": COACH_EVENT_BUS_NAME,
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m         }])
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m     except Exception as exc:
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m         logger.error(
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m             "EventBridge emit failed for %s: %s",
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m             detail_type, exc)
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m def _put_metric(metric_name: str, value: float,
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m                 dimensions: dict) -> None:
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m     """Emit a CloudWatch metric. Best-effort; never blocks."""
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m     try:
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m         cloudwatch_client.put_metric_data(
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m             Namespace=CLOUDWATCH_NAMESPACE,
[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m             MetricData=[{
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m                 "MetricName": metric_name,
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m                 "Value":      value,
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m                 "Unit":       "Count",
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m                 "Dimensions": [
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m                     {"Name": k, "Value": str(v)}
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m                     for k, v in dimensions.items()
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m                 ],
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m             }])
