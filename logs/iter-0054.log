[0m[49m[38;5;10m+    1348[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1349[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1350[0m:[38;5;10m[49m def _initialize_behavior_change_stages(care_plan, chart):
[0m[49m[38;5;10m+    1351[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1352[0m:[38;5;10m[49m     Initialize per-goal behavior-change-stage estimates from
[0m[49m[38;5;10m+    1353[0m:[38;5;10m[49m     the chart context. Production runs the institutional
[0m[49m[38;5;10m+    1354[0m:[38;5;10m[49m     classifier; the demo defaults to "preparation" for every
[0m[49m[38;5;10m+    1355[0m:[38;5;10m[49m     goal, which is a common starting point for newly-enrolled
[0m[49m[38;5;10m+    1356[0m:[38;5;10m[49m     patients who consented to coaching.
[0m[49m[38;5;10m+    1357[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1358[0m:[38;5;10m[49m     stages = {}
[0m[49m[38;5;10m+    1359[0m:[38;5;10m[49m     for goal in care_plan["goals"]:
[0m[49m[38;5;10m+    1360[0m:[38;5;10m[49m         stages[goal["goal_id"]] = {
[0m[49m[38;5;10m+    1361[0m:[38;5;10m[49m             "stage": "preparation",
[0m[49m[38;5;10m+    1362[0m:[38;5;10m[49m             "evidence":
[0m[49m[38;5;10m+    1363[0m:[38;5;10m[49m                 "default initialization at enrollment",
[0m[49m[38;5;10m+    1364[0m:[38;5;10m[49m             "updated_at": _now_iso(),
[0m[49m[38;5;10m+    1365[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1366[0m:[38;5;10m[49m     return stages
[0m[49m[38;5;10m+    1367[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1368[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1369[0m:[38;5;10m[49m def _extract_outcome_baseline(chart, care_plan):
[0m[49m[38;5;10m+    1370[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1371[0m:[38;5;10m[49m     Extract the outcome-tracking baseline from the chart for
[0m[49m[38;5;10m+    1372[0m:[38;5;10m[49m     later outcome-correlation work. Production reads a curated
[0m[49m[38;5;10m+    1373[0m:[38;5;10m[49m     set of baseline metrics per condition (A1c, BP, weight,
[0m[49m[38;5;10m+    1374[0m:[38;5;10m[49m     eGFR, condition-specific outcomes); the demo records
[0m[49m[38;5;10m+    1375[0m:[38;5;10m[49m     whatever is in the chart's "baseline" field.
[0m[49m[38;5;10m+    1376[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1377[0m:[38;5;10m[49m     return chart.get("baseline", {})
[0m[49m[38;5;10m+    1378[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    1379[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1380[0m:[38;5;10m[49m The enrollment function is doing six things, in order. Read them as one workflow:
[0m[49m[38;5;10m+    1381[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1382[0m:[38;5;10m[49m 1. **Pick the template.** The condition determines the template; the template comes from the institutional library owned by clinical leadership.
[0m[49m[38;5;10m+    1383[0m:[38;5;10m[49m 2. **Instantiate the care plan.** The patient-specific values come from the chart and from clinical-team inputs at signoff. The plan is signed and version-stamped.
[0m[49m[38;5;10m+    1384[0m:[38;5;10m[49m 3. **Confirm patient consent.** Without it, no enrollment.
[0m[49m[38;5;10m+    1385[0m:[38;5;10m[49m 4. **Initialize the longitudinal store.** Behavior-change-stage per goal, patient preferences, baselines. Skip this and the coach has no foundation.
[0m[49m[38;5;10m+    1386[0m:[38;5;10m[49m 5. **Persist the care plan as its own clinical record.** Separately governed from the longitudinal store.
[0m[49m[38;5;10m+    1387[0m:[38;5;10m[49m 6. **Schedule onboarding.** The first engagement goes out 24 hours later (production schedules it for the patient's preferred time window).
[0m[49m[38;5;10m+    1388[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1389[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    1390[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1391[0m:[38;5;10m[49m ## Step 2: Ingest Biometric Data and Evaluate Against Care-Plan Thresholds
[0m[49m[38;5;10m+    1392[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1393[0m:[38;5;10m[49m Connected devices feed the coach. Each reading is validated, stored, and evaluated against the thresholds specified in the patient's care plan. Threshold-crossing events trigger engagement (or escalation, depending on severity). The thresholds are not chosen by the LLM; they are clinical-care-plan inputs signed by the patient's clinical team. Skip this step and the coach is missing one of its highest-value inputs (the data the patient is generating between visits).
[0m[49m[38;5;10m+    1394[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1395[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    1396[0m:[38;5;10m[49m def biometric_data_received(*,
[0m[49m[38;5;10m+    1397[0m:[38;5;10m[49m                              patient_id,
[0m[49m[38;5;10m+    1398[0m:[38;5;10m[49m                              device_type,
[0m[49m[38;5;10m+    1399[0m:[38;5;10m[49m                              reading,
[0m[49m[38;5;10m+    1400[0m:[38;5;10m[49m                              reading_timestamp=None):
[0m[49m[38;5;10m+    1401[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1402[0m:[38;5;10m[49m     Ingest a biometric reading from a connected device. The
[0m[49m[38;5;10m+    1403[0m:[38;5;10m[49m     flow validates the reading, stores it, evaluates it
[0m[49m[38;5;10m+    1404[0m:[38;5;10m[49m     against the patient's care-plan thresholds, and dispatches
[0m[49m[38;5;10m+    1405[0m:[38;5;10m[49m     engagement or escalation events.
[0m[49m[38;5;10m+    1406[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1407[0m:[38;5;10m[49m     reading_timestamp = reading_timestamp or _now_iso()
[0m[49m[38;5;10m+    1408[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1409[0m:[38;5;10m[49m     # Step 2A: validate the reading. Production has per-device
[0m[49m[38;5;10m+    1410[0m:[38;5;10m[49m     # validation rules (impossible values, sensor-error codes,
[0m[49m[38;5;10m+    1411[0m:[38;5;10m[49m     # device-status flags); the demo runs a minimal sanity
[0m[49m[38;5;10m+    1412[0m:[38;5;10m[49m     # check.
[0m[49m[38;5;10m+    1413[0m:[38;5;10m[49m     validation = _validate_biometric_reading(
[0m[49m[38;5;10m+    1414[0m:[38;5;10m[49m         device_type, reading, patient_id)
[0m[49m[38;5;10m+    1415[0m:[38;5;10m[49m     if not validation["valid"]:
[0m[49m[38;5;10m+    1416[0m:[38;5;10m[49m         logger.warning(
[0m[49m[38;5;10m+    1417[0m:[38;5;10m[49m             "Discarded invalid biometric reading: "
[0m[49m[38;5;10m+    1418[0m:[38;5;10m[49m             "patient=%s device=%s reason=%s",
[0m[49m[38;5;10m+    1419[0m:[38;5;10m[49m             patient_id, device_type, validation["reason"])
[0m[49m[38;5;10m+    1420[0m:[38;5;10m[49m         return {"action": "invalid_reading_discarded"}
[0m[49m[38;5;10m+    1421[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1422[0m:[38;5;10m[49m     # Step 2B: store the reading.
[0m[49m[38;5;10m+    1423[0m:[38;5;10m[49m     biometric_store = dynamodb.Table(
[0m[49m[38;5;10m+    1424[0m:[38;5;10m[49m         BIOMETRIC_EVENT_STORE_TABLE)
[0m[49m[38;5;10m+    1425[0m:[38;5;10m[49m     biometric_store.put_item(Item=_to_decimal({
[0m[49m[38;5;10m+    1426[0m:[38;5;10m[49m         "patient_id":         patient_id,
[0m[49m[38;5;10m+    1427[0m:[38;5;10m[49m         "device_type":        device_type,
[0m[49m[38;5;10m+    1428[0m:[38;5;10m[49m         "reading":            reading,
[0m[49m[38;5;10m+    1429[0m:[38;5;10m[49m         "reading_timestamp":  reading_timestamp,
[0m[49m[38;5;10m+    1430[0m:[38;5;10m[49m         "ingested_at":        _now_iso(),
[0m[49m[38;5;10m+    1431[0m:[38;5;10m[49m     }))
[0m[49m[38;5;10m+    1432[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1433[0m:[38;5;10m[49m     # Step 2C: load the patient's active care plan to find
[0m[49m[38;5;10m+    1434[0m:[38;5;10m[49m     # the thresholds for this device type.
[0m[49m[38;5;10m+    1435[0m:[38;5;10m[49m     care_plan = _read_active_care_plan(patient_id)
[0m[49m[38;5;10m+    1436[0m:[38;5;10m[49m     if not care_plan:
[0m[49m[38;5;10m+    1437[0m:[38;5;10m[49m         logger.warning(
[0m[49m[38;5;10m+    1438[0m:[38;5;10m[49m             "No active care plan for patient %s; "
[0m[49m[38;5;10m+    1439[0m:[38;5;10m[49m             "skipping threshold evaluation.",
[0m[49m[38;5;10m+    1440[0m:[38;5;10m[49m             patient_id)
[0m[49m[38;5;10m+    1441[0m:[38;5;10m[49m         return {"action": "no_care_plan"}
[0m[49m[38;5;10m+    1442[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1443[0m:[38;5;10m[49m     thresholds = care_plan.get(
[0m[49m[38;5;10m+    1444[0m:[38;5;10m[49m         "biometric_thresholds", {}).get(device_type)
[0m[49m[38;5;10m+    1445[0m:[38;5;10m[49m     if not thresholds:
[0m[49m[38;5;10m+    1446[0m:[38;5;10m[49m         # Reading is recorded for trend analysis but no
[0m[49m[38;5;10m+    1447[0m:[38;5;10m[49m         # threshold is configured for it.
[0m[49m[38;5;10m+    1448[0m:[38;5;10m[49m         return {"action": "stored_no_thresholds"}
[0m[49m[38;5;10m+    1449[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1450[0m:[38;5;10m[49m     # Step 2D: evaluate single-reading thresholds. These are
[0m[49m[38;5;10m+    1451[0m:[38;5;10m[49m     # the immediate-action triggers (e.g., a single glucose
[0m[49m[38;5;10m+    1452[0m:[38;5;10m[49m     # reading above 250 or below 60).
[0m[49m[38;5;10m+    1453[0m:[38;5;10m[49m     single_event = _evaluate_single_reading(
[0m[49m[38;5;10m+    1454[0m:[38;5;10m[49m         reading, thresholds, device_type)
[0m[49m[38;5;10m+    1455[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1456[0m:[38;5;10m[49m     # Step 2E: evaluate trend thresholds. Production has
[0m[49m[38;5;10m+    1457[0m:[38;5;10m[49m     # condition-specific trend logic (3-day average, 7-day
[0m[49m[38;5;10m+    1458[0m:[38;5;10m[49m     # average, percentage change from baseline); the demo
[0m[49m[38;5;10m+    1459[0m:[38;5;10m[49m     # uses a simple windowed average.
[0m[49m[38;5;10m+    1460[0m:[38;5;10m[49m     recent_readings = mock_biometric_vendor.recent(
[0m[49m[38;5;10m+    1461[0m:[38;5;10m[49m         patient_id, device_type,
[0m[49m[38;5;10m+    1462[0m:[38;5;10m[49m         days=int(thresholds.get("trend_window_days", 7)))
[0m[49m[38;5;10m+    1463[0m:[38;5;10m[49m     trend_event = _evaluate_trend(
[0m[49m[38;5;10m+    1464[0m:[38;5;10m[49m         recent_readings, thresholds, device_type)
[0m[49m[38;5;10m+    1465[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1466[0m:[38;5;10m[49m     # Step 2F: dispatch events.
[0m[49m[38;5;10m+    1467[0m:[38;5;10m[49m     for event in [single_event, trend_event]:
[0m[49m[38;5;10m+    1468[0m:[38;5;10m[49m         if event is None:
[0m[49m[38;5;10m+    1469[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    1470[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1471[0m:[38;5;10m[49m         if event["severity"] == "engagement":
[0m[49m[38;5;10m+    1472[0m:[38;5;10m[49m             # Schedule a follow-up engagement.
[0m[49m[38;5;10m+    1473[0m:[38;5;10m[49m             schedule_engagement(
[0m[49m[38;5;10m+    1474[0m:[38;5;10m[49m                 patient_id=patient_id,
