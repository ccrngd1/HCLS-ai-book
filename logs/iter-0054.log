[0m[49m[38;5;10m+    1651[0m:[38;5;10m[49m                          context=None):
[0m[49m[38;5;10m+    1652[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1653[0m:[38;5;10m[49m     Add a proactive engagement to the schedule. Production
[0m[49m[38;5;10m+    1654[0m:[38;5;10m[49m     runs this through Step Functions for durable scheduling
[0m[49m[38;5;10m+    1655[0m:[38;5;10m[49m     with delay states; the demo writes to DynamoDB directly.
[0m[49m[38;5;10m+    1656[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1657[0m:[38;5;10m[49m     engagement_id = f"eng_{uuid.uuid4().hex}"
[0m[49m[38;5;10m+    1658[0m:[38;5;10m[49m     record = {
[0m[49m[38;5;10m+    1659[0m:[38;5;10m[49m         "engagement_id":     engagement_id,
[0m[49m[38;5;10m+    1660[0m:[38;5;10m[49m         "patient_id":        patient_id,
