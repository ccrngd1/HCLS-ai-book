[0m[49m[38;5;10m+    1960[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1961[0m:[38;5;10m[49m ## Step 4: Handle Patient-Initiated or Patient-Responding Conversation
[0m[49m[38;5;10m+    1962[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1963[0m:[38;5;10m[49m The coach loads the full longitudinal context (care plan, recent biometric data, recent conversation history, patient preferences, behavior-change-stage estimates, recent life-context disclosures) before generating any response. The longitudinal context is the architectural primitive that makes the coach a coach rather than a chatbot.
[0m[49m[38;5;10m+    1964[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1965[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    1966[0m:[38;5;10m[49m def receive_message(*,
[0m[49m[38;5;10m+    1967[0m:[38;5;10m[49m                      channel,
[0m[49m[38;5;10m+    1968[0m:[38;5;10m[49m                      channel_session_id,
[0m[49m[38;5;10m+    1969[0m:[38;5;10m[49m                      user_message,
[0m[49m[38;5;10m+    1970[0m:[38;5;10m[49m                      auth_context):
[0m[49m[38;5;10m+    1971[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1972[0m:[38;5;10m[49m     Entry point for patient-initiated or patient-responding
[0m[49m[38;5;10m+    1973[0m:[38;5;10m[49m     conversation. Returns the bot's response payload.
[0m[49m[38;5;10m+    1974[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1975[0m:[38;5;10m[49m     # Step 4A: identify or create the conversation session.
[0m[49m[38;5;10m+    1976[0m:[38;5;10m[49m     state_table = dynamodb.Table(CONVERSATION_STATE_TABLE)
[0m[49m[38;5;10m+    1977[0m:[38;5;10m[49m     session = _get_or_create_session(
[0m[49m[38;5;10m+    1978[0m:[38;5;10m[49m         state_table, channel, channel_session_id, auth_context)
[0m[49m[38;5;10m+    1979[0m:[38;5;10m[49m     session_id = session["session_id"]
[0m[49m[38;5;10m+    1980[0m:[38;5;10m[49m     patient_id = session["verified_patient_id"]
[0m[49m[38;5;10m+    1981[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1982[0m:[38;5;10m[49m     # Step 4B: persist the user's message.
[0m[49m[38;5;10m+    1983[0m:[38;5;10m[49m     metadata_table = dynamodb.Table(
[0m[49m[38;5;10m+    1984[0m:[38;5;10m[49m         CONVERSATION_METADATA_TABLE)
[0m[49m[38;5;10m+    1985[0m:[38;5;10m[49m     metadata_table.put_item(Item=_to_decimal({
[0m[49m[38;5;10m+    1986[0m:[38;5;10m[49m         "session_id":     session_id,
