[0m[49m[38;5;10m+    2015[0m:[38;5;10m[49m     disclosure = _sensitive_disclosure_screen(user_message)
[0m[49m[38;5;10m+    2016[0m:[38;5;10m[49m     if disclosure["disclosure_detected"]:
[0m[49m[38;5;10m+    2017[0m:[38;5;10m[49m         _handle_sensitive_disclosure(
[0m[49m[38;5;10m+    2018[0m:[38;5;10m[49m             session_id, patient_id, disclosure)
[0m[49m[38;5;10m+    2019[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2020[0m:[38;5;10m[49m     # Step 4F: load longitudinal context. This is the heart
[0m[49m[38;5;10m+    2021[0m:[38;5;10m[49m     # of the coach's value: the care plan, recent biometric
[0m[49m[38;5;10m+    2022[0m:[38;5;10m[49m     # data, recent conversation history, patient preferences,
[0m[49m[38;5;10m+    2023[0m:[38;5;10m[49m     # behavior-change-stage estimates, recent life-context
[0m[49m[38;5;10m+    2024[0m:[38;5;10m[49m     # disclosures, open follow-up items.
[0m[49m[38;5;10m+    2025[0m:[38;5;10m[49m     care_plan = _read_active_care_plan(patient_id)
[0m[49m[38;5;10m+    2026[0m:[38;5;10m[49m     if not care_plan:
