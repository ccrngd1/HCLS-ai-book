[0m[49m[38;5;10m+    2556[0m:[38;5;10m[49m                          citations,
[0m[49m[38;5;10m+    2557[0m:[38;5;10m[49m                          tool_calls,
[0m[49m[38;5;10m+    2558[0m:[38;5;10m[49m                          longitudinal_context):
[0m[49m[38;5;10m+    2559[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2560[0m:[38;5;10m[49m     Output screening. Returns the final response payload or a
[0m[49m[38;5;10m+    2561[0m:[38;5;10m[49m     safer template. Production runs an independent verifier
[0m[49m[38;5;10m+    2562[0m:[38;5;10m[49m     model with structured-output validation; the demo runs
[0m[49m[38;5;10m+    2563[0m:[38;5;10m[49m     rule-based checks that demonstrate the structure.
[0m[49m[38;5;10m+    2564[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    2565[0m:[38;5;10m[49m     care_plan = longitudinal_context["care_plan"]
[0m[49m[38;5;10m+    2566[0m:[38;5;10m[49m     longitudinal = longitudinal_context["longitudinal"]
[0m[49m[38;5;10m+    2567[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2568[0m:[38;5;10m[49m     # Step 6A: scope checks specific to coaching.
[0m[49m[38;5;10m+    2569[0m:[38;5;10m[49m     scope_violation = _detect_coaching_scope_violations(
[0m[49m[38;5;10m+    2570[0m:[38;5;10m[49m         response_text)
[0m[49m[38;5;10m+    2571[0m:[38;5;10m[49m     if scope_violation:
[0m[49m[38;5;10m+    2572[0m:[38;5;10m[49m         if scope_violation["category"] == \
[0m[49m[38;5;10m+    2573[0m:[38;5;10m[49m                 "new_condition_diagnosis_attempted":
[0m[49m[38;5;10m+    2574[0m:[38;5;10m[49m             return {
[0m[49m[38;5;10m+    2575[0m:[38;5;10m[49m                 "response":     OUT_OF_SCOPE_DIAGNOSIS_TEMPLATE,
[0m[49m[38;5;10m+    2576[0m:[38;5;10m[49m                 "disposition":  "scope_replaced",
[0m[49m[38;5;10m+    2577[0m:[38;5;10m[49m                 "citations":    [],
[0m[49m[38;5;10m+    2578[0m:[38;5;10m[49m                 "violation":    scope_violation["category"],
[0m[49m[38;5;10m+    2579[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    2580[0m:[38;5;10m[49m         if scope_violation["category"] == \
[0m[49m[38;5;10m+    2581[0m:[38;5;10m[49m                 "off_care_plan_treatment_recommendation":
[0m[49m[38;5;10m+    2582[0m:[38;5;10m[49m             return {
[0m[49m[38;5;10m+    2583[0m:[38;5;10m[49m                 "response":     OUT_OF_SCOPE_TREATMENT_TEMPLATE,
[0m[49m[38;5;10m+    2584[0m:[38;5;10m[49m                 "disposition":  "scope_replaced",
[0m[49m[38;5;10m+    2585[0m:[38;5;10m[49m                 "citations":    [],
[0m[49m[38;5;10m+    2586[0m:[38;5;10m[49m                 "violation":    scope_violation["category"],
[0m[49m[38;5;10m+    2587[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    2588[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    2589[0m:[38;5;10m[49m             "response":     UNGROUNDED_RESPONSE_FALLBACK,
[0m[49m[38;5;10m+    2590[0m:[38;5;10m[49m             "disposition":  "scope_replaced",
[0m[49m[38;5;10m+    2591[0m:[38;5;10m[49m             "citations":    [],
[0m[49m[38;5;10m+    2592[0m:[38;5;10m[49m             "violation":    scope_violation["category"],
[0m[49m[38;5;10m+    2593[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    2594[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    2595[0m:[38;5;10m[49m     # Step 6B: citation verification. Every recommendation
[0m[49m[38;5;10m+    2596[0m:[38;5;10m[49m     # must be grounded.
[0m[49m[38;5;10m+    2597[0m:[38;5;10m[49m     citation_check = _verify_coaching_citations(
[0m[49m[38;5;10m+    2598[0m:[38;5;10m[49m         response_text, citations, care_plan)
