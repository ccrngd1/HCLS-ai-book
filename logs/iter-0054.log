[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m # --- Versioning ---
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m # Every conversation turn carries the model version, the
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m # prompt version, the Knowledge Base versions, the Guardrail
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m # version, the active care-plan version, the active clinical-
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m # guideline-corpus version, and the active behavior-change-
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m # stage signal-logic version. This is how a future audit
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m # reconstructs which versions produced any given coaching
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m # decision.
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m PROMPT_VERSION                   = "coach-prompt-v1.0"
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m AGENT_VERSION                    = "coach-agent-v1.0"
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m STAGE_LOGIC_VERSION              = "stage-signal-v1.0"
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m INSTITUTION_ID                   = "acme-health-system"
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m INSTITUTION_DISPLAY_NAME         = "Acme Health"
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m # --- Model IDs ---
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m # Two model roles. The orchestration model handles the multi-
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m # step reasoning, the tool calls, the warm relationship-quality
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m # language, and the final response generation. The smaller
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m # model handles intent classification, behavior-change-stage
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m # estimation signals, biometric-data summarization, and
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m # engagement-message composition for routine check-ins.
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m #
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m # If your region requires cross-region inference, use the
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m # inference profile ID. TODO: verify the exact model IDs
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m # available in your region and account; Bedrock model
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m # availability evolves over time.
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m SMALL_MODEL_ID                   = "anthropic.claude-3-5-haiku-20241022-v1:0"
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m ORCHESTRATION_MODEL_ID           = "anthropic.claude-3-5-sonnet-20241022-v2:0"
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m # --- Pipeline Tuning ---
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m # Below this confidence on intent classification, ask a
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m # clarifying question rather than routing to a specific tool
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m # that will produce a low-quality answer.
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m INTENT_CONFIDENCE_THRESHOLD      = Decimal("0.70")
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m # Engagement-policy floors. Maximum proactive engagements per
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m # day per patient (the patient can dial this down through
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m # preferences; production has per-condition defaults). Quiet
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m # hours (default; patient-overridable). Engagement-fatigue
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m # threshold (declining response rate over a rolling window
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m # triggers cadence reduction).
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m MAX_DAILY_ENGAGEMENTS_DEFAULT    = 1
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m QUIET_HOURS_START_DEFAULT_LOCAL  = 21  # 9 pm
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m QUIET_HOURS_END_DEFAULT_LOCAL    = 8   # 8 am
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m ENGAGEMENT_FATIGUE_RESPONSE_RATE_FLOOR = Decimal("0.30")
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m # Behavior-change stages, in the canonical order. The coach
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m # adapts tone, pacing, and content per stage.
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m BEHAVIOR_CHANGE_STAGES = [
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m     "pre_contemplation",
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m     "contemplation",
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m     "preparation",
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m     "action",
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     "maintenance",
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m # Institution regulatory positioning: "informational" indicates
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m # the deployment is positioned as informational coaching with
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m # clinician oversight in regulated edge cases; "registered_samd"
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m # indicates the deployment is registered as Software-as-a-
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m # Medical-Device with FDA SaMD post-market obligations. The
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m # disclaimer language and the audit retention scale with this.
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m INSTITUTION_REGULATORY_POSITION  = "informational"
