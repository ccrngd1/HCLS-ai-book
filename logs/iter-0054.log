[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m def _to_decimal(obj):
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m     Recursively convert floats to Decimal for DynamoDB.
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m     DynamoDB rejects Python float values; every numeric field
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m     has to pass through Decimal on the way in. This is a
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m     recurring SDK gotcha.
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m     if isinstance(obj, float):
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m         return Decimal(str(obj))
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m     if isinstance(obj, dict):
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m         return {k: _to_decimal(v) for k, v in obj.items()}
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m     if isinstance(obj, list):
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m         return [_to_decimal(v) for v in obj]
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m     return obj
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m def _from_decimal(obj):
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m     """Inverse of _to_decimal for JSON serialization."""
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m     if isinstance(obj, Decimal):
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m         if obj % 1 == 0:
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m             return int(obj)
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m         return float(obj)
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m     if isinstance(obj, dict):
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m         return {k: _from_decimal(v) for k, v in obj.items()}
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m     if isinstance(obj, list):
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m         return [_from_decimal(v) for v in obj]
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m     return obj
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m def _now_iso() -> str:
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m     """Current UTC time in ISO-8601 format."""
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m     return datetime.now(timezone.utc).isoformat()
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m def _now() -> datetime:
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m     """Current UTC datetime."""
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m     return datetime.now(timezone.utc)
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m def _redact_pii_for_logging(text: str) -> str:
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m     """Light redaction for log lines."""
