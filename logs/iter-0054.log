[0m[49m[38;5;10m+    2009[0m:[38;5;10m[49m     if emergency["emergency_detected"]:
[0m[49m[38;5;10m+    2010[0m:[38;5;10m[49m         return _handle_emergency_routing(
[0m[49m[38;5;10m+    2011[0m:[38;5;10m[49m             session_id, patient_id, emergency)
