[0m[49m[38;5;10m+    1988[0m:[38;5;10m[49m         "speaker":        "user",
[0m[49m[38;5;10m+    1989[0m:[38;5;10m[49m         "text":           user_message,
[0m[49m[38;5;10m+    1990[0m:[38;5;10m[49m         "timestamp":      _now_iso(),
[0m[49m[38;5;10m+    1991[0m:[38;5;10m[49m     }))
[0m[49m[38;5;10m+    1992[0m:[38;5;10m[49m 
