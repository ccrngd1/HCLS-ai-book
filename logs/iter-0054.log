[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m                                      region_name=REGION,
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m                                      config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m # --- Resource Names ---
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m # Fill these in with your actual resource names. The demo
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m # prints what it would write rather than failing if the
