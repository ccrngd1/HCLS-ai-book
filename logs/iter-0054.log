[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m # time bug, not a runtime surprise.
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m for _name, _value in [
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m     ("LONGITUDINAL_STORE_TABLE",     LONGITUDINAL_STORE_TABLE),
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m     ("CONVERSATION_STATE_TABLE",     CONVERSATION_STATE_TABLE),
