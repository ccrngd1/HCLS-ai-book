[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m     ("DECISION_RECORD_TABLE",        DECISION_RECORD_TABLE),
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m     ("ENGAGEMENT_SCHEDULE_TABLE",    ENGAGEMENT_SCHEDULE_TABLE),
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m     ("BIOMETRIC_EVENT_STORE_TABLE",  BIOMETRIC_EVENT_STORE_TABLE),
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m     ("CARE_TEAM_ALERT_QUEUE_TABLE",  CARE_TEAM_ALERT_QUEUE_TABLE),
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m     ("OUTCOME_CORRELATION_TABLE",    OUTCOME_CORRELATION_TABLE),
