[0m[49m[39m  262, 191[0m:[39m[49m 
[0m[49m[38;5;9m- 263     [0m:[38;5;9m[49m **Step 1: Ingest clinical data streams.** ICU data arrives from multiple source systems at different frequencies. Bedside monitors push vitals every few seconds. Lab results arrive every few hours. Medication administrations are logged as they happen. All of these streams must be captured, ordered, and made available for feature computation. The key design choice is partitioning by patient ID so that all data for a single patient flows through the same processing path in order. Without this ordering guarantee, you might compute features using a lab result that arrived before the vital signs that preceded it chronologically. Skip this step and you have no data to score.
[0m[49m[38;5;10m+      192[0m:[38;5;10m[49m **Step 1: Extract clinical features from FHIR store.** When a prediction is triggered (either by new data arriving or by the scheduled 4-hour refresh), the system queries HealthLake for the patient's current ICU data. This includes vital signs, laboratory results, medications, and clinical assessments from the current admission. The query window matters: we want the full ICU trajectory, not just the most recent values, because temporal patterns (is the patient getting better or worse?) are among the strongest predictors. Skip this step or use stale data, and the prediction reflects yesterday's patient, not today's.
[0m[49m[39m  264, 193[0m:[39m[49m 
[0m[49m[39m  265, 194[0m:[39m[49m ```
[0m[49m[38;5;9m- 266     [0m:[38;5;9m[49m FUNCTION ingest_clinical_event(event):
[0m[49m[38;5;9m- 267     [0m:[38;5;9m[49m     // Each clinical event arrives with a patient identifier, timestamp,
[0m[49m[38;5;9m- 268     [0m:[38;5;9m[49m     // event type (vital, lab, medication, assessment), and the actual values.
[0m[49m[38;5;9m- 269     [0m:[38;5;9m[49m     // We route it to a stream partitioned by patient ID to maintain ordering.
[0m[49m[38;5;9m- 270     [0m:[38;5;9m[49m 
[0m[49m[38;5;9m- 271     [0m:[38;5;9m[49m     record = {
[0m[49m[38;5;9m- 272     [0m:[38;5;9m[49m         patient_id:   event.patient_id,          // ICU patient identifier
[0m[49m[38;5;9m- 273     [0m:[38;5;9m[49m         timestamp:    event.timestamp,            // when this measurement was taken
[0m[49m[38;5;9m- 274     [0m:[38;5;9m[49m         event_type:   event.type,                 // "vital", "lab", "medication", "assessment"
[0m[49m[38;5;9m- 275     [0m:[38;5;9m[49m         source:       event.source_system,        // which system sent this (monitor, LIS, eMAR)
[0m[49m[38;5;9m- 276     [0m:[38;5;9m[49m         values:       event.measurements          // the actual data (HR=110, SBP=85, etc.)
[0m[49m[38;5;10m+      195[0m:[38;5;10m[49m FUNCTION extract_icu_features(patient_id, admission_id):
[0m[49m[38;5;10m+      196[0m:[38;5;10m[49m     // Query the FHIR store for all relevant observations during this ICU stay.
[0m[49m[38;5;10m+      197[0m:[38;5;10m[49m     // We need vital signs, labs, medications, and assessments.
[0m[49m[38;5;10m+      198[0m:[38;5;10m[49m     // The time window is from ICU admission to now.
[0m[49m[38;5;10m+      199[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      200[0m:[38;5;10m[49m     admission = query HealthLake for Encounter where:
[0m[49m[38;5;10m+      201[0m:[38;5;10m[49m         patient = patient_id
[0m[49m[38;5;10m+      202[0m:[38;5;10m[49m         id = admission_id
[0m[49m[38;5;10m+      203[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      204[0m:[38;5;10m[49m     icu_start = admission.period.start
[0m[49m[38;5;10m+      205[0m:[38;5;10m[49m     now = current UTC timestamp
[0m[49m[38;5;10m+      206[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      207[0m:[38;5;10m[49m     // Vital signs: heart rate, blood pressure, respiratory rate, SpO2, temperature
[0m[49m[38;5;10m+      208[0m:[38;5;10m[49m     vitals = query HealthLake for Observation where:
[0m[49m[38;5;10m+      209[0m:[38;5;10m[49m         patient = patient_id
[0m[49m[38;5;10m+      210[0m:[38;5;10m[49m         category = "vital-signs"
[0m[49m[38;5;10m+      211[0m:[38;5;10m[49m         date >= icu_start
[0m[49m[38;5;10m+      212[0m:[38;5;10m[49m         date <= now
[0m[49m[38;5;10m+      213[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      214[0m:[38;5;10m[49m     // Laboratory results: metabolic panel, CBC, ABG, lactate, coagulation
[0m[49m[38;5;10m+      215[0m:[38;5;10m[49m     labs = query HealthLake for Observation where:
[0m[49m[38;5;10m+      216[0m:[38;5;10m[49m         patient = patient_id
[0m[49m[38;5;10m+      217[0m:[38;5;10m[49m         category = "laboratory"
[0m[49m[38;5;10m+      218[0m:[38;5;10m[49m         date >= icu_start
[0m[49m[38;5;10m+      219[0m:[38;5;10m[49m         date <= now
[0m[49m[38;5;10m+      220[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      221[0m:[38;5;10m[49m     // Active medications: vasopressors, sedatives, antibiotics
[0m[49m[38;5;10m+      222[0m:[38;5;10m[49m     medications = query HealthLake for MedicationAdministration where:
[0m[49m[38;5;10m+      223[0m:[38;5;10m[49m         patient = patient_id
[0m[49m[38;5;10m+      224[0m:[38;5;10m[49m         effective-time >= icu_start
[0m[49m[38;5;10m+      225[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      226[0m:[38;5;10m[49m     // Patient demographics and comorbidities
[0m[49m[38;5;10m+      227[0m:[38;5;10m[49m     patient_info = query HealthLake for Patient where id = patient_id
[0m[49m[38;5;10m+      228[0m:[38;5;10m[49m     conditions = query HealthLake for Condition where:
[0m[49m[38;5;10m+      229[0m:[38;5;10m[49m         patient = patient_id
[0m[49m[38;5;10m+      230[0m:[38;5;10m[49m         clinical-status = "active"
[0m[49m[38;5;10m+      231[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      232[0m:[38;5;10m[49m     RETURN {
[0m[49m[38;5;10m+      233[0m:[38;5;10m[49m         vitals: vitals,
[0m[49m[38;5;10m+      234[0m:[38;5;10m[49m         labs: labs,
[0m[49m[38;5;10m+      235[0m:[38;5;10m[49m         medications: medications,
[0m[49m[38;5;10m+      236[0m:[38;5;10m[49m         patient_info: patient_info,
[0m[49m[38;5;10m+      237[0m:[38;5;10m[49m         conditions: conditions,
[0m[49m[38;5;10m+      238[0m:[38;5;10m[49m         icu_start: icu_start,
