tasks = []
priority = 1
specs_base = 'specs'

for ch_num, ch_data in chapters.items():
    nn = f'{ch_num:02d}'
    preface_id = f'ch{nn}-preface'
    tasks.append({
        'id': preface_id,
        'title': f'Write Chapter {ch_num} preface: {ch_data[\"name\"]}',
        'priority': priority,
        'status': 'pending',
        'spec_path': f'{specs_base}/{preface_id}.md',
        'retry_count': 0,
        'target_persona': 'TechWriter',
        'depends_on': [],
        'tags': [f'chapter{nn}', 'preface']
    })
    priority += 1

    for rr, recipe_name, slug in ch_data['recipes']:
        draft_id = f'ch{nn}-r{rr}-draft'
        tasks.append({
            'id': draft_id,
            'title': f'Draft recipe {ch_num}.{int(rr)} {recipe_name}',
            'priority': priority,
            'status': 'pending',
            'spec_path': f'{specs_base}/{draft_id}.md',
            'retry_count': 0,
            'target_persona': 'TechWriter',
            'depends_on': [preface_id],
            'tags': [f'chapter{nn}', 'recipe', 'draft']
        })
        priority += 1

        python_id = f'ch{nn}-r{rr}-python'
        tasks.append({
            'id': python_id,
            'title': f'Draft Python companion for recipe {ch_num}.{int(rr)} {recipe_name}',
            'priority': priority,
            'status': 'pending',
            'spec_path': f'{specs_base}/{python_id}.md',
            'retry_count': 0,
            'target_persona': 'TechWriter',
            'depends_on': [draft_id],
            'tags': [f'chapter{nn}', 'recipe', 'python']
        })
        priority += 1

        code_review_id = f'ch{nn}-r{rr}-code-review'
        tasks.append({
            'id': code_review_id,
            'title': f'Code review for recipe {ch_num}.{int(rr)} {recipe_name}',
            'priority': priority,
            'status': 'pending',
            'spec_path': f'{specs_base}/{code_review_id}.md',
            'retry_count': 0,
            'target_persona': 'TechCodeReviewer',
            'depends_on': [python_id],
            'tags': [f'chapter{nn}', 'recipe', 'code-review']
        })
        priority += 1

        expert_review_id = f'ch{nn}-r{rr}-expert-review'
        tasks.append({
            'id': expert_review_id,
            'title': f'Expert review for recipe {ch_num}.{int(rr)} {recipe_name}',
            'priority': priority,
            'status': 'pending',
            'spec_path': f'{specs_base}/{expert_review_id}.md',
            'retry_count': 0,
            'target_persona': 'TechExpertReviewer',
            'depends_on': [draft_id],
            'tags': [f'chapter{nn}', 'recipe', 'expert-review']
        })
        priority += 1

        edit_id = f'ch{nn}-r{rr}-edit'
        tasks.append({
            'id': edit_id,
            'title': f'Final edit for recipe {ch_num}.{int(rr)} {recipe_name}',
            'priority': priority,
            'status': 'pending',
            'spec_path': f'{specs_base}/{edit_id}.md',
            'retry_count': 0,
            'target_persona': 'TechEditor',
            'depends_on': [code_review_id, expert_review_id],
            'tags': [f'chapter{nn}', 'recipe', 'edit']
        })
        priority += 1

with open('tasks.json', 'w', encoding='utf-8') as f:
    json.dump(tasks, f, indent=2, ensure_ascii=False)

