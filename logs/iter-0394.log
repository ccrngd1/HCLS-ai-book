[0m[49m[38;5;10m+    1318[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    1319[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1320[0m:[38;5;10m[49m What can go wrong if you skip or shortcut this: the assistant has no provenance for its assertions, the consent posture is unenforceable per data source, the sensitive-record categories are mishandled, the reconciliation is ad-hoc, and the seam-detection layer has no signal to operate on. The ingestion layer is multi-quarter engineering work for any institution that takes the assistant seriously.
[0m[49m[38;5;10m+    1321[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1322[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    1323[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1324[0m:[38;5;10m[49m **Step 3: Run the seam-detection rule engine and the protocol-trigger evaluator.** Seam detection is the assistant's distinctive value layer. The rules and the protocols are institutional content with named clinical-leadership ownership; the engine runs them deterministically (or with calibrated heuristic models) and routes detected gaps to the appropriate human or to the patient-and-caregiver engagement scheduler.
[0m[49m[38;5;10m+    1325[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1326[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    1327[0m:[38;5;10m[49m ON care_event_or_periodic_tick(patient_id, event):
[0m[49m[38;5;10m+    1328[0m:[38;5;10m[49m     // Step 3A: load the patient's coordination state and
[0m[49m[38;5;10m+    1329[0m:[38;5;10m[49m     // the relevant protocol context.
[0m[49m[38;5;10m+    1330[0m:[38;5;10m[49m     state = load_coordination_state(patient_id)
[0m[49m[38;5;10m+    1331[0m:[38;5;10m[49m     context = load_protocol_context({
[0m[49m[38;5;10m+    1332[0m:[38;5;10m[49m         patient_id: patient_id,
[0m[49m[38;5;10m+    1333[0m:[38;5;10m[49m         active_care_events: state.active_care_events
[0m[49m[38;5;10m+    1334[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    1335[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1336[0m:[38;5;10m[49m     // Step 3B: run the seam-detection rule set.
[0m[49m[38;5;10m+    1337[0m:[38;5;10m[49m     // Each rule is owned by a named clinical leader; rules
[0m[49m[38;5;10m+    1338[0m:[38;5;10m[49m     // have effective dates and version histories.
[0m[49m[38;5;10m+    1339[0m:[38;5;10m[49m     seam_findings = []
[0m[49m[38;5;10m+    1340[0m:[38;5;10m[49m     FOR each rule IN ENABLED_SEAM_RULES:
[0m[49m[38;5;10m+    1341[0m:[38;5;10m[49m         IF rule.applies_to(state, event):
[0m[49m[38;5;10m+    1342[0m:[38;5;10m[49m             finding = rule.evaluate({
[0m[49m[38;5;10m+    1343[0m:[38;5;10m[49m                 state: state,
[0m[49m[38;5;10m+    1344[0m:[38;5;10m[49m                 event: event,
[0m[49m[38;5;10m+    1345[0m:[38;5;10m[49m                 context: context
[0m[49m[38;5;10m+    1346[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    1347[0m:[38;5;10m[49m             IF finding.detected:
[0m[49m[38;5;10m+    1348[0m:[38;5;10m[49m                 seam_findings.append({
[0m[49m[38;5;10m+    1349[0m:[38;5;10m[49m                     rule_id: rule.id,
[0m[49m[38;5;10m+    1350[0m:[38;5;10m[49m                     rule_version: rule.version,
[0m[49m[38;5;10m+    1351[0m:[38;5;10m[49m                     rule_owner: rule.owner,
[0m[49m[38;5;10m+    1352[0m:[38;5;10m[49m                     finding: finding,
[0m[49m[38;5;10m+    1353[0m:[38;5;10m[49m                     confidence: finding.confidence,
[0m[49m[38;5;10m+    1354[0m:[38;5;10m[49m                     suggested_resolver:
[0m[49m[38;5;10m+    1355[0m:[38;5;10m[49m                         finding.suggested_resolver
[0m[49m[38;5;10m+    1356[0m:[38;5;10m[49m                         // values: "patient", "caregiver",
[0m[49m[38;5;10m+    1357[0m:[38;5;10m[49m                         // "care_team", "clinician",
[0m[49m[38;5;10m+    1358[0m:[38;5;10m[49m                         // "patient_and_care_team"
[0m[49m[38;5;10m+    1359[0m:[38;5;10m[49m                 })
[0m[49m[38;5;10m+    1360[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1361[0m:[38;5;10m[49m     // Step 3C: persist seam-flags to the seam-flag-store.
[0m[49m[38;5;10m+    1362[0m:[38;5;10m[49m     FOR each finding IN seam_findings:
[0m[49m[38;5;10m+    1363[0m:[38;5;10m[49m         seam_flag_id = persist_seam_flag(patient_id, finding)
[0m[49m[38;5;10m+    1364[0m:[38;5;10m[49m         emit_event("seam_flag_raised", {
[0m[49m[38;5;10m+    1365[0m:[38;5;10m[49m             patient_id: patient_id,
[0m[49m[38;5;10m+    1366[0m:[38;5;10m[49m             seam_flag_id: seam_flag_id,
[0m[49m[38;5;10m+    1367[0m:[38;5;10m[49m             rule_id: finding.rule_id,
[0m[49m[38;5;10m+    1368[0m:[38;5;10m[49m             suggested_resolver: finding.suggested_resolver
[0m[49m[38;5;10m+    1369[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    1370[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1371[0m:[38;5;10m[49m     // Step 3D: evaluate protocol triggers.
[0m[49m[38;5;10m+    1372[0m:[38;5;10m[49m     // Triggers come from the protocol library, not from LLM
[0m[49m[38;5;10m+    1373[0m:[38;5;10m[49m     // judgment. Examples: post-discharge welcome-home
[0m[49m[38;5;10m+    1374[0m:[38;5;10m[49m     // conversation within 48 hours; referral-tracking
[0m[49m[38;5;10m+    1375[0m:[38;5;10m[49m     // check-in 1 week after order if not scheduled; lab-
[0m[49m[38;5;10m+    1376[0m:[38;5;10m[49m     // result acknowledgement after clinician sign-off;
[0m[49m[38;5;10m+    1377[0m:[38;5;10m[49m     // medication-fill check after new prescription.
[0m[49m[38;5;10m+    1378[0m:[38;5;10m[49m     protocol_triggers = []
[0m[49m[38;5;10m+    1379[0m:[38;5;10m[49m     FOR each protocol IN ACTIVE_PROTOCOLS_FOR_PATIENT(state):
[0m[49m[38;5;10m+    1380[0m:[38;5;10m[49m         triggered = protocol.evaluate_triggers({
[0m[49m[38;5;10m+    1381[0m:[38;5;10m[49m             state: state,
[0m[49m[38;5;10m+    1382[0m:[38;5;10m[49m             event: event,
[0m[49m[38;5;10m+    1383[0m:[38;5;10m[49m             now: now()
[0m[49m[38;5;10m+    1384[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    1385[0m:[38;5;10m[49m         protocol_triggers.extend(triggered)
[0m[49m[38;5;10m+    1386[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1387[0m:[38;5;10m[49m     // Step 3E: schedule patient-and-caregiver engagements
[0m[49m[38;5;10m+    1388[0m:[38;5;10m[49m     // for resolvable items.
[0m[49m[38;5;10m+    1389[0m:[38;5;10m[49m     FOR each trigger IN protocol_triggers:
[0m[49m[38;5;10m+    1390[0m:[38;5;10m[49m         IF trigger.action_type == "engage_patient_or_caregiver":
[0m[49m[38;5;10m+    1391[0m:[38;5;10m[49m             schedule_engagement({
[0m[49m[38;5;10m+    1392[0m:[38;5;10m[49m                 patient_id: patient_id,
[0m[49m[38;5;10m+    1393[0m:[38;5;10m[49m                 trigger: trigger,
[0m[49m[38;5;10m+    1394[0m:[38;5;10m[49m                 target_role:
[0m[49m[38;5;10m+    1395[0m:[38;5;10m[49m                     determine_target_role(trigger, state),
[0m[49m[38;5;10m+    1396[0m:[38;5;10m[49m                 channel:
[0m[49m[38;5;10m+    1397[0m:[38;5;10m[49m                     select_channel(state.preferences, trigger),
[0m[49m[38;5;10m+    1398[0m:[38;5;10m[49m                 quiet_hours_check:
[0m[49m[38;5;10m+    1399[0m:[38;5;10m[49m                     state.preferences.quiet_hours,
[0m[49m[38;5;10m+    1400[0m:[38;5;10m[49m                 window: trigger.window
[0m[49m[38;5;10m+    1401[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    1402[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1403[0m:[38;5;10m[49m     // Step 3F: route care-team-resolvable items to alerts.
[0m[49m[38;5;10m+    1404[0m:[38;5;10m[49m     FOR each finding IN seam_findings:
[0m[49m[38;5;10m+    1405[0m:[38;5;10m[49m         IF finding.suggested_resolver IN [
[0m[49m[38;5;10m+    1406[0m:[38;5;10m[49m             "care_team", "clinician", "patient_and_care_team"]:
[0m[49m[38;5;10m+    1407[0m:[38;5;10m[49m             create_care_team_alert({
[0m[49m[38;5;10m+    1408[0m:[38;5;10m[49m                 patient_id: patient_id,
[0m[49m[38;5;10m+    1409[0m:[38;5;10m[49m                 finding: finding,
[0m[49m[38;5;10m+    1410[0m:[38;5;10m[49m                 priority:
[0m[49m[38;5;10m+    1411[0m:[38;5;10m[49m                     derive_priority(finding, state),
[0m[49m[38;5;10m+    1412[0m:[38;5;10m[49m                 routing:
[0m[49m[38;5;10m+    1413[0m:[38;5;10m[49m                     determine_routing(finding, state)
[0m[49m[38;5;10m+    1414[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    1415[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1416[0m:[38;5;10m[49m     // Step 3G: handle high-acuity events.
[0m[49m[38;5;10m+    1417[0m:[38;5;10m[49m     // Some seam findings or protocol triggers are
[0m[49m[38;5;10m+    1418[0m:[38;5;10m[49m     // immediately escalation-worthy (e.g., post-discharge
[0m[49m[38;5;10m+    1419[0m:[38;5;10m[49m     // symptoms suggestive of decompensation reported by
[0m[49m[38;5;10m+    1420[0m:[38;5;10m[49m     // the patient or caregiver; conflicting orders for
[0m[49m[38;5;10m+    1421[0m:[38;5;10m[49m     // a high-risk medication class; missed critical
[0m[49m[38;5;10m+    1422[0m:[38;5;10m[49m     // medication for an active condition).
[0m[49m[38;5;10m+    1423[0m:[38;5;10m[49m     FOR each finding IN seam_findings:
