[0m[49m[39m  182, 184[0m:[39m[49m ### Code
[0m[49m[39m  183, 185[0m:[39m[49m 
[0m[49m[39m  184, 186[0m:[39m[49m > **Reference implementations:** The following AWS resources demonstrate patterns used in this recipe:
[0m[49m[39m  185, 187[0m:[39m[49m >
[0m[49m[39m  186, 188[0m:[39m[49m > - [`amazon-sagemaker-examples`](https://github.com/aws/amazon-sagemaker-examples): SageMaker training, deployment, and monitoring patterns including time series and survival analysis examples
[0m[49m[39m  187, 189[0m:[39m[49m > - [`amazon-healthlake-toolkit`](https://github.com/aws-samples/amazon-healthlake-toolkit): HealthLake data ingestion and FHIR query patterns for clinical data
[0m[49m[39m  188, 190[0m:[39m[49m 
[0m[49m[39m  189, 191[0m:[39m[49m #### Walkthrough
[0m[49m[39m  190, 192[0m:[39m[49m 
[0m[49m[39m  191, 193[0m:[39m[49m **Step 1: Assemble longitudinal patient history.** The foundation of disease progression modeling is a complete temporal record for each patient. This step queries HealthLake (or your clinical data store) to retrieve all relevant observations, medications, conditions, and procedures for a patient cohort, organized by time. The key insight: you need not just the current values but the full history of how values changed over time. A single eGFR of 52 tells you almost nothing about trajectory. A sequence of [63, 58, 55, 52] over four years tells you the rate of decline. Skip this step or use only point-in-time snapshots, and your model has no temporal signal to learn from.
[0m[49m[39m  192, 194[0m:[39m[49m 
[0m[49m[38;5;10m+      195[0m:[38;5;10m[49m <!-- TODO (TechWriter): Expert review S-1 (HIGH). FHIR queries below should be scoped to clinically relevant data categories only (specific LOINC codes for eGFR, creatinine, HbA1c, albumin, hemoglobin, potassium; relevant condition categories like renal, cardiovascular, endocrine, metabolic). Querying all patient data violates the Minimum Necessary standard (45 CFR 164.502(b)) and may violate 42 CFR Part 2 if substance abuse records are returned. Add LOINC code filters and a note about consulting your privacy officer regarding consent requirements before assembling longitudinal datasets. -->
[0m[49m[38;5;10m+      196[0m:[38;5;10m[49m 
[0m[49m[39m  193, 197[0m:[39m[49m ```
[0m[49m[39m  194, 198[0m:[39m[49m FUNCTION assemble_patient_timeline(patient_id, lookback_years):
[0m[49m[38;5;9m- 195     [0m:[38;5;9m[49m     // Query the clinical data store for this patient's full history.
[0m[49m[38;5;10m+      199[0m:[38;5;10m[49m     // Query the clinical data store for this patient's history.
[0m[49m[39m  196, 200[0m:[39m[49m     // We need labs, vitals, medications, and diagnoses over the lookback period.
[0m[49m[39m  197, 201[0m:[39m[49m     // Each record includes a timestamp so we can reconstruct the timeline.
[0m[49m[38;5;10m+      202[0m:[38;5;10m[49m     //
[0m[49m[38;5;10m+      203[0m:[38;5;10m[49m     // IMPORTANT: Scope queries to clinically relevant data categories only.
[0m[49m[38;5;10m+      204[0m:[38;5;10m[49m     // For CKD progression, retrieve specific LOINC codes (eGFR, creatinine,
[0m[49m[38;5;10m+      205[0m:[38;5;10m[49m     // HbA1c, albumin, hemoglobin, potassium) and relevant condition categories
[0m[49m[38;5;10m+      206[0m:[38;5;10m[49m     // (renal, cardiovascular, endocrine, metabolic). Do NOT query all patient
[0m[49m[38;5;10m+      207[0m:[38;5;10m[49m     // data. The Minimum Necessary standard requires limiting access to what
[0m[49m[38;5;10m+      208[0m:[38;5;10m[49m     // the model actually uses.
[0m[49m[39m  198, 209[0m:[39m[49m 
[0m[49m[39m  199, 210[0m:[39m[49m     start_date = today minus lookback_years
[0m[49m[39m  200, 211[0m:[39m[49m 
[0m[49m[39m  201, 212[0m:[39m[49m     // Retrieve lab results (eGFR, HbA1c, creatinine, albumin, etc.)
[0m[49m[39m  202, 213[0m:[39m[49m     labs = query FHIR Observation resources where:
[0m[49m[39m  203, 214[0m:[39m[49m         patient = patient_id
[0m[49m[39m  204, 215[0m:[39m[49m         date >= start_date
[0m[49m[39m  205, 216[0m:[39m[49m         category = "laboratory"
[0m[49m[39m  206, 217[0m:[39m[49m     // Sort chronologically. Each lab has: code, value, unit, date.
[0m[49m[39m  207, 218[0m:[39m[49m 
[0m[49m[39m  208, 219[0m:[39m[49m     // Retrieve medication history (what was prescribed, when, dosage)
[0m[49m[39m  209, 220[0m:[39m[49m     medications = query FHIR MedicationRequest resources where:
[0m[49m[39m  210, 221[0m:[39m[49m         patient = patient_id
[0m[49m[39m  211, 222[0m:[39m[49m         authoredOn >= start_date
[0m[49m[39m  212, 223[0m:[39m[49m     // Each medication has: drug code, dose, start date, end date (if stopped).
[0m[49m[39m  213, 224[0m:[39m[49m 
[0m[49m[39m  214, 225[0m:[39m[49m     // Retrieve active conditions and their onset dates
[0m[49m[39m  215, 226[0m:[39m[49m     conditions = query FHIR Condition resources where:
[0m[49m[39m  216, 227[0m:[39m[49m         patient = patient_id
[0m[49m[39m  217, 228[0m:[39m[49m         onset >= start_date OR clinicalStatus = "active"
[0m[49m[39m  218, 229[0m:[39m[49m 
[0m[49m[39m  219, 230[0m:[39m[49m     // Retrieve procedures (surgeries, dialysis sessions, etc.)
[0m[49m[39m  220, 231[0m:[39m[49m     procedures = query FHIR Procedure resources where:
[0m[49m[39m  221, 232[0m:[39m[49m         patient = patient_id
[0m[49m[39m  222, 233[0m:[39m[49m         performedDateTime >= start_date
[0m[49m[39m  223, 234[0m:[39m[49m 
[0m[49m[39m  224, 235[0m:[39m[49m     // Assemble into a unified timeline structure
[0m[49m[39m  225, 236[0m:[39m[49m     timeline = {
[0m[49m[39m  226, 237[0m:[39m[49m         patient_id:   patient_id,
[0m[49m[39m  227, 238[0m:[39m[49m         labs:         labs sorted by date,
[0m[49m[39m  228, 239[0m:[39m[49m         medications:  medications sorted by start date,
[0m[49m[39m  229, 240[0m:[39m[49m         conditions:   conditions sorted by onset,
[0m[49m[39m  230, 241[0m:[39m[49m         procedures:   procedures sorted by date,
[0m[49m[39m  231, 242[0m:[39m[49m         demographics: get patient demographics (age, sex, race, zip code)
[0m[49m[39m  232, 243[0m:[39m[49m     }
[0m[49m[39m  233, 244[0m:[39m[49m 
[0m[49m[39m  234, 245[0m:[39m[49m     RETURN timeline
[0m[49m[39m  235, 246[0m:[39m[49m ```
[0m[49m[39m  236, 247[0m:[39m[49m 
[0m[49m[39m  237, 248[0m:[39m[49m **Step 2: Engineer temporal features.** Raw timeline data isn't directly usable by most models. This step transforms the longitudinal record into features that capture the dynamics of disease progression. The most important features aren't the current values; they're the rates of change, the variability, and the treatment context. A patient with eGFR declining at 5 points per year is in a very different situation than one declining at 1 point per year, even if their current eGFR is identical. This step computes those dynamics. Skip it and your model sees only snapshots, missing the trajectory information that makes progression modeling valuable.
[0m[49m[39m  238, 249[0m:[39m[49m 
[0m[49m[39m  239, 250[0m:[39m[49m ```
[0m[49m[38;5;9m- 240     [0m:[38;5;9m[49m FUNCTION engineer_progression_features(timeline):
[0m[49m[38;5;10m+      251[0m:[38;5;10m[49m FUNCTION engineer_progression_features(timeline, cutoff_date):
[0m[49m[38;5;10m+      252[0m:[38;5;10m[49m     // cutoff_date: the point in time from which we predict forward.
[0m[49m[38;5;10m+      253[0m:[38;5;10m[49m     // CRITICAL: Only use data available at cutoff_date. Using future labs
[0m[49m[38;5;10m+      254[0m:[38;5;10m[49m     // in feature computation is the #1 source of inflated metrics in
[0m[49m[38;5;10m+      255[0m:[38;5;10m[49m     // progression modeling. Every value and date below must be <= cutoff_date.
[0m[49m[38;5;10m+      256[0m:[38;5;10m[49m 
[0m[49m[39m  241, 257[0m:[39m[49m     features = empty map
[0m[49m[39m  242, 258[0m:[39m[49m 
[0m[49m[39m  243, 259[0m:[39m[49m     // --- Biomarker trajectory features ---
[0m[49m[39m  244, 260[0m:[39m[49m     // For each key lab (eGFR, HbA1c, blood pressure, etc.),
[0m[49m[39m  245, 261[0m:[39m[49m     // compute rate of change, variability, and trend.
[0m[49m[39m  246, 262[0m:[39m[49m 
[0m[49m[39m  247, 263[0m:[39m[49m     FOR each biomarker in [eGFR, HbA1c, systolic_bp, creatinine, albumin]:
[0m[49m[38;5;9m- 248     [0m:[38;5;9m[49m         values = extract values for biomarker from timeline.labs, sorted by date
[0m[49m[38;5;10m+      264[0m:[38;5;10m[49m         values = extract values for biomarker from timeline.labs
[0m[49m[38;5;10m+      265[0m:[38;5;10m[49m                  where date <= cutoff_date, sorted by date
[0m[49m[39m  249, 266[0m:[39m[49m         dates  = extract corresponding dates
[0m[49m[39m  250, 267[0m:[39m[49m 
[0m[49m[39m  251, 268[0m:[39m[49m         IF length(values) >= 2:
[0m[49m[39m  252, 269[0m:[39m[49m             // Linear slope: average rate of change per year.
[0m[49m[39m  253, 270[0m:[39m[49m             // Positive slope for eGFR = improving. Negative = declining.
[0m[49m[39m  254, 271[0m:[39m[49m             features[biomarker + "_slope_per_year"] = linear_regression_slope(dates, values)
[0m[49m[39m  255, 272[0m:[39m[49m 
[0m[49m[38;5;9m- 256     [0m:[38;5;9m[49m             // Recent slope (last 12 months) vs. overall slope.
[0m[49m[38;5;10m+      273[0m:[38;5;10m[49m             // Recent slope (last 12 months before cutoff) vs. overall slope.
[0m[49m[39m  257, 274[0m:[39m[49m             // Acceleration or deceleration of decline matters clinically.
[0m[49m[38;5;9m- 258     [0m:[38;5;9m[49m             recent_values = values from last 12 months
[0m[49m[38;5;10m+      275[0m:[38;5;10m[49m             recent_values = values from last 12 months before cutoff_date
[0m[49m[39m  259, 276[0m:[39m[49m             IF length(recent_values) >= 2:
[0m[49m[39m  260, 277[0m:[39m[49m                 features[biomarker + "_recent_slope"] = linear_regression_slope(
[0m[49m[39m  261, 278[0m:[39m[49m                     recent_dates, recent_values
[0m[49m[39m  262, 279[0m:[39m[49m                 )
[0m[49m[39m  263, 280[0m:[39m[49m 
[0m[49m[39m  264, 281[0m:[39m[49m             // Variability: standard deviation of values.
[0m[49m[39m  265, 282[0m:[39m[49m             // High variability in eGFR suggests unstable kidney function.
[0m[49m[39m  266, 283[0m:[39m[49m             features[biomarker + "_variability"] = standard_deviation(values)
[0m[49m[39m  267, 284[0m:[39m[49m 
[0m[49m[39m  268, 285[0m:[39m[49m             // Most recent value (the current state)
[0m[49m[39m  269, 286[0m:[39m[49m             features[biomarker + "_current"] = last element of values
[0m[49m[39m  270, 287[0m:[39m[49m 
[0m[49m[39m  271, 288[0m:[39m[49m             // Time since last measurement (data freshness)
[0m[49m[38;5;9m- 272     [0m:[38;5;9m[49m             features[biomarker + "_days_since_last"] = days between last date and today
[0m[49m[38;5;10m+      289[0m:[38;5;10m[49m             features[biomarker + "_days_since_last"] = days between last date and cutoff_date
[0m[49m[39m  273, 290[0m:[39m[49m 
[0m[49m[39m  274, 291[0m:[39m[49m     // --- Medication features ---
[0m[49m[39m  275, 292[0m:[39m[49m     // Encode current and historical medication exposure.
[0m[49m[39m  276, 293[0m:[39m[49m     // Which drug classes is the patient on? For how long?
[0m[49m[39m  277, 294[0m:[39m[49m 
[0m[49m[38;5;9m- 278     [0m:[38;5;9m[49m     features["ace_arb_duration_months"] = total months on ACE inhibitors or ARBs
[0m[49m[38;5;9m- 279     [0m:[38;5;9m[49m     features["diabetes_med_count"] = number of distinct diabetes medications active
