[0m[49m[38;5;10m+      296[0m:[38;5;10m[49m     features["diabetes_med_count"] = number of distinct diabetes medications active at cutoff_date
[0m[49m[38;5;10m+      297[0m:[38;5;10m[49m     features["medication_changes_12mo"] = count of medication starts/stops in 12 months before cutoff_date
