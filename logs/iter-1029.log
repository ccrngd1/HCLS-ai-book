[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m     "PAT-004": "NP-JOHNSON",
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m     "PAT-005": "DR-PATEL",
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m     "PAT-006": "NP-JOHNSON",
