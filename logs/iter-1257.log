[0m[49m[38;5;9m- 241     [0m:[38;5;9m[49m **Step 2: Call InferICD10CM for code candidates.**
[0m[49m[38;5;10m+      208[0m:[38;5;10m[49m **Step 2: Extract medical entities with negation detection.** Now we pass the cleaned text through a medical NER system. The goal is to identify every medical concept mentioned, along with whether it's affirmed, negated, or uncertain. This is where you hand the text to Amazon Comprehend Medical's DetectEntitiesV2 API. It returns structured entities with their category (condition, medication, procedure), traits (negation, diagnosis), and position in the text. The negation trait is particularly critical: "no evidence of pneumonia" should not generate a suggestion for pneumonia codes. Skip this step and feed raw text directly to the code prediction model, and you lose the ability to filter negated conditions before prediction.
[0m[49m[39m  242, 209[0m:[39m[49m 
[0m[49m[38;5;9m- 243     [0m:[38;5;9m[49m This is the core inference step. Comprehend Medical's InferICD10CM API takes clinical text and returns a list of detected medical conditions, each with one or more candidate ICD-10-CM codes ranked by confidence.
[0m[49m[38;5;9m- 244     [0m:[38;5;9m[49m 
[0m[49m[39m  245, 210[0m:[39m[49m ```pseudocode
[0m[49m[38;5;9m- 246     [0m:[38;5;9m[49m // InferICD10CM returns entities, each with:
[0m[49m[38;5;9m- 247     [0m:[38;5;9m[49m //   - Text: the original text span that triggered the detection
[0m[49m[38;5;9m- 248     [0m:[38;5;9m[49m //   - Category: MEDICAL_CONDITION (for ICD-10 relevant entities)
[0m[49m[38;5;9m- 249     [0m:[38;5;9m[49m //   - Traits: NEGATION, DIAGNOSIS, SIGN, SYMPTOM, etc.
[0m[49m[38;5;9m- 250     [0m:[38;5;9m[49m //   - ICD10CMConcepts: ranked list of {Code, Description, Score}
[0m[49m[38;5;9m- 251     [0m:[38;5;9m[49m //
[0m[49m[38;5;9m- 252     [0m:[38;5;9m[49m // The "Score" is a confidence between 0 and 1.
[0m[49m[38;5;9m- 253     [0m:[38;5;9m[49m // Scores above 0.7 are generally reliable for common diagnoses.
[0m[49m[38;5;9m- 254     [0m:[38;5;9m[49m // Scores between 0.4 and 0.7 are worth showing but need coder review.
[0m[49m[38;5;9m- 255     [0m:[38;5;9m[49m // Scores below 0.4 are noise for most use cases.
[0m[49m[38;5;9m- 256     [0m:[38;5;9m[49m 
[0m[49m[38;5;9m- 257     [0m:[38;5;9m[49m CONFIDENCE_THRESHOLD_HIGH = 0.70    // Auto-suggest to coder
[0m[49m[38;5;9m- 258     [0m:[38;5;9m[49m CONFIDENCE_THRESHOLD_LOW  = 0.40    // Show as "possible" with lower prominence
[0m[49m[38;5;9m- 259     [0m:[38;5;9m[49m MAX_CODES_PER_ENTITY      = 3       // Top N candidates per detected condition
[0m[49m[38;5;9m- 260     [0m:[38;5;9m[49m 
[0m[49m[38;5;9m- 261     [0m:[38;5;9m[49m FUNCTION get_icd10_suggestions(clinical_text):
[0m[49m[38;5;9m- 262     [0m:[38;5;9m[49m     response = call ComprehendMedical.InferICD10CM(Text = clinical_text)
[0m[49m[38;5;9m- 263     [0m:[38;5;9m[49m 
[0m[49m[38;5;9m- 264     [0m:[38;5;9m[49m     suggestions = empty list
[0m[49m[38;5;9m- 265     [0m:[38;5;9m[49m 
[0m[49m[38;5;9m- 266     [0m:[38;5;9m[49m     FOR each entity in response.Entities:
[0m[49m[38;5;9m- 267     [0m:[38;5;9m[49m         // Skip entities with negation trait
[0m[49m[38;5;9m- 268     [0m:[38;5;9m[49m         // InferICD10CM includes a NEGATION trait on entities that are negated in text
[0m[49m[38;5;9m- 269     [0m:[38;5;9m[49m         IF entity has trait "NEGATION":
[0m[49m[38;5;9m- 270     [0m:[38;5;9m[49m             CONTINUE
[0m[49m[38;5;9m- 271     [0m:[38;5;9m[49m 
[0m[49m[38;5;9m- 272     [0m:[38;5;9m[49m         // Skip entities with low entity-level confidence
[0m[49m[38;5;9m- 273     [0m:[38;5;9m[49m         IF entity.Score < CONFIDENCE_THRESHOLD_LOW:
[0m[49m[38;5;9m- 274     [0m:[38;5;9m[49m             CONTINUE
[0m[49m[38;5;9m- 275     [0m:[38;5;9m[49m 
[0m[49m[38;5;9m- 276     [0m:[38;5;9m[49m         // Extract the top N code candidates
[0m[49m[38;5;9m- 277     [0m:[38;5;9m[49m         candidates = empty list
[0m[49m[38;5;9m- 278     [0m:[38;5;9m[49m         FOR each concept in entity.ICD10CMConcepts (first MAX_CODES_PER_ENTITY):
[0m[49m[38;5;9m- 279     [0m:[38;5;9m[49m             IF concept.Score >= CONFIDENCE_THRESHOLD_LOW:
[0m[49m[38;5;9m- 280     [0m:[38;5;9m[49m                 candidates.append({
[0m[49m[38;5;9m- 281     [0m:[38;5;9m[49m                     code: concept.Code,
[0m[49m[38;5;9m- 282     [0m:[38;5;9m[49m                     description: concept.Description,
[0m[49m[38;5;9m- 283     [0m:[38;5;9m[49m                     score: concept.Score,
[0m[49m[38;5;9m- 284     [0m:[38;5;9m[49m                     tier: "high" if concept.Score >= CONFIDENCE_THRESHOLD_HIGH else "review"
[0m[49m[38;5;9m- 285     [0m:[38;5;9m[49m                 })
[0m[49m[38;5;9m- 286     [0m:[38;5;9m[49m 
[0m[49m[38;5;9m- 287     [0m:[38;5;9m[49m         IF candidates is not empty:
[0m[49m[38;5;9m- 288     [0m:[38;5;9m[49m             suggestions.append({
[0m[49m[38;5;9m- 289     [0m:[38;5;9m[49m                 evidence_text: entity.Text,
[0m[49m[38;5;9m- 290     [0m:[38;5;9m[49m                 begin_offset: entity.BeginOffset,
[0m[49m[38;5;9m- 291     [0m:[38;5;9m[49m                 end_offset: entity.EndOffset,
[0m[49m[38;5;9m- 292     [0m:[38;5;9m[49m                 entity_score: entity.Score,
[0m[49m[38;5;9m- 293     [0m:[38;5;9m[49m                 traits: entity.Traits,
[0m[49m[38;5;9m- 294     [0m:[38;5;9m[49m                 candidates: candidates
[0m[49m[38;5;9m- 295     [0m:[38;5;9m[49m             })
[0m[49m[38;5;9m- 296     [0m:[38;5;9m[49m 
[0m[49m[38;5;9m- 297     [0m:[38;5;9m[49m     RETURN suggestions
[0m[49m[38;5;10m+      211[0m:[38;5;10m[49m FUNCTION extract_entities(cleaned_text):
[0m[49m[38;5;10m+      212[0m:[38;5;10m[49m     // Call the medical NER service to identify clinical concepts in the text.
[0m[49m[38;5;10m+      213[0m:[38;5;10m[49m     // DetectEntitiesV2 returns entities with:
[0m[49m[38;5;10m+      214[0m:[38;5;10m[49m     //   - Text: the surface form ("type 2 diabetes mellitus")
[0m[49m[38;5;10m+      215[0m:[38;5;10m[49m     //   - Category: MEDICAL_CONDITION, MEDICATION, TEST_TREATMENT_PROCEDURE, etc.
[0m[49m[38;5;10m+      216[0m:[38;5;10m[49m     //   - Traits: NEGATION, DIAGNOSIS, SIGN, SYMPTOM
[0m[49m[38;5;10m+      217[0m:[38;5;10m[49m     //   - Score: confidence (0.0-1.0)
[0m[49m[38;5;10m+      218[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      219[0m:[38;5;10m[49m     response = call ComprehendMedical.DetectEntitiesV2 with:
[0m[49m[38;5;10m+      220[0m:[38;5;10m[49m         Text = cleaned_text
[0m[49m[38;5;10m+      221[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      222[0m:[38;5;10m[49m     entities = response.Entities
[0m[49m[38;5;10m+      223[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      224[0m:[38;5;10m[49m     // Separate affirmed conditions from negated ones.
[0m[49m[38;5;10m+      225[0m:[38;5;10m[49m     // Only affirmed conditions should drive code suggestions.
[0m[49m[38;5;10m+      226[0m:[38;5;10m[49m     affirmed_conditions = empty list
[0m[49m[38;5;10m+      227[0m:[38;5;10m[49m     negated_conditions  = empty list
[0m[49m[38;5;10m+      228[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      229[0m:[38;5;10m[49m     FOR each entity in entities:
[0m[49m[38;5;10m+      230[0m:[38;5;10m[49m         IF entity.Category == "MEDICAL_CONDITION":
[0m[49m[38;5;10m+      231[0m:[38;5;10m[49m             is_negated = any trait in entity.Traits where trait.Name == "NEGATION" and trait.Score > 0.85
