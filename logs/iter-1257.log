[0m[49m[38;5;9m- 203     [0m:[38;5;9m[49m The clinical note arrives from the EHR system via API call. Before sending it to Comprehend Medical, we do lightweight preprocessing: identify the note sections (if structured), validate character length, and prepare the text segments.
[0m[49m[38;5;10m+      173[0m:[38;5;10m[49m **Step 1: Receive and preprocess the clinical note.** When a coder opens an encounter in their worklist, the coding tool sends the clinical note to your API. The first step is cleaning the text for NLP processing. Clinical notes have structure that helps and structure that hurts: section headers help you weight the Assessment/Plan section more heavily; copy-forward boilerplate from prior visits hurts because it introduces stale information. This preprocessing step segments the note, identifies the highest-value sections, and normalizes common abbreviations. Skip this and your model gets confused by noise, especially template text that appears in every note regardless of the patient's conditions.
[0m[49m[39m  204, 174[0m:[39m[49m 
[0m[49m[39m  205, 175[0m:[39m[49m ```pseudocode
[0m[49m[38;5;9m- 206     [0m:[38;5;9m[49m // Clinical notes have implicit structure: HPI, ROS, A&P, etc.
[0m[49m[38;5;9m- 207     [0m:[38;5;9m[49m // The Assessment & Plan section is the most valuable for coding.
[0m[49m[38;5;9m- 208     [0m:[38;5;9m[49m // If we can identify it, we weight those suggestions higher.
[0m[49m[38;5;9m- 209     [0m:[38;5;9m[49m 
[0m[49m[38;5;9m- 210     [0m:[38;5;9m[49m SECTION_MARKERS = [
[0m[49m[38;5;9m- 211     [0m:[38;5;9m[49m     "assessment and plan", "assessment/plan", "a/p", "a&p",
[0m[49m[38;5;9m- 212     [0m:[38;5;9m[49m     "assessment:", "plan:", "impression:", "diagnoses:"
[0m[49m[38;5;9m- 213     [0m:[38;5;9m[49m ]
[0m[49m[38;5;9m- 214     [0m:[38;5;9m[49m 
[0m[49m[39m  215, 176[0m:[39m[49m FUNCTION preprocess_note(raw_note_text):
[0m[49m[38;5;9m- 216     [0m:[38;5;9m[49m     // Comprehend Medical InferICD10CM limit: 10,000 UTF-8 characters per request
[0m[49m[38;5;9m- 217     [0m:[38;5;9m[49m     IF length(raw_note_text) > 10000:
[0m[49m[38;5;9m- 218     [0m:[38;5;9m[49m         // Prioritize Assessment & Plan section
[0m[49m[38;5;9m- 219     [0m:[38;5;9m[49m         ap_section = find_section(raw_note_text, SECTION_MARKERS)
[0m[49m[38;5;9m- 220     [0m:[38;5;9m[49m         IF ap_section is not null AND length(ap_section) <= 10000:
[0m[49m[38;5;9m- 221     [0m:[38;5;9m[49m             primary_text = ap_section
[0m[49m[38;5;9m- 222     [0m:[38;5;9m[49m             supplementary_text = remainder of note (first 10000 chars)
[0m[49m[38;5;9m- 223     [0m:[38;5;9m[49m         ELSE:
[0m[49m[38;5;9m- 224     [0m:[38;5;9m[49m             primary_text = first 10000 characters of raw_note_text
[0m[49m[38;5;9m- 225     [0m:[38;5;9m[49m             supplementary_text = null
[0m[49m[38;5;9m- 226     [0m:[38;5;9m[49m     ELSE:
[0m[49m[38;5;9m- 227     [0m:[38;5;9m[49m         primary_text = raw_note_text
[0m[49m[38;5;9m- 228     [0m:[38;5;9m[49m         supplementary_text = null
[0m[49m[38;5;9m- 229     [0m:[38;5;9m[49m 
[0m[49m[38;5;9m- 230     [0m:[38;5;9m[49m     // Identify if A&P section exists for downstream weighting
[0m[49m[38;5;9m- 231     [0m:[38;5;9m[49m     has_ap_section = (find_section(raw_note_text, SECTION_MARKERS) is not null)
[0m[49m[38;5;9m- 232     [0m:[38;5;9m[49m 
[0m[49m[38;5;9m- 233     [0m:[38;5;9m[49m     RETURN {
[0m[49m[38;5;9m- 234     [0m:[38;5;9m[49m         primary_text: primary_text,
[0m[49m[38;5;9m- 235     [0m:[38;5;9m[49m         supplementary_text: supplementary_text,
[0m[49m[38;5;9m- 236     [0m:[38;5;9m[49m         has_ap_section: has_ap_section,
[0m[49m[38;5;9m- 237     [0m:[38;5;9m[49m         character_count: length(primary_text)
[0m[49m[38;5;9m- 238     [0m:[38;5;9m[49m     }
[0m[49m[38;5;10m+      177[0m:[38;5;10m[49m     // Clinical notes have predictable section headers (HPI, ROS, Assessment, Plan, etc.)
[0m[49m[38;5;10m+      178[0m:[38;5;10m[49m     // The Assessment and Plan sections carry the most coding-relevant information.
[0m[49m[38;5;10m+      179[0m:[38;5;10m[49m     // Other sections (vitals, review of systems) are useful but noisier.
[0m[49m[38;5;10m+      180[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      181[0m:[38;5;10m[49m     sections = segment_by_headers(raw_note_text)
[0m[49m[38;5;10m+      182[0m:[38;5;10m[49m     // segment_by_headers splits on known patterns like "ASSESSMENT:", "A/P:", "PLAN:"
[0m[49m[38;5;10m+      183[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      184[0m:[38;5;10m[49m     // Weight sections by coding relevance:
[0m[49m[38;5;10m+      185[0m:[38;5;10m[49m     // Assessment/Plan = primary signal
[0m[49m[38;5;10m+      186[0m:[38;5;10m[49m     // History of Present Illness = secondary signal
[0m[49m[38;5;10m+      187[0m:[38;5;10m[49m     // Medications/Problem List = supporting evidence
[0m[49m[38;5;10m+      188[0m:[38;5;10m[49m     // Review of Systems = mostly negated findings (still useful for ruling things out)
[0m[49m[38;5;10m+      189[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      190[0m:[38;5;10m[49m     priority_text = concatenate sections in order:
[0m[49m[38;5;10m+      191[0m:[38;5;10m[49m         sections["assessment_plan"]       // highest coding signal
[0m[49m[38;5;10m+      192[0m:[38;5;10m[49m         sections["hpi"]                   // describes current conditions
[0m[49m[38;5;10m+      193[0m:[38;5;10m[49m         sections["problem_list"]          // explicit condition list
[0m[49m[38;5;10m+      194[0m:[38;5;10m[49m         sections["medications"]           // implies conditions being treated
[0m[49m[38;5;10m+      195[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      196[0m:[38;5;10m[49m     // Normalize abbreviations that confuse NLP models
[0m[49m[38;5;10m+      197[0m:[38;5;10m[49m     // "HTN" -> "hypertension", "DM2" -> "type 2 diabetes", "CHF" -> "congestive heart failure"
[0m[49m[38;5;10m+      198[0m:[38;5;10m[49m     normalized_text = expand_abbreviations(priority_text, CLINICAL_ABBREV_MAP)
[0m[49m[38;5;10m+      199[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      200[0m:[38;5;10m[49m     // Remove copy-forward artifacts: text blocks identical to prior encounters.
[0m[49m[38;5;10m+      201[0m:[38;5;10m[49m     // These introduce stale conditions that may no longer apply.
[0m[49m[38;5;10m+      202[0m:[38;5;10m[49m     // In production, compare against the patient's last 3-5 notes to detect copy-forward.
[0m[49m[38;5;10m+      203[0m:[38;5;10m[49m     cleaned_text = remove_duplicate_blocks(normalized_text)
[0m[49m[38;5;10m+      204[0m:[38;5;10m[49m     
[0m[49m[38;5;10m+      205[0m:[38;5;10m[49m     RETURN cleaned_text
