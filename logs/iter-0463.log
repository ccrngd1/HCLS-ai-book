[0m[49m[38;5;10m+    1260[0m:[38;5;10m[49m             "slope_per_month":           slope_per_month,
[0m[49m[38;5;10m+    1261[0m:[38;5;10m[49m             "slope_p_value":             p_value,
[0m[49m[38;5;10m+    1262[0m:[38;5;10m[49m             "deviation_from_baseline":   deviation,
[0m[49m[38;5;10m+    1263[0m:[38;5;10m[49m             "trend_duration_days":       duration_days,
[0m[49m[38;5;10m+    1264[0m:[38;5;10m[49m             "most_recent_value":         latest_value,
[0m[49m[38;5;10m+    1265[0m:[38;5;10m[49m             "baseline_value":            baseline_value,
[0m[49m[38;5;10m+    1266[0m:[38;5;10m[49m             "method_diagnostics": {
