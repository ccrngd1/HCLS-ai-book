[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m     covers the common cases (int, float, str-of-number, None) and
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m     lets exotic types fail loudly rather than silently.
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m     if value is None:
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m     if isinstance(value, Decimal):
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m         return value
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m     if isinstance(value, bool):
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m         # bool is a subclass of int in Python; route it explicitly
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m         # so True does not become Decimal('1') unexpectedly.
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m         return value
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m     if isinstance(value, (int, float)):
