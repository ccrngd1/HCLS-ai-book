[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m     "718-7": {    # Hemoglobin
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m         "display":             "Hemoglobin",
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m         "canonical_unit":      "g/dL",
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m         "molecular_weight":    None,
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m         "umol_factor":         None,
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m         "detector":            "theil_sen",
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m         "rules": {
