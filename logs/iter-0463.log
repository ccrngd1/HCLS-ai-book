[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m # --- Source-System to LOINC Mapping ---
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m # Local lab dictionaries vary; production maintains a curated
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m # mapping table with vendor-specific source codes. The demo's
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m # entries cover a few realistic source codes per LOINC.
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m SOURCE_CODE_TO_LOINC = {
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m     ("EPIC", "CREAT"):     "2160-0",
