[0m[49m[38;5;10m+    938[0m:[38;5;10m[49m     baseline_value      = _interquartile_mean(values)
[0m[49m[38;5;10m+    939[0m:[38;5;10m[49m     baseline_dispersion = _median_absolute_deviation(values)
[0m[49m[38;5;10m+    940[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    941[0m:[38;5;10m[49m     baseline = {
[0m[49m[38;5;10m+    942[0m:[38;5;10m[49m         "patient_id":          patient_id,
[0m[49m[38;5;10m+    943[0m:[38;5;10m[49m         "loinc_code":          loinc_code,
[0m[49m[38;5;10m+    944[0m:[38;5;10m[49m         "status":              "ready",
