[49m[38;5;10m+     980[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     981[0m:[38;5;10m[49m ## Step 3: Run Trend Detection
[0m[49m[38;5;10m+     982[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     983[0m:[38;5;10m[49m Different labs benefit from different detectors. The demo implements four pedagogical detectors that share a common `run` interface so the per-LOINC routing is straightforward:
[0m[49m[38;5;10m+     984[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     985[0m:[38;5;10m[49m - **Theil-Sen plus Mann-Kendall** for slow chronic-disease slopes (creatinine, A1c, hemoglobin). Theil-Sen is a non-parametric slope estimator robust to outliers; Mann-Kendall is a non-parametric rank test for monotonic trend significance.
[0m[49m[38;5;10m+     986[0m:[38;5;10m[49m - **CUSUM (cumulative sum)** for change-point detection on previously-stable patients (platelets dropping after a regimen change).
[0m[49m[38;5;10m+     987[0m:[38;5;10m[49m - **Kalman state-space filter** for irregularly sampled labs that benefit from continuous-time estimation with calibrated uncertainty (TSH).
[0m[49m[38;5;10m+     988[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     989[0m:[38;5;10m[49m Production swaps these for the corresponding statsmodels, scipy, and pykalman implementations. The interface (`run(recent_values, baseline_value, baseline_dispersion) -> trend dict`) is what matters for the routing logic.
[0m[49m[38;5;10m+     990[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     991[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     992[0m:[38;5;10m[49m def _days_between_iso(ts_a, ts_b):
[0m[49m[38;5;10m+     993[0m:[38;5;10m[49m     """Days from ts_a to ts_b, both ISO strings."""
[0m[49m[38;5;10m+     994[0m:[38;5;10m[49m     a = datetime.fromisoformat(ts_a)
[0m[49m[38;5;10m+     995[0m:[38;5;10m[49m     b = datetime.fromisoformat(ts_b)
[0m[49m[38;5;10m+     996[0m:[38;5;10m[49m     return (b - a).total_seconds() / 86400.0
[0m[49m[38;5;10m+     997[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     998[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     999[0m:[38;5;10m[49m class TheilSenDetector:
[0m[49m[38;5;10m+    1000[0m:[38;5;10m[49m     """Pedagogical Theil-Sen + Mann-Kendall detector.
[0m[49m[38;5;10m+    1001[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1002[0m:[38;5;10m[49m     Production uses scipy.stats.theilslopes for the slope and
[0m[49m[38;5;10m+    1003[0m:[38;5;10m[49m     scipy.stats.kendalltau (or pymannkendall.original_test) for
[0m[49m[38;5;10m+    1004[0m:[38;5;10m[49m     the trend-significance test. The demo computes both from
[0m[49m[38;5;10m+    1005[0m:[38;5;10m[49m     primitives so the math is visible.
[0m[49m[38;5;10m+    1006[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1007[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1008[0m:[38;5;10m[49m     name = "theil_sen"
[0m[49m[38;5;10m+    1009[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1010[0m:[38;5;10m[49m     def run(self, recent, baseline_value, baseline_dispersion):
[0m[49m[38;5;10m+    1011[0m:[38;5;10m[49m         """Compute a normalized trend object for a recent series."""
[0m[49m[38;5;10m+    1012[0m:[38;5;10m[49m         if len(recent) < 3:
[0m[49m[38;5;10m+    1013[0m:[38;5;10m[49m             return {"trend_status": "insufficient_data"}
[0m[49m[38;5;10m+    1014[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1015[0m:[38;5;10m[49m         # Convert to (days_from_start, value) pairs so the slope
[0m[49m[38;5;10m+    1016[0m:[38;5;10m[49m         # is per day and easy to convert to per-month.
[0m[49m[38;5;10m+    1017[0m:[38;5;10m[49m         first_ts = recent[0]["effective_dt"]
[0m[49m[38;5;10m+    1018[0m:[38;5;10m[49m         points = [
[0m[49m[38;5;10m+    1019[0m:[38;5;10m[49m             (_days_between_iso(first_ts, o["effective_dt"]),
[0m[49m[38;5;10m+    1020[0m:[38;5;10m[49m              float(o["value_quantity"]))
[0m[49m[38;5;10m+    1021[0m:[38;5;10m[49m             for o in recent
[0m[49m[38;5;10m+    1022[0m:[38;5;10m[49m         ]
[0m[49m[38;5;10m+    1023[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1024[0m:[38;5;10m[49m         # Theil-Sen slope: median of all pairwise slopes. Robust
[0m[49m[38;5;10m+    1025[0m:[38;5;10m[49m         # to outliers and does not assume normality. The demo's
[0m[49m[38;5;10m+    1026[0m:[38;5;10m[49m         # pure-Python version is O(n^2); scipy has an O(n log n)
[0m[49m[38;5;10m+    1027[0m:[38;5;10m[49m         # variant when n is large.
[0m[49m[38;5;10m+    1028[0m:[38;5;10m[49m         pairwise = []
[0m[49m[38;5;10m+    1029[0m:[38;5;10m[49m         for i in range(len(points)):
[0m[49m[38;5;10m+    1030[0m:[38;5;10m[49m             for j in range(i + 1, len(points)):
[0m[49m[38;5;10m+    1031[0m:[38;5;10m[49m                 dx = points[j][0] - points[i][0]
[0m[49m[38;5;10m+    1032[0m:[38;5;10m[49m                 dy = points[j][1] - points[i][1]
[0m[49m[38;5;10m+    1033[0m:[38;5;10m[49m                 if dx > 0:
[0m[49m[38;5;10m+    1034[0m:[38;5;10m[49m                     pairwise.append(dy / dx)
[0m[49m[38;5;10m+    1035[0m:[38;5;10m[49m         if not pairwise:
[0m[49m[38;5;10m+    1036[0m:[38;5;10m[49m             return {"trend_status": "insufficient_data"}
[0m[49m[38;5;10m+    1037[0m:[38;5;10m[49m         slope_per_day = median(pairwise)
[0m[49m[38;5;10m+    1038[0m:[38;5;10m[49m         slope_per_month = slope_per_day * 30.0
[0m[49m[38;5;10m+    1039[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1040[0m:[38;5;10m[49m         # Mann-Kendall S statistic and a normal-approximation
[0m[49m[38;5;10m+    1041[0m:[38;5;10m[49m         # p-value. For each pair (i, j) with i < j: +1 if
[0m[49m[38;5;10m+    1042[0m:[38;5;10m[49m         # values[j] > values[i], -1 if less, 0 if tied.
[0m[49m[38;5;10m+    1043[0m:[38;5;10m[49m         n = len(points)
[0m[49m[38;5;10m+    1044[0m:[38;5;10m[49m         s = 0
[0m[49m[38;5;10m+    1045[0m:[38;5;10m[49m         for i in range(n):
[0m[49m[38;5;10m+    1046[0m:[38;5;10m[49m             for j in range(i + 1, n):
[0m[49m[38;5;10m+    1047[0m:[38;5;10m[49m                 vi, vj = points[i][1], points[j][1]
[0m[49m[38;5;10m+    1048[0m:[38;5;10m[49m                 if   vj > vi: s += 1
[0m[49m[38;5;10m+    1049[0m:[38;5;10m[49m                 elif vj < vi: s -= 1
[0m[49m[38;5;10m+    1050[0m:[38;5;10m[49m         # Variance under H0 of no trend (no ties correction).
[0m[49m[38;5;10m+    1051[0m:[38;5;10m[49m         var_s = (n * (n - 1) * (2 * n + 5)) / 18.0
[0m[49m[38;5;10m+    1052[0m:[38;5;10m[49m         if var_s <= 0:
[0m[49m[38;5;10m+    1053[0m:[38;5;10m[49m             z = 0.0
[0m[49m[38;5;10m+    1054[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    1055[0m:[38;5;10m[49m             sd = math.sqrt(var_s)
[0m[49m[38;5;10m+    1056[0m:[38;5;10m[49m             if   s > 0: z = (s - 1) / sd
[0m[49m[38;5;10m+    1057[0m:[38;5;10m[49m             elif s < 0: z = (s + 1) / sd
[0m[49m[38;5;10m+    1058[0m:[38;5;10m[49m             else:       z = 0.0
[0m[49m[38;5;10m+    1059[0m:[38;5;10m[49m         # Two-sided normal approximation for the p-value.
[0m[49m[38;5;10m+    1060[0m:[38;5;10m[49m         p_value = 2.0 * (1.0 - _normal_cdf(abs(z)))
[0m[49m[38;5;10m+    1061[0m:[38;5;10m[49m         # Floor the p-value so log/format calls do not surprise.
[0m[49m[38;5;10m+    1062[0m:[38;5;10m[49m         p_value = max(min(p_value, 1.0), 1e-6)
[0m[49m[38;5;10m+    1063[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1064[0m:[38;5;10m[49m         latest_value = points[-1][1]
[0m[49m[38;5;10m+    1065[0m:[38;5;10m[49m         deviation = latest_value - baseline_value
[0m[49m[38;5;10m+    1066[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1067[0m:[38;5;10m[49m         # Trend duration approximated as the span of the recent
[0m[49m[38;5;10m+    1068[0m:[38;5;10m[49m         # window (days between first and last point). Production
[0m[49m[38;5;10m+    1069[0m:[38;5;10m[49m         # may run a change-point detection upstream and use the
[0m[49m[38;5;10m+    1070[0m:[38;5;10m[49m         # detected change-point as the trend start.
[0m[49m[38;5;10m+    1071[0m:[38;5;10m[49m         duration_days = points[-1][0] - points[0][0]
[0m[49m[38;5;10m+    1072[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1073[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+    1074[0m:[38;5;10m[49m             "trend_status":              "ok",
[0m[49m[38;5;10m+    1075[0m:[38;5;10m[49m             "method":                    self.name,
[0m[49m[38;5;10m+    1076[0m:[38;5;10m[49m             "slope_per_month":           slope_per_month,
[0m[49m[38;5;10m+    1077[0m:[38;5;10m[49m             "slope_p_value":             p_value,
[0m[49m[38;5;10m+    1078[0m:[38;5;10m[49m             "deviation_from_baseline":   deviation,
[0m[49m[38;5;10m+    1079[0m:[38;5;10m[49m             "trend_duration_days":       duration_days,
[0m[49m[38;5;10m+    1080[0m:[38;5;10m[49m             "most_recent_value":         latest_value,
[0m[49m[38;5;10m+    1081[0m:[38;5;10m[49m             "baseline_value":            baseline_value,
[0m[49m[38;5;10m+    1082[0m:[38;5;10m[49m             "method_diagnostics": {
[0m[49m[38;5;10m+    1083[0m:[38;5;10m[49m                 "mann_kendall_s":         s,
[0m[49m[38;5;10m+    1084[0m:[38;5;10m[49m                 "mann_kendall_z":         z,
[0m[49m[38;5;10m+    1085[0m:[38;5;10m[49m                 "sample_count_recent":    n,
[0m[49m[38;5;10m+    1086[0m:[38;5;10m[49m                 "theil_sen_pairwise":     len(pairwise),
[0m[49m[38;5;10m+    1087[0m:[38;5;10m[49m             },
[0m[49m[38;5;10m+    1088[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1089[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1090[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1091[0m:[38;5;10m[49m def _normal_cdf(z):
[0m[49m[38;5;10m+    1092[0m:[38;5;10m[49m     """Standard normal CDF using the error function approximation."""
[0m[49m[38;5;10m+    1093[0m:[38;5;10m[49m     return 0.5 * (1.0 + math.erf(z / math.sqrt(2.0)))
[0m[49m[38;5;10m+    1094[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1095[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1096[0m:[38;5;10m[49m class CUSUMDetector:
[0m[49m[38;5;10m+    1097[0m:[38;5;10m[49m     """Pedagogical CUSUM change-point detector.
[0m[49m[38;5;10m+    1098[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1099[0m:[38;5;10m[49m     Tracks the cumulative sum of deviations from the baseline.
[0m[49m[38;5;10m+    1100[0m:[38;5;10m[49m     A run that exceeds a control-limit multiple of the baseline
[0m[49m[38;5;10m+    1101[0m:[38;5;10m[49m     dispersion signals a change point. Production uses
[0m[49m[38;5;10m+    1102[0m:[38;5;10m[49m     scipy.signal-style implementations or ruptures.detection.Pelt
[0m[49m[38;5;10m+    1103[0m:[38;5;10m[49m     for more sophisticated change-point detection.
[0m[49m[38;5;10m+    1104[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1105[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1106[0m:[38;5;10m[49m     name             = "cusum"
[0m[49m[38;5;10m+    1107[0m:[38;5;10m[49m     K_FACTOR         = 0.5     # slack parameter (multiples of dispersion)
[0m[49m[38;5;10m+    1108[0m:[38;5;10m[49m     H_FACTOR         = 4.0     # control limit (multiples of dispersion)
[0m[49m[38;5;10m+    1109[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1110[0m:[38;5;10m[49m     def run(self, recent, baseline_value, baseline_dispersion):
[0m[49m[38;5;10m+    1111[0m:[38;5;10m[49m         if len(recent) < 4:
[0m[49m[38;5;10m+    1112[0m:[38;5;10m[49m             return {"trend_status": "insufficient_data"}
[0m[49m[38;5;10m+    1113[0m:[38;5;10m[49m         if baseline_dispersion <= 0:
[0m[49m[38;5;10m+    1114[0m:[38;5;10m[49m             baseline_dispersion = max(0.05 * abs(baseline_value), 1e-3)
[0m[49m[38;5;10m+    1115[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1116[0m:[38;5;10m[49m         first_ts = recent[0]["effective_dt"]
[0m[49m[38;5;10m+    1117[0m:[38;5;10m[49m         points = [
[0m[49m[38;5;10m+    1118[0m:[38;5;10m[49m             (_days_between_iso(first_ts, o["effective_dt"]),
[0m[49m[38;5;10m+    1119[0m:[38;5;10m[49m              float(o["value_quantity"]))
[0m[49m[38;5;10m+    1120[0m:[38;5;10m[49m             for o in recent
[0m[49m[38;5;10m+    1121[0m:[38;5;10m[49m         ]
[0m[49m[38;5;10m+    1122[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1123[0m:[38;5;10m[49m         # Standardize the slack and limit by the baseline dispersion.
[0m[49m[38;5;10m+    1124[0m:[38;5;10m[49m         k = self.K_FACTOR * baseline_dispersion
[0m[49m[38;5;10m+    1125[0m:[38;5;10m[49m         h = self.H_FACTOR * baseline_dispersion
[0m[49m[38;5;10m+    1126[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1127[0m:[38;5;10m[49m         # Track the high-side and low-side cumulative sums.
[0m[49m[38;5;10m+    1128[0m:[38;5;10m[49m         cusum_pos = 0.0
[0m[49m[38;5;10m+    1129[0m:[38;5;10m[49m         cusum_neg = 0.0
[0m[49m[38;5;10m+    1130[0m:[38;5;10m[49m         change_idx_pos = None
[0m[49m[38;5;10m+    1131[0m:[38;5;10m[49m         change_idx_neg = None
[0m[49m[38;5;10m+    1132[0m:[38;5;10m[49m         for i, (_, v) in enumerate(points):
[0m[49m[38;5;10m+    1133[0m:[38;5;10m[49m             cusum_pos = max(0.0, cusum_pos + (v - baseline_value) - k)
[0m[49m[38;5;10m+    1134[0m:[38;5;10m[49m             cusum_neg = min(0.0, cusum_neg + (v - baseline_value) + k)
[0m[49m[38;5;10m+    1135[0m:[38;5;10m[49m             if cusum_pos > h and change_idx_pos is None:
[0m[49m[38;5;10m+    1136[0m:[38;5;10m[49m                 change_idx_pos = i
[0m[49m[38;5;10m+    1137[0m:[38;5;10m[49m             if cusum_neg < -h and change_idx_neg is None:
[0m[49m[38;5;10m+    1138[0m:[38;5;10m[49m                 change_idx_neg = i
[0m[49m[38;5;10m+    1139[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1140[0m:[38;5;10m[49m         # Decide which direction (if any) triggered the alarm.
[0m[49m[38;5;10m+    1141[0m:[38;5;10m[49m         change_idx = None
[0m[49m[38;5;10m+    1142[0m:[38;5;10m[49m         direction  = None
[0m[49m[38;5;10m+    1143[0m:[38;5;10m[49m         if change_idx_pos is not None and change_idx_neg is None:
[0m[49m[38;5;10m+    1144[0m:[38;5;10m[49m             change_idx = change_idx_pos; direction = "rising"
[0m[49m[38;5;10m+    1145[0m:[38;5;10m[49m         elif change_idx_neg is not None and change_idx_pos is None:
[0m[49m[38;5;10m+    1146[0m:[38;5;10m[49m             change_idx = change_idx_neg; direction = "falling"
[0m[49m[38;5;10m+    1147[0m:[38;5;10m[49m         elif change_idx_pos is not None and change_idx_neg is not None:
[0m[49m[38;5;10m+    1148[0m:[38;5;10m[49m             # Whichever fired first wins.
[0m[49m[38;5;10m+    1149[0m:[38;5;10m[49m             if change_idx_pos <= change_idx_neg:
[0m[49m[38;5;10m+    1150[0m:[38;5;10m[49m                 change_idx = change_idx_pos; direction = "rising"
[0m[49m[38;5;10m+    1151[0m:[38;5;10m[49m             else:
[0m[49m[38;5;10m+    1152[0m:[38;5;10m[49m                 change_idx = change_idx_neg; direction = "falling"
[0m[49m[38;5;10m+    1153[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1154[0m:[38;5;10m[49m         latest_value = points[-1][1]
[0m[49m[38;5;10m+    1155[0m:[38;5;10m[49m         deviation    = latest_value - baseline_value
[0m[49m[38;5;10m+    1156[0m:[38;5;10m[49m         # Trend slope is the average slope from the change point
[0m[49m[38;5;10m+    1157[0m:[38;5;10m[49m         # forward, scaled to per-month for the consumer.
[0m[49m[38;5;10m+    1158[0m:[38;5;10m[49m         slope_per_month = 0.0
[0m[49m[38;5;10m+    1159[0m:[38;5;10m[49m         duration_days   = 0.0
[0m[49m[38;5;10m+    1160[0m:[38;5;10m[49m         if change_idx is not None and change_idx < len(points) - 1:
[0m[49m[38;5;10m+    1161[0m:[38;5;10m[49m             change_day  = points[change_idx][0]
[0m[49m[38;5;10m+    1162[0m:[38;5;10m[49m             latest_day  = points[-1][0]
[0m[49m[38;5;10m+    1163[0m:[38;5;10m[49m             duration_days = latest_day - change_day
[0m[49m[38;5;10m+    1164[0m:[38;5;10m[49m             if duration_days > 0:
[0m[49m[38;5;10m+    1165[0m:[38;5;10m[49m                 slope_per_day = ((points[-1][1] - points[change_idx][1])
[0m[49m[38;5;10m+    1166[0m:[38;5;10m[49m                                  / duration_days)
[0m[49m[38;5;10m+    1167[0m:[38;5;10m[49m                 slope_per_month = slope_per_day * 30.0
[0m[49m[38;5;10m+    1168[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    1169[0m:[38;5;10m[49m             # No change point fired. Report the trend as flat.
[0m[49m[38;5;10m+    1170[0m:[38;5;10m[49m             duration_days = points[-1][0] - points[0][0]
[0m[49m[38;5;10m+    1171[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1172[0m:[38;5;10m[49m         # Approximate p-value: a Z-style ratio of the final
[0m[49m[38;5;10m+    1173[0m:[38;5;10m[49m         # CUSUM magnitude over the control limit. Production uses
[0m[49m[38;5;10m+    1174[0m:[38;5;10m[49m         # the proper ARL-based threshold; this is illustrative.
[0m[49m[38;5;10m+    1175[0m:[38;5;10m[49m         max_cusum = max(abs(cusum_pos), abs(cusum_neg))
[0m[49m[38;5;10m+    1176[0m:[38;5;10m[49m         z_like    = max_cusum / max(h, 1e-6)
[0m[49m[38;5;10m+    1177[0m:[38;5;10m[49m         p_value   = max(min(2.0 * (1.0 - _normal_cdf(z_like)), 1.0), 1e-6)
[0m[49m[38;5;10m+    1178[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1179[0m:[38;5;10m[49m         return {
