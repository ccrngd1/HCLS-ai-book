[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m         # repr surprise (Decimal(0.1) is not Decimal('0.1')).
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m         return Decimal(str(round(float(value), 6)))
