[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m def harmonize_lab_result(raw_result, healthlake, s3, bucket):
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m     """Step 1: Map source code to LOINC, convert units, tag context.
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m     See pseudocode Step 1 in the main recipe. Returns the
[0m[49m[38;5;10m+    725[0m:[38;5;10m[49m     harmonized record on success, or None if mapping or conversion
[0m[49m[38;5;10m+    726[0m:[38;5;10m[49m     failed (in which case the record is logged for manual review).
[0m[49m[38;5;10m+    727[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    728[0m:[38;5;10m[49m     # 1a. Look up the canonical LOINC code for the source-system
[0m[49m[38;5;10m+    729[0m:[38;5;10m[49m     # test code. Failing the mapping is far better than guessing;
