[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m     if loinc_code == "777-3":
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m         equivalent_units = {"10*3/uL", "K/uL", "10^9/L", "10*9/L"}
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m         if from_unit in equivalent_units and to_unit in equivalent_units:
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m             return float(value)
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m 
