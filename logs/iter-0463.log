[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m                 "Time":  datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m def generate_synthetic_lab_results(history_days=SYNTHETIC_HISTORY_DAYS,
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m                                    seed=SYNTHETIC_RANDOM_SEED):
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m     """Generate synthetic longitudinal lab results for a small panel of patients.
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m     Production reads from Amazon HealthLake (or an HL7 ORU-R01
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m     landing zone on S3). The demo synthesizes four illustrative
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m     chronic-disease trajectories so you can see the pipeline
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m     detect what it should and ignore what it should:
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m       patient-CKD-001  - Slowly rising creatinine over 14 months
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m                          (should surface).
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m       patient-DM-002   - Drifting A1c with a recent regimen-change
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m                          uplift (should surface).
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m       patient-BMS-003  - Falling platelets on a marrow-suppressing
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m                          regimen (should surface as change-point).
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m       patient-EUTH-004 - Stable TSH and creatinine, normal patient
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m                          (should not surface).
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m     Each result is emitted as a synthetic source-system row with
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m     the source code, raw value, raw unit, encounter class, and
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m     issuing-lab reference range. The harmonization step is what
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m     turns these into canonical LOINC + UCUM observations.
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m     rng = random.Random(seed)
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m     end_d   = date.today()
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m     start_d = end_d - timedelta(days=history_days)
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m     raw_results = []
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m     # --- patient-CKD-001: slowly rising creatinine ---
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m     # Most chronic ambulatory results, a few inpatient acute
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m     # results sprinkled in (which the chronic pipeline must
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m     # exclude). Slope around 0.06 mg/dL per month, baseline 1.18,
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m     # current value around 1.6.
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m     creat_dates = []
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m     cursor = start_d + timedelta(days=14)
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m     while cursor <= end_d:
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m         creat_dates.append(cursor)
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m         # Every ~90 days for chronic monitoring.
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m         cursor += timedelta(days=rng.randint(78, 102))
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m     base_creat = 1.18
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m     slope_per_day_ckd = 0.06 / 30.0
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m     for i, d in enumerate(creat_dates):
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m         # Small per-result noise plus the long-term slope.
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m         days_in = (d - creat_dates[0]).days
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m         value = base_creat + slope_per_day_ckd * days_in + rng.gauss(0, 0.05)
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m         # Most results from EPIC, ambulatory.
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m         raw_results.append({
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m             "patient_id":          "patient-CKD-001",
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m             "source_system":       "EPIC",
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m             "source_test_code":    "CR",
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m             "value":               round(value, 2),
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m             "unit":                "mg/dL",
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m             "ref_low":             0.70,
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m             "ref_high":            1.30,
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m             "ref_unit":            "mg/dL",
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m             "collection_ts":       datetime(d.year, d.month, d.day, 8, 0, 0).isoformat(),
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m             "encounter_class":     "ambulatory",
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m             "lab_id":              "central-lab-A",
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m             "method_or_analyzer":  "enzymatic",
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m     # Two acute-context results during a hospitalization that
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m     # should NOT be in the chronic baseline. These are spikes
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m     # the chronic pipeline must exclude.
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m     for offset_days in (220, 222):
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m         d = start_d + timedelta(days=offset_days)
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m         raw_results.append({
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m             "patient_id":          "patient-CKD-001",
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m             "source_system":       "EPIC",
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m             "source_test_code":    "CR",
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m             "value":               2.4 + rng.gauss(0, 0.1),
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m             "unit":                "mg/dL",
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m             "ref_low":             0.70,
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m             "ref_high":            1.30,
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m             "ref_unit":            "mg/dL",
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m             "collection_ts":       datetime(d.year, d.month, d.day, 14, 0, 0).isoformat(),
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m             "encounter_class":     "inpatient",
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m             "lab_id":              "central-lab-A",
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m             "method_or_analyzer":  "enzymatic",
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m     # --- patient-DM-002: drifting A1c ---
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m     # Quarterly A1c, baseline 7.2, recent uplift to 8.4 over the
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m     # last 9 months (regimen quietly failing).
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m     a1c_dates = []
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m     cursor = start_d + timedelta(days=21)
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m     while cursor <= end_d:
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m         a1c_dates.append(cursor)
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m         cursor += timedelta(days=rng.randint(85, 100))
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m     n = len(a1c_dates)
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m     breakpoint_idx = max(0, n - 4)
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m     base_a1c = 7.2
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m     for i, d in enumerate(a1c_dates):
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m         if i < breakpoint_idx:
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m             value = base_a1c + rng.gauss(0, 0.15)
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m             months_since_break = (i - breakpoint_idx + 1) * 3
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m             value = base_a1c + 0.13 * months_since_break + rng.gauss(0, 0.15)
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m         raw_results.append({
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m             "patient_id":          "patient-DM-002",
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m             "source_system":       "CERNER",
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m             "source_test_code":    "13458",
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m             "value":               round(value, 2),
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m             "unit":                "%",
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m             "ref_low":             4.0,
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m             "ref_high":            5.6,
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m             "ref_unit":            "%",
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m             "collection_ts":       datetime(d.year, d.month, d.day, 9, 0, 0).isoformat(),
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m             "encounter_class":     "ambulatory",
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m             "lab_id":              "central-lab-B",
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m             "method_or_analyzer":  "HPLC",
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m     # --- patient-BMS-003: falling platelets (change-point) ---
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m     # Stable around 220 for 18 months, then a sustained drop to
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m     # ~120 over the last 4 months on a marrow-suppressing regimen.
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m     plt_dates = []
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m     cursor = start_d + timedelta(days=10)
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m     while cursor <= end_d:
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m         plt_dates.append(cursor)
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m         cursor += timedelta(days=rng.randint(28, 35))
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m     n = len(plt_dates)
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m     breakpoint_idx = max(0, n - 5)
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m     for i, d in enumerate(plt_dates):
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m         if i < breakpoint_idx:
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m             value = 220 + rng.gauss(0, 12)
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m             steps_after = i - breakpoint_idx
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m             value = 220 - 22 * steps_after + rng.gauss(0, 8)
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m             value = max(50, value)
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m         raw_results.append({
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m             "patient_id":          "patient-BMS-003",
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m             "source_system":       "EPIC",
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m             "source_test_code":    "PLT",
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m             "value":               round(value, 0),
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m             "unit":                "10*3/uL",
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m             "ref_low":             150.0,
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m             "ref_high":            450.0,
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m             "ref_unit":            "10*3/uL",
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m             "collection_ts":       datetime(d.year, d.month, d.day, 8, 30, 0).isoformat(),
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m             "encounter_class":     "ambulatory",
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m             "lab_id":              "central-lab-A",
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m             "method_or_analyzer":  "impedance",
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m     # --- patient-EUTH-004: stable, no concerning trend ---
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m     # Routine annual TSH around 2.0 mIU/L with normal noise.
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m     tsh_dates = []
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m     cursor = start_d + timedelta(days=30)
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m     while cursor <= end_d:
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m         tsh_dates.append(cursor)
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m         cursor += timedelta(days=rng.randint(330, 380))
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m     for d in tsh_dates:
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m         raw_results.append({
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m             "patient_id":          "patient-EUTH-004",
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m             "source_system":       "EPIC",
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m             "source_test_code":    "TSH",
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m             "value":               round(2.0 + rng.gauss(0, 0.4), 2),
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m             "unit":                "mIU/L",
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m             "ref_low":             0.4,
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m             "ref_high":            4.5,
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m             "ref_unit":            "mIU/L",
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m             "collection_ts":       datetime(d.year, d.month, d.day, 9, 0, 0).isoformat(),
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m             "encounter_class":     "ambulatory",
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m             "lab_id":              "central-lab-A",
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m             "method_or_analyzer":  "immunoassay",
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m     # Plus quarterly creatinine that stays stable.
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m     creat_stable_dates = []
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m     cursor = start_d + timedelta(days=14)
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m     while cursor <= end_d:
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m         creat_stable_dates.append(cursor)
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m         cursor += timedelta(days=rng.randint(85, 100))
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m     for d in creat_stable_dates:
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m         raw_results.append({
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m             "patient_id":          "patient-EUTH-004",
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m             "source_system":       "EPIC",
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m             "source_test_code":    "CR",
