[0m[49m[38;5;10m+    1268[0m:[38;5;10m[49m                 "posterior_variance":   p,
[0m[49m[38;5;10m+    1269[0m:[38;5;10m[49m                 "sample_count_recent":  len(recent),
[0m[49m[38;5;10m+    1270[0m:[38;5;10m[49m             },
[0m[49m[38;5;10m+    1271[0m:[38;5;10m[49m         }
