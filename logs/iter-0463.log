[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m             "minimum_duration_days":         180,
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m             "minimum_deviation_from_baseline": 0.50,
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m             "concerning_direction":          "rising",
