[0m[49m[38;5;10m+    732[0m:[38;5;10m[49m     canonical_loinc = SOURCE_CODE_TO_LOINC.get(key)
[0m[49m[38;5;10m+    733[0m:[38;5;10m[49m     if canonical_loinc is None:
