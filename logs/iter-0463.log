[49m[38;5;10m+    849[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    850[0m:[38;5;10m[49m ## Step 2: Maintain Per-Patient Baselines
[0m[49m[38;5;10m+    851[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    852[0m:[38;5;10m[49m For each (patient, LOINC code) pair, the pipeline keeps a rolling baseline computed only from chronic-context measurements over a configurable window. The robust statistic (interquartile mean) resists outliers, so a single weird value does not destabilize the comparison. Acute-context values are intentionally excluded; including a patient's hospitalization labs in their outpatient creatinine baseline produces unstable comparisons.
[0m[49m[38;5;10m+    853[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    854[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    855[0m:[38;5;10m[49m def _interquartile_mean(values):
[0m[49m[38;5;10m+    856[0m:[38;5;10m[49m     """Mean of the values between the 25th and 75th percentile.
[0m[49m[38;5;10m+    857[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    858[0m:[38;5;10m[49m     A robust central-tendency statistic that resists outliers.
[0m[49m[38;5;10m+    859[0m:[38;5;10m[49m     Production uses scipy.stats.trim_mean(values, 0.25) which is
[0m[49m[38;5;10m+    860[0m:[38;5;10m[49m     the standard implementation; the demo computes it from
[0m[49m[38;5;10m+    861[0m:[38;5;10m[49m     primitives so the math is visible.
[0m[49m[38;5;10m+    862[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    863[0m:[38;5;10m[49m     if not values:
[0m[49m[38;5;10m+    864[0m:[38;5;10m[49m         return 0.0
[0m[49m[38;5;10m+    865[0m:[38;5;10m[49m     sorted_vals = sorted(values)
[0m[49m[38;5;10m+    866[0m:[38;5;10m[49m     n = len(sorted_vals)
[0m[49m[38;5;10m+    867[0m:[38;5;10m[49m     if n < 4:
[0m[49m[38;5;10m+    868[0m:[38;5;10m[49m         # Too few values for meaningful trimming. Fall back to mean.
[0m[49m[38;5;10m+    869[0m:[38;5;10m[49m         return sum(sorted_vals) / n
[0m[49m[38;5;10m+    870[0m:[38;5;10m[49m     lo = int(n * 0.25)
[0m[49m[38;5;10m+    871[0m:[38;5;10m[49m     hi = int(n * 0.75)
[0m[49m[38;5;10m+    872[0m:[38;5;10m[49m     if hi <= lo:
[0m[49m[38;5;10m+    873[0m:[38;5;10m[49m         return sorted_vals[lo]
[0m[49m[38;5;10m+    874[0m:[38;5;10m[49m     trimmed = sorted_vals[lo:hi]
[0m[49m[38;5;10m+    875[0m:[38;5;10m[49m     return sum(trimmed) / len(trimmed) if trimmed else sum(sorted_vals) / n
[0m[49m[38;5;10m+    876[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    877[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    878[0m:[38;5;10m[49m def _median_absolute_deviation(values):
[0m[49m[38;5;10m+    879[0m:[38;5;10m[49m     """Robust dispersion measure: median of |x - median(x)|.
[0m[49m[38;5;10m+    880[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    881[0m:[38;5;10m[49m     More resistant to outliers than standard deviation. Production
[0m[49m[38;5;10m+    882[0m:[38;5;10m[49m     uses scipy.stats.median_abs_deviation; the demo computes it
[0m[49m[38;5;10m+    883[0m:[38;5;10m[49m     from primitives.
[0m[49m[38;5;10m+    884[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    885[0m:[38;5;10m[49m     if not values:
[0m[49m[38;5;10m+    886[0m:[38;5;10m[49m         return 0.0
[0m[49m[38;5;10m+    887[0m:[38;5;10m[49m     m = median(values)
[0m[49m[38;5;10m+    888[0m:[38;5;10m[49m     return median([abs(v - m) for v in values])
[0m[49m[38;5;10m+    889[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    890[0m:[38;5;10m[49m 
