[49m[38;5;10m+    656[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m ## Step 1: Harmonize Incoming Lab Results
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m This step takes raw source-system results, maps each test code to a canonical LOINC code, converts the unit to the canonical UCUM unit per LOINC, and tags the encounter context. In production this is an AWS Glue job that reads new HealthLake Observations on a schedule and writes the harmonized rows to S3 partitioned by LOINC and date. The demo does the equivalent in plain Python so you can trace what each transform accomplishes.
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m def _convert_units(value, from_unit, to_unit, loinc_code):
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m     """Convert a numeric value between units for a specific LOINC code.
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m     UCUM conversion is mostly mechanical. A few analytes need a
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m     molecular-weight factor because the conversion crosses mass
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m     and molar units (mg/dL vs mmol/L for glucose, mg/dL vs umol/L
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m     for creatinine). The per-LOINC catalog carries those factors
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m     so the helper picks the right one.
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m     Returns the converted value, or None if the conversion is
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m     unsupported for this LOINC code (which should quarantine the
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m     record for manual review rather than guess).
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m     if value is None:
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m     if from_unit == to_unit:
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m         return float(value)
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m     catalog = LOINC_CATALOG.get(loinc_code)
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m     if not catalog:
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m     # Creatinine: mg/dL <-> umol/L using umol_factor.
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m     if loinc_code == "2160-0":
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m         if from_unit == "umol/L" and to_unit == "mg/dL":
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m             return float(value) / catalog["umol_factor"]
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m         if from_unit == "mg/dL" and to_unit == "umol/L":
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m             return float(value) * catalog["umol_factor"]
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m     # Glucose-like analytes: mg/dL <-> mmol/L using molecular weight.
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m     # Not exercised by the demo's synthetic data; covered here so
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m     # production extension is straightforward.
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m     if from_unit == "mg/dL" and to_unit == "mmol/L":
[0m[49m[38;5;10m+    695[0m:[38;5;10m[49m         mw = catalog.get("molecular_weight")
