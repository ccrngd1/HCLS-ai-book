[0m[49m[38;5;10m+    1199[0m:[38;5;10m[49m class KalmanDetector:
[0m[49m[38;5;10m+    1200[0m:[38;5;10m[49m     """Pedagogical local-level Kalman filter for irregularly sampled labs.
[0m[49m[38;5;10m+    1201[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1202[0m:[38;5;10m[49m     Tracks a hidden 'true' value and updates it with each new
[0m[49m[38;5;10m+    1203[0m:[38;5;10m[49m     observation. The slope is the recovered drift between the
[0m[49m[38;5;10m+    1204[0m:[38;5;10m[49m     latest filtered estimate and the baseline. Production uses
[0m[49m[38;5;10m+    1205[0m:[38;5;10m[49m     pykalman, filterpy, or a state-space module from statsmodels;
[0m[49m[38;5;10m+    1206[0m:[38;5;10m[49m     this version computes the Kalman update in primitives so the
[0m[49m[38;5;10m+    1207[0m:[38;5;10m[49m     math is visible.
[0m[49m[38;5;10m+    1208[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    1209[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1210[0m:[38;5;10m[49m     name = "kalman"
[0m[49m[38;5;10m+    1211[0m:[38;5;10m[49m     PROCESS_VARIANCE_PER_DAY = 0.0001
[0m[49m[38;5;10m+    1212[0m:[38;5;10m[49m     OBSERVATION_VARIANCE     = 0.05
[0m[49m[38;5;10m+    1213[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1214[0m:[38;5;10m[49m     def run(self, recent, baseline_value, baseline_dispersion):
[0m[49m[38;5;10m+    1215[0m:[38;5;10m[49m         if len(recent) < 3:
[0m[49m[38;5;10m+    1216[0m:[38;5;10m[49m             return {"trend_status": "insufficient_data"}
[0m[49m[38;5;10m+    1217[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1218[0m:[38;5;10m[49m         # Initialize the filter at the baseline with a wide prior.
[0m[49m[38;5;10m+    1219[0m:[38;5;10m[49m         x = float(baseline_value)
[0m[49m[38;5;10m+    1220[0m:[38;5;10m[49m         p = max(baseline_dispersion ** 2, 0.1)
[0m[49m[38;5;10m+    1221[0m:[38;5;10m[49m         last_ts = None
[0m[49m[38;5;10m+    1222[0m:[38;5;10m[49m         smoothed = []
[0m[49m[38;5;10m+    1223[0m:[38;5;10m[49m         for o in recent:
[0m[49m[38;5;10m+    1224[0m:[38;5;10m[49m             v       = float(o["value_quantity"])
[0m[49m[38;5;10m+    1225[0m:[38;5;10m[49m             this_ts = o["effective_dt"]
[0m[49m[38;5;10m+    1226[0m:[38;5;10m[49m             if last_ts is not None:
[0m[49m[38;5;10m+    1227[0m:[38;5;10m[49m                 dt_days = max(_days_between_iso(last_ts, this_ts), 0.0)
[0m[49m[38;5;10m+    1228[0m:[38;5;10m[49m                 p += self.PROCESS_VARIANCE_PER_DAY * dt_days
[0m[49m[38;5;10m+    1229[0m:[38;5;10m[49m             # Kalman gain and update.
[0m[49m[38;5;10m+    1230[0m:[38;5;10m[49m             k_gain = p / (p + self.OBSERVATION_VARIANCE)
[0m[49m[38;5;10m+    1231[0m:[38;5;10m[49m             x      = x + k_gain * (v - x)
[0m[49m[38;5;10m+    1232[0m:[38;5;10m[49m             p      = (1 - k_gain) * p
[0m[49m[38;5;10m+    1233[0m:[38;5;10m[49m             smoothed.append((this_ts, x))
[0m[49m[38;5;10m+    1234[0m:[38;5;10m[49m             last_ts = this_ts
[0m[49m[38;5;10m+    1235[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1236[0m:[38;5;10m[49m         first_ts = smoothed[0][0]
[0m[49m[38;5;10m+    1237[0m:[38;5;10m[49m         last_ts  = smoothed[-1][0]
[0m[49m[38;5;10m+    1238[0m:[38;5;10m[49m         duration_days = _days_between_iso(first_ts, last_ts)
[0m[49m[38;5;10m+    1239[0m:[38;5;10m[49m         if duration_days > 0:
[0m[49m[38;5;10m+    1240[0m:[38;5;10m[49m             slope_per_day   = (smoothed[-1][1] - smoothed[0][1]) / duration_days
[0m[49m[38;5;10m+    1241[0m:[38;5;10m[49m             slope_per_month = slope_per_day * 30.0
[0m[49m[38;5;10m+    1242[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    1243[0m:[38;5;10m[49m             slope_per_month = 0.0
[0m[49m[38;5;10m+    1244[0m:[38;5;10m[49m 
