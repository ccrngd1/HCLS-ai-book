[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m import math
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m import random
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m import uuid
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m from collections import defaultdict
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m from datetime import date, datetime, timedelta, timezone
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m from statistics import mean, median, stdev
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m # Structured logging. In production, ship JSON-formatted records
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m # to CloudWatch Logs Insights for cross-call investigation. Lab
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m # results are PHI in their entirety. Log structural metadata only
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m # (run_id, patient_id_hash, loinc_code, surface_decision,
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m # runtime_ms), never raw values, never collection timestamps tied
