[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m # that includes the institution's calibration choices.
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m # Adaptive retry handles throttling from S3, DynamoDB, EventBridge,
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m # CloudWatch, HealthLake, and SageMaker. The nightly chronic-trend
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m # pipeline is a scheduled batch job that touches every active
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m # patient, so retries should be quick and capped. A stuck dependency
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m # must not balloon a 90-minute nightly window into a multi-hour
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m # incident that delays the morning's clinician inboxes.
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m     retries={"max_attempts": 5, "mode": "adaptive"})
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m # Module-level clients. Reused across function calls within the
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m # pipeline so each call does not pay the connection cost. The
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m # demo wires up MockS3 / MockTable / MockEventBus / MockCloudWatch /
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m # MockHealthLake via run_demo() and never touches these real
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m # handles; they are staged here so production wiring is a one-line
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m # swap. boto3 client and resource construction is lazy (no network
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m # call until first use), so the unused handles are free at import.
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m REGION = "us-east-1"
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m s3_client          = boto3.client("s3",
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m                                   region_name=REGION,
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m                                   config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m dynamodb           = boto3.resource("dynamodb",
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m                                     region_name=REGION,
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m                                     config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m healthlake_client  = boto3.client("healthlake",
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m                                   region_name=REGION,
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m                                   config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m eventbridge_client = boto3.client("events",
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m                                   region_name=REGION,
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m                                   config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m cloudwatch_client  = boto3.client("cloudwatch",
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m                                   region_name=REGION,
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m                                   config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m sagemaker_runtime  = boto3.client("sagemaker-runtime",
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m                                   region_name=REGION,
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m                                   config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m lambda_client      = boto3.client("lambda",
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m                                   region_name=REGION,
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m                                   config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m # --- Resource Names ---
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m # Fill these in with your actual resource names. The demo prints
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m # what it would write rather than failing if the resources do
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m # not exist; see run_demo() at the bottom.
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m HEALTHLAKE_DATASTORE_ID    = "lab-results-fhir-datastore"
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m RAW_HL7_BUCKET             = "lab-trend-raw-hl7"
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m HARMONIZED_BUCKET          = "lab-trend-harmonized"
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m PATIENT_BASELINE_BUCKET    = "lab-trend-baselines"
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m TREND_SCORE_BUCKET         = "lab-trend-scores"
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m SUPPRESSED_TREND_BUCKET    = "lab-trend-suppressed"
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m MODEL_ARTIFACT_BUCKET      = "lab-trend-models"
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m PATIENT_TRENDS_TABLE       = "patient-lab-trends"
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m TREND_EVENT_BUS_NAME       = "lab-trend-events-bus"
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m CLOUDWATCH_NAMESPACE       = "LabTrendAnalysis"
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m # --- Versioning ---
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m # Every surfaced trend carries the model version and the rule
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m # version active at the time of generation. This is how a future
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m # audit reconstructs which detector and which calibration produced
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m # which inbox surface on which night.
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m PIPELINE_VERSION   = "lab-trend-v1.2"
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m RULE_LIBRARY_VERSION = "clinical-rules-2026-04"
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m # --- Window and Cadence ---
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m # 12-month baseline window is the default for chronic-disease
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m # labs. Some labs (vitamin D, seasonal markers) use a 24-month
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m # window to span seasonal variation; the per-LOINC config can
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m # override the default.
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m DEFAULT_BASELINE_WINDOW_MONTHS = 12
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m DEFAULT_RECENT_WINDOW_MONTHS   = 6
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m DEFAULT_BASELINE_MIN_SAMPLES   = 4
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m # --- Acute Encounter Classes ---
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m # Encounter classes that get tagged "acute" and excluded from
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m # chronic-trend baselines. The exact list depends on the EHR's
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m # encounter-class vocabulary; this is illustrative.
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m ACUTE_ENCOUNTER_CLASSES = {"inpatient", "emergency", "observation"}
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m # --- LOINC Mapping ---
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m # Per-LOINC configuration covering the small panel the demo
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m # operates on. Production maintains a curated table with thousands
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m # of entries managed by the institutional terminology team.
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m # Each entry carries: the canonical UCUM unit, the per-analyte
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m # molecular-weight factor (or None for linear conversion), the
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m # detector to use, the clinical-relevance rules, and the display
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m # name for surfaced payloads.
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m LOINC_CATALOG = {
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m     "2160-0": {   # Creatinine, Serum or Plasma
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m         "display":             "Creatinine, Serum",
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m         "canonical_unit":      "mg/dL",
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m         "molecular_weight":    113.12,    # for mg/dL <-> umol/L
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m         "umol_factor":         88.4,      # 1 mg/dL = 88.4 umol/L for creatinine
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m         "detector":            "theil_sen",
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m         "rules": {
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m             "minimum_slope_per_month":       0.04,
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m             "minimum_duration_days":         90,
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m             "minimum_deviation_from_baseline": 0.20,
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m             "concerning_direction":          "rising",
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m             "minimum_slope_significance":    0.05,
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m     },
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m     "4548-4": {   # Hemoglobin A1c
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m         "display":             "Hemoglobin A1c",
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m         "canonical_unit":      "%",
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m         "molecular_weight":    None,
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m         "umol_factor":         None,
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m         "detector":            "theil_sen",
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m         "rules": {
