[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m     if from_unit == "mmol/L" and to_unit == "mg/dL":
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m         mw = catalog.get("molecular_weight")
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m         if mw:
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m             return float(value) * mw / 10.0
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m     # Hemoglobin: g/dL <-> g/L is a linear x10 / /10 conversion.
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m     if loinc_code == "718-7":
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m         if from_unit == "g/L" and to_unit == "g/dL":
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m             return float(value) / 10.0
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m         if from_unit == "g/dL" and to_unit == "g/L":
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m             return float(value) * 10.0
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m     # Platelet count: 10*3/uL == K/uL == 10^9/L are equivalent
