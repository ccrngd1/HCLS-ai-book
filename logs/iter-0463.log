[0m[49m[38;5;10m+    919[0m:[38;5;10m[49m     catalog = LOINC_CATALOG.get(loinc_code, {})
[0m[49m[38;5;10m+    920[0m:[38;5;10m[49m     minimum = catalog.get("baseline_min_samples", DEFAULT_BASELINE_MIN_SAMPLES)
[0m[49m[38;5;10m+    921[0m:[38;5;10m[49m     if len(chronic) < minimum:
