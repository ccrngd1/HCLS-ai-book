[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m # --- Synthetic Data ---
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m # Knobs for the demo's synthetic-history generator. The ranges
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m # produce a small but realistic-shaped two-year history with
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m # four illustrative chronic-disease trajectories so you can see
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m # the pipeline detect (and not detect) the patterns it should.
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m SYNTHETIC_HISTORY_DAYS = 730     # two years of history
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m SYNTHETIC_RANDOM_SEED  = 42
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m # Deploy-time guardrail. Any blank resource name is a deploy-time
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m # bug, not a runtime surprise.
