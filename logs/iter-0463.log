[0m[49m[38;5;10m+    903[0m:[38;5;10m[49m         now_dt = datetime.now(timezone.utc).replace(tzinfo=None)
[0m[49m[38;5;10m+    904[0m:[38;5;10m[49m     from_dt = (now_dt - timedelta(days=int(window_months * 30.5))).isoformat()
[0m[49m[38;5;10m+    905[0m:[38;5;10m[49m     to_dt   = now_dt.isoformat()
[0m[49m[38;5;10m+    906[0m:[38;5;10m[49m 
