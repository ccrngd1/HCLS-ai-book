[0m[49m[39m  238, 240[0m:[39m[49m     response = call ComprehendMedical.DetectEntitiesV2 with:
[0m[49m[39m  239, 241[0m:[39m[49m         text = medication_text
[0m[49m[39m  240, 242[0m:[39m[49m 
[0m[49m[39m  241, 243[0m:[39m[49m     rxnorm_mappings = []
[0m[49m[39m  242, 244[0m:[39m[49m 
[0m[49m[39m  243, 245[0m:[39m[49m     FOR each entity in response.Entities:
[0m[49m[39m  244, 246[0m:[39m[49m         // Only process MEDICATION category entities.
[0m[49m[39m  245, 247[0m:[39m[49m         // DetectEntitiesV2 also detects MEDICAL_CONDITION, TEST_TREATMENT_PROCEDURE, etc.
[0m[49m[39m  246, 248[0m:[39m[49m         // We want only the medication entities for this step.
[0m[49m[39m  247, 249[0m:[39m[49m         IF entity.Category == "MEDICATION":
[0m[49m[39m  248, 250[0m:[39m[49m 
