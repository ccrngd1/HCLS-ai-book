[0m[49m[39m  254, 256[0m:[39m[49m                         {
[0m[49m[38;5;9m- 255     [0m:[38;5;9m[49m                             detected_text:   entity.Text,       // what Comprehend Medical read
[0m[49m[38;5;9m- 256     [0m:[38;5;9m[49m                             rxnorm_id:       concept.Code,      // standard RxNorm concept ID
[0m[49m[38;5;10m+      257[0m:[38;5;10m[49m                             detected_text:   entity.Text,         // what Comprehend Medical read
[0m[49m[38;5;10m+      258[0m:[38;5;10m[49m                             rxnorm_id:       concept.Code,        // standard RxNorm concept ID
[0m[49m[39m  257, 259[0m:[39m[49m                             description:     concept.Description, // e.g., "lisinopril 10 MG Oral Tablet"
[0m[49m[38;5;10m+      260[0m:[38;5;10m[49m                             concept_type:    concept.Type,        // TTY: "SCD", "IN", "SBD", etc.
[0m[49m[39m  258, 261[0m:[39m[49m                             confidence:      round(concept.Score, 3)
[0m[49m[39m  259, 262[0m:[39m[49m                         }
[0m[49m[39m  260, 263[0m:[39m[49m 
[0m[49m[39m  261, 264[0m:[39m[49m     // Return the list of matched concepts, sorted by confidence descending.
