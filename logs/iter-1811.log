[49m[39m  132, 132[0m:[39m[49m **Step 2: Document parsing and sentence segmentation.** Raw XML needs to be converted into processable text segments. This step extracts the relevant sections (abstract, methods, results, discussion), splits them into individual sentences, and tags each sentence with its source location (which paper, which section, which paragraph). Sentence boundaries in biomedical text are tricky: abbreviations like "Fig. 2" and "et al." contain periods that aren't sentence endings. Use a biomedical-trained sentence splitter rather than a generic one. The section information matters for evidence grading later: a finding stated in the Results section carries more weight than one mentioned speculatively in the Discussion.
[0m[49m[39m  133, 133[0m:[39m[49m 
[0m[49m[39m  134, 134[0m:[39m[49m ```pseudocode
[0m[49m[39m  135, 135[0m:[39m[49m FUNCTION parse_and_segment(document_s3_key):
[0m[49m[39m  136, 136[0m:[39m[49m     // Load the raw article XML from the document lake
[0m[49m[39m  137, 137[0m:[39m[49m     raw_xml = load from S3 at document_s3_key
[0m[49m[39m  138, 138[0m:[39m[49m 
[0m[49m[39m  139, 139[0m:[39m[49m     // Parse XML structure to extract text sections
[0m[49m[39m  140, 140[0m:[39m[49m     // PubMed XML has well-defined tags for abstract, body sections, etc.
[0m[49m[39m  141, 141[0m:[39m[49m     parsed = parse XML extracting:
[0m[49m[39m  142, 142[0m:[39m[49m         title       = //ArticleTitle
[0m[49m[39m  143, 143[0m:[39m[49m         abstract    = //AbstractText (may have multiple labeled sections)
[0m[49m[39m  144, 144[0m:[39m[49m         body        = //body/sec (for PMC full-text articles)
[0m[49m[39m  145, 145[0m:[39m[49m         metadata    = {pmid, journal, pub_date, authors, mesh_terms}
[0m[49m[39m  146, 146[0m:[39m[49m 
[0m[49m[39m  147, 147[0m:[39m[49m     // Segment each text section into individual sentences
[0m[49m[39m  148, 148[0m:[39m[49m     // Use a biomedical sentence splitter that handles abbreviations correctly
[0m[49m[39m  149, 149[0m:[39m[49m     sentences = empty list
[0m[49m[39m  150, 150[0m:[39m[49m     
[0m[49m[39m  151, 151[0m:[39m[49m     FOR each section in [abstract, body_sections]:
[0m[49m[39m  152, 152[0m:[39m[49m         section_sentences = biomedical_sentence_split(section.text)
[0m[49m[39m  153, 153[0m:[39m[49m         
[0m[49m[39m  154, 154[0m:[39m[49m         FOR each sentence in section_sentences:
[0m[49m[39m  155, 155[0m:[39m[49m             append to sentences: {
[0m[49m[39m  156, 156[0m:[39m[49m                 text:         sentence,
[0m[49m[39m  157, 157[0m:[39m[49m                 section:      section.label,    // "abstract", "results", "discussion", etc.
[0m[49m[39m  158, 158[0m:[39m[49m                 position:     index,            // sentence position within section
[0m[49m[39m  159, 159[0m:[39m[49m                 document_id:  parsed.metadata.pmid,
[0m[49m[39m  160, 160[0m:[39m[49m                 source_key:   document_s3_key
[0m[49m[39m  161, 161[0m:[39m[49m             }
[0m[49m[39m  162, 162[0m:[39m[49m 
[0m[49m[39m  163, 163[0m:[39m[49m     // Store parsed output for downstream NLP steps
[0m[49m[39m  164, 164[0m:[39m[49m     store sentences to S3 at "parsed/{pmid}/sentences.json"
[0m[49m[39m  165, 165[0m:[39m[49m     
[0m[49m[39m  166, 166[0m:[39m[49m     RETURN sentences
[0m[49m[38;5;10m+      167[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+      168[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      169[0m:[38;5;10m[49m **Step 2b: PHI screening.** Case reports and clinical trial results may embed individually identifiable health information in source sentences, even though published literature is generally considered public. Before storing provenance sentences in Neptune or OpenSearch (where they'll persist and be queryable), screen for PHI risk. Articles tagged with the MeSH publication type "Case Reports" get flagged. For flagged documents, run Comprehend Medical's DetectPHI API against each sentence. Sentences containing detected PHI either get redacted (PHI spans replaced with `[REDACTED]`) or excluded from provenance storage entirely. The extracted relationships themselves (drug-treats-disease) are fine; it's the verbatim source sentences that carry the risk.
[0m[49m[38;5;10m+      170[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      171[0m:[38;5;10m[49m ```pseudocode
[0m[49m[38;5;10m+      172[0m:[38;5;10m[49m FUNCTION screen_for_phi(sentences, article_metadata):
[0m[49m[38;5;10m+      173[0m:[38;5;10m[49m     // Determine if this article is high-risk for containing PHI.
[0m[49m[38;5;10m+      174[0m:[38;5;10m[49m     // Case reports describe individual patients in detail.
[0m[49m[38;5;10m+      175[0m:[38;5;10m[49m     // Clinical trial results sometimes include individual-level data.
[0m[49m[38;5;10m+      176[0m:[38;5;10m[49m     pub_types = article_metadata.pub_types
[0m[49m[38;5;10m+      177[0m:[38;5;10m[49m     is_case_report = "Case Reports" IN pub_types
[0m[49m[38;5;10m+      178[0m:[38;5;10m[49m     is_clinical_trial = "Clinical Trial" IN pub_types OR "Randomized Controlled Trial" IN pub_types
[0m[49m[38;5;10m+      179[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      180[0m:[38;5;10m[49m     IF NOT is_case_report AND NOT is_clinical_trial:
[0m[49m[38;5;10m+      181[0m:[38;5;10m[49m         // Low PHI risk. Pass through without modification.
[0m[49m[38;5;10m+      182[0m:[38;5;10m[49m         RETURN sentences
[0m[49m[38;5;10m+      183[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      184[0m:[38;5;10m[49m     // High-risk article: screen each sentence for PHI
[0m[49m[38;5;10m+      185[0m:[38;5;10m[49m     screened_sentences = empty list
[0m[49m[38;5;10m+      186[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      187[0m:[38;5;10m[49m     FOR each sentence in sentences:
[0m[49m[38;5;10m+      188[0m:[38;5;10m[49m         phi_response = call ComprehendMedical.DetectPHI with:
[0m[49m[38;5;10m+      189[0m:[38;5;10m[49m             text = sentence.text
[0m[49m[38;5;10m+      190[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      191[0m:[38;5;10m[49m         phi_entities = phi_response.Entities
[0m[49m[38;5;10m+      192[0m:[38;5;10m[49m         // Filter to high-confidence PHI detections
[0m[49m[38;5;10m+      193[0m:[38;5;10m[49m         phi_entities = [e for e in phi_entities WHERE e.Score >= 0.80]
[0m[49m[38;5;10m+      194[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      195[0m:[38;5;10m[49m         IF phi_entities is empty:
[0m[49m[38;5;10m+      196[0m:[38;5;10m[49m             // No PHI detected. Keep sentence as-is.
[0m[49m[38;5;10m+      197[0m:[38;5;10m[49m             append sentence to screened_sentences
[0m[49m[38;5;10m+      198[0m:[38;5;10m[49m         ELSE:
[0m[49m[38;5;10m+      199[0m:[38;5;10m[49m             // Redact PHI spans from the sentence text before storing as provenance.
[0m[49m[38;5;10m+      200[0m:[38;5;10m[49m             // The sentence will still be used for NER/RE processing (in-memory only),
[0m[49m[38;5;10m+      201[0m:[38;5;10m[49m             // but the stored provenance version has PHI removed.
[0m[49m[38;5;10m+      202[0m:[38;5;10m[49m             redacted_text = sentence.text
[0m[49m[38;5;10m+      203[0m:[38;5;10m[49m             // Process spans in reverse order to preserve character offsets
[0m[49m[38;5;10m+      204[0m:[38;5;10m[49m             FOR each phi_entity in REVERSE(sorted by BeginOffset):
[0m[49m[38;5;10m+      205[0m:[38;5;10m[49m                 redacted_text = (
[0m[49m[38;5;10m+      206[0m:[38;5;10m[49m                     redacted_text[:phi_entity.BeginOffset]
[0m[49m[38;5;10m+      207[0m:[38;5;10m[49m                     + "[REDACTED]"
[0m[49m[38;5;10m+      208[0m:[38;5;10m[49m                     + redacted_text[phi_entity.EndOffset:]
[0m[49m[38;5;10m+      209[0m:[38;5;10m[49m                 )
[0m[49m[38;5;10m+      210[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      211[0m:[38;5;10m[49m             sentence.provenance_text = redacted_text  // stored version
[0m[49m[38;5;10m+      212[0m:[38;5;10m[49m             sentence.text = sentence.text              // processing version (in-memory only)
[0m[49m[38;5;10m+      213[0m:[38;5;10m[49m             sentence.phi_redacted = TRUE
[0m[49m[38;5;10m+      214[0m:[38;5;10m[49m             append sentence to screened_sentences
[0m[49m[38;5;10m+      215[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      216[0m:[38;5;10m[49m     RETURN screened_sentences
[0m[49m[39m  167, 217[0m:[39m[49m ```
