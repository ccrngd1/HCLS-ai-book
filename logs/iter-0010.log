[0m[48;2;40;67;43m[39m+    435[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAmazon S3[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m Data lake foundation for claims, eligibility, remittance, provider data, external reference data, case outcomes [38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    436[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m [38;2;235;203;139m**[38;2;235;203;139mAWS Glue[38;2;235;203;139m**[38;2;192;197;206m [38;2;192;197;206m|[38;2;192;197;206m Data catalog, ETL jobs, entity resolution, schema evolution [38;2;192;197;206m|[K
