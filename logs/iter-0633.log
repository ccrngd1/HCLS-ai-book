[49m[38;5;10m+      1[0m:[38;5;10m[49m # Recipe 6.5: Python Implementation Example
[0m[49m[38;5;10m+      2[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      3[0m:[38;5;10m[49m > **Heads up:** This is a deliberately simplified, illustrative implementation of the pseudocode walkthrough from Recipe 6.5. It shows one way you could translate provider practice pattern clustering into working Python code. It is not production-ready. The synthetic data is tiny, the case-mix adjustment is basic, and the clustering runs on a single machine. Think of it as the sketchpad version: useful for understanding the shape of the solution, not something you'd deploy against your real provider roster on Monday morning. Consider it a starting point, not a destination.
[0m[49m[38;5;10m+      4[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      5[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+      6[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      7[0m:[38;5;10m[49m ## Setup
[0m[49m[38;5;10m+      8[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+      9[0m:[38;5;10m[49m You'll need the following packages:
[0m[49m[38;5;10m+     10[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     11[0m:[38;5;10m[49m ```bash
[0m[49m[38;5;10m+     12[0m:[38;5;10m[49m pip install boto3 pandas numpy scikit-learn
[0m[49m[38;5;10m+     13[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     14[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     15[0m:[38;5;10m[49m Your environment needs AWS credentials configured (via environment variables, an instance profile, or `~/.aws/credentials`). The IAM role or user needs `s3:GetObject`, `s3:PutObject`, `sagemaker:CreateProcessingJob`, and `redshift:GetClusterCredentials` if you're connecting to Redshift. For this example, we'll work with local data and S3 storage to keep things focused on the clustering logic.
[0m[49m[38;5;10m+     16[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     17[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     18[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     19[0m:[38;5;10m[49m ## Config and Constants
[0m[49m[38;5;10m+     20[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     21[0m:[38;5;10m[49m Before we get to the steps, here's the configuration that drives the analysis. These thresholds and parameters live at the top of your module because they're the knobs you'll tune most often. The minimum panel size, the number of clusters to try, the winsorization bounds: these are all judgment calls that depend on your provider population and organizational goals.
[0m[49m[38;5;10m+     22[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     23[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     24[0m:[38;5;10m[49m import numpy as np
[0m[49m[38;5;10m+     25[0m:[38;5;10m[49m import pandas as pd
[0m[49m[38;5;10m+     26[0m:[38;5;10m[49m from sklearn.preprocessing import StandardScaler
[0m[49m[38;5;10m+     27[0m:[38;5;10m[49m from sklearn.decomposition import PCA
[0m[49m[38;5;10m+     28[0m:[38;5;10m[49m from sklearn.cluster import KMeans
[0m[49m[38;5;10m+     29[0m:[38;5;10m[49m from sklearn.metrics import silhouette_score
[0m[49m[38;5;10m+     30[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+     31[0m:[38;5;10m[49m import logging
[0m[49m[38;5;10m+     32[0m:[38;5;10m[49m from datetime import datetime, timezone
[0m[49m[38;5;10m+     33[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     34[0m:[38;5;10m[49m logger = logging.getLogger(__name__)
[0m[49m[38;5;10m+     35[0m:[38;5;10m[49m logger.setLevel(logging.INFO)
[0m[49m[38;5;10m+     36[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     37[0m:[38;5;10m[49m # --- Analysis Configuration ---
[0m[49m[38;5;10m+     38[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     39[0m:[38;5;10m[49m # Minimum number of attributed patients for a provider to be included.
[0m[49m[38;5;10m+     40[0m:[38;5;10m[49m # Below this threshold, metrics are too noisy to be meaningful.
[0m[49m[38;5;10m+     41[0m:[38;5;10m[49m # 50 is typical for primary care. Specialists with lower volumes
[0m[49m[38;5;10m+     42[0m:[38;5;10m[49m # might need a lower threshold (20-30), but you trade stability for coverage.
[0m[49m[38;5;10m+     43[0m:[38;5;10m[49m MIN_PANEL_SIZE = 50
[0m[49m[38;5;10m+     44[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     45[0m:[38;5;10m[49m # Range of cluster counts to evaluate. Provider profiling typically
[0m[49m[38;5;10m+     46[0m:[38;5;10m[49m # lands between 3 and 6 meaningful practice styles per specialty.
[0m[49m[38;5;10m+     47[0m:[38;5;10m[49m # More than 6 clusters becomes hard to explain to a medical director.
[0m[49m[38;5;10m+     48[0m:[38;5;10m[49m K_RANGE = [3, 4, 5, 6]
[0m[49m[38;5;10m+     49[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m # Winsorization bounds (in standard deviations). Values beyond this
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m # are capped to prevent extreme outliers from distorting cluster centroids.
[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m # 2.5 SD covers roughly the 99th percentile in a normal distribution.
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m WINSORIZE_SD = 2.5
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     55[0m:[38;5;10m[49m # PCA variance threshold. Keep enough components to explain this
[0m[49m[38;5;10m+     56[0m:[38;5;10m[49m # fraction of total variance. 0.85 is a reasonable default that
[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m # balances dimensionality reduction with information preservation.
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m PCA_VARIANCE_THRESHOLD = 0.85
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m # Metrics used for provider profiling. Each metric gets case-mix adjusted
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m # before clustering. The names here must match your data columns.
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m PROFILE_METRICS = [
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m     "lab_rate",
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m     "imaging_rate",
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m     "mri_rate",
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m     "referral_rate",
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m     "referral_breadth",
[0m[49m[38;5;10m+     68[0m:[38;5;10m[49m     "generic_rx_rate",
[0m[49m[38;5;10m+     69[0m:[38;5;10m[49m     "avg_cost_per_patient",
[0m[49m[38;5;10m+     70[0m:[38;5;10m[49m     "ed_rate",
[0m[49m[38;5;10m+     71[0m:[38;5;10m[49m     "readmit_rate",
[0m[49m[38;5;10m+     72[0m:[38;5;10m[49m     "quality_composite",
[0m[49m[38;5;10m+     73[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+     74[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     75[0m:[38;5;10m[49m # Patient-level features used for case-mix adjustment.
[0m[49m[38;5;10m+     76[0m:[38;5;10m[49m # These predict "expected" utilization given the provider's patient mix.
[0m[49m[38;5;10m+     77[0m:[38;5;10m[49m CASE_MIX_FEATURES = [
[0m[49m[38;5;10m+     78[0m:[38;5;10m[49m     "avg_age",
[0m[49m[38;5;10m+     79[0m:[38;5;10m[49m     "pct_female",
[0m[49m[38;5;10m+     80[0m:[38;5;10m[49m     "avg_hcc_score",
[0m[49m[38;5;10m+     81[0m:[38;5;10m[49m     "avg_chronic_conditions",
[0m[49m[38;5;10m+     82[0m:[38;5;10m[49m     "pct_dual_eligible",
[0m[49m[38;5;10m+     83[0m:[38;5;10m[49m ]
[0m[49m[38;5;10m+     84[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     85[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     86[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     87[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     88[0m:[38;5;10m[49m ## Step 1: Generate Synthetic Provider Data
[0m[49m[38;5;10m+     89[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     90[0m:[38;5;10m[49m *The pseudocode calls this `aggregate_provider_metrics()`. In production, you'd query your claims warehouse or Redshift. Here we generate realistic synthetic data so you can run this example without any external dependencies.*
[0m[49m[38;5;10m+     91[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     92[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+     93[0m:[38;5;10m[49m def generate_synthetic_providers(n_providers: int = 150, seed: int = 42) -> pd.DataFrame:
[0m[49m[38;5;10m+     94[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+     95[0m:[38;5;10m[49m     Generate synthetic provider-level data for demonstration.
[0m[49m[38;5;10m+     96[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     97[0m:[38;5;10m[49m     Creates a population of internal medicine providers with realistic
[0m[49m[38;5;10m+     98[0m:[38;5;10m[49m     distributions of utilization metrics and patient panel characteristics.
[0m[49m[38;5;10m+     99[0m:[38;5;10m[49m     The data includes natural correlations (sicker panels correlate with
[0m[49m[38;5;10m+    100[0m:[38;5;10m[49m     higher utilization) so the case-mix adjustment has something to work with.
[0m[49m[38;5;10m+    101[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    102[0m:[38;5;10m[49m     In production, this function is replaced by a Redshift query that
[0m[49m[38;5;10m+    103[0m:[38;5;10m[49m     aggregates claims/encounter data to the provider level over your
[0m[49m[38;5;10m+    104[0m:[38;5;10m[49m     chosen time window.
[0m[49m[38;5;10m+    105[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    106[0m:[38;5;10m[49m     rng = np.random.default_rng(seed)
[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m     # Generate patient panel characteristics (these drive case-mix adjustment).
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m     # Providers with sicker panels should have higher raw utilization.
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m     avg_age = rng.normal(55, 8, n_providers).clip(35, 80)
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m     pct_female = rng.normal(0.55, 0.08, n_providers).clip(0.3, 0.8)
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m     avg_hcc_score = rng.normal(1.2, 0.4, n_providers).clip(0.5, 3.0)
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m     avg_chronic_conditions = rng.normal(2.5, 0.8, n_providers).clip(0.5, 6.0)
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m     pct_dual_eligible = rng.normal(0.15, 0.08, n_providers).clip(0.0, 0.5)
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m     # Generate raw utilization metrics. These are intentionally correlated
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m     # with panel complexity (avg_hcc_score) to simulate the confounding
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m     # that case-mix adjustment needs to remove.
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m     complexity_signal = avg_hcc_score  # sicker patients drive higher utilization
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m     # Add a "practice style" signal that varies independently of case mix.
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m     # This is what clustering should ultimately detect.
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m     practice_style = rng.normal(0, 1, n_providers)
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m     lab_rate = (4.0 + 1.5 * complexity_signal + 0.8 * practice_style
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m                 + rng.normal(0, 0.5, n_providers)).clip(1.0, 12.0)
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m     imaging_rate = (0.8 + 0.4 * complexity_signal + 0.3 * practice_style
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m                     + rng.normal(0, 0.2, n_providers)).clip(0.1, 3.0)
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m     mri_rate = (0.2 + 0.15 * complexity_signal + 0.1 * practice_style
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m                 + rng.normal(0, 0.08, n_providers)).clip(0.0, 1.0)
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m     referral_rate = (0.12 + 0.05 * complexity_signal + 0.04 * rng.normal(0, 1, n_providers)
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m                      + rng.normal(0, 0.02, n_providers)).clip(0.02, 0.4)
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m     referral_breadth = (rng.poisson(8, n_providers) + (referral_rate * 20)).astype(int).clip(2, 30)
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m     generic_rx_rate = (0.85 - 0.02 * complexity_signal
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m                        + rng.normal(0, 0.05, n_providers)).clip(0.5, 0.98)
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m     avg_cost_per_patient = (3200 + 800 * complexity_signal + 400 * practice_style
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m                             + rng.normal(0, 300, n_providers)).clip(1500, 8000)
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m     ed_rate = (0.15 + 0.08 * complexity_signal
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m                + rng.normal(0, 0.03, n_providers)).clip(0.02, 0.5)
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m     readmit_rate = (0.10 + 0.04 * complexity_signal
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m                     + rng.normal(0, 0.02, n_providers)).clip(0.02, 0.3)
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m     quality_composite = (82 - 2 * complexity_signal + 3 * rng.normal(0, 1, n_providers)
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m                          + rng.normal(0, 3, n_providers)).clip(50, 100)
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m     panel_size = rng.integers(60, 400, n_providers)
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m     df = pd.DataFrame({
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m         "provider_id": [f"PROV-{i:04d}" for i in range(n_providers)],
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m         "specialty": "Internal Medicine",
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m         "panel_size": panel_size,
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m         # Case-mix features
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m         "avg_age": avg_age.round(1),
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m         "pct_female": pct_female.round(3),
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m         "avg_hcc_score": avg_hcc_score.round(2),
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m         "avg_chronic_conditions": avg_chronic_conditions.round(1),
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m         "pct_dual_eligible": pct_dual_eligible.round(3),
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m         # Utilization metrics
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m         "lab_rate": lab_rate.round(2),
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m         "imaging_rate": imaging_rate.round(2),
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m         "mri_rate": mri_rate.round(3),
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m         "referral_rate": referral_rate.round(3),
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m         "referral_breadth": referral_breadth,
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m         "generic_rx_rate": generic_rx_rate.round(3),
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m         "avg_cost_per_patient": avg_cost_per_patient.round(0),
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m         "ed_rate": ed_rate.round(3),
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m         "readmit_rate": readmit_rate.round(3),
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m         "quality_composite": quality_composite.round(1),
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m     return df
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m ## Step 2: Case-Mix Adjustment
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m *The pseudocode calls this `case_mix_adjust()`. This is the most important step in the pipeline. It separates practice style from patient complexity by calculating observed-to-expected ratios for each metric. Without this, you're just measuring who has sicker patients.*
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m from sklearn.linear_model import LinearRegression
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m def case_mix_adjust(df: pd.DataFrame) -> pd.DataFrame:
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m     Adjust each utilization metric for patient panel complexity.
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m     For each metric, we build a simple linear regression predicting
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m     the metric from patient panel characteristics (age, HCC score, etc.).
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m     The observed-to-expected ratio (O/E) isolates the provider's practice
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m     style from their patient mix.
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m     O/E = 1.0 means "exactly as expected given your patients."
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m     O/E = 1.3 means "30% more than expected" (a practice style signal).
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m     O/E = 0.7 means "30% less than expected."
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m     In production, you'd use more sophisticated models (ridge regression,
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m     gradient boosting) and validate the adjustment with held-out data.
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m     The linear model here is intentionally simple for clarity.
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m     # Extract the case-mix features (patient panel characteristics).
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m     X = df[CASE_MIX_FEATURES].values
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m     adjusted = df.copy()
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m     for metric in PROFILE_METRICS:
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m         y = df[metric].values
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m         # Fit a regression: metric = f(panel characteristics).
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m         # This learns what utilization you'd EXPECT given the patient mix.
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m         model = LinearRegression()
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m         model.fit(X, y)
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m         # Predict expected values for each provider.
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m         expected = model.predict(X)
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m         # Avoid division by zero for metrics where expected could be near zero.
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m         # Replace near-zero expected values with a small floor.
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m         expected = np.maximum(expected, 0.01)
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m         # Calculate observed-to-expected ratio.
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m         # This is the provider's practice style signal, separated from case mix.
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m         oe_ratio = y / expected
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m         # Store the adjusted metric. Column name gets "_oe" suffix.
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m         adjusted[f"{metric}_oe"] = oe_ratio.round(3)
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m         r_squared = model.score(X, y)
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m         logger.info(
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m             "  %s: R²=%.3f (%.0f%% of variation explained by case mix)",
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m             metric, r_squared, r_squared * 100
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m     return adjusted
[0m[49m[38;5;10m+    234[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    235[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    236[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    237[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    238[0m:[38;5;10m[49m ## Step 3: Feature Engineering and Normalization
[0m[49m[38;5;10m+    239[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    240[0m:[38;5;10m[49m *The pseudocode calls this `prepare_features()`. It normalizes the adjusted metrics, caps extreme outliers, and optionally reduces dimensionality with PCA. This prepares the data for clustering by ensuring all features contribute equally to distance calculations.*
[0m[49m[38;5;10m+    241[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    242[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    243[0m:[38;5;10m[49m def prepare_features(df: pd.DataFrame) -> tuple[np.ndarray, list[str], PCA | None]:
[0m[49m[38;5;10m+    244[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    245[0m:[38;5;10m[49m     Normalize, winsorize, and optionally reduce dimensionality of
[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m     the case-mix-adjusted provider metrics.
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m         - feature_matrix: numpy array ready for clustering
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m         - feature_names: list of column names (or PCA component names)
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m         - pca_model: fitted PCA object (None if PCA wasn't applied)
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m     # Extract the O/E ratio columns (our adjusted metrics).
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m     oe_columns = [f"{m}_oe" for m in PROFILE_METRICS]
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m     raw_features = df[oe_columns].values
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m     # Step 3a: Z-score normalization.
[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m     # Each metric gets zero mean and unit variance so that metrics with
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m     # larger numeric ranges don't dominate the distance calculations.
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m     scaler = StandardScaler()
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m     normalized = scaler.fit_transform(raw_features)
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m     # Step 3b: Winsorization.
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m     # Cap extreme values at +/- WINSORIZE_SD standard deviations.
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m     # After z-scoring, values beyond 2.5 are extreme outliers that
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m     # would pull cluster centroids toward them disproportionately.
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m     winsorized = np.clip(normalized, -WINSORIZE_SD, WINSORIZE_SD)
[0m[49m[38;5;10m+    268[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    269[0m:[38;5;10m[49m     # Step 3c: PCA (if we have many features).
[0m[49m[38;5;10m+    270[0m:[38;5;10m[49m     # Reduces noise and helps clustering find cleaner structure.
[0m[49m[38;5;10m+    271[0m:[38;5;10m[49m     pca_model = None
[0m[49m[38;5;10m+    272[0m:[38;5;10m[49m     if winsorized.shape[1] > 8:
[0m[49m[38;5;10m+    273[0m:[38;5;10m[49m         pca_model = PCA(n_components=PCA_VARIANCE_THRESHOLD)
[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m         feature_matrix = pca_model.fit_transform(winsorized)
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m         n_components = feature_matrix.shape[1]
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m         explained = pca_model.explained_variance_ratio_.sum()
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m         logger.info(
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m             "  PCA: %d components explain %.1f%% of variance",
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m             n_components, explained * 100
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m         )
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m         feature_names = [f"PC{i+1}" for i in range(n_components)]
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m         feature_matrix = winsorized
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m         feature_names = oe_columns
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m     return feature_matrix, feature_names, pca_model
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    289[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    290[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    291[0m:[38;5;10m[49m ## Step 4: Clustering
[0m[49m[38;5;10m+    292[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    293[0m:[38;5;10m[49m *The pseudocode calls this `cluster_providers()`. It runs K-Means for multiple values of K, evaluates each with silhouette score, and selects the best segmentation. In production, you'd also evaluate with domain experts to ensure the clusters are clinically interpretable.*
[0m[49m[38;5;10m+    294[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    295[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m def cluster_providers(feature_matrix: np.ndarray) -> tuple[np.ndarray, KMeans, dict]:
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m     Try multiple cluster counts and select the best segmentation.
[0m[49m[38;5;10m+    299[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    300[0m:[38;5;10m[49m     Evaluates K-Means for each K in K_RANGE using silhouette score.
[0m[49m[38;5;10m+    301[0m:[38;5;10m[49m     Returns the assignments from the best model along with evaluation
[0m[49m[38;5;10m+    302[0m:[38;5;10m[49m     metrics for all K values (useful for the "elbow plot" conversation
[0m[49m[38;5;10m+    303[0m:[38;5;10m[49m     with your medical director).
[0m[49m[38;5;10m+    304[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    305[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    306[0m:[38;5;10m[49m         - assignments: cluster label for each provider
[0m[49m[38;5;10m+    307[0m:[38;5;10m[49m         - best_model: the fitted KMeans object
[0m[49m[38;5;10m+    308[0m:[38;5;10m[49m         - evaluation: dict of K -> {silhouette, inertia} for all K tried
[0m[49m[38;5;10m+    309[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    310[0m:[38;5;10m[49m     evaluation = {}
[0m[49m[38;5;10m+    311[0m:[38;5;10m[49m     best_score = -1
[0m[49m[38;5;10m+    312[0m:[38;5;10m[49m     best_model = None
[0m[49m[38;5;10m+    313[0m:[38;5;10m[49m     best_assignments = None
[0m[49m[38;5;10m+    314[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    315[0m:[38;5;10m[49m     for k in K_RANGE:
[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m         # Fit K-Means. n_init=10 runs the algorithm 10 times with different
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m         # random initializations and keeps the best result. This reduces
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m         # sensitivity to the random starting centroids.
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m         model = KMeans(n_clusters=k, n_init=10, random_state=42)
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m         assignments = model.fit_predict(feature_matrix)
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m         # Silhouette score measures how well-separated the clusters are.
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m         # Range: -1 to 1. Higher is better.
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m         # 0.25-0.45 is typical for provider data (it's noisy).
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m         score = silhouette_score(feature_matrix, assignments)
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m         evaluation[k] = {
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m             "silhouette": round(score, 3),
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m             "inertia": round(model.inertia_, 1),
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m         logger.info("  K=%d: silhouette=%.3f, inertia=%.1f", k, score, model.inertia_)
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m         if score > best_score:
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m             best_score = score
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m             best_model = model
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m             best_assignments = assignments
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m     logger.info("  Selected K=%d (silhouette=%.3f)", best_model.n_clusters, best_score)
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m     return best_assignments, best_model, evaluation
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m ## Step 5: Cluster Interpretation
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m *The pseudocode calls this `interpret_clusters()`. It characterizes each cluster by identifying which metrics are most distinctive relative to the overall population. This is what turns "Cluster 0" into "Conservative/Efficient" in the medical director's vocabulary.*
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m def interpret_clusters(
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m     df: pd.DataFrame,
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m     assignments: np.ndarray,
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m ) -> list[dict]:
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m     Characterize each cluster by its most distinctive metrics.
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m     For each cluster, calculates the mean of each O/E metric and compares
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m     it to the overall population mean. The metrics with the largest
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m     deviations become the cluster's "signature" and drive the label.
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m     Returns a list of cluster profile dicts with size, distinctive features,
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m     and a suggested label.
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m     oe_columns = [f"{m}_oe" for m in PROFILE_METRICS]
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m     df = df.copy()
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m     df["cluster"] = assignments
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m     # Overall population statistics for comparison.
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m     overall_means = df[oe_columns].mean()
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m     overall_stds = df[oe_columns].std()
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m     profiles = []
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m     for cluster_id in sorted(df["cluster"].unique()):
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m         members = df[df["cluster"] == cluster_id]
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m         cluster_means = members[oe_columns].mean()
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m         # Z-score of cluster mean relative to overall population.
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m         # Positive = this cluster is above average on this metric.
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m         # Negative = below average.
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m         z_scores = (cluster_means - overall_means) / overall_stds
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m         # Top distinctive features (largest absolute z-scores).
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m         top_features = z_scores.abs().nlargest(5)
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m         distinctive = []
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m         for col in top_features.index:
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m             z = z_scores[col]
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m             metric_name = col.replace("_oe", "")
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m             direction = "above" if z > 0 else "below"
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m             pct_diff = abs(cluster_means[col] - 1.0) * 100
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m             distinctive.append({
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m                 "metric": col,
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m                 "z_score": round(z, 2),
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m                 "interpretation": f"{pct_diff:.0f}% {direction} expected {metric_name}",
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m         # Generate a suggested label based on the dominant pattern.
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m         label = _suggest_label(z_scores)
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m         # Outcome metrics for this cluster (not adjusted, just raw).
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m         outcomes = {
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m             "quality_composite": round(members["quality_composite"].mean(), 1),
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m             "readmit_rate": round(members["readmit_rate"].mean(), 3),
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m             "avg_cost_per_patient": round(members["avg_cost_per_patient"].mean(), 0),
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m         profiles.append({
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m             "cluster_id": int(cluster_id),
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m             "label": label,
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m             "size": len(members),
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m             "distinctive_features": distinctive[:3],
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m             "outcomes": outcomes,
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m     return profiles
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m def _suggest_label(z_scores: pd.Series) -> str:
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m     Heuristic label generation based on the cluster's metric profile.
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m     In production, these labels should be reviewed and refined by
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m     clinical leadership. The algorithm suggests; humans decide.
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m     cost_z = z_scores.get("avg_cost_per_patient_oe", 0)
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m     imaging_z = z_scores.get("imaging_rate_oe", 0)
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m     referral_z = z_scores.get("referral_rate_oe", 0)
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m     quality_z = z_scores.get("quality_composite_oe", 0)
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m     if cost_z < -0.5 and imaging_z < -0.5:
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m         return "Conservative / Efficient"
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m     elif cost_z > 0.5 and imaging_z > 0.5:
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m         return "Thorough / Resource-Intensive"
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m     elif referral_z > 1.0:
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m         return "Referral-Oriented"
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m     elif quality_z > 0.8:
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m         return "Balanced / Guideline-Adherent"
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m         return "Mixed Practice Style"
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m ## Step 6: Generate Provider Reports and Upload to S3
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m *The pseudocode calls this `generate_reports()`. It produces individual provider reports and an aggregate summary, then stores them in S3 for downstream consumption by QuickSight dashboards or direct provider access.*
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m import boto3
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m from botocore.config import Config
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m BOTO3_RETRY_CONFIG = Config(retries={"max_attempts": 3, "mode": "adaptive"})
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m s3_client = boto3.client("s3", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m # Replace with your actual bucket name.
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m RESULTS_BUCKET = "provider-practice-patterns"
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m def generate_provider_report(
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m     provider_row: pd.Series,
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m     cluster_profiles: list[dict],
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m ) -> dict:
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m     Build an individual provider report showing their cluster assignment,
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m     peer comparison, and key metrics.
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m     This is what a provider sees when they log into the dashboard.
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m     It answers: "Where do I fit? How do I compare? What's distinctive
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m     about my practice style?"
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m     cluster_id = int(provider_row["cluster"])
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m     profile = next(p for p in cluster_profiles if p["cluster_id"] == cluster_id)
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m     oe_columns = [f"{m}_oe" for m in PROFILE_METRICS]
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m     report = {
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m         "provider_id": provider_row["provider_id"],
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m         "specialty": provider_row["specialty"],
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m         "panel_size": int(provider_row["panel_size"]),
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m         "analysis_date": datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m         "cluster_assignment": {
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m             "cluster_id": cluster_id,
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m             "label": profile["label"],
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m             "cluster_size": profile["size"],
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m         "metrics": {
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m             col.replace("_oe", ""): {
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m                 "oe_ratio": round(provider_row[col], 2),
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m                 "interpretation": _interpret_oe(provider_row[col]),
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m             for col in oe_columns
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m         "cluster_outcomes": profile["outcomes"],
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m     return report
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m def _interpret_oe(oe_ratio: float) -> str:
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m     """Human-readable interpretation of an O/E ratio."""
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m     if oe_ratio < 0.8:
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m         return f"{(1 - oe_ratio) * 100:.0f}% below expected"
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m     elif oe_ratio > 1.2:
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m         return f"{(oe_ratio - 1) * 100:.0f}% above expected"
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m         return "Near expected"
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m def upload_results_to_s3(
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m     cluster_profiles: list[dict],
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m     provider_reports: list[dict],
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m     evaluation: dict,
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m ) -> None:
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m     Upload analysis results to S3 for downstream consumption.
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m     Three outputs:
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m     - cluster_profiles.json: aggregate cluster characteristics (for dashboards)
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m     - provider_reports.json: individual provider reports (for row-level-security views)
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m     - evaluation.json: model evaluation metrics (for audit trail)
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m     timestamp = datetime.now(timezone.utc).strftime("%Y-%m-%d")
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m     prefix = f"results/{timestamp}"
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m     # Cluster profiles (aggregate view for medical directors).
