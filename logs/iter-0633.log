[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m     print("Provider Practice Pattern Analysis")
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m 
