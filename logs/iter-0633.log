[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m     df = df[df["panel_size"] >= MIN_PANEL_SIZE].reset_index(drop=True)
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m     print(f"  After panel size filter (>={MIN_PANEL_SIZE}): {len(df)} providers")
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m     # Step 2: Case-mix adjustment.
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m     print("\nStep 2: Case-mix adjusting metrics...")
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m     df = case_mix_adjust(df)
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m     print("  Calculated O/E ratios for all metrics")
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m     # Step 3: Feature preparation.
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m     print("\nStep 3: Preparing features...")
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m     feature_matrix, feature_names, pca_model = prepare_features(df)
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m     print(f"  Feature matrix shape: {feature_matrix.shape}")
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m     # Step 4: Clustering.
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m     print("\nStep 4: Clustering providers...")
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m     assignments, model, evaluation = cluster_providers(feature_matrix)
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m     df["cluster"] = assignments
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m     print(f"  Assigned {len(df)} providers to {model.n_clusters} clusters")
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m     # Step 5: Interpretation.
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m     print("\nStep 5: Interpreting clusters...")
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m     cluster_profiles = interpret_clusters(df, assignments)
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m     for profile in cluster_profiles:
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m         print(f"  Cluster {profile['cluster_id']}: {profile['label']} "
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m               f"(n={profile['size']})")
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m         for feat in profile["distinctive_features"]:
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m             print(f"    - {feat['interpretation']}")
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m     # Step 6: Generate reports.
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m     print("\nStep 6: Generating provider reports...")
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m     provider_reports = []
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m     for _, row in df.iterrows():
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m         report = generate_provider_report(row, cluster_profiles)
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m         provider_reports.append(report)
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m     print(f"  Generated {len(provider_reports)} individual reports")
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m     # Step 7: Upload to S3 (optional).
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m     if upload_to_s3:
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m         print("\nStep 7: Uploading results to S3...")
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m         upload_results_to_s3(cluster_profiles, provider_reports, evaluation)
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m     else:
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m         print("\nStep 7: Skipping S3 upload (set upload_to_s3=True to enable)")
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m     # Summary output.
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m     summary = {
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m         "analysis_date": datetime.now(timezone.utc).isoformat(),
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m         "specialty": "Internal Medicine",
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m         "provider_count": len(df),
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m         "clusters": cluster_profiles,
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m         "evaluation": evaluation,
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m     print("\n" + "=" * 60)
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m     print("Analysis Complete")
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m     print("=" * 60)
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m     print(json.dumps(summary, indent=2, default=str))
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m 
