[0m[48;2;40;67;43m[39m+    177[0m:[39m[48;2;24;38;30m [38;2;192;197;206m└───────────────────────────────────────────────────────────┘[K
[0m[48;2;40;67;43m[39m+    178[0m:[39m[48;2;24;38;30m [K
[0m[48;2;40;67;43m[39m+    179[0m:[39m[48;2;24;38;30m [38;2;192;197;206m┌──────────────────── PRE-PROCESSING ──────────────────────┐[K
[0m[48;2;40;67;43m[39m+    180[0m:[39m[48;2;24;38;30m [38;2;192;197;206m│                                                           │[K
[0m[48;2;40;67;43m[39m+    181[0m:[39m[48;2;24;38;30m [38;2;192;197;206m│   [Length filter]                                         │[K
[0m[48;2;40;67;43m[39m+    182[0m:[39m[48;2;24;38;30m [38;2;192;197;206m│    - Drop or specially-handle clips under threshold      │[K
[0m[48;2;40;67;43m[39m+    183[0m:[39m[48;2;24;38;30m [38;2;192;197;206m│      (commonly 3 seconds: pocket dials, hangups)         │[K
