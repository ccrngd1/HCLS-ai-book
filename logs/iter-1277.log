[0m[49m[38;5;9m- 402     [0m:[38;5;9m[49m             assertion         = finding.assertion
[0m[49m[38;5;9m- 403     [0m:[38;5;9m[49m             confidence        = finding.confidence
[0m[49m[38;5;9m- 404     [0m:[38;5;9m[49m             suggested_icd10   = finding.suggested_icd10
