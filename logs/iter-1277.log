[0m[49m[38;5;9m- 396     [0m:[38;5;9m[49m             sk                = finding.sdoh_domain + "#" + finding.extraction_time
[0m[49m[38;5;9m- 397     [0m:[38;5;9m[49m             encounter_id      = finding.encounter_id
[0m[49m[38;5;9m- 398     [0m:[38;5;9m[49m             domain            = finding.sdoh_domain
[0m[49m[38;5;9m- 399     [0m:[38;5;9m[49m             extracted_text    = finding.extracted_text
[0m[49m[38;5;9m- 400     [0m:[38;5;9m[49m             source_sentence   = finding.source_sentence
