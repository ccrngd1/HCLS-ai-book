[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m     s3_client.upload_file(val_path, ML_BUCKET, val_key)
[0m[49m[38;5;10m+    280[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    281[0m:[38;5;10m[49m     train_uri = f"s3://{ML_BUCKET}/{train_key}"
[0m[49m[38;5;10m+    282[0m:[38;5;10m[49m     val_uri = f"s3://{ML_BUCKET}/{val_key}"
[0m[49m[38;5;10m+    283[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    284[0m:[38;5;10m[49m     logger.info("Uploaded training data to %s", train_uri)
[0m[49m[38;5;10m+    285[0m:[38;5;10m[49m     logger.info("Uploaded validation data to %s", val_uri)
[0m[49m[38;5;10m+    286[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    287[0m:[38;5;10m[49m     return train_uri, val_uri
[0m[49m[38;5;10m+    288[0m:[38;5;10m[49m ```
