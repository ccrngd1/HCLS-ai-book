[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m     train_data = pd.concat([y_train.reset_index(drop=True),
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m                             X_train.reset_index(drop=True)], axis=1)
