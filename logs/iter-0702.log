[0m[49m[38;5;10m+     48[0m:[38;5;10m[49m FEATURES_PREFIX = "features/members/"
[0m[49m[38;5;10m+     49[0m:[38;5;10m[49m TRAINING_PREFIX = "features/training/"
[0m[49m[38;5;10m+     50[0m:[38;5;10m[49m MODELS_PREFIX = "models/churn/"
[0m[49m[38;5;10m+     51[0m:[38;5;10m[49m PREDICTIONS_PREFIX = "predictions/"
[0m[49m[38;5;10m+     52[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     53[0m:[38;5;10m[49m # DynamoDB table for storing member churn risk scores.
[0m[49m[38;5;10m+     54[0m:[38;5;10m[49m RISK_TABLE = "member-churn-risk"
