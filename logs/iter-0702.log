[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m         entries.append(entry)
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m         # PutEvents accepts max 10 entries per call.
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m         if len(entries) == 10:
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m             events_client.put_events(Entries=entries)
