[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m     # Separate features and label.
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m     X = df[FEATURE_COLUMNS]
