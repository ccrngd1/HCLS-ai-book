[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m         role=SAGEMAKER_ROLE,
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m         sagemaker_session=session,
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m     # Configure the batch transform job.
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m     output_uri = f"s3://{ML_BUCKET}/{PREDICTIONS_PREFIX}scoring_date={scoring_date}/"
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m     transformer = model.transformer(
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m         instance_count=1,
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m         instance_type=TRANSFORM_INSTANCE_TYPE,
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m         output_path=output_uri,
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m         accept="text/csv",
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m         strategy="MultiRecord",     # process multiple records per request (faster)
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m         max_payload=6,              # MB per request batch
[0m[49m[38;5;10m+    436[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m     # Launch the transform job. Blocks until complete.
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m     logger.info("Starting batch transform for %d members...", len(members_df))
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m     transformer.transform(
[0m[49m[38;5;10m+    441[0m:[38;5;10m[49m         data=scoring_uri,
[0m[49m[38;5;10m+    442[0m:[38;5;10m[49m         content_type="text/csv",
[0m[49m[38;5;10m+    443[0m:[38;5;10m[49m         split_type="Line",
[0m[49m[38;5;10m+    444[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    445[0m:[38;5;10m[49m     transformer.wait()
[0m[49m[38;5;10m+    446[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    447[0m:[38;5;10m[49m     logger.info("Batch transform complete. Results at: %s", output_uri)
[0m[49m[38;5;10m+    448[0m:[38;5;10m[49m     return output_uri
[0m[49m[38;5;10m+    449[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    450[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    451[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    452[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    453[0m:[38;5;10m[49m ## Step 5: Assign Risk Tiers and Identify Top Risk Factors
[0m[49m[38;5;10m+    454[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    455[0m:[38;5;10m[49m *The pseudocode calls this `assign_tier(probability)` and uses SHAP values for explainability. In this simplified version, we assign tiers based on the probability thresholds and use feature value heuristics to identify likely churn drivers. A production system would compute actual SHAP values using the `shap` library.*
[0m[49m[38;5;10m+    456[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    457[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    458[0m:[38;5;10m[49m def assign_risk_tiers(members_df: pd.DataFrame, probabilities: np.ndarray) -> pd.DataFrame:
[0m[49m[38;5;10m+    459[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    460[0m:[38;5;10m[49m     Combine member data with model predictions, assign risk tiers,
[0m[49m[38;5;10m+    461[0m:[38;5;10m[49m     and identify the top contributing factors for each high-risk member.
[0m[49m[38;5;10m+    462[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    463[0m:[38;5;10m[49m     The tier thresholds are operational decisions calibrated to your retention
[0m[49m[38;5;10m+    464[0m:[38;5;10m[49m     team's capacity. If you can handle 200 outreach calls per week and your
[0m[49m[38;5;10m+    465[0m:[38;5;10m[49m     high-risk tier produces 500 members, either raise the threshold or
[0m[49m[38;5;10m+    466[0m:[38;5;10m[49m     prioritize within the tier.
[0m[49m[38;5;10m+    467[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    468[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    469[0m:[38;5;10m[49m         members_df: DataFrame with member IDs and features.
[0m[49m[38;5;10m+    470[0m:[38;5;10m[49m         probabilities: Array of churn probabilities from the model.
[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m         DataFrame with predictions, tiers, and top risk factors added.
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m     results = members_df[["member_id"]].copy()
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m     results["churn_probability"] = probabilities
[0m[49m[38;5;10m+    477[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    478[0m:[38;5;10m[49m     # Assign risk tiers based on probability thresholds.
[0m[49m[38;5;10m+    479[0m:[38;5;10m[49m     results["risk_tier"] = "low"
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m     results.loc[results["churn_probability"] >= MEDIUM_RISK_THRESHOLD, "risk_tier"] = "medium"
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m     results.loc[results["churn_probability"] >= HIGH_RISK_THRESHOLD, "risk_tier"] = "high"
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m     # For high-risk members, identify the top contributing factors.
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m     # In production, you'd compute SHAP values for proper feature attribution.
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m     # Here we use a simplified heuristic: flag features that deviate most from
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m     # the "healthy" baseline for retained members.
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m     risk_factors = []
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m     for idx, row in results.iterrows():
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m         if row["risk_tier"] == "high":
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m             factors = _identify_risk_factors(members_df.iloc[idx])
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m             factors = []
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m         risk_factors.append(factors)
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m     results["top_risk_factors"] = risk_factors
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m     # Recommend intervention type based on the dominant risk factor.
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m     results["intervention_type"] = results["top_risk_factors"].apply(_recommend_intervention)
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m     tier_counts = results["risk_tier"].value_counts()
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m     logger.info("Risk distribution: high=%d, medium=%d, low=%d",
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m                 tier_counts.get("high", 0),
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m                 tier_counts.get("medium", 0),
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m                 tier_counts.get("low", 0))
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m     return results
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m def _identify_risk_factors(member_row: pd.Series) -> list[dict]:
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m     Identify the top risk factors for a single member based on feature values.
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m     This is a simplified heuristic. In production, use SHAP values from the
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m     trained model for proper feature attribution. SHAP tells you exactly how
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m     much each feature contributed to this specific prediction.
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m     The heuristic here flags features that cross known risk thresholds.
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m     factors = []
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m     if member_row.get("pcp_in_network", 1) == 0:
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m         factors.append({"feature": "pcp_in_network", "value": 0,
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m                         "explanation": "PCP is no longer in network"})
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m     if member_row.get("unresolved_grievances", 0) > 0:
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m         factors.append({"feature": "unresolved_grievances",
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m                         "value": int(member_row["unresolved_grievances"]),
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m                         "explanation": "Has unresolved grievances"})
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m     if member_row.get("utilization_trend_ratio", 1.0) < 0.5:
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m         factors.append({"feature": "utilization_trend_ratio",
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m                         "value": round(float(member_row["utilization_trend_ratio"]), 2),
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m                         "explanation": "Significant drop in utilization"})
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m     if member_row.get("portal_login_trend", 1.0) < 0.4:
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m         factors.append({"feature": "portal_login_trend",
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m                         "value": round(float(member_row["portal_login_trend"]), 2),
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m                         "explanation": "Sharp decline in portal engagement"})
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m     if member_row.get("denied_claims_last_6m", 0) >= 2:
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m         factors.append({"feature": "denied_claims_last_6m",
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m                         "value": int(member_row["denied_claims_last_6m"]),
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m                         "explanation": "Multiple denied claims"})
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m     if member_row.get("grievances_last_6m", 0) >= 2:
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m         factors.append({"feature": "grievances_last_6m",
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m                         "value": int(member_row["grievances_last_6m"]),
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m                         "explanation": "Multiple grievances filed"})
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m     # Return top 5 factors (sorted by severity, most impactful first).
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m     return factors[:5]
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m def _recommend_intervention(factors: list[dict]) -> str:
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m     Route to the appropriate intervention team based on the dominant risk factor.
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m     In production, this routing logic is often more sophisticated: it considers
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m     the member's communication preferences, prior intervention history, and
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m     the retention team's current capacity.
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m     if not factors:
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m         return "standard_engagement"
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m     # Check the top factor and route accordingly.
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m     top_feature = factors[0]["feature"]
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m     routing = {
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m         "pcp_in_network": "network_adequacy_outreach",
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m         "unresolved_grievances": "member_services_escalation",
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m         "utilization_trend_ratio": "care_coordinator_outreach",
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m         "portal_login_trend": "digital_engagement_campaign",
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m         "denied_claims_last_6m": "benefits_counseling",
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m         "grievances_last_6m": "member_services_escalation",
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m     return routing.get(top_feature, "general_retention_outreach")
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m ## Step 6: Store Results in DynamoDB
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m *The pseudocode calls this `store_and_serve(results, scoring_date)`. We write each member's risk score to DynamoDB so operational systems (call center apps, care management platforms, member portals) can look up churn risk in real time. The TTL ensures stale scores auto-expire if the weekly scoring job fails.*
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m from decimal import Decimal
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m import json
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m # Create DynamoDB resource.
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m dynamodb = boto3.resource("dynamodb", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m def store_results_dynamodb(results_df: pd.DataFrame, scoring_date: str) -> int:
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m     Write member churn risk scores to DynamoDB for real-time operational lookup.
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m     Downstream systems query this table when a member calls in, logs into
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m     the portal, or is being reviewed by a care manager. The risk tier and
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m     top factors help the agent or system decide how to handle the interaction.
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m     Each put_item overwrites the previous score for that member. Only the
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m     current risk matters for intervention routing. Historical scores are
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m     preserved in S3 (Parquet) for trend analysis.
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m         results_df: DataFrame with member_id, churn_probability, risk_tier,
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m                     top_risk_factors, and intervention_type.
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m         scoring_date: ISO date string for the scored_at timestamp.
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m         Number of records written.
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m     table = dynamodb.Table(RISK_TABLE)
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m     written = 0
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m     # Calculate TTL: 30 days from scoring date.
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m     # If the weekly scoring job fails for multiple weeks, stale scores
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m     # auto-expire rather than persisting indefinitely.
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m     scoring_dt = datetime.datetime.fromisoformat(scoring_date)
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m     ttl_dt = scoring_dt + datetime.timedelta(days=30)
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m     ttl_epoch = int(ttl_dt.timestamp())
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m     # Write each member's score. In production, use batch_writer for efficiency.
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m     with table.batch_writer() as batch:
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m         for _, row in results_df.iterrows():
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m             item = {
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m                 "member_id": row["member_id"],
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m                 "churn_probability": Decimal(str(round(row["churn_probability"], 4))),
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m                 "risk_tier": row["risk_tier"],
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m                 "top_risk_factors": json.dumps(row["top_risk_factors"]),
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m                 "intervention_type": row["intervention_type"],
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m                 "scored_at": scoring_date,
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m                 "ttl": ttl_epoch,
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m             batch.put_item(Item=item)
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m             written += 1
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m     logger.info("Wrote %d member risk scores to DynamoDB", written)
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m     return written
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m ## Step 7: Publish High-Risk Events to EventBridge
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m *The pseudocode publishes high-risk members to EventBridge with `detail_type = "MemberChurnRiskHigh"`. Downstream rules route these events to the appropriate intervention queues: network team, member services, care coordination, or benefits counseling.*
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m # Create EventBridge client.
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m events_client = boto3.client("events", config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    652[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    653[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    654[0m:[38;5;10m[49m def publish_high_risk_events(results_df: pd.DataFrame, scoring_date: str) -> int:
[0m[49m[38;5;10m+    655[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    656[0m:[38;5;10m[49m     Publish EventBridge events for high-risk members to trigger interventions.
[0m[49m[38;5;10m+    657[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    658[0m:[38;5;10m[49m     EventBridge rules downstream route these events to the appropriate
[0m[49m[38;5;10m+    659[0m:[38;5;10m[49m     intervention queue based on the intervention_type field. For example:
[0m[49m[38;5;10m+    660[0m:[38;5;10m[49m     - "network_adequacy_outreach" -> Network team's SQS queue
[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m     - "member_services_escalation" -> Priority member services queue
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m     - "care_coordinator_outreach" -> Care management platform
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m     EventBridge accepts up to 10 entries per PutEvents call.
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m     For large batches, we chunk accordingly.
[0m[49m[38;5;10m+    666[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    667[0m:[38;5;10m[49m     Args:
[0m[49m[38;5;10m+    668[0m:[38;5;10m[49m         results_df: Full results DataFrame (we filter to high-risk here).
[0m[49m[38;5;10m+    669[0m:[38;5;10m[49m         scoring_date: ISO date string for event metadata.
[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m     Returns:
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m         Number of events published.
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m     high_risk = results_df[results_df["risk_tier"] == "high"]
[0m[49m[38;5;10m+    675[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    676[0m:[38;5;10m[49m     if high_risk.empty:
[0m[49m[38;5;10m+    677[0m:[38;5;10m[49m         logger.info("No high-risk members to publish")
[0m[49m[38;5;10m+    678[0m:[38;5;10m[49m         return 0
[0m[49m[38;5;10m+    679[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    680[0m:[38;5;10m[49m     published = 0
[0m[49m[38;5;10m+    681[0m:[38;5;10m[49m     entries = []
[0m[49m[38;5;10m+    682[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    683[0m:[38;5;10m[49m     for _, row in high_risk.iterrows():
[0m[49m[38;5;10m+    684[0m:[38;5;10m[49m         entry = {
[0m[49m[38;5;10m+    685[0m:[38;5;10m[49m             "Source": "churn-prediction-pipeline",
[0m[49m[38;5;10m+    686[0m:[38;5;10m[49m             "DetailType": "MemberChurnRiskHigh",
[0m[49m[38;5;10m+    687[0m:[38;5;10m[49m             "Detail": json.dumps({
[0m[49m[38;5;10m+    688[0m:[38;5;10m[49m                 "member_id": row["member_id"],
[0m[49m[38;5;10m+    689[0m:[38;5;10m[49m                 "churn_probability": round(row["churn_probability"], 4),
[0m[49m[38;5;10m+    690[0m:[38;5;10m[49m                 "risk_tier": row["risk_tier"],
[0m[49m[38;5;10m+    691[0m:[38;5;10m[49m                 "top_risk_factors": row["top_risk_factors"],
[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m                 "intervention_type": row["intervention_type"],
