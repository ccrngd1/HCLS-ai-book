[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m     # This is maintained by AWS and includes optimized XGBoost builds.
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m     region = session.boto_region_name
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m     container = sagemaker.image_uris.retrieve(
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m         framework="xgboost",
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m         region=region,
