[0m[49m[38;5;10m+     57[0m:[38;5;10m[49m SAGEMAKER_ROLE = "arn:aws:iam::123456789012:role/SageMakerExecutionRole"
[0m[49m[38;5;10m+     58[0m:[38;5;10m[49m TRAINING_INSTANCE_TYPE = "ml.m5.xlarge"
[0m[49m[38;5;10m+     59[0m:[38;5;10m[49m TRANSFORM_INSTANCE_TYPE = "ml.m5.large"
[0m[49m[38;5;10m+     60[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     61[0m:[38;5;10m[49m # Risk tier thresholds. These are operational decisions, not model decisions.
[0m[49m[38;5;10m+     62[0m:[38;5;10m[49m # Tune based on your retention team's capacity and intervention costs.
[0m[49m[38;5;10m+     63[0m:[38;5;10m[49m # A plan with a large care coordination team might lower the "high" threshold
[0m[49m[38;5;10m+     64[0m:[38;5;10m[49m # to catch more at-risk members. A plan with limited outreach capacity raises it.
[0m[49m[38;5;10m+     65[0m:[38;5;10m[49m HIGH_RISK_THRESHOLD = 0.60    # above this: proactive retention outreach
[0m[49m[38;5;10m+     66[0m:[38;5;10m[49m MEDIUM_RISK_THRESHOLD = 0.35  # above this: automated engagement nudges
[0m[49m[38;5;10m+     67[0m:[38;5;10m[49m 
