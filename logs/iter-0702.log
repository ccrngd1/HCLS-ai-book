[0m[49m[38;5;10m+    258[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m     logger.info("Train set: %d rows (%d churned)", len(X_train), y_train.sum())
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m     logger.info("Validation set: %d rows (%d churned)", len(X_val), y_val.sum())
