[0m[49m[39m  372, 383[0m:[39m[49m ```pseudocode
[0m[49m[38;5;9m- 373     [0m:[38;5;9m[49m FUNCTION parse_and_present(solution, current_blocks, forecasts):
[0m[49m[38;5;9m- 374     [0m:[38;5;9m[49m     // Convert solver output into a readable block schedule.
[0m[49m[38;5;9m- 375     [0m:[38;5;9m[49m     proposed_schedule = FOR each (service, room, day, slot) where solution.x[s,r,d,t] == 1:
[0m[49m[38;5;9m- 376     [0m:[38;5;9m[49m         RECORD: { service, room, day, time_slot, start_time, end_time }
[0m[49m[38;5;10m+      384[0m:[38;5;10m[49m FUNCTION daily_release_check(date, release_threshold_hours=72):
[0m[49m[38;5;10m+      385[0m:[38;5;10m[49m     // Find blocks within the release window that haven't been filled.
[0m[49m[38;5;10m+      386[0m:[38;5;10m[49m     upcoming_blocks = query DynamoDB for blocks on date
[0m[49m[38;5;10m+      387[0m:[38;5;10m[49m     releasable = filter upcoming_blocks where:
[0m[49m[38;5;10m+      388[0m:[38;5;10m[49m         hours_until_block < release_threshold_hours
[0m[49m[38;5;10m+      389[0m:[38;5;10m[49m         AND cases_scheduled == 0
[0m[49m[38;5;10m+      390[0m:[38;5;10m[49m         AND not already_released
[0m[49m[39m  377, 391[0m:[39m[49m 
[0m[49m[38;5;9m- 378     [0m:[38;5;9m[49m     // Compute comparison metrics.
[0m[49m[38;5;9m- 379     [0m:[38;5;9m[49m     comparison = {
[0m[49m[38;5;9m- 380     [0m:[38;5;9m[49m         current_utilization: calculate from current_blocks and historical data,
[0m[49m[38;5;9m- 381     [0m:[38;5;9m[49m         proposed_utilization: calculate from proposed_schedule and forecasts,
[0m[49m[38;5;9m- 382     [0m:[38;5;9m[49m         blocks_changed: count of assignments that differ between current and proposed,
[0m[49m[38;5;9m- 383     [0m:[38;5;9m[49m         services_gaining_time: list of services with more hours in proposed,
[0m[49m[38;5;9m- 384     [0m:[38;5;9m[49m         services_losing_time: list of services with fewer hours in proposed,
[0m[49m[38;5;9m- 385     [0m:[38;5;9m[49m         fairness_index: Gini coefficient of allocation proportionality
[0m[49m[38;5;9m- 386     [0m:[38;5;9m[49m     }
[0m[49m[38;5;10m+      392[0m:[38;5;10m[49m     IF releasable is empty:
[0m[49m[38;5;10m+      393[0m:[38;5;10m[49m         RETURN "No blocks to release today"
[0m[49m[39m  387, 394[0m:[39m[49m 
[0m[49m[38;5;9m- 388     [0m:[38;5;9m[49m     // Generate per-service impact summary.
[0m[49m[38;5;9m- 389     [0m:[38;5;9m[49m     // This is what department chairs care about: "what happens to MY time?"
[0m[49m[38;5;9m- 390     [0m:[38;5;9m[49m     service_impact = FOR each service:
[0m[49m[38;5;9m- 391     [0m:[38;5;9m[49m         current_hours = sum of hours in current_blocks for this service
[0m[49m[38;5;9m- 392     [0m:[38;5;9m[49m         proposed_hours = sum of hours in proposed_schedule for this service
[0m[49m[38;5;9m- 393     [0m:[38;5;9m[49m         change = proposed_hours - current_hours
[0m[49m[38;5;9m- 394     [0m:[38;5;9m[49m         utilization_forecast = forecasts[service].expected_weekly_minutes / (proposed_hours * 60)
[0m[49m[38;5;9m- 395     [0m:[38;5;9m[49m         RETURN { service, current_hours, proposed_hours, change, projected_utilization }
[0m[49m[38;5;10m+      395[0m:[38;5;10m[49m     // For each releasable block, find the best recipient.
[0m[49m[38;5;10m+      396[0m:[38;5;10m[49m     FOR each block in releasable:
[0m[49m[38;5;10m+      397[0m:[38;5;10m[49m         // Who wants this block? Check waitlist demand by service.
[0m[49m[38;5;10m+      398[0m:[38;5;10m[49m         eligible_services = services where:
[0m[49m[38;5;10m+      399[0m:[38;5;10m[49m             room capabilities match service requirements
[0m[49m[38;5;10m+      400[0m:[38;5;10m[49m             AND service has active waitlist (patients needing surgery)
[0m[49m[38;5;10m+      401[0m:[38;5;10m[49m             AND service is not over their maximum allocation this week
[0m[49m[38;5;10m+      402[0m:[38;5;10m[49m         
[0m[49m[38;5;10m+      403[0m:[38;5;10m[49m         IF eligible_services is empty:
