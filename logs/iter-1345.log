[0m[49m[38;5;10m+      376[0m:[38;5;10m[49m         APPEND {allocation, metrics} to results
[0m[49m[39m  349, 377[0m:[39m[49m 
[0m[49m[38;5;9m- 350     [0m:[38;5;9m[49m     // Invoke the solver.
[0m[49m[38;5;9m- 351     [0m:[38;5;9m[49m     result = solver.optimize(model, solver_config)
[0m[49m[38;5;9m- 352     [0m:[38;5;9m[49m 
[0m[49m[38;5;9m- 353     [0m:[38;5;9m[49m     // Check solution status.
[0m[49m[38;5;9m- 354     [0m:[38;5;9m[49m     IF result.status == "OPTIMAL" OR result.status == "FEASIBLE":
[0m[49m[38;5;9m- 355     [0m:[38;5;9m[49m         solution = extract variable values from result
[0m[49m[38;5;9m- 356     [0m:[38;5;9m[49m         objective_value = result.objective_value
