[0m[49m[38;5;9m- 358     [0m:[38;5;9m[49m         RETURN { solution, objective_value, gap, status: "success" }
[0m[49m[38;5;9m- 359     [0m:[38;5;9m[49m     ELSE IF result.status == "INFEASIBLE":
[0m[49m[38;5;9m- 360     [0m:[38;5;9m[49m         // No allocation exists that satisfies all hard constraints.
[0m[49m[38;5;9m- 361     [0m:[38;5;9m[49m         // This usually means minimum access guarantees exceed available capacity.
[0m[49m[38;5;9m- 362     [0m:[38;5;9m[49m         // Return diagnostics: which constraints are conflicting.
