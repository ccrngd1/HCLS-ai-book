[0m[49m[38;5;10m+     807[0m:[38;5;10m[49m **Step 3: Capture the prescreen with provenance and consent discipline.** The prescreen is the structured patient-reported information the coordinator would have spent thirty to forty minutes capturing on the phone. The capture flow tags every field as patient-reported (versus chart-verified), preserves the question-and-answer chain that produced it, and operates within the IRB-approved data-collection consent.
[0m[49m[38;5;10m+     808[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     809[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     810[0m:[38;5;10m[49m ON capture_prescreen(trial_id, conversation_id,
[0m[49m[38;5;10m+     811[0m:[38;5;10m[49m                      conversation_turn_data,
[0m[49m[38;5;10m+     812[0m:[38;5;10m[49m                      consent_record):
[0m[49m[38;5;10m+     813[0m:[38;5;10m[49m     // Step 3A: check that the patient has consented to
[0m[49m[38;5;10m+     814[0m:[38;5;10m[49m     // the IRB-approved data-collection plan for this trial.
[0m[49m[38;5;10m+     815[0m:[38;5;10m[49m     // Without consent, the prescreen is not captured;
[0m[49m[38;5;10m+     816[0m:[38;5;10m[49m     // the conversation may continue for general FAQ but
[0m[49m[38;5;10m+     817[0m:[38;5;10m[49m     // not for prescreen.
[0m[49m[38;5;10m+     818[0m:[38;5;10m[49m     IF NOT consent_record.data_collection_consented:
[0m[49m[38;5;10m+     819[0m:[38;5;10m[49m         return {
[0m[49m[38;5;10m+     820[0m:[38;5;10m[49m             action: "prescreen_skipped",
[0m[49m[38;5;10m+     821[0m:[38;5;10m[49m             reason: "data_collection_consent_not_given"
[0m[49m[38;5;10m+     822[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+     823[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     824[0m:[38;5;10m[49m     // Step 3B: extract structured patient-reported fields
[0m[49m[38;5;10m+     825[0m:[38;5;10m[49m     // from the conversation turn. The extraction is
[0m[49m[38;5;10m+     826[0m:[38;5;10m[49m     // tool-driven (the LLM produces tool calls with
[0m[49m[38;5;10m+     827[0m:[38;5;10m[49m     // structured arguments) rather than free-text
[0m[49m[38;5;10m+     828[0m:[38;5;10m[49m     // interpretation downstream. Comprehend Medical may
[0m[49m[38;5;10m+     829[0m:[38;5;10m[49m     // assist with named-entity recognition.
[0m[49m[38;5;10m+     830[0m:[38;5;10m[49m     extracted_fields = extract_structured({
[0m[49m[38;5;10m+     831[0m:[38;5;10m[49m         turn_data: conversation_turn_data,
[0m[49m[38;5;10m+     832[0m:[38;5;10m[49m         target_schema:
[0m[49m[38;5;10m+     833[0m:[38;5;10m[49m             PRESCREEN_SCHEMA[trial_id],
[0m[49m[38;5;10m+     834[0m:[38;5;10m[49m         ner_assist: comprehend_medical_extract(
[0m[49m[38;5;10m+     835[0m:[38;5;10m[49m             conversation_turn_data.patient_text)
[0m[49m[38;5;10m+     836[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+     837[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     838[0m:[38;5;10m[49m     // Step 3C: tag each field with provenance.
[0m[49m[38;5;10m+     839[0m:[38;5;10m[49m     // Provenance includes: source ("patient_reported"
[0m[49m[38;5;10m+     840[0m:[38;5;10m[49m     // versus "chart_verified" versus "coordinator_
[0m[49m[38;5;10m+     841[0m:[38;5;10m[49m     // entered"), the specific question that elicited the
[0m[49m[38;5;10m+     842[0m:[38;5;10m[49m     // value, the response timestamp, the conversation
[0m[49m[38;5;10m+     843[0m:[38;5;10m[49m     // turn id, the language the patient used, and a
[0m[49m[38;5;10m+     844[0m:[38;5;10m[49m     // confidence score where applicable.
[0m[49m[38;5;10m+     845[0m:[38;5;10m[49m     provenance_tagged = []
[0m[49m[38;5;10m+     846[0m:[38;5;10m[49m     FOR each field IN extracted_fields:
[0m[49m[38;5;10m+     847[0m:[38;5;10m[49m         provenance_tagged.append({
[0m[49m[38;5;10m+     848[0m:[38;5;10m[49m             field_name: field.name,
[0m[49m[38;5;10m+     849[0m:[38;5;10m[49m             field_value: field.value,
[0m[49m[38;5;10m+     850[0m:[38;5;10m[49m             source: "patient_reported",
[0m[49m[38;5;10m+     851[0m:[38;5;10m[49m             eliciting_question:
[0m[49m[38;5;10m+     852[0m:[38;5;10m[49m                 field.eliciting_question_id,
[0m[49m[38;5;10m+     853[0m:[38;5;10m[49m             eliciting_question_text:
[0m[49m[38;5;10m+     854[0m:[38;5;10m[49m                 field.eliciting_question_text,
[0m[49m[38;5;10m+     855[0m:[38;5;10m[49m             response_timestamp: now(),
[0m[49m[38;5;10m+     856[0m:[38;5;10m[49m             conversation_turn_id:
[0m[49m[38;5;10m+     857[0m:[38;5;10m[49m                 conversation_turn_data.turn_id,
[0m[49m[38;5;10m+     858[0m:[38;5;10m[49m             language: conversation_turn_data.language,
[0m[49m[38;5;10m+     859[0m:[38;5;10m[49m             extraction_confidence: field.confidence
[0m[49m[38;5;10m+     860[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+     861[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     862[0m:[38;5;10m[49m     // Step 3D: write to the prescreen-store. The store is
[0m[49m[38;5;10m+     863[0m:[38;5;10m[49m     // append-only; corrections create new records that
[0m[49m[38;5;10m+     864[0m:[38;5;10m[49m     // reference the prior record rather than overwriting.
[0m[49m[38;5;10m+     865[0m:[38;5;10m[49m     prescreen_record_id = persist_prescreen({
[0m[49m[38;5;10m+     866[0m:[38;5;10m[49m         trial_id: trial_id,
[0m[49m[38;5;10m+     867[0m:[38;5;10m[49m         conversation_id: conversation_id,
[0m[49m[38;5;10m+     868[0m:[38;5;10m[49m         fields: provenance_tagged,
[0m[49m[38;5;10m+     869[0m:[38;5;10m[49m         consent_version:
[0m[49m[38;5;10m+     870[0m:[38;5;10m[49m             consent_record.consent_version,
[0m[49m[38;5;10m+     871[0m:[38;5;10m[49m         store_timestamp: now()
[0m[49m[38;5;10m+     872[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+     873[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     874[0m:[38;5;10m[49m     // Step 3E: emit prescreen-progress event for the
[0m[49m[38;5;10m+     875[0m:[38;5;10m[49m     // recruitment-funnel dashboards.
[0m[49m[38;5;10m+     876[0m:[38;5;10m[49m     emit_event("prescreen_field_captured", {
[0m[49m[38;5;10m+     877[0m:[38;5;10m[49m         trial_id: trial_id,
[0m[49m[38;5;10m+     878[0m:[38;5;10m[49m         conversation_id: conversation_id,
[0m[49m[38;5;10m+     879[0m:[38;5;10m[49m         field_count: provenance_tagged.length,
[0m[49m[38;5;10m+     880[0m:[38;5;10m[49m         prescreen_record_id: prescreen_record_id
[0m[49m[38;5;10m+     881[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+     882[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     883[0m:[38;5;10m[49m     return {
[0m[49m[38;5;10m+     884[0m:[38;5;10m[49m         action: "prescreen_captured",
[0m[49m[38;5;10m+     885[0m:[38;5;10m[49m         prescreen_record_id: prescreen_record_id,
[0m[49m[38;5;10m+     886[0m:[38;5;10m[49m         fields_captured: provenance_tagged.length
[0m[49m[38;5;10m+     887[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+     888[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     889[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     890[0m:[38;5;10m[49m What can go wrong if you skip or shortcut this: the prescreen data lacks provenance, the coordinator cannot trace any field back to the question the patient was answering, the IRB-approved data-collection consent is unverified, the data overwrite-vs-append discipline is missing, and the prescreen ages out of compliance during the trial's audit window. The provenance tagging is the audit-grade primitive that lets the coordinator (and the IRB during inspection) verify what the patient was actually asked and how they actually answered.
[0m[49m[38;5;10m+     891[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     892[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+     893[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     894[0m:[38;5;10m[49m **Step 4: Orchestrate the coordinator handoff with structured prescreen summary, patient confirmation, and follow-up commitment.** The coordinator handoff is the production-scope downstream workflow. A handoff that arrives in the coordinator queue without the prescreen attached, without the patient's stated questions, without the patient's preferred follow-up channel and time, or without the patient's confirmation that they understand the next step, is a handoff the coordinator workflow rejects.
[0m[49m[38;5;10m+     895[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+     896[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+     897[0m:[38;5;10m[49m ON schedule_coordinator_handoff(trial_id, conversation_id,
[0m[49m[38;5;10m+     898[0m:[38;5;10m[49m                                 eligibility_disposition,
[0m[49m[38;5;10m+     899[0m:[38;5;10m[49m                                 prescreen_record_id,
[0m[49m[38;5;10m+     900[0m:[38;5;10m[49m                                 patient_preferences):
[0m[49m[38;5;10m+     901[0m:[38;5;10m[49m     // Step 4A: confirm the handoff is appropriate.
[0m[49m[38;5;10m+     902[0m:[38;5;10m[49m     // Coordinator handoff applies for "clearly_eligible_
[0m[49m[38;5;10m+     903[0m:[38;5;10m[49m     // pending_coordinator_confirmation" and "uncertain_
[0m[49m[38;5;10m+     904[0m:[38;5;10m[49m     // pending_coordinator_verification" dispositions.
[0m[49m[38;5;10m+     905[0m:[38;5;10m[49m     // Disqualified prospects and patient-declined
[0m[49m[38;5;10m+     906[0m:[38;5;10m[49m     // conversations route to other flows.
[0m[49m[38;5;10m+     907[0m:[38;5;10m[49m     IF eligibility_disposition NOT IN [
[0m[49m[38;5;10m+     908[0m:[38;5;10m[49m         "clearly_eligible_pending_coordinator_confirmation",
[0m[49m[38;5;10m+     909[0m:[38;5;10m[49m         "uncertain_pending_coordinator_verification"]:
