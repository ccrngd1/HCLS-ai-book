[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m         balance_id = pred["balance_id"]
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m         if score >= HIGH_PROPENSITY_THRESHOLD:
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m             # High propensity: standard statement cadence.
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m             # These patients typically pay without special intervention.
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m             strategy = "standard_statements"
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m         elif score >= MEDIUM_PROPENSITY_THRESHOLD:
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m             # Medium propensity: proactive intervention likely to help.
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m             if amount > 500:
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m                 strategy = "financial_counselor_outreach"
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m             else:
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m                 strategy = "payment_plan_offer"
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m             # Low propensity: likely unable to pay.
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m             # Screen for financial assistance eligibility early.
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m             strategy = "financial_assistance_screening"
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m         routing_summary[strategy] += 1
