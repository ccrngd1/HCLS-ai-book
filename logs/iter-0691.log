[0m[49m[38;5;10m+    670[0m:[38;5;10m[49m     logger.info("Step 4: Scoring open balances with batch transform")
[0m[49m[38;5;10m+    671[0m:[38;5;10m[49m     logger.info("=" * 60)
[0m[49m[38;5;10m+    672[0m:[38;5;10m[49m     scoring_uri = prepare_scoring_input(df)
[0m[49m[38;5;10m+    673[0m:[38;5;10m[49m     predictions_uri = run_batch_scoring(model_artifact_uri, scoring_uri)
[0m[49m[38;5;10m+    674[0m:[38;5;10m[49m     print(f"  Predictions: {predictions_uri}")
