[0m[49m[38;5;10m+    661[0m:[38;5;10m[49m     logger.info("Step 3: Training XGBoost model on SageMaker")
[0m[49m[38;5;10m+    662[0m:[38;5;10m[49m     logger.info("=" * 60)
[0m[49m[38;5;10m+    663[0m:[38;5;10m[49m     model_artifact_uri = train_propensity_model(train_uri, val_uri)
[0m[49m[38;5;10m+    664[0m:[38;5;10m[49m     print(f"  Model artifact: {model_artifact_uri}")
[0m[49m[38;5;10m+    665[0m:[38;5;10m[49m 
