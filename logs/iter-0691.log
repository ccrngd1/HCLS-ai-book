[0m[49m[38;5;10m+    692[0m:[38;5;10m[49m     balance_ids = [f"BAL-2026-{i:07d}" for i in range(len(df))]
[0m[49m[38;5;10m+    693[0m:[38;5;10m[49m     patient_ids = [f"PAT-{i:08d}" for i in range(len(df))]
[0m[49m[38;5;10m+    694[0m:[38;5;10m[49m 
