[0m[49m[38;5;10m+    696[0m:[38;5;10m[49m         balance_ids=balance_ids,
[0m[49m[38;5;10m+    697[0m:[38;5;10m[49m         patient_ids=patient_ids,
[0m[49m[38;5;10m+    698[0m:[38;5;10m[49m         calibrated_scores=calibrated,
[0m[49m[38;5;10m+    699[0m:[38;5;10m[49m         balance_amounts=df["balance_amount"].values,
[0m[49m[38;5;10m+    700[0m:[38;5;10m[49m         model_version="v1.0-demo",
[0m[49m[38;5;10m+    701[0m:[38;5;10m[49m     )
[0m[49m[38;5;10m+    702[0m:[38;5;10m[49m     print(f"  Wrote {records_written} predictions to DynamoDB")
[0m[49m[38;5;10m+    703[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    704[0m:[38;5;10m[49m     # Step 6: Apply collection strategy.
[0m[49m[38;5;10m+    705[0m:[38;5;10m[49m     logger.info("=" * 60)
[0m[49m[38;5;10m+    706[0m:[38;5;10m[49m     logger.info("Step 6: Applying collection strategy routing")
[0m[49m[38;5;10m+    707[0m:[38;5;10m[49m     logger.info("=" * 60)
[0m[49m[38;5;10m+    708[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    709[0m:[38;5;10m[49m     # Build prediction dicts as they'd come from DynamoDB.
[0m[49m[38;5;10m+    710[0m:[38;5;10m[49m     predictions = [
[0m[49m[38;5;10m+    711[0m:[38;5;10m[49m         {
[0m[49m[38;5;10m+    712[0m:[38;5;10m[49m             "balance_id": balance_ids[i],
[0m[49m[38;5;10m+    713[0m:[38;5;10m[49m             "propensity_score": Decimal(str(round(float(calibrated[i]), 4))),
[0m[49m[38;5;10m+    714[0m:[38;5;10m[49m             "balance_amount": Decimal(str(round(float(df["balance_amount"].iloc[i]), 2))),
[0m[49m[38;5;10m+    715[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    716[0m:[38;5;10m[49m         for i in range(len(df))
[0m[49m[38;5;10m+    717[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    718[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    719[0m:[38;5;10m[49m     routing = apply_collection_strategy(predictions)
[0m[49m[38;5;10m+    720[0m:[38;5;10m[49m     print(f"\n  Strategy routing summary:")
[0m[49m[38;5;10m+    721[0m:[38;5;10m[49m     for strategy, count in routing.items():
[0m[49m[38;5;10m+    722[0m:[38;5;10m[49m         pct = count / len(predictions) * 100
[0m[49m[38;5;10m+    723[0m:[38;5;10m[49m         print(f"    {strategy}: {count} balances ({pct:.1f}%)")
[0m[49m[38;5;10m+    724[0m:[38;5;10m[49m 
