[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m         # or call an API on your collection workflow tool.
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m         logger.debug("Balance %s (score=%.3f, amount=$%.2f) -> %s",
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m                      balance_id, score, amount, strategy)
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m     return routing_summary
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m ```
