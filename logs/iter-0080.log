[0m[48;2;40;67;43m[39m+    1307[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m--------[38;2;192;197;206m|[38;2;192;197;206m------------------------[38;2;192;197;206m|[38;2;192;197;206m-----------------[38;2;192;197;206m|[K
[0m[48;2;40;67;43m[39m+    1308[0m:[39m[48;2;24;38;30m [38;2;192;197;206m|[38;2;192;197;206m Targeting precision (intervention matched to barrier) [38;2;192;197;206m|[38;2;192;197;206m n/a (single intervention type) [38;2;192;197;206m|[38;2;192;197;206m 65-80% (per audit sample) [38;2;192;197;206m|[K
