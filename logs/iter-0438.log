[0m[49m[38;5;10m+    107[0m:[38;5;10m[49m                                   region_name=REGION,
[0m[49m[38;5;10m+    108[0m:[38;5;10m[49m                                   config=BOTO3_RETRY_CONFIG)
[0m[49m[38;5;10m+    109[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    110[0m:[38;5;10m[49m # --- Resource Names ---
[0m[49m[38;5;10m+    111[0m:[38;5;10m[49m # Fill these in with your actual resource names. The demo prints
[0m[49m[38;5;10m+    112[0m:[38;5;10m[49m # what it would write rather than failing if the resources do
[0m[49m[38;5;10m+    113[0m:[38;5;10m[49m # not exist; see run_demo() at the bottom.
[0m[49m[38;5;10m+    114[0m:[38;5;10m[49m CONSUMPTION_HISTORY_BUCKET = "supply-forecast-consumption-history"
[0m[49m[38;5;10m+    115[0m:[38;5;10m[49m SKU_MASTER_BUCKET          = "supply-forecast-sku-master"
[0m[49m[38;5;10m+    116[0m:[38;5;10m[49m MODEL_ARTIFACT_BUCKET      = "supply-forecast-models"
[0m[49m[38;5;10m+    117[0m:[38;5;10m[49m FORECAST_OUTPUT_BUCKET     = "supply-forecast-outputs"
[0m[49m[38;5;10m+    118[0m:[38;5;10m[49m SKU_FORECASTS_TABLE        = "supply-forecast-sku-forecasts"
[0m[49m[38;5;10m+    119[0m:[38;5;10m[49m FORECAST_EVENT_BUS_NAME    = "supply-forecast-events-bus"
[0m[49m[38;5;10m+    120[0m:[38;5;10m[49m CLOUDWATCH_NAMESPACE       = "SupplyForecast"
[0m[49m[38;5;10m+    121[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    122[0m:[38;5;10m[49m # --- Versioning ---
[0m[49m[38;5;10m+    123[0m:[38;5;10m[49m # Every forecast record carries the model version active at the
[0m[49m[38;5;10m+    124[0m:[38;5;10m[49m # time of generation. This is how a future audit reconstructs
[0m[49m[38;5;10m+    125[0m:[38;5;10m[49m # which calibration produced which reorder point.
[0m[49m[38;5;10m+    126[0m:[38;5;10m[49m PIPELINE_VERSION       = "supply-forecast-v1.3"
[0m[49m[38;5;10m+    127[0m:[38;5;10m[49m SEGMENTATION_VERSION   = "syntetos-boylan-2025-04"
[0m[49m[38;5;10m+    128[0m:[38;5;10m[49m SAFETY_STOCK_VERSION   = "classical-z-score-v1"
[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m # --- Segmentation Thresholds ---
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m # Standard four-corner classification from Syntetos, Boylan, and
[0m[49m[38;5;10m+    132[0m:[38;5;10m[49m # Croston. ADI = average demand interval (days between non-zero
[0m[49m[38;5;10m+    133[0m:[38;5;10m[49m # demand observations). CV² = coefficient of variation squared
[0m[49m[38;5;10m+    134[0m:[38;5;10m[49m # of non-zero demand size. The cutoffs (1.32 and 0.49) are the
[0m[49m[38;5;10m+    135[0m:[38;5;10m[49m # commonly cited defaults from the Syntetos-Boylan-Croston
[0m[49m[38;5;10m+    136[0m:[38;5;10m[49m # research. Tune them to your portfolio if your demand shapes
[0m[49m[38;5;10m+    137[0m:[38;5;10m[49m # are unusual.
[0m[49m[38;5;10m+    138[0m:[38;5;10m[49m ADI_THRESHOLD = Decimal("1.32")
[0m[49m[38;5;10m+    139[0m:[38;5;10m[49m CV2_THRESHOLD = Decimal("0.49")
[0m[49m[38;5;10m+    140[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    141[0m:[38;5;10m[49m # --- Forecast Horizon ---
[0m[49m[38;5;10m+    142[0m:[38;5;10m[49m # 90 days is a typical operational horizon: long enough to span
[0m[49m[38;5;10m+    143[0m:[38;5;10m[49m # most lead times plus a buffer, short enough that the forecast
[0m[49m[38;5;10m+    144[0m:[38;5;10m[49m # does not lose accuracy from extrapolating too far.
[0m[49m[38;5;10m+    145[0m:[38;5;10m[49m FORECAST_HORIZON_DAYS = 90
[0m[49m[38;5;10m+    146[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    147[0m:[38;5;10m[49m # --- Service Level Defaults ---
[0m[49m[38;5;10m+    148[0m:[38;5;10m[49m # Per-SKU target service levels in production come from the SKU
[0m[49m[38;5;10m+    149[0m:[38;5;10m[49m # master and reflect clinical criticality. The defaults below
[0m[49m[38;5;10m+    150[0m:[38;5;10m[49m # stand in for that lookup. A 99% service level is appropriate
[0m[49m[38;5;10m+    151[0m:[38;5;10m[49m # for emergency drugs and critical implants; 95% is fine for
[0m[49m[38;5;10m+    152[0m:[38;5;10m[49m # most consumables; 90% is acceptable for slow-moving non-clinical
[0m[49m[38;5;10m+    153[0m:[38;5;10m[49m # items. Below 90%, you are essentially accepting routine
[0m[49m[38;5;10m+    154[0m:[38;5;10m[49m # stockouts as a cost center.
[0m[49m[38;5;10m+    155[0m:[38;5;10m[49m DEFAULT_SERVICE_LEVEL_BY_SEGMENT = {
[0m[49m[38;5;10m+    156[0m:[38;5;10m[49m     "smooth":             Decimal("0.95"),
[0m[49m[38;5;10m+    157[0m:[38;5;10m[49m     "intermittent":       Decimal("0.97"),
[0m[49m[38;5;10m+    158[0m:[38;5;10m[49m     "erratic":            Decimal("0.95"),
[0m[49m[38;5;10m+    159[0m:[38;5;10m[49m     "lumpy":              Decimal("0.97"),
[0m[49m[38;5;10m+    160[0m:[38;5;10m[49m     "procedure_driven":   Decimal("0.99"),
[0m[49m[38;5;10m+    161[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    162[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    163[0m:[38;5;10m[49m # Z-score lookup for common service levels. Production reads
[0m[49m[38;5;10m+    164[0m:[38;5;10m[49m # the per-SKU service-level target from the SKU master and
[0m[49m[38;5;10m+    165[0m:[38;5;10m[49m # computes the z-score from the inverse normal CDF.
[0m[49m[38;5;10m+    166[0m:[38;5;10m[49m Z_SCORE_BY_SERVICE_LEVEL = {
[0m[49m[38;5;10m+    167[0m:[38;5;10m[49m     Decimal("0.90"): Decimal("1.282"),
[0m[49m[38;5;10m+    168[0m:[38;5;10m[49m     Decimal("0.95"): Decimal("1.645"),
[0m[49m[38;5;10m+    169[0m:[38;5;10m[49m     Decimal("0.97"): Decimal("1.881"),
[0m[49m[38;5;10m+    170[0m:[38;5;10m[49m     Decimal("0.99"): Decimal("2.326"),
[0m[49m[38;5;10m+    171[0m:[38;5;10m[49m }
[0m[49m[38;5;10m+    172[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    173[0m:[38;5;10m[49m # --- Lead Time Defaults ---
[0m[49m[38;5;10m+    174[0m:[38;5;10m[49m # Per-SKU lead times in production come from the vendor contract
[0m[49m[38;5;10m+    175[0m:[38;5;10m[49m # and the SKU master. The default below is a placeholder used
[0m[49m[38;5;10m+    176[0m:[38;5;10m[49m # when the SKU master lookup is missing.
[0m[49m[38;5;10m+    177[0m:[38;5;10m[49m DEFAULT_LEAD_TIME_DAYS = 7
[0m[49m[38;5;10m+    178[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    179[0m:[38;5;10m[49m # --- Order Quantity Defaults ---
[0m[49m[38;5;10m+    180[0m:[38;5;10m[49m # A simple cycle-stock heuristic stand-in for full Economic Order
[0m[49m[38;5;10m+    181[0m:[38;5;10m[49m # Quantity (EOQ) calculations. Production uses real holding-cost
[0m[49m[38;5;10m+    182[0m:[38;5;10m[49m # and order-cost data per SKU.
[0m[49m[38;5;10m+    183[0m:[38;5;10m[49m DEFAULT_ORDER_CYCLE_DAYS = 14
[0m[49m[38;5;10m+    184[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    185[0m:[38;5;10m[49m # --- Synthetic Data ---
[0m[49m[38;5;10m+    186[0m:[38;5;10m[49m # Knobs for the demo's synthetic-consumption generator. The
[0m[49m[38;5;10m+    187[0m:[38;5;10m[49m # ranges produce a small but realistic-shaped portfolio across
[0m[49m[38;5;10m+    188[0m:[38;5;10m[49m # the four demand-pattern segments plus the procedure-driven
[0m[49m[38;5;10m+    189[0m:[38;5;10m[49m # branch.
[0m[49m[38;5;10m+    190[0m:[38;5;10m[49m SYNTHETIC_HISTORY_DAYS = 730     # two years of daily history
[0m[49m[38;5;10m+    191[0m:[38;5;10m[49m SYNTHETIC_FACILITY_ID  = "main-hospital-001"
[0m[49m[38;5;10m+    192[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    193[0m:[38;5;10m[49m # Deploy-time guardrail. Any blank resource name is a deploy-time
[0m[49m[38;5;10m+    194[0m:[38;5;10m[49m # bug, not a runtime surprise.
[0m[49m[38;5;10m+    195[0m:[38;5;10m[49m for _name, _value in [
[0m[49m[38;5;10m+    196[0m:[38;5;10m[49m     ("CONSUMPTION_HISTORY_BUCKET", CONSUMPTION_HISTORY_BUCKET),
[0m[49m[38;5;10m+    197[0m:[38;5;10m[49m     ("SKU_MASTER_BUCKET",          SKU_MASTER_BUCKET),
[0m[49m[38;5;10m+    198[0m:[38;5;10m[49m     ("MODEL_ARTIFACT_BUCKET",      MODEL_ARTIFACT_BUCKET),
[0m[49m[38;5;10m+    199[0m:[38;5;10m[49m     ("FORECAST_OUTPUT_BUCKET",     FORECAST_OUTPUT_BUCKET),
[0m[49m[38;5;10m+    200[0m:[38;5;10m[49m     ("SKU_FORECASTS_TABLE",        SKU_FORECASTS_TABLE),
[0m[49m[38;5;10m+    201[0m:[38;5;10m[49m     ("FORECAST_EVENT_BUS_NAME",    FORECAST_EVENT_BUS_NAME),
[0m[49m[38;5;10m+    202[0m:[38;5;10m[49m     ("CLOUDWATCH_NAMESPACE",       CLOUDWATCH_NAMESPACE),
[0m[49m[38;5;10m+    203[0m:[38;5;10m[49m ]:
[0m[49m[38;5;10m+    204[0m:[38;5;10m[49m     assert _value, f"{_name} must be set before deploying."
[0m[49m[38;5;10m+    205[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    206[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    207[0m:[38;5;10m[49m def _to_decimal(value):
[0m[49m[38;5;10m+    208[0m:[38;5;10m[49m     """Convert numeric values to Decimal for DynamoDB-safe writes.
[0m[49m[38;5;10m+    209[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    210[0m:[38;5;10m[49m     DynamoDB rejects Python float at the SDK boundary because
[0m[49m[38;5;10m+    211[0m:[38;5;10m[49m     floating-point cannot represent every decimal value exactly.
[0m[49m[38;5;10m+    212[0m:[38;5;10m[49m     Pass everything numeric through this helper before any
[0m[49m[38;5;10m+    213[0m:[38;5;10m[49m     PutItem, BatchWriteItem, or UpdateItem call. Pandas and
[0m[49m[38;5;10m+    214[0m:[38;5;10m[49m     numpy types are not Decimal-friendly out of the box, so the
[0m[49m[38;5;10m+    215[0m:[38;5;10m[49m     helper covers the common cases (int, float, str-of-number,
[0m[49m[38;5;10m+    216[0m:[38;5;10m[49m     None) and lets exotic types fail loudly rather than silently.
[0m[49m[38;5;10m+    217[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    218[0m:[38;5;10m[49m     if value is None:
[0m[49m[38;5;10m+    219[0m:[38;5;10m[49m         return None
[0m[49m[38;5;10m+    220[0m:[38;5;10m[49m     if isinstance(value, Decimal):
[0m[49m[38;5;10m+    221[0m:[38;5;10m[49m         return value
[0m[49m[38;5;10m+    222[0m:[38;5;10m[49m     if isinstance(value, bool):
[0m[49m[38;5;10m+    223[0m:[38;5;10m[49m         # bool is a subclass of int in Python; route it explicitly
[0m[49m[38;5;10m+    224[0m:[38;5;10m[49m         # so a True does not become Decimal('1') unexpectedly.
[0m[49m[38;5;10m+    225[0m:[38;5;10m[49m         return value
[0m[49m[38;5;10m+    226[0m:[38;5;10m[49m     if isinstance(value, (int, float)):
[0m[49m[38;5;10m+    227[0m:[38;5;10m[49m         # Round float through string to avoid the float->Decimal
[0m[49m[38;5;10m+    228[0m:[38;5;10m[49m         # repr surprise (Decimal(0.1) is not Decimal('0.1')).
[0m[49m[38;5;10m+    229[0m:[38;5;10m[49m         return Decimal(str(value))
[0m[49m[38;5;10m+    230[0m:[38;5;10m[49m     if isinstance(value, str):
[0m[49m[38;5;10m+    231[0m:[38;5;10m[49m         return Decimal(value)
[0m[49m[38;5;10m+    232[0m:[38;5;10m[49m     raise TypeError(f"Cannot convert {type(value).__name__} to Decimal")
[0m[49m[38;5;10m+    233[0m:[38;5;10m[49m ```
