[0m[49m[38;5;10m+    471[0m:[38;5;10m[49m             "holding_cost_per_unit": Decimal("18.50"),
[0m[49m[38;5;10m+    472[0m:[38;5;10m[49m             "order_cost":           Decimal("100.00"),
[0m[49m[38;5;10m+    473[0m:[38;5;10m[49m             "successor_sku_id":     None,
[0m[49m[38;5;10m+    474[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    475[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    476[0m:[38;5;10m[49m ```
