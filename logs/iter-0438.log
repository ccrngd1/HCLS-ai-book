[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m         noise     = rng.gauss(0, 5)
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m         qty       = max(0, int(base * weekend + noise))
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m         rows.append({
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m             "facility_id": SYNTHETIC_FACILITY_ID,
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m             "sku_id":      "GLOVE-NITRILE-MED-100CT",
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m             "date":        d.isoformat(),
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m             "quantity":    qty,
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m     # --- Erratic, smooth interval but variable size: IV solution ---
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m     # Daily demand but with spiky size due to inpatient surges.
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m     for i in range(SYNTHETIC_HISTORY_DAYS):
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m         d         = start_date + timedelta(days=i)
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m         base      = 30
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m         spike     = 25 if rng.random() < 0.10 else 0
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m         noise     = rng.gauss(0, 8)
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m         qty       = max(0, int(base + spike + noise))
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m         rows.append({
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m             "facility_id": SYNTHETIC_FACILITY_ID,
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m             "sku_id":      "IV-SOLUTION-NS-1L",
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m             "date":        d.isoformat(),
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m             "quantity":    qty,
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m     # --- Intermittent: niche surgical kit ---
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m     # Many zero days with small bursts, 2-3 cases per week.
