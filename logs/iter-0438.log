[0m[49m[38;5;10m+    259[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    260[0m:[38;5;10m[49m         def __enter__(self):
[0m[49m[38;5;10m+    261[0m:[38;5;10m[49m             return self
[0m[49m[38;5;10m+    262[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    263[0m:[38;5;10m[49m         def __exit__(self, *exc):
[0m[49m[38;5;10m+    264[0m:[38;5;10m[49m             return False
[0m[49m[38;5;10m+    265[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    266[0m:[38;5;10m[49m         def put_item(self, Item):
[0m[49m[38;5;10m+    267[0m:[38;5;10m[49m             pk = Item["facility_sku"]
