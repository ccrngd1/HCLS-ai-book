[0m[49m[38;5;10m+    246[0m:[38;5;10m[49m     mock supports the operations the demo calls: batch_writer,
[0m[49m[38;5;10m+    247[0m:[38;5;10m[49m     put_item, query, get_item. It is not a complete DynamoDB
[0m[49m[38;5;10m+    248[0m:[38;5;10m[49m     emulation; it covers what this pipeline needs.
[0m[49m[38;5;10m+    249[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    250[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    251[0m:[38;5;10m[49m     def __init__(self, name):
[0m[49m[38;5;10m+    252[0m:[38;5;10m[49m         self.name           = name
[0m[49m[38;5;10m+    253[0m:[38;5;10m[49m         self.items          = {}    # (pk, sk) -> item dict
[0m[49m[38;5;10m+    254[0m:[38;5;10m[49m         self.write_count    = 0
[0m[49m[38;5;10m+    255[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    256[0m:[38;5;10m[49m     class _BatchWriter:
[0m[49m[38;5;10m+    257[0m:[38;5;10m[49m         def __init__(self, table):
