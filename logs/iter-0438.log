[49m[38;5;10m+    479[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    480[0m:[38;5;10m[49m ## Step 1: Prepare Consumption Data
[0m[49m[38;5;10m+    481[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    482[0m:[38;5;10m[49m This step pulls the raw daily consumption rows, collapses them to one row per `(facility_id, sku_id, date)` triple, fills missing days with zero counts, applies the SKU master successor map, and attaches calendar features. In production this is a Glue ETL job (PySpark or Glue notebooks) reading partitioned Parquet from S3 and writing a modeling-ready Parquet output back to S3. The demo does the equivalent in plain Python over the synthetic rows so you can trace what each transform accomplishes.
[0m[49m[38;5;10m+    483[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    484[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    485[0m:[38;5;10m[49m def prepare_consumption_data(raw_rows, sku_master):
[0m[49m[38;5;10m+    486[0m:[38;5;10m[49m     """Step 1: Clean, fill gaps, reconcile successors, add features.
[0m[49m[38;5;10m+    487[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    488[0m:[38;5;10m[49m     See pseudocode Step 1 in the main recipe. The output is a list
[0m[49m[38;5;10m+    489[0m:[38;5;10m[49m     of rows, one per (facility_id, sku_id, date) triple, with
[0m[49m[38;5;10m+    490[0m:[38;5;10m[49m     quantity (zero-filled), calendar features (day_of_week,
[0m[49m[38;5;10m+    491[0m:[38;5;10m[49m     month, is_holiday placeholder), and a flag for procedure-
[0m[49m[38;5;10m+    492[0m:[38;5;10m[49m     driven SKUs that the segmentation step uses to override the
[0m[49m[38;5;10m+    493[0m:[38;5;10m[49m     quantitative classification.
[0m[49m[38;5;10m+    494[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    495[0m:[38;5;10m[49m     # 1a. Group raw transactions by (facility, sku, date) and sum.
[0m[49m[38;5;10m+    496[0m:[38;5;10m[49m     grouped = defaultdict(int)
[0m[49m[38;5;10m+    497[0m:[38;5;10m[49m     for row in raw_rows:
[0m[49m[38;5;10m+    498[0m:[38;5;10m[49m         key = (row["facility_id"], row["sku_id"], row["date"])
[0m[49m[38;5;10m+    499[0m:[38;5;10m[49m         grouped[key] += row["quantity"]
[0m[49m[38;5;10m+    500[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    501[0m:[38;5;10m[49m     # 1b. Determine the date range so we can fill gaps. A missing
[0m[49m[38;5;10m+    502[0m:[38;5;10m[49m     # day in the source extract is not the same as zero
[0m[49m[38;5;10m+    503[0m:[38;5;10m[49m     # consumption, but for forecasting purposes the safer
[0m[49m[38;5;10m+    504[0m:[38;5;10m[49m     # default is to assume the SKU was available and not used
[0m[49m[38;5;10m+    505[0m:[38;5;10m[49m     # rather than to leave a gap that the model interprets as
[0m[49m[38;5;10m+    506[0m:[38;5;10m[49m     # continuity. Production has a separate pipeline branch
[0m[49m[38;5;10m+    507[0m:[38;5;10m[49m     # that flags facility-wide outages (system downtime, holiday
[0m[49m[38;5;10m+    508[0m:[38;5;10m[49m     # closures) and excludes those days rather than zero-filling.
[0m[49m[38;5;10m+    509[0m:[38;5;10m[49m     all_dates = sorted({k[2] for k in grouped})
[0m[49m[38;5;10m+    510[0m:[38;5;10m[49m     if not all_dates:
[0m[49m[38;5;10m+    511[0m:[38;5;10m[49m         return []
[0m[49m[38;5;10m+    512[0m:[38;5;10m[49m     start_d = date.fromisoformat(all_dates[0])
[0m[49m[38;5;10m+    513[0m:[38;5;10m[49m     end_d   = date.fromisoformat(all_dates[-1])
[0m[49m[38;5;10m+    514[0m:[38;5;10m[49m     full_dates = [
[0m[49m[38;5;10m+    515[0m:[38;5;10m[49m         (start_d + timedelta(days=i)).isoformat()
[0m[49m[38;5;10m+    516[0m:[38;5;10m[49m         for i in range((end_d - start_d).days + 1)
[0m[49m[38;5;10m+    517[0m:[38;5;10m[49m     ]
[0m[49m[38;5;10m+    518[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    519[0m:[38;5;10m[49m     # 1c. Identify the (facility, sku) pairs we need to emit rows for.
[0m[49m[38;5;10m+    520[0m:[38;5;10m[49m     pairs = sorted({(k[0], k[1]) for k in grouped})
[0m[49m[38;5;10m+    521[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    522[0m:[38;5;10m[49m     # 1d. Build the cleaned, filled, feature-rich output.
[0m[49m[38;5;10m+    523[0m:[38;5;10m[49m     output = []
[0m[49m[38;5;10m+    524[0m:[38;5;10m[49m     for facility_id, sku_id in pairs:
[0m[49m[38;5;10m+    525[0m:[38;5;10m[49m         # Apply the SKU master successor map: if this SKU has been
[0m[49m[38;5;10m+    526[0m:[38;5;10m[49m         # superseded by a successor, attribute its history to the
[0m[49m[38;5;10m+    527[0m:[38;5;10m[49m         # successor so the new SKU has continuous history. The
[0m[49m[38;5;10m+    528[0m:[38;5;10m[49m         # demo SKUs have no successors; production routinely sees
[0m[49m[38;5;10m+    529[0m:[38;5;10m[49m         # 5-15% of the catalog change identifiers per year.
[0m[49m[38;5;10m+    530[0m:[38;5;10m[49m         master_entry        = sku_master.get(sku_id, {})
[0m[49m[38;5;10m+    531[0m:[38;5;10m[49m         successor_sku_id    = master_entry.get("successor_sku_id")
[0m[49m[38;5;10m+    532[0m:[38;5;10m[49m         target_sku_id       = successor_sku_id if successor_sku_id else sku_id
[0m[49m[38;5;10m+    533[0m:[38;5;10m[49m         is_procedure_driven = bool(master_entry.get("is_procedure_driven", False))
[0m[49m[38;5;10m+    534[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    535[0m:[38;5;10m[49m         for d_iso in full_dates:
[0m[49m[38;5;10m+    536[0m:[38;5;10m[49m             qty       = grouped.get((facility_id, sku_id, d_iso), 0)
[0m[49m[38;5;10m+    537[0m:[38;5;10m[49m             d         = date.fromisoformat(d_iso)
[0m[49m[38;5;10m+    538[0m:[38;5;10m[49m             output.append({
[0m[49m[38;5;10m+    539[0m:[38;5;10m[49m                 "facility_id":         facility_id,
[0m[49m[38;5;10m+    540[0m:[38;5;10m[49m                 "sku_id":              target_sku_id,
[0m[49m[38;5;10m+    541[0m:[38;5;10m[49m                 "date":                d_iso,
[0m[49m[38;5;10m+    542[0m:[38;5;10m[49m                 "quantity":            qty,
[0m[49m[38;5;10m+    543[0m:[38;5;10m[49m                 "day_of_week":         d.weekday(),
[0m[49m[38;5;10m+    544[0m:[38;5;10m[49m                 "month":               d.month,
[0m[49m[38;5;10m+    545[0m:[38;5;10m[49m                 "is_holiday":          False,   # production reads from a holiday calendar table
[0m[49m[38;5;10m+    546[0m:[38;5;10m[49m                 "is_procedure_driven": is_procedure_driven,
[0m[49m[38;5;10m+    547[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    548[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    549[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    550[0m:[38;5;10m[49m         "Prepared consumption data: %d rows across %d SKUs and %d days",
[0m[49m[38;5;10m+    551[0m:[38;5;10m[49m         len(output), len(pairs), len(full_dates))
[0m[49m[38;5;10m+    552[0m:[38;5;10m[49m     return output
[0m[49m[38;5;10m+    553[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    554[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    555[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    556[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    557[0m:[38;5;10m[49m ## Step 2: Segment SKUs by Demand Pattern
[0m[49m[38;5;10m+    558[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    559[0m:[38;5;10m[49m The Average Demand Interval (ADI) and the Coefficient of Variation Squared on non-zero demand sizes (CV²) classify each SKU into one of four corners: smooth, intermittent, erratic, lumpy. Procedure-driven SKUs flagged in the master data override the quantitative classification because their right model is the case-volume-times-usage two-stage approach regardless of how their historical demand looks.
[0m[49m[38;5;10m+    560[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    561[0m:[38;5;10m[49m ```python
[0m[49m[38;5;10m+    562[0m:[38;5;10m[49m def segment_skus(prepared_rows):
[0m[49m[38;5;10m+    563[0m:[38;5;10m[49m     """Step 2: Classify each SKU by demand pattern.
[0m[49m[38;5;10m+    564[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    565[0m:[38;5;10m[49m     Returns a mapping sku_id -> segment_label and a small
[0m[49m[38;5;10m+    566[0m:[38;5;10m[49m     diagnostics dict per SKU (adi, cv2, non_zero_count,
[0m[49m[38;5;10m+    567[0m:[38;5;10m[49m     total_days, mean_size). Production writes the segment
[0m[49m[38;5;10m+    568[0m:[38;5;10m[49m     assignments to a small DynamoDB table so downstream stages
[0m[49m[38;5;10m+    569[0m:[38;5;10m[49m     can read them without recomputing.
[0m[49m[38;5;10m+    570[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    571[0m:[38;5;10m[49m     by_sku = defaultdict(list)
[0m[49m[38;5;10m+    572[0m:[38;5;10m[49m     procedure_driven_skus = set()
[0m[49m[38;5;10m+    573[0m:[38;5;10m[49m     for row in prepared_rows:
[0m[49m[38;5;10m+    574[0m:[38;5;10m[49m         by_sku[row["sku_id"]].append(row)
[0m[49m[38;5;10m+    575[0m:[38;5;10m[49m         if row["is_procedure_driven"]:
[0m[49m[38;5;10m+    576[0m:[38;5;10m[49m             procedure_driven_skus.add(row["sku_id"])
[0m[49m[38;5;10m+    577[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    578[0m:[38;5;10m[49m     segments    = {}
[0m[49m[38;5;10m+    579[0m:[38;5;10m[49m     diagnostics = {}
[0m[49m[38;5;10m+    580[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    581[0m:[38;5;10m[49m     for sku_id, rows in by_sku.items():
[0m[49m[38;5;10m+    582[0m:[38;5;10m[49m         # Procedure-driven override: route to the two-stage model
[0m[49m[38;5;10m+    583[0m:[38;5;10m[49m         # regardless of the quantitative classification. The
[0m[49m[38;5;10m+    584[0m:[38;5;10m[49m         # historical demand pattern of an implant SKU often looks
[0m[49m[38;5;10m+    585[0m:[38;5;10m[49m         # erratic or lumpy, but its underlying signal is OR case
[0m[49m[38;5;10m+    586[0m:[38;5;10m[49m         # volume, which is far more stable.
[0m[49m[38;5;10m+    587[0m:[38;5;10m[49m         if sku_id in procedure_driven_skus:
[0m[49m[38;5;10m+    588[0m:[38;5;10m[49m             segments[sku_id] = "procedure_driven"
[0m[49m[38;5;10m+    589[0m:[38;5;10m[49m             diagnostics[sku_id] = {
[0m[49m[38;5;10m+    590[0m:[38;5;10m[49m                 "adi":            None,
[0m[49m[38;5;10m+    591[0m:[38;5;10m[49m                 "cv2":            None,
[0m[49m[38;5;10m+    592[0m:[38;5;10m[49m                 "total_days":     len(rows),
[0m[49m[38;5;10m+    593[0m:[38;5;10m[49m                 "non_zero_count": sum(1 for r in rows if r["quantity"] > 0),
[0m[49m[38;5;10m+    594[0m:[38;5;10m[49m                 "mean_size":      None,
[0m[49m[38;5;10m+    595[0m:[38;5;10m[49m                 "override_reason": "procedure_driven_flag_in_master",
[0m[49m[38;5;10m+    596[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    597[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    598[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    599[0m:[38;5;10m[49m         non_zero = [r["quantity"] for r in rows if r["quantity"] > 0]
[0m[49m[38;5;10m+    600[0m:[38;5;10m[49m         total_days     = len(rows)
[0m[49m[38;5;10m+    601[0m:[38;5;10m[49m         non_zero_count = len(non_zero)
[0m[49m[38;5;10m+    602[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    603[0m:[38;5;10m[49m         # If a SKU has fewer than ~12 non-zero observations we
[0m[49m[38;5;10m+    604[0m:[38;5;10m[49m         # cannot reliably classify it; route to "lumpy" as the
[0m[49m[38;5;10m+    605[0m:[38;5;10m[49m         # safest default (which uses category-level aggregation)
[0m[49m[38;5;10m+    606[0m:[38;5;10m[49m         # and let the master-data team flag it for review.
[0m[49m[38;5;10m+    607[0m:[38;5;10m[49m         if non_zero_count < 12:
[0m[49m[38;5;10m+    608[0m:[38;5;10m[49m             segments[sku_id] = "lumpy"
[0m[49m[38;5;10m+    609[0m:[38;5;10m[49m             diagnostics[sku_id] = {
[0m[49m[38;5;10m+    610[0m:[38;5;10m[49m                 "adi":            None,
[0m[49m[38;5;10m+    611[0m:[38;5;10m[49m                 "cv2":            None,
[0m[49m[38;5;10m+    612[0m:[38;5;10m[49m                 "total_days":     total_days,
[0m[49m[38;5;10m+    613[0m:[38;5;10m[49m                 "non_zero_count": non_zero_count,
[0m[49m[38;5;10m+    614[0m:[38;5;10m[49m                 "mean_size":      None,
[0m[49m[38;5;10m+    615[0m:[38;5;10m[49m                 "override_reason": "insufficient_non_zero_history",
[0m[49m[38;5;10m+    616[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    617[0m:[38;5;10m[49m             continue
[0m[49m[38;5;10m+    618[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    619[0m:[38;5;10m[49m         # Average Demand Interval: total days / count of non-zero days.
[0m[49m[38;5;10m+    620[0m:[38;5;10m[49m         adi = Decimal(total_days) / Decimal(non_zero_count)
[0m[49m[38;5;10m+    621[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    622[0m:[38;5;10m[49m         # Coefficient of Variation Squared on non-zero demand sizes.
[0m[49m[38;5;10m+    623[0m:[38;5;10m[49m         avg_size = mean(non_zero)
[0m[49m[38;5;10m+    624[0m:[38;5;10m[49m         if avg_size <= 0:
[0m[49m[38;5;10m+    625[0m:[38;5;10m[49m             cv2 = Decimal("0")
[0m[49m[38;5;10m+    626[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    627[0m:[38;5;10m[49m             sd_size = stdev(non_zero) if len(non_zero) > 1 else 0
[0m[49m[38;5;10m+    628[0m:[38;5;10m[49m             cv2     = Decimal(str((sd_size / avg_size) ** 2))
[0m[49m[38;5;10m+    629[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    630[0m:[38;5;10m[49m         # Standard four-corner classification.
[0m[49m[38;5;10m+    631[0m:[38;5;10m[49m         if   adi <  ADI_THRESHOLD and cv2 <  CV2_THRESHOLD: label = "smooth"
[0m[49m[38;5;10m+    632[0m:[38;5;10m[49m         elif adi >= ADI_THRESHOLD and cv2 <  CV2_THRESHOLD: label = "intermittent"
[0m[49m[38;5;10m+    633[0m:[38;5;10m[49m         elif adi <  ADI_THRESHOLD and cv2 >= CV2_THRESHOLD: label = "erratic"
[0m[49m[38;5;10m+    634[0m:[38;5;10m[49m         else:                                                label = "lumpy"
[0m[49m[38;5;10m+    635[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    636[0m:[38;5;10m[49m         segments[sku_id]    = label
[0m[49m[38;5;10m+    637[0m:[38;5;10m[49m         diagnostics[sku_id] = {
[0m[49m[38;5;10m+    638[0m:[38;5;10m[49m             "adi":            adi,
[0m[49m[38;5;10m+    639[0m:[38;5;10m[49m             "cv2":            cv2,
[0m[49m[38;5;10m+    640[0m:[38;5;10m[49m             "total_days":     total_days,
[0m[49m[38;5;10m+    641[0m:[38;5;10m[49m             "non_zero_count": non_zero_count,
[0m[49m[38;5;10m+    642[0m:[38;5;10m[49m             "mean_size":      _to_decimal(avg_size),
[0m[49m[38;5;10m+    643[0m:[38;5;10m[49m             "override_reason": None,
[0m[49m[38;5;10m+    644[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    645[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    646[0m:[38;5;10m[49m     logger.info(
[0m[49m[38;5;10m+    647[0m:[38;5;10m[49m         "Segmented %d SKUs: %s",
[0m[49m[38;5;10m+    648[0m:[38;5;10m[49m         len(segments),
[0m[49m[38;5;10m+    649[0m:[38;5;10m[49m         ", ".join(f"{seg}={n}" for seg, n in
[0m[49m[38;5;10m+    650[0m:[38;5;10m[49m                   sorted({(s, sum(1 for v in segments.values() if v == s))
[0m[49m[38;5;10m+    651[0m:[38;5;10m[49m                           for s in set(segments.values())})))
