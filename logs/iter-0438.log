[0m[49m[38;5;10m+    811[0m:[38;5;10m[49m         # demand because MAPE blows up on zero days.
[0m[49m[38;5;10m+    812[0m:[38;5;10m[49m         residuals = [q - self.daily_forecast for q in daily_quantities]
[0m[49m[38;5;10m+    813[0m:[38;5;10m[49m         if len(residuals) > 1:
[0m[49m[38;5;10m+    814[0m:[38;5;10m[49m             self.sigma = stdev(residuals)
[0m[49m[38;5;10m+    815[0m:[38;5;10m[49m         else:
[0m[49m[38;5;10m+    816[0m:[38;5;10m[49m             self.sigma = 0.0
[0m[49m[38;5;10m+    817[0m:[38;5;10m[49m         return self
[0m[49m[38;5;10m+    818[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    819[0m:[38;5;10m[49m     def predict_horizon(self, last_date_iso, horizon_days):
[0m[49m[38;5;10m+    820[0m:[38;5;10m[49m         last_d = date.fromisoformat(last_date_iso)
[0m[49m[38;5;10m+    821[0m:[38;5;10m[49m         return [
[0m[49m[38;5;10m+    822[0m:[38;5;10m[49m             {
[0m[49m[38;5;10m+    823[0m:[38;5;10m[49m                 "date":  (last_d + timedelta(days=h)).isoformat(),
[0m[49m[38;5;10m+    824[0m:[38;5;10m[49m                 "point": max(0.0, self.daily_forecast),
[0m[49m[38;5;10m+    825[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    826[0m:[38;5;10m[49m             for h in range(1, horizon_days + 1)
[0m[49m[38;5;10m+    827[0m:[38;5;10m[49m         ]
[0m[49m[38;5;10m+    828[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    829[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    830[0m:[38;5;10m[49m class ProcedureDrivenModel:
[0m[49m[38;5;10m+    831[0m:[38;5;10m[49m     """Two-stage forecast: case_volume * per-case usage rate.
[0m[49m[38;5;10m+    832[0m:[38;5;10m[49m 
