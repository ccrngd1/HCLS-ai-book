[0m[49m[38;5;10m+    316[0m:[38;5;10m[49m def generate_synthetic_consumption(seed=42):
[0m[49m[38;5;10m+    317[0m:[38;5;10m[49m     """Generate two years of daily SKU consumption with mixed shapes.
[0m[49m[38;5;10m+    318[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m     Real consumption history comes from the materials management
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m     ledger, the OR case-cart system, and the inpatient pharmacy
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m     system. The demo replaces that extract with a deterministic
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m     generator that produces five SKUs covering each demand
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m     segment, plus an OR case-volume series for the procedure-
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m     driven branch. Seeding makes the run reproducible.
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m     """
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m     rng       = random.Random(seed)
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m     end_date  = date(2026, 4, 14)
[0m[49m[38;5;10m+    328[0m:[38;5;10m[49m     start_date = end_date - timedelta(days=SYNTHETIC_HISTORY_DAYS - 1)
[0m[49m[38;5;10m+    329[0m:[38;5;10m[49m     rows      = []
[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m     # --- Smooth, high-volume: examination gloves ---
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m     # Steady weekday volume, lighter weekends, mild trend up.
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m     for i in range(SYNTHETIC_HISTORY_DAYS):
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m         d         = start_date + timedelta(days=i)
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m         dow       = d.weekday()
