[0m[49m[38;5;10m+    274[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    275[0m:[38;5;10m[49m     def put_item(self, Item):
[0m[49m[38;5;10m+    276[0m:[38;5;10m[49m         pk = Item["facility_sku"]
[0m[49m[38;5;10m+    277[0m:[38;5;10m[49m         sk = Item["generated_at"]
[0m[49m[38;5;10m+    278[0m:[38;5;10m[49m         self.items[(pk, sk)] = dict(Item)
[0m[49m[38;5;10m+    279[0m:[38;5;10m[49m         self.write_count += 1
