[0m[49m[38;5;10m+    1287[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    1288[0m:[38;5;10m[49m         caregivers: caregiver_records,
[0m[49m[38;5;10m+    1289[0m:[38;5;10m[49m         network: network_record,
