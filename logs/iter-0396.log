[0m[49m[38;5;10m+    1293[0m:[38;5;10m[49m                 network: network_record),
[0m[49m[38;5;10m+    1294[0m:[38;5;10m[49m         enrolled_at: now(),
[0m[49m[38;5;10m+    1295[0m:[38;5;10m[49m         active: true
