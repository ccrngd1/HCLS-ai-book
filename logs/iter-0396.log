[0m[49m[38;5;10m+    1232[0m:[38;5;10m[49m     // authentication, rate-limit handling, and
[0m[49m[38;5;10m+    1233[0m:[38;5;10m[49m     // provenance-tagging.
[0m[49m[38;5;10m+    1234[0m:[38;5;10m[49m     FOR clinician IN known_clinicians:
[0m[49m[38;5;10m+    1235[0m:[38;5;10m[49m         IF clinician.organization HAS_FHIR_PARTNERSHIP:
[0m[49m[38;5;10m+    1236[0m:[38;5;10m[49m             configure_fhir_adapter({
[0m[49m[38;5;10m+    1237[0m:[38;5;10m[49m                 patient_id: patient_id,
[0m[49m[38;5;10m+    1238[0m:[38;5;10m[49m                 organization: clinician.organization,
[0m[49m[38;5;10m+    1239[0m:[38;5;10m[49m                 ehr_identifier: clinician.ehr_identifier,
[0m[49m[38;5;10m+    1240[0m:[38;5;10m[49m                 fhir_endpoint:
