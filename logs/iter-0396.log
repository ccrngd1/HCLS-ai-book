[0m[49m[38;5;10m+    1604[0m:[38;5;10m[49m                 source: "care_coordination_assistant",
[0m[49m[38;5;10m+    1605[0m:[38;5;10m[49m                 detail_type: "seam_flag_detected",
[0m[49m[38;5;10m+    1606[0m:[38;5;10m[49m                 detail: seam_flag
[0m[49m[38;5;10m+    1607[0m:[38;5;10m[49m             }])
[0m[49m[38;5;10m+    1608[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1609[0m:[38;5;10m[49m     // Step 3C: route detected flags. Patient-
[0m[49m[38;5;10m+    1610[0m:[38;5;10m[49m     // resolvable flags go to the engagement scheduler
[0m[49m[38;5;10m+    1611[0m:[38;5;10m[49m     // for a care-event-triggered conversation. Care-
[0m[49m[38;5;10m+    1612[0m:[38;5;10m[49m     // team-resolvable flags go to the alert queue.
[0m[49m[38;5;10m+    1613[0m:[38;5;10m[49m     // Both-resolvable flags do both. Escalation-
[0m[49m[38;5;10m+    1614[0m:[38;5;10m[49m     // required flags trigger the escalation workflow.
[0m[49m[38;5;10m+    1615[0m:[38;5;10m[49m     FOR flag IN detected_flags:
