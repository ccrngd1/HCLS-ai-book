[0m[49m[38;5;10m+    1195[0m:[38;5;10m[49m             consent_to_caregiver_role: true,
[0m[49m[38;5;10m+    1196[0m:[38;5;10m[49m             consent_to_engagement: true,
[0m[49m[38;5;10m+    1197[0m:[38;5;10m[49m             registered_at: now(),
