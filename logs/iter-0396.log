[0m[49m[38;5;10m+    1191[0m:[38;5;10m[49m             preferred_channels:
[0m[49m[38;5;10m+    1192[0m:[38;5;10m[49m                 caregiver.preferred_channels,
[0m[49m[38;5;10m+    1193[0m:[38;5;10m[49m             quiet_hours: caregiver.quiet_hours,
