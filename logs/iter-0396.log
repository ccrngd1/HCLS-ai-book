[0m[49m[38;5;10m+    1279[0m:[38;5;10m[49m             language: legal_consent_form_signed.language,
[0m[49m[38;5;10m+    1280[0m:[38;5;10m[49m             preferred_channels:
[0m[49m[38;5;10m+    1281[0m:[38;5;10m[49m                 legal_consent_form_signed.channels,
[0m[49m[38;5;10m+    1282[0m:[38;5;10m[49m             quiet_hours:
[0m[49m[38;5;10m+    1283[0m:[38;5;10m[49m                 legal_consent_form_signed.quiet_hours,
[0m[49m[38;5;10m+    1284[0m:[38;5;10m[49m             engagement_intensity_preference:
