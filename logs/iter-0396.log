[0m[49m[38;5;10m+    1327[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    1328[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1329[0m:[38;5;10m[49m **Step 2: Ingest cross-organizational data with provenance discipline.** The integration layer is the architectural floor. Each adapter (HL7 listener, FHIR consumer, claims-feed processor, pharmacy-API consumer, vendor-API consumers) ingests data from its respective source, validates against schema and outlier rules, classifies sensitive-record categories, captures provenance metadata, deduplicates against existing entries, surfaces conflicts to the seam-detection layer, and updates derived views in the coordination state. Skip the provenance discipline and the coordination state becomes a source you cannot defend in audit; skip the deduplication and the assistant becomes a source of confusion.
[0m[49m[38;5;10m+    1330[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1331[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    1332[0m:[38;5;10m[49m ON ingest_message(source_type, raw_message):
[0m[49m[38;5;10m+    1333[0m:[38;5;10m[49m     // Step 2A: parse and validate the message per its
[0m[49m[38;5;10m+    1334[0m:[38;5;10m[49m     // source-type schema.
[0m[49m[38;5;10m+    1335[0m:[38;5;10m[49m     SWITCH source_type:
[0m[49m[38;5;10m+    1336[0m:[38;5;10m[49m         CASE "HL7_v2":
[0m[49m[38;5;10m+    1337[0m:[38;5;10m[49m             parsed = hl7_v2_parser.parse(raw_message)
[0m[49m[38;5;10m+    1338[0m:[38;5;10m[49m             schema_validation =
[0m[49m[38;5;10m+    1339[0m:[38;5;10m[49m                 hl7_v2_schema_validator.validate(parsed)
[0m[49m[38;5;10m+    1340[0m:[38;5;10m[49m         CASE "FHIR":
[0m[49m[38;5;10m+    1341[0m:[38;5;10m[49m             parsed = fhir_parser.parse(raw_message)
[0m[49m[38;5;10m+    1342[0m:[38;5;10m[49m             schema_validation =
[0m[49m[38;5;10m+    1343[0m:[38;5;10m[49m                 fhir_schema_validator.validate(parsed)
[0m[49m[38;5;10m+    1344[0m:[38;5;10m[49m         CASE "claims_feed":
[0m[49m[38;5;10m+    1345[0m:[38;5;10m[49m             parsed = claims_parser.parse(raw_message)
[0m[49m[38;5;10m+    1346[0m:[38;5;10m[49m             schema_validation =
[0m[49m[38;5;10m+    1347[0m:[38;5;10m[49m                 claims_schema_validator.validate(parsed)
[0m[49m[38;5;10m+    1348[0m:[38;5;10m[49m         CASE "pharmacy_api":
[0m[49m[38;5;10m+    1349[0m:[38;5;10m[49m             parsed = pharmacy_parser.parse(raw_message)
[0m[49m[38;5;10m+    1350[0m:[38;5;10m[49m             schema_validation =
[0m[49m[38;5;10m+    1351[0m:[38;5;10m[49m                 pharmacy_schema_validator.validate(parsed)
[0m[49m[38;5;10m+    1352[0m:[38;5;10m[49m         CASE "vendor_api":
[0m[49m[38;5;10m+    1353[0m:[38;5;10m[49m             parsed = vendor_parser.parse(raw_message)
[0m[49m[38;5;10m+    1354[0m:[38;5;10m[49m             schema_validation =
[0m[49m[38;5;10m+    1355[0m:[38;5;10m[49m                 vendor_schema_validator.validate(parsed)
[0m[49m[38;5;10m+    1356[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1357[0m:[38;5;10m[49m     IF NOT schema_validation.valid:
[0m[49m[38;5;10m+    1358[0m:[38;5;10m[49m         log_ingestion_failure({
[0m[49m[38;5;10m+    1359[0m:[38;5;10m[49m             source_type: source_type,
[0m[49m[38;5;10m+    1360[0m:[38;5;10m[49m             reason: schema_validation.reason,
[0m[49m[38;5;10m+    1361[0m:[38;5;10m[49m             raw_message_hash: hash(raw_message)
[0m[49m[38;5;10m+    1362[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    1363[0m:[38;5;10m[49m         return {action: "rejected"}
[0m[49m[38;5;10m+    1364[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1365[0m:[38;5;10m[49m     // Step 2B: identify the patient. Cross-
[0m[49m[38;5;10m+    1366[0m:[38;5;10m[49m     // organizational data carries different patient
[0m[49m[38;5;10m+    1367[0m:[38;5;10m[49m     // identifiers per source; patient matching is its
[0m[49m[38;5;10m+    1368[0m:[38;5;10m[49m     // own discipline (recipe 5.5 covers cross-facility
[0m[49m[38;5;10m+    1369[0m:[38;5;10m[49m     // patient matching).
[0m[49m[38;5;10m+    1370[0m:[38;5;10m[49m     patient_match = patient_matcher.match({
[0m[49m[38;5;10m+    1371[0m:[38;5;10m[49m         source_identifiers: parsed.identifiers,
[0m[49m[38;5;10m+    1372[0m:[38;5;10m[49m         source_type: source_type
[0m[49m[38;5;10m+    1373[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    1374[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1375[0m:[38;5;10m[49m     IF patient_match.confidence < MATCH_CONFIDENCE_FLOOR:
[0m[49m[38;5;10m+    1376[0m:[38;5;10m[49m         log_unmatched_message({
[0m[49m[38;5;10m+    1377[0m:[38;5;10m[49m             source_type: source_type,
[0m[49m[38;5;10m+    1378[0m:[38;5;10m[49m             parsed_identifiers: parsed.identifiers,
[0m[49m[38;5;10m+    1379[0m:[38;5;10m[49m             top_candidates:
[0m[49m[38;5;10m+    1380[0m:[38;5;10m[49m                 patient_match.top_candidates
[0m[49m[38;5;10m+    1381[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    1382[0m:[38;5;10m[49m         return {action: "queued_for_match_review"}
[0m[49m[38;5;10m+    1383[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1384[0m:[38;5;10m[49m     patient_id = patient_match.patient_id
[0m[49m[38;5;10m+    1385[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1386[0m:[38;5;10m[49m     // Step 2C: classify sensitive-record category. The
[0m[49m[38;5;10m+    1387[0m:[38;5;10m[49m     // classification gates downstream handling per
[0m[49m[38;5;10m+    1388[0m:[38;5;10m[49m     // patient consent and state law.
[0m[49m[38;5;10m+    1389[0m:[38;5;10m[49m     sensitive_category = classify_sensitive_category({
[0m[49m[38;5;10m+    1390[0m:[38;5;10m[49m         parsed: parsed,
[0m[49m[38;5;10m+    1391[0m:[38;5;10m[49m         source_type: source_type
[0m[49m[38;5;10m+    1392[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    1393[0m:[38;5;10m[49m         // none, mental_health, substance_use_42_cfr_2,
[0m[49m[38;5;10m+    1394[0m:[38;5;10m[49m         // hiv, genetic, adolescent_confidential
[0m[49m[38;5;10m+    1395[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1396[0m:[38;5;10m[49m     IF sensitive_category != "none":
[0m[49m[38;5;10m+    1397[0m:[38;5;10m[49m         consent_check = consent_record_table
[0m[49m[38;5;10m+    1398[0m:[38;5;10m[49m             .check_sensitive_category_consent({
[0m[49m[38;5;10m+    1399[0m:[38;5;10m[49m                 patient_id: patient_id,
[0m[49m[38;5;10m+    1400[0m:[38;5;10m[49m                 sensitive_category: sensitive_category
[0m[49m[38;5;10m+    1401[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    1402[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1403[0m:[38;5;10m[49m         IF NOT consent_check.consented:
[0m[49m[38;5;10m+    1404[0m:[38;5;10m[49m             // Per state law and patient preference,
[0m[49m[38;5;10m+    1405[0m:[38;5;10m[49m             // the data may not be ingestible. Log the
[0m[49m[38;5;10m+    1406[0m:[38;5;10m[49m             // received-and-not-ingested event for
[0m[49m[38;5;10m+    1407[0m:[38;5;10m[49m             // Information Blocking compliance, but
[0m[49m[38;5;10m+    1408[0m:[38;5;10m[49m             // do not persist to the coordination
[0m[49m[38;5;10m+    1409[0m:[38;5;10m[49m             // state.
[0m[49m[38;5;10m+    1410[0m:[38;5;10m[49m             log_consent_excluded_message({
[0m[49m[38;5;10m+    1411[0m:[38;5;10m[49m                 source_type: source_type,
[0m[49m[38;5;10m+    1412[0m:[38;5;10m[49m                 patient_id: patient_id,
[0m[49m[38;5;10m+    1413[0m:[38;5;10m[49m                 sensitive_category: sensitive_category
[0m[49m[38;5;10m+    1414[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    1415[0m:[38;5;10m[49m             return {action: "excluded_per_consent"}
[0m[49m[38;5;10m+    1416[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1417[0m:[38;5;10m[49m     // Step 2D: capture provenance metadata.
[0m[49m[38;5;10m+    1418[0m:[38;5;10m[49m     provenance_record = {
[0m[49m[38;5;10m+    1419[0m:[38;5;10m[49m         provenance_id: generate_provenance_id(),
[0m[49m[38;5;10m+    1420[0m:[38;5;10m[49m         patient_id: patient_id,
[0m[49m[38;5;10m+    1421[0m:[38;5;10m[49m         source_type: source_type,
[0m[49m[38;5;10m+    1422[0m:[38;5;10m[49m         source_organization:
[0m[49m[38;5;10m+    1423[0m:[38;5;10m[49m             parsed.source_organization_identifier,
[0m[49m[38;5;10m+    1424[0m:[38;5;10m[49m         source_message_id: parsed.message_id,
[0m[49m[38;5;10m+    1425[0m:[38;5;10m[49m         source_timestamp: parsed.source_timestamp,
[0m[49m[38;5;10m+    1426[0m:[38;5;10m[49m         ingested_at: now(),
[0m[49m[38;5;10m+    1427[0m:[38;5;10m[49m         ingestion_path: detect_ingestion_path(),
[0m[49m[38;5;10m+    1428[0m:[38;5;10m[49m             // HL7 listener, FHIR polling, FHIR
[0m[49m[38;5;10m+    1429[0m:[38;5;10m[49m             // subscription, claims batch, pharmacy
[0m[49m[38;5;10m+    1430[0m:[38;5;10m[49m             // API call, vendor API call
[0m[49m[38;5;10m+    1431[0m:[38;5;10m[49m         transformation_history: [],
[0m[49m[38;5;10m+    1432[0m:[38;5;10m[49m         integrity_hash: hash(parsed),
[0m[49m[38;5;10m+    1433[0m:[38;5;10m[49m         sensitive_category: sensitive_category
[0m[49m[38;5;10m+    1434[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1435[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1436[0m:[38;5;10m[49m     provenance_journal_table.write(provenance_record)
[0m[49m[38;5;10m+    1437[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1438[0m:[38;5;10m[49m     // Step 2E: map source data to the coordination
[0m[49m[38;5;10m+    1439[0m:[38;5;10m[49m     // state schema. Each source-type has its own
[0m[49m[38;5;10m+    1440[0m:[38;5;10m[49m     // mapper. FHIR mappers preserve resource type;
[0m[49m[38;5;10m+    1441[0m:[38;5;10m[49m     // HL7 mappers convert to FHIR-equivalent shapes;
[0m[49m[38;5;10m+    1442[0m:[38;5;10m[49m     // pharmacy mappers normalize medication naming
[0m[49m[38;5;10m+    1443[0m:[38;5;10m[49m     // and dosing; claims mappers extract encounter
[0m[49m[38;5;10m+    1444[0m:[38;5;10m[49m     // and service-utilization signals.
[0m[49m[38;5;10m+    1445[0m:[38;5;10m[49m     mapped_entries = mapper_for(source_type).map({
[0m[49m[38;5;10m+    1446[0m:[38;5;10m[49m         parsed: parsed,
[0m[49m[38;5;10m+    1447[0m:[38;5;10m[49m         provenance_record: provenance_record
[0m[49m[38;5;10m+    1448[0m:[38;5;10m[49m     })
[0m[49m[38;5;10m+    1449[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1450[0m:[38;5;10m[49m     // Step 2F: deduplicate against the existing
[0m[49m[38;5;10m+    1451[0m:[38;5;10m[49m     // coordination state. Cross-organizational data
[0m[49m[38;5;10m+    1452[0m:[38;5;10m[49m     // frequently contains the same encounter
[0m[49m[38;5;10m+    1453[0m:[38;5;10m[49m     // reported by multiple sources (the hospital
[0m[49m[38;5;10m+    1454[0m:[38;5;10m[49m     // ADT plus the HIE feed plus the payer claims
[0m[49m[38;5;10m+    1455[0m:[38;5;10m[49m     // feed all describe the same admission).
[0m[49m[38;5;10m+    1456[0m:[38;5;10m[49m     FOR mapped_entry IN mapped_entries:
[0m[49m[38;5;10m+    1457[0m:[38;5;10m[49m         existing = coordination_state_table
[0m[49m[38;5;10m+    1458[0m:[38;5;10m[49m             .find_matching_entry({
[0m[49m[38;5;10m+    1459[0m:[38;5;10m[49m                 patient_id: patient_id,
[0m[49m[38;5;10m+    1460[0m:[38;5;10m[49m                 entry_type: mapped_entry.entry_type,
[0m[49m[38;5;10m+    1461[0m:[38;5;10m[49m                 match_keys: mapped_entry.match_keys
[0m[49m[38;5;10m+    1462[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    1463[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1464[0m:[38;5;10m[49m         IF existing:
[0m[49m[38;5;10m+    1465[0m:[38;5;10m[49m             merge_result = merger_for(
[0m[49m[38;5;10m+    1466[0m:[38;5;10m[49m                 mapped_entry.entry_type
[0m[49m[38;5;10m+    1467[0m:[38;5;10m[49m             ).merge({
