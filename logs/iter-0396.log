[0m[49m[38;5;10m+    1215[0m:[38;5;10m[49m             // each: pharmacy_chain_or_independent,
[0m[49m[38;5;10m+    1216[0m:[38;5;10m[49m             // pharmacy_npi, ncpdp_id, mail_order,
[0m[49m[38;5;10m+    1217[0m:[38;5;10m[49m             // pharmacy_api_partnership
[0m[49m[38;5;10m+    1218[0m:[38;5;10m[49m         payers: known_payers,
[0m[49m[38;5;10m+    1219[0m:[38;5;10m[49m             // each: payer_name, plan_id, claims_feed_
[0m[49m[38;5;10m+    1220[0m:[38;5;10m[49m             // available, value_based_contract
[0m[49m[38;5;10m+    1221[0m:[38;5;10m[49m         ancillary_services: known_ancillary_services,
