[0m[49m[38;5;10m+    1097[0m:[38;5;10m[49m             // typically: patients in active inpatient or
[0m[49m[38;5;10m+    1098[0m:[38;5;10m[49m             // residential care without a clear post-
[0m[49m[38;5;10m+    1099[0m:[38;5;10m[49m             // discharge plan; patients without any
[0m[49m[38;5;10m+    1100[0m:[38;5;10m[49m             // verifiable clinical relationships; minors
[0m[49m[38;5;10m+    1101[0m:[38;5;10m[49m             // (in adult-only deployments); patients in
[0m[49m[38;5;10m+    1102[0m:[38;5;10m[49m             // populations the institution has not yet
[0m[49m[38;5;10m+    1103[0m:[38;5;10m[49m             // built protocol coverage for
[0m[49m[38;5;10m+    1104[0m:[38;5;10m[49m     })
