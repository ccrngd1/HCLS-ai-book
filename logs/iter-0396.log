[0m[49m[38;5;10m+    1246[0m:[38;5;10m[49m                 patient_id: patient_id,
[0m[49m[38;5;10m+    1247[0m:[38;5;10m[49m                 organization: clinician.organization,
[0m[49m[38;5;10m+    1248[0m:[38;5;10m[49m                 hie_endpoint: hie_registry.get(
[0m[49m[38;5;10m+    1249[0m:[38;5;10m[49m                     clinician.organization)
[0m[49m[38;5;10m+    1250[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    1251[0m:[38;5;10m[49m         ELSE:
[0m[49m[38;5;10m+    1252[0m:[38;5;10m[49m             log_integration_gap({
[0m[49m[38;5;10m+    1253[0m:[38;5;10m[49m                 patient_id: patient_id,
[0m[49m[38;5;10m+    1254[0m:[38;5;10m[49m                 organization: clinician.organization,
[0m[49m[38;5;10m+    1255[0m:[38;5;10m[49m                 reason: "no_partnership_available",
[0m[49m[38;5;10m+    1256[0m:[38;5;10m[49m                 fallback: "patient_caregiver_reported"
[0m[49m[38;5;10m+    1257[0m:[38;5;10m[49m             })
[0m[49m[38;5;10m+    1258[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1259[0m:[38;5;10m[49m     // Step 1F: initialize the longitudinal coordination
[0m[49m[38;5;10m+    1260[0m:[38;5;10m[49m     // state.
[0m[49m[38;5;10m+    1261[0m:[38;5;10m[49m     coordination_state = {
[0m[49m[38;5;10m+    1262[0m:[38;5;10m[49m         patient_id: patient_id,
[0m[49m[38;5;10m+    1263[0m:[38;5;10m[49m         target_population_segment:
[0m[49m[38;5;10m+    1264[0m:[38;5;10m[49m             target_population_segment,
[0m[49m[38;5;10m+    1265[0m:[38;5;10m[49m         consent_id: consent_record.consent_id,
[0m[49m[38;5;10m+    1266[0m:[38;5;10m[49m         active_conditions: [],
[0m[49m[38;5;10m+    1267[0m:[38;5;10m[49m         active_medications: [],
[0m[49m[38;5;10m+    1268[0m:[38;5;10m[49m         open_referrals: [],
[0m[49m[38;5;10m+    1269[0m:[38;5;10m[49m         upcoming_encounters: [],
[0m[49m[38;5;10m+    1270[0m:[38;5;10m[49m         recent_encounters: [],
