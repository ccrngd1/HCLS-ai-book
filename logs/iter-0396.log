[0m[49m[38;5;10m+    1551[0m:[38;5;10m[49m     state = coordination_state_table.get(
[0m[49m[38;5;10m+    1552[0m:[38;5;10m[49m         patient_id: patient_id)
[0m[49m[38;5;10m+    1553[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1554[0m:[38;5;10m[49m     // Step 3B: evaluate each applicable rule.
[0m[49m[38;5;10m+    1555[0m:[38;5;10m[49m     applicable_rules =
[0m[49m[38;5;10m+    1556[0m:[38;5;10m[49m         seam_detection_rule_registry
[0m[49m[38;5;10m+    1557[0m:[38;5;10m[49m             .applicable_rules(
[0m[49m[38;5;10m+    1558[0m:[38;5;10m[49m                 change_event_type:
[0m[49m[38;5;10m+    1559[0m:[38;5;10m[49m                     change_event.event_type,
[0m[49m[38;5;10m+    1560[0m:[38;5;10m[49m                 patient_segment:
[0m[49m[38;5;10m+    1561[0m:[38;5;10m[49m                     state.target_population_segment,
[0m[49m[38;5;10m+    1562[0m:[38;5;10m[49m                 conditions: state.active_conditions)
[0m[49m[38;5;10m+    1563[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1564[0m:[38;5;10m[49m     detected_flags = []
[0m[49m[38;5;10m+    1565[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1566[0m:[38;5;10m[49m     FOR rule IN applicable_rules:
[0m[49m[38;5;10m+    1567[0m:[38;5;10m[49m         rule_result = rule.evaluate({
[0m[49m[38;5;10m+    1568[0m:[38;5;10m[49m             state: state,
[0m[49m[38;5;10m+    1569[0m:[38;5;10m[49m             change_event: change_event,
[0m[49m[38;5;10m+    1570[0m:[38;5;10m[49m             rule_version: rule.version,
[0m[49m[38;5;10m+    1571[0m:[38;5;10m[49m             rule_effective_date: rule.effective_date
[0m[49m[38;5;10m+    1572[0m:[38;5;10m[49m         })
[0m[49m[38;5;10m+    1573[0m:[38;5;10m[49m 
