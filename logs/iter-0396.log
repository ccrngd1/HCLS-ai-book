[0m[49m[38;5;10m+    1630[0m:[38;5;10m[49m                     seam_flag_id: flag.seam_flag_id,
[0m[49m[38;5;10m+    1631[0m:[38;5;10m[49m                     alert_type: flag.flag_type,
[0m[49m[38;5;10m+    1632[0m:[38;5;10m[49m                     priority: flag.severity,
