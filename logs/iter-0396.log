[0m[49m[38;5;10m+    1111[0m:[38;5;10m[49m         }
[0m[49m[38;5;10m+    1112[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1113[0m:[38;5;10m[49m     // Step 1B: capture coordination-specific consent.
[0m[49m[38;5;10m+    1114[0m:[38;5;10m[49m     // Generic terms-of-service is not sufficient. The
[0m[49m[38;5;10m+    1115[0m:[38;5;10m[49m     // consent flow covers the assistant's nature (a
[0m[49m[38;5;10m+    1116[0m:[38;5;10m[49m     // coordination tool, not a person, not a clinician),
[0m[49m[38;5;10m+    1117[0m:[38;5;10m[49m     // the cross-organizational data-sharing scope, the
[0m[49m[38;5;10m+    1118[0m:[38;5;10m[49m     // caregiver-access posture, the state-specific
[0m[49m[38;5;10m+    1119[0m:[38;5;10m[49m     // privacy provisions, the escalation pathway, and
[0m[49m[38;5;10m+    1120[0m:[38;5;10m[49m     // the data-retention posture.
[0m[49m[38;5;10m+    1121[0m:[38;5;10m[49m     state_specific_consent = state_consent_registry.get(
[0m[49m[38;5;10m+    1122[0m:[38;5;10m[49m         state: state_of_residence)
[0m[49m[38;5;10m+    1123[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1124[0m:[38;5;10m[49m     consent_record = {
[0m[49m[38;5;10m+    1125[0m:[38;5;10m[49m         patient_id: patient_id,
[0m[49m[38;5;10m+    1126[0m:[38;5;10m[49m         consent_id: generate_consent_id(),
[0m[49m[38;5;10m+    1127[0m:[38;5;10m[49m         consent_version: state_specific_consent.version,
[0m[49m[38;5;10m+    1128[0m:[38;5;10m[49m         nature_disclosure_acknowledged: true,
[0m[49m[38;5;10m+    1129[0m:[38;5;10m[49m         scope_disclosure_acknowledged: true,
[0m[49m[38;5;10m+    1130[0m:[38;5;10m[49m         cross_organization_sharing_disclosure_acknowledged:
[0m[49m[38;5;10m+    1131[0m:[38;5;10m[49m             true,
[0m[49m[38;5;10m+    1132[0m:[38;5;10m[49m         caregiver_access_disclosure_acknowledged: true,
[0m[49m[38;5;10m+    1133[0m:[38;5;10m[49m         privacy_disclosure_acknowledged: true,
[0m[49m[38;5;10m+    1134[0m:[38;5;10m[49m         escalation_pathway_disclosure_acknowledged: true,
[0m[49m[38;5;10m+    1135[0m:[38;5;10m[49m         sensitive_category_disclosures: {
[0m[49m[38;5;10m+    1136[0m:[38;5;10m[49m             mental_health_records:
[0m[49m[38;5;10m+    1137[0m:[38;5;10m[49m                 legal_consent_form_signed
[0m[49m[38;5;10m+    1138[0m:[38;5;10m[49m                     .mental_health_sharing,
[0m[49m[38;5;10m+    1139[0m:[38;5;10m[49m             substance_use_records_42_cfr_part_2:
[0m[49m[38;5;10m+    1140[0m:[38;5;10m[49m                 legal_consent_form_signed
[0m[49m[38;5;10m+    1141[0m:[38;5;10m[49m                     .substance_use_sharing,
[0m[49m[38;5;10m+    1142[0m:[38;5;10m[49m             hiv_records:
[0m[49m[38;5;10m+    1143[0m:[38;5;10m[49m                 legal_consent_form_signed
[0m[49m[38;5;10m+    1144[0m:[38;5;10m[49m                     .hiv_record_sharing,
[0m[49m[38;5;10m+    1145[0m:[38;5;10m[49m             genetic_test_results:
[0m[49m[38;5;10m+    1146[0m:[38;5;10m[49m                 legal_consent_form_signed
[0m[49m[38;5;10m+    1147[0m:[38;5;10m[49m                     .genetic_record_sharing,
[0m[49m[38;5;10m+    1148[0m:[38;5;10m[49m             adolescent_confidential_records:
[0m[49m[38;5;10m+    1149[0m:[38;5;10m[49m                 legal_consent_form_signed
[0m[49m[38;5;10m+    1150[0m:[38;5;10m[49m                     .adolescent_confidential_sharing
[0m[49m[38;5;10m+    1151[0m:[38;5;10m[49m         },
[0m[49m[38;5;10m+    1152[0m:[38;5;10m[49m         retention_policy_acknowledged: true,
[0m[49m[38;5;10m+    1153[0m:[38;5;10m[49m         signed_at: now(),
[0m[49m[38;5;10m+    1154[0m:[38;5;10m[49m         state_of_residence: state_of_residence,
[0m[49m[38;5;10m+    1155[0m:[38;5;10m[49m         state_specific_provisions:
[0m[49m[38;5;10m+    1156[0m:[38;5;10m[49m             state_specific_consent.provisions
[0m[49m[38;5;10m+    1157[0m:[38;5;10m[49m     }
[0m[49m[38;5;10m+    1158[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1159[0m:[38;5;10m[49m     consent_record_table.write(consent_record)
[0m[49m[38;5;10m+    1160[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    1161[0m:[38;5;10m[49m     // Step 1C: register caregivers as first-class
[0m[49m[38;5;10m+    1162[0m:[38;5;10m[49m     // identities with proxy-access scope. Each
[0m[49m[38;5;10m+    1163[0m:[38;5;10m[49m     // caregiver gets their own identity, their own
[0m[49m[38;5;10m+    1164[0m:[38;5;10m[49m     // authentication path, and their own access scope
[0m[49m[38;5;10m+    1165[0m:[38;5;10m[49m     // calibrated to the patient's preference and state
[0m[49m[38;5;10m+    1166[0m:[38;5;10m[49m     // law.
[0m[49m[38;5;10m+    1167[0m:[38;5;10m[49m     caregiver_records = []
[0m[49m[38;5;10m+    1168[0m:[38;5;10m[49m     FOR caregiver IN caregiver_designations:
