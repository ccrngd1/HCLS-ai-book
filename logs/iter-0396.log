[0m[49m[38;5;10m+    1211[0m:[38;5;10m[49m             // each: organization, role, primary_contact,
[0m[49m[38;5;10m+    1212[0m:[38;5;10m[49m             // ehr_identifier (where known), is_primary
[0m[49m[38;5;10m+    1213[0m:[38;5;10m[49m             // (PCP indicator), specialty
