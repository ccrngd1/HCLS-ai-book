[0m[49m[38;5;10m+    1173[0m:[38;5;10m[49m             legal_authority: caregiver.legal_authority,
[0m[49m[38;5;10m+    1174[0m:[38;5;10m[49m                 // healthcare_proxy, durable_power_of_
[0m[49m[38;5;10m+    1175[0m:[38;5;10m[49m                 // attorney, parent_of_minor, guardian,
[0m[49m[38;5;10m+    1176[0m:[38;5;10m[49m                 // family_member_with_consent
[0m[49m[38;5;10m+    1177[0m:[38;5;10m[49m             scope: caregiver.access_scope,
[0m[49m[38;5;10m+    1178[0m:[38;5;10m[49m                 // full_coordination_state, restricted_
[0m[49m[38;5;10m+    1179[0m:[38;5;10m[49m                 // coordination_state (some categories
[0m[49m[38;5;10m+    1180[0m:[38;5;10m[49m                 // withheld per patient preference),
[0m[49m[38;5;10m+    1181[0m:[38;5;10m[49m                 // crisis_only, schedule_only
[0m[49m[38;5;10m+    1182[0m:[38;5;10m[49m             sensitive_category_access:
[0m[49m[38;5;10m+    1183[0m:[38;5;10m[49m                 caregiver.sensitive_category_access,
[0m[49m[38;5;10m+    1184[0m:[38;5;10m[49m                 // per state law and patient preference,
[0m[49m[38;5;10m+    1185[0m:[38;5;10m[49m                 // sensitive categories may be excluded
[0m[49m[38;5;10m+    1186[0m:[38;5;10m[49m                 // from caregiver access
[0m[49m[38;5;10m+    1187[0m:[38;5;10m[49m             authentication_method:
