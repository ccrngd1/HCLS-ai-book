[0m[49m[38;5;10m+    1206[0m:[38;5;10m[49m     // payer, and ancillary service is a potential data
[0m[49m[38;5;10m+    1207[0m:[38;5;10m[49m     // source.
[0m[49m[38;5;10m+    1208[0m:[38;5;10m[49m     network_record = {
