[0m[49m[38;5;10m+    1599[0m:[38;5;10m[49m             }
[0m[49m[38;5;10m+    1600[0m:[38;5;10m[49m             seam_flags_registry.write(seam_flag)
[0m[49m[38;5;10m+    1601[0m:[38;5;10m[49m             detected_flags.append(seam_flag)
[0m[49m[38;5;10m+    1602[0m:[38;5;10m[49m 
