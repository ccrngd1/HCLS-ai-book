[0m[49m[38;5;10m+    1304[0m:[38;5;10m[49m         detail_type: "patient_enrolled",
[0m[49m[38;5;10m+    1305[0m:[38;5;10m[49m         detail: {
[0m[49m[38;5;10m+    1306[0m:[38;5;10m[49m             patient_id: patient_id,
[0m[49m[38;5;10m+    1307[0m:[38;5;10m[49m             target_population_segment:
