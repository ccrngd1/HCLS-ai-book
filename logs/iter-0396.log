[0m[49m[38;5;10m+    1086[0m:[38;5;10m[49m                   known_pharmacies,
[0m[49m[38;5;10m+    1087[0m:[38;5;10m[49m                   known_payers,
[0m[49m[38;5;10m+    1088[0m:[38;5;10m[49m                   known_ancillary_services):
[0m[49m[38;5;10m+    1089[0m:[38;5;10m[49m     // Step 1A: validate the patient is eligible for the
[0m[49m[38;5;10m+    1090[0m:[38;5;10m[49m     // institution's deployment scope.
[0m[49m[38;5;10m+    1091[0m:[38;5;10m[49m     eligibility = check_eligibility({
[0m[49m[38;5;10m+    1092[0m:[38;5;10m[49m         patient_id: patient_id,
